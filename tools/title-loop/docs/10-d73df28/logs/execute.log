{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01B9y28S2tgsuBdBBnpYDS85","type":"tool_result","content":"    40→ * Patterns that identify recipe metadata lines (not titles)\n    41→ */\n    42→const METADATA_PATTERNS = [\n    43→  /^(SERVES?|MAKES?|YIELDS?)\\b/i,\n    44→  /^(PREP(ARATION)?|COOK(ING)?|PROOF|RISING|FERMENTATION|REST(ING)?)\\s*(AND\\s*)?(COOK(ING)?)?\\s*TIME/i,\n    45→  /^SAMPLE\\s+SCHEDULE\\b/i,\n    46→  /^BULK\\s+FERMENTATION\\b/i,\n    47→  /^(THIS\\s+RECIPE\\s+)?MAKES\\b/i,\n    48→  // Polish serving-size patterns: \"NA 3 PAPRYKI\", \"NA OKOŁO 1 KG\", \"DLA 4 OSÓB\"\n    49→  /^NA\\s+(\\d|OKOŁO)\\b/i,\n    50→  /^DLA\\s+\\d/i,\n    51→  // Time-unit metadata: any line containing \"N MIN\" or \"N GODZ\" is prep/cook/rest time,\n    52→  // regardless of OCR-corrupted prefix (catches PRZYGOTOWANTE, GOTOMANTE, etc.)\n    53→  /\\b\\d+\\s*MIN\\b/i,\n    54→  /\\b\\d+\\s*GODZ/i,\n    55→];\n    56→\n    57→/**\n    58→ * Single-word non-title words — standalone OCR fragments unlikely to be recipe titles\n    59→ */\n    60→const NON_TITLE_WORDS = new Set([\n    61→  \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"are\", \"was\",\n    62→  \"has\", \"his\", \"her\", \"its\", \"our\", \"who\", \"how\", \"may\", \"new\", \"now\",\n    63→  \"old\", \"see\", \"way\", \"did\", \"get\", \"let\", \"say\", \"she\", \"too\", \"use\",\n    64→  \"buns\", \"with\",\n    65→]);\n    66→\n    67→function looksLikeIngredient(line: string): boolean {\n    68→  const lowerLine = line.toLowerCase();\n    69→  return MEASUREMENT_PATTERNS.some((pattern) => lowerLine.includes(pattern));\n    70→}\n    71→\n    72→function startsWithNumber(line: string): boolean {\n    73→  return /^\\s*\\d/.test(line);\n    74→}\n    75→\n    76→function isAllCaps(line: string): boolean {\n    77→  const letters = line.replace(/[^a-zA-Z]/g, \"\");\n    78→  return letters.length > 0 && letters === letters.toUpperCase();\n    79→}\n    80→\n    81→function looksLikeMetadata(text: string): boolean {\n    82→  return METADATA_PATTERNS.some((pattern) => pattern.test(text.trim()));\n    83→}\n    84→\n    85→function isLikelyGarbled(text: string): boolean {\n    86→  const letters = text.replace(/[^a-zA-Z]/g, \"\");\n    87→  if (letters.length < 2) return true;\n    88→\n    89→  // Check vowel ratio — English/Polish text typically has 30–50% vowels\n    90→  const vowels = letters.replace(/[^aeiouAEIOUyYąęóĄĘÓ]/g, \"\").length;\n    91→  const vowelRatio = vowels / letters.length;\n    92→  if (vowelRatio < 0.15 || vowelRatio > 0.85) return true;\n    93→\n    94→  // Single orphaned word ≤3 letters that isn't a common word\n    95→  const words = text.trim().split(/\\s+/);\n    96→  const COMMON_SHORT = new Set([\n    97→    \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"had\", \"her\",\n    98→    \"was\", \"one\", \"our\", \"out\", \"are\", \"has\", \"his\", \"how\", \"its\", \"may\",\n    99→    \"new\", \"now\", \"old\", \"see\", \"way\", \"who\", \"did\", \"get\", \"let\", \"say\",\n   100→    \"she\", \"too\", \"use\",\n   101→  ]);\n   102→  if (words.length === 1 && letters.length <= 3 && !COMMON_SHORT.has(text.trim().toLowerCase())) {\n   103→    return true;\n   104→  }\n   105→\n   106→  // Recipe titles never start with a lowercase letter\n   107→  if (/^[a-z]/.test(text.trim())) {\n   108→    return true;\n   109→  }\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"84856199-2e39-4e5f-88ee-7f061b951e03","uuid":"6fc4b298-2fa4-42a5-8b83-19e80a3a6b6a","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/title-extractor.ts","content":" * Patterns that identify recipe metadata lines (not titles)\n */\nconst METADATA_PATTERNS = [\n  /^(SERVES?|MAKES?|YIELDS?)\\b/i,\n  /^(PREP(ARATION)?|COOK(ING)?|PROOF|RISING|FERMENTATION|REST(ING)?)\\s*(AND\\s*)?(COOK(ING)?)?\\s*TIME/i,\n  /^SAMPLE\\s+SCHEDULE\\b/i,\n  /^BULK\\s+FERMENTATION\\b/i,\n  /^(THIS\\s+RECIPE\\s+)?MAKES\\b/i,\n  // Polish serving-size patterns: \"NA 3 PAPRYKI\", \"NA OKOŁO 1 KG\", \"DLA 4 OSÓB\"\n  /^NA\\s+(\\d|OKOŁO)\\b/i,\n  /^DLA\\s+\\d/i,\n  // Time-unit metadata: any line containing \"N MIN\" or \"N GODZ\" is prep/cook/rest time,\n  // regardless of OCR-corrupted prefix (catches PRZYGOTOWANTE, GOTOMANTE, etc.)\n  /\\b\\d+\\s*MIN\\b/i,\n  /\\b\\d+\\s*GODZ/i,\n];\n\n/**\n * Single-word non-title words — standalone OCR fragments unlikely to be recipe titles\n */\nconst NON_TITLE_WORDS = new Set([\n  \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"are\", \"was\",\n  \"has\", \"his\", \"her\", \"its\", \"our\", \"who\", \"how\", \"may\", \"new\", \"now\",\n  \"old\", \"see\", \"way\", \"did\", \"get\", \"let\", \"say\", \"she\", \"too\", \"use\",\n  \"buns\", \"with\",\n]);\n\nfunction looksLikeIngredient(line: string): boolean {\n  const lowerLine = line.toLowerCase();\n  return MEASUREMENT_PATTERNS.some((pattern) => lowerLine.includes(pattern));\n}\n\nfunction startsWithNumber(line: string): boolean {\n  return /^\\s*\\d/.test(line);\n}\n\nfunction isAllCaps(line: string): boolean {\n  const letters = line.replace(/[^a-zA-Z]/g, \"\");\n  return letters.length > 0 && letters === letters.toUpperCase();\n}\n\nfunction looksLikeMetadata(text: string): boolean {\n  return METADATA_PATTERNS.some((pattern) => pattern.test(text.trim()));\n}\n\nfunction isLikelyGarbled(text: string): boolean {\n  const letters = text.replace(/[^a-zA-Z]/g, \"\");\n  if (letters.length < 2) return true;\n\n  // Check vowel ratio — English/Polish text typically has 30–50% vowels\n  const vowels = letters.replace(/[^aeiouAEIOUyYąęóĄĘÓ]/g, \"\").length;\n  const vowelRatio = vowels / letters.length;\n  if (vowelRatio < 0.15 || vowelRatio > 0.85) return true;\n\n  // Single orphaned word ≤3 letters that isn't a common word\n  const words = text.trim().split(/\\s+/);\n  const COMMON_SHORT = new Set([\n    \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"had\", \"her\",\n    \"was\", \"one\", \"our\", \"out\", \"are\", \"has\", \"his\", \"how\", \"its\", \"may\",\n    \"new\", \"now\", \"old\", \"see\", \"way\", \"who\", \"did\", \"get\", \"let\", \"say\",\n    \"she\", \"too\", \"use\",\n  ]);\n  if (words.length === 1 && letters.length <= 3 && !COMMON_SHORT.has(text.trim().toLowerCase())) {\n    return true;\n  }\n\n  // Recipe titles never start with a lowercase letter\n  if (/^[a-z]/.test(text.trim())) {\n    return true;\n  }","numLines":70,"startLine":40,"totalLines":601}}}
