{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CYeDzrZyBoquK6u4WxH1A8","type":"tool_result","content":"     1→#!/usr/bin/env node\n     2→\n     3→/**\n     4→ * Standalone title extraction CLI.\n     5→ * Reads a text file, runs extractTitleWithEmbeddings, prints the title to stdout.\n     6→ * Exit 0 on success, 1 on error.\n     7→ *\n     8→ * Usage: npx tsx tools/title-loop/extract-title.ts <text-file-path>\n     9→ */\n    10→\n    11→import { readFileSync } from \"fs\";\n    12→import {\n    13→  embedText,\n    14→  loadEmbedder,\n    15→  type FeatureEmbedder,\n    16→} from \"@/lib/text-classifier/embedder\";\n    17→import { extractTitleWithEmbeddings } from \"@/lib/text-classifier/title-extractor\";\n    18→\n    19→let cachedEmbedder: FeatureEmbedder | null = null;\n    20→\n    21→async function getEmbedder(): Promise<FeatureEmbedder> {\n    22→  if (!cachedEmbedder) {\n    23→    cachedEmbedder = await loadEmbedder();\n    24→  }\n    25→  return cachedEmbedder;\n    26→}\n    27→\n    28→async function embed(text: string): Promise<Array<number>> {\n    29→  return embedText(await getEmbedder(), text);\n    30→}\n    31→\n    32→async function main(): Promise<void> {\n    33→  const filePath = process.argv[2];\n    34→  if (!filePath) {\n    35→    console.error(\"Usage: npx tsx tools/title-loop/extract-title.ts <text-file>\");\n    36→    process.exit(1);\n    37→  }\n    38→\n    39→  const text = readFileSync(filePath, \"utf-8\");\n    40→  const title = await extractTitleWithEmbeddings(text, embed);\n    41→  process.stdout.write(title ?? \"\");\n    42→}\n    43→\n    44→main().catch((err) => {\n    45→  console.error(err);\n    46→  process.exit(1);\n    47→});\n    48→"}]},"parent_tool_use_id":null,"session_id":"f1cce918-fde6-46b5-9093-50476190ee9c","uuid":"7763a6db-eb1a-417b-8756-5de4d7595d95","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/tools/title-loop/extract-title.ts","content":"#!/usr/bin/env node\n\n/**\n * Standalone title extraction CLI.\n * Reads a text file, runs extractTitleWithEmbeddings, prints the title to stdout.\n * Exit 0 on success, 1 on error.\n *\n * Usage: npx tsx tools/title-loop/extract-title.ts <text-file-path>\n */\n\nimport { readFileSync } from \"fs\";\nimport {\n  embedText,\n  loadEmbedder,\n  type FeatureEmbedder,\n} from \"@/lib/text-classifier/embedder\";\nimport { extractTitleWithEmbeddings } from \"@/lib/text-classifier/title-extractor\";\n\nlet cachedEmbedder: FeatureEmbedder | null = null;\n\nasync function getEmbedder(): Promise<FeatureEmbedder> {\n  if (!cachedEmbedder) {\n    cachedEmbedder = await loadEmbedder();\n  }\n  return cachedEmbedder;\n}\n\nasync function embed(text: string): Promise<Array<number>> {\n  return embedText(await getEmbedder(), text);\n}\n\nasync function main(): Promise<void> {\n  const filePath = process.argv[2];\n  if (!filePath) {\n    console.error(\"Usage: npx tsx tools/title-loop/extract-title.ts <text-file>\");\n    process.exit(1);\n  }\n\n  const text = readFileSync(filePath, \"utf-8\");\n  const title = await extractTitleWithEmbeddings(text, embed);\n  process.stdout.write(title ?? \"\");\n}\n\nmain().catch((err) => {\n  console.error(err);\n  process.exit(1);\n});\n","numLines":48,"startLine":1,"totalLines":48}}}
