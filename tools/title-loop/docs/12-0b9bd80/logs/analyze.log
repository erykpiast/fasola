{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012BGje9n3GN857DLNCjxQ3E","type":"tool_result","content":"     1→/**\n     2→ * Title Extraction\n     3→ * Extracts potential recipe title from OCR text using heuristics or semantic embeddings\n     4→ */\n     5→\n     6→import { cosineSimilarity } from \"./embeddings\";\n     7→\n     8→export type EmbedFn = (text: string) => Promise<Array<number>>;\n     9→\n    10→const TITLE_REFERENCE =\n    11→  \"recipe name, dish title, name of the food, nazwa przepisu, nazwa dania\";\n    12→const HEADER_REFERENCE =\n    13→  \"ingredients list, cooking directions, section heading, składniki, przygotowanie, sposób wykonania\";\n    14→const NOISE_REFERENCE =\n    15→  \"page number, table of contents, book footer, garbled text\";\n    16→\n    17→/**\n    18→ * Measurement units commonly found in ingredient lists\n    19→ */\n    20→const MEASUREMENT_PATTERNS = [\n    21→  \"cup\",\n    22→  \"cups\",\n    23→  \"tbsp\",\n    24→  \"tsp\",\n    25→  \"tablespoon\",\n    26→  \"teaspoon\",\n    27→  \"oz\",\n    28→  \"lb\",\n    29→  \"gram\",\n    30→  \"grams\",\n    31→  \"kg\",\n    32→  \"ml\",\n    33→  \"liter\",\n    34→  \"pinch\",\n    35→  \"dash\",\n    36→  \"handful\",\n    37→];\n    38→\n    39→/**\n    40→ * Patterns that identify recipe metadata lines (not titles)\n    41→ */\n    42→const METADATA_PATTERNS = [\n    43→  /^(SERVES?|MAKES?|YIELDS?)\\b/i,\n    44→  /^(PREP(ARATION)?|COOK(ING)?|PROOF|RISING|FERMENTATION|REST(ING)?)\\s*(AND\\s*)?(COOK(ING)?)?\\s*TIME/i,\n    45→  /^SAMPLE\\s+SCHEDULE\\b/i,\n    46→  /^BULK\\s+FERMENTATION\\b/i,\n    47→  /^(THIS\\s+RECIPE\\s+)?MAKES\\b/i,\n    48→  // Polish serving-size patterns: \"NA 3 PAPRYKI\", \"NA OKOŁO 1 KG\", \"DLA 4 OSÓB\"\n    49→  /^NA\\s+(\\d|OKOŁO)\\b/i,\n    50→  /^DLA\\s+\\d/i,\n    51→  // Time-unit metadata: any line containing \"N MIN\" or \"N GODZ\" is prep/cook/rest time,\n    52→  // regardless of OCR-corrupted prefix (catches PRZYGOTOWANTE, GOTOMANTE, etc.)\n    53→  /\\b\\d+\\s*MIN\\b/i,\n    54→  /\\b\\d+\\s*GODZ/i,\n    55→];\n    56→\n    57→/**\n    58→ * Single-word non-title words — standalone OCR fragments unlikely to be recipe titles\n    59→ */\n    60→const NON_TITLE_WORDS = new Set([\n    61→  \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"are\", \"was\",\n    62→  \"has\", \"his\", \"her\", \"its\", \"our\", \"who\", \"how\", \"may\", \"new\", \"now\",\n    63→  \"old\", \"see\", \"way\", \"did\", \"get\", \"let\", \"say\", \"she\", \"too\", \"use\",\n    64→  \"buns\", \"with\",\n    65→]);\n    66→\n    67→function looksLikeIngredient(line: string): boolean {\n    68→  const lowerLine = line.toLowerCase();\n    69→  return MEASUREMENT_PATTERNS.some((pattern) => lowerLine.includes(pattern));\n    70→}\n    71→\n    72→function startsWithNumber(line: string): boolean {\n    73→  return /^\\s*\\d/.test(line);\n    74→}\n    75→\n    76→function isAllCaps(line: string): boolean {\n    77→  const letters = line.replace(/[^a-zA-Z]/g, \"\");\n    78→  return letters.length > 0 && letters === letters.toUpperCase();\n    79→}\n    80→\n    81→function looksLikeMetadata(text: string): boolean {\n    82→  return METADATA_PATTERNS.some((pattern) => pattern.test(text.trim()));\n    83→}\n    84→\n    85→function isLikelyGarbled(text: string): boolean {\n    86→  const letters = text.replace(/[^a-zA-Z]/g, \"\");\n    87→  if (letters.length < 2) return true;\n    88→\n    89→  // Check vowel ratio — English/Polish text typically has 30–50% vowels\n    90→  const vowels = letters.replace(/[^aeiouAEIOUyYąęóĄĘÓ]/g, \"\").length;\n    91→  const vowelRatio = vowels / letters.length;\n    92→  if (vowelRatio < 0.15 || vowelRatio > 0.85) return true;\n    93→\n    94→  // Single orphaned word ≤3 letters that isn't a common word\n    95→  const words = text.trim().split(/\\s+/);\n    96→  const COMMON_SHORT = new Set([\n    97→    \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"had\", \"her\",\n    98→    \"was\", \"one\", \"our\", \"out\", \"are\", \"has\", \"his\", \"how\", \"its\", \"may\",\n    99→    \"new\", \"now\", \"old\", \"see\", \"way\", \"who\", \"did\", \"get\", \"let\", \"say\",\n   100→    \"she\", \"too\", \"use\",\n   101→  ]);\n   102→  if (words.length === 1 && letters.length <= 3 && !COMMON_SHORT.has(text.trim().toLowerCase())) {\n   103→    return true;\n   104→  }\n   105→\n   106→  // Recipe titles never start with a lowercase letter\n   107→  if (/^[a-z]/.test(text.trim())) {\n   108→    return true;\n   109→  }\n   110→\n   111→  // Mid-text sentence boundary (\". \" followed by a letter) — body text fragment spliced from multiple sentences\n   112→  const trimmed = text.trim();\n   113→  if (/\\.\\s+[a-zA-Z]/.test(trimmed) && !trimmed.endsWith(\")\")) {\n   114→    return true;\n   115→  }\n   116→\n   117→  // Multi-word candidate containing a garbled OCR fragment: a short lowercase word that isn't a known short word\n   118→  if (words.length >= 2) {\n   119→    const commonShort2 = new Set([\n   120→      \"a\", \"i\", \"of\", \"or\", \"to\", \"in\", \"on\", \"is\", \"it\", \"an\",\n   121→      \"as\", \"at\", \"by\", \"do\", \"go\", \"if\", \"no\", \"so\", \"up\", \"we\",\n   122→      \"w\", \"z\",  // Polish prepositions\n   123→    ]);\n   124→    const hasGarbledWord = words.some(\n   125→      (w) =>\n   126→        /^[a-z]/.test(w) &&\n   127→        w.replace(/[^a-z]/g, \"\").length <= 2 &&\n   128→        !commonShort2.has(w.toLowerCase())\n   129→    );\n   130→    if (hasGarbledWord) {\n   131→      return true;\n   132→    }\n   133→  }\n   134→\n   135→  return false;\n   136→}\n   137→\n   138→function passesHardFilters(text: string): boolean {\n   139→  if (text.length < 3 || text.length > 80) return false;\n   140→  if (looksLikeIngredient(text)) return false;\n   141→  if (startsWithNumber(text)) return false;\n   142→  if (looksLikeMetadata(text)) return false;\n   143→  if (isLikelyGarbled(text)) return false;\n   144→  // Pipe-separated lines are book category/chapter headers, not recipe titles\n   145→  if (text.includes(\" | \")) return false;\n   146→  // Single-word non-title fragments\n   147→  const words = text.trim().split(/\\s+/);\n   148→  if (words.length === 1 && NON_TITLE_WORDS.has(text.trim().toLowerCase())) return false;\n   149→  return true;\n   150→}\n   151→\n   152→/**\n   153→ * Detect initial burst of short garbled lines.\n   154→ * Returns the index of the first non-garbled or long line.\n   155→ */\n   156→function findBurstEnd(lines: Array<{ text: string }>): number {\n   157→  let i = 0;\n   158→  while (i < lines.length && lines[i].text.length < 20 && isLikelyGarbled(lines[i].text)) {\n   159→    i++;\n   160→  }\n   161→  return i;\n   162→}\n   163→\n   164→function wordCount(text: string): number {\n   165→  return text.split(/\\s+/).filter((w) => w.length > 0).length;\n   166→}\n   167→\n   168→/**\n   169→ * Build candidate strings from lines: single lines plus multi-line joins (2-3 consecutive).\n   170→ * Skips initial burst of short garbled lines. Scans all remaining lines. Caps at 25.\n   171→ */\n   172→export type CandidateOrigin = \"single\" | \"2-line\" | \"3-line\";\n   173→\n   174→function buildCandidates(\n   175→  lines: Array<string>\n   176→): Array<{ text: string; position: number; origin: CandidateOrigin }> {\n   177→  const nonEmptyLines: Array<{ text: string; index: number }> = [];\n   178→\n   179→  for (let i = 0; i < lines.length; i++) {\n   180→    const trimmed = lines[i].trim();\n   181→    if (trimmed.length > 0) {\n   182→      nonEmptyLines.push({ text: trimmed, index: i });\n   183→    }\n   184→  }\n   185→\n   186→  const burstEnd = findBurstEnd(nonEmptyLines);\n   187→\n   188→  // Pre-merge continuation lines: a line starting with /&+:( is never a standalone title.\n   189→  // Merge it into the preceding line so the complete title enters the pool as a single candidate,\n   190→  // avoiding the fragile chain of conditions required by the downstream join survival logic.\n   191→  // Limitation: only one continuation line per preceding line is merged. Titles split across\n   192→  // three or more lines with continuation tokens (rare in practice) are not handled here —\n   193→  // the downstream 2-line and 3-line join candidates cover those cases instead.\n   194→  const mergedLines: Array<{ text: string; index: number }> = [];\n   195→  for (let i = burstEnd; i < nonEmptyLines.length; i++) {\n   196→    const line = nonEmptyLines[i];\n   197→    if (i + 1 < nonEmptyLines.length) {\n   198→      const nextText = nonEmptyLines[i + 1].text;\n   199→      if (/^[/&+:(]/.test(nextText)) {\n   200→        mergedLines.push({ text: `${line.text} ${nextText}`, index: line.index });\n   201→        i++;\n   202→        continue;\n   203→      }\n   204→    }\n   205→    mergedLines.push(line);\n   206→  }\n   207→\n   208→  const candidates: Array<{ text: string; position: number; origin: CandidateOrigin }> = [];\n   209→  const seen = new Set<string>();\n   210→\n   211→  for (let i = 0; i < mergedLines.length; i++) {\n   212→    const line = mergedLines[i];\n   213→\n   214→    // Single line\n   215→    if (passesHardFilters(line.text)) {\n   216→      const norm = line.text.toLowerCase();\n   217→      if (!seen.has(norm)) {\n   218→        seen.add(norm);\n   219→        candidates.push({ text: line.text, position: line.index, origin: \"single\" });\n   220→      }\n   221→    }\n   222→\n   223→    // 2-line join\n   224→    if (i + 1 < mergedLines.length) {\n   225→      const joined2 = `${line.text} ${mergedLines[i + 1].text}`;\n   226→      if (passesHardFilters(joined2)) {\n   227→        const norm = joined2.toLowerCase();\n   228→        if (!seen.has(norm)) {\n   229→          seen.add(norm);\n   230→          candidates.push({ text: joined2, position: line.index, origin: \"2-line\" });\n   231→        }\n   232→      }\n   233→    }\n   234→\n   235→    // 3-line join\n   236→    if (i + 2 < mergedLines.length) {\n   237→      const joined3 = `${line.text} ${mergedLines[i + 1].text} ${mergedLines[i + 2].text}`;\n   238→      if (passesHardFilters(joined3)) {\n   239→        const norm = joined3.toLowerCase();\n   240→        if (!seen.has(norm)) {\n   241→          seen.add(norm);\n   242→          candidates.push({ text: joined3, position: line.index, origin: \"3-line\" });\n   243→        }\n   244→      }\n   245→    }\n   246→  }\n   247→\n   248→  // Pre-filter to 25 before embedding calls: prefer ALL_CAPS and short candidates.\n   249→  // Position-based scoring handles final ranking.\n   250→  if (candidates.length > 25) {\n   251→    const prioritized = candidates.slice().sort((a, b) => {\n   252→      const aAllCaps = isAllCaps(a.text) ? 0 : 1;\n   253→      const bAllCaps = isAllCaps(b.text) ? 0 : 1;\n   254→      if (aAllCaps !== bAllCaps) return aAllCaps - bAllCaps;\n   255→      const aShort = wordCount(a.text) <= 5 ? 0 : 1;\n   256→      const bShort = wordCount(b.text) <= 5 ? 0 : 1;\n   257→      return aShort - bShort;\n   258→    });\n   259→    return prioritized.slice(0, 25);\n   260→  }\n   261→\n   262→  return candidates;\n   263→}\n   264→\n   265→// Module-level cache for reference embeddings\n   266→let cachedTitleRefEmbedding: Array<number> | null = null;\n   267→let cachedHeaderRefEmbedding: Array<number> | null = null;\n   268→let cachedNoiseRefEmbedding: Array<number> | null = null;\n   269→\n   270→export function _resetEmbeddingCacheForTests(): void {\n   271→  cachedTitleRefEmbedding = null;\n   272→  cachedHeaderRefEmbedding = null;\n   273→  cachedNoiseRefEmbedding = null;\n   274→}\n   275→\n   276→export async function extractTitleWithEmbeddings(\n   277→  text: string,\n   278→  embed: EmbedFn\n   279→): Promise<string | undefined> {\n   280→  if (!text || text.trim().length === 0) {\n   281→    return undefined;\n   282→  }\n   283→\n   284→  const lines = text.split(\"\\n\");\n   285→  const candidates = buildCandidates(lines);\n   286→\n   287→  if (candidates.length === 0) {\n   288→    return undefined;\n   289→  }\n   290→\n   291→  // Cache reference embeddings\n   292→  if (!cachedTitleRefEmbedding) {\n   293→    cachedTitleRefEmbedding = await embed(TITLE_REFERENCE);\n   294→  }\n   295→  if (!cachedHeaderRefEmbedding) {\n   296→    cachedHeaderRefEmbedding = await embed(HEADER_REFERENCE);\n   297→  }\n   298→  if (!cachedNoiseRefEmbedding) {\n   299→    cachedNoiseRefEmbedding = await embed(NOISE_REFERENCE);\n   300→  }\n   301→\n   302→  // Find ALL_CAPS candidates with ≥2 words where every significant word has ≥4 alpha letters.\n   303→  // Insignificant tokens (≤1 alpha letter: \"/\", \"&\", \"+\", \":\", \"D)\", etc.) are filtered before\n   304→  // the check so that multi-line joins with continuation punctuation still qualify.\n   305→  const isStructuralHeading = (c: { text: string }): boolean => {\n   306→    if (!isAllCaps(c.text) || wordCount(c.text) < 2) return false;\n   307→    const sigWords = c.text.trim().split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length > 1);\n   308→    return sigWords.length >= 2 && sigWords.every((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   309→  };\n   310→\n   311→  // Pass 1: compute rawScore for all candidates (embedding quality signal)\n   312→  const rawScored: Array<{ text: string; position: number; origin: CandidateOrigin; rawScore: number; embedding: Array<number> }> = [];\n   313→  for (const candidate of candidates) {\n   314→    const embedding = await embed(candidate.text);\n   315→    const titleSim = cosineSimilarity(embedding, cachedTitleRefEmbedding);\n   316→    const headerSim = cosineSimilarity(embedding, cachedHeaderRefEmbedding);\n   317→    const noiseSim = cosineSimilarity(embedding, cachedNoiseRefEmbedding);\n   318→    const rawScore = titleSim - Math.max(headerSim, noiseSim);\n   319→    rawScored.push({ text: candidate.text, position: candidate.position, origin: candidate.origin, rawScore, embedding });\n   320→  }\n   321→\n   322→  // Select baseHeading by embedding quality (rawScore), not position.\n   323→  // This prevents OCR-garbled fragments from claiming the structural heading slot.\n   324→  const structuralCandidates = rawScored.filter((s) => isStructuralHeading(s));\n   325→\n   326→  // Penalize structural headings with truncated OCR words:\n   327→  // if \"FRON\" appears and another heading has \"SAFFRON\", \"FRON\" is likely garbled.\n   328→  for (const sc of structuralCandidates) {\n   329→    const sigWords = sc.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   330→    for (const other of structuralCandidates) {\n   331→      if (other === sc) continue;\n   332→      const otherSigWords = other.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   333→      const hasTruncation = sigWords.some((w) =>\n   334→        otherSigWords.some((ow) => ow !== w && ow.length > w.length && ow.endsWith(w))\n   335→      );\n   336→      if (hasTruncation) {\n   337→        sc.rawScore = -1.0;  // Hard disqualification — truncated OCR artifact\n   338→        break;\n   339→      }\n   340→    }\n   341→  }\n   342→\n   343→  const bestStructural = structuralCandidates.length > 0\n   344→    ? structuralCandidates.reduce((a, b) => {\n   345→        const scoreDiff = a.rawScore - b.rawScore;\n   346→        if (Math.abs(scoreDiff) > 0.03) return scoreDiff > 0 ? a : b;\n   347→        // Tiebreak: single-line origin beats multi-line joins (avoids conflating two separate headings)\n   348→        if (a.origin === \"single\" && b.origin !== \"single\") return a;\n   349→        if (b.origin === \"single\" && a.origin !== \"single\") return b;\n   350→        // Tiebreak: more words (more specific) → better\n   351→        const wcDiff = wordCount(b.text) - wordCount(a.text);\n   352→        if (wcDiff !== 0) return wcDiff > 0 ? b : a;\n   353→        // Tiebreak: earlier position → better\n   354→        return a.position < b.position ? a : b;\n   355→      })\n   356→    : null;\n   357→  const baseHeading = bestStructural ?? undefined;\n   358→\n   359→  // When the best structural heading has a continuation on the next line introduced by a\n   360→  // punctuation token (/, &, +, :, or parenthesis), prefer the longer 2-line join as the\n   361→  // complete heading. E.g. \"SAFFRON WHEAT BUNS WITH QUARK\" + \"/ COTTAGE CHEESE (VARIATION D)\".\n   362→  // Guard: the remainder after the prefix must start with a continuation character to avoid\n   363→  // merging two separate consecutive recipe titles (FINNISH MILK FLATBREADS stays separate\n   364→  // from FINNISH POTATO FLATBREADS because \"FINNISH\" does not start with a continuation token).\n   365→  const firstStructuralHeading = baseHeading && (\n   366→    rawScored.find((c) => {\n   367→      if (!isStructuralHeading(c)) return false;\n   368→      const hLower = baseHeading.text.toLowerCase();\n   369→      const cLower = c.text.toLowerCase();\n   370→      return cLower.startsWith(hLower + \" \") && /^[/&+:(]/.test(cLower.slice(hLower.length + 1));\n   371→    }) ?? baseHeading\n   372→  );\n   373→\n   374→  // Pass 2: apply bonuses\n   375→  const scored: Array<{ text: string; position: number; origin: CandidateOrigin; score: number; rawScore: number; baseScore: number; thresholdScore: number }> = rawScored.map((rs) => {\n   376→    // Position factor: multiplicative tiebreaker — amplifies existing signal, doesn't replace it\n   377→    const relativePosition = rs.position / lines.length;\n   378→    const positionFactor = relativePosition < 0.5\n   379→      ? 1.0 + 0.12 * (1 - relativePosition * 2)\n   380→      : 1.0;\n   381→\n   382→    // ALL_CAPS bonus: recipe books use ALL_CAPS for titles and section headings\n   383→    const allCapsBonus = isAllCaps(rs.text) && rs.text.replace(/[^a-zA-Z]/g, \"\").length >= 4\n   384→      ? 0.08\n   385→      : 0;\n   386→\n   387→    // Structural heading bonus: best ALL_CAPS heading (or its continuation join) is almost always the recipe title\n   388→    const structuralBonus = firstStructuralHeading && rs.text === firstStructuralHeading.text ? 0.10 : 0;\n   389→\n   390→    // thresholdScore excludes structural bonus so the bonus doesn't inflate the threshold\n   391→    // and prevent equally-valid structural headings from passing on multi-recipe pages.\n   392→    const thresholdScore = rs.rawScore + allCapsBonus;\n   393→    // baseScore excludes position factor — used for diagnostics and ranking\n   394→    const baseScore = rs.rawScore + allCapsBonus + structuralBonus;\n   395→    const score = rs.rawScore * positionFactor + allCapsBonus + structuralBonus;\n   396→    return { text: rs.text, position: rs.position, origin: rs.origin, score, rawScore: rs.rawScore, baseScore, thresholdScore };\n   397→  });\n   398→\n   399→  if (scored.length === 0) {\n   400→    return undefined;\n   401→  }\n   402→\n   403→  // --- Pre-threshold bilingual title detection ---\n   404→  // When a mixed-case candidate at position 0 is followed by an ALL_CAPS candidate\n   405→  // at position ≤ 2 that is semantically similar to it, this is a bilingual recipe\n   406→  // page (e.g., Polish title + ALL_CAPS Korean romanization). Suppress confirmed\n   407→  // translation candidates before computing threshold so their bonuses don't inflate\n   408→  // the threshold beyond the mixed-case title's reach.\n   409→  // Note: we check position ≤ 2 (local proximity), not global ALL_CAPS count, so\n   410→  // section headers later in the document (SKŁADNIKI, WARZYWA, etc.) are irrelevant.\n   411→  let scoredForThreshold = scored;\n   412→  const prePos0 = scored.find((s) => s.position === 0 && !isAllCaps(s.text));\n   413→  if (prePos0) {\n   414→    const nearbyAllCaps = scored.filter(\n   415→      (s) => isAllCaps(s.text) && s.position >= 1 && s.position <= 2\n   416→    );\n   417→    const pos0Embedding = rawScored.find((r) => r.text === prePos0.text)?.embedding;\n   418→    if (pos0Embedding && nearbyAllCaps.length > 0) {\n   419→      const translationCandidates = nearbyAllCaps.filter((cap) => {\n   420→        const capEmbedding = rawScored.find((r) => r.text === cap.text)?.embedding;\n   421→        if (!capEmbedding) return false;\n   422→        return cosineSimilarity(pos0Embedding, capEmbedding) > 0.4;\n   423→      });\n   424→      if (translationCandidates.length > 0) {\n   425→        // Also suppress multi-line joins that start with the translation text\n   426→        // (e.g. \"PAPRIKA GYERAN-JJIM Ingredients\" starts with \"PAPRIKA GYERAN-JJIM\")\n   427→        scoredForThreshold = scored.filter((s) => {\n   428→          const sLower = s.text.toLowerCase();\n   429→          return !translationCandidates.some((t) => sLower.startsWith(t.text.toLowerCase()));\n   430→        });\n   431→      }\n   432→    }\n   433→  }\n   434→\n   435→  // Use thresholdScore (excludes structural bonus) so the structural bonus doesn't inflate\n   436→  // the threshold and block equally-valid headings on multi-recipe pages.\n   437→  const bestThresholdScore = Math.max(...scoredForThreshold.map((s) => s.thresholdScore));\n   438→  const threshold = Math.max(0.08, bestThresholdScore * 0.7);\n   439→\n   440→  // Filter candidates above threshold\n   441→  let selected = scoredForThreshold.filter((s) => s.score >= threshold);\n   442→\n   443→  // Empty-pool fallback: when threshold filtering discards every candidate,\n   444→  // the hard filters' structural verdict should not be overruled by weak\n   445→  // embedding differentiation. Return the best positional candidate.\n   446→  if (selected.length === 0 && scored.length > 0) {\n   447→    const fallback = scored\n   448→      .slice()\n   449→      .sort((a, b) => a.position - b.position || b.score - a.score);\n   450→    selected = [fallback[0]];\n   451→  }\n   452→\n   453→  // Remove word-boundary prefixes of firstStructuralHeading when the heading itself survived\n   454→  // the threshold. Cases:\n   455→  //   ARAYES case:  firstStructuralHeading = \"ARAYES SHRAK\" (2-word join qualifies; \"ARAYES\"\n   456→  //     alone = 1 word, so it never qualified). Filter removes \"ARAYES\" so dedup keeps the join.\n   457→  //   SAFFRON case: baseHeading was the partial line; continuation logic above upgraded\n   458→  //     firstStructuralHeading to the full join. Filter removes the partial so dedup keeps join.\n   459→  // Safety: only fires when the complete heading itself is in selected (passed the threshold).\n   460→  if (firstStructuralHeading && selected.some((s) => s.text === firstStructuralHeading.text)) {\n   461→    const fshLower = firstStructuralHeading.text.toLowerCase();\n   462→    selected = selected.filter((s) => {\n   463→      if (s.text === firstStructuralHeading.text) return true;\n   464→      const sLower = s.text.toLowerCase();\n   465→      // Remove s if it is a space-delimited prefix of the structural heading\n   466→      return !fshLower.startsWith(sLower + \" \");\n   467→    });\n   468→  }\n   469→\n   470→  // Protect continuation joins: when a multi-line join (2-line or 3-line) survived the threshold\n   471→  // and its second part starts with a continuation character, remove the single-line prefix/suffix\n   472→  // so the dedup \"shorter wins\" rule doesn't destroy the complete join.\n   473→  // Note: the pre-merge step above already handles the common Baked Eggs case (&/continuation\n   474→  // on next line) by turning it into a single candidate — this block covers the rarer case where\n   475→  // a continuation-character join was generated as a 2-line/3-line candidate and the prefix\n   476→  // single also survived threshold independently (e.g. from a different code path or OCR layout).\n   477→  // Safety: only fires for joins whose continuation