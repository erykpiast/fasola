28→# OCR noise functions\n   129→def random_ocr_noise():\n   130→    \"\"\"Generate random OCR artifacts.\"\"\"\n   131→    artifacts = [\n   132→        \"1' \",\n   133→        \"''\",\n   134→        \"|\",\n   135→        \"!\",\n   136→        \"0\",\n   137→        \"rn\",\n   138→        \"ni\",\n   139→        \"cl\",\n   140→        \"rl\",\n   141→        \"-\",\n   142→        \"_\",\n   143→        \"~\",\n   144→        \"`\",\n   145→    ]\n   146→    return random.choice(artifacts)\n   147→\n   148→def garbled_line():\n   149→    \"\"\"Generate a garbled OCR line.\"\"\"\n   150→    patterns = [\n   151→        \"1l1l1l1l1l1l1l1l1l\",\n   152→        \"0|0|0|0|0|0|0|0|0|\",\n   153→        \"~-~-~-~-~-~-~-~-~-\",\n   154→        \"''''''''''''''''''\",\n   155→        \"||||||||||||||||\",\n   156→        \"rnrnrnrnrnrnrnrnrn\",\n   157→    ]\n   158→    return random.choice(patterns)\n   159→\n   160→def mangle_word(word):\n   161→    \"\"\"Introduce OCR errors into a word.\"\"\"\n   162→    if random.random() < 0.3:\n   163→        chars = list(word)\n   164→        if len(chars) > 1:\n   165→            idx = random.randint(0, len(chars) - 1)\n   166→            replacements = ['1', '|', '0', 'n', 'rn', 'rl']\n   167→            chars[idx] = random.choice(replacements)\n   168→        return ''.join(chars)\n   169→    return word\n   170→\n   171→def generate_recipe_text(title, is_polish=False):\n   172→    \"\"\"Generate realistic OCR recipe text.\"\"\"\n   173→    lines = []\n   174→\n   175→    # Decide title position\n   176→    title_pos = random.randint(0, 2)\n   177→\n   178→    # Sometimes add noise at top\n   179→    if random.random() < 0.7:\n   180→        for _ in range(random.randint(1, 3)):\n   181→            if random.random() < 0.5:\n   182→                lines.append(garbled_line())\n   183→            else:\n   184→                lines.append(\"Page 47 \" + \"\".join(random.choice([\"'\", \"|\", \"l\", \"1\"]) for _ in range(ran