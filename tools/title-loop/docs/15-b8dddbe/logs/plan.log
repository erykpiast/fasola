{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01U4QMkrNweqy9y6SWVt6NJ4","type":"tool_result","content":"     1→/**\n     2→ * Title Extraction\n     3→ * Extracts potential recipe title from OCR text using heuristics or semantic embeddings\n     4→ */\n     5→\n     6→import { cosineSimilarity } from \"./embeddings\";\n     7→\n     8→export type EmbedFn = (text: string) => Promise<Array<number>>;\n     9→\n    10→const TITLE_REFERENCE =\n    11→  \"recipe name, dish title, name of the food, nazwa przepisu, nazwa dania\";\n    12→const HEADER_REFERENCE =\n    13→  \"ingredients list, cooking directions, section heading, składniki, przygotowanie, sposób wykonania\";\n    14→const NOISE_REFERENCE =\n    15→  \"page number, table of contents, book footer, garbled text\";\n    16→\n    17→/**\n    18→ * Measurement units commonly found in ingredient lists\n    19→ */\n    20→const MEASUREMENT_PATTERNS = [\n    21→  // English\n    22→  \"cup\",\n    23→  \"cups\",\n    24→  \"tbsp\",\n    25→  \"tsp\",\n    26→  \"tablespoon\",\n    27→  \"teaspoon\",\n    28→  // \"oz\" and \"lb\" are matched with word boundaries in looksLikeIngredient\n    29→  // to avoid false positives (\"oz\" in \"mozzarella\", \"lb\" in \"albacore\")\n    30→  \"gram\",\n    31→  \"grams\",\n    32→  \"kg\",\n    33→  \"ml\",\n    34→  \"liter\",\n    35→  \"pinch\",\n    36→  \"dash\",\n    37→  \"handful\",\n    38→  // Polish\n    39→  \"łyżka\", \"łyżki\", \"łyżek\",           // tablespoon(s)\n    40→  \"łyżeczka\", \"łyżeczki\", \"łyżeczek\",   // teaspoon(s)\n    41→  \"szklanka\", \"szklanki\", \"szklanek\",    // cup(s)\n    42→  \"szczypta\",                            // pinch\n    43→  \"garść\",                               // handful\n    44→  \"opakowanie\", \"opakowania\",            // package(s)\n    45→  \"plasterek\", \"plasterki\",             // slice(s)\n    46→];\n    47→\n    48→/**\n    49→ * Patterns that identify recipe metadata lines (not titles)\n    50→ */\n    51→const METADATA_PATTERNS = [\n    52→  /^(SERVES?|MAKES?|YIELDS?)\\b/i,\n    53→  /^(PREP(ARATION)?|COOK(ING)?|PROOF|RISING|FERMENTATION|REST(ING)?)\\s*(AND\\s*)?(COOK(ING)?)?\\s*TIME/i,\n    54→  /^SAMPLE\\s+SCHEDULE\\b/i,\n    55→  /^BULK\\s+FERMENTATION\\b/i,\n    56→  /^(THIS\\s+RECIPE\\s+)?MAKES\\b/i,\n    57→  // Polish serving-size patterns: \"NA 3 PAPRYKI\", \"NA OKOŁO 1 KG\", \"DLA 4 OSÓB\"\n    58→  /^NA\\s+(\\d|OKOŁO)\\b/i,\n    59→  /^DLA\\s+\\d/i,\n    60→  // Time-unit metadata: any line containing \"N MIN\" or \"N GODZ\" is prep/cook/rest time,\n    61→  // regardless of OCR-corrupted prefix (catches PRZYGOTOWANTE, GOTOMANTE, etc.)\n    62→  /\\b\\d+\\s*MIN\\b/i,\n    63→  /\\b\\d+\\s*GODZ/i,\n    64→];\n    65→\n    66→/**\n    67→ * Single-word non-title words — standalone OCR fragments unlikely to be recipe titles\n    68→ */\n    69→const NON_TITLE_WORDS = new Set([\n    70→  \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"are\", \"was\",\n    71→  \"has\", \"his\", \"her\", \"its\", \"our\", \"who\", \"how\", \"may\", \"new\", \"now\",\n    72→  \"old\", \"see\", \"way\", \"did\", \"get\", \"let\", \"say\", \"she\", \"too\", \"use\",\n    73→  \"buns\", \"with\",\n    74→]);\n    75→\n    76→function looksLikeIngredient(line: string): boolean {\n    77→  const lowerLine = line.toLowerCase();\n    78→  if (MEASUREMENT_PATTERNS.some((pattern) => lowerLine.includes(pattern))) return true;\n    79→  // Compact metric: \"100g\", \"50ml\", \"250g\" — digit immediately followed by g/ml/kg\n    80→  if (/\\b\\d+\\s*(?:g|ml|kg)\\b/i.test(line)) return true;\n    81→  // \"to taste\" / \"do smaku\" — qualitative ingredient with no unit\n    82→  if (/\\bto taste\\b/i.test(line) || /\\bdo smaku\\b/i.test(line)) return true;\n    83→  return false;\n    84→}\n    85→\n    86→function startsWithNumber(line: string): boolean {\n    87→  // Match lines starting with a digit, or bullet-then-digit (e.g., \"- 2 jajka\")\n    88→  return /^\\s*(?:[-•*]\\s*)?\\d/.test(line);\n    89→}\n    90→\n    91→/**\n    92→ * Known recipe section labels — these are structural headers, not recipe titles.\n    93→ * Matched case-insensitively after trimming and stripping trailing punctuation (colon, period).\n    94→ */\n    95→const SECTION_LABELS = new Set([\n    96→  // English\n    97→  \"ingredients\", \"directions\", \"instructions\", \"method\", \"preparation\",\n    98→  \"steps\", \"notes\", \"tip\", \"tips\", \"variations\", \"variation\",\n    99→  \"garnish\", \"topping\", \"toppings\", \"frosting\", \"filling\",\n   100→  // Polish\n   101→  \"składniki\", \"przygotowanie\", \"sposób przygotowania\", \"sposób wykonania\",\n   102→  \"wykonanie\", \"wskazówki\", \"podpowiedź\", \"warianty\",\n   103→  \"sos\", \"nadzienie\", \"polewa\", \"lukier\", \"ciasto\",\n   104→]);\n   105→\n   106→function isSectionLabel(text: string): boolean {\n   107→  const normalized = text.trim().replace(/[:.]$/, \"\").toLowerCase();\n   108→  return SECTION_LABELS.has(normalized);\n   109→}\n   110→\n   111→function isAllCaps(line: string): boolean {\n   112→  const letters = line.replace(/[^a-zA-Z]/g, \"\");\n   113→  return letters.length > 0 && letters === letters.toUpperCase();\n   114→}\n   115→\n   116→function looksLikeMetadata(text: string): boolean {\n   117→  return METADATA_PATTERNS.some((pattern) => pattern.test(text.trim()));\n   118→}\n   119→\n   120→function isLikelyGarbled(text: string): boolean {\n   121→  const letters = text.replace(/[^a-zA-Z]/g, \"\");\n   122→  if (letters.length < 2) return true;\n   123→\n   124→  // Check vowel ratio — English/Polish text typically has 30–50% vowels\n   125→  const vowels = letters.replace(/[^aeiouAEIOUyYąęóĄĘÓ]/g, \"\").length;\n   126→  const vowelRatio = vowels / letters.length;\n   127→  if (vowelRatio < 0.15 || vowelRatio > 0.85) return true;\n   128→\n   129→  // Single orphaned word ≤3 letters that isn't a common word\n   130→  const words = text.trim().split(/\\s+/);\n   131→  const COMMON_SHORT = new Set([\n   132→    \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"had\", \"her\",\n   133→    \"was\", \"one\", \"our\", \"out\", \"are\", \"has\", \"his\", \"how\", \"its\", \"may\",\n   134→    \"new\", \"now\", \"old\", \"see\", \"way\", \"who\", \"did\", \"get\", \"let\", \"say\",\n   135→    \"she\", \"too\", \"use\",\n   136→  ]);\n   137→  if (words.length === 1 && letters.length <= 3 && !COMMON_SHORT.has(text.trim().toLowerCase())) {\n   138→    return true;\n   139→  }\n   140→\n   141→  // Recipe titles never start with a lowercase letter\n   142→  if (/^[a-z]/.test(text.trim())) {\n   143→    return true;\n   144→  }\n   145→\n   146→  // Mid-text sentence boundary (\". \" followed by a letter) — body text fragment spliced from multiple sentences\n   147→  const trimmed = text.trim();\n   148→  if (/\\.\\s+[a-zA-Z]/.test(trimmed) && !trimmed.endsWith(\")\")) {\n   149→    return true;\n   150→  }\n   151→\n   152→  // Multi-word candidate containing a garbled OCR fragment: a short lowercase word that isn't a known short word\n   153→  if (words.length >= 2) {\n   154→    const commonShort2 = new Set([\n   155→      \"a\", \"i\", \"of\", \"or\", \"to\", \"in\", \"on\", \"is\", \"it\", \"an\",\n   156→      \"as\", \"at\", \"by\", \"do\", \"go\", \"if\", \"no\", \"so\", \"up\", \"we\",\n   157→      \"w\", \"z\",  // Polish prepositions\n   158→    ]);\n   159→    const hasGarbledWord = words.some(\n   160→      (w) =>\n   161→        /^[a-z]/.test(w) &&\n   162→        w.replace(/[^a-z]/g, \"\").length <= 2 &&\n   163→        !commonShort2.has(w.toLowerCase())\n   164→    );\n   165→    if (hasGarbledWord) {\n   166→      return true;\n   167→    }\n   168→  }\n   169→\n   170→  return false;\n   171→}\n   172→\n   173→function passesHardFilters(text: string): boolean {\n   174→  if (text.length < 3 || text.length > 80) return false;\n   175→  if (looksLikeIngredient(text)) return false;\n   176→  if (startsWithNumber(text)) return false;\n   177→  if (looksLikeMetadata(text)) return false;\n   178→  if (isLikelyGarbled(text)) return false;\n   179→  // Pipe-separated lines are book category/chapter headers, not recipe titles\n   180→  if (text.includes(\" | \")) return false;\n   181→  // Bullet-list items (ingredients or instruction steps) are never titles\n   182→  if (/^\\s*[-•*]\\s/.test(text)) return false;\n   183→  // Known recipe section labels are structural headers, not titles\n   184→  if (isSectionLabel(text)) return false;\n   185→  // Single-word non-title fragments\n   186→  const words = text.trim().split(/\\s+/);\n   187→  if (words.length === 1 && NON_TITLE_WORDS.has(text.trim().toLowerCase())) return false;\n   188→  return true;\n   189→}\n   190→\n   191→/**\n   192→ * Detect initial burst of short garbled lines.\n   193→ * Returns the index of the first non-garbled or long line.\n   194→ */\n   195→function findBurstEnd(lines: Array<{ text: string }>): number {\n   196→  let i = 0;\n   197→  while (i < lines.length && lines[i].text.length < 20 && isLikelyGarbled(lines[i].text)) {\n   198→    i++;\n   199→  }\n   200→  return i;\n   201→}\n   202→\n   203→function wordCount(text: string): number {\n   204→  return text.split(/\\s+/).filter((w) => w.length > 0).length;\n   205→}\n   206→\n   207→/**\n   208→ * Build candidate strings from lines: single lines plus multi-line joins (2-3 consecutive).\n   209→ * Skips initial burst of short garbled lines. Scans all remaining lines. Caps at 25.\n   210→ */\n   211→export type CandidateOrigin = \"single\" | \"2-line\" | \"3-line\";\n   212→\n   213→function buildCandidates(\n   214→  lines: Array<string>\n   215→): Array<{ text: string; position: number; origin: CandidateOrigin }> {\n   216→  const nonEmptyLines: Array<{ text: string; index: number }> = [];\n   217→\n   218→  for (let i = 0; i < lines.length; i++) {\n   219→    const trimmed = lines[i].trim();\n   220→    if (trimmed.length > 0) {\n   221→      nonEmptyLines.push({ text: trimmed, index: i });\n   222→    }\n   223→  }\n   224→\n   225→  const burstEnd = findBurstEnd(nonEmptyLines);\n   226→\n   227→  // Pre-merge consecutive short ALL_CAPS lines (OCR-fragmented headings).\n   228→  // When a sequence of 2+ ALL_CAPS lines each has ≤2 words and ≤25 chars, they are\n   229→  // almost certainly OCR fragments of a single heading. Merge them into one line so\n   230→  // the complete title enters the candidate pool without hitting the 3-line join ceiling.\n   231→  const capsCoalesced: Array<{ text: string; index: number }> = [];\n   232→  let ci = burstEnd;\n   233→  while (ci < nonEmptyLines.length) {\n   234→    const line = nonEmptyLines[ci];\n   235→    if (\n   236→      isAllCaps(line.text) &&\n   237→      wordCount(line.text) <= 2 &&\n   238→      line.text.length <= 25 &&\n   239→      !isSectionLabel(line.text) &&\n   240→      !looksLikeMetadata(line.text)\n   241→    ) {\n   242→      let merged = line.text;\n   243→      const startIndex = line.index;\n   244→      let j = ci + 1;\n   245→      while (j < nonEmptyLines.length) {\n   246→        const next = nonEmptyLines[j];\n   247→        if (\n   248→          isAllCaps(next.text) &&\n   249→          wordCount(next.text) <= 2 &&\n   250→          next.text.length <= 25 &&\n   251→          !isSectionLabel(next.text) &&\n   252→          !looksLikeMetadata(next.text) &&\n   253→          (merged + \" \" + next.text).length <= 80\n   254→        ) {\n   255→          merged += \" \" + next.text;\n   256→          j++;\n   257→        } else {\n   258→          break;\n   259→        }\n   260→      }\n   261→      if (j > ci + 1) {\n   262→        capsCoalesced.push({ text: merged, index: startIndex });\n   263→        ci = j;\n   264→        continue;\n   265→      }\n   266→    }\n   267→    capsCoalesced.push(line);\n   268→    ci++;\n   269→  }\n   270→\n   271→  // Pre-merge continuation lines: a line starting with /&+:( is never a standalone title.\n   272→  // Merge it into the preceding line so the complete title enters the pool as a single candidate,\n   273→  // avoiding the fragile chain of conditions required by the downstream join survival logic.\n   274→  // Limitation: only one continuation line per preceding line is merged. Titles split across\n   275→  // three or more lines with continuation tokens (rare in practice) are not handled here —\n   276→  // the downstream 2-line and 3-line join candidates cover those cases instead.\n   277→  const mergedLines: Array<{ text: string; index: number }> = [];\n   278→  for (let i = 0; i < capsCoalesced.length; i++) {\n   279→    const line = capsCoalesced[i];\n   280→    if (i + 1 < capsCoalesced.length) {\n   281→      const nextText = capsCoalesced[i + 1].text;\n   282→      if (/^[/&+:(]/.test(nextText)) {\n   283→        mergedLines.push({ text: `${line.text} ${nextText}`, index: line.index });\n   284→        i++;\n   285→        continue;\n   286→      }\n   287→    }\n   288→    mergedLines.push(line);\n   289→  }\n   290→\n   291→  const candidates: Array<{ text: string; position: number; origin: CandidateOrigin }> = [];\n   292→  const seen = new Set<string>();\n   293→\n   294→  for (let i = 0; i < mergedLines.length; i++) {\n   295→    const line = mergedLines[i];\n   296→\n   297→    // Single line\n   298→    if (passesHardFilters(line.text)) {\n   299→      const norm = line.text.toLowerCase();\n   300→      if (!seen.has(norm)) {\n   301→        seen.add(norm);\n   302→        candidates.push({ text: line.text, position: line.index, origin: \"single\" });\n   303→      }\n   304→    }\n   305→\n   306→    // 2-line join — skip if first line is a section label (prevents \"INGREDIENTS TITLE\" joins)\n   307→    if (i + 1 < mergedLines.length && !isSectionLabel(line.text)) {\n   308→      const joined2 = `${line.text} ${mergedLines[i + 1].text}`;\n   309→      if (passesHardFilters(joined2)) {\n   310→        const norm = joined2.toLowerCase();\n   311→        if (!seen.has(norm)) {\n   312→          seen.add(norm);\n   313→          candidates.push({ text: joined2, position: line.index, origin: \"2-line\" });\n   314→        }\n   315→      }\n   316→    }\n   317→\n   318→    // 3-line join — skip if first line is a section label\n   319→    if (i + 2 < mergedLines.length && !isSectionLabel(line.text)) {\n   320→      const joined3 = `${line.text} ${mergedLines[i + 1].text} ${mergedLines[i + 2].text}`;\n   321→      if (passesHardFilters(joined3)) {\n   322→        const norm = joined3.toLowerCase();\n   323→        if (!seen.has(norm)) {\n   324→          seen.add(norm);\n   325→          candidates.push({ text: joined3, position: line.index, origin: \"3-line\" });\n   326→        }\n   327→      }\n   328→    }\n   329→  }\n   330→\n   331→  // Pre-filter to 25 before embedding calls: prefer ALL_CAPS and short candidates.\n   332→  // Position-based scoring handles final ranking.\n   333→  if (candidates.length > 25) {\n   334→    const prioritized = candidates.slice().sort((a, b) => {\n   335→      const aAllCaps = isAllCaps(a.text) ? 0 : 1;\n   336→      const bAllCaps = isAllCaps(b.text) ? 0 : 1;\n   337→      if (aAllCaps !== bAllCaps) return aAllCaps - bAllCaps;\n   338→      const aShort = wordCount(a.text) <= 5 ? 0 : 1;\n   339→      const bShort = wordCount(b.text) <= 5 ? 0 : 1;\n   340→      return aShort - bShort;\n   341→    });\n   342→    return prioritized.slice(0, 25);\n   343→  }\n   344→\n   345→  return candidates;\n   346→}\n   347→\n   348→// Module-level cache for reference embeddings\n   349→let cachedTitleRefEmbedding: Array<number> | null = null;\n   350→let cachedHeaderRefEmbedding: Array<number> | null = null;\n   351→let cachedNoiseRefEmbedding: Array<number> | null = null;\n   352→\n   353→export function _resetEmbeddingCacheForTests(): void {\n   354→  cachedTitleRefEmbedding = null;\n   355→  cachedHeaderRefEmbedding = null;\n   356→  cachedNoiseRefEmbedding = null;\n   357→}\n   358→\n   359→export async function extractTitleWithEmbeddings(\n   360→  text: string,\n   361→  embed: EmbedFn\n   362→): Promise<string | undefined> {\n   363→  if (!text || text.trim().length === 0) {\n   364→    return undefined;\n   365→  }\n   366→\n   367→  const lines = text.split(\"\\n\");\n   368→  const candidates = buildCandidates(lines);\n   369→\n   370→  if (candidates.length === 0) {\n   371→    return undefined;\n   372→  }\n   373→\n   374→  // Cache reference embeddings\n   375→  if (!cachedTitleRefEmbedding) {\n   376→    cachedTitleRefEmbedding = await embed(TITLE_REFERENCE);\n   377→  }\n   378→  if (!cachedHeaderRefEmbedding) {\n   379→    cachedHeaderRefEmbedding = await embed(HEADER_REFERENCE);\n   380→  }\n   381→  if (!cachedNoiseRefEmbedding) {\n   382→    cachedNoiseRefEmbedding = await embed(NOISE_REFERENCE);\n   383→  }\n   384→\n   385→  // Find ALL_CAPS candidates with ≥2 words where every significant word has ≥4 alpha letters.\n   386→  // Insignificant tokens (≤1 alpha letter: \"/\", \"&\", \"+\", \":\", \"D)\", etc.) are filtered before\n   387→  // the check so that multi-line joins with continuation punctuation still qualify.\n   388→  const isStructuralHeading = (c: { text: string }): boolean => {\n   389→    if (!isAllCaps(c.text) || wordCount(c.text) < 2) return false;\n   390→    const sigWords = c.text.trim().split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length > 1);\n   391→    return sigWords.length >= 2 && sigWords.every((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   392→  };\n   393→\n   394→  // Pass 1: compute rawScore for all candidates (embedding quality signal)\n   395→  const rawScored: Array<{ text: string; position: number; origin: CandidateOrigin; rawScore: number; embedding: Array<number> }> = [];\n   396→  for (const candidate of candidates) {\n   397→    const embedding = await embed(candidate.text);\n   398→    const titleSim = cosineSimilarity(embedding, cachedTitleRefEmbedding);\n   399→    const headerSim = cosineSimilarity(embedding, cachedHeaderRefEmbedding);\n   400→    const noiseSim = cosineSimilarity(embedding, cachedNoiseRefEmbedding);\n   401→    const rawScore = titleSim - Math.max(headerSim, noiseSim);\n   402→    rawScored.push({ text: candidate.text, position: candidate.position, origin: candidate.origin, rawScore, embedding });\n   403→  }\n   404→\n   405→  // Select baseHeading by embedding quality (rawScore), not position.\n   406→  // This prevents OCR-garbled fragments from claiming the structural heading slot.\n   407→  const structuralCandidates = rawScored.filter((s) => isStructuralHeading(s));\n   408→\n   409→  // Penalize structural headings with truncated OCR words:\n   410→  // if \"FRON\" appears and another heading has \"SAFFRON\", \"FRON\" is likely garbled.\n   411→  for (const sc of structuralCandidates) {\n   412→    const sigWords = sc.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   413→    for (const other of structuralCandidates) {\n   414→      if (other === sc) continue;\n   415→      const otherSigWords = other.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   416→      const hasTruncation = sigWords.some((w) =>\n   417→        otherSigWords.some((ow) => ow !== w && ow.length > w.length && ow.endsWith(w))\n   418→      );\n   419→      if (hasTruncation) {\n   420→        sc.rawScore = -1.0;  // Hard disqualification — truncated OCR artifact\n   421→        break;\n   422→      }\n   423→    }\n   424→  }\n   425→\n   426→  const bestStructural = structuralCandidates.length > 0\n   427→    ? structuralCandidates.reduce((a, b) => {\n   428→        const scoreDiff = a.rawScore - b.rawScore;\n   429→        if (Math.abs(scoreDiff) > 0.03) return scoreDiff > 0 ? a : b;\n   430→        // Tiebreak: single-line origin beats multi-line joins (avoids conflating two separate headings)\n   431→        if (a.origin === \"single\" && b.origin !== \"single\") return a;\n   432→        if (b.origin === \"single\" && a.origin !== \"single\") return b;\n   433→        // Tiebreak: more words (more specific) → better\n   434→        const wcDiff = wordCount(b.text) - wordCount(a.text);\n   435→        if (wcDiff !== 0) return wcDiff > 0 ? b : a;\n   436→        // Tiebreak: earlier position → better\n   437→        return a.position < b.position ? a : b;\n   438→      })\n   439→    : null;\n   440→  const baseHeading = bestStructural ?? undefined;\n   441→\n   442→  // When the best structural heading has a continuation on the next line introduced by a\n   443→  // punctuation token (/, &, +, :, or parenthesis), prefer the longer 2-line join as the\n   444→  // complete heading. E.g. \"SAFFRON WHEAT BUNS WITH QUARK\" + \"/ COTTAGE CHEESE (VARIATION D)\".\n   445→  // Guard: the remainder after the prefix must start with a continuation character to avoid\n   446→  // merging two separate consecutive recipe titles (FINNISH MILK FLATBREADS stays separate\n   447→  // from FINNISH POTATO FLATBREADS because \"FINNISH\" does not start with a continuation token).\n   448→  const firstStructuralHeading = baseHeading && (\n   449→    rawScored.find((c) => {\n   450→      if (!isStructuralHeading(c)) return false;\n   451→      const hLower = baseHeading.text.toLowerCase();\n   452→      const cLower = c.text.toLowerCase();\n   453→      return cLower.startsWith(hLower + \" \") && /^[/&+:(]/.test(cLower.slice(hLower.length + 1));\n   454→    }) ?? baseHeading\n   455→  );\n   456→\n   457→  // Pass 2: apply bonuses\n   458→  const scored: Array<{ text: string; position: number; origin: CandidateOrigin; score: number; rawScore: number; baseScore: number; thresholdScore: number }> = rawScored.map((rs) => {\n   459→    // Position factor: multiplicative tiebreaker — amplifies existing signal, doesn't replace it\n   460→    const relativePosition = rs.position / lines.length;\n   461→    const positionFactor = relativePosition < 0.5\n   462→      ? 1.0 + 0.12 * (1 - relativePosition * 2)\n   463→      : 1.0;\n   464→\n   465→    // ALL_CAPS bonus: recipe books use ALL_CAPS for titles and section headings\n   466→    const allCapsBonus = isAllCaps(rs.text) && rs.text.replace(/[^a-zA-Z]/g, \"\").length >= 4\n   467→      ? 0.08\n   468→      : 0;\n   469→\n   470→    // Structural heading bonus: best ALL_CAPS heading (or its continuation join) is almost always the recipe title\n   471→    const structuralBonus = firstStructuralHeading && rs.text === firstStructuralHeading.text ? 0.10 : 0;\n   472→\n   473→    // thresholdScore excludes structural bonus so the bonus doesn't inflate the threshold\n   474→    // and prevent equally-valid structural headings from passing on multi-recipe pages.\n   475→    const thresholdScore = rs.rawScore + allCapsBonus;\n   476→    // baseScore excludes position factor — used for diagnostics and ranking\n   477→    const baseScore = rs.rawScore + allCapsBonus + structuralBonus;\n   478→    const score = rs.rawScore * positionFactor + allCapsBonus + structuralBonus;\n   479→    return { text: rs.text, position: rs.position, origin: rs.origin, score, rawScore: rs.rawScore, baseScore, thresholdScore };\n   480→  });\n   481→\n   482→  if (scored.length === 0) {\n   483→    return undefined;\n   484→  }\n   485→\n   486→  // --- Pre-threshold bilingual title detection ---\n   487→  // When a mixed-case candidate at position 0 is followed by an ALL_CAPS candidate\n   488→  // at position ≤ 2 that is semantically similar to it, this is a bilingual recipe\n   489→  // page (e.g., Polish title + ALL_CAPS Korean romanization). Suppress confirmed\n   490→  // translation candidates before computing threshold so their bonuses don't inflate\n   491→  // the threshold beyond the mixed-case title's reach.\n   492→  // Note: we check position ≤ 2 (local proximity), not global ALL_CAPS count, so\n   493→  // section headers later in the document (SKŁADNIKI, WARZYWA, etc.) are irrelevant.\n   494→  let scoredForThreshold = scored;\n   495→  const prePos0 = scored.find((s) => s.position === 0 && !isAllCaps(s.text));\n   496→  if (prePos0) {\n   497→    const nearbyAllCaps = scored.filter(\n   498→      (s) => isAllCaps(s.text) && s.position >= 1 && s.position <= 2 && s.origin === \"single\"\n   499→    );\n   500→    const pos0Embedding = rawScored.find((r) => r.text === prePos0.text)?.embedding;\n   501→\n   502→    let translationCandidates: typeof nearbyAllCaps = [];\n   503→\n   504→    // Method 1: embedding similarity (works for related languages)\n   505→    if (pos0Embedding && nearbyAllCaps.length > 0) {\n   506→      translationCandidates = nearbyAllCaps.filter((cap) => {\n   507→        const capEmbedding = rawScored.find((r) => r.text === cap.text)?.embedding;\n   508→        if (!capEmbedding) return false;\n   509→        return cosineSimilarity(pos0Embedding, capEmbedding) > 0.4;\n   510→      });\n   511→    }\n   512→\n   513→    // Method 2: layout-based detection (cross-lingual fallback).\n   514→    // When embedding similarity is insufficient (e.g. Polish ↔ Korean romanization),\n   515→    // detect bilingual layout by position and word overlap:\n   516→    // mixed-case ≥2 words at pos 0 + ALL_CAPS ≥2 words at pos 1-2 with no shared words.\n   517→    if (translationCandidates.length === 0 && wordCount(prePos0.text) >= 2) {\n   518→      const pos0Words = new Set(\n   519→        prePos0.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2)\n   520→      );\n   521→      translationCandidates = nearbyAllCaps.filter((cap) => {\n   522→        if (wordCount(cap.text) < 2) return false;\n   523→        const capWords = cap.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2);\n   524→        return !capWords.some((w) => pos0Words.has(w));\n   525→      });\n   526→    }\n   527→\n   528→    if (translationCandidates.length > 0) {\n   529→      // Also suppress multi-line joins that start with the translation text\n   530→      // (e.g. \"PAPRIKA GYERAN-JJIM Ingredients\" starts with \"PAPRIKA GYERAN-JJIM\")\n   531→      scoredForThreshold = scored.filter((s) => {\n   532→        const sLower = s.text.toLowerCase();\n   533→        return !translationCandidates.some((t) => sLower.startsWith(t.text.toLowerCase()));\n   534→      });\n   535→    }\n   536→  }\n   537→\n   538→  // Use thresholdScore (excludes structural bonus) so the structural bonus doesn't inflate\n   539→  // the threshold and block equally-valid headings on multi-recipe pages.\n   540→  const bestThresholdScore = Math.max(...scoredForThreshold.map((s) => s.thresholdScore));\n   541→  const threshold = Math.max(0.08, bestThresholdScore * 0.7);\n   542→\n   543→  // Filter candidates above threshold\n   544→  let selected = scoredForThreshold.filter((s) => s.score >= threshold);\n   545→\n   546→  // Empty-pool fallback: when threshold filtering discards every candidate,\n   547→  // the hard filters' structural verdict should not be overruled by weak\n   548→  // embedding differentiation. Return the best positional candidate.\n   549→  if (selected.length === 0 && scored.length > 0) {\n   550→    const fallback = scored\n   551→      .slice()\n   552→      .sort((a, b) => a.position - b.position || b.score - a.score);\n   553→    selected = [fallback[0]];\n   554→  }\n   555→\n   556→  // Remove word-boundary prefixes of firstStructuralHeading when the heading itself survived\n   557→  // the threshold. Cases:\n   558→  //   ARAYES case:  firstStructuralHeading = \"ARAYES SHRAK\" (2-word join qualifies; \"ARAYES\"\n   559→  //     alone = 1 word, so it never qualified). Filter removes \"ARAYES\" so dedup keeps the join.\n   560→  //   SAFFRON case: baseHeading was the partial line; continuation logic above upgraded\n   561→  //     firstStructuralHeading to the full join. Filter removes the partial so dedup keeps join.\n   562→  // Safety: only fires when the complete heading itself is in selected (passed the threshold).\n   563→  if (firstStructuralHeading && selected.some((s) => s.text === firstStructuralHeading.text)) {\n   564→    const fshLower = firstStructuralHeading.text.toLowerCase();\n   565→    selected = selected.filter((s) => {\n   566→      if (s.text === firstStructuralHeading.text) return true;\n   567→      const sLower = s.text.toLowerCase();\n   568→      // Remove s if it is a space-delimited prefix of the structural heading\n   569→      return !fshLower.startsWith(sLower + \" \");\n   570→    });\n   571→  }\n   572→\n   573→  // Protect continuation joins: when a multi-line join (2-line or 3-line) survived the threshold\n   574→  // and its second part starts with a continuation character, remove the single-line prefix/suffix\n   575→  // so the dedup \"shorter wins\" rule doesn't destroy the complete join.\n   576→  // Note: the pre-merge step above already handles the common Baked Eggs case (&/continuation\n   577→  // on next line) by turning it into a single candidate — this block covers the rarer case where\n   578→  // a continuation-character join was generated as a 2-line/3-line candidate and the prefix\n   579→  // single also survived threshold independently (e.g. from a different code path or OCR layout).\n   580→  // Safety: only fires for joins whose continuation starts with /&+:( — digit continuations\n   581→  // like \"Pierogi Ruskie 200g mąki\" are NOT protected, so dedup correctly keeps the shorter form.\n   582→  const survivingJoins = selected.filter((s) => s.origin === \"2-line\" || s.origin === \"3-line\");\n   583→  if (survivingJoins.length > 0) {\n   584→    selected = selected.filter((s) => {\n   585→      if (s.origin !== \"single\") return true;\n   586→      const sLower = s.text.toLowerCase();\n   587→      // Remove PREFIX singles whose continuation join also survived\n   588→      const isPrefixOfJoin = survivingJoins.some((j) => {\n   589→        const jLower = j.text.toLowerCase();\n   590→        if (!jLower.startsWith(sLower + \" \")) return false;\n   591→        const remainder = jLower.slice(sLower.length + 1);\n   592→        return /^[/&+:(]/.test(remainder);\n   593→      });\n   594→      if (isPrefixOfJoin) return false;\n   595→      // Remove SUFFIX singles (e.g. \"& Coriander\") whose parent join also survived\n   596→      const isSuffixOfJoin = survivingJoins.some((j) => {\n   597→        const jLower = j.text.toLowerCase();\n   598→        if (!jLower.endsWith(\" \" + sLower)) return false;\n   599→        // Only remove if the suffix starts with a continuation character\n   600→        return /^[/&+:(]/.test(sLower);\n   601→      });\n   602→      if (isSuffixOfJoin) return false;\n   603→      return true;\n   604→    });\n   605→  }\n   606→\n   607→  // Pre-dedup: remove sub-section headers that are substrings of other surviving candidates.\n   608→  // A sub-section header is an ALL_CAPS candidate followed by ingredient-like lines in the source.\n   609→  // Example: \"CHLEBEK\" (bread section header, followed by \"500 g mąki\") is a substring of\n   610→  // \"CHLEBEK Z WARZYWAMI I BOCZKIEM\" (the real title). Without this filter, dedup kills the title.\n   611→  selected = selected.filter((candidate) => {\n   612→    if (!isAllCaps(candidate.text)) return true;\n   613→    // Check if this candidate is immediately followed by ingredient-like content\n   614→    const nextSourceLines = lines.slice(candidate.position + 1, candidate.position + 2);\n   615→    const followedByIngredients = nextSourceLines.some(\n   616→      (l) => looksLikeIngredient(l.trim()) || startsWithNumber(l.trim())\n   617→    );\n   618→    if (!followedByIngredients) return true;\n   619→    // Only remove if a longer candidate contains this one as a substring\n   620→    const candidateLower = candidate.text.toLowerCase();\n   621→    const hasLongerParent = rawScored.some(\n   622→      (other) =>\n   623→        other.text !== candidate.text &&\n   624→        other.text.length > candidate.text.length &&\n   625→        other.text.toLowerCase().includes(candidateLower)\n   626→    );\n   627→    return !hasLongerParent;\n   628→  });\n   629→\n   630→  // Deduplicate: if one title is a substring of another, keep the shorter (more focused) one.\n   631→  // DO NOT CHANGE THIS LOGIC — it has been incorrectly \"improved\" by the title-loop 5 times.\n   632→  // The tests require shorter wins: \"Pierogi Ruskie\" over \"Pierogi Ruskie 200g mąki 3 ziemniaki\".\n   633→  // The pre-filter above handles the conflicting case (structural heading prefix removal) so that\n   634→  // the incomplete prefix line is never present here when the complete join is in selected.\n   635→  selected = selected.filter((a) => {\n   636→    const aLower = a.text.toLowerCase();\n   637→    return !selected.some(\n   638→      (b) =>\n   639→        b !== a &&\n   640→        aLower.includes(b.text.toLowerCase()) &&\n   641→        b.text.length < a.text.length\n   642→    );\n   643→  });\n   644→\n   645→  // Multi-title guard: only join multiple candidates with \"+\" when there is\n   646→  // structural evidence of a multi-recipe page (≥2 ALL_CAPS headings).\n   647→  // A single ALL_CAPS title among mixed-case survivors is a single-recipe page —\n   648→  // collapse to the highest-scoring candidate.\n   649→  // Zero ALL_CAPS survivors → mixed-case multi-title page → keep all.\n   650→  if (selected.length > 1) {\n   651→    const allCapsSelected = selected.filter((s) => isAllCaps(s.text));\n   652→    if (allCapsSelected.length >= 2) {\n   653→      // Check whether non-first ALL_CAPS headings are section headers within one recipe\n   654→      // (followed immediately by ingredient-like content) rather than separate recipe titles.\n   655→      // A multi-recipe page has body text between titles; a single-recipe page has\n   656→      // ingredient lines immediately after each section heading.\n   657→      const sortedCaps = [...allCapsSelected].sort((a, b) => a.position - b.position);\n   658→      const isSubHeader = sortedCaps.slice(1).every((cap) => {\n   659→        const nextLines = lines.slice(cap.position + 1, cap.position + 3);\n   660→        return nextLines.some(\n   661→          (l) => looksLikeIngredient(l.trim()) || /^\\s*\\d/.test(l.trim())\n   662→        );\n   663→      });\n   664→      if (isSubHeader) {\n   665→        selected = [sortedCaps[0]];\n   666→      } else {\n   667→        selected = allCapsSelected;\n   668→      }\n   669→    } else if (allCapsSelected.length === 1) {\n   670→      selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n   671→    }\n   672→  }\n   673→\n   674→  // Cap at 3, sort by document position\n   675→  selected.sort((a, b) => a.position - b.position);\n   676→  selected = selected.slice(0, 3);\n   677→\n   678→  if (selected.length === 0) {\n   679→    return undefined;\n   680→  }\n   681→\n   682→  return selected.map((s) => s.text).join(\" + \");\n   683→}\n   684→\n   685→/**\n   686→ * Extract potential recipe title from OCR text (sync heuristic fallback)\n   687→ */\n   688→export function extractTitle(text: string): string | undefined {\n   689→  if (!text || text.trim().length === 0) {\n   690→    return undefined;\n   691→  }\n   692→\n   693→  const lines = text.split(\"\\n\").map((line) => line.trim());\n   694→\n   695→  for (const line of lines) {\n   696→    if (line.length === 0) continue;\n   697→    if (line.length < 3 || line.length > 50) continue;\n   698→    if (looksLikeIngredient(line)) continue;\n   699→    if (isAllCaps(line)) continue;\n   700→    if (startsWithNumber(line)) continue;\n   701→    return line;\n   702→  }\n   703→\n   704→  return undefined;\n   705→}\n   706→"}]},"parent_tool_use_id":null,"session_id":"beba072c-8756-4212-892f-70153dbd85fa","uuid":"54ec3f1f-d31d-4b18-b07a-5b8022e6058d","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/title-extractor.ts","content":"/**\n * Title Extraction\n * Extracts potential recipe title from OCR text using heuristics or semantic embeddings\n */\n\nimport { cosineSimilarity } from \"./embeddings\";\n\nexport type EmbedFn = (text: string) => Promise<Array<number>>;\n\nconst TITLE_REFERENCE =\n  \"recipe name, dish title, name of the food, nazwa przepisu, nazwa dania\";\nconst HEADER_REFERENCE =\n  \"ingredients list, cooking directions, section heading, składniki, przygotowanie, sposób wykonania\";\nconst NOISE_REFERENCE =\n  \"page number, table of contents, book footer, garbled text\";\n\n/**\n * Measurement units commonly found in ingredient lists\n */\nconst MEASUREMENT_PATTERNS = [\n  // English\n  \"cup\",\n  \"cups\",\n  \"tbsp\",\n  \"tsp\",\n  \"tablespoon\",\n  \"teaspoon\",\n  // \"oz\" and \"lb\" are matched with word boundaries in looksLikeIngredient\n  // to avoid false positives (\"oz\" in \"mozzarella\", \"lb\" in \"albacore\")\n  \"gram\",\n  \"grams\",\n  \"kg\",\n  \"ml\",\n  \"liter\",\n  \"pinch\",\n  \"dash\",\n  \"handful\",\n  // Polish\n  \"łyżka\", \"łyżki\", \"łyżek\",           // tablespoon(s)\n  \"łyżeczka\", \"łyżeczki\", \"łyżeczek\",   // teaspoon(s)\n  \"szklanka\", \"szklanki\", \"szklanek\",    // cup(s)\n  \"szczypta\",                            // pinch\n  \"garść\",                               // handful\n  \"opakowanie\", \"opakowania\",            // package(s)\n  \"plasterek\", \"plasterki\",             // slice(s)\n];\n\n/**\n * Patterns that identify recipe metadata lines (not titles)\n */\nconst METADATA_PATTERNS = [\n  /^(SERVES?|MAKES?|YIELDS?)\\b/i,\n  /^(PREP(ARATION)?|COOK(ING)?|PROOF|RISING|FERMENTATION|REST(ING)?)\\s*(AND\\s*)?(COOK(ING)?)?\\s*TIME/i,\n  /^SAMPLE\\s+SCHEDULE\\b/i,\n  /^BULK\\s+FERMENTATION\\b/i,\n  /^(THIS\\s+RECIPE\\s+)?MAKES\\b/i,\n  // Polish serving-size patterns: \"NA 3 PAPRYKI\", \"NA OKOŁO 1 KG\", \"DLA 4 OSÓB\"\n  /^NA\\s+(\\d|OKOŁO)\\b/i,\n  /^DLA\\s+\\d/i,\n  // Time-unit metadata: any line containing \"N MIN\" or \"N GODZ\" is prep/cook/rest time,\n  // regardless of OCR-corrupted prefix (catches PRZYGOTOWANTE, GOTOMANTE, etc.)\n  /\\b\\d+\\s*MIN\\b/i,\n  /\\b\\d+\\s*GODZ/i,\n];\n\n/**\n * Single-word non-title words — standalone OCR fragments unlikely to be recipe titles\n */\nconst NON_TITLE_WORDS = new Set([\n  \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"are\", \"was\",\n  \"has\", \"his\", \"her\", \"its\", \"our\", \"who\", \"how\", \"may\", \"new\", \"now\",\n  \"old\", \"see\", \"way\", \"did\", \"get\", \"let\", \"say\", \"she\", \"too\", \"use\",\n  \"buns\", \"with\",\n]);\n\nfunction looksLikeIngredient(line: string): boolean {\n  const lowerLine = line.toLowerCase();\n  if (MEASUREMENT_PATTERNS.some((pattern) => lowerLine.includes(pattern))) return true;\n  // Compact metric: \"100g\", \"50ml\", \"250g\" — digit immediately followed by g/ml/kg\n  if (/\\b\\d+\\s*(?:g|ml|kg)\\b/i.test(line)) return true;\n  // \"to taste\" / \"do smaku\" — qualitative ingredient with no unit\n  if (/\\bto taste\\b/i.test(line) || /\\bdo smaku\\b/i.test(line)) return true;\n  return false;\n}\n\nfunction startsWithNumber(line: string): boolean {\n  // Match lines starting with a digit, or bullet-then-digit (e.g., \"- 2 jajka\")\n  return /^\\s*(?:[-•*]\\s*)?\\d/.test(line);\n}\n\n/**\n * Known recipe section labels — these are structural headers, not recipe titles.\n * Matched case-insensitively after trimming and stripping trailing punctuation (colon, period).\n */\nconst SECTION_LABELS = new Set([\n  // English\n  \"ingredients\", \"directions\", \"instructions\", \"method\", \"preparation\",\n  \"steps\", \"notes\", \"tip\", \"tips\", \"variations\", \"variation\",\n  \"garnish\", \"topping\", \"toppings\", \"frosting\", \"filling\",\n  // Polish\n  \"składniki\", \"przygotowanie\", \"sposób przygotowania\", \"sposób wykonania\",\n  \"wykonanie\", \"wskazówki\", \"podpowiedź\", \"warianty\",\n  \"sos\", \"nadzienie\", \"polewa\", \"lukier\", \"ciasto\",\n]);\n\nfunction isSectionLabel(text: string): boolean {\n  const normalized = text.trim().replace(/[:.]$/, \"\").toLowerCase();\n  return SECTION_LABELS.has(normalized);\n}\n\nfunction isAllCaps(line: string): boolean {\n  const letters = line.replace(/[^a-zA-Z]/g, \"\");\n  return letters.length > 0 && letters === letters.toUpperCase();\n}\n\nfunction looksLikeMetadata(text: string): boolean {\n  return METADATA_PATTERNS.some((pattern) => pattern.test(text.trim()));\n}\n\nfunction isLikelyGarbled(text: string): boolean {\n  const letters = text.replace(/[^a-zA-Z]/g, \"\");\n  if (letters.length < 2) return true;\n\n  // Check vowel ratio — English/Polish text typically has 30–50% vowels\n  const vowels = letters.replace(/[^aeiouAEIOUyYąęóĄĘÓ]/g, \"\").length;\n  const vowelRatio = vowels / letters.length;\n  if (vowelRatio < 0.15 || vowelRatio > 0.85) return true;\n\n  // Single orphaned word ≤3 letters that isn't a common word\n  const words = text.trim().split(/\\s+/);\n  const COMMON_SHORT = new Set([\n    \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"had\", \"her\",\n    \"was\", \"one\", \"our\", \"out\", \"are\", \"has\", \"his\", \"how\", \"its\", \"may\",\n    \"new\", \"now\", \"old\", \"see\", \"way\", \"who\", \"did\", \"get\", \"let\", \"say\",\n    \"she\", \"too\", \"use\",\n  ]);\n  if (words.length === 1 && letters.length <= 3 && !COMMON_SHORT.has(text.trim().toLowerCase())) {\n    return true;\n  }\n\n  // Recipe titles never start with a lowercase letter\n  if (/^[a-z]/.test(text.trim())) {\n    return true;\n  }\n\n  // Mid-text sentence boundary (\". \" followed by a letter) — body text fragment spliced from multiple sentences\n  const trimmed = text.trim();\n  if (/\\.\\s+[a-zA-Z]/.test(trimmed) && !trimmed.endsWith(\")\")) {\n    return true;\n  }\n\n  // Multi-word candidate containing a garbled OCR fragment: a short lowercase word that isn't a known short word\n  if (words.length >= 2) {\n    const commonShort2 = new Set([\n      \"a\", \"i\", \"of\", \"or\", \"to\", \"in\", \"on\", \"is\", \"it\", \"an\",\n      \"as\", \"at\", \"by\", \"do\", \"go\", \"if\", \"no\", \"so\", \"up\", \"we\",\n      \"w\", \"z\",  // Polish prepositions\n    ]);\n    const hasGarbledWord = words.some(\n      (w) =>\n        /^[a-z]/.test(w) &&\n        w.replace(/[^a-z]/g, \"\").length <= 2 &&\n        !commonShort2.has(w.toLowerCase())\n    );\n    if (hasGarbledWord) {\n      return true;\n    }\n  }\n\n  return false;\n}\n\nfunction passesHardFilters(text: string): boolean {\n  if (text.length < 3 || text.length > 80) return false;\n  if (looksLikeIngredient(text)) return false;\n  if (startsWithNumber(text)) return false;\n  if (looksLikeMetadata(text)) return false;\n  if (isLikelyGarbled(text)) return false;\n  // Pipe-separated lines are book category/chapter headers, not recipe titles\n  if (text.includes(\" | \")) return false;\n  // Bullet-list items (ingredients or instruction steps) are never titles\n  if (/^\\s*[-•*]\\s/.test(text)) return false;\n  // Known recipe section labels are structural headers, not titles\n  if (isSectionLabel(text)) return false;\n  // Single-word non-title fragments\n  const words = text.trim().split(/\\s+/);\n  if (words.length === 1 && NON_TITLE_WORDS.has(text.trim().toLowerCase())) return false;\n  return true;\n}\n\n/**\n * Detect initial burst of short garbled lines.\n * Returns the index of the first non-garbled or long line.\n */\nfunction findBurstEnd(lines: Array<{ text: string }>): number {\n  let i = 0;\n  while (i < lines.length && lines[i].text.length < 20 && isLikelyGarbled(lines[i].text)) {\n    i++;\n  }\n  return i;\n}\n\nfunction wordCount(text: string): number {\n  return text.split(/\\s+/).filter((w) => w.length > 0).length;\n}\n\n/**\n * Build candidate strings from lines: single lines plus multi-line joins (2-3 consecutive).\n * Skips initial burst of short garbled lines. Scans all remaining lines. Caps at 25.\n */\nexport type CandidateOrigin = \"single\" | \"2-line\" | \"3-line\";\n\nfunction buildCandidates(\n  lines: Array<string>\n): Array<{ text: string; position: number; origin: CandidateOrigin }> {\n  const nonEmptyLines: Array<{ text: string; index: number }> = [];\n\n  for (let i = 0; i < lines.length; i++) {\n    const trimmed = lines[i].trim();\n    if (trimmed.length > 0) {\n      nonEmptyLines.push({ text: trimmed, index: i });\n    }\n  }\n\n  const burstEnd = findBurstEnd(nonEmptyLines);\n\n  // Pre-merge consecutive short ALL_CAPS lines (OCR-fragmented headings).\n  // When a sequence of 2+ ALL_CAPS lines each has ≤2 words and ≤25 chars, they are\n  // almost certainly OCR fragments of a single heading. Merge them into one line so\n  // the complete title enters the candidate pool without hitting the 3-line join ceiling.\n  const capsCoalesced: Array<{ text: string; index: number }> = [];\n  let ci = burstEnd;\n  while (ci < nonEmptyLines.length) {\n    const line = nonEmptyLines[ci];\n    if (\n      isAllCaps(line.text) &&\n      wordCount(line.text) <= 2 &&\n      line.text.length <= 25 &&\n      !isSectionLabel(line.text) &&\n      !looksLikeMetadata(line.text)\n    ) {\n      let merged = line.text;\n      const startIndex = line.index;\n      let j = ci + 1;\n      while (j < nonEmptyLines.length) {\n        const next = nonEmptyLines[j];\n        if (\n          isAllCaps(next.text) &&\n          wordCount(next.text) <= 2 &&\n          next.text.length <= 25 &&\n          !isSectionLabel(next.text) &&\n          !looksLikeMetadata(next.text) &&\n          (merged + \" \" + next.text).length <= 80\n        ) {\n          merged += \" \" + next.text;\n          j++;\n        } else {\n          break;\n        }\n      }\n      if (j > ci + 1) {\n        capsCoalesced.push({ text: merged, index: startIndex });\n        ci = j;\n        continue;\n      }\n    }\n    capsCoalesced.push(line);\n    ci++;\n  }\n\n  // Pre-merge continuation lines: a line starting with /&+:( is never a standalone title.\n  // Merge it into the preceding line so the complete title enters the pool as a single candidate,\n  // avoiding the fragile chain of conditions required by the downstream join survival logic.\n  // Limitation: only one continuation line per preceding line is merged. Titles split across\n  // three or more lines with continuation tokens (rare in practice) are not handled here —\n  // the downstream 2-line and 3-line join candidates cover those cases instead.\n  const mergedLines: Array<{ text: string; index: number }> = [];\n  for (let i = 0; i < capsCoalesced.length; i++) {\n    const line = capsCoalesced[i];\n    if (i + 1 < capsCoalesced.length) {\n      const nextText = capsCoalesced[i + 1].text;\n      if (/^[/&+:(]/.test(nextText)) {\n        mergedLines.push({ text: `${line.text} ${nextText}`, index: line.index });\n        i++;\n        continue;\n      }\n    }\n    mergedLines.push(line);\n  }\n\n  const candidates: Array<{ text: string; position: number; origin: CandidateOrigin }> = [];\n  const seen = new Set<string>();\n\n  for (let i = 0; i < mergedLines.length; i++) {\n    const line = mergedLines[i];\n\n    // Single line\n    if (passesHardFilters(line.text)) {\n      const norm = line.text.toLowerCase();\n      if (!seen.has(norm)) {\n        seen.add(norm);\n        candidates.push({ text: line.text, position: line.index, origin: \"single\" });\n      }\n    }\n\n    // 2-line join — skip if first line is a section label (prevents \"INGREDIENTS TITLE\" joins)\n    if (i + 1 < mergedLines.length && !isSectionLabel(line.text)) {\n      const joined2 = `${line.text} ${mergedLines[i + 1].text}`;\n      if (passesHardFilters(joined2)) {\n        const norm = joined2.toLowerCase();\n        if (!seen.has(norm)) {\n          seen.add(norm);\n          candidates.push({ text: joined2, position: line.index, origin: \"2-line\" });\n        }\n      }\n    }\n\n    // 3-line join — skip if first line is a section label\n    if (i + 2 < mergedLines.length && !isSectionLabel(line.text)) {\n      const joined3 = `${line.text} ${mergedLines[i + 1].text} ${mergedLines[i + 2].text}`;\n      if (passesHardFilters(joined3)) {\n        const norm = joined3.toLowerCase();\n        if (!seen.has(norm)) {\n          seen.add(norm);\n          candidates.push({ text: joined3, position: line.index, origin: \"3-line\" });\n        }\n      }\n    }\n  }\n\n  // Pre-filter to 25 before embedding calls: prefer ALL_CAPS and short candidates.\n  // Position-based scoring handles final ranking.\n  if (candidates.length > 25) {\n    const prioritized = candidates.slice().sort((a, b) => {\n      const aAllCaps = isAllCaps(a.text) ? 0 : 1;\n      const bAllCaps = isAllCaps(b.text) ? 0 : 1;\n      if (aAllCaps !== bAllCaps) return aAllCaps - bAllCaps;\n      const aShort = wordCount(a.text) <= 5 ? 0 : 1;\n      const bShort = wordCount(b.text) <= 5 ? 0 : 1;\n      return aShort - bShort;\n    });\n    return prioritized.slice(0, 25);\n  }\n\n  return candidates;\n}\n\n// Module-level cache for reference embeddings\nlet cachedTitleRefEmbedding: Array<number> | null = null;\nlet cachedHeaderRefEmbedding: Array<number> | null = null;\nlet cachedNoiseRefEmbedding: Array<number> | null = null;\n\nexport function _resetEmbeddingCacheForTests(): void {\n  cachedTitleRefEmbedding = null;\n  cachedHeaderRefEmbedding = null;\n  cachedNoiseRefEmbedding = null;\n}\n\nexport async function extractTitleWithEmbeddings(\n  text: string,\n  embed: EmbedFn\n): Promise<string | undefined> {\n  if (!text || text.trim().length === 0) {\n    return undefined;\n  }\n\n  const lines = text.split(\"\\n\");\n  const candidates = buildCandidates(lines);\n\n  if (candidates.length === 0) {\n    return undefined;\n  }\n\n  // Cache reference embeddings\n  if (!cachedTitleRefEmbedding) {\n    cachedTitleRefEmbedding = await embed(TITLE_REFERENCE);\n  }\n  if (!cachedHeaderRefEmbedding) {\n    cachedHeaderRefEmbedding = await embed(HEADER_REFERENCE);\n  }\n  if (!cachedNoiseRefEmbedding) {\n    cachedNoiseRefEmbedding = await embed(NOISE_REFERENCE);\n  }\n\n  // Find ALL_CAPS candidates with ≥2 words where every significant word has ≥4 alpha letters.\n  // Insignificant tokens (≤1 alpha letter: \"/\", \"&\", \"+\", \":\", \"D)\", etc.) are filtered before\n  // the check so that multi-line joins with continuation punctuation still qualify.\n  const isStructuralHeading = (c: { text: string }): boolean => {\n    if (!isAllCaps(c.text) || wordCount(c.text) < 2) return false;\n    const sigWords = c.text.trim().split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length > 1);\n    return sigWords.length >= 2 && sigWords.every((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n  };\n\n  // Pass 1: compute rawScore for all candidates (embedding quality signal)\n  const rawScored: Array<{ text: string; position: number; origin: CandidateOrigin; rawScore: number; embedding: Array<number> }> = [];\n  for (const candidate of candidates) {\n    const embedding = await embed(candidate.text);\n    const titleSim = cosineSimilarity(embedding, cachedTitleRefEmbedding);\n    const headerSim = cosineSimilarity(embedding, cachedHeaderRefEmbedding);\n    const noiseSim = cosineSimilarity(embedding, cachedNoiseRefEmbedding);\n    const rawScore = titleSim - Math.max(headerSim, noiseSim);\n    rawScored.push({ text: candidate.text, position: candidate.position, origin: candidate.origin, rawScore, embedding });\n  }\n\n  // Select baseHeading by embedding quality (rawScore), not position.\n  // This prevents OCR-garbled fragments from claiming the structural heading slot.\n  const structuralCandidates = rawScored.filter((s) => isStructuralHeading(s));\n\n  // Penalize structural headings with truncated OCR words:\n  // if \"FRON\" appears and another heading has \"SAFFRON\", \"FRON\" is likely garbled.\n  for (const sc of structuralCandidates) {\n    const sigWords = sc.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n    for (const other of structuralCandidates) {\n      if (other === sc) continue;\n      const otherSigWords = other.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n      const hasTruncation = sigWords.some((w) =>\n        otherSigWords.some((ow) => ow !== w && ow.length > w.length && ow.endsWith(w))\n      );\n      if (hasTruncation) {\n        sc.rawScore = -1.0;  // Hard disqualification — truncated OCR artifact\n        break;\n      }\n    }\n  }\n\n  const bestStructural = structuralCandidates.length > 0\n    ? structuralCandidates.reduce((a, b) => {\n        const scoreDiff = a.rawScore - b.rawScore;\n        if (Math.abs(scoreDiff) > 0.03) return scoreDiff > 0 ? a : b;\n        // Tiebreak: single-line origin beats multi-line joins (avoids conflating two separate headings)\n        if (a.origin === \"single\" && b.origin !== \"single\") return a;\n        if (b.origin === \"single\" && a.origin !== \"single\") return b;\n        // Tiebreak: more words (more specific) → better\n        const wcDiff = wordCount(b.text) - wordCount(a.text);\n        if (wcDiff !== 0) return wcDiff > 0 ? b : a;\n        // Tiebreak: earlier position → better\n        return a.position < b.position ? a : b;\n      })\n    : null;\n  const baseHeading = bestStructural ?? undefined;\n\n  // When the best structural heading has a continuation on the next line introduced by a\n  // punctuation token (/, &, +, :, or parenthesis), prefer the longer 2-line join as the\n  // complete heading. E.g. \"SAFFRON WHEAT BUNS WITH QUARK\" + \"/ COTTAGE CHEESE (VARIATION D)\".\n  // Guard: the remainder after the prefix must start with a continuation character to avoid\n  // merging two separate consecutive recipe titles (FINNISH MILK FLATBREADS stays separate\n  // from FINNISH POTATO FLATBREADS because \"FINNISH\" does not start with a continuation token).\n  const firstStructuralHeading = baseHeading && (\n    rawScored.find((c) => {\n      if (!isStructuralHeading(c)) return false;\n      const hLower = baseHeading.text.toLowerCase();\n      const cLower = c.text.toLowerCase();\n      return cLower.startsWith(hLower + \" \") && /^[/&+:(]/.test(cLower.slice(hLower.length + 1));\n    }) ?? baseHeading\n  );\n\n  // Pass 2: apply bonuses\n  const scored: Array<{ text: string; position: number; origin: CandidateOrigin; score: number; rawScore: number; baseScore: number; thresholdScore: number }> = rawScored.map((rs) => {\n    // Position factor: multiplicative tiebreaker — amplifies existing signal, doesn't replace it\n    const relativePosition = rs.position / lines.length;\n    const positionFactor = relativePosition < 0.5\n      ? 1.0 + 0.12 * (1 - relativePosition * 2)\n      : 1.0;\n\n    // ALL_CAPS bonus: recipe books use ALL_CAPS for titles and section headings\n    const allCapsBonus = isAllCaps(rs.text) && rs.text.replace(/[^a-zA-Z]/g, \"\").length >= 4\n      ? 0.08\n      : 0;\n\n    // Structural heading bonus: best ALL_CAPS heading (or its continuation join) is almost always the recipe title\n    const structuralBonus = firstStructuralHeading && rs.text === firstStructuralHeading.text ? 0.10 : 0;\n\n    // thresholdScore excludes structural bonus so the bonus doesn't inflate the threshold\n    // and prevent equally-valid structural headings from passing on multi-recipe pages.\n    const thresholdScore = rs.rawScore + allCapsBonus;\n    // baseScore excludes position factor — used for diagnostics and ranking\n    const baseScore = rs.rawScore + allCapsBonus + structuralBonus;\n    const score = rs.rawScore * positionFactor + allCapsBonus + structuralBonus;\n    return { text: rs.text, position: rs.position, origin: rs.origin, score, rawScore: rs.rawScore, baseScore, thresholdScore };\n  });\n\n  if (scored.length === 0) {\n    return undefined;\n  }\n\n  // --- Pre-threshold bilingual title detection ---\n  // When a mixed-case candidate at position 0 is followed by an ALL_CAPS candidate\n  // at position ≤ 2 that is semantically similar to it, this is a bilingual recipe\n  // page (e.g., Polish title + ALL_CAPS Korean romanization). Suppress confirmed\n  // translation candidates before computing threshold so their bonuses don't inflate\n  // the threshold beyond the mixed-case title's reach.\n  // Note: we check position ≤ 2 (local proximity), not global ALL_CAPS count, so\n  // section headers later in the document (SKŁADNIKI, WARZYWA, etc.) are irrelevant.\n  let scoredForThreshold = scored;\n  const prePos0 = scored.find((s) => s.position === 0 && !isAllCaps(s.text));\n  if (prePos0) {\n    const nearbyAllCaps = scored.filter(\n      (s) => isAllCaps(s.text) && s.position >= 1 && s.position <= 2 && s.origin === \"single\"\n    );\n    const pos0Embedding = rawScored.find((r) => r.text === prePos0.text)?.embedding;\n\n    let translationCandidates: typeof nearbyAllCaps = [];\n\n    // Method 1: embedding similarity (works for related languages)\n    if (pos0Embedding && nearbyAllCaps.length > 0) {\n      translationCandidates = nearbyAllCaps.filter((cap) => {\n        const capEmbedding = rawScored.find((r) => r.text === cap.text)?.embedding;\n        if (!capEmbedding) return false;\n        return cosineSimilarity(pos0Embedding, capEmbedding) > 0.4;\n      });\n    }\n\n    // Method 2: layout-based detection (cross-lingual fallback).\n    // When embedding similarity is insufficient (e.g. Polish ↔ Korean romanization),\n    // detect bilingual layout by position and word overlap:\n    // mixed-case ≥2 words at pos 0 + ALL_CAPS ≥2 words at pos 1-2 with no shared words.\n    if (translationCandidates.length === 0 && wordCount(prePos0.text) >= 2) {\n      const pos0Words = new Set(\n        prePos0.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2)\n      );\n      translationCandidates = nearbyAllCaps.filter((cap) => {\n        if (wordCount(cap.text) < 2) return false;\n        const capWords = cap.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2);\n        return !capWords.some((w) => pos0Words.has(w));\n      });\n    }\n\n    if (translationCandidates.length > 0) {\n      // Also suppress multi-line joins that start with the translation text\n      // (e.g. \"PAPRIKA GYERAN-JJIM Ingredients\" starts with \"PAPRIKA GYERAN-JJIM\")\n      scoredForThreshold = scored.filter((s) => {\n        const sLower = s.text.toLowerCase();\n        return !translationCandidates.some((t) => sLower.startsWith(t.text.toLowerCase()));\n      });\n    }\n  }\n\n  // Use thresholdScore (excludes structural bonus) so the structural bonus doesn't inflate\n  // the threshold and block equally-valid headings on multi-recipe pages.\n  const bestThresholdScore = Math.max(...scoredForThreshold.map((s) => s.thresholdScore));\n  const threshold = Math.max(0.08, bestThresholdScore * 0.7);\n\n  // Filter candidates above threshold\n  let selected = scoredForThreshold.filter((s) => s.score >= threshold);\n\n  // Empty-pool fallback: when threshold filtering discards every candidate,\n  // the hard filters' structural verdict should not be overruled by weak\n  // embedding differentiation. Return the best positional candidate.\n  if (selected.length === 0 && scored.length > 0) {\n    const fallback = scored\n      .slice()\n      .sort((a, b) => a.position - b.position || b.score - a.score);\n    selected = [fallback[0]];\n  }\n\n  // Remove word-boundary prefixes of firstStructuralHeading when the heading itself survived\n  // the threshold. Cases:\n  //   ARAYES case:  firstStructuralHeading = \"ARAYES SHRAK\" (2-word join qualifies; \"ARAYES\"\n  //     alone = 1 word, so it never qualified). Filter removes \"ARAYES\" so dedup keeps the join.\n  //   SAFFRON case: baseHeading was the partial line; continuation logic above upgraded\n  //     firstStructuralHeading to the full join. Filter removes the partial so dedup keeps join.\n  // Safety: only fires when the complete heading itself is in selected (passed the threshold).\n  if (firstStructuralHeading && selected.some((s) => s.text === firstStructuralHeading.text)) {\n    const fshLower = firstStructuralHeading.text.toLowerCase();\n    selected = selected.filter((s) => {\n      if (s.text === firstStructuralHeading.text) return true;\n      const sLower = s.text.toLowerCase();\n      // Remove s if it is a space-delimited prefix of the structural heading\n      return !fshLower.startsWith(sLower + \" \");\n    });\n  }\n\n  // Protect continuation joins: when a multi-line join (2-line or 3-line) survived the threshold\n  // and its second part starts with a continuation character, remove the single-line prefix/suffix\n  // so the dedup \"shorter wins\" rule doesn't destroy the complete join.\n  // Note: the pre-merge step above already handles the common Baked Eggs case (&/continuation\n  // on next line) by turning it into a single candidate — this block covers the rarer case where\n  // a continuation-character join was generated as a 2-line/3-line candidate and the prefix\n  // single also survived threshold independently (e.g. from a different code path or OCR layout).\n  // Safety: only fires for joins whose continuation starts with /&+:( — digit continuations\n  // like \"Pierogi Ruskie 200g mąki\" are NOT protected, so dedup correctly keeps the shorter form.\n  const survivingJoins = selected.filter((s) => s.origin === \"2-line\" || s.origin === \"3-line\");\n  if (survivingJoins.length > 0) {\n    selected = selected.filter((s) => {\n      if (s.origin !== \"single\") return true;\n      const sLower = s.text.toLowerCase();\n      // Remove PREFIX singles whose continuation join also survived\n      const isPrefixOfJoin = survivingJoins.some((j) => {\n        const jLower = j.text.toLowerCase();\n        if (!jLower.startsWith(sLower + \" \")) return false;\n        const remainder = jLower.slice(sLower.length + 1);\n        return /^[/&+:(]/.test(remainder);\n      });\n      if (isPrefixOfJoin) return false;\n      // Remove SUFFIX singles (e.g. \"& Coriander\") whose parent join also survived\n      const isSuffixOfJoin = survivingJoins.some((j) => {\n        const jLower = j.text.toLowerCase();\n        if (!jLower.endsWith(\" \" + sLower)) return false;\n        // Only remove if the suffix starts with a continuation character\n        return /^[/&+:(]/.test(sLower);\n      });\n      if (isSuffixOfJoin) return false;\n      return true;\n    });\n  }\n\n  // Pre-dedup: remove sub-section headers that are substrings of other surviving candidates.\n  // A sub-section header is an ALL_CAPS candidate followed by ingredient-like lines in the source.\n  // Example: \"CHLEBEK\" (bread section header, followed by \"500 g mąki\") is a substring of\n  // \"CHLEBEK Z WARZYWAMI I BOCZKIEM\" (the real title). Without this filter, dedup kills the title.\n  selected = selected.filter((candidate) => {\n    if (!isAllCaps(candidate.text)) return true;\n    // Check if this candidate is immediately followed by ingredient-like content\n    const nextSourceLines = lines.slice(candidate.position + 1, candidate.position + 2);\n    const followedByIngredients = nextSourceLines.some(\n      (l) => looksLikeIngredient(l.trim()) || startsWithNumber(l.trim())\n    );\n    if (!followedByIngredients) return true;\n    // Only remove if a longer candidate contains this one as a substring\n    const candidateLower = candidate.text.toLowerCase();\n    const hasLongerParent = rawScored.some(\n      (other) =>\n        other.text !== candidate.text &&\n        other.text.length > candidate.text.length &&\n        other.text.toLowerCase().includes(candidateLower)\n    );\n    return !hasLongerParent;\n  });\n\n  // Deduplicate: if one title is a substring of another, keep the shorter (more focused) one.\n  // DO NOT CHANGE THIS LOGIC — it has been incorrectly \"improved\" by the title-loop 5 times