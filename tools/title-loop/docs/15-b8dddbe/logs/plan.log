{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AkEWG6JemGdP2EMnJWvJBM","type":"tool_result","content":"     1→import {\n     2→  extractTitle,\n     3→  extractTitleWithEmbeddings,\n     4→  _resetEmbeddingCacheForTests,\n     5→} from \"../title-extractor\";\n     6→\n     7→/**\n     8→ * Creates a mock embed function that returns predictable vectors.\n     9→ * Words matching titleWords get a vector pointing \"toward titles\",\n    10→ * words matching headerWords get a vector pointing \"toward headers\",\n    11→ * and everything else gets a neutral vector.\n    12→ */\n    13→function createMockEmbed(\n    14→  titleWords: Array<string>,\n    15→  headerWords: Array<string>\n    16→): (text: string) => Promise<Array<number>> {\n    17→  // Reference phrases from the module\n    18→  const TITLE_REF =\n    19→    \"recipe name, dish title, name of the food, nazwa przepisu, nazwa dania\";\n    20→  const HEADER_REF =\n    21→    \"ingredients list, cooking directions, section heading, składniki, przygotowanie, sposób wykonania\";\n    22→  const NOISE_REF =\n    23→    \"page number, table of contents, book footer, garbled text\";\n    24→\n    25→  return async (text: string): Promise<Array<number>> => {\n    26→    const lower = text.toLowerCase();\n    27→\n    28→    // Title reference → unit vector in dimension 0\n    29→    if (lower === TITLE_REF.toLowerCase()) {\n    30→      return [1, 0, 0];\n    31→    }\n    32→    // Header reference → unit vector in dimension 1\n    33→    if (lower === HEADER_REF.toLowerCase()) {\n    34→      return [0, 1, 0];\n    35→    }\n    36→    // Noise reference → unit vector in dimension 2 (orthogonal)\n    37→    if (lower === NOISE_REF.toLowerCase()) {\n    38→      return [0, 0, 1];\n    39→    }\n    40→\n    41→    // Check if text contains title-like words → high cosine with title ref\n    42→    const isTitle = titleWords.some((w) => lower.includes(w.toLowerCase()));\n    43→    // Check if text contains header-like words → high cosine with header ref\n    44→    const isHeader = headerWords.some((w) => lower.includes(w.toLowerCase()));\n    45→\n    46→    if (isTitle && !isHeader) {\n    47→      return [0.9, 0.1, 0]; // High title similarity, low header similarity\n    48→    }\n    49→    if (isHeader && !isTitle) {\n    50→      return [0.1, 0.9, 0]; // Low title similarity, high header similarity\n    51→    }\n    52→    if (isTitle && isHeader) {\n    53→      return [0.5, 0.5, 0]; // Ambiguous\n    54→    }\n    55→    // Neutral\n    56→    return [0.3, 0.3, 0.7];\n    57→  };\n    58→}\n    59→\n    60→describe(\"extractTitle (heuristic)\", () => {\n    61→  it(\"returns undefined for empty text\", () => {\n    62→    expect(extractTitle(\"\")).toBeUndefined();\n    63→    expect(extractTitle(\"  \")).toBeUndefined();\n    64→  });\n    65→\n    66→  it(\"returns the first valid line\", () => {\n    67→    expect(extractTitle(\"Chicken Soup\\nIngredients\\n1 cup water\")).toBe(\n    68→      \"Chicken Soup\"\n    69→    );\n    70→  });\n    71→\n    72→  it(\"skips lines that are too short or too long\", () => {\n    73→    const longLine = \"A\".repeat(51);\n    74→    expect(extractTitle(`ab\\n${longLine}\\nGood Title`)).toBe(\"Good Title\");\n    75→  });\n    76→\n    77→  it(\"skips ingredient lines\", () => {\n    78→    expect(extractTitle(\"2 cups flour\\nApple Pie\")).toBe(\"Apple Pie\");\n    79→  });\n    80→\n    81→  it(\"skips all-caps lines\", () => {\n    82→    expect(extractTitle(\"INGREDIENTS\\nChocolate Cake\")).toBe(\"Chocolate Cake\");\n    83→  });\n    84→\n    85→  it(\"skips lines starting with numbers\", () => {\n    86→    expect(extractTitle(\"12\\nApple Pie\")).toBe(\"Apple Pie\");\n    87→  });\n    88→});\n    89→\n    90→describe(\"extractTitleWithEmbeddings\", () => {\n    91→  beforeEach(() => {\n    92→    _resetEmbeddingCacheForTests();\n    93→  });\n    94→\n    95→  it(\"returns undefined for empty text\", async () => {\n    96→    const embed = createMockEmbed([], []);\n    97→    expect(await extractTitleWithEmbeddings(\"\", embed)).toBeUndefined();\n    98→    expect(await extractTitleWithEmbeddings(\"  \", embed)).toBeUndefined();\n    99→  });\n   100→\n   101→  it(\"picks title over section header (Polish)\", async () => {\n   102→    const embed = createMockEmbed([\"pierogi ruskie\"], [\"składniki\"]);\n   103→    const text = \"Składniki\\nPierogi Ruskie\\n200g mąki\\n3 ziemniaki\";\n   104→    const result = await extractTitleWithEmbeddings(text, embed);\n   105→    expect(result).toBe(\"Pierogi Ruskie\");\n   106→  });\n   107→\n   108→  it(\"picks title over section header (English)\", async () => {\n   109→    const embed = createMockEmbed([\"chicken soup\"], [\"ingredients\"]);\n   110→    const text = \"Ingredients\\nChicken Soup\\n1 cup water\\nSalt\";\n   111→    const result = await extractTitleWithEmbeddings(text, embed);\n   112→    expect(result).toBe(\"Chicken Soup\");\n   113→  });\n   114→\n   115→  it(\"preserves all-caps titles\", async () => {\n   116→    const embed = createMockEmbed([\"chocolate cake\"], [\"ingredients\"]);\n   117→    const text = \"CHOCOLATE CAKE\\nIngredients\\n200g flour\";\n   118→    const result = await extractTitleWithEmbeddings(text, embed);\n   119→    expect(result).toBe(\"CHOCOLATE CAKE\");\n   120→  });\n   121→\n   122→  it(\"skips numbered lines\", async () => {\n   123→    const embed = createMockEmbed([\"apple pie\"], []);\n   124→    const text = \"12\\nApple Pie\\nSome instructions\";\n   125→    const result = await extractTitleWithEmbeddings(text, embed);\n   126→    expect(result).toBe(\"Apple Pie\");\n   127→  });\n   128→\n   129→  it(\"joins multi-line title (2 lines)\", async () => {\n   130→    const embed = createMockEmbed(\n   131→      [\"kurczak w sosie śmietanowym z pieczarkami\"],\n   132→      [\"składniki\"]\n   133→    );\n   134→    const text =\n   135→      \"Kurczak w sosie\\nśmietanowym z pieczarkami\\nSkładniki\\n200g kurczaka\";\n   136→    const result = await extractTitleWithEmbeddings(text, embed);\n   137→    expect(result).toBe(\"Kurczak w sosie śmietanowym z pieczarkami\");\n   138→  });\n   139→\n   140→  it(\"joins multi-line title (3 lines)\", async () => {\n   141→    const embed = createMockEmbed(\n   142→      [\"makaron z sosem pomidorowym i bazylią\"],\n   143→      [\"składniki\"]\n   144→    );\n   145→    const text =\n   146→      \"Makaron z sosem\\npomidorowym\\ni bazylią\\nSkładniki\\n300g makaronu\";\n   147→    const result = await extractTitleWithEmbeddings(text, embed);\n   148→    expect(result).toBe(\"Makaron z sosem pomidorowym i bazylią\");\n   149→  });\n   150→\n   151→  it(\"does not over-greedily join title with header\", async () => {\n   152→    const embed = createMockEmbed([\"apple pie\"], [\"ingredients\"]);\n   153→    const text = \"Apple Pie\\nIngredients\\n200g flour\";\n   154→    const result = await extractTitleWithEmbeddings(text, embed);\n   155→    // Should prefer \"Apple Pie\" alone, not \"Apple Pie Ingredients\"\n   156→    expect(result).toBe(\"Apple Pie\");\n   157→  });\n   158→\n   159→  it(\"returns multiple titles joined with + when both score well\", async () => {\n   160→    const embed = createMockEmbed(\n   161→      [\"first recipe\", \"second recipe\"],\n   162→      []\n   163→    );\n   164→    const text = \"First Recipe\\nSecond Recipe\\nSome other text\";\n   165→    const result = await extractTitleWithEmbeddings(text, embed);\n   166→    expect(result).toBe(\"First Recipe + Second Recipe\");\n   167→  });\n   168→\n   169→  it(\"skips burst of short lines at start and finds title after\", async () => {\n   170→    const embed = createMockEmbed([\"beef stew\"], [\"ingredients\"]);\n   171→    // 3+ short garbled lines at start, then real content with a long line\n   172→    const text =\n   173→      \"pg 42\\nA.\\nfoo\\nThis is a longer line that triggers burst end detection\\nBeef Stew\\nIngredients\\n500g beef\";\n   174→    const result = await extractTitleWithEmbeddings(text, embed);\n   175→    expect(result).toBe(\"Beef Stew\");\n   176→  });\n   177→\n   178→  it(\"two titles deep in text returns both joined\", async () => {\n   179→    const embed = createMockEmbed(\n   180→      [\"pasta carbonara\", \"tiramisu classico\"],\n   181→      [\"ingredients\", \"składniki\"]\n   182→    );\n   183→    const text =\n   184→      \"Ingredients\\nPasta Carbonara\\n200g pasta\\n100g guanciale\\nIngredients\\nTiramisu Classico\\n250g mascarpone\";\n   185→    const result = await extractTitleWithEmbeddings(text, embed);\n   186→    expect(result).toBe(\"Pasta Carbonara + Tiramisu Classico\");\n   187→  });\n   188→\n   189→  it(\"single-recipe page still returns one title\", async () => {\n   190→    const embed = createMockEmbed([\"tomato soup\"], [\"ingredients\"]);\n   191→    const text = \"Tomato Soup\\nIngredients\\n4 tomatoes\\n1 cup cream\\nSalt\";\n   192→    const result = await extractTitleWithEmbeddings(text, embed);\n   193→    expect(result).toBe(\"Tomato Soup\");\n   194→  });\n   195→\n   196→  it(\"keeps 2-word ALL_CAPS join over its single-word prefix (ARAYES-type)\", async () => {\n   197→    // \"ARAYES\" alone is 1 word → never qualifies as firstStructuralHeading.\n   198→    // \"ARAYES SHRAK\" qualifies → pre-filter removes \"ARAYES\" so dedup keeps the join.\n   199→    const embed = createMockEmbed([\"arayes\"], [\"ingredients\"]);\n   200→    const text = \"ARAYES\\nSHRAK\\nIngredients\\n2 cups flour\";\n   201→    const result = await extractTitleWithEmbeddings(text, embed);\n   202→    expect(result).toBe(\"ARAYES SHRAK\");\n   203→  });\n   204→\n   205→  it(\"extends ALL_CAPS structural heading when next line starts with continuation token (SAFFRON-type)\", async () => {\n   206→    // \"TITLE FIRST PART\" qualifies as structural heading; continuation upgrades it to the join.\n   207→    // Pre-filter then removes the partial so dedup keeps the complete join.\n   208→    const embed = createMockEmbed([\"title first part\"], [\"ingredients\"]);\n   209→    const text = \"TITLE FIRST PART\\n/ SECOND PART\\nIngredients\\n1 cup flour\";\n   210→    const result = await extractTitleWithEmbeddings(text, embed);\n   211→    expect(result).toBe(\"TITLE FIRST PART / SECOND PART\");\n   212→  });\n   213→\n   214→  it(\"pre-merges continuation line starting with & into preceding line (Baked Eggs type)\", async () => {\n   215→    // \"& Coriander\" starts with & so it's merged into the preceding line before candidate\n   216→    // generation — the complete title enters the pool as a single candidate.\n   217→    const embed = createMockEmbed(\n   218→      [\"baked eggs with feta\"],\n   219→      [\"ingredients\"]\n   220→    );\n   221→    const text =\n   222→      \"Baked Eggs with Feta, Harissa Tomato Sauce\\n& Coriander\\nIngredients\\n2 eggs\";\n   223→    const result = await extractTitleWithEmbeddings(text, embed);\n   224→    expect(result).toBe(\"Baked Eggs with Feta, Harissa Tomato Sauce & Coriander\");\n   225→  });\n   226→\n   227→  it(\"does not pre-merge second line that lacks a continuation character (ARAYES-type safety)\", async () => {\n   228→    // \"SHRAK\" does not start with /&+:( so it is NOT pre-merged.\n   229→    // The existing structural heading join logic handles it instead.\n   230→    const embed = createMockEmbed([\"arayes\"], [\"ingredients\"]);\n   231→    const text = \"ARAYES\\nSHRAK\\nIngredients\\n2 cups flour\";\n   232→    const result = await extractTitleWithEmbeddings(text, embed);\n   233→    expect(result).toBe(\"ARAYES SHRAK\");\n   234→  });\n   235→\n   236→  it(\"returns only the first ALL_CAPS heading when subsequent ALL_CAPS headings are section headers followed by ingredients (CHLEBEK type)\", async () => {\n   237→    // WARZYWA I BOCZEK is immediately followed by ingredient lines (numbers) →\n   238→    // it's a section header, not a second recipe title. Keep only CHLEBEK Z WARZYWAMI I BOCZKIEM.\n   239→    const embed = createMockEmbed(\n   240→      [\"chlebek z warzywami i boczkiem\", \"warzywa i boczek\"],\n   241→      []\n   242→    );\n   243→    const text = [\n   244→      \"CHLEBEK Z WARZYWAMI I BOCZKIEM\",\n   245→      \"WARZYWA I BOCZEK\",\n   246→      \"500 g strączków zielonego groszku\",\n   247→      \"1 żółta papryka\",\n   248→      \"CHLEBEK\",\n   249→      \"500 g mąki\",\n   250→    ].join(\"\\n\");\n   251→    const result = await extractTitleWithEmbeddings(text, embed);\n   252→    expect(result).toBe(\"CHLEBEK Z WARZYWAMI I BOCZKIEM\");\n   253→  });\n   254→\n   255→  it(\"returns both ALL_CAPS titles when headings are NOT followed by ingredient lines (FINNISH-type)\", async () => {\n   256→    // POTATO FLATBREADS is followed by body text, not ingredients →\n   257→    // these are two separate recipe titles on a multi-recipe page.\n   258→    const embed = createMockEmbed(\n   259→      [\"milk flatbreads\", \"potato flatbreads\"],\n   260→      []\n   261→    );\n   262→    const text = [\n   263→      \"MILK FLATBREADS\",\n   264→      \"Mix flour with milk and knead\",\n   265→      \"Cook on a dry skillet\",\n   266→      \"POTATO FLATBREADS\",\n   267→      \"Boil potatoes until tender\",\n   268→      \"Mash well before mixing\",\n   269→    ].join(\"\\n\");\n   270→    const result = await extractTitleWithEmbeddings(text, embed);\n   271→    expect(result).toBe(\"MILK FLATBREADS + POTATO FLATBREADS\");\n   272→  });\n   273→\n   274→  it(\"filters bullet-list lines so real title wins\", async () => {\n   275→    const embed = createMockEmbed([\"mozzarella sticks\"], []);\n   276→    const text = \"MOZZARELLA STICKS\\n- 2 tbsp sugar\\n- Salt to taste\";\n   277→    const result = await extractTitleWithEmbeddings(text, embed);\n   278→    expect(result).toBe(\"MOZZARELLA STICKS\");\n   279→  });\n   280→\n   281→  it(\"filters INGREDIENTS section label so real ALL_CAPS title wins\", async () => {\n   282→    const embed = createMockEmbed([\"mozzarella sticks\"], []);\n   283→    const text = \"INGREDIENTS\\nMOZZARELLA STICKS\\n- 2 tbsp sugar\";\n   284→    const result = await extractTitleWithEmbeddings(text, embed);\n   285→    expect(result).toBe(\"MOZZARELLA STICKS\");\n   286→  });\n   287→\n   288→  it(\"filters compact metric ingredient lines so real title wins\", async () => {\n   289→    const embed = createMockEmbed([\"barszcz czerwony\"], []);\n   290→    const text = \"BARSZCZ CZERWONY\\n100g buraków\\n50ml bulionu\";\n   291→    const result = await extractTitleWithEmbeddings(text, embed);\n   292→    expect(result).toBe(\"BARSZCZ CZERWONY\");\n   293→  });\n   294→\n   295→  it(\"prefers mixed-case title at position 0 over ALL_CAPS subtitle at position 1 (bilingual page)\", async () => {\n   296→    // \"Faszerowana papryka\" is the Polish title at position 0 (mixed-case).\n   297→    // \"PAPRIKA GYERAN-JJIM\" is an ALL_CAPS romanization at position 1 — treated as subtitle.\n   298→    const embed = createMockEmbed(\n   299→      [\"faszerowana papryka\", \"paprika gyeran\"],\n   300→      []\n   301→    );\n   302→    const text =\n   303→      \"Faszerowana papryka\\nPAPRIKA GYERAN-JJIM\\nIngredients\\n200g peppers\";\n   304→    const result = await extractTitleWithEmbeddings(text, embed);\n   305→    expect(result).toBe(\"Faszerowana papryka\");\n   306→  });\n   307→\n   308→  it(\"merges 4 consecutive short ALL_CAPS lines into one title (LABANEH-type)\", async () => {\n   309→    // Each OCR line is ≤2 words and ≤25 chars — the short-caps merge pass coalesces them.\n   310→    const embed = createMockEmbed([\"labaneh\"], []);\n   311→    const text = [\n   312→      \"LABANEH\",\n   313→      \"BALLS\",\n   314→      \"WITH NIGELLA\",\n   315→      \"SEEDS\",\n   316→      \"Essential to blending the flavours together\",\n   317→    ].join(\"\\n\");\n   318→    const result = await extractTitleWithEmbeddings(text, embed);\n   319→    expect(result).toBe(\"LABANEH BALLS WITH NIGELLA SEEDS\");\n   320→  });\n   321→\n   322→  it(\"short-caps merge breaks at a section label, preventing spurious joins\", async () => {\n   323→    // WORD ONE and WORD TWO are short ALL_CAPS, but INGREDIENTS (section label) sits between\n   324→    // them and breaks the run — they should NOT be merged into \"WORD ONE WORD TWO\".\n   325→    const embed = createMockEmbed([\"word one\"], []);\n   326→    const text = [\n   327→      \"WORD ONE\",\n   328→      \"INGREDIENTS\",\n   329→      \"WORD TWO\",\n   330→      \"Some body text here to fill the page\",\n   331→    ].join(\"\\n\");\n   332→    const result = await extractTitleWithEmbeddings(text, embed);\n   333→    // WORD ONE wins (title word); WORD TWO is a separate candidate but scores lower.\n   334→    // The key assertion: no \"WORD ONE INGREDIENTS WORD TWO\" merged result.\n   335→    expect(result).toBe(\"WORD ONE\");\n   336→  });\n   337→\n   338→  it(\"short-caps merge does not fire when a line exceeds 2 words\", async () => {\n   339→    // \"THREE WORD LINE\" has 3 words — above the ≤2 limit — so it is never the start of a merge run.\n   340→    const embed = createMockEmbed([\"three word line\"], []);\n   341→    const text = [\n   342→      \"THREE WORD LINE\",\n   343→      \"ANOTHER LINE\",\n   344→      \"Body text follows here\",\n   345→    ].join(\"\\n\");\n   346→    const result = await extractTitleWithEmbeddings(text, embed);\n   347→    // Candidates are generated individually; no spurious merge of the two lines by the caps pass.\n   348→    // \"THREE WORD LINE ANOTHER LINE\" may appear as a downstream 2-line join candidate but\n   349→    // \"THREE WORD LINE\" wins as the structural heading (more words, higher rawScore from title word).\n   350→    expect(result).toBe(\"THREE WORD LINE\");\n   351→  });\n   352→\n   353→  it(\"layout-based bilingual detection suppresses ALL_CAPS romanization with no word overlap\", async () => {\n   354→    // Mixed-case title at position 0 (≥2 words) + ALL_CAPS candidate at position 1 with no\n   355→    // words in common → layout guard fires and suppresses the ALL_CAPS candidate.\n   356→    const embed = createMockEmbed([\"mixed case title\", \"all caps different\"], []);\n   357→    const text = [\n   358→      \"Mixed Case Title\",\n   359→      \"ALL CAPS DIFFERENT\",\n   360→      \"Body text that fills the rest of the page\",\n   361→    ].join(\"\\n\");\n   362→    const result = await extractTitleWithEmbeddings(text, embed);\n   363→    expect(result).toBe(\"Mixed Case Title\");\n   364→  });\n   365→});\n   366→"}]},"parent_tool_use_id":null,"session_id":"beba072c-8756-4212-892f-70153dbd85fa","uuid":"fdbe5c23-7c88-467e-b226-dc7105859f40","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/__tests__/title-extractor.test.ts","content":"import {\n  extractTitle,\n  extractTitleWithEmbeddings,\n  _resetEmbeddingCacheForTests,\n} from \"../title-extractor\";\n\n/**\n * Creates a mock embed function that returns predictable vectors.\n * Words matching titleWords get a vector pointing \"toward titles\",\n * words matching headerWords get a vector pointing \"toward headers\",\n * and everything else gets a neutral vector.\n */\nfunction createMockEmbed(\n  titleWords: Array<string>,\n  headerWords: Array<string>\n): (text: string) => Promise<Array<number>> {\n  // Reference phrases from the module\n  const TITLE_REF =\n    \"recipe name, dish title, name of the food, nazwa przepisu, nazwa dania\";\n  const HEADER_REF =\n    \"ingredients list, cooking directions, section heading, składniki, przygotowanie, sposób wykonania\";\n  const NOISE_REF =\n    \"page number, table of contents, book footer, garbled text\";\n\n  return async (text: string): Promise<Array<number>> => {\n    const lower = text.toLowerCase();\n\n    // Title reference → unit vector in dimension 0\n    if (lower === TITLE_REF.toLowerCase()) {\n      return [1, 0, 0];\n    }\n    // Header reference → unit vector in dimension 1\n    if (lower === HEADER_REF.toLowerCase()) {\n      return [0, 1, 0];\n    }\n    // Noise reference → unit vector in dimension 2 (orthogonal)\n    if (lower === NOISE_REF.toLowerCase()) {\n      return [0, 0, 1];\n    }\n\n    // Check if text contains title-like words → high cosine with title ref\n    const isTitle = titleWords.some((w) => lower.includes(w.toLowerCase()));\n    // Check if text contains header-like words → high cosine with header ref\n    const isHeader = headerWords.some((w) => lower.includes(w.toLowerCase()));\n\n    if (isTitle && !isHeader) {\n      return [0.9, 0.1, 0]; // High title similarity, low header similarity\n    }\n    if (isHeader && !isTitle) {\n      return [0.1, 0.9, 0]; // Low title similarity, high header similarity\n    }\n    if (isTitle && isHeader) {\n      return [0.5, 0.5, 0]; // Ambiguous\n    }\n    // Neutral\n    return [0.3, 0.3, 0.7];\n  };\n}\n\ndescribe(\"extractTitle (heuristic)\", () => {\n  it(\"returns undefined for empty text\", () => {\n    expect(extractTitle(\"\")).toBeUndefined();\n    expect(extractTitle(\"  \")).toBeUndefined();\n  });\n\n  it(\"returns the first valid line\", () => {\n    expect(extractTitle(\"Chicken Soup\\nIngredients\\n1 cup water\")).toBe(\n      \"Chicken Soup\"\n    );\n  });\n\n  it(\"skips lines that are too short or too long\", () => {\n    const longLine = \"A\".repeat(51);\n    expect(extractTitle(`ab\\n${longLine}\\nGood Title`)).toBe(\"Good Title\");\n  });\n\n  it(\"skips ingredient lines\", () => {\n    expect(extractTitle(\"2 cups flour\\nApple Pie\")).toBe(\"Apple Pie\");\n  });\n\n  it(\"skips all-caps lines\", () => {\n    expect(extractTitle(\"INGREDIENTS\\nChocolate Cake\")).toBe(\"Chocolate Cake\");\n  });\n\n  it(\"skips lines starting with numbers\", () => {\n    expect(extractTitle(\"12\\nApple Pie\")).toBe(\"Apple Pie\");\n  });\n});\n\ndescribe(\"extractTitleWithEmbeddings\", () => {\n  beforeEach(() => {\n    _resetEmbeddingCacheForTests();\n  });\n\n  it(\"returns undefined for empty text\", async () => {\n    const embed = createMockEmbed([], []);\n    expect(await extractTitleWithEmbeddings(\"\", embed)).toBeUndefined();\n    expect(await extractTitleWithEmbeddings(\"  \", embed)).toBeUndefined();\n  });\n\n  it(\"picks title over section header (Polish)\", async () => {\n    const embed = createMockEmbed([\"pierogi ruskie\"], [\"składniki\"]);\n    const text = \"Składniki\\nPierogi Ruskie\\n200g mąki\\n3 ziemniaki\";\n    const result = await extractTitleWithEmbeddings(text, embed);\n    expect(result).toBe(\"Pierogi Ruskie\");\n  });\n\n  it(\"picks title over section header (English)\", async () => {\n    const embed = createMockEmbed([\"chicken soup\"], [\"ingredients\"]);\n    const text = \"Ingredients\\nChicken Soup\\n1 cup water\\nSalt\";\n    const result = await extractTitleWithEmbeddings(text, embed);\n    expect(result).toBe(\"Chicken Soup\");\n  });\n\n  it(\"preserves all-caps titles\", async () => {\n    const embed = createMockEmbed([\"chocolate cake\"], [\"ingredients\"]);\n    const text = \"CHOCOLATE CAKE\\nIngredients\\n200g flour\";\n    const result = await extractTitleWithEmbeddings(text, embed);\n    expect(result).toBe(\"CHOCOLATE CAKE\");\n  });\n\n  it(\"skips numbered lines\", async () => {\n    const embed = createMockEmbed([\"apple pie\"], []);\n    const text = \"12\\nApple Pie\\nSome instructions\";\n    const result = await extractTitleWithEmbeddings(text, embed);\n    expect(result).toBe(\"Apple Pie\");\n  });\n\n  it(\"joins multi-line title (2 lines)\", async () => {\n    const embed = createMockEmbed(\n      [\"kurczak w sosie śmietanowym z pieczarkami\"],\n      [\"składniki\"]\n    );\n    const text =\n      \"Kurczak w sosie\\nśmietanowym z pieczarkami\\nSkładniki\\n200g kurczaka\";\n    const result = await extractTitleWithEmbeddings(text, embed);\n    expect(result).toBe(\"Kurczak w sosie śmietanowym z pieczarkami\");\n  });\n\n  it(\"joins multi-line title (3 lines)\", async () => {\n    const embed = createMockEmbed(\n      [\"makaron z sosem pomidorowym i bazylią\"],\n      [\"składniki\"]\n    );\n    const text =\n      \"Makaron z sosem\\npomidorowym\\ni bazylią\\nSkładniki\\n300g makaronu\";\n    const result = await extractTitleWithEmbeddings(text, embed);\n    expect(result).toBe(\"Makaron z sosem pomidorowym i bazylią\");\n  });\n\n  it(\"does not over-greedily join title with header\", async () => {\n    const embed = createMockEmbed([\"apple pie\"], [\"ingredients\"]);\n    const text = \"Apple Pie\\nIngredients\\n200g flour\";\n    const result = await extractTitleWithEmbeddings(text, embed);\n    // Should prefer \"Apple Pie\" alone, not \"Apple Pie Ingredients\"\n    expect(result).toBe(\"Apple Pie\");\n  });\n\n  it(\"returns multiple titles joined with + when both score well\", async () => {\n    const embed = createMockEmbed(\n      [\"first recipe\", \"second recipe\"],\n      []\n    );\n    const text = \"First Recipe\\nSecond Recipe\\nSome other text\";\n    const result = await extractTitleWithEmbeddings(text, embed);\n    expect(result).toBe(\"First Recipe + Second Recipe\");\n  });\n\n  it(\"skips burst of short lines at start and finds title after\", async () => {\n    const embed = createMockEmbed([\"beef stew\"], [\"ingredients\"]);\n    // 3+ short garbled lines at start, then real content with a long line\n    const text =\n      \"pg 42\\nA.\\nfoo\\nThis is a longer line that triggers burst end detection\\nBeef Stew\\nIngredients\\n500g beef\";\n    const result = await extractTitleWithEmbeddings(text, embed);\n    expect(result).toBe(\"Beef Stew\");\n  });\n\n  it(\"two titles deep in text returns both joined\", async () => {\n    const embed = createMockEmbed(\n      [\"pasta carbonara\", \"tiramisu classico\"],\n      [\"ingredients\", \"składniki\"]\n    );\n    const text =\n      \"Ingredients\\nPasta Carbonara\\n200g pasta\\n100g guanciale\\nIngredients\\nTiramisu Classico\\n250g mascarpone\";\n    const result = await extractTitleWithEmbeddings(text, embed);\n    expect(result).toBe(\"Pasta Carbonara + Tiramisu Classico\");\n  });\n\n  it(\"single-recipe page still returns one title\", async () => {\n    const embed = createMockEmbed([\"tomato soup\"], [\"ingredients\"]);\n    const text = \"Tomato Soup\\nIngredients\\n4 tomatoes\\n1 cup cream\\nSalt\";\n    const result = await extractTitleWithEmbeddings(text, embed);\n    expect(result).toBe(\"Tomato Soup\");\n  });\n\n  it(\"keeps 2-word ALL_CAPS join over its single-word prefix (ARAYES-type)\", async () => {\n    // \"ARAYES\" alone is 1 word → never qualifies as firstStructuralHeading.\n    // \"ARAYES SHRAK\" qualifies → pre-filter removes \"ARAYES\" so dedup keeps the join.\n    const embed = createMockEmbed([\"arayes\"], [\"ingredients\"]);\n    const text = \"ARAYES\\nSHRAK\\nIngredients\\n2 cups flour\";\n    const result = await extractTitleWithEmbeddings(text, embed);\n    expect(result).toBe(\"ARAYES SHRAK\");\n  });\n\n  it(\"extends ALL_CAPS structural heading when next line starts with continuation token (SAFFRON-type)\", async () => {\n    // \"TITLE FIRST PART\" qualifies as structural heading; continuation upgrades it to the join.\n    // Pre-filter then removes the partial so dedup keeps the complete join.\n    const embed = createMockEmbed([\"title first part\"], [\"ingredients\"]);\n    const text = \"TITLE FIRST PART\\n/ SECOND PART\\nIngredients\\n1 cup flour\";\n    const result = await extractTitleWithEmbeddings(text, embed);\n    expect(result).toBe(\"TITLE FIRST PART / SECOND PART\");\n  });\n\n  it(\"pre-merges continuation line starting with & into preceding line (Baked Eggs type)\", async () => {\n    // \"& Coriander\" starts with & so it's merged into the preceding line before candidate\n    // generation — the complete title enters the pool as a single candidate.\n    const embed = createMockEmbed(\n      [\"baked eggs with feta\"],\n      [\"ingredients\"]\n    );\n    const text =\n      \"Baked Eggs with Feta, Harissa Tomato Sauce\\n& Coriander\\nIngredients\\n2 eggs\";\n    const result = await extractTitleWithEmbeddings(text, embed);\n    expect(result).toBe(\"Baked Eggs with Feta, Harissa Tomato Sauce & Coriander\");\n  });\n\n  it(\"does not pre-merge second line that lacks a continuation character (ARAYES-type safety)\", async () => {\n    // \"SHRAK\" does not start with /&+:( so it is NOT pre-merged.\n    // The existing structural heading join logic handles it instead.\n    const embed = createMockEmbed([\"arayes\"], [\"ingredients\"]);\n    const text = \"ARAYES\\nSHRAK\\nIngredients\\n2 cups flour\";\n    const result = await extractTitleWithEmbeddings(text, embed);\n    expect(result).toBe(\"ARAYES SHRAK\");\n  });\n\n  it(\"returns only the first ALL_CAPS heading when subsequent ALL_CAPS headings are section headers followed by ingredients (CHLEBEK type)\", async () => {\n    // WARZYWA I BOCZEK is immediately followed by ingredient lines (numbers) →\n    // it's a section header, not a second recipe title. Keep only CHLEBEK Z WARZYWAMI I BOCZKIEM.\n    const embed = createMockEmbed(\n      [\"chlebek z warzywami i boczkiem\", \"warzywa i boczek\"],\n      []\n    );\n    const text = [\n      \"CHLEBEK Z WARZYWAMI I BOCZKIEM\",\n      \"WARZYWA I BOCZEK\",\n      \"500 g strączków zielonego groszku\",\n      \"1 żółta papryka\",\n      \"CHLEBEK\",\n      \"500 g mąki\",\n    ].join(\"\\n\");\n    const result = await extractTitleWithEmbeddings(text, embed);\n    expect(result).toBe(\"CHLEBEK Z WARZYWAMI I BOCZKIEM\");\n  });\n\n  it(\"returns both ALL_CAPS titles when headings are NOT followed by ingredient lines (FINNISH-type)\", async () => {\n    // POTATO FLATBREADS is followed by body text, not ingredients →\n    // these are two separate recipe titles on a multi-recipe page.\n    const embed = createMockEmbed(\n      [\"milk flatbreads\", \"potato flatbreads\"],\n      []\n    );\n    const text = [\n      \"MILK FLATBREADS\",\n      \"Mix flour with milk and knead\",\n      \"Cook on a dry skillet\",\n      \"POTATO FLATBREADS\",\n      \"Boil potatoes until tender\",\n      \"Mash well before mixing\",\n    ].join(\"\\n\");\n    const result = await extractTitleWithEmbeddings(text, embed);\n    expect(result).toBe(\"MILK FLATBREADS + POTATO FLATBREADS\");\n  });\n\n  it(\"filters bullet-list lines so real title wins\", async () => {\n    const embed = createMockEmbed([\"mozzarella sticks\"], []);\n    const text = \"MOZZARELLA STICKS\\n- 2 tbsp sugar\\n- Salt to taste\";\n    const result = await extractTitleWithEmbeddings(text, embed);\n    expect(result).toBe(\"MOZZARELLA STICKS\");\n  });\n\n  it(\"filters INGREDIENTS section label so real ALL_CAPS title wins\", async () => {\n    const embed = createMockEmbed([\"mozzarella sticks\"], []);\n    const text = \"INGREDIENTS\\nMOZZARELLA STICKS\\n- 2 tbsp sugar\";\n    const result = await extractTitleWithEmbeddings(text, embed);\n    expect(result).toBe(\"MOZZARELLA STICKS\");\n  });\n\n  it(\"filters compact metric ingredient lines so real title wins\", async () => {\n    const embed = createMockEmbed([\"barszcz czerwony\"], []);\n    const text = \"BARSZCZ CZERWONY\\n100g buraków\\n50ml bulionu\";\n    const result = await extractTitleWithEmbeddings(text, embed);\n    expect(result).toBe(\"BARSZCZ CZERWONY\");\n  });\n\n  it(\"prefers mixed-case title at position 0 over ALL_CAPS subtitle at position 1 (bilingual page)\", async () => {\n    // \"Faszerowana papryka\" is the Polish title at position 0 (mixed-case).\n    // \"PAPRIKA GYERAN-JJIM\" is an ALL_CAPS romanization at position 1 — treated as subtitle.\n    const embed = createMockEmbed(\n      [\"faszerowana papryka\", \"paprika gyeran\"],\n      []\n    );\n    const text =\n      \"Faszerowana papryka\\nPAPRIKA GYERAN-JJIM\\nIngredients\\n200g peppers\";\n    const result = await extractTitleWithEmbeddings(text, embed);\n    expect(result).toBe(\"Faszerowana papryka\");\n  });\n\n  it(\"merges 4 consecutive short ALL_CAPS lines into one title (LABANEH-type)\", async () => {\n    // Each OCR line is ≤2 words and ≤25 chars — the short-caps merge pass coalesces them.\n    const embed = createMockEmbed([\"labaneh\"], []);\n    const text = [\n      \"LABANEH\",\n      \"BALLS\",\n      \"WITH NIGELLA\",\n      \"SEEDS\",\n      \"Essential to blending the flavours together\",\n    ].join(\"\\n\");\n    const result = await extractTitleWithEmbeddings(text, embed);\n    expect(result).toBe(\"LABANEH BALLS WITH NIGELLA SEEDS\");\n  });\n\n  it(\"short-caps merge breaks at a section label, preventing spurious joins\", async () => {\n    // WORD ONE and WORD TWO are short ALL_CAPS, but INGREDIENTS (section label) sits between\n    // them and breaks the run — they should NOT be merged into \"WORD ONE WORD TWO\".\n    const embed = createMockEmbed([\"word one\"], []);\n    const text = [\n      \"WORD ONE\",\n      \"INGREDIENTS\",\n      \"WORD TWO\",\n      \"Some body text here to fill the page\",\n    ].join(\"\\n\");\n    const result = await extractTitleWithEmbeddings(text, embed);\n    // WORD ONE wins (title word); WORD TWO is a separate candidate but scores lower.\n    // The key assertion: no \"WORD ONE INGREDIENTS WORD TWO\" merged result.\n    expect(result).toBe(\"WORD ONE\");\n  });\n\n  it(\"short-caps merge does not fire when a line exceeds 2 words\", async () => {\n    // \"THREE WORD LINE\" has 3 words — above the ≤2 limit — so it is never the start of a merge run.\n    const embed = createMockEmbed([\"three word line\"], []);\n    const text = [\n      \"THREE WORD LINE\",\n      \"ANOTHER LINE\",\n      \"Body text follows here\",\n    ].join(\"\\n\");\n    const result = await extractTitleWithEmbeddings(text, embed);\n    // Candidates are generated individually; no spurious merge of the two lines by the caps pass.\n    // \"THREE WORD LINE ANOTHER LINE\" may appear as a downstream 2-line join candidate but\n    // \"THREE WORD LINE\" wins as the structural heading (more words, higher rawScore from title word).\n    expect(result).toBe(\"THREE WORD LINE\");\n  });\n\n  it(\"layout-based bilingual detection suppresses ALL_CAPS romanization with no word overlap\", async () => {\n    // Mixed-case title at position 0 (≥2 words) + ALL_CAPS candidate at position 1 with no\n    // words in common → layout guard fires and suppresses the ALL_CAPS candidate.\n    const embed = createMockEmbed([\"mixed case title\", \"all caps different\"], []);\n    const text = [\n      \"Mixed Case Title\",\n      \"ALL CAPS DIFFERENT\",\n      \"Body text that fills the rest of the page\",\n    ].join(\"\\n\");\n    const result = await extractTitleWithEmbeddings(text, embed);\n    expect(result).toBe(\"Mixed Case Title\");\n  });\n});\n","numLines":366,"startLine":1,"totalLines":366}}}
