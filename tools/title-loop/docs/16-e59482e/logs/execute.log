{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Kmc6phwjJJAWUcQu4f5e8z","type":"tool_result","content":"    95→/**\n    96→ * Known recipe section labels — these are structural headers, not recipe titles.\n    97→ * Matched case-insensitively after trimming, stripping trailing punctuation, and stripping diacritics.\n    98→ * Polish entries are stored without diacritics for OCR resilience (e.g. \"SKLADNIKI\" matches \"składniki\").\n    99→ */\n   100→const SECTION_LABELS = new Set([\n   101→  // English\n   102→  \"ingredients\", \"directions\", \"instructions\", \"method\", \"preparation\",\n   103→  \"steps\", \"notes\", \"tip\", \"tips\", \"variations\", \"variation\",\n   104→  \"garnish\", \"topping\", \"toppings\", \"frosting\", \"filling\",\n   105→  // Polish (stored without diacritics for OCR resilience)\n   106→  \"skladniki\", \"przygotowanie\", \"sposob przygotowania\", \"sposob wykonania\",\n   107→  \"wykonanie\", \"wskazowki\", \"podpowiedz\", \"warianty\",\n   108→  \"sos\", \"nadzienie\", \"polewa\", \"lukier\", \"ciasto\",\n   109→]);\n   110→\n   111→function stripDiacritics(text: string): string {\n   112→  return text.normalize(\"NFKD\").replace(/[\\u0300-\\u036f]/g, \"\");\n   113→}\n   114→\n   115→function isSectionLabel(text: string): boolean {\n   116→  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n   117→  return SECTION_LABELS.has(normalized);\n   118→}\n   119→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"69be8f57-504b-40bc-8d20-876849e39e96","uuid":"e59f1883-851b-4627-b39b-9b36cd709367","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/title-extractor.ts","content":"/**\n * Known recipe section labels — these are structural headers, not recipe titles.\n * Matched case-insensitively after trimming, stripping trailing punctuation, and stripping diacritics.\n * Polish entries are stored without diacritics for OCR resilience (e.g. \"SKLADNIKI\" matches \"składniki\").\n */\nconst SECTION_LABELS = new Set([\n  // English\n  \"ingredients\", \"directions\", \"instructions\", \"method\", \"preparation\",\n  \"steps\", \"notes\", \"tip\", \"tips\", \"variations\", \"variation\",\n  \"garnish\", \"topping\", \"toppings\", \"frosting\", \"filling\",\n  // Polish (stored without diacritics for OCR resilience)\n  \"skladniki\", \"przygotowanie\", \"sposob przygotowania\", \"sposob wykonania\",\n  \"wykonanie\", \"wskazowki\", \"podpowiedz\", \"warianty\",\n  \"sos\", \"nadzienie\", \"polewa\", \"lukier\", \"ciasto\",\n]);\n\nfunction stripDiacritics(text: string): string {\n  return text.normalize(\"NFKD\").replace(/[\\u0300-\\u036f]/g, \"\");\n}\n\nfunction isSectionLabel(text: string): boolean {\n  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n  return SECTION_LABELS.has(normalized);\n}\n","numLines":25,"startLine":95,"totalLines":774}}}
