{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012jggGVPJDSXyQKmL5DGuCo","type":"tool_result","content":"     1→/**\n     2→ * Title Extraction\n     3→ * Extracts potential recipe title from OCR text using heuristics or semantic embeddings\n     4→ */\n     5→\n     6→import { cosineSimilarity } from \"./embeddings\";\n     7→\n     8→export type EmbedFn = (text: string) => Promise<Array<number>>;\n     9→\n    10→const TITLE_REFERENCE =\n    11→  \"recipe name, dish title, name of the food, nazwa przepisu, nazwa dania\";\n    12→const HEADER_REFERENCE =\n    13→  \"ingredients list, cooking directions, section heading, składniki, przygotowanie, sposób wykonania\";\n    14→const NOISE_REFERENCE =\n    15→  \"page number, table of contents, book footer, garbled text\";\n    16→\n    17→/**\n    18→ * Measurement units commonly found in ingredient lists\n    19→ */\n    20→const MEASUREMENT_PATTERNS = [\n    21→  // English\n    22→  \"cup\",\n    23→  \"cups\",\n    24→  \"tbsp\",\n    25→  \"tsp\",\n    26→  \"tablespoon\",\n    27→  \"teaspoon\",\n    28→  // \"oz\" and \"lb\" are matched with word boundaries in looksLikeIngredient\n    29→  // to avoid false positives (\"oz\" in \"mozzarella\", \"lb\" in \"albacore\")\n    30→  \"gram\",\n    31→  \"grams\",\n    32→  \"kg\",\n    33→  \"ml\",\n    34→  \"liter\",\n    35→  \"pinch\",\n    36→  \"dash\",\n    37→  \"handful\",\n    38→  // Polish\n    39→  \"łyżka\", \"łyżki\", \"łyżek\",           // tablespoon(s)\n    40→  \"łyżeczka\", \"łyżeczki\", \"łyżeczek\",   // teaspoon(s)\n    41→  \"szklanka\", \"szklanki\", \"szklanek\",    // cup(s)\n    42→  \"szczypta\",                            // pinch\n    43→  \"garść\",                               // handful\n    44→  \"opakowanie\", \"opakowania\",            // package(s)\n    45→  \"plasterek\", \"plasterki\",             // slice(s)\n    46→];\n    47→\n    48→/**\n    49→ * Patterns that identify recipe metadata lines (not titles)\n    50→ */\n    51→const METADATA_PATTERNS = [\n    52→  /^(SERVES?|MAKES?|YIELDS?)\\b/i,\n    53→  /^(PREP(ARATION)?|COOK(ING)?|PROOF|RISING|FERMENTATION|REST(ING)?)\\s*(AND\\s*)?(COOK(ING)?)?\\s*TIME/i,\n    54→  /^SAMPLE\\s+SCHEDULE\\b/i,\n    55→  /^BULK\\s+FERMENTATION\\b/i,\n    56→  /^(THIS\\s+RECIPE\\s+)?MAKES\\b/i,\n    57→  // Polish serving-size patterns: \"NA 3 PAPRYKI\", \"NA OKOŁO 1 KG\", \"DLA 4 OSÓB\"\n    58→  /^NA\\s+(\\d|OKOŁO)\\b/i,\n    59→  /^DLA\\s+\\d/i,\n    60→  // OCR-resilient: \"DLA\" + any token + serving-unit word (handles DLA & OSOB, DLA § OSOB, etc.)\n    61→  /^DLA\\s+\\S+\\s+OSOB/i,\n    62→  // OCR-resilient: \"DLA\" + single non-alphanumeric char (common digit→symbol OCR error)\n    63→  /^DLA\\s+[^a-zA-Z0-9\\s]\\s/i,\n    64→  // Time-unit metadata: any line containing \"N MIN\" or \"N GODZ\" is prep/cook/rest time,\n    65→  // regardless of OCR-corrupted prefix (catches PRZYGOTOWANTE, GOTOMANTE, etc.)\n    66→  /\\b\\d+\\s*MIN\\b/i,\n    67→  /\\b\\d+\\s*GODZ/i,\n    68→];\n    69→\n    70→/**\n    71→ * Single-word non-title words — standalone OCR fragments unlikely to be recipe titles\n    72→ */\n    73→const NON_TITLE_WORDS = new Set([\n    74→  \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"are\", \"was\",\n    75→  \"has\", \"his\", \"her\", \"its\", \"our\", \"who\", \"how\", \"may\", \"new\", \"now\",\n    76→  \"old\", \"see\", \"way\", \"did\", \"get\", \"let\", \"say\", \"she\", \"too\", \"use\",\n    77→  \"buns\", \"with\",\n    78→]);\n    79→\n    80→function looksLikeIngredient(line: string): boolean {\n    81→  const lowerLine = line.toLowerCase();\n    82→  if (MEASUREMENT_PATTERNS.some((pattern) => lowerLine.includes(pattern))) return true;\n    83→  // Compact metric: \"100g\", \"50ml\", \"250g\" — digit immediately followed by g/ml/kg\n    84→  if (/\\b\\d+\\s*(?:g|ml|kg)\\b/i.test(line)) return true;\n    85→  // \"to taste\" / \"do smaku\" — qualitative ingredient with no unit\n    86→  if (/\\bto taste\\b/i.test(line) || /\\bdo smaku\\b/i.test(line)) return true;\n    87→  return false;\n    88→}\n    89→\n    90→function startsWithNumber(line: string): boolean {\n    91→  // Match lines starting with a digit, or bullet-then-digit (e.g., \"- 2 jajka\")\n    92→  return /^\\s*(?:[-•*]\\s*)?\\d/.test(line);\n    93→}\n    94→\n    95→/**\n    96→ * Known recipe section labels — these are structural headers, not recipe titles.\n    97→ * Matched case-insensitively after trimming, stripping trailing punctuation, and stripping diacritics.\n    98→ * Polish entries are stored without diacritics for OCR resilience (e.g. \"SKLADNIKI\" matches \"składniki\").\n    99→ */\n   100→const SECTION_LABELS = new Set([\n   101→  // English\n   102→  \"ingredients\", \"directions\", \"instructions\", \"method\", \"preparation\",\n   103→  \"steps\", \"notes\", \"tip\", \"tips\", \"variations\", \"variation\",\n   104→  \"garnish\", \"topping\", \"toppings\", \"frosting\", \"filling\",\n   105→  // Polish (stored without diacritics for OCR resilience)\n   106→  \"skladniki\", \"przygotowanie\", \"sposob przygotowania\", \"sposob wykonania\",\n   107→  \"wykonanie\", \"wskazowki\", \"podpowiedz\", \"warianty\",\n   108→  \"sos\", \"nadzienie\", \"polewa\", \"lukier\", \"ciasto\",\n   109→]);\n   110→\n   111→function stripDiacritics(text: string): string {\n   112→  return text.normalize(\"NFKD\").replace(/[\\u0300-\\u036f]/g, \"\");\n   113→}\n   114→\n   115→function isSectionLabel(text: string): boolean {\n   116→  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n   117→  return SECTION_LABELS.has(normalized);\n   118→}\n   119→\n   120→function isAllCaps(line: string): boolean {\n   121→  const letters = line.replace(/[^a-zA-Z]/g, \"\");\n   122→  return letters.length > 0 && letters === letters.toUpperCase();\n   123→}\n   124→\n   125→function looksLikeMetadata(text: string): boolean {\n   126→  return METADATA_PATTERNS.some((pattern) => pattern.test(text.trim()));\n   127→}\n   128→\n   129→function isLikelyGarbled(text: string): boolean {\n   130→  const letters = text.replace(/[^a-zA-Z]/g, \"\");\n   131→  if (letters.length < 2) return true;\n   132→\n   133→  // Check vowel ratio — English/Polish text typically has 30–50% vowels\n   134→  const vowels = letters.replace(/[^aeiouAEIOUyYąęóĄĘÓ]/g, \"\").length;\n   135→  const vowelRatio = vowels / letters.length;\n   136→  if (vowelRatio < 0.15 || vowelRatio > 0.85) return true;\n   137→\n   138→  // Single orphaned word ≤3 letters that isn't a common word\n   139→  const words = text.trim().split(/\\s+/);\n   140→  const COMMON_SHORT = new Set([\n   141→    \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"had\", \"her\",\n   142→    \"was\", \"one\", \"our\", \"out\", \"are\", \"has\", \"his\", \"how\", \"its\", \"may\",\n   143→    \"new\", \"now\", \"old\", \"see\", \"way\", \"who\", \"did\", \"get\", \"let\", \"say\",\n   144→    \"she\", \"too\", \"use\",\n   145→  ]);\n   146→  if (words.length === 1 && letters.length <= 3 && !COMMON_SHORT.has(text.trim().toLowerCase())) {\n   147→    return true;\n   148→  }\n   149→\n   150→  // Single word with internal lowercase→uppercase transition — OCR noise (e.g., \"UuIw\", \"aBC\")\n   151→  // No recipe title uses this pattern as a standalone single-word candidate.\n   152→  if (words.length === 1 && /[a-z][A-Z]/.test(text.trim())) {\n   153→    return true;\n   154→  }\n   155→\n   156→  // Recipe titles never start with a lowercase letter\n   157→  if (/^[a-z]/.test(text.trim())) {\n   158→    return true;\n   159→  }\n   160→\n   161→  // Mid-text sentence boundary (\". \" followed by a letter) — body text fragment spliced from multiple sentences\n   162→  const trimmed = text.trim();\n   163→  if (/\\.\\s+[a-zA-Z]/.test(trimmed) && !trimmed.endsWith(\")\")) {\n   164→    return true;\n   165→  }\n   166→\n   167→  // Multi-word candidate containing a garbled OCR fragment: a short lowercase word that isn't a known short word\n   168→  if (words.length >= 2) {\n   169→    const commonShort2 = new Set([\n   170→      \"a\", \"i\", \"of\", \"or\", \"to\", \"in\", \"on\", \"is\", \"it\", \"an\",\n   171→      \"as\", \"at\", \"by\", \"do\", \"go\", \"if\", \"no\", \"so\", \"up\", \"we\",\n   172→      \"w\", \"z\",  // Polish prepositions\n   173→    ]);\n   174→    const hasGarbledWord = words.some(\n   175→      (w) =>\n   176→        /^[a-z]/.test(w) &&\n   177→        w.replace(/[^a-z]/g, \"\").length <= 2 &&\n   178→        !commonShort2.has(w.toLowerCase())\n   179→    );\n   180→    if (hasGarbledWord) {\n   181→      return true;\n   182→    }\n   183→  }\n   184→\n   185→  return false;\n   186→}\n   187→\n   188→function passesHardFilters(text: string): boolean {\n   189→  if (text.length < 3 || text.length > 80) return false;\n   190→  if (looksLikeIngredient(text)) return false;\n   191→  if (startsWithNumber(text)) return false;\n   192→  if (looksLikeMetadata(text)) return false;\n   193→  if (isLikelyGarbled(text)) return false;\n   194→  // Pipe-separated lines are book category/chapter headers, not recipe titles\n   195→  if (text.includes(\" | \")) return false;\n   196→  // Slash-separated breadcrumbs (e.g., \"/ Jesien / Zupy\") are navigation, not titles\n   197→  // Only filter when 2+ slashes are present — single-slash lines like\n   198→  // \"TITLE / SUBTITLE\" are legitimate continuation-merged titles\n   199→  if ((text.match(/\\//g) || []).length >= 2) return false;\n   200→  // Bullet-list items (ingredients or instruction steps) are never titles\n   201→  if (/^\\s*[-•*]\\s/.test(text)) return false;\n   202→  // Known recipe section labels are structural headers, not titles\n   203→  if (isSectionLabel(text)) return false;\n   204→  // Single-word non-title fragments\n   205→  const words = text.trim().split(/\\s+/);\n   206→  if (words.length === 1 && NON_TITLE_WORDS.has(text.trim().toLowerCase())) return false;\n   207→  return true;\n   208→}\n   209→\n   210→/**\n   211→ * Detect initial burst of short garbled lines.\n   212→ * Returns the index of the first non-garbled or long line.\n   213→ */\n   214→function findBurstEnd(lines: Array<{ text: string }>): number {\n   215→  let i = 0;\n   216→  while (i < lines.length && lines[i].text.length < 20 && isLikelyGarbled(lines[i].text)) {\n   217→    i++;\n   218→  }\n   219→  return i;\n   220→}\n   221→\n   222→function wordCount(text: string): number {\n   223→  return text.split(/\\s+/).filter((w) => w.length > 0).length;\n   224→}\n   225→\n   226→/**\n   227→ * Build candidate strings from lines: single lines plus multi-line joins (2-3 consecutive).\n   228→ * Skips initial burst of short garbled lines. Scans all remaining lines. Caps at 25.\n   229→ */\n   230→export type CandidateOrigin = \"single\" | \"2-line\" | \"3-line\";\n   231→\n   232→function buildCandidates(\n   233→  lines: Array<string>\n   234→): Array<{ text: string; position: number; origin: CandidateOrigin }> {\n   235→  const nonEmptyLines: Array<{ text: string; index: number }> = [];\n   236→\n   237→  for (let i = 0; i < lines.length; i++) {\n   238→    const trimmed = lines[i].trim();\n   239→    if (trimmed.length > 0) {\n   240→      nonEmptyLines.push({ text: trimmed, index: i });\n   241→    }\n   242→  }\n   243→\n   244→  const burstEnd = findBurstEnd(nonEmptyLines);\n   245→\n   246→  // Pre-merge consecutive short ALL_CAPS lines (OCR-fragmented headings).\n   247→  // When a sequence of 2+ ALL_CAPS lines each has ≤2 words and ≤25 chars, they are\n   248→  // almost certainly OCR fragments of a single heading. Merge them into one line so\n   249→  // the complete title enters the candidate pool without hitting the 3-line join ceiling.\n   250→  const capsCoalesced: Array<{ text: string; index: number }> = [];\n   251→  let ci = burstEnd;\n   252→  while (ci < nonEmptyLines.length) {\n   253→    const line = nonEmptyLines[ci];\n   254→    if (\n   255→      isAllCaps(line.text) &&\n   256→      wordCount(line.text) <= 2 &&\n   257→      line.text.length <= 25 &&\n   258→      !isSectionLabel(line.text) &&\n   259→      !looksLikeMetadata(line.text)\n   260→    ) {\n   261→      let merged = line.text;\n   262→      const startIndex = line.index;\n   263→      let j = ci + 1;\n   264→      while (j < nonEmptyLines.length) {\n   265→        const next = nonEmptyLines[j];\n   266→        if (\n   267→          isAllCaps(next.text) &&\n   268→          wordCount(next.text) <= 2 &&\n   269→          next.text.length <= 25 &&\n   270→          !isSectionLabel(next.text) &&\n   271→          !looksLikeMetadata(next.text) &&\n   272→          (merged + \" \" + next.text).length <= 80\n   273→        ) {\n   274→          merged += \" \" + next.text;\n   275→          j++;\n   276→        } else {\n   277→          break;\n   278→        }\n   279→      }\n   280→      if (j > ci + 1) {\n   281→        capsCoalesced.push({ text: merged, index: startIndex });\n   282→        ci = j;\n   283→        continue;\n   284→      }\n   285→    }\n   286→    capsCoalesced.push(line);\n   287→    ci++;\n   288→  }\n   289→\n   290→  // Pre-merge continuation lines: a line starting with /&+:( is never a standalone title.\n   291→  // Merge it into the preceding line so the complete title enters the pool as a single candidate,\n   292→  // avoiding the fragile chain of conditions required by the downstream join survival logic.\n   293→  // Limitation: only one continuation line per preceding line is merged. Titles split across\n   294→  // three or more lines with continuation tokens (rare in practice) are not handled here —\n   295→  // the downstream 2-line and 3-line join candidates cover those cases instead.\n   296→  const mergedLines: Array<{ text: string; index: number }> = [];\n   297→  for (let i = 0; i < capsCoalesced.length; i++) {\n   298→    const line = capsCoalesced[i];\n   299→    if (i + 1 < capsCoalesced.length) {\n   300→      const nextText = capsCoalesced[i + 1].text;\n   301→      if (/^[/&+:(]/.test(nextText)) {\n   302→        mergedLines.push({ text: `${line.text} ${nextText}`, index: line.index });\n   303→        i++;\n   304→        continue;\n   305→      }\n   306→    }\n   307→    mergedLines.push(line);\n   308→  }\n   309→\n   310→  const candidates: Array<{ text: string; position: number; origin: CandidateOrigin }> = [];\n   311→  const seen = new Set<string>();\n   312→\n   313→  // Build a set of positions to skip: short ALL_CAPS lines immediately following metadata\n   314→  const metadataContinuationPositions = new Set<number>();\n   315→  for (let i = 0; i < mergedLines.length - 1; i++) {\n   316→    if (looksLikeMetadata(mergedLines[i].text)) {\n   317→      const next = mergedLines[i + 1];\n   318→      if (isAllCaps(next.text) && wordCount(next.text) <= 2 && next.text.length <= 15) {\n   319→        metadataContinuationPositions.add(next.index);\n   320→      }\n   321→    }\n   322→  }\n   323→\n   324→  for (let i = 0; i < mergedLines.length; i++) {\n   325→    const line = mergedLines[i];\n   326→\n   327→    // Skip metadata continuation fragments\n   328→    if (metadataContinuationPositions.has(line.index)) continue;\n   329→\n   330→    // Single line\n   331→    if (passesHardFilters(line.text)) {\n   332→      const norm = line.text.toLowerCase();\n   333→      if (!seen.has(norm)) {\n   334→        seen.add(norm);\n   335→        candidates.push({ text: line.text, position: line.index, origin: \"single\" });\n   336→      }\n   337→    }\n   338→\n   339→    // 2-line join — skip if first line is a section label (prevents \"INGREDIENTS TITLE\" joins)\n   340→    if (i + 1 < mergedLines.length && !isSectionLabel(line.text)) {\n   341→      const joined2 = `${line.text} ${mergedLines[i + 1].text}`;\n   342→      if (passesHardFilters(joined2)) {\n   343→        const norm = joined2.toLowerCase();\n   344→        if (!seen.has(norm)) {\n   345→          seen.add(norm);\n   346→          candidates.push({ text: joined2, position: line.index, origin: \"2-line\" });\n   347→        }\n   348→      }\n   349→    }\n   350→\n   351→    // 3-line join — skip if first line is a section label\n   352→    if (i + 2 < mergedLines.length && !isSectionLabel(line.text)) {\n   353→      const joined3 = `${line.text} ${mergedLines[i + 1].text} ${mergedLines[i + 2].text}`;\n   354→      if (passesHardFilters(joined3)) {\n   355→        const norm = joined3.toLowerCase();\n   356→        if (!seen.has(norm)) {\n   357→          seen.add(norm);\n   358→          candidates.push({ text: joined3, position: line.index, origin: \"3-line\" });\n   359→        }\n   360→      }\n   361→    }\n   362→  }\n   363→\n   364→  // Pre-filter to 25 before embedding calls: prefer ALL_CAPS and short candidates.\n   365→  // Position-based scoring handles final ranking.\n   366→  if (candidates.length > 25) {\n   367→    const prioritized = candidates.slice().sort((a, b) => {\n   368→      const aAllCaps = isAllCaps(a.text) ? 0 : 1;\n   369→      const bAllCaps = isAllCaps(b.text) ? 0 : 1;\n   370→      if (aAllCaps !== bAllCaps) return aAllCaps - bAllCaps;\n   371→      const aShort = wordCount(a.text) <= 5 ? 0 : 1;\n   372→      const bShort = wordCount(b.text) <= 5 ? 0 : 1;\n   373→      return aShort - bShort;\n   374→    });\n   375→    return prioritized.slice(0, 25);\n   376→  }\n   377→\n   378→  return candidates;\n   379→}\n   380→\n   381→// Module-level cache for reference embeddings\n   382→let cachedTitleRefEmbedding: Array<number> | null = null;\n   383→let cachedHeaderRefEmbedding: Array<number> | null = null;\n   384→let cachedNoiseRefEmbedding: Array<number> | null = null;\n   385→\n   386→export function _resetEmbeddingCacheForTests(): void {\n   387→  cachedTitleRefEmbedding = null;\n   388→  cachedHeaderRefEmbedding = null;\n   389→  cachedNoiseRefEmbedding = null;\n   390→}\n   391→\n   392→export async function extractTitleWithEmbeddings(\n   393→  text: string,\n   394→  embed: EmbedFn\n   395→): Promise<string | undefined> {\n   396→  if (!text || text.trim().length === 0) {\n   397→    return undefined;\n   398→  }\n   399→\n   400→  const lines = text.split(\"\\n\");\n   401→  const candidates = buildCandidates(lines);\n   402→\n   403→  if (candidates.length === 0) {\n   404→    return undefined;\n   405→  }\n   406→\n   407→  // Cache reference embeddings\n   408→  if (!cachedTitleRefEmbedding) {\n   409→    cachedTitleRefEmbedding = await embed(TITLE_REFERENCE);\n   410→  }\n   411→  if (!cachedHeaderRefEmbedding) {\n   412→    cachedHeaderRefEmbedding = await embed(HEADER_REFERENCE);\n   413→  }\n   414→  if (!cachedNoiseRefEmbedding) {\n   415→    cachedNoiseRefEmbedding = await embed(NOISE_REFERENCE);\n   416→  }\n   417→\n   418→  // Find ALL_CAPS candidates with ≥2 words where every significant word has ≥4 alpha letters.\n   419→  // Insignificant tokens (≤1 alpha letter: \"/\", \"&\", \"+\", \":\", \"D)\", etc.) are filtered before\n   420→  // the check so that multi-line joins with continuation punctuation still qualify.\n   421→  const isStructuralHeading = (c: { text: string }): boolean => {\n   422→    if (!isAllCaps(c.text) || wordCount(c.text) < 2) return false;\n   423→    const sigWords = c.text.trim().split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length > 1);\n   424→    return sigWords.length >= 2 && sigWords.every((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   425→  };\n   426→\n   427→  // Pass 1: compute rawScore for all candidates (embedding quality signal)\n   428→  const rawScored: Array<{ text: string; position: number; origin: CandidateOrigin; rawScore: number; embedding: Array<number> }> = [];\n   429→  for (const candidate of candidates) {\n   430→    const embedding = await embed(candidate.text);\n   431→    const titleSim = cosineSimilarity(embedding, cachedTitleRefEmbedding);\n   432→    const headerSim = cosineSimilarity(embedding, cachedHeaderRefEmbedding);\n   433→    const noiseSim = cosineSimilarity(embedding, cachedNoiseRefEmbedding);\n   434→    const rawScore = titleSim - Math.max(headerSim, noiseSim);\n   435→    rawScored.push({ text: candidate.text, position: candidate.position, origin: candidate.origin, rawScore, embedding });\n   436→  }\n   437→\n   438→  // Select baseHeading by embedding quality (rawScore), not position.\n   439→  // This prevents OCR-garbled fragments from claiming the structural heading slot.\n   440→  const structuralCandidates = rawScored.filter((s) => isStructuralHeading(s));\n   441→\n   442→  // Penalize structural headings with truncated OCR words:\n   443→  // if \"FRON\" appears and another heading has \"SAFFRON\", \"FRON\" is likely garbled.\n   444→  for (const sc of structuralCandidates) {\n   445→    const sigWords = sc.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   446→    for (const other of structuralCandidates) {\n   447→      if (other === sc) continue;\n   448→      const otherSigWords = other.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   449→      const hasTruncation = sigWords.some((w) =>\n   450→        otherSigWords.some((ow) => ow !== w && ow.length > w.length && ow.endsWith(w))\n   451→      );\n   452→      if (hasTruncation) {\n   453→        sc.rawScore = -1.0;  // Hard disqualification — truncated OCR artifact\n   454→        break;\n   455→      }\n   456→    }\n   457→  }\n   458→\n   459→  const bestStructural = structuralCandidates.length > 0\n   460→    ? structuralCandidates.reduce((a, b) => {\n   461→        const scoreDiff = a.rawScore - b.rawScore;\n   462→        if (Math.abs(scoreDiff) > 0.03) return scoreDiff > 0 ? a : b;\n   463→        // Tiebreak: single-line origin beats multi-line joins (avoids conflating two separate headings)\n   464→        if (a.origin === \"single\" && b.origin !== \"single\") return a;\n   465→        if (b.origin === \"single\" && a.origin !== \"single\") return b;\n   466→        // Tiebreak: more words (more specific) → better\n   467→        const wcDiff = wordCount(b.text) - wordCount(a.text);\n   468→        if (wcDiff !== 0) return wcDiff > 0 ? b : a;\n   469→        // Tiebreak: earlier position → better\n   470→        return a.position < b.position ? a : b;\n   471→      })\n   472→    : null;\n   473→  const baseHeading = bestStructural ?? undefined;\n   474→\n   475→  // When the best structural heading has a continuation on the next line introduced by a\n   476→  // punctuation token (/, &, +, :, or parenthesis), prefer the longer 2-line join as the\n   477→  // complete heading. E.g. \"SAFFRON WHEAT BUNS WITH QUARK\" + \"/ COTTAGE CHEESE (VARIATION D)\".\n   478→  // Guard: the remainder after the prefix must start with a continuation character to avoid\n   479→  // merging two separate consecutive recipe titles (FINNISH MILK FLATBREADS stays separate\n   480→  // from FINNISH POTATO FLATBREADS because \"FINNISH\" does not start with a continuation token).\n   481→  let firstStructuralHeading = baseHeading && (\n   482→    rawScored.find((c) => {\n   483→      if (!isStructuralHeading(c)) return false;\n   484→      const hLower = baseHeading.text.toLowerCase();\n   485→      const cLower = c.text.toLowerCase();\n   486→      return cLower.startsWith(hLower + \" \") && /^[/&+:(]/.test(cLower.slice(hLower.length + 1));\n   487→    }) ?? baseHeading\n   488→  );\n   489→\n   490→  // Pass 2: apply bonuses\n   491→  const scored: Array<{ text: string; position: number; origin: CandidateOrigin; score: number; rawScore: number; baseScore: number; thresholdScore: number }> = rawScored.map((rs) => {\n   492→    // Position factor: multiplicative tiebreaker — amplifies existing signal, doesn't replace it\n   493→    const relativePosition = rs.position / lines.length;\n   494→    const positionFactor = relativePosition < 0.5\n   495→      ? 1.0 + 0.12 * (1 - relativePosition * 2)\n   496→      : 1.0;\n   497→\n   498→    // ALL_CAPS bonus: recipe books use ALL_CAPS for titles and section headings\n   499→    const allCapsBonus = isAllCaps(rs.text) && rs.text.replace(/[^a-zA-Z]/g, \"\").length >= 4\n   500→      ? 0.08\n   501→      : 0;\n   502→\n   503→    // Structural heading bonus: best ALL_CAPS heading (or its continuation join) is almost always the recipe title\n   504→    const structuralBonus = firstStructuralHeading && rs.text === firstStructuralHeading.text ? 0.10 : 0;\n   505→\n   506→    // thresholdScore excludes structural bonus so the bonus doesn't inflate the threshold\n   507→    // and prevent equally-valid structural headings from passing on multi-recipe pages.\n   508→    const thresholdScore = rs.rawScore + allCapsBonus;\n   509→    // baseScore excludes position factor — used for diagnostics and ranking\n   510→    const baseScore = rs.rawScore + allCapsBonus + structuralBonus;\n   511→    const score = rs.rawScore * positionFactor + allCapsBonus + structuralBonus;\n   512→    return { text: rs.text, position: rs.position, origin: rs.origin, score, rawScore: rs.rawScore, baseScore, thresholdScore };\n   513→  });\n   514→\n   515→  if (scored.length === 0) {\n   516→    return undefined;\n   517→  }\n   518→\n   519→  // --- Pre-threshold bilingual title detection ---\n   520→  // When a mixed-case candidate at position 0 is followed by an ALL_CAPS candidate\n   521→  // at position ≤ 2 that is semantically similar to it, this is a bilingual recipe\n   522→  // page (e.g., Polish title + ALL_CAPS Korean romanization). Suppress confirmed\n   523→  // translation candidates before computing threshold so their bonuses don't inflate\n   524→  // the threshold beyond the mixed-case title's reach.\n   525→  // Note: we check position ≤ 2 (local proximity), not global ALL_CAPS count, so\n   526→  // section headers later in the document (SKŁADNIKI, WARZYWA, etc.) are irrelevant.\n   527→  let translationCandidates: typeof scored = [];\n   528→  let scoredForThreshold = scored;\n   529→  const prePos0 = scored.find((s) => s.position === 0 && !isAllCaps(s.text));\n   530→  if (prePos0) {\n   531→    const nearbyAllCaps = scored.filter(\n   532→      (s) => isAllCaps(s.text) && s.position >= 1 && s.position <= 2 && s.origin === \"single\"\n   533→    );\n   534→    const pos0Embedding = rawScored.find((r) => r.text === prePos0.text)?.embedding;\n   535→\n   536→    // Method 1: embedding similarity (works for related languages)\n   537→    if (pos0Embedding && nearbyAllCaps.length > 0) {\n   538→      translationCandidates = nearbyAllCaps.filter((cap) => {\n   539→        const capEmbedding = rawScored.find((r) => r.text === cap.text)?.embedding;\n   540→        if (!capEmbedding) return false;\n   541→        return cosineSimilarity(pos0Embedding, capEmbedding) > 0.4;\n   542→      });\n   543→    }\n   544→\n   545→    // Method 2: layout-based detection (cross-lingual fallback).\n   546→    // When embedding similarity is insufficient (e.g. Polish ↔ Korean romanization),\n   547→    // detect bilingual layout by position and word overlap:\n   548→    // mixed-case ≥2 words at pos 0 + ALL_CAPS ≥2 words at pos 1-2 with no shared words.\n   549→    if (translationCandidates.length === 0 && wordCount(prePos0.text) >= 2) {\n   550→      const pos0Words = new Set(\n   551→        prePos0.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2)\n   552→      );\n   553→      translationCandidates = nearbyAllCaps.filter((cap) => {\n   554→        if (wordCount(cap.text) < 2) return false;\n   555→        const capWords = cap.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2);\n   556→        return !capWords.some((w) => pos0Words.has(w));\n   557→      });\n   558→    }\n   559→\n   560→    if (translationCandidates.length > 0) {\n   561→      // Suppress standalone translations and any multi-line joins that embed the translation\n   562→      // as a suffix or substring (e.g. \"Smażona zielona fasolka GREEN BEANS BORKEUM\" ends with\n   563→      // the translation; \"Title GREEN BEANS BORKEUM 그린빈\" includes it as a substring).\n   564→      scoredForThreshold = scored.filter((s) => {\n   565→        const sLower = s.text.toLowerCase();\n   566→        return !translationCandidates.some((t) => {\n   567→          const tLower = t.text.toLowerCase();\n   568→          return sLower.startsWith(tLower) ||\n   569→                 sLower.endsWith(tLower) ||\n   570→                 sLower.includes(\" \" + tLower);\n   571→        });\n   572→      });\n   573→    }\n   574→  }\n   575→\n   576→  // Fix 2: If the structural heading was identified as a bilingual translation, reassign it.\n   577→  // This prevents the translation's ALL_CAPS bonus from inflating the threshold and ensures\n   578→  // the fallback path in scored also uses the correct heading.\n   579→  if (\n   580→    translationCandidates.length > 0 &&\n   581→    firstStructuralHeading &&\n   582→    translationCandidates.some((t) => t.text === firstStructuralHeading!.text)\n   583→  ) {\n   584→    const nonTranslationStructural = structuralCandidates.filter(\n   585→      (sc) => !translationCandidates.some((t) => t.text === sc.text)\n   586→    );\n   587→    const newHeading = nonTranslationStructural.length > 0\n   588→      ? nonTranslationStructural.reduce((a, b) => a.rawScore > b.rawScore ? a : b)\n   589→      : undefined;\n   590→\n   591→    // Patch scored array: remove old structural bonus, apply new one\n   592→    for (const s of scored) {\n   593→      if (s.text === firstStructuralHeading.text) {\n   594→        s.score -= 0.10;\n   595→        s.baseScore -= 0.10;\n   596→      }\n   597→      if (newHeading && s.text === newHeading.text) {\n   598→        s.score += 0.10;\n   599→        s.baseScore += 0.10;\n   600→      }\n   601→    }\n   602→    // Update reference for downstream prefix-removal logic\n   603→    firstStructuralHeading = newHeading ?? undefined;\n   604→  }\n   605→\n   606→  // Use thresholdScore (excludes structural bonus) so the structural bonus doesn't inflate\n   607→  // the threshold and block equally-valid headings on multi-recipe pages.\n   608→  const bestThresholdScore = Math.max(...scoredForThreshold.map((s) => s.thresholdScore));\n   609→  const threshold = Math.max(0.08, bestThresholdScore * 0.7);\n   610→\n   611→  // Filter candidates above threshold\n   612→  let selected = scoredForThreshold.filter((s) => s.score >= threshold);\n   613→\n   614→  // Empty-pool fallback: when threshold filtering discards every candidate,\n   615→  // the hard filters' structural verdict should not be overruled by weak\n   616→  // embedding differentiation. Return the best positional candidate.\n   617→  if (selected.length === 0 && scored.length > 0) {\n   618→    const fallback = scored\n   619→      .slice()\n   620→      .sort((a, b) => a.position - b.position || b.score - a.score);\n   621→    selected = [fallback[0]];\n   622→  }\n   623→\n   624→  // Remove word-boundary prefixes of firstStructuralHeading when the heading itself survived\n   625→  // the threshold. Cases:\n   626→  //   ARAYES case:  firstStructuralHeading = \"ARAYES SHRAK\" (2-word join qualifies; \"ARAYES\"\n   627→  //     alone = 1 word, so it never qualified). Filter removes \"ARAYES\" so dedup keeps the join.\n   628→  //   SAFFRON case: baseHeading was the partial line; continuation logic above upgraded\n   629→  //     firstStructuralHeading to the full join. Filter removes the partial so dedup keeps join.\n   630→  // Safety: only fires when the complete heading itself is in selected (passed the threshold).\n   631→  if (firstStructuralHeading && selected.some((s) => s.text === firstStructuralHeading.text)) {\n   632→    const fshLower = firstStructuralHeading.text.toLowerCase();\n   633→    selected = selected.filter((s) => {\n   634→      if (s.text === firstStructuralHeading.text) return true;\n   635→      const sLower = s.text.toLowerCase();\n   636→      // Remove s if it is a space-delimited prefix of the structural heading\n   637→      return !fshLower.startsWith(sLower + \" \");\n   638→    });\n   639→  }\n   640→\n   641→  // Protect continuation joins: when a multi-line join (2-line or 3-line) survived the threshold\n   642→  // and its second part starts with a continuation character, remove the single-line prefix/suffix\n   643→  // so the dedup \"shorter wins\" rule doesn't destroy the complete join.\n   644→  // Note: the pre-merge step above already handles the common Baked Eggs case (&/continuation\n   645→  // on next line) by turning it into a single candidate — this block covers the rarer case where\n   646→  // a continuation-character join was generated as a 2-line/3-line candidate and the prefix\n   647→  // single also survived threshold independently (e.g. from a different code path or OCR layout).\n   648→  // Safety: only fires for joins whose continuation starts with /&+:( — digit continuations\n   649→  // like \"Pierogi Ruskie 200g mąki\" are NOT protected, so dedup correctly keeps the shorter form.\n   650→  const survivingJoins = selected.filter((s) => s.origin === \"2-line\" || s.origin === \"3-line\");\n   651→  if (survivingJoins.length > 0) {\n   652→    selected = selected.filter((s) => {\n   653→      if (s.origin !== \"single\") return true;\n   654→      const sLower = s.text.toLowerCase();\n   655→      // Remove PREFIX singles whose continuation join also survived\n   656→      const isPrefixOfJoin = survivingJoins.some((j) => {\n   657→        const jLower = j.text.toLowerCase();\n   658→        if (!jLower.startsWith(sLower + \" \")) return false;\n   659→        const remainder = jLower.slice(sLower.length + 1);\n   660→        return /^[/&+:(]/.test(remainder);\n   661→      });\n   662→      if (isPrefixOfJoin) return false;\n   663→      // Remove SUFFIX singles (e.g. \"& Coriander\") whose parent join also survived\n   664→      const isSuffixOfJoin = survivingJoins.some((j) => {\n   665→        const jLower = j.text.toLowerCase();\n   666→        if (!jLower.endsWith(\" \" + sLower)) return false;\n   667→        // Only remove if the suffix starts with a continuation character\n   668→        return /^[/&+:(]/.test(sLower);\n   669→      });\n   670→      if (isSuffixOfJoin) return false;\n   671→      return true;\n   672→    });\n   673→  }\n   674→\n   675→  // Pre-dedup: remove sub-section headers that are substrings of other surviving candidates.\n   676→  // A sub-section header is an ALL_CAPS candidate followed by ingredient-like lines in the source.\n   677→  // Example: \"CHLEBEK\" (bread section header, followed by \"500 g mąki\") is a substring of\n   678→  // \"CHLEBEK Z WARZYWAMI I BOCZKIEM\" (the real title). Without this filter, dedup kills the title.\n   679→  selected = selected.filter((candidate) => {\n   680→    if (!isAllCaps(candidate.text)) return true;\n   681→    // Check if this candidate is immediately followed by ingredient-like content\n   682→    const nextSourceLines = lines.slice(candidate.position + 1, candidate.position + 2);\n   683→    const followedByIngredients = nextSourceLines.some(\n   684→      (l) => looksLikeIngredient(l.trim()) || startsWithNumber(l.trim())\n   685→    );\n   686→    if (!followedByIngredients) return true;\n   687→    // Only remove if a longer candidate contains this one as a substring\n   688→    const candidateLower = candidate.text.toLowerCase();\n   689→    const hasLongerParent = rawScored.some(\n   690→      (other) =>\n   691→        other.text !== candidate.text &&\n   692→        other.text.length > candidate.text.length &&\n   693→        other.text.toLowerCase().includes(candidateLower)\n   694→    );\n   695→    return !hasLongerParent;\n   696→  });\n   697→\n   698→  // Deduplicate: if one title is a substring of another, keep the shorter (more focused) one.\n   699→  // DO NOT CHANGE THIS LOGIC — it has been incorrectly \"improved\" by the title-loop 5 times.\n   700→  // The tests require shorter wins: \"Pierogi Ruskie\" over \"Pierogi Ruskie 200g mąki 3 ziemniaki\".\n   701→  // The pre-filter above handles the conflicting case (structural heading prefix removal) so that\n   702→  // the incomplete prefix line is never present here when the complete join is in selected.\n   703→  selected = selected.filter((a) => {\n   704→    const aLower = a.text.toLowerCase();\n   705→    return !selected.some(\n   706→      (b) =>\n   707→        b !== a &&\n   708→        aLower.includes(b.text.toLowerCase()) &&\n   709→        b.text.length < a.text.length\n   710→    );\n   711→  });\n   712→\n   713→  // Multi-title guard: only join multiple candidates with \"+\" when there is\n   714→  // structural evidence of a multi-recipe page (≥2 ALL_CAPS headings).\n   715→  // A single ALL_CAPS title among mixed-case survivors is a single-recipe page —\n   716→  // collapse to the highest-scoring candidate.\n   717→  // Zero ALL_CAPS survivors → mixed-case multi-title page → keep all.\n   718→  if (selected.length > 1) {\n   719→    const allCapsSelected = selected.filter((s) => isAllCaps(s.text));\n   720→    if (allCapsSelected.length >= 2) {\n   721→      // Check whether non-first ALL_CAPS headings are section headers within one recipe\n   722→      // (followed immediately by ingredient-like content) rather than separate recipe titles.\n   723→      // A multi-recipe page has body text between titles; a single-recipe page has\n   724→      // ingredient lines immediately after each section heading.\n   725→      const sortedCaps = [...allCapsSelected].sort((a, b) => a.position - b.position);\n   726→      const isSubHeader = sortedCaps.slice(1).every((cap) => {\n   727→        const nextLines = lines.slice(cap.position + 1, cap.position + 3);\n   728→        return nextLines.some(\n   729→          (l) => looksLikeIngredient(l.trim()) || /^\\s*\\d/.test(l.trim())\n   730→        );\n   731→      });\n   732→      if (isSubHeader) {\n   733→        selected = [sortedCaps[0]];\n   734→      } else {\n   735→        selected = allCapsSelected;\n   736→      }\n   737→    } else if (allCapsSelected.length === 1) {\n   738→      selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n   739→    }\n   740→  }\n   741→\n   742→  // Cap at 3, sort by document position\n   743→  selected.sort((a, b) => a.position - b.position);\n   744→  selected = selected.slice(0, 3);\n   745→\n   746→  if (selected.length === 0) {\n   747→    return undefined;\n   748→  }\n   749→\n   750→  return selected.map((s) => s.text).join(\" + \");\n   751→}\n   752→\n   753→/**\n   754→ * Extract potential recipe title from OCR text (sync heuristic fallback)\n   755→ */\n   756→export function extractTitle(text: string): string | undefined {\n   757→  if (!text || text.trim().length === 0) {\n   758→    return undefined;\n   759→  }\n   760→\n   761→  const lines = text.split(\"\\n\").map((line) => line.trim());\n   762→\n   763→  for (const line of lines) {\n   764→    if (line.length === 0) continue;\n   765→    if (line.length < 3 || line.length > 50) continue;\n   766→    if (looksLikeIngredient(line)) continue;\n   767→    if (isAllCaps(line)) continue;\n   768→    if (startsWithNumber(line)) continue;\n   769→    return line;\n   770→  }\n   771→\n   772→  return undefined;\n   773→}\n   774→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_016VPztTugtQjHecoZo6zBy1","session_id":"69be8f57-504b-40bc-8d20-876849e39e96","uuid":"002e021d-294c-4cc3-820e-6b07e17c71f8"}
