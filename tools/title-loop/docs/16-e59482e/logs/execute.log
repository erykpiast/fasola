{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DxzpYhX4qJMbGZL7JskMSE","type":"tool_result","content":"     1→/**\n     2→ * Title Extraction\n     3→ * Extracts potential recipe title from OCR text using heuristics or semantic embeddings\n     4→ */\n     5→\n     6→import { cosineSimilarity } from \"./embeddings\";\n     7→\n     8→export type EmbedFn = (text: string) => Promise<Array<number>>;\n     9→\n    10→const TITLE_REFERENCE =\n    11→  \"recipe name, dish title, name of the food, nazwa przepisu, nazwa dania\";\n    12→const HEADER_REFERENCE =\n    13→  \"ingredients list, cooking directions, section heading, składniki, przygotowanie, sposób wykonania\";\n    14→const NOISE_REFERENCE =\n    15→  \"page number, table of contents, book footer, garbled text\";\n    16→\n    17→/**\n    18→ * Measurement units commonly found in ingredient lists\n    19→ */\n    20→const MEASUREMENT_PATTERNS = [\n    21→  // English\n    22→  \"cup\",\n    23→  \"cups\",\n    24→  \"tbsp\",\n    25→  \"tsp\",\n    26→  \"tablespoon\",\n    27→  \"teaspoon\",\n    28→  // \"oz\" and \"lb\" are matched with word boundaries in looksLikeIngredient\n    29→  // to avoid false positives (\"oz\" in \"mozzarella\", \"lb\" in \"albacore\")\n    30→  \"gram\",\n    31→  \"grams\",\n    32→  \"kg\",\n    33→  \"ml\",\n    34→  \"liter\",\n    35→  \"pinch\",\n    36→  \"dash\",\n    37→  \"handful\",\n    38→  // Polish\n    39→  \"łyżka\", \"łyżki\", \"łyżek\",           // tablespoon(s)\n    40→  \"łyżeczka\", \"łyżeczki\", \"łyżeczek\",   // teaspoon(s)\n    41→  \"szklanka\", \"szklanki\", \"szklanek\",    // cup(s)\n    42→  \"szczypta\",                            // pinch\n    43→  \"garść\",                               // handful\n    44→  \"opakowanie\", \"opakowania\",            // package(s)\n    45→  \"plasterek\", \"plasterki\",             // slice(s)\n    46→];\n    47→\n    48→/**\n    49→ * Patterns that identify recipe metadata lines (not titles)\n    50→ */\n    51→const METADATA_PATTERNS = [\n    52→  /^(SERVES?|MAKES?|YIELDS?)\\b/i,\n    53→  /^(PREP(ARATION)?|COOK(ING)?|PROOF|RISING|FERMENTATION|REST(ING)?)\\s*(AND\\s*)?(COOK(ING)?)?\\s*TIME/i,\n    54→  /^SAMPLE\\s+SCHEDULE\\b/i,\n    55→  /^BULK\\s+FERMENTATION\\b/i,\n    56→  /^(THIS\\s+RECIPE\\s+)?MAKES\\b/i,\n    57→  // Polish serving-size patterns: \"NA 3 PAPRYKI\", \"NA OKOŁO 1 KG\", \"DLA 4 OSÓB\"\n    58→  /^NA\\s+(\\d|OKOŁO)\\b/i,\n    59→  /^DLA\\s+\\d/i,\n    60→  // OCR-resilient: \"DLA\" + any token + serving-unit word (handles DLA & OSOB, DLA § OSOB, etc.)\n    61→  /^DLA\\s+\\S+\\s+OSOB/i,\n    62→  // OCR-resilient: \"DLA\" + single non-alphanumeric char (common digit→symbol OCR error)\n    63→  /^DLA\\s+[^a-zA-Z0-9\\s]\\s/i,\n    64→  // Time-unit metadata: any line containing \"N MIN\" or \"N GODZ\" is prep/cook/rest time,\n    65→  // regardless of OCR-corrupted prefix (catches PRZYGOTOWANTE, GOTOMANTE, etc.)\n    66→  /\\b\\d+\\s*MIN\\b/i,\n    67→  /\\b\\d+\\s*GODZ/i,\n    68→];\n    69→\n    70→/**\n    71→ * Single-word non-title words — standalone OCR fragments unlikely to be recipe titles\n    72→ */\n    73→const NON_TITLE_WORDS = new Set([\n    74→  \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"are\", \"was\",\n    75→  \"has\", \"his\", \"her\", \"its\", \"our\", \"who\", \"how\", \"may\", \"new\", \"now\",\n    76→  \"old\", \"see\", \"way\", \"did\", \"get\", \"let\", \"say\", \"she\", \"too\", \"use\",\n    77→  \"buns\", \"with\",\n    78→]);\n    79→\n    80→function looksLikeIngredient(line: string): boolean {\n    81→  const lowerLine = line.toLowerCase();\n    82→  if (MEASUREMENT_PATTERNS.some((pattern) => lowerLine.includes(pattern))) return true;\n    83→  // Compact metric: \"100g\", \"50ml\", \"250g\" — digit immediately followed by g/ml/kg\n    84→  if (/\\b\\d+\\s*(?:g|ml|kg)\\b/i.test(line)) return true;\n    85→  // \"to taste\" / \"do smaku\" — qualitative ingredient with no unit\n    86→  if (/\\bto taste\\b/i.test(line) || /\\bdo smaku\\b/i.test(line)) return true;\n    87→  return false;\n    88→}\n    89→\n    90→function startsWithNumber(line: string): boolean {\n    91→  // Match lines starting with a digit, or bullet-then-digit (e.g., \"- 2 jajka\")\n    92→  return /^\\s*(?:[-•*]\\s*)?\\d/.test(line);\n    93→}\n    94→\n    95→/**\n    96→ * Known recipe section labels — these are structural headers, not recipe titles.\n    97→ * Matched case-insensitively after trimming and stripping trailing punctuation (colon, period).\n    98→ */\n    99→const SECTION_LABELS = new Set([\n   100→  // English\n   101→  \"ingredients\", \"directions\", \"instructions\", \"method\", \"preparation\",\n   102→  \"steps\", \"notes\", \"tip\", \"tips\", \"variations\", \"variation\",\n   103→  \"garnish\", \"topping\", \"toppings\", \"frosting\", \"filling\",\n   104→  // Polish\n   105→  \"składniki\", \"przygotowanie\", \"sposób przygotowania\", \"sposób wykonania\",\n   106→  \"wykonanie\", \"wskazówki\", \"podpowiedź\", \"warianty\",\n   107→  \"sos\", \"nadzienie\", \"polewa\", \"lukier\", \"ciasto\",\n   108→]);\n   109→\n   110→function isSectionLabel(text: string): boolean {\n   111→  const normalized = text.trim().replace(/[:.]$/, \"\").toLowerCase();\n   112→  return SECTION_LABELS.has(normalized);\n   113→}\n   114→\n   115→function isAllCaps(line: string): boolean {\n   116→  const letters = line.replace(/[^a-zA-Z]/g, \"\");\n   117→  return letters.length > 0 && letters === letters.toUpperCase();\n   118→}\n   119→\n   120→function looksLikeMetadata(text: string): boolean {\n   121→  return METADATA_PATTERNS.some((pattern) => pattern.test(text.trim()));\n   122→}\n   123→\n   124→function isLikelyGarbled(text: string): boolean {\n   125→  const letters = text.replace(/[^a-zA-Z]/g, \"\");\n   126→  if (letters.length < 2) return true;\n   127→\n   128→  // Check vowel ratio — English/Polish text typically has 30–50% vowels\n   129→  const vowels = letters.replace(/[^aeiouAEIOUyYąęóĄĘÓ]/g, \"\").length;\n   130→  const vowelRatio = vowels / letters.length;\n   131→  if (vowelRatio < 0.15 || vowelRatio > 0.85) return true;\n   132→\n   133→  // Single orphaned word ≤3 letters that isn't a common word\n   134→  const words = text.trim().split(/\\s+/);\n   135→  const COMMON_SHORT = new Set([\n   136→    \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"had\", \"her\",\n   137→    \"was\", \"one\", \"our\", \"out\", \"are\", \"has\", \"his\", \"how\", \"its\", \"may\",\n   138→    \"new\", \"now\", \"old\", \"see\", \"way\", \"who\", \"did\", \"get\", \"let\", \"say\",\n   139→    \"she\", \"too\", \"use\",\n   140→  ]);\n   141→  if (words.length === 1 && letters.length <= 3 && !COMMON_SHORT.has(text.trim().toLowerCase())) {\n   142→    return true;\n   143→  }\n   144→\n   145→  // Single word with internal lowercase→uppercase transition — OCR noise (e.g., \"UuIw\", \"aBC\")\n   146→  // No recipe title uses this pattern as a standalone single-word candidate.\n   147→  if (words.length === 1 && /[a-z][A-Z]/.test(text.trim())) {\n   148→    return true;\n   149→  }\n   150→\n   151→  // Recipe titles never start with a lowercase letter\n   152→  if (/^[a-z]/.test(text.trim())) {\n   153→    return true;\n   154→  }\n   155→\n   156→  // Mid-text sentence boundary (\". \" followed by a letter) — body text fragment spliced from multiple sentences\n   157→  const trimmed = text.trim();\n   158→  if (/\\.\\s+[a-zA-Z]/.test(trimmed) && !trimmed.endsWith(\")\")) {\n   159→    return true;\n   160→  }\n   161→\n   162→  // Multi-word candidate containing a garbled OCR fragment: a short lowercase word that isn't a known short word\n   163→  if (words.length >= 2) {\n   164→    const commonShort2 = new Set([\n   165→      \"a\", \"i\", \"of\", \"or\", \"to\", \"in\", \"on\", \"is\", \"it\", \"an\",\n   166→      \"as\", \"at\", \"by\", \"do\", \"go\", \"if\", \"no\", \"so\", \"up\", \"we\",\n   167→      \"w\", \"z\",  // Polish prepositions\n   168→    ]);\n   169→    const hasGarbledWord = words.some(\n   170→      (w) =>\n   171→        /^[a-z]/.test(w) &&\n   172→        w.replace(/[^a-z]/g, \"\").length <= 2 &&\n   173→        !commonShort2.has(w.toLowerCase())\n   174→    );\n   175→    if (hasGarbledWord) {\n   176→      return true;\n   177→    }\n   178→  }\n   179→\n   180→  return false;\n   181→}\n   182→\n   183→function passesHardFilters(text: string): boolean {\n   184→  if (text.length < 3 || text.length > 80) return false;\n   185→  if (looksLikeIngredient(text)) return false;\n   186→  if (startsWithNumber(text)) return false;\n   187→  if (looksLikeMetadata(text)) return false;\n   188→  if (isLikelyGarbled(text)) return false;\n   189→  // Pipe-separated lines are book category/chapter headers, not recipe titles\n   190→  if (text.includes(\" | \")) return false;\n   191→  // Slash-separated breadcrumbs (e.g., \"/ Jesien / Zupy\") are navigation, not titles\n   192→  // Only filter when 2+ slashes are present — single-slash lines like\n   193→  // \"TITLE / SUBTITLE\" are legitimate continuation-merged titles\n   194→  if ((text.match(/\\//g) || []).length >= 2) return false;\n   195→  // Bullet-list items (ingredients or instruction steps) are never titles\n   196→  if (/^\\s*[-•*]\\s/.test(text)) return false;\n   197→  // Known recipe section labels are structural headers, not titles\n   198→  if (isSectionLabel(text)) return false;\n   199→  // Single-word non-title fragments\n   200→  const words = text.trim().split(/\\s+/);\n   201→  if (words.length === 1 && NON_TITLE_WORDS.has(text.trim().toLowerCase())) return false;\n   202→  return true;\n   203→}\n   204→\n   205→/**\n   206→ * Detect initial burst of short garbled lines.\n   207→ * Returns the index of the first non-garbled or long line.\n   208→ */\n   209→function findBurstEnd(lines: Array<{ text: string }>): number {\n   210→  let i = 0;\n   211→  while (i < lines.length && lines[i].text.length < 20 && isLikelyGarbled(lines[i].text)) {\n   212→    i++;\n   213→  }\n   214→  return i;\n   215→}\n   216→\n   217→function wordCount(text: string): number {\n   218→  return text.split(/\\s+/).filter((w) => w.length > 0).length;\n   219→}\n   220→\n   221→/**\n   222→ * Build candidate strings from lines: single lines plus multi-line joins (2-3 consecutive).\n   223→ * Skips initial burst of short garbled lines. Scans all remaining lines. Caps at 25.\n   224→ */\n   225→export type CandidateOrigin = \"single\" | \"2-line\" | \"3-line\";\n   226→\n   227→function buildCandidates(\n   228→  lines: Array<string>\n   229→): Array<{ text: string; position: number; origin: CandidateOrigin }> {\n   230→  const nonEmptyLines: Array<{ text: string; index: number }> = [];\n   231→\n   232→  for (let i = 0; i < lines.length; i++) {\n   233→    const trimmed = lines[i].trim();\n   234→    if (trimmed.length > 0) {\n   235→      nonEmptyLines.push({ text: trimmed, index: i });\n   236→    }\n   237→  }\n   238→\n   239→  const burstEnd = findBurstEnd(nonEmptyLines);\n   240→\n   241→  // Pre-merge consecutive short ALL_CAPS lines (OCR-fragmented headings).\n   242→  // When a sequence of 2+ ALL_CAPS lines each has ≤2 words and ≤25 chars, they are\n   243→  // almost certainly OCR fragments of a single heading. Merge them into one line so\n   244→  // the complete title enters the candidate pool without hitting the 3-line join ceiling.\n   245→  const capsCoalesced: Array<{ text: string; index: number }> = [];\n   246→  let ci = burstEnd;\n   247→  while (ci < nonEmptyLines.length) {\n   248→    const line = nonEmptyLines[ci];\n   249→    if (\n   250→      isAllCaps(line.text) &&\n   251→      wordCount(line.text) <= 2 &&\n   252→      line.text.length <= 25 &&\n   253→      !isSectionLabel(line.text) &&\n   254→      !looksLikeMetadata(line.text)\n   255→    ) {\n   256→      let merged = line.text;\n   257→      const startIndex = line.index;\n   258→      let j = ci + 1;\n   259→      while (j < nonEmptyLines.length) {\n   260→        const next = nonEmptyLines[j];\n   261→        if (\n   262→          isAllCaps(next.text) &&\n   263→          wordCount(next.text) <= 2 &&\n   264→          next.text.length <= 25 &&\n   265→          !isSectionLabel(next.text) &&\n   266→          !looksLikeMetadata(next.text) &&\n   267→          (merged + \" \" + next.text).length <= 80\n   268→        ) {\n   269→          merged += \" \" + next.text;\n   270→          j++;\n   271→        } else {\n   272→          break;\n   273→        }\n   274→      }\n   275→      if (j > ci + 1) {\n   276→        capsCoalesced.push({ text: merged, index: startIndex });\n   277→        ci = j;\n   278→        continue;\n   279→      }\n   280→    }\n   281→    capsCoalesced.push(line);\n   282→    ci++;\n   283→  }\n   284→\n   285→  // Pre-merge continuation lines: a line starting with /&+:( is never a standalone title.\n   286→  // Merge it into the preceding line so the complete title enters the pool as a single candidate,\n   287→  // avoiding the fragile chain of conditions required by the downstream join survival logic.\n   288→  // Limitation: only one continuation line per preceding line is merged. Titles split across\n   289→  // three or more lines with continuation tokens (rare in practice) are not handled here —\n   290→  // the downstream 2-line and 3-line join candidates cover those cases instead.\n   291→  const mergedLines: Array<{ text: string; index: number }> = [];\n   292→  for (let i = 0; i < capsCoalesced.length; i++) {\n   293→    const line = capsCoalesced[i];\n   294→    if (i + 1 < capsCoalesced.length) {\n   295→      const nextText = capsCoalesced[i + 1].text;\n   296→      if (/^[/&+:(]/.test(nextText)) {\n   297→        mergedLines.push({ text: `${line.text} ${nextText}`, index: line.index });\n   298→        i++;\n   299→        continue;\n   300→      }\n   301→    }\n   302→    mergedLines.push(line);\n   303→  }\n   304→\n   305→  const candidates: Array<{ text: string; position: number; origin: CandidateOrigin }> = [];\n   306→  const seen = new Set<string>();\n   307→\n   308→  // Build a set of positions to skip: short ALL_CAPS lines immediately following metadata\n   309→  const metadataContinuationPositions = new Set<number>();\n   310→  for (let i = 0; i < mergedLines.length - 1; i++) {\n   311→    if (looksLikeMetadata(mergedLines[i].text)) {\n   312→      const next = mergedLines[i + 1];\n   313→      if (isAllCaps(next.text) && wordCount(next.text) <= 2 && next.text.length <= 15) {\n   314→        metadataContinuationPositions.add(next.index);\n   315→      }\n   316→    }\n   317→  }\n   318→\n   319→  for (let i = 0; i < mergedLines.length; i++) {\n   320→    const line = mergedLines[i];\n   321→\n   322→    // Skip metadata continuation fragments\n   323→    if (metadataContinuationPositions.has(line.index)) continue;\n   324→\n   325→    // Single line\n   326→    if (passesHardFilters(line.text)) {\n   327→      const norm = line.text.toLowerCase();\n   328→      if (!seen.has(norm)) {\n   329→        seen.add(norm);\n   330→        candidates.push({ text: line.text, position: line.index, origin: \"single\" });\n   331→      }\n   332→    }\n   333→\n   334→    // 2-line join — skip if first line is a section label (prevents \"INGREDIENTS TITLE\" joins)\n   335→    if (i + 1 < mergedLines.length && !isSectionLabel(line.text)) {\n   336→      const joined2 = `${line.text} ${mergedLines[i + 1].text}`;\n   337→      if (passesHardFilters(joined2)) {\n   338→        const norm = joined2.toLowerCase();\n   339→        if (!seen.has(norm)) {\n   340→          seen.add(norm);\n   341→          candidates.push({ text: joined2, position: line.index, origin: \"2-line\" });\n   342→        }\n   343→      }\n   344→    }\n   345→\n   346→    // 3-line join — skip if first line is a section label\n   347→    if (i + 2 < mergedLines.length && !isSectionLabel(line.text)) {\n   348→      const joined3 = `${line.text} ${mergedLines[i + 1].text} ${mergedLines[i + 2].text}`;\n   349→      if (passesHardFilters(joined3)) {\n   350→        const norm = joined3.toLowerCase();\n   351→        if (!seen.has(norm)) {\n   352→          seen.add(norm);\n   353→          candidates.push({ text: joined3, position: line.index, origin: \"3-line\" });\n   354→        }\n   355→      }\n   356→    }\n   357→  }\n   358→\n   359→  // Pre-filter to 25 before embedding calls: prefer ALL_CAPS and short candidates.\n   360→  // Position-based scoring handles final ranking.\n   361→  if (candidates.length > 25) {\n   362→    const prioritized = candidates.slice().sort((a, b) => {\n   363→      const aAllCaps = isAllCaps(a.text) ? 0 : 1;\n   364→      const bAllCaps = isAllCaps(b.text) ? 0 : 1;\n   365→      if (aAllCaps !== bAllCaps) return aAllCaps - bAllCaps;\n   366→      const aShort = wordCount(a.text) <= 5 ? 0 : 1;\n   367→      const bShort = wordCount(b.text) <= 5 ? 0 : 1;\n   368→      return aShort - bShort;\n   369→    });\n   370→    return prioritized.slice(0, 25);\n   371→  }\n   372→\n   373→  return candidates;\n   374→}\n   375→\n   376→// Module-level cache for reference embeddings\n   377→let cachedTitleRefEmbedding: Array<number> | null = null;\n   378→let cachedHeaderRefEmbedding: Array<number> | null = null;\n   379→let cachedNoiseRefEmbedding: Array<number> | null = null;\n   380→\n   381→export function _resetEmbeddingCacheForTests(): void {\n   382→  cachedTitleRefEmbedding = null;\n   383→  cachedHeaderRefEmbedding = null;\n   384→  cachedNoiseRefEmbedding = null;\n   385→}\n   386→\n   387→export async function extractTitleWithEmbeddings(\n   388→  text: string,\n   389→  embed: EmbedFn\n   390→): Promise<string | undefined> {\n   391→  if (!text || text.trim().length === 0) {\n   392→    return undefined;\n   393→  }\n   394→\n   395→  const lines = text.split(\"\\n\");\n   396→  const candidates = buildCandidates(lines);\n   397→\n   398→  if (candidates.length === 0) {\n   399→    return undefined;\n   400→  }\n   401→\n   402→  // Cache reference embeddings\n   403→  if (!cachedTitleRefEmbedding) {\n   404→    cachedTitleRefEmbedding = await embed(TITLE_REFERENCE);\n   405→  }\n   406→  if (!cachedHeaderRefEmbedding) {\n   407→    cachedHeaderRefEmbedding = await embed(HEADER_REFERENCE);\n   408→  }\n   409→  if (!cachedNoiseRefEmbedding) {\n   410→    cachedNoiseRefEmbedding = await embed(NOISE_REFERENCE);\n   411→  }\n   412→\n   413→  // Find ALL_CAPS candidates with ≥2 words where every significant word has ≥4 alpha letters.\n   414→  // Insignificant tokens (≤1 alpha letter: \"/\", \"&\", \"+\", \":\", \"D)\", etc.) are filtered before\n   415→  // the check so that multi-line joins with continuation punctuation still qualify.\n   416→  const isStructuralHeading = (c: { text: string }): boolean => {\n   417→    if (!isAllCaps(c.text) || wordCount(c.text) < 2) return false;\n   418→    const sigWords = c.text.trim().split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length > 1);\n   419→    return sigWords.length >= 2 && sigWords.every((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   420→  };\n   421→\n   422→  // Pass 1: compute rawScore for all candidates (embedding quality signal)\n   423→  const rawScored: Array<{ text: string; position: number; origin: CandidateOrigin; rawScore: number; embedding: Array<number> }> = [];\n   424→  for (const candidate of candidates) {\n   425→    const embedding = await embed(candidate.text);\n   426→    const titleSim = cosineSimilarity(embedding, cachedTitleRefEmbedding);\n   427→    const headerSim = cosineSimilarity(embedding, cachedHeaderRefEmbedding);\n   428→    const noiseSim = cosineSimilarity(embedding, cachedNoiseRefEmbedding);\n   429→    const rawScore = titleSim - Math.max(headerSim, noiseSim);\n   430→    rawScored.push({ text: candidate.text, position: candidate.position, origin: candidate.origin, rawScore, embedding });\n   431→  }\n   432→\n   433→  // Select baseHeading by embedding quality (rawScore), not position.\n   434→  // This prevents OCR-garbled fragments from claiming the structural heading slot.\n   435→  const structuralCandidates = rawScored.filter((s) => isStructuralHeading(s));\n   436→\n   437→  // Penalize structural headings with truncated OCR words:\n   438→  // if \"FRON\" appears and another heading has \"SAFFRON\", \"FRON\" is likely garbled.\n   439→  for (const sc of structuralCandidates) {\n   440→    const sigWords = sc.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   441→    for (const other of structuralCandidates) {\n   442→      if (other === sc) continue;\n   443→      const otherSigWords = other.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   444→      const hasTruncation = sigWords.some((w) =>\n   445→        otherSigWords.some((ow) => ow !== w && ow.length > w.length && ow.endsWith(w))\n   446→      );\n   447→      if (hasTruncation) {\n   448→        sc.rawScore = -1.0;  // Hard disqualification — truncated OCR artifact\n   449→        break;\n   450→      }\n   451→    }\n   452→  }\n   453→\n   454→  const bestStructural = structuralCandidates.length > 0\n   455→    ? structuralCandidates.reduce((a, b) => {\n   456→        const scoreDiff = a.rawScore - b.rawScore;\n   457→        if (Math.abs(scoreDiff) > 0.03) return scoreDiff > 0 ? a : b;\n   458→        // Tiebreak: single-line origin beats multi-line joins (avoids conflating two separate headings)\n   459→        if (a.origin === \"single\" && b.origin !== \"single\") return a;\n   460→        if (b.origin === \"single\" && a.origin !== \"single\") return b;\n   461→        // Tiebreak: more words (more specific) → better\n   462→        const wcDiff = wordCount(b.text) - wordCount(a.text);\n   463→        if (wcDiff !== 0) return wcDiff > 0 ? b : a;\n   464→        // Tiebreak: earlier position → better\n   465→        return a.position < b.position ? a : b;\n   466→      })\n   467→    : null;\n   468→  const baseHeading = bestStructural ?? undefined;\n   469→\n   470→  // When the best structural heading has a continuation on the next line introduced by a\n   471→  // punctuation token (/, &, +, :, or parenthesis), prefer the longer 2-line join as the\n   472→  // complete heading. E.g. \"SAFFRON WHEAT BUNS WITH QUARK\" + \"/ COTTAGE CHEESE (VARIATION D)\".\n   473→  // Guard: the remainder after the prefix must start with a continuation character to avoid\n   474→  // merging two separate consecutive recipe titles (FINNISH MILK FLATBREADS stays separate\n   475→  // from FINNISH POTATO FLATBREADS because \"FINNISH\" does not start with a continuation token).\n   476→  const firstStructuralHeading = baseHeading && (\n   477→    rawScored.find((c) => {\n   478→      if (!isStructuralHeading(c)) return false;\n   479→      const hLower = baseHeading.text.toLowerCase();\n   480→      const cLower = c.text.toLowerCase();\n   481→      return cLower.startsWith(hLower + \" \") && /^[/&+:(]/.test(cLower.slice(hLower.length + 1));\n   482→    }) ?? baseHeading\n   483→  );\n   484→\n   485→  // Pass 2: apply bonuses\n   486→  const scored: Array<{ text: string; position: number; origin: CandidateOrigin; score: number; rawScore: number; baseScore: number; thresholdScore: number }> = rawScored.map((rs) => {\n   487→    // Position factor: multiplicative tiebreaker — amplifies existing signal, doesn't replace it\n   488→    const relativePosition = rs.position / lines.length;\n   489→    const positionFactor = relativePosition < 0.5\n   490→      ? 1.0 + 0.12 * (1 - relativePosition * 2)\n   491→      : 1.0;\n   492→\n   493→    // ALL_CAPS bonus: recipe books use ALL_CAPS for titles and section headings\n   494→    const allCapsBonus = isAllCaps(rs.text) && rs.text.replace(/[^a-zA-Z]/g, \"\").length >= 4\n   495→      ? 0.08\n   496→      : 0;\n   497→\n   498→    // Structural heading bonus: best ALL_CAPS heading (or its continuation join) is almost always the recipe title\n   499→    const structuralBonus = firstStructuralHeading && rs.text === firstStructuralHeading.text ? 0.10 : 0;\n   500→\n   501→    // thresholdScore excludes structural bonus so the bonus doesn't inflate the threshold\n   502→    // and prevent equally-valid structural headings from passing on multi-recipe pages.\n   503→    const thresholdScore = rs.rawScore + allCapsBonus;\n   504→    // baseScore excludes position factor — used for diagnostics and ranking\n   505→    const baseScore = rs.rawScore + allCapsBonus + structuralBonus;\n   506→    const score = rs.rawScore * positionFactor + allCapsBonus + structuralBonus;\n   507→    return { text: rs.text, position: rs.position, origin: rs.origin, score, rawScore: rs.rawScore, baseScore, thresholdScore };\n   508→  });\n   509→\n   510→  if (scored.length === 0) {\n   511→    return undefined;\n   512→  }\n   513→\n   514→  // --- Pre-threshold bilingual title detection ---\n   515→  // When a mixed-case candidate at position 0 is followed by an ALL_CAPS candidate\n   516→  // at position ≤ 2 that is semantically similar to it, this is a bilingual recipe\n   517→  // page (e.g., Polish title + ALL_CAPS Korean romanization). Suppress confirmed\n   518→  // translation candidates before computing threshold so their bonuses don't inflate\n   519→  // the threshold beyond the mixed-case title's reach.\n   520→  // Note: we check position ≤ 2 (local proximity), not global ALL_CAPS count, so\n   521→  // section headers later in the document (SKŁADNIKI, WARZYWA, etc.) are irrelevant.\n   522→  let scoredForThreshold = scored;\n   523→  const prePos0 = scored.find((s) => s.position === 0 && !isAllCaps(s.text));\n   524→  if (prePos0) {\n   525→    const nearbyAllCaps = scored.filter(\n   526→      (s) => isAllCaps(s.text) && s.position >= 1 && s.position <= 2 && s.origin === \"single\"\n   527→    );\n   528→    const pos0Embedding = rawScored.find((r) => r.text === prePos0.text)?.embedding;\n   529→\n   530→    let translationCandidates: typeof nearbyAllCaps = [];\n   531→\n   532→    // Method 1: embedding similarity (works for related languages)\n   533→    if (pos0Embedding && nearbyAllCaps.length > 0) {\n   534→      translationCandidates = nearbyAllCaps.filter((cap) => {\n   535→        const capEmbedding = rawScored.find((r) => r.text === cap.text)?.embedding;\n   536→        if (!capEmbedding) return false;\n   537→        return cosineSimilarity(pos0Embedding, capEmbedding) > 0.4;\n   538→      });\n   539→    }\n   540→\n   541→    // Method 2: layout-based detection (cross-lingual fallback).\n   542→    // When embedding similarity is insufficient (e.g. Polish ↔ Korean romanization),\n   543→    // detect bilingual layout by position and word overlap:\n   544→    // mixed-case ≥2 words at pos 0 + ALL_CAPS ≥2 words at pos 1-2 with no shared words.\n   545→    if (translationCandidates.length === 0 && wordCount(prePos0.text) >= 2) {\n   546→      const pos0Words = new Set(\n   547→        prePos0.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2)\n   548→      );\n   549→      translationCandidates = nearbyAllCaps.filter((cap) => {\n   550→        if (wordCount(cap.text) < 2) return false;\n   551→        const capWords = cap.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2);\n   552→        return !capWords.some((w) => pos0Words.has(w));\n   553→      });\n   554→    }\n   555→\n   556→    if (translationCandidates.length > 0) {\n   557→      // Also suppress multi-line joins that start with the translation text\n   558→      // (e.g. \"PAPRIKA GYERAN-JJIM Ingredients\" starts with \"PAPRIKA GYERAN-JJIM\")\n   559→      scoredForThreshold = scored.filter((s) => {\n   560→        const sLower = s.text.toLowerCase();\n   561→        return !translationCandidates.some((t) => sLower.startsWith(t.text.toLowerCase()));\n   562→      });\n   563→    }\n   564→  }\n   565→\n   566→  // Use thresholdScore (excludes structural bonus) so the structural bonus doesn't inflate\n   567→  // the threshold and block equally-valid headings on multi-recipe pages.\n   568→  const bestThresholdScore = Math.max(...scoredForThreshold.map((s) => s.thresholdScore));\n   569→  const threshold = Math.max(0.08, bestThresholdScore * 0.7);\n   570→\n   571→  // Filter candidates above threshold\n   572→  let selected = scoredForThreshold.filter((s) => s.score >= threshold);\n   573→\n   574→  // Empty-pool fallback: when threshold filtering discards every candidate,\n   575→  // the hard filters' structural verdict should not be overruled by weak\n   576→  // embedding differentiation. Return the best positional candidate.\n   577→  if (selected.length === 0 && scored.length > 0) {\n   578→    const fallback = scored\n   579→      .slice()\n   580→      .sort((a, b) => a.position - b.position || b.score - a.score);\n   581→    selected = [fallback[0]];\n   582→  }\n   583→\n   584→  // Remove word-boundary prefixes of firstStructuralHeading when the heading itself survived\n   585→  // the threshold. Cases:\n   586→  //   ARAYES case:  firstStructuralHeading = \"ARAYES SHRAK\" (2-word join qualifies; \"ARAYES\"\n   587→  //     alone = 1 word, so it never qualified). Filter removes \"ARAYES\" so dedup keeps the join.\n   588→  //   SAFFRON case: baseHeading was the partial line; continuation logic above upgraded\n   589→  //     firstStructuralHeading to the full join. Filter removes the partial so dedup keeps join.\n   590→  // Safety: only fires when the complete heading itself is in selected (passed the threshold).\n   591→  if (firstStructuralHeading && selected.some((s) => s.text === firstStructuralHeading.text)) {\n   592→    const fshLower = firstStructuralHeading.text.toLowerCase();\n   593→    selected = selected.filter((s) => {\n   594→      if (s.text === firstStructuralHeading.text) return true;\n   595→      const sLower = s.text.toLowerCase();\n   596→      // Remove s if it is a space-delimited prefix of the structural heading\n   597→      return !fshLower.startsWith(sLower + \" \");\n   598→    });\n   599→  }\n   600→\n   601→  // Protect continuation joins: when a multi-line join (2-line or 3-line) survived the threshold\n   602→  // and its second part starts with a continuation character, remove the single-line prefix/suffix\n   603→  // so the dedup \"shorter wins\" rule doesn't destroy the complete join.\n   604→  // Note: the pre-merge step above already handles the common Baked Eggs case (&/continuation\n   605→  // on next line) by turning it into a single candidate — this block covers the rarer case where\n   606→  // a continuation-character join was generated as a 2-line/3-line candidate and the prefix\n   607→  // single also survived threshold independently (e.g. from a different code path or OCR layout).\n   608→  // Safety: only fires for joins whose continuation starts with /&+:( — digit continuations\n   609→  // like \"Pierogi Ruskie 200g mąki\" are NOT protected, so dedup correctly keeps the shorter form.\n   610→  const survivingJoins = selected.filter((s) => s.origin === \"2-line\" || s.origin === \"3-line\");\n   611→  if (survivingJoins.length > 0) {\n   612→    selected = selected.filter((s) => {\n   613→      if (s.origin !== \"single\") return true;\n   614→      const sLower = s.text.toLowerCase();\n   615→      // Remove PREFIX singles whose continuation join also survived\n   616→      const isPrefixOfJoin = survivingJoins.some((j) => {\n   617→        const jLower = j.text.toLowerCase();\n   618→        if (!jLower.startsWith(sLower + \" \")) return false;\n   619→        const remainder = jLower.slice(sLower.length + 1);\n   620→        return /^[/&+:(]/.test(remainder);\n   621→      });\n   622→      if (isPrefixOfJoin) return false;\n   623→      // Remove SUFFIX singles (e.g. \"& Coriander\") whose parent join also survived\n   624→      const isSuffixOfJoin = survivingJoins.some((j) => {\n   625→        const jLower = j.text.toLowerCase();\n   626→        if (!jLower.endsWith(\" \" + sLower)) return false;\n   627→        // Only remove if the suffix starts with a continuation character\n   628→        return /^[/&+:(]/.test(sLower);\n   629→      });\n   630→      if (isSuffixOfJoin) return false;\n   631→      return true;\n   632→    });\n   633→  }\n   634→\n   635→  // Pre-dedup: remove sub-section headers that are substrings of other surviving candidates.\n   636→  // A sub-section header is an ALL_CAPS candidate followed by ingredient-like lines in the source.\n   637→  // Example: \"CHLEBEK\" (bread section header, followed by \"500 g mąki\") is a substring of\n   638→  // \"CHLEBEK Z WARZYWAMI I BOCZKIEM\" (the real title). Without this filter, dedup kills the title.\n   639→  selected = selected.filter((candidate) => {\n   640→    if (!isAllCaps(candidate.text)) return true;\n   641→    // Check if this candidate is immediately followed by ingredient-like content\n   642→    const nextSourceLines = lines.slice(candidate.position + 1, candidate.position + 2);\n   643→    const followedByIngredients = nextSourceLines.some(\n   644→      (l) => looksLikeIngredient(l.trim()) || startsWithNumber(l.trim())\n   645→    );\n   646→    if (!followedByIngredients) return true;\n   647→    // Only remove if a longer candidate contains this one as a substring\n   648→    const candidateLower = candidate.text.toLowerCase();\n   649→    const hasLongerParent = rawScored.some(\n   650→      (other) =>\n   651→        other.text !== candidate.text &&\n   652→        other.text.length > candidate.text.length &&\n   653→        other.text.toLowerCase().includes(candidateLower)\n   654→    );\n   655→    return !hasLongerParent;\n   656→  });\n   657→\n   658→  // Deduplicate: if one title is a substring of another, keep the shorter (more focused) one.\n   659→  // DO NOT CHANGE THIS LOGIC — it has been incorrectly \"improved\" by the title-loop 5 times.\n   660→  // The tests require shorter wins: \"Pierogi Ruskie\" over \"Pierogi Ruskie 200g mąki 3 ziemniaki\".\n   661→  // The pre-filter above handles the conflicting case (structural heading prefix removal) so that\n   662→  // the incomplete prefix line is never present here when the complete join is in selected.\n   663→  selected = selected.filter((a) => {\n   664→    const aLower = a.text.toLowerCase();\n   665→    return !selected.some(\n   666→      (b) =>\n   667→        b !== a &&\n   668→        aLower.includes(b.text.toLowerCase()) &&\n   669→        b.text.length < a.text.length\n   670→    );\n   671→  });\n   672→\n   673→  // Multi-title guard: only join multiple candidates with \"+\" when there is\n   674→  // structural evidence of a multi-recipe page (≥2 ALL_CAPS headings).\n   675→  // A single ALL_CAPS title among mixed-case survivors is a single-recipe page —\n   676→  // collapse to the highest-scoring candidate.\n   677→  // Zero ALL_CAPS survivors → mixed-case multi-title page → keep all.\n   678→  if (selected.length > 1) {\n   679→    const allCapsSelected = selected.filter((s) => isAllCaps(s.text));\n   680→    if (allCapsSelected.length >= 2) {\n   681→      // Check whether non-first ALL_CAPS headings are section headers within one recipe\n   682→      // (followed immediately by ingredient-like content) rather than separate recipe titles.\n   683→      // A multi-recipe page has body text between titles; a single-recipe page has\n   684→      // ingredient lines immediately after each section heading.\n   685→      const sortedCaps = [...allCapsSelected].sort((a, b) => a.position - b.position);\n   686→      const isSubHeader = sortedCaps.slice(1).every((cap) => {\n   687→        const nextLines = lines.slice(cap.position + 1, cap.position + 3);\n   688→        return nextLines.some(\n   689→          (l) => looksLikeIngredient(l.trim()) || /^\\s*\\d/.test(l.trim())\n   690→        );\n   691→      });\n   692→      if (isSubHeader) {\n   693→        selected = [sortedCaps[0]];\n   694→      } else {\n   695→        selected = allCapsSelected;\n   696→      }\n   697→    } else if (allCapsSelected.length === 1) {\n   698→      selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n   699→    }\n   700→  }\n   701→\n   702→  // Cap at 3, sort by document position\n   703→  selected.sort((a, b) => a.position - b.position);\n   704→  selected = selected.slice(0, 3);\n   705→\n   706→  if (selected.length === 0) {\n   707→    return undefined;\n   708→  }\n   709→\n   710→  return selected.map((s) => s.text).join(\" + \");\n   711→}\n   712→\n   713→/**\n   714→ * Extract potential recipe title from OCR text (sync heuristic fallback)\n   715→ */\n   716→export function extractTitle(text: string): string | undefined {\n   717→  if (!text || text.trim().length === 0) {\n   718→    return undefined;\n   719→  }\n   720→\n   721→  const lines = text.split(\"\\n\").map((line) => line.trim());\n   722→\n   723→  for (const line of lines) {\n   724→    if (line.length === 0) continue;\n   725→    if (line.length < 3 || line.length > 50) continue;\n   726→    if (looksLikeIngredient(line)) continue;\n   727→    if (isAllCaps(line)) continue;\n   728→    if (startsWithNumber(line)) continue;\n   729→    return line;\n   730→  }\n   731→\n   732→  return undefined;\n   733→}\n   734→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"69be8f57-504b-40bc-8d20-876849e39e96","uuid":"e52e8821-1dad-4973-be87-60b271fd2ddd","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/title-extractor.ts","content":"/**\n * Title Extraction\n * Extracts potential recipe title from OCR text using heuristics or semantic embeddings\n */\n\nimport { cosineSimilarity } from \"./embeddings\";\n\nexport type EmbedFn = (text: string) => Promise<Array<number>>;\n\nconst TITLE_REFERENCE =\n  \"recipe name, dish title, name of the food, nazwa przepisu, nazwa dania\";\nconst HEADER_REFERENCE =\n  \"ingredients list, cooking directions, section heading, składniki, przygotowanie, sposób wykonania\";\nconst NOISE_REFERENCE =\n  \"page number, table of contents, book footer, garbled text\";\n\n/**\n * Measurement units commonly found in ingredient lists\n */\nconst MEASUREMENT_PATTERNS = [\n  // English\n  \"cup\",\n  \"cups\",\n  \"tbsp\",\n  \"tsp\",\n  \"tablespoon\",\n  \"teaspoon\",\n  // \"oz\" and \"lb\" are matched with word boundaries in looksLikeIngredient\n  // to avoid false positives (\"oz\" in \"mozzarella\", \"lb\" in \"albacore\")\n  \"gram\",\n  \"grams\",\n  \"kg\",\n  \"ml\",\n  \"liter\",\n  \"pinch\",\n  \"dash\",\n  \"handful\",\n  // Polish\n  \"łyżka\", \"łyżki\", \"łyżek\",           // tablespoon(s)\n  \"łyżeczka\", \"łyżeczki\", \"łyżeczek\",   // teaspoon(s)\n  \"szklanka\", \"szklanki\", \"szklanek\",    // cup(s)\n  \"szczypta\",                            // pinch\n  \"garść\",                               // handful\n  \"opakowanie\", \"opakowania\",            // package(s)\n  \"plasterek\", \"plasterki\",             // slice(s)\n];\n\n/**\n * Patterns that identify recipe metadata lines (not titles)\n */\nconst METADATA_PATTERNS = [\n  /^(SERVES?|MAKES?|YIELDS?)\\b/i,\n  /^(PREP(ARATION)?|COOK(ING)?|PROOF|RISING|FERMENTATION|REST(ING)?)\\s*(AND\\s*)?(COOK(ING)?)?\\s*TIME/i,\n  /^SAMPLE\\s+SCHEDULE\\b/i,\n  /^BULK\\s+FERMENTATION\\b/i,\n  /^(THIS\\s+RECIPE\\s+)?MAKES\\b/i,\n  // Polish serving-size patterns: \"NA 3 PAPRYKI\", \"NA OKOŁO 1 KG\", \"DLA 4 OSÓB\"\n  /^NA\\s+(\\d|OKOŁO)\\b/i,\n  /^DLA\\s+\\d/i,\n  // OCR-resilient: \"DLA\" + any token + serving-unit word (handles DLA & OSOB, DLA § OSOB, etc.)\n  /^DLA\\s+\\S+\\s+OSOB/i,\n  // OCR-resilient: \"DLA\" + single non-alphanumeric char (common digit→symbol OCR error)\n  /^DLA\\s+[^a-zA-Z0-9\\s]\\s/i,\n  // Time-unit metadata: any line containing \"N MIN\" or \"N GODZ\" is prep/cook/rest time,\n  // regardless of OCR-corrupted prefix (catches PRZYGOTOWANTE, GOTOMANTE, etc.)\n  /\\b\\d+\\s*MIN\\b/i,\n  /\\b\\d+\\s*GODZ/i,\n];\n\n/**\n * Single-word non-title words — standalone OCR fragments unlikely to be recipe titles\n */\nconst NON_TITLE_WORDS = new Set([\n  \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"are\", \"was\",\n  \"has\", \"his\", \"her\", \"its\", \"our\", \"who\", \"how\", \"may\", \"new\", \"now\",\n  \"old\", \"see\", \"way\", \"did\", \"get\", \"let\", \"say\", \"she\", \"too\", \"use\",\n  \"buns\", \"with\",\n]);\n\nfunction looksLikeIngredient(line: string): boolean {\n  const lowerLine = line.toLowerCase();\n  if (MEASUREMENT_PATTERNS.some((pattern) => lowerLine.includes(pattern))) return true;\n  // Compact metric: \"100g\", \"50ml\", \"250g\" — digit immediately followed by g/ml/kg\n  if (/\\b\\d+\\s*(?:g|ml|kg)\\b/i.test(line)) return true;\n  // \"to taste\" / \"do smaku\" — qualitative ingredient with no unit\n  if (/\\bto taste\\b/i.test(line) || /\\bdo smaku\\b/i.test(line)) return true;\n  return false;\n}\n\nfunction startsWithNumber(line: string): boolean {\n  // Match lines starting with a digit, or bullet-then-digit (e.g., \"- 2 jajka\")\n  return /^\\s*(?:[-•*]\\s*)?\\d/.test(line);\n}\n\n/**\n * Known recipe section labels — these are structural headers, not recipe titles.\n * Matched case-insensitively after trimming and stripping trailing punctuation (colon, period).\n */\nconst SECTION_LABELS = new Set([\n  // English\n  \"ingredients\", \"directions\", \"instructions\", \"method\", \"preparation\",\n  \"steps\", \"notes\", \"tip\", \"tips\", \"variations\", \"variation\",\n  \"garnish\", \"topping\", \"toppings\", \"frosting\", \"filling\",\n  // Polish\n  \"składniki\", \"przygotowanie\", \"sposób przygotowania\", \"sposób wykonania\",\n  \"wykonanie\", \"wskazówki\", \"podpowiedź\", \"warianty\",\n  \"sos\", \"nadzienie\", \"polewa\", \"lukier\", \"ciasto\",\n]);\n\nfunction isSectionLabel(text: string): boolean {\n  const normalized = text.trim().replace(/[:.]$/, \"\").toLowerCase();\n  return SECTION_LABELS.has(normalized);\n}\n\nfunction isAllCaps(line: string): boolean {\n  const letters = line.replace(/[^a-zA-Z]/g, \"\");\n  return letters.length > 0 && letters === letters.toUpperCase();\n}\n\nfunction looksLikeMetadata(text: string): boolean {\n  return METADATA_PATTERNS.some((pattern) => pattern.test(text.trim()));\n}\n\nfunction isLikelyGarbled(text: string): boolean {\n  const letters = text.replace(/[^a-zA-Z]/g, \"\");\n  if (letters.length < 2) return true;\n\n  // Check vowel ratio — English/Polish text typically has 30–50% vowels\n  const vowels = letters.replace(/[^aeiouAEIOUyYąęóĄĘÓ]/g, \"\").length;\n  const vowelRatio = vowels / letters.length;\n  if (vowelRatio < 0.15 || vowelRatio > 0.85) return true;\n\n  // Single orphaned word ≤3 letters that isn't a common word\n  const words = text.trim().split(/\\s+/);\n  const COMMON_SHORT = new Set([\n    \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"had\", \"her\",\n    \"was\", \"one\", \"our\", \"out\", \"are\", \"has\", \"his\", \"how\", \"its\", \"may\",\n    \"new\", \"now\", \"old\", \"see\", \"way\", \"who\", \"did\", \"get\", \"let\", \"say\",\n    \"she\", \"too\", \"use\",\n  ]);\n  if (words.length === 1 && letters.length <= 3 && !COMMON_SHORT.has(text.trim().toLowerCase())) {\n    return true;\n  }\n\n  // Single word with internal lowercase→uppercase transition — OCR noise (e.g., \"UuIw\", \"aBC\")\n  // No recipe title uses this pattern as a standalone single-word candidate.\n  if (words.length === 1 && /[a-z][A-Z]/.test(text.trim())) {\n    return true;\n  }\n\n  // Recipe titles never start with a lowercase letter\n  if (/^[a-z]/.test(text.trim())) {\n    return true;\n  }\n\n  // Mid-text sentence boundary (\". \" followed by a letter) — body text fragment spliced from multiple sentences\n  const trimmed = text.trim();\n  if (/\\.\\s+[a-zA-Z]/.test(trimmed) && !trimmed.endsWith(\")\")) {\n    return true;\n  }\n\n  // Multi-word candidate containing a garbled OCR fragment: a short lowercase word that isn't a known short word\n  if (words.length >= 2) {\n    const commonShort2 = new Set([\n      \"a\", \"i\", \"of\", \"or\", \"to\", \"in\", \"on\", \"is\", \"it\", \"an\",\n      \"as\", \"at\", \"by\", \"do\", \"go\", \"if\", \"no\", \"so\", \"up\", \"we\",\n      \"w\", \"z\",  // Polish prepositions\n    ]);\n    const hasGarbledWord = words.some(\n      (w) =>\n        /^[a-z]/.test(w) &&\n        w.replace(/[^a-z]/g, \"\").length <= 2 &&\n        !commonShort2.has(w.toLowerCase())\n    );\n    if (hasGarbledWord) {\n      return true;\n    }\n  }\n\n  return false;\n}\n\nfunction passesHardFilters(text: string): boolean {\n  if (text.length < 3 || text.length > 80) return false;\n  if (looksLikeIngredient(text)) return false;\n  if (startsWithNumber(text)) return false;\n  if (looksLikeMetadata(text)) return false;\n  if (isLikelyGarbled(text)) return false;\n  // Pipe-separated lines are book category/chapter headers, not recipe titles\n  if (text.includes(\" | \")) return false;\n  // Slash-separated breadcrumbs (e.g., \"/ Jesien / Zupy\") are navigation, not titles\n  // Only filter when 2+ slashes are present — single-slash lines like\n  // \"TITLE / SUBTITLE\" are legitimate continuation-merged titles\n  if ((text.match(/\\//g) || []).length >= 2) return false;\n  // Bullet-list items (ingredients or instruction steps) are never titles\n  if (/^\\s*[-•*]\\s/.test(text)) return false;\n  // Known recipe section labels are structural headers, not titles\n  if (isSectionLabel(text)) return false;\n  // Single-word non-title fragments\n  const words = text.trim().split(/\\s+/);\n  if (words.length === 1 && NON_TITLE_WORDS.has(text.trim().toLowerCase())) return false;\n  return true;\n}\n\n/**\n * Detect initial burst of short garbled lines.\n * Returns the index of the first non-garbled or long line.\n */\nfunction findBurstEnd(lines: Array<{ text: string }>): number {\n  let i = 0;\n  while (i < lines.length && lines[i].text.length < 20 && isLikelyGarbled(lines[i].text)) {\n    i++;\n  }\n  return i;\n}\n\nfunction wordCount(text: string): number {\n  return text.split(/\\s+/).filter((w) => w.length > 0).length;\n}\n\n/**\n * Build candidate strings from lines: single lines plus multi-line joins (2-3 consecutive).\n * Skips initial burst of short garbled lines. Scans all remaining lines. Caps at 25.\n */\nexport type CandidateOrigin = \"single\" | \"2-line\" | \"3-line\";\n\nfunction buildCandidates(\n  lines: Array<string>\n): Array<{ text: string; position: number; origin: CandidateOrigin }> {\n  const nonEmptyLines: Array<{ text: string; index: number }> = [];\n\n  for (let i = 0; i < lines.length; i++) {\n    const trimmed = lines[i].trim();\n    if (trimmed.length > 0) {\n      nonEmptyLines.push({ text: trimmed, index: i });\n    }\n  }\n\n  const burstEnd = findBurstEnd(nonEmptyLines);\n\n  // Pre-merge consecutive short ALL_CAPS lines (OCR-fragmented headings).\n  // When a sequence of 2+ ALL_CAPS lines each has ≤2 words and ≤25 chars, they are\n  // almost certainly OCR fragments of a single heading. Merge them into one line so\n  // the complete title enters the candidate pool without hitting the 3-line join ceiling.\n  const capsCoalesced: Array<{ text: string; index: number }> = [];\n  let ci = burstEnd;\n  while (ci < nonEmptyLines.length) {\n    const line = nonEmptyLines[ci];\n    if (\n      isAllCaps(line.text) &&\n      wordCount(line.text) <= 2 &&\n      line.text.length <= 25 &&\n      !isSectionLabel(line.text) &&\n      !looksLikeMetadata(line.text)\n    ) {\n      let merged = line.text;\n      const startIndex = line.index;\n      let j = ci + 1;\n      while (j < nonEmptyLines.length) {\n        const next = nonEmptyLines[j];\n        if (\n          isAllCaps(next.text) &&\n          wordCount(next.text) <= 2 &&\n          next.text.length <= 25 &&\n          !isSectionLabel(next.text) &&\n          !looksLikeMetadata(next.text) &&\n          (merged + \" \" + next.text).length <= 80\n        ) {\n          merged += \" \" + next.text;\n          j++;\n        } else {\n          break;\n        }\n      }\n      if (j > ci + 1) {\n        capsCoalesced.push({ text: merged, index: startIndex });\n        ci = j;\n        continue;\n      }\n    }\n    capsCoalesced.push(line);\n    ci++;\n  }\n\n  // Pre-merge continuation lines: a line starting with /&+:( is never a standalone title.\n  // Merge it into the preceding line so the complete title enters the pool as a single candidate,\n  // avoiding the fragile chain of conditions required by the downstream join survival logic.\n  // Limitation: only one continuation line per preceding line is merged. Titles split across\n  // three or more lines with continuation tokens (rare in practice) are not handled here —\n  // the downstream 2-line and 3-line join candidates cover those cases instead.\n  const mergedLines: Array<{ text: string; index: number }> = [];\n  for (let i = 0; i < capsCoalesced.length; i++) {\n    const line = capsCoalesced[i];\n    if (i + 1 < capsCoalesced.length) {\n      const nextText = capsCoalesced[i + 1].text;\n      if (/^[/&+:(]/.test(nextText)) {\n        mergedLines.push({ text: `${line.text} ${nextText}`, index: line.index });\n        i++;\n        continue;\n      }\n    }\n    mergedLines.push(line);\n  }\n\n  const candidates: Array<{ text: string; position: number; origin: CandidateOrigin }> = [];\n  const seen = new Set<string>();\n\n  // Build a set of positions to skip: short ALL_CAPS lines immediately following metadata\n  const metadataContinuationPositions = new Set<number>();\n  for (let i = 0; i < mergedLines.length - 1; i++) {\n    if (looksLikeMetadata(mergedLines[i].text)) {\n      const next = mergedLines[i + 1];\n      if (isAllCaps(next.text) && wordCount(next.text) <= 2 && next.text.length <= 15) {\n        metadataContinuationPositions.add(next.index);\n      }\n    }\n  }\n\n  for (let i = 0; i < mergedLines.length; i++) {\n    const line = mergedLines[i];\n\n    // Skip metadata continuation fragments\n    if (metadataContinuationPositions.has(line.index)) continue;\n\n    // Single line\n    if (passesHardFilters(line.text)) {\n      const norm = line.text.toLowerCase();\n      if (!seen.has(norm)) {\n        seen.add(norm);\n        candidates.push({ text: line.text, position: line.index, origin: \"single\" });\n      }\n    }\n\n    // 2-line join — skip if first line is a section label (prevents \"INGREDIENTS TITLE\" joins)\n    if (i + 1 < mergedLines.length && !isSectionLabel(line.text)) {\n      const joined2 = `${line.text} ${mergedLines[i + 1].text}`;\n      if (passesHardFilters(joined2)) {\n        const norm = joined2.toLowerCase();\n        if (!seen.has(norm)) {\n          seen.add(norm);\n          candidates.push({ text: joined2, position: line.index, origin: \"2-line\" });\n        }\n      }\n    }\n\n    // 3-line join — skip if first line is a section label\n    if (i + 2 < mergedLines.length && !isSectionLabel(line.text)) {\n      const joined3 = `${line.text} ${mergedLines[i + 1].text} ${mergedLines[i + 2].text}`;\n      if (passesHardFilters(joined3)) {\n        const norm = joined3.toLowerCase();\n        if (!seen.has(norm)) {\n          seen.add(norm);\n          candidates.push({ text: joined3, position: line.index, origin: \"3-line\" });\n        }\n      }\n    }\n  }\n\n  // Pre-filter to 25 before embedding calls: prefer ALL_CAPS and short candidates.\n  // Position-based scoring handles final ranking.\n  if (candidates.length > 25) {\n    const prioritized = candidates.slice().sort((a, b) => {\n      const aAllCaps = isAllCaps(a.text) ? 0 : 1;\n      const bAllCaps = isAllCaps(b.text) ? 0 : 1;\n      if (aAllCaps !== bAllCaps) return aAllCaps - bAllCaps;\n      const aShort = wordCount(a.text) <= 5 ? 0 : 1;\n      const bShort = wordCount(b.text) <= 5 ? 0 : 1;\n      return aShort - bShort;\n    });\n    return prioritized.slice(0, 25);\n  }\n\n  return candidates;\n}\n\n// Module-level cache for reference embeddings\nlet cachedTitleRefEmbedding: Array<number> | null = null;\nlet cachedHeaderRefEmbedding: Array<number> | null = null;\nlet cachedNoiseRefEmbedding: Array<number> | null = null;\n\nexport function _resetEmbeddingCacheForTests(): void {\n  cachedTitleRefEmbedding = null;\n  cachedHeaderRefEmbedding = null;\n  cachedNoiseRefEmbedding = null;\n}\n\nexport async function extractTitleWithEmbeddings(\n  text: string,\n  embed: EmbedFn\n): Promise<string | undefined> {\n  if (!text || text.trim().length === 0) {\n    return undefined;\n  }\n\n  const lines = text.split(\"\\n\");\n  const candidates = buildCandidates(lines);\n\n  if (candidates.length === 0) {\n    return undefined;\n  }\n\n  // Cache reference embeddings\n  if (!cachedTitleRefEmbedding) {\n    cachedTitleRefEmbedding = await embed(TITLE_REFERENCE);\n  }\n  if (!cachedHeaderRefEmbedding) {\n    cachedHeaderRefEmbedding = await embed(HEADER_REFERENCE);\n  }\n  if (!cachedNoiseRefEmbedding) {\n    cachedNoiseRefEmbedding = await embed(NOISE_REFERENCE);\n  }\n\n  // Find ALL_CAPS candidates with ≥2 words where every significant word has ≥4 alpha letters.\n  // Insignificant tokens (≤1 alpha letter: \"/\", \"&\", \"+\", \":\", \"D)\", etc.) are filtered before\n  // the check so that multi-line joins with continuation punctuation still qualify.\n  const isStructuralHeading = (c: { text: string }): boolean => {\n    if (!isAllCaps(c.text) || wordCount(c.text) < 2) return false;\n    const sigWords = c.text.trim().split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length > 1);\n    return sigWords.length >= 2 && sigWords.every((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n  };\n\n  // Pass 1: compute rawScore for all candidates (embedding quality signal)\n  const rawScored: Array<{ text: string; position: number; origin: CandidateOrigin; rawScore: number; embedding: Array<number> }> = [];\n  for (const candidate of candidates) {\n    const embedding = await embed(candidate.text);\n    const titleSim = cosineSimilarity(embedding, cachedTitleRefEmbedding);\n    const headerSim = cosineSimilarity(embedding, cachedHeaderRefEmbedding);\n    const noiseSim = cosineSimilarity(embedding, cachedNoiseRefEmbedding);\n    const rawScore = titleSim - Math.max(headerSim, noiseSim);\n    rawScored.push({ text: candidate.text, position: candidate.position, origin: candidate.origin, rawScore, embedding });\n  }\n\n  // Select baseHeading by embedding quality (rawScore), not position.\n  // This prevents OCR-garbled fragments from claiming the structural heading slot.\n  const structuralCandidates = rawScored.filter((s) => isStructuralHeading(s));\n\n  // Penalize structural headings with truncated OCR words:\n  // if \"FRON\" appears and another heading has \"SAFFRON\", \"FRON\" is likely garbled.\n  for (const sc of structuralCandidates) {\n    const sigWords = sc.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n    for (const other of structuralCandidates) {\n      if (other === sc) continue;\n      const otherSigWords = other.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n      const hasTruncation = sigWords.some((w) =>\n        otherSigWords.some((ow) => ow !== w && ow.length > w.length && ow.endsWith(w))\n      );\n      if (hasTruncation) {\n        sc.rawScore = -1.0;  // Hard disqualification — truncated OCR artifact\n        break;\n      }\n    }\n  }\n\n  const bestStructural = structuralCandidates.length > 0\n    ? structuralCandidates.reduce((a, b) => {\n        const scoreDiff = a.rawScore - b.rawScore;\n        if (Math.abs(scoreDiff) > 0.03) return scoreDiff > 0 ? a : b;\n        // Tiebreak: single-line origin beats multi-line joins (avoids conflating two separate headings)\n        if (a.origin === \"single\" && b.origin !== \"single\") return a;\n        if (b.origin === \"single\" && a.origin !== \"single\") return b;\n        // Tiebreak: more words (more specific) → better\n        const wcDiff = wordCount(b.text) - wordCount(a.text);\n        if (wcDiff !== 0) return wcDiff > 0 ? b : a;\n        // Tiebreak: earlier position → better\n        return a.position < b.position ? a : b;\n      })\n    : null;\n  const baseHeading = bestStructural ?? undefined;\n\n  // When the best structural heading has a continuation on the next line introduced by a\n  // punctuation token (/, &, +, :, or parenthesis), prefer the longer 2-line join as the\n  // complete heading. E.g. \"SAFFRON WHEAT BUNS WITH QUARK\" + \"/ COTTAGE CHEESE (VARIATION D)\".\n  // Guard: the remainder after the prefix must start with a continuation character to avoid\n  // merging two separate consecutive recipe titles (FINNISH MILK FLATBREADS stays separate\n  // from FINNISH POTATO FLATBREADS because \"FINNISH\" does not start with a continuation token).\n  const firstStructuralHeading = baseHeading && (\n    rawScored.find((c) => {\n      if (!isStructuralHeading(c)) return false;\n      const hLower = baseHeading.text.toLowerCase();\n      const cLower = c.text.toLowerCase();\n      return cLower.startsWith(hLower + \" \") && /^[/&+:(]/.test(cLower.slice(hLower.length + 1));\n    }) ?? baseHeading\n  );\n\n  // Pass 2: apply bonuses\n  const scored: Array<{ text: string; position: number; origin: CandidateOrigin; score: number; rawScore: number; baseScore: number; thresholdScore: number }> = rawScored.map((rs) => {\n    // Position factor: multiplicative tiebreaker — amplifies existing signal, doesn't replace it\n    const relativePosition = rs.position / lines.length;\n    const positionFactor = relativePosition < 0.5\n      ? 1.0 + 0.12 * (1 - relativePosition * 2)\n      : 1.0;\n\n    // ALL_CAPS bonus: recipe books use ALL_CAPS for titles and section headings\n    const allCapsBonus = isAllCaps(rs.text) && rs.text.replace(/[^a-zA-Z]/g, \"\").length >= 4\n      ? 0.08\n      : 0;\n\n    // Structural heading bonus: best ALL_CAPS heading (or its continuation join) is almost always the recipe title\n    const structuralBonus = firstStructuralHeading && rs.text === firstStructuralHeading.text ? 0.10 : 0;\n\n    // thresholdScore excludes structural bonus so the bonus doesn't inflate the threshold\n    // and prevent equally-valid structural headings from passing on multi-recipe pages.\n    const thresholdScore = rs.rawScore + allCapsBonus;\n    // baseScore excludes position factor — used for diagnostics and ranking\n    const baseScore = rs.rawScore + allCapsBonus + structuralBonus;\n    const score = rs.rawScore * positionFactor + allCapsBonus + structuralBonus;\n    return { text: rs.text, position: rs.position, origin: rs.origin, score, rawScore: rs.rawScore, baseScore, thresholdScore };\n  });\n\n  if (scored.length === 0) {\n    return undefined;\n  }\n\n  // --- Pre-threshold bilingual title detection ---\n  // When a mixed-case candidate at position 0 is followed by an ALL_CAPS candidate\n  // at position ≤ 2 that is semantically similar to it, this is a bilingual recipe\n  // page (e.g., Polish title + ALL_CAPS Korean romanization). Suppress confirmed\n  // translation candidates before computing threshold so their bonuses don't inflate\n  // the threshold beyond the mixed-case title's reach.\n  // Note: we check position ≤ 2 (local proximity), not global ALL_CAPS count, so\n  // section headers later in the document (SKŁADNIKI, WARZYWA, etc.) are irrelevant.\n  let scoredForThreshold = scored;\n  const prePos0 = scored.find((s) => s.position === 0 && !isAllCaps(s.text));\n  if (prePos0) {\n    const nearbyAllCaps = scored.filter(\n      (s) => isAllCaps(s.text) && s.position >= 1 && s.position <= 2 && s.origin === \"single\"\n    );\n    const pos0Embedding = rawScored.find((r) => r.text === prePos0.text)?.embedding;\n\n    let translationCandidates: typeof nearbyAllCaps = [];\n\n    // Method 1: embedding similarity (works for related languages)\n    if (pos0Embedding && nearbyAllCaps.length > 0) {\n      translationCandidates = nearbyAllCaps.filter((cap) => {\n        const capEmbedding = rawScored.find((r) => r.text === cap.text)?.embedding;\n        if (!capEmbedding) return false;\n        return cosineSimilarity(pos0Embedding, capEmbedding) > 0.4;\n      });\n    }\n\n    // Method 2: layout-based detection (cross-lingual fallback).\n    // When embedding similarity is insufficient (e.g. Polish ↔ Korean romanization),\n    // detect bilingual layout by position and word overlap:\n    // mixed-case ≥2 words at pos 0 + ALL_CAPS ≥2 words at pos 1-2 with no shared words.\n    if (translationCandidates.length === 0 && wordCount(prePos0.text) >= 2) {\n      const pos0Words = new Set(\n        prePos0.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2)\n      );\n      translationCandidates = nearbyAllCaps.filter((cap) => {\n        if (wordCount(cap.text) < 2) return false;\n        const capWords = cap.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2);\n        return !capWords.some((w) => pos0Words.has(w));\n      });\n    }\n\n    if (translationCandidates.length > 0) {\n      // Also suppress multi-line joins that start with the translation text\n      // (e.g. \"PAPRIKA GYERAN-JJIM Ingredients\" starts with \"PAPRIKA GYERAN-JJIM\")\n      scoredForThreshold = scored.filter((s) => {\n        const sLower = s.text.toLowerCase();\n        return !translationCandidates.some((t) => sLower.startsWith(t.text.toLowerCase()));\n      });\n    }\n  }\n\n  // Use thresholdScore (excludes structural bonus) so the structural bonus doesn't inflate\n  // the threshold and block equally-valid headings on multi-recipe pages.\n  const bestThresholdScore = Math.max(...scoredForThreshold.map((s) => s.thresholdScore));\n  const threshold = Math.max(0.08, bestThresholdScore * 0.7);\n\n  // Filter candidates above threshold\n  let selected = scoredForThreshold.filter((s) => s.score >= threshold);\n\n  // Empty-pool fallback: when threshold filtering discards every candidate,\n  // the hard filters' structural verdict should not be overruled by weak\n  // embedding differentiation. Return the best positional candidate.\n  if (selected.length === 0 && scored.length > 0) {\n    const fallback = scored\n      .slice()\n      .sort((a, b) => a.position - b.position || b.score - a.score);\n    selected = [fallback[0]];\n  }\n\n  // Remove word-boundary prefixes of firstStructuralHeading when the heading itself survived\n  // the threshold. Cases:\n  //   ARAYES case:  firstStructuralHeading = \"ARAYES SHRAK\" (2-word join qualifies; \"ARAYES\"\n  //     alone = 1 word, so it never qualified). Filter removes \"ARAYES\" so dedup keeps the join.\n  //   SAFFRON case: baseHeading was the partial line; continuation logic above upgraded\n  //     firstStructuralHeading to the full join. Filter removes the partial so dedup keeps join.\n  // Safety: only fires when the complete heading itself is in selected (passed the threshold).\n  if (firstStructuralHeading && selected.some((s) => s.text === firstStructuralHeading.text)) {\n    const fshLower = firstStructuralHeading.text.toLowerCase();\n    selected = selected.filter((s) => {\n      if (s.text === firstStructuralHeading.text) return true;\n      const sLower = s.text.toLowerCase();\n      // Remove s if it is a space-delimited prefix of the structural heading\n      return !fshLower.startsWith(sLower + \" \");\n    });\n  }\n\n  // Protect continuation joins: when a multi-line join (2-line or 3-line) survived the threshold\n  // and its second part starts with a continuation character, remove the single-line prefix/suffix\n  // so the dedup \"shorter wins\" rule doesn't destroy the complete join.\n  // Note: the pre-merge step above already handles the common Baked Eggs case (&/continuation\n  // on next line) by turning it into a single candidate — this block covers the rarer case where\n  // a continuation-character join was generated as a 2-line/3-line candidate and the prefix\n  // single also survived threshold independently (e.g. from a different code path or OCR layout).\n  // Safety: only fires for joins whose continuation starts with /&+:( — digit continuations\n  // like \"Pierogi Ruskie 200g mąki\" are NOT protected, so dedup correctly keeps the shorter form.\n  const survivingJoins = selected.filter((s) => s.origin === \"2-line\" || s.origin === \"3-line\");\n  if (survivingJoins.length > 0) {\n    selected = selected.filter((s) => {\n      if (s.origin !== \"single\") return true;\n      const sLower = s.text.toLowerCase();\n      // Remove PREFIX singles whose continuation join also survived\n      const isPrefixOfJoin = survivingJoins.some((j) => {\n        const jLower = j.text.toLowerCase();\n        if (!jLower.startsWith(sLower + \" \")) return false;\n        const remainder = jLower.slice(sLower.length + 1);\n        return /^[/&+:(]/.test(remainder);\n      });\n      if (isPrefixOfJoin) return false;\n      // Remove SUFFIX singles (e.g. \"& Coriander\") whose parent join also survived\n      const isSuffixOfJoin = survivingJoins.some((j) => {\n        const jLower = j.text.toLowerCase();\n        if (!jLower.endsWith(\" \" + sLower)) return false;\n        // Only remove if the suffix starts with a continuation character\n        return /^[/&+:(]/.test(sLower);\n      });\n      if (isSuffixOfJoin) return false;\n      return true;\n    });\n  }\n\n  // Pre-dedup: remove sub-section headers that are substrings of other surviving candidates.\n  // A sub-section header is an ALL_CAPS candidate followed by ingredient-like lines in the source.\n  // Example: \"CHLEBEK\" (bread section header, followed by \"500 g mąki\") is a substring of\n  // \"CHLEBEK Z WARZYWAMI I BOCZKIEM\" (the real title). Without this filter, dedup kills the title.\n  selected = selected.filter((candidate) => {\n    if (!isAllCaps(candidate.text)) return true;\n    // Check if this candidate is immediately followed by ingredient-like content\n    const nextSourceLines = lines.slice(candidate.position + 1, candidate.position + 2);\n    const followedByIngredients = nextSourceLines.some(\n      (l) => looksLikeIngredient(l.trim()) || startsWithNumber(l.trim())\n    );\n    if (!followedByIngredients) return true;\n    // Only remove if a longer candidate contains this one as a substring\n    const candidateLower = candidate.text.toLowerCase();\n    const hasLongerParent = rawScored.some(\n      (other) =>\n        other.text !== candidate.text &&\n        other.text.length > candidate.text.length &&\n        other.text.toLowerCase().includes(candidateLower)\n    );\n    return !hasLongerParent;\n  });\n\n  // Deduplicate: if one title is a substring of another, keep the shorter (more focused) one.\n  // DO NOT CHANGE THIS LOGIC — it has been incorrectly \"improved\" by the title-loop 5 times.\n  // The tests require shorter wins: \"Pierogi Ruskie\" over \"Pierogi Ruskie 200g mąki 3 ziemniaki\".\n  // The pre-filter above handles the conflicting case (structural heading prefix removal) so that\n  // the incomplete prefix line is never present here when the complete join is in selected.\n  selected = selected.filter((a) => {\n    const aLower = a.text.toLowerCase();\n    return !selected.some(\n      (b) =>\n        b !== a &&\n        aLower.includes(b.text.toLowerCase()) &&\n        b.text.length < a.text.length\n    );\n  });\n\n  // Multi-title guard: only join multiple candidates with \"+\" when there is\n  // structural evidence of a multi-recipe page (≥2 ALL_CAPS headings).\n  // A single ALL_CAPS title among mixed-case survivors is a single-recipe page —\n  // collapse to the highest-scoring candidate.\n  // Zero ALL_CAPS survivors → mixed-case multi-title page → keep all.\n  if (selected.length > 1) {\n    const allCapsSelected = selected.filter((s) => isAllCaps(s.text));\n    if (allCapsSelected.length >= 2) {\n      // Check whether non-first ALL_CAPS headings are section headers within one recipe\n      // (followed immediately by ingredient-like content) rather than separate recipe titles.\n      // A multi-recipe page has body text between titles; a single-recipe page has\n      // ingredient lines immediately after each section heading.\n      const sortedCaps = [...allCapsSelected].sort((a, b) => a.position - b.position);\n      const isSubHeader = sortedCaps.slice(1).every((cap) => {\n        const nextLines = lines.slice(cap.position + 1, cap.position + 3);\n        return nextLines.some(\n          (l) => looksLikeIngredient(l.trim()) || /^\\s*\\d/.test(l.trim())\n        );\n      });\n      if (isSubHeader) {\n        selected = [sortedCaps[0]];\n      } else {\n        selected = allCapsSelected;\n      }\n    } else if (allCapsSelected.length === 1) {\n      selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n    }\n  }\n\n  // Cap at 3, sort by document position\n  selected.sort((a, b) => a.position - b.position);\n  selected = selected.slice(0, 3);\n\n  if (selected.length === 0) {\n    return undefined;\n  }\n\n  return selected.map((s) => s.text).join(\" + \");\n}\n\n/**\n * Extract potential recipe title from OCR text (sync heuristic fallback)\n */\nexport function extractTitle(text: string): string | undefined {\n  if (!text || text.trim().length === 0) {\n    return undefined;\n  }\n\n  const lines = text.split(\"\\n\").map((line) => line.trim());\n\n  for (const line of lines) {\n    if (line.length === 0) continue;\n    if (line.length < 3 || line.length > 50) continue;\n    if (looksLikeIngredient(line)) continue;\n    if (isAllCaps(line)) continue;\n    if (startsWithNumber(line)) continue;\n    return line;\n  }\n\n  return undefined;\n}\n","numLines":734,"startLine":1,"totalLines":734}}}
