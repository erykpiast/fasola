se if (allCapsSelected.length === 1) {\n   768→      const theCapCandidate = allCapsSelected[0];\n   769→      // Use non-empty line count so the 75% threshold is consistent regardless of blank-line density.\n   770→      const nonEmptyCount = lines.filter((l) => l.trim().length > 0).length;\n   771→      const capRelPos = theCapCandidate.position / Math.max(nonEmptyCount, 1);\n   772→      // If the sole ALL_CAPS candidate is in the last 25% of the document,\n   773→      // it's likely a category footer, not a title. Prefer the best earlier candidate.\n   774→      if (capRelPos > 0.75) {\n   775→        const earlierCandidates = selected.filter(\n   776→          (s) => s.position / Math.max(nonEmptyCount, 1) <= 0.75\n   777→        );\n   778→        if (earlierCandidates.length > 0) {\n   779→          selected = [earlierCandidates.reduce((a, b) => (a.score > b.score ? a : b))];\n   780→        } else {\n   781→          // All candidates are in the last 25% — no positional basis to prefer one over another;\n   782→          // fall back to score, accepting that the guard cannot help here.\n   783→          selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n   784→        }\n   785→      } else {\n   786→        selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n   787→      }\n   788→    }\n   789→  }\n   790→\n   791→  // Cap at 3, sort by document position\n   792→  selected.sort((a, b) => a.position - b.position);\n   793→  selected = selected.slice(0, 3);\n   794→\n   795→  if (selected.length === 0) {\n   796→    return undefined;\n   797→  }\n   798→\n   799→  return selected.map((s) => s.text).join(\" + \");\n   800→}\n   801→\n   802→/**\n   803→ * Extract potential recipe title from OCR text (sync heuristic fallback)\n   804→ */\n   805→export function extractTitle(text: string): string | undefined {\n   806→  if (!text || text.trim().length === 0) {\n   807→    return undefined;\n   808→  }\n   809→\n   810→  con