{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01P248DBG82HfsrGj1R3Yqr3","type":"tool_result","content":"     1→#!/usr/bin/env python3\n     2→\"\"\"\n     3→Generate 100 realistic fake OCR recipe text files.\n     4→Patterns: page spillover, split titles, metadata prefix, character corruption,\n     5→multi-language variants, narrative intros, compound titles, and simple files.\n     6→\"\"\"\n     7→\n     8→import os\n     9→import random\n    10→from pathlib import Path\n    11→\n    12→OUTPUT_DIR = Path(\"tools/title-loop/input\")\n    13→OUTPUT_DIR.mkdir(parents=True, exist_ok=True)\n    14→\n    15→# Exclude existing recipes\n    16→EXCLUDED_TITLES = {\n    17→    \"arayes shrak\",\n    18→    \"smażona zielona fasolka\",\n    19→    \"chlebek z warzywami i boczkiem\",\n    20→    \"saffron wheat buns with quark cottage cheese variation d\",\n    21→    \"mixed seed crispbread\",\n    22→    \"labaneh balls with nigella seeds\",\n    23→    \"baked eggs with feta\",\n    24→    \"harissa tomato sauce coriander\",\n    25→    \"faszerowana papryka\",\n    26→    \"overnight straight pizza dough\",\n    27→    \"finnish milk flatbreads finnish potato flatbreads\",\n    28→    \"krem selerowy z gorgonzola\",\n    29→}\n    30→\n    31→# English recipes (65+ total)\n    32→ENGLISH_RECIPES = [\n    33→    \"Chicken Piccata\",\n    34→    \"Beef Bourguignon\",\n    35→    \"Pan Seared Salmon\",\n    36→    \"Grilled Steak\",\n    37→    \"Roasted Chicken Thighs\",\n    38→    \"Caesar Salad\",\n    39→    \"Greek Salad\",\n    40→    \"Kale Salad\",\n    41→    \"Quinoa Salad\",\n    42→    \"Caprese Salad\",\n    43→\n    44→    \"Tomato Bisque\",\n    45→    \"French Onion Soup\",\n    46→    \"Mushroom Barley Soup\",\n    47→    \"Lentil and Kale Soup\",\n    48→    \"Minestrone Vegetable Soup\",\n    49→    \"Clam Chowder\",\n    50→    \"Split Pea Soup\",\n    51→    \"Butternut Squash Soup\",\n    52→    \"Vegetable Stir Fry\",\n    53→    \"Turkey Meatballs\",\n    54→\n    55→    \"Sourdough Loaf\",\n    56→    \"Ciabatta\",\n    57→    \"Focaccia Bread\",\n    58→    \"Garlic Bread\",\n    59→    \"Irish Soda Bread\",\n    60→    \"Whole Wheat Rolls\",\n    61→    \"Authentic Irish Soda Bread\",\n    62→    \"Banana Bread\",\n    63→    \"Brownies\",\n    64→    \"Baked Cod with Herbs\",\n    65→\n    66→    \"Tiramisu\",\n    67→    \"Lemon Meringue Pie\",\n    68→    \"Chocolate Lava Cake\",\n    69→    \"Cheesecake\",\n    70→    \"Strawberry Shortcake\",\n    71→    \"Vanilla Panna Cotta\",\n    72→    \"Caramel Pudding\",\n    73→    \"Apple Crumble\",\n    74→    \"Deviled Eggs\",\n    75→    \"Quick Beef Bourguignon\",\n    76→\n    77→    \"Bruschetta\",\n    78→    \"Mozzarella Sticks\",\n    79→    \"Stuffed Mushrooms\",\n    80→    \"Shrimp Saganaki\",\n    81→    \"Spinach and Feta Phyllo\",\n    82→    \"Coleslaw\",\n    83→    \"Beet Salad\",\n    84→    \"Authentic Kale Salad\",\n    85→    \"Lamb Stew\",\n    86→    \"Homemade Vegetable Stir Fry\",\n    87→\n    88→    \"Strawberry Smoothie\",\n    89→    \"Lemonade\",\n    90→    \"Iced Tea\",\n    91→    \"Sangria\",\n    92→    \"Strawberry Jam\",\n    93→    \"Tomato Chutney\",\n    94→    \"Dill Pickles\",\n    95→    \"Ratatouille Po Polsku\",\n    96→    \"Quick Golabki\",\n    97→    \"Baked Eggs with Feta\",\n    98→    \"Spaghetti Carbonara\",\n    99→]\n   100→\n   101→# Polish recipes (45+ total)\n   102→POLISH_RECIPES = [\n   103→    \"Żurek\",\n   104→    \"Bigos\",\n   105→    \"Golabki\",\n   106→    \"Mizeria\",\n   107→    \"Placki Ziemniaczane\",\n   108→    \"Schabowy\",\n   109→    \"Chleb Żytni\",\n   110→\n   111→    \"Sernik\",\n   112→    \"Makowiec\",\n   113→    \"Kremwka\",\n   114→    \"Szarlotka\",\n   115→    \"Buki Mleczne\",\n   116→    \"Paczki\",\n   117→    \"Piernik\",\n   118→\n   119→    \"Zupa Pomidorowa\",\n   120→    \"Zupa Grzybowa\",\n   121→    \"Kompot\",\n   122→    \"Kompot Malinowy\",\n   123→    \"Urek\",\n   124→    \"Chodnik\",\n   125→    \"Żur Żytni\",\n   126→\n   127→    \"Piekarnik\",\n   128→    \"Babka Wielkanocna\",\n   129→    \"Ur-Paski\",\n   130→    \"Ur Ze Mietan\",\n   131→    \"Drożdżowiec\",\n   132→    \"Pita Żytnia\",\n   133→\n   134→    \"Kaczka Pieczona\",\n   135→    \"Kotlety Mielone\",\n   136→    \"Pulpety w Mietanie\",\n   137→    \"Drab w Sosie Grzybowym\",\n   138→    \"Bigos z Wdzonych Kielbas\",\n   139→    \"Salata Warzywna\",\n   140→    \"Roladki Szpinakowe\",\n   141→\n   142→    \"Marynata Pieczarkowa\",\n   143→    \"Konfitury ze Liwek\",\n   144→    \"Ogrki Konserwowe\",\n   145→    \"Surwka z Kapusty\",\n   146→    \"Kisiel Malinowy\",\n   147→    \"Barszcz Czysty\",\n   148→]\n   149→\n   150→def corrupt_text(text, corruption_rate=0.1):\n   151→    \"\"\"Apply OCR character corruption to text.\"\"\"\n   152→    corruption_map = {\n   153→        'l': 'ı',  # dotless i\n   154→        'L': 'L',\n   155→        'o': '0',\n   156→        'O': '0',\n   157→        's': 's1',\n   158→        'ś': 'so1',\n   159→        'n': 'n',\n   160→        'i': 'ı',\n   161→    }\n   162→\n   163→    result = []\n   164→    for char in text:\n   165→        if random.random() < corruption_rate and char in corruption_map:\n   166→            result.append(corruption_map[char])\n   167→        else:\n   168→            result.append(char)\n   169→    return ''.join(result)\n   170→\n   171→def generate_ingredients(num=8):\n   172→    \"\"\"Generate a simple ingredients list.\"\"\"\n   173→    ingredients = [\n   174→        \"salt and pepper to taste\",\n   175→        \"2 tablespoons olive oil\",\n   176→        \"1 large onion, diced\",\n   177→        \"3 cloves garlic, minced\",\n   178→        \"1 cup chicken broth\",\n   179→        \"500g meat\",\n   180→        \"2 cups vegetables\",\n   181→        \"1 teaspoon paprika\",\n   182→        \"¼ cup cream\",\n   183→        \"2 eggs\",\n   184→        \"100g butter\",\n   185→        \"3 tablespoons flour\",\n   186→        \"1 lemon, juiced\",\n   187→        \"fresh parsley\",\n   188→        \"2 bay leaves\",\n   189→        \"500ml water\",\n   190→    ]\n   191→    return random.sample(ingredients, min(num, len(ingredients)))\n   192→\n   193→def generate_spillover_garbage():\n   194→    \"\"\"Generate corrupted text from a fake previous recipe.\"\"\"\n   195→    garbage_recipes = [\n   196→        \"Peel the potatoes and cut nto a loured work counter...\",\n   197→        \"Melt butter in a 225°C/435-VI0 oven. Heat until golden\",\n   198→        \"½ cup plus ı tablespoon of sugar mixed with cinnamon\",\n   199→        \"Fold gently UuIw then fold again. Bake at gorg-onzol temp\",\n   200→        \"Stir in the centy-metrowe pieces of...chocolate, diced\",\n   201→        \"Cook until tender, about 20-30 minutes or untıl fork...\",\n   202→        \"Add salt, pepper, and herbs. Mix weII with the bnutter\",\n   203→        \"Serve warm with accompanıments of your chosing, optıonal\",\n   204→    ]\n   205→    lines = []\n   206→    num_lines = random.randint(10, 50)\n   207→    for _ in range(num_lines):\n   208→        line = random.choice(garbage_recipes)\n   209→        if random.random() < 0.3:\n   210→            line = corrupt_text(line, corruption_rate=0.15)\n   211→        lines.append(line)\n   212→    return lines\n   213→\n   214→def generate_file_simple(title):\n   215→    \"\"\"Generate a simple OCR file with basic noise.\"\"\"\n   216→    lines = []\n   217→\n   218→    # Add some page noise\n   219→    if random.random() < 0.3:\n   220→        lines.append(f\"Page 42 | Recipe\")\n   221→\n   222→    lines.append(title)\n   223→    lines.append(\"\")\n   224→\n   225→    # Ingredients\n   226→    lines.append(\"INGREDIENTS:\")\n   227→    for ingredient in generate_ingredients(random.randint(6, 10)):\n   228→        lines.append(f\"  • {ingredient}\")\n   229→\n   230→    lines.append(\"\")\n   231→    lines.append(\"INSTRUCTIONS:\")\n   232→    for i in range(1, random.randint(4, 8)):\n   233→        lines.append(f\"{i}. Mix and cook until done.\")\n   234→\n   235→    # Add some footer noise\n   236→    if random.random() < 0.2:\n   237→        lines.append(\"\")\n   238→        lines.append(\"--- End of page ---\")\n   239→\n   240→    return lines\n   241→\n   242→def generate_file_page_spillover(title):\n   243→    \"\"\"Generate file with corrupted text from a previous recipe (40-60 lines).\"\"\"\n   244→    lines = []\n   245→\n   246→    # Add spillover garbage\n   247→    lines.extend(generate_spillover_garbage())\n   248→\n   249→    lines.append(\"\")\n   250→    lines.append(\"=\" * 50)\n   251→    lines.append(\"\")\n   252→    lines.append(title)\n   253→    lines.append(\"\")\n   254→\n   255→    # Ingredients and instructions\n   256→    lines.append(\"INGREDIENTS:\")\n   257→    for ingredient in generate_ingredients(random.randint(6, 10)):\n   258→        lines.append(f\"  • {ingredient}\")\n   259→\n   260→    lines.append(\"\")\n   261→    lines.append(\"INSTRUCTIONS:\")\n   262→    for i in range(1, random.randint(4, 6)):\n   263→        lines.append(f\"{i}. Prepare and cook.\")\n   264→\n   265→    return lines\n   266→\n   267→def generate_file_split_title(title):\n   268→    \"\"\"Generate file with title split across 2-4 lines.\"\"\"\n   269→    lines = []\n   270→\n   271→    # Split title randomly\n   272→    words = title.split()\n   273→    if len(words) >= 2:\n   274→        split_positions = random.sample(range(1, len(words)), min(random.randint(1, 2), len(words) - 1))\n   275→        split_positions.sort()\n   276→\n   277→        idx = 0\n   278→        for pos in split_positions:\n   279→            lines.append(\" \".join(words[idx:pos]))\n   280→            idx = pos\n   281→        lines.append(\" \".join(words[idx:]))\n   282→    else:\n   283→        lines.append(title)\n   284→\n   285→    lines.append(\"\")\n   286→    lines.append(\"INGREDIENTS:\")\n   287→    for ingredient in generate_ingredients(random.randint(6, 10)):\n   288→        lines.append(f\"  • {ingredient}\")\n   289→\n   290→    lines.append(\"\")\n   291→    lines.append(\"INSTRUCTIONS:\")\n   292→    for i in range(1, random.randint(4, 7)):\n   293→        lines.append(f\"{i}. Mix and prepare.\")\n   294→\n   295→    return lines\n   296→\n   297→def generate_file_metadata_prefix(title):\n   298→    \"\"\"Generate file with metadata/category before title.\"\"\"\n   299→    lines = []\n   300→\n   301→    metadata_options = [\n   302→        \"DANIA GŁÓWNE | Lato\",\n   303→        \"ZUPY / Jesień\",\n   304→        \"DLA 4 OSÓB\",\n   305→        \"PRZYGOTOWANIE: 10 MIN | GOTOWANIE: 30 MIN\",\n   306→        \"DESSERTS & PASTRIES\",\n   307→        \"VEGETARIAN | SERVES 6\",\n   308→        \"STARTER | PREPARATION TIME: 15 MINUTES\",\n   309→        \"GŁÓWNE | Gotowanie: 45 min\",\n   310→    ]\n   311→\n   312→    lines.append(random.choice(metadata_options))\n   313→    lines.append(\"\")\n   314→    lines.append(title)\n   315→    lines.append(\"\")\n   316→\n   317→    lines.append(\"INGREDIENTS:\")\n   318→    for ingredient in generate_ingredients(random.randint(6, 10)):\n   319→        lines.append(f\"  • {ingredient}\")\n   320→\n   321→    lines.append(\"\")\n   322→    lines.append(\"INSTRUCTIONS:\")\n   323→    for i in range(1, random.randint(4, 7)):\n   324→        lines.append(f\"{i}. Cook until ready.\")\n   325→\n   326→    return lines\n   327→\n   328→def generate_file_ocr_corruption(title):\n   329→    \"\"\"Generate file with OCR character corruption throughout.\"\"\"\n   330→    lines = []\n   331→\n   332→    lines.append(corrupt_text(title, corruption_rate=0.08))\n   333→    lines.append(\"\")\n   334→\n   335→    lines.append(\"INGREDIENTS:\")\n   336→    for ingredient in generate_ingredients(random.randint(6, 10)):\n   337→        corrupted = corrupt_text(ingredient, corruption_rate=0.1)\n   338→        lines.append(f\"  • {corrupted}\")\n   339→\n   340→    lines.append(\"\")\n   341→    lines.append(\"INSTRUCTIONS:\")\n   342→    for i in range(1, random.randint(4, 7)):\n   343→        instr = f\"{i}. Prepare and cook together with care.\"\n   344→        corrupted = corrupt_text(instr, corruption_rate=0.08)\n   345→        lines.append(corrupted)\n   346→\n   347→    return lines\n   348→\n   349→def generate_file_multi_language(title):\n   350→    \"\"\"Generate file with multi-language variant titles.\"\"\"\n   351→    lines = []\n   352→\n   353→    # Polish and English versions\n   354→    lines.append(title)  # Original\n   355→\n   356→    # Add English translation or variant\n   357→    translations = {\n   358→        \"żurek\": \"SOUR RYE SOUP\",\n   359→        \"bigos\": \"HUNTER'S STEW\",\n   360→        \"golabki\": \"STUFFED CABBAGE ROLLS\",\n   361→        \"mizeria\": \"CUCUMBER AND SOUR CREAM\",\n   362→        \"placki ziemniaczane\": \"POTATO PANCAKES\",\n   363→        \"schabowy\": \"BREADED PORK CUTLET\",\n   364→    }\n   365→\n   366→    title_lower = title.lower()\n   367→    if any(t in title_lower for t in translations.keys()):\n   368→        for key, trans in translations.items():\n   369→            if key in title_lower:\n   370→                lines.append(trans)\n   371→                break\n   372→    else:\n   373→        lines.append(title.upper() + \" (ENGLISH VERSION)\")\n   374→\n   375→    lines.append(\"\")\n   376→    lines.append(\"INGREDIENTS:\")\n   377→    for ingredient in generate_ingredients(random.randint(6, 10)):\n   378→        lines.append(f\"  • {ingredient}\")\n   379→\n   380→    lines.append(\"\")\n   381→    lines.append(\"INSTRUCTIONS:\")\n   382→    for i in range(1, random.randint(4, 7)):\n   383→        lines.append(f\"{i}. Combine and cook.\")\n   384→\n   385→    return lines\n   386→\n   387→def generate_file_narrative_intro(title):\n   388→    \"\"\"Generate file with narrative intro between title and ingredients.\"\"\"\n   389→    lines = []\n   390→\n   391→    lines.append(title)\n   392→    lines.append(\"\")\n   393→\n   394→    # Narrative intros\n   395→    intros = [\n   396→        \"This classic recipe has been passed down through generations of home cooks. The combination of fresh ingredients creates a warm and satisfying dish.\",\n   397→        \"A beloved comfort food that brings families together at the dinner table. Prepare with care and love for the best results.\",\n   398→        \"Traditional preparation method ensures authentic flavor and texture. This dish pairs well with fresh bread and a simple salad.\",\n   399→        \"An elegant presentation worthy of any special occasion. The aroma alone will delight your guests.\",\n   400→        \"Simple yet sophisticated, this recipe showcases the natural flavors of quality ingredients.\",\n   401→        \"Preparation is straightforward, but the results are impressive and deeply satisfying.\",\n   402→        \"A versatile dish that can be prepared ahead and reheated when needed.\",\n   403→    ]\n   404→\n   405→    num_intro_lines = random.randint(3, 7)\n   406→    intro = random.choice(intros)\n   407→    lines.append(intro)\n   408→    lines.append(\"\")\n   409→\n   410→    lines.append(\"INGREDIENTS:\")\n   411→    for ingredient in generate_ingredients(random.randint(6, 10)):\n   412→        lines.append(f\"  • {ingredient}\")\n   413→\n   414→    lines.append(\"\")\n   415→    lines.append(\"INSTRUCTIONS:\")\n   416→    for i in range(1, random.randint(4, 7)):\n   417→        lines.append(f\"{i}. Follow preparation steps carefully.\")\n   418→\n   419→    return lines\n   420→\n   421→def generate_file_compound_title(title):\n   422→    \"\"\"Generate file with compound/complex title (multiple recipes or variations).\"\"\"\n   423→    lines = []\n   424→\n   425→    # Create a compound title with variations\n   426→    if \" \" in title:\n   427→        parts = title.split(\" \", 1)\n   428→        compound = f\"{parts[0]} + {title.upper()} (VARIATION A)\"\n   429→    else:\n   430→        compound = f\"{title} + {title} WITH VARIATION\"\n   431→\n   432→    lines.append(compound)\n   433→    lines.append(\"\")\n   434→\n   435→    lines.append(\"INGREDIENTS:\")\n   436→    for ingredient in generate_ingredients(random.randint(8, 12)):\n   437→        lines.append(f\"  • {ingredient}\")\n   438→\n   439→    lines.append(\"\")\n   440→    lines.append(\"INSTRUCTIONS:\")\n   441→    lines.append(\"VARIATION A:\")\n   442→    for i in range(1, 4):\n   443→        lines.append(f\"{i}. Follow these steps.\")\n   444→\n   445→    lines.append(\"\")\n   446→    lines.append(\"VARIATION B:\")\n   447→    for i in range(1, 4):\n   448→        lines.append(f\"{i}. Alternative method.\")\n   449→\n   450→    return lines\n   451→\n   452→def generate_file(title, pattern_type):\n   453→    \"\"\"Generate a file based on pattern type.\"\"\"\n   454→    if pattern_type == \"spillover\":\n   455→        return generate_file_page_spillover(title)\n   456→    elif pattern_type == \"split_title\":\n   457→        return generate_file_split_title(title)\n   458→    elif pattern_type == \"metadata\":\n   459→        return generate_file_metadata_prefix(title)\n   460→    elif pattern_type == \"corruption\":\n   461→        return generate_file_ocr_corruption(title)\n   462→    elif pattern_type == \"multi_language\":\n   463→        return generate_file_multi_language(title)\n   464→    elif pattern_type == \"narrative\":\n   465→        return generate_file_narrative_intro(title)\n   466→    elif pattern_type == \"compound\":\n   467→        return generate_file_compound_title(title)\n   468→    else:\n   469→        return generate_file_simple(title)\n   470→\n   471→def save_file(title, lines):\n   472→    \"\"\"Save file with proper filename convention.\"\"\"\n   473→    # Filename uses spaces, not hyphens\n   474→    filename = f\"{title}.generated.18.txt\"\n   475→    filepath = OUTPUT_DIR / filename\n   476→\n   477→    with open(filepath, \"w\", encoding=\"utf-8\") as f:\n   478→        f.write(\"\\n\".join(lines))\n   479→\n   480→    print(f\"✓ {filename}\")\n   481→\n   482→def main():\n   483→    \"\"\"Generate 100 OCR recipe files.\"\"\"\n   484→    # Combine recipes\n   485→    all_recipes = ENGLISH_RECIPES + POLISH_RECIPES\n   486→\n   487→    # Filter out excluded titles\n   488→    all_recipes = [r for r in all_recipes if r.lower() not in EXCLUDED_TITLES]\n   489→\n   490→    # Ensure 60% English, 40% Polish from what we have\n   491→    random.shuffle(all_recipes)\n   492→    selected_recipes = all_recipes[:100]\n   493→\n   494→    # Distribute patterns\n   495→    patterns = (\n   496→        [\"spillover\"] * 15 +\n   497→        [\"split_title\"] * 15 +\n   498→        [\"metadata\"] * 10 +\n   499→        [\"corruption\"] * 20 +\n   500→        [\"multi_language\"] * 5 +\n   501→        [\"narrative\"] * 15 +\n   502→        [\"compound\"] * 5 +\n   503→        [\"simple\"] * 15\n   504→    )\n   505→\n   506→    random.shuffle(patterns)\n   507→\n   508→    print(f\"Generating {len(selected_recipes)} OCR recipe files...\\n\")\n   509→\n   510→    for i, (recipe, pattern) in enumerate(zip(selected_recipes, patterns), 1):\n   511→        lines = generate_file(recipe, pattern)\n   512→        save_file(recipe, lines)\n   513→\n   514→        if i % 20 == 0:\n   515→            print(f\"  ... {i}/100 files created\")\n   516→\n   517→    print(f\"\\n✓ All 100 files generated in {OUTPUT_DIR}\")\n   518→\n   519→if __name__ == \"__main__\":\n   520→    main()\n   521→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_01UmtqPNc54yBZB5S6nKaNXw","session_id":"6b686ee1-940f-489c-85cf-6ec8e28e5ea8","uuid":"3014a4e3-c3a8-48e7-9136-6f43cf084403"}
