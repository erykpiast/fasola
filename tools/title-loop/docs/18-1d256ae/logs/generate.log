{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012t9vUd2KVz8icG5Q4537PM","type":"tool_result","content":"     1→#!/usr/bin/env python3\n     2→\"\"\"\n     3→Self-improving title extraction loop.\n     4→\n     5→Iteratively evaluates and improves the title extraction algorithm by:\n     6→1. Running extraction against real and generated OCR input files\n     7→2. Using Claude Code headless for analysis, planning, and implementation\n     8→3. Committing improvements and tracking accuracy across iterations\n     9→\n    10→Fully resumable: detects which step of an iteration was last completed\n    11→and picks up from there.\n    12→\n    13→Usage: python3 tools/title-loop/title-loop.py\n    14→\"\"\"\n    15→\n    16→import glob\n    17→import json\n    18→import os\n    19→import re\n    20→import shutil\n    21→import subprocess\n    22→import sys\n    23→import threading\n    24→import time\n    25→from pathlib import Path\n    26→\n    27→# --- Configuration ---\n    28→MAX_ITERATIONS = 20\n    29→ACCURACY_THRESHOLD = 0.95  # \"close to 100%\"\n    30→SYNTHETIC_COUNT = 100\n    31→CLAUDE_TIMEOUT = 900  # 15 minutes per Claude invocation\n    32→CLAUDE_STALL_TIMEOUT = 60  # kill if no output for N seconds (default)\n    33→CLAUDE_STALL_TIMEOUT_BY_MODEL = {\"opus\": 180, \"sonnet\": 120, \"haiku\": 60}\n    34→CLAUDE_MAX_RETRIES = 3  # max retries per stage on stall/failure\n    35→EXTRACT_TIMEOUT = 120  # 2 minutes per file extraction\n    36→\n    37→PROJECT_ROOT = Path(__file__).resolve().parent.parent.parent\n    38→LOOP_DIR = Path(__file__).resolve().parent\n    39→INPUT_DIR = LOOP_DIR / \"input\"\n    40→DOCS_DIR = LOOP_DIR / \"docs\"\n    41→EXTRACT_SCRIPT = LOOP_DIR / \"extract-title.ts\"\n    42→ITER_LOG = DOCS_DIR / \"iter.txt\"\n    43→\n    44→# Number of recent output lines to show in live display\n    45→\n    46→\n    47→# --- Resume state detection ---\n    48→\n    49→def find_iter_dir(iteration: int) -> Path | None:\n    50→    \"\"\"Find the iteration directory for a given iteration number (hash may vary).\"\"\"\n    51→    matches = sorted(DOCS_DIR.glob(f\"{iteration}-*\"))\n    52→    matches = [m for m in matches if re.match(rf\"^{iteration}-[a-f0-9]+$\", m.name)]\n    53→    return matches[0] if matches else None\n    54→\n    55→\n    56→def get_logged_accuracy(iteration: int) -> float | None:\n    57→    \"\"\"Read the accuracy logged for a specific iteration from iter.txt.\"\"\"\n    58→    if not ITER_LOG.exists():\n    59→        return None\n    60→    for line in ITER_LOG.read_text().strip().splitlines():\n    61→        m = re.match(r\"^(\\d+)\\s*-\\s*([\\d.]+)%\", line)\n    62→        if m and int(m.group(1)) == iteration:\n    63→            return float(m.group(2)) / 100\n    64→    return None\n    65→\n    66→\n    67→def get_last_logged_iteration() -> int:\n    68→    \"\"\"Read iter.txt to find the last logged iteration number. Returns 0 if none.\"\"\"\n    69→    if not ITER_LOG.exists():\n    70→        return 0\n    71→    last = 0\n    72→    for line in ITER_LOG.read_text().strip().splitlines():\n    73→        m = re.match(r\"^(\\d+)\\s*-\\s*\", line)\n    74→        if m:\n    75→            last = int(m.group(1))\n    76→    return last\n    77→\n    78→\n    79→def determine_resume_phase(iteration: int) -> str:\n    80→    \"\"\"\n    81→    Determine what phase to resume from for a given iteration.\n    82→\n    83→    Returns one of:\n    84→      'evaluate'  — no results yet, start from scratch\n    85→      'analyze'   — results exist but no feedback.md\n    86→      'plan'      — feedback exists but no improvement-plan.md\n    87→      'execute'   — plan exists but not yet implemented/committed\n    88→      'done'      — accuracy met threshold, iteration complete\n    89→    \"\"\"\n    90→    iter_dir = find_iter_dir(iteration)\n    91→    if iter_dir is None or not (iter_dir / \"results.txt\").exists():\n    92→        return \"evaluate\"\n    93→\n    94→    accuracy = get_logged_accuracy(iteration)\n    95→    if accuracy is not None and accuracy >= ACCURACY_THRESHOLD:\n    96→        return \"done\"\n    97→\n    98→    if not (iter_dir / \"feedback.md\").exists():\n    99→        return \"analyze\"\n   100→\n   101→    if not (iter_dir / \"improvement-plan.md\").exists():\n   102→        return \"plan\"\n   103→\n   104→    if (iter_dir / \"committed\").exists():\n   105→        return \"done\"\n   106→\n   107→    return \"execute\"\n   108→\n   109→\n   110→# --- Core helpers ---\n   111→\n   112→def normalize(s: str) -> str:\n   113→    \"\"\"Normalize whitespace, hyphens, and case for comparison.\"\"\"\n   114→    return \" \".join(s.lower().replace(\"-\", \" \").split())\n   115→\n   116→\n   117→def normalize_separators(s: str) -> str:\n   118→    \"\"\"Normalize filesystem-substituted characters (: replaces / in filenames).\"\"\"\n   119→    return s.replace(\":\", \"/\")\n   120→\n   121→\n   122→# Map stripped ASCII to Polish diacritics for fuzzy filename matching.\n   123→# Generated filenames often drop diacritics (e.g., \"Zaby\" for \"Żaby\").\n   124→_POLISH_DIACRITICS = str.maketrans(\n   125→    \"ąćęłńóśźżĄĆĘŁŃÓŚŹŻ\",\n   126→    \"acelnoszzACELNOSZZ\",\n   127→)\n   128→\n   129→\n   130→def _strip_diacritics(s: str) -> str:\n   131→    \"\"\"Strip Polish diacritics to ASCII equivalents.\"\"\"\n   132→    return s.translate(_POLISH_DIACRITICS)\n   133→\n   134→\n   135→def titles_match(extracted: str, expected: str) -> bool:\n   136→    \"\"\"\n   137→    Binary match: does the extracted title contain all expected title parts?\n   138→    Expected may contain multiple titles separated by '+'.\n   139→    Normalizes hyphens→spaces and strips Polish diacritics for robustness\n   140→    against generated filenames that use kebab-case or drop diacritics.\n   141→    \"\"\"\n   142→    if not extracted:\n   143→        return False\n   144→    extracted_norm = _strip_diacritics(normalize_separators(normalize(extracted)))\n   145→    expected_parts = [\n   146→        _strip_diacritics(normalize_separators(normalize(p)))\n   147→        for p in expected.split(\"+\")\n   148→    ]\n   149→    return all(part in extracted_norm for part in expected_parts)\n   150→\n   151→\n   152→def extract_expected_title(filename: str) -> str:\n   153→    \"\"\"Extract expected title from filename like 'Tomato Soup.real.txt'.\"\"\"\n   154→    name = Path(filename).name\n   155→    cleaned = re.sub(r\"\\.(real|generated\\.\\d+)\\.txt$\", \"\", name)\n   156→    if cleaned == name:\n   157→        raise ValueError(f\"Unrecognized filename format: {filename!r}\")\n   158→    return cleaned\n   159→\n   160→\n   161→def run_extraction(file_path: str) -> str:\n   162→    \"\"\"Run the title extraction CLI on a file and return the extracted title.\"\"\"\n   163→    try:\n   164→        result = subprocess.run(\n   165→            [\"npx\", \"tsx\", str(EXTRACT_SCRIPT), file_path],\n   166→            capture_output=True,\n   167→            text=True,\n   168→            timeout=EXTRACT_TIMEOUT,\n   169→            cwd=str(PROJECT_ROOT),\n   170→        )\n   171→        if result.returncode != 0:\n   172→            print(f\"  WARNING: extraction failed for {file_path}: {result.stderr.strip()}\")\n   173→            return \"\"\n   174→        return result.stdout.strip()\n   175→    except subprocess.TimeoutExpired:\n   176→        print(f\"  WARNING: extraction timed out for {file_path}\")\n   177→        return \"\"\n   178→\n   179→\n   180→def evaluate_files(file_paths: list[str]) -> list[dict]:\n   181→    \"\"\"Evaluate extraction on a list of files. Returns list of result dicts.\"\"\"\n   182→    results = []\n   183→    for fp in file_paths:\n   184→        expected = extract_expected_title(fp)\n   185→        extracted = run_extraction(fp)\n   186→        match = titles_match(extracted, expected)\n   187→        results.append({\n   188→            \"file\": fp,\n   189→            \"expected\": expected,\n   190→            \"extracted\": extracted,\n   191→            \"match\": match,\n   192→        })\n   193→        status = \"YES\" if match else \"NO\"\n   194→        print(f\"  {status}: expected='{expected}' got='{extracted}'\")\n   195→    return results\n   196→\n   197→\n   198→def compute_accuracy(results: list[dict]) -> float:\n   199→    \"\"\"Compute accuracy as fraction of matches.\"\"\"\n   200→    if not results:\n   201→        return 0.0\n   202→    return sum(1 for r in results if r[\"match\"]) / len(results)\n   203→\n   204→\n   205→def write_results(iter_dir: Path, results: list[dict]) -> None:\n   206→    \"\"\"Write results.txt with one line per file.\"\"\"\n   207→    iter_dir.mkdir(parents=True, exist_ok=True)\n   208→    with open(iter_dir / \"results.txt\", \"w\") as f:\n   209→        for r in results:\n   210→            status = \"yes\" if r[\"match\"] else \"no\"\n   211→            f.write(f\"{r['expected']} - {status}\\n\")\n   212→\n   213→\n   214→def load_results_from_file(iter_dir: Path) -> list[dict]:\n   215→    \"\"\"Reconstruct minimal results from results.txt for building failure prompts.\"\"\"\n   216→    results = []\n   217→    results_path = iter_dir / \"results.txt\"\n   218→    if not results_path.exists():\n   219→        return results\n   220→    for line in results_path.read_text().strip().splitlines():\n   221→        m = re.match(r\"^(.+) - (yes|no)$\", line)\n   222→        if m:\n   223→            expected = m.group(1)\n   224→            match = m.group(2) == \"yes\"\n   225→            real_file = INPUT_DIR / f\"{expected}.real.txt\"\n   226→            file_path = str(real_file) if real_file.exists() else f\"(input file for '{expected}')\"\n   227→            results.append({\n   228→                \"file\": file_path,\n   229→                \"expected\": expected,\n   230→                \"extracted\": \"(from previous evaluation)\",\n   231→                \"match\": match,\n   232→            })\n   233→    return results\n   234→\n   235→\n   236→def get_commit_hash() -> str:\n   237→    \"\"\"Get current git commit hash (short).\"\"\"\n   238→    result = subprocess.run(\n   239→        [\"git\", \"rev-parse\", \"--short\", \"HEAD\"],\n   240→        capture_output=True,\n   241→        text=True,\n   242→        cwd=str(PROJECT_ROOT),\n   243→    )\n   244→    return result.stdout.strip()\n   245→\n   246→\n   247→def git_commit_all(message: str) -> str:\n   248→    \"\"\"Stage source changes and iteration docs. Returns new commit hash.\"\"\"\n   249→    subprocess.run(\n   250→        [\"git\", \"add\",\n   251→         \"lib/text-classifier/\",\n   252→         \"tools/title-loop/docs/\",\n   253→         \"tools/title-loop/extract-title.ts\",\n   254→         \"tools/title-loop/title-loop.py\"],\n   255→        cwd=str(PROJECT_ROOT),\n   256→        check=True,\n   257→    )\n   258→    # Temporarily disable Entire hooks to avoid interactive /dev/tty prompts\n   259→    subprocess.run([\"entire\", \"disable\"], cwd=str(PROJECT_ROOT),\n   260→                   capture_output=True)\n   261→    try:\n   262→        subprocess.run(\n   263→            [\"git\", \"commit\", \"-m\", message],\n   264→            cwd=str(PROJECT_ROOT),\n   265→            check=True,\n   266→        )\n   267→        return get_commit_hash()\n   268→    finally:\n   269→        subprocess.run([\"entire\", \"enable\", \"--agent\", \"claude-code\"],\n   270→                       cwd=str(PROJECT_ROOT), capture_output=True)\n   271→\n   272→\n   273→# --- Claude invocation with live display ---\n   274→\n   275→def _clear_display(height: int) -> None:\n   276→    \"\"\"Move cursor up and clear lines to overwrite previous display.\"\"\"\n   277→    if height > 0:\n   278→        sys.stdout.write(f\"\\033[{height}A\")\n   279→        for _ in range(height):\n   280→            sys.stdout.write(\"\\033[2K\\n\")\n   281→        sys.stdout.write(f\"\\033[{height}A\")\n   282→\n   283→\n   284→def _render_display(model: str, elapsed: float,\n   285→                    input_tokens: int = 0, output_tokens: int = 0) -> int:\n   286→    \"\"\"Render the live display line. Returns number of lines written.\"\"\"\n   287→    term_width = shutil.get_terminal_size().columns\n   288→\n   289→    header = f\"  Running Claude ({model})...\"\n   290→    stats = f\"\\u2191 {input_tokens:,} | \\u2193 {output_tokens:,} | {elapsed:.0f}s\"\n   291→    padding = max(1, term_width - len(header) - len(stats))\n   292→    sys.stdout.write(f\"{header}{' ' * padding}{stats}\\n\")\n   293→\n   294→    sys.stdout.flush()\n   295→    return 1\n   296→\n   297→\n   298→class ClaudeStallError(RuntimeError):\n   299→    \"\"\"Raised when Claude produces no output for CLAUDE_STALL_TIMEOUT seconds.\"\"\"\n   300→    pass\n   301→\n   302→\n   303→def _run_claude_once(\n   304→    prompt: str,\n   305→    model: str = \"sonnet\",\n   306→    log_path: Path | None = None,\n   307→) -> str:\n   308→    \"\"\"\n   309→    Run Claude Code in headless mode with live streaming display (single attempt).\n   310→\n   311→    Uses --output-format stream-json with --include-partial-messages to get\n   312→    real-time text deltas. Shows elapsed time and the last 5 lines of output.\n   313→    Saves full output to log_path if provided.\n   314→\n   315→    Raises ClaudeStallError if no output received for CLAUDE_STALL_TIMEOUT seconds.\n   316→    Raises RuntimeError on non-zero exit or overall timeout.\n   317→    \"\"\"\n   318→    cmd = [\n   319→        \"claude\", \"--print\", \"--dangerously-skip-permissions\",\n   320→        \"--verbose\",\n   321→        \"--output-format\", \"stream-json\",\n   322→        \"--include-partial-messages\",\n   323→    ]\n   324→\n   325→    model_ids = {\n   326→        \"opus\": \"claude-opus-4-6\",\n   327→        \"sonnet\": \"claude-sonnet-4-6\",\n   328→        \"haiku\": \"claude-haiku-4-5-20251001\",\n   329→    }\n   330→    cmd.extend([\"--model\", model_ids.get(model, model_ids[\"sonnet\"])])\n   331→\n   332→    start = time.time()\n   333→    raw_lines: list[str] = []  # raw NDJSON lines for logging\n   334→    result_text = \"\"  # final result extracted from stream\n   335→    input_tokens = 0  # running count from message_start usage\n   336→    output_tokens = 0  # running count from message_delta usage\n   337→    last_activity = time.time()  # tracks last time model produced any output\n   338→    display_height = 0\n   339→    reader_done = threading.Event()\n   340→    lock = threading.Lock()\n   341→\n   342→    proc = subprocess.Popen(\n   343→        cmd,\n   344→        stdin=subprocess.PIPE,\n   345→        stdout=subprocess.PIPE,\n   346→        stderr=subprocess.PIPE,\n   347→        text=True,\n   348→        cwd=str(PROJECT_ROOT),\n   349→    )\n   350→\n   351→    # Send prompt and close stdin\n   352→    try:\n   353→        proc.stdin.write(prompt)\n   354→        proc.stdin.close()\n   355→    except BrokenPipeError:\n   356→        pass\n   357→\n   358→    # Read and parse stream-json stdout in background\n   359→    def reader():\n   360→        nonlocal result_text, input_tokens, output_tokens, last_activity\n   361→        try:\n   362→            for line in proc.stdout:\n   363→                raw_lines.append(line)\n   364→                stripped = line.strip()\n   365→                if not stripped:\n   366→                    continue\n   367→                try:\n   368→                    event = json.loads(stripped)\n   369→                except json.JSONDecodeError:\n   370→                    continue\n   371→\n   372→                etype = event.get(\"type\", \"\")\n   373→\n   374→                if etype == \"stream_event\":\n   375→                    nested = event.get(\"event\", {})\n   376→                    ntype = nested.get(\"type\", \"\")\n   377→                    # Any content_block_delta (thinking, text, tool JSON) = model is active\n   378→                    if ntype == \"content_block_delta\":\n   379→                        with lock:\n   380→                            last_activity = time.time()\n   381→                    # Track input tokens from message_start\n   382→                    elif ntype == \"message_start\":\n   383→                        usage = nested.get(\"message\", {}).get(\"usage\", {})\n   384→                        added = (usage.get(\"input_tokens\", 0)\n   385→                                 + usage.get(\"cache_creation_input_tokens\", 0)\n   386→                                 + usage.get(\"cache_read_input_tokens\", 0))\n   387→                        if added:\n   388→                            with lock:\n   389→                                input_tokens += added\n   390→                                last_activity = time.time()\n   391→                    # Track output tokens from message_delta\n   392→                    elif ntype == \"message_delta\":\n   393→                        usage = nested.get(\"usage\", {})\n   394→                        tok = usage.get(\"output_tokens\", 0)\n   395→                        if tok:\n   396→                            with lock:\n   397→                                output_tokens += tok\n   398→                                last_activity = time.time()\n   399→\n   400→                # Final result\n   401→                elif etype == \"result\":\n   402→                    result_text = event.get(\"result\", \"\")\n   403→        finally:\n   404→            reader_done.set()\n   405→\n   406→    thread = threading.Thread(target=reader, daemon=True)\n   407→    thread.start()\n   408→\n   409→    # Live display loop\n   410→    stall_timeout = CLAUDE_STALL_TIMEOUT_BY_MODEL.get(model, CLAUDE_STALL_TIMEOUT)\n   411→    stalled = False\n   412→    try:\n   413→        while not reader_done.is_set():\n   414→            elapsed = time.time() - start\n   415→\n   416→            # Overall timeout check\n   417→            if elapsed > CLAUDE_TIMEOUT:\n   418→                proc.kill()\n   419→                break\n   420→\n   421→            # Stall detection: no token traffic for stall_timeout seconds\n   422→            with lock:\n   423→                silence = time.time() - last_activity\n   424→            if silence > stall_timeout:\n   425→                stalled = True\n   426→                proc.kill()\n   427→                break\n   428→\n   429→            _clear_display(display_height)\n   430→            display_height = _render_display(model, elapsed, input_tokens, output_tokens)\n   431→\n   432→            reader_done.wait(timeout=1.0)\n   433→\n   434→        # Final display update\n   435→        elapsed = time.time() - start\n   436→        _clear_display(display_height)\n   437→        display_height = _render_display(model, elapsed, input_tokens, output_tokens)\n   438→\n   439→    except KeyboardInterrupt:\n   440→        proc.kill()\n   441→        _clear_display(display_height)\n   442→        print(f\"  Claude ({model}) interrupted by user\")\n   443→        raise\n   444→\n   445→    # Wait for process to finish\n   446→    try:\n   447→        proc.wait(timeout=30)\n   448→    except subprocess.TimeoutExpired:\n   449→        proc.kill()\n   450→        proc.wait()\n   451→\n   452→    stderr_output = proc.stderr.read()\n   453→    elapsed = time.time() - start\n   454→\n   455→    # Use result from stream; fall back to joining raw output\n   456→    full_output = result_text or \"\".join(raw_lines)\n   457→\n   458→    # Save log (always, even on failure)\n   459→    if log_path:\n   460→        log_path.parent.mkdir(parents=True, exist_ok=True)\n   461→        with open(log_path, \"w\") as f:\n   462→            f.write(f\"# Claude ({model}) — {time.strftime('%Y-%m-%d %H:%M:%S')}\\n\")\n   463→            f.write(f\"# Duration: {elapsed:.0f}s — Exit: {proc.returncode}\\n\")\n   464→            f.write(f\"# Prompt:\\n\")\n   465→            for pline in prompt.splitlines():\n   466→                f.write(f\"#   {pline}\\n\")\n   467→            f.write(f\"\\n{'=' * 60}\\n\\n\")\n   468→            f.write(result_text or \"\")\n   469→            if stderr_output:\n   470→                f.write(f\"\\n{'=' * 60}\\n# STDERR:\\n{stderr_output}\\n\")\n   471→            # Also save raw NDJSON stream for debugging\n   472→            f.write(f\"\\n{'=' * 60}\\n# RAW STREAM ({len(raw_lines)} events):\\n\")\n   473→            for rl in raw_lines:\n   474→                f.write(rl)\n   475→\n   476→    # Status line and error handling\n   477→    if stalled:\n   478→        msg = f\"Claude ({model}) stalled (no output for {stall_timeout}s) at {elapsed:.0f}s\"\n   479→        print(f\"\\n  {msg}\")\n   480→        raise ClaudeStallError(msg)\n   481→    elif proc.returncode == 0:\n   482→        print(f\"\\n  Claude ({model}) finished in {elapsed:.0f}s\")\n   483→    elif elapsed > CLAUDE_TIMEOUT:\n   484→        print(f\"\\n  Claude ({model}) timed out after {elapsed:.0f}s\")\n   485→        raise RuntimeError(f\"Claude ({model}) timed out after {elapsed:.0f}s\")\n   486→    else:\n   487→        msg = f\"Claude ({model}) failed (exit {proc.returncode}) in {elapsed:.0f}s\"\n   488→        print(f\"\\n  {msg}\")\n   489→        if stderr_output:\n   490→            print(f\"  stderr: {stderr_output[:500]}\")\n   491→        raise RuntimeError(f\"{msg}\\n{stderr_output[:1000]}\")\n   492→\n   493→    return result_text or full_output\n   494→\n   495→\n   496→def run_claude(\n   497→    prompt: str,\n   498→    model: str = \"sonnet\",\n   499→    log_path: Path | None = None,\n   500→) -> str:\n   501→    \"\"\"\n   502→    Run Claude Code with automatic retry on stalls.\n   503→\n   504→    Retries up to CLAUDE_MAX_RETRIES times when Claude stalls (no output for\n   505→    CLAUDE_STALL_TIMEOUT seconds). After exhausting retries, raises RuntimeError.\n   506→    Non-stall failures (exit code, overall timeout) are raised immediately.\n   507→    \"\"\"\n   508→    for attempt in range(1, CLAUDE_MAX_RETRIES + 1):\n   509→        try:\n   510→            return _run_claude_once(prompt, model=model, log_path=log_path)\n   511→        except ClaudeStallError:\n   512→            if attempt < CLAUDE_MAX_RETRIES:\n   513→                print(f\"  Retrying ({attempt}/{CLAUDE_MAX_RETRIES})...\")\n   514→            else:\n   515→                raise RuntimeError(\n   516→                    f\"Claude ({model}) stalled {CLAUDE_MAX_RETRIES} times — giving up\"\n   517→                )\n   518→    # unreachable, but satisfies type checker\n   519→    raise RuntimeError(\"unreachable\")\n   520→\n   521→\n   522→# --- Iteration phases ---\n   523→\n   524→def check_real_accuracy() -> tuple[float, list[dict]]:\n   525→    \"\"\"Evaluate real input files and return (accuracy, results).\"\"\"\n   526→    real_files = sorted(glob.glob(str(INPUT_DIR / \"*.real.txt\")))\n   527→    print(f\"  Found {len(real_files)} real files\")\n   528→    real_results = evaluate_files(real_files)\n   529→    real_accuracy = compute_accuracy(real_results)\n   530→    real_pass = sum(1 for r in real_results if r[\"match\"])\n   531→    print(f\"\\n  Real accuracy: {real_accuracy:.1%} ({real_pass}/{len(real_files)})\")\n   532→    return real_accuracy, real_results\n   533→\n   534→\n   535→def phase_evaluate(iteration: int, log_dir: Path) -> tuple[Path, float, list[dict]]:\n   536→    \"\"\"Run evaluation, write results, log accuracy. Returns (iter_dir, accuracy, results).\n   537→\n   538→    The returned accuracy only meets ACCURACY_THRESHOLD when BOTH the real\n   539→    examples AND the combined (real + synthetic) score are above the threshold.\n   540→    This prevents synthetic examples from masking regressions on real data.\n   541→    \"\"\"\n   542→    print(f\"\\nEvaluating real input files...\")\n   543→    real_accuracy, real_results = check_real_accuracy()\n   544→\n   545→    gen_results: list[dict] = []\n   546→    combined_accuracy = real_accuracy\n   547→\n   548→    # If real accuracy is high enough, test on generated data too\n   549→    if real_accuracy >= ACCURACY_THRESHOLD:\n   550→        print(f\"\\nGenerating {SYNTHETIC_COUNT} synthetic OCR files...\")\n   551→        generate_synthetic_data(iteration, log_dir=log_dir)\n   552→\n   553→        print(f\"\\nEvaluating generated files...\")\n   554→        gen_files = sorted(glob.glob(str(INPUT_DIR / f\"*.generated.{iteration}.txt\")))\n   555→        print(f\"  Found {len(gen_files)} generated files\")\n   556→        if gen_files:\n   557→            gen_results = evaluate_files(gen_files)\n   558→            gen_accuracy = compute_accuracy(gen_results)\n   559→            print(f\"\\n  Generated accuracy: {gen_accuracy:.1%}\")\n   560→            combined_accuracy = compute_accuracy(real_results + gen_results)\n   561→        else:\n   562→            print(\"  WARNING: No generated files found. Claude may have failed.\")\n   563→\n   564→    all_results = real_results + gen_results\n   565→    print(f\"\\n  Combined accuracy: {combined_accuracy:.1%}\")\n   566→\n   567→    # Gate: real accuracy must independently meet the threshold.\n   568→    # If combined is above target but real is below, use real accuracy as the\n   569→    # effective score so the loop continues iterating.\n   570→    effective_accuracy = min(real_accuracy, combined_accuracy)\n   571→    if combined_accuracy >= ACCURACY_THRESHOLD and real_accuracy < ACCURACY_THRESHOLD:\n   572→        print(f\"  WARNING: Combined accuracy meets threshold but real accuracy \"\n   573→              f\"({real_accuracy:.1%}) does not — continuing iteration.\")\n   574→\n   575→    # Log iteration accuracy — first number is always the effective (gated) score\n   576→    # so that get_logged_accuracy / determine_resume_phase see the right value.\n   577→    with open(ITER_LOG, \"a\") as f:\n   578→        if gen_results:\n   579→            f.write(f\"{iteration} - {effective_accuracy:.1%} (combined: {combined_accuracy:.1%}, real: {real_accuracy:.1%})\\n\")\n   580→        else:\n   581→            f.write(f\"{iteration} - {real_accuracy:.1%}\\n\")\n   582→\n   583→    # Create iteration directory and write results\n   584→    commit_hash = get_commit_hash()\n   585→    iter_dir = DOCS_DIR / f\"{iteration}-{commit_hash}\"\n   586→    write_results(iter_dir, all_results)\n   587→    print(f\"  Results written to {iter_dir.relative_to(PROJECT_ROOT)}\")\n   588→\n   589→    return iter_dir, effective_accuracy, all_results\n   590→\n   591→\n   592→def generate_synthetic_data(iteration: int, log_dir: Path) -> None:\n   593→    \"\"\"Generate synthetic OCR data using Claude Code.\"\"\"\n   594→    real_files = glob.glob(str(INPUT_DIR / \"*.real.txt\"))\n   595→    existing_titles = [extract_expected_title(f) for f in real_files]\n   596→    titles_list = \", \".join(existing_titles)\n   597→\n   598→    prompt = f\"\"\"Generate {SYNTHETIC_COUNT} realistic fake OCR recipe text files.\n   599→\n   600→Each file simulates real OCR output from a scanned cookbook page. Save each file to:\n   601→tools/title-loop/input/{{RECIPE_TITLE}}.generated.{iteration}.txt\n   602→\n   603→FILENAME RULES (critical):\n   604→- RECIPE_TITLE must use SPACES, not hyphens or underscores\n   605→  (e.g., \"Apple Crumble.generated.{iteration}.txt\", NOT \"apple-crumble.generated.{iteration}.txt\")\n   606→- Preserve Polish diacritics in filenames (e.g., \"Żurek.generated.{iteration}.txt\")\n   607→- The filename title must EXACTLY match the main title in the text content (case-insensitive OK)\n   608→\n   609→RECIPE MIX:\n   610→- 60% English, 40% Polish recipes\n   611→- Variety: soups, mains, desserts, salads, appetizers, breads, drinks, preserves\n   612→- Mix of multi-word titles (2-5 words) and single-word titles\n   613→- Generate DIFFERENT recipes than these existing ones: {titles_list}\n   614→\n   615→OCR PATTERN CATALOG — apply these patterns at the specified rates across the {SYNTHETIC_COUNT} files:\n   616→\n   617→1. PAGE SPILLOVER (~15% of files): 10-50 lines of corrupted text from a PREVIOUS recipe\n   618→   before the actual title. Include partial measurements (\"½ cup plus ı tablespoon\"),\n   619→   broken words (\"nto a loured work counter\"), garbled temperatures (\"225°C/435-VI0..\").\n   620→   The real title only appears after this garbage block. Make these files 40-60 lines.\n   621→\n   622→2. MULTI-LINE SPLIT TITLES (~15%): Title split across 2-4 lines, 1-2 words per line.\n   623→   Examples: \"ARAYES\" / \"SHRAK\" on separate lines, or \"Baked Eggs with Feta, Harissa\n   624→   Tomato Sauce\" / \"& Coriander\" split mid-phrase.\n   625→\n   626→3. METADATA PREFIX LINES (~10%): Category or serving info on the line(s) just before title.\n   627→   Examples: \"Lato | Dania główne\", \"/ Jesień / Zupy\", \"DLA 4 OSÓB\",\n   628→   \"PRZYGOTOWANIE 10 MIN\", \"GOTOWANIE 30 MIN\".\n   629→\n   630→4. OCR CHARACTER CORRUPTION (~20%): Misrecognized characters throughout the file.\n   631→   Examples: \"só1\" for \"sól\" (digit for letter), \"ı\" (dotless i) for \"l\",\n   632→   hyphenation artifacts (\"centy-metrowe\", \"gorg-onzol\"), garbage tokens (\"UuIw\").\n   633→   Apply to both Polish and English files.\n   634→\n   635→5. MULTI-LANGUAGE VARIANT TITLES (~5%): Polish title line 1, English line 2,\n   636→   optionally another script line 3. Example: \"Faszerowana papryka\" / \"PAPRIKA GYERAN-JJIM\".\n   637→\n   638→6. NARRATIVE INTRO BETWEEN TITLE AND INGREDIENTS (~15%): 3-7 lines of prose cooking story\n   639→   or recipe introduction between the title and the structured ingredient list.\n   640→\n   641→7. COMPOUND/COMPLEX TITLES (~5%): Multiple recipes or variations in one title.\n   642→   Examples: \"FINNISH MILK FLATBREADS + FINNISH POTATO FLATBREADS\",\n   643→   \"SAFFRON WHEAT BUNS WITH QUARK : COTTAGE CHEESE (VARIATION D)\".\n   644→\n   645→Remaining ~15% should be simpler files with basic OCR noise (stray numbers, page headers,\n   646→broken words at line edges).\n   647→\n   648→FILE LENGTH: 15-60 lines. Spillover files should be longer (40-60 lines).\n   649→\n   650→Generate all {SYNTHETIC_COUNT} files. Work through them systematically.\"\"\"\n   651→\n   652→    run_claude(prompt, model=\"haiku\", log_path=log_dir / \"generate.log\")\n   653→\n   654→\n   655→def phase_analyze(iter_dir: Path, results: list[dict]) -> None:\n   656→    \"\"\"Analyze extraction failures with Claude (Sonnet).\"\"\"\n   657→    log_dir = iter_dir / \"logs\"\n   658→    failures = [r for r in results if not r[\"match\"]]\n   659→    if not failures:\n   660→        (iter_dir / \"feedback.md\").write_text(\"No failures to analyze — all extractions matched.\\n\")\n   661→        return\n   662→\n   663→    failure_details = \"\\n\".join(\n   664→        f\"- File: {r['file']}\\n  Expected: '{r['expected']}'\\n  Got: '{r['extracted']}'\"\n   665→        for r in failures\n   666→    )\n   667→\n   668→    prompt = f\"\"\"Analyze the title extraction failures below. Read each failing input file\n   669→and the current implementation at lib/text-classifier/title-extractor.ts.\n   670→\n   671→Write your analysis to {iter_dir.relative_to(PROJECT_ROOT)}/feedback.md explaining:\n   672→1. What patterns the algorithm fails on\n   673→2. Why each specific failure occurred\n   674→3. Common themes across failures\n   675→\n   676→Do NOT modify any code files. Only write the feedback.md file.\n   677→\n   678→Failures:\n   679→{failure_details}\n   680→\n   681→Results file: {iter_dir.relative_to(PROJECT_ROOT)}/results.txt\"\"\"\n   682→\n   683→    run_claude(prompt, model=\"sonnet\", log_path=log_dir / \"analyze.log\")\n   684→\n   685→\n   686→def phase_plan(iter_dir: Path, iteration: int) -> None:\n   687→    \"\"\"Plan algorithm improvements with Claude (Opus).\"\"\"\n   688→    log_dir = iter_dir / \"logs\"\n   689→    prompt = f\"\"\"Read the feedback at {iter_dir.relative_to(PROJECT_ROOT)}/feedback.md\n   690→and the current title extraction implementation at lib/text-classifier/title-extractor.ts.\n   691→Also read previous iteration docs in tools/title-loop/docs/ to understand what has been tried.\n   692→\n   693→Your job: propose changes that fix every failure. Think creatively and ambitiously.\n   694→\n   695→Hard constraints:\n   696→- Must run on a mobile device (React Native / Expo)\n   697→- Total title extraction must complete under 10 seconds\n   698→- Changes land in lib/text-classifier/ and related files\n   699→\n   700→Everything else is open for debate. The current approach (MiniLM embeddings + heuristic scoring)\n   701→is one option, but you are free to propose alternatives if they'd work better:\n   702→- Different embedding model or similarity strategy\n   703→- Replacing embeddings entirely with a rule-based or hybrid approach\n   704→- Restructuring the pipeline (e.g., two-pass, re-ranking, candidate merging)\n   705→- Changing how candidates are generated, filtered, or deduplicated\n   706→- Any other approach that solves the failures within the hard constraints\n   707→\n   708→Don't be incremental for the sake of it — if the feedback reveals a fundamental design flaw,\n   709→propose a fundamental fix. But also don't change things that already work well.\n   710→\n   711→Before writing any files, briefly outline your key proposed changes (2-3 sentences per failure)\n   712→so you can think through the approach first.\n   713→\n   714→Then write a detailed improvement plan to {iter_dir.relative_to(PROJECT_ROOT)}/improvement-plan.md\n   715→that includes:\n   716→1. Root cause analysis for each failure pattern\n   717→2. Specific code changes with before/after examples\n   718→3. New or modified heuristics, scoring adjustments, or pipeline changes\n   719→4. Expected impact on accuracy\n   720→\n   721→Do NOT modify any code files. Only write the improvement-plan.md file.\"\"\"\n   722→\n   723→    run_claude(prompt, model=\"opus\", log_path=log_dir / \"plan.log\")\n   724→\n   725→\n   726→def phase_execute(iter_dir: Path) -> None:\n   727→    \"\"\"Execute improvements with Claude (Sonnet), verify, and commit.\"\"\"\n   728→    log_dir = iter_dir / \"logs\"\n   729→    prompt = f\"\"\"Execute the improvement plan at {iter_dir.relative_to(PROJECT_ROOT)}/improvement-plan.md.\n   730→\n   731→Modify lib/text-classifier/title-extractor.ts and any related files as needed.\n   732→Make sure:\n   733→1. All existing tests still pass\n   734→2. The CLI at tools/title-loop/extract-title.ts still works\n   735→3. The code is clean and follows the project conventions in AGENTS.md\n   736→4. No unnecessary changes outside the title extraction logic\n   737→\n   738→CRITICAL CONSTRAINT: Do NOT modify the substring deduplication logic in title-extractor.ts.\n   739→The block starting with \"// Deduplicate: if one title is a substring of another, keep the shorter\"\n   740→must remain exactly as-is. It keeps the SHORTER candidate. Do not invert this to keep the longer.\n   741→This has been incorrectly changed 5 times and breaks tests every time.\n   742→\n   743→After making changes, run: npx vitest run --globals lib/text-classifier/__tests__/title-extractor.test.ts\n   744→Fix any test failures before finishing.\"\"\"\n   745→\n   746→    run_claude(prompt, model=\"sonnet\", log_path=log_dir / \"execute.log\")\n   747→\n   748→    # Verify tests and CLI\n   749→    print(f\"\\nVerifying tests and CLI...\")\n   750→    tests_ok = run_tests()\n   751→    cli_ok = verify_cli()\n   752→\n   753→    if not tests_ok or not cli_ok:\n   754→        print(\"  WARNING: Verification failed. Attempting to fix...\")\n   755→        fix_prompt = \"\"\"The title extraction tests or CLI are failing after recent changes.\n   756→Please fix any issues in lib/text-classifier/title-extractor.ts.\n   757→Run: npx vitest run lib/text-classifier/__tests__/title-extractor.test.ts\n   758→And verify: npx tsx tools/title-loop/extract-title.ts tools/title-loop/input/*.real.txt\n   759→Make sure both pass before finishing.\"\"\"\n   760→        run_claude(fix_prompt, model=\"sonnet\", log_path=log_dir / \"fix.log\")\n   761→\n   762→        if not run_tests() or not verify_cli():\n   763→            raise RuntimeError(\"Tests or CLI still failing after fix attempt\")\n   764→\n   765→\n   766→def run_tests() -> bool:\n   767→    \"\"\"Run the title extraction tests.\"\"\"\n   768→    print(\"  Running tests...\")\n   769→    result = subprocess.run(\n   770→        [\"npx\", \"vitest\", \"run\", \"--globals\", \"lib/text-classifier/__tests__/title-extractor.test.ts\"],\n   771→        capture_output=True,\n   772→        text=True,\n   773→        timeout=120,\n   774→        cwd=str(PROJECT_ROOT),\n   775→    )\n   776→    if result.returncode != 0:\n   777→        print(f\"  Tests FAILED: {result.stdout[-500:]}\")\n   778→        return False\n   779→    print(\"  Tests passed.\")\n   780→    return True\n   781→\n   782→\n   783→def verify_cli() -> bool:\n   784→    \"\"\"Verify the CLI script runs without errors on a sample file.\"\"\"\n   785→    real_files = glob.glob(str(INPUT_DIR / \"*.real.txt\"))\n   786→    if not real_files:\n   787→        print(\"  No real files to test CLI with\")\n   788→        return False\n   789→\n   790→    sample = real_files[0]\n   791→    print(f\"  Verifying CLI on: {Path(sample).name}\")\n   792→    result = subprocess.run(\n   793→        [\"npx\", \"tsx\", str(EXTRACT_SCRIPT), sample],\n   794→        capture_output=True,\n   795→        text=True,\n   796→        timeout=EXTRACT_TIMEOUT,\n   797→        cwd=str(PROJECT_ROOT),\n   798→    )\n   799→    if result.returncode != 0:\n   800→        print(f\"  CLI verification FAILED: {result.stderr[:300]}\")\n   801→        return False\n   802→    print(f\"  CLI output: '{result.stdout.strip()}'\")\n   803→    return True\n   804→\n   805→\n   806→# --- Main loop ---\n   807→\n   808→def main() -> None:\n   809→    \"\"\"Main self-improving loop with full mid-iteration resumability.\"\"\"\n   810→    DOCS_DIR.mkdir(parents=True, exist_ok=True)\n   811→\n   812→    last_logged = get_last_logged_iteration()\n   813→    if last_logged > 0:\n   814→        last_phase = determine_resume_phase(last_logged)\n   815→        if last_phase == \"done\":\n   816→            accuracy = get_logged_accuracy(last_logged)\n   817→            if accuracy is not None and accuracy >= ACCURACY_THRESHOLD:\n   818→                # Re-check real examples before declaring victory — code may\n   819→                # have changed since the logged accuracy was recorded.\n   820→                print(f\"Iteration {last_logged} logged {accuracy:.1%}. Re-checking real examples...\")\n   821→                real_accuracy, _ = check_real_accuracy()\n   822→                if real_accuracy >= ACCURACY_THRESHOLD:\n   823→                    print(f\"  Real examples still passing. Nothing to do.\")\n   824→                    return\n   825→                print(f\"  Real accuracy regressed — continuing with new iteration.\")\n   826→            start_iteration = last_logged + 1\n   827→        else:\n   828→            start_iteration = last_logged\n   829→    else:\n   830→        start_iteration = 1\n   831→\n   832→    print(\"=\" * 60)\n   833→    print(\"SELF-IMPROVING TITLE EXTRACTION LOOP\")\n   834→    print(f\"Max iterations: {MAX_ITERATIONS}\")\n   835→    print(f\"Accuracy threshold: {ACCURACY_THRESHOLD:.0%}\")\n   836→    print(f\"Input dir: {INPUT_DIR}\")\n   837→    if start_iteration > 1:\n   838→        phase = determine_resume_phase(start_iteration)\n   839→        print(f\"Resuming: iteration {start_iteration}, phase '{phase}'\")\n   840→    print(\"=\" * 60)\n   841→    print()\n   842→\n   843→    # Verify CLI works before starting\n   844→    print(\"Pre-flight: verifying CLI...\")\n   845→    if not verify_cli():\n   846→        print(\"FATAL: CLI verification failed. Fix before running the loop.\")\n   847→        sys.exit(1)\n   848→    print()\n   849→\n   850→    for iteration in range(start_iteration, MAX_ITERATIONS + 1):\n   851→        phase = determine_resume_phase(iteration)\n   852→\n   853→        if phase == \"done\":\n   854→            print(f\"Iteration {iteration} already completed. Skipping.\")\n   855→            continue\n   856→\n   857→        print(\"=\" * 60)\n   858→        print(f\"ITERATION {iteration}\" + (f\"  (resuming from '{phase}')\" if phase != \"evaluate\" else \"\"))\n   859→        print(\"=\" * 60)\n   860→\n   861→        iter_dir = find_iter_dir(iteration)\n   862→        all_results: list[dict] | None = None\n   863→\n   864→        # Ensure logs dir exists for this iteration\n   865→        if iter_dir:\n   866→            (iter_dir / \"logs\").mkdir(parents=True, exist_ok=True)\n   867→\n   868→        # --- EVALUATE ---\n   869→        if phase == \"evaluate\":\n   870→            # Create provisional log dir (iter_dir doesn't exist yet)\n   871→            commit_hash = get_commit_hash()\n   872→            provisional_log_dir = DOCS_DIR / f\"{iteration}-{commit_hash}\" / \"logs\"\n   873→            provisional_log_dir.mkdir(parents=True, exist_ok=True)\n   874→\n   875→            try:\n   876→                iter_dir, combined_accuracy, all_results = phase_evaluate(iteration, log_dir=provisional_log_dir)\n   877→            except RuntimeError as e:\n   878→                print(f\"  FATAL: {e}. Stopping.\")\n   879→                break\n   880→\n   881→            if combined_accuracy >= ACCURACY_THRESHOLD:\n   882→                print(f\"\\n{'=' * 60}\")\n   883→                print(f\"TARGET ACCURACY REACHED: {combined_accuracy:.1%}\")\n   884→                print(f\"Stopping after iteration {iteration}\")\n   885→                print(f\"{'=' * 60}\")\n   886→                break\n   887→\n   888→        assert iter_dir is not None, f\"No iteration directory found for iteration {iteration}\"\n   889→\n   890→        # --- ANALYZE ---\n   891→        if phase in (\"evaluate\", \"analyze\"):\n   892→            print(f\"\\nAnalyzing failures with Claude (Sonnet)...\")\n   893→            if all_results is None:\n   894→                all_results = load_results_from_file(iter_dir)\n   895→            try:\n   896→                phase_analyze(iter_dir, all_results)\n   897→            except RuntimeError as e:\n   898→                print(f\"  FATAL: {e}. Stopping.\")\n   899→                break\n   900→\n   901→        # --- PLAN ---\n   902→        if phase in (\"evaluate\", \"analyze\", \"plan\"):\n   903→            print(f\"\\nPlanning improvements with Claude (Opus)...\")\n   904→            try:\n   905→                phase_plan(iter_dir, iteration)\n   906→            except RuntimeError as e:\n   907→                print(f\"  FATAL: {e}. Stopping.\")\n   908→                break\n   909→\n   910→        # --- EXECUTE + VERIFY + COMMIT ---\n   911→        print(f\"\\nExecuting improvements with Claude (Sonnet)...\")\n   912→        try:\n   913→            phase_execute(iter_dir)\n   914→        except RuntimeError as e:\n   915→            print(f\"  FATAL: {e}. Stopping.\")\n   916→            break\n   917→\n   918→        # Commit changes\n   919→        print(f\"\\nCommitting changes...\")\n   920→        try:\n   921→            commit_hash = git_commit_all(f\"title-extraction: iteration {iteration}\")\n   922→            print(f\"  Committed: {commit_hash}\")\n   923→        except subprocess.CalledProcessError as e:\n   924→            # git commit exits 1 both for \"nothing to commit\" and real failures.\n   925→            # Check git status to distinguish.\n   926→            status = subprocess.run(\n   927→                [\"git\", \"status\", \"--porcelain\"],\n   928→                capture_output=True, text=True, cwd=str(PROJECT_ROOT),\n   929→            )\n   930→            if not status.stdout.strip():\n   931→                print(\"  WARNING: Nothing to commit (no changes made)\")\n   932→                commit_hash = get_commit_hash()\n   933→            else:\n   934→                print(f\"  FATAL: git commit failed: {e}. Stopping.\")\n   935→                break\n   936→\n   937→        # Mark iteration as committed so resume skips it\n   938→        (iter_dir / \"committed\").write_text(f\"{commit_hash}\\n\")\n   939→\n   940→        # Prepare next iteration directory\n   941→        next_dir = DOCS_DIR / f\"{iteration + 1}-{commit_hash}\"\n   942→        next_dir.mkdir(parents=True, exist_ok=True)\n   943→\n   944→        print(f\"\\n  Next iteration dir: {next_dir.relative_to(PROJECT_ROOT)}\")\n   945→        print()\n   946→\n   947→    else:\n   948→        print(f\"\\n{'=' * 60}\")\n   949→        print(f\"MAX ITERATIONS ({MAX_ITERATIONS}) REACHED\")\n   950→        print(f\"Final accuracy may not have met threshold.\")\n   951→        print(f\"{'=' * 60}\")\n   952→\n   953→    # Print summary\n   954→    print(f\"\\nIteration log:\")\n   955→    if ITER_LOG.exists():\n   956→        print(ITER_LOG.read_text())\n   957→\n   958→\n   959→if __name__ == \"__main__\":\n   960→    main()\n   961→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_01UmtqPNc54yBZB5S6nKaNXw","session_id":"6b686ee1-940f-489c-85cf-6ec8e28e5ea8","uuid":"b3cdd0ee-bc1f-4c5d-9d71-dabff52848e2"}
