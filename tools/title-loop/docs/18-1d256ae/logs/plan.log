{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017GVW3NfF8zzJHrrp29Pcs4","type":"tool_result","content":"     1→/**\n     2→ * Title Extraction\n     3→ * Extracts potential recipe title from OCR text using heuristics or semantic embeddings\n     4→ */\n     5→\n     6→import { cosineSimilarity } from \"./embeddings\";\n     7→\n     8→export type EmbedFn = (text: string) => Promise<Array<number>>;\n     9→\n    10→const TITLE_REFERENCE =\n    11→  \"recipe name, dish title, name of the food, nazwa przepisu, nazwa dania\";\n    12→const HEADER_REFERENCE =\n    13→  \"ingredients list, cooking directions, section heading, składniki, przygotowanie, sposób wykonania\";\n    14→const NOISE_REFERENCE =\n    15→  \"page number, table of contents, book footer, garbled text\";\n    16→\n    17→/**\n    18→ * Measurement units commonly found in ingredient lists\n    19→ */\n    20→const MEASUREMENT_PATTERNS = [\n    21→  // English\n    22→  \"cup\",\n    23→  \"cups\",\n    24→  \"tbsp\",\n    25→  \"tsp\",\n    26→  \"tablespoon\",\n    27→  \"teaspoon\",\n    28→  // \"oz\" and \"lb\" are matched with word boundaries in looksLikeIngredient\n    29→  // to avoid false positives (\"oz\" in \"mozzarella\", \"lb\" in \"albacore\")\n    30→  \"gram\",\n    31→  \"grams\",\n    32→  \"kg\",\n    33→  \"ml\",\n    34→  \"liter\",\n    35→  \"pinch\",\n    36→  \"dash\",\n    37→  \"handful\",\n    38→  // Polish\n    39→  \"łyżka\", \"łyżki\", \"łyżek\",           // tablespoon(s)\n    40→  \"łyżeczka\", \"łyżeczki\", \"łyżeczek\",   // teaspoon(s)\n    41→  \"szklanka\", \"szklanki\", \"szklanek\",    // cup(s)\n    42→  \"szczypta\",                            // pinch\n    43→  \"garść\",                               // handful\n    44→  \"opakowanie\", \"opakowania\",            // package(s)\n    45→  \"plasterek\", \"plasterki\",             // slice(s)\n    46→];\n    47→\n    48→/**\n    49→ * Patterns that identify recipe metadata lines (not titles)\n    50→ */\n    51→const METADATA_PATTERNS = [\n    52→  /^(SERVES?|MAKES?|YIELDS?)\\b/i,\n    53→  /^(PREP(ARATION)?|COOK(ING)?|PROOF|RISING|FERMENTATION|REST(ING)?)\\s*(AND\\s*)?(COOK(ING)?)?\\s*TIME/i,\n    54→  /^SAMPLE\\s+SCHEDULE\\b/i,\n    55→  /^BULK\\s+FERMENTATION\\b/i,\n    56→  /^(THIS\\s+RECIPE\\s+)?MAKES\\b/i,\n    57→  // Polish serving-size patterns: \"NA 3 PAPRYKI\", \"NA OKOŁO 1 KG\", \"DLA 4 OSÓB\"\n    58→  /^NA\\s+(\\d|OKOŁO)\\b/i,\n    59→  /^DLA\\s+\\d/i,\n    60→  // OCR-resilient: \"DLA\" + any token + serving-unit word (handles DLA & OSOB, DLA § OSOB, etc.)\n    61→  /^DLA\\s+\\S+\\s+OSOB/i,\n    62→  // OCR-resilient: \"DLA\" + single non-alphanumeric char (common digit→symbol OCR error)\n    63→  /^DLA\\s+[^a-zA-Z0-9\\s]\\s/i,\n    64→  // Time-unit metadata: any line containing \"N MIN\" or \"N GODZ\" is prep/cook/rest time,\n    65→  // regardless of OCR-corrupted prefix (catches PRZYGOTOWANTE, GOTOMANTE, etc.)\n    66→  /\\b\\d+\\s*MIN\\b/i,\n    67→  /\\b\\d+\\s*GODZ/i,\n    68→];\n    69→\n    70→/**\n    71→ * Single-word non-title words — standalone OCR fragments unlikely to be recipe titles\n    72→ */\n    73→const NON_TITLE_WORDS = new Set([\n    74→  \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"are\", \"was\",\n    75→  \"has\", \"his\", \"her\", \"its\", \"our\", \"who\", \"how\", \"may\", \"new\", \"now\",\n    76→  \"old\", \"see\", \"way\", \"did\", \"get\", \"let\", \"say\", \"she\", \"too\", \"use\",\n    77→  \"buns\", \"with\",\n    78→]);\n    79→\n    80→function looksLikeIngredient(line: string): boolean {\n    81→  const lowerLine = line.toLowerCase();\n    82→  if (MEASUREMENT_PATTERNS.some((pattern) => lowerLine.includes(pattern))) return true;\n    83→  // Compact metric: \"100g\", \"50ml\", \"250g\" — digit immediately followed by g/ml/kg\n    84→  if (/\\b\\d+\\s*(?:g|ml|kg)\\b/i.test(line)) return true;\n    85→  // \"to taste\" / \"do smaku\" — qualitative ingredient with no unit\n    86→  if (/\\bto taste\\b/i.test(line) || /\\bdo smaku\\b/i.test(line)) return true;\n    87→  return false;\n    88→}\n    89→\n    90→function startsWithNumber(line: string): boolean {\n    91→  // Match lines starting with a digit, or bullet-then-digit (e.g., \"- 2 jajka\")\n    92→  return /^\\s*(?:[-•*]\\s*)?\\d/.test(line);\n    93→}\n    94→\n    95→function stripDiacritics(text: string): string {\n    96→  return text.normalize(\"NFKD\").replace(/[\\u0300-\\u036f]/g, \"\");\n    97→}\n    98→\n    99→/**\n   100→ * Known recipe section labels — these are structural headers, not recipe titles.\n   101→ * Matched case-insensitively after trimming, stripping trailing punctuation, and stripping diacritics.\n   102→ * Polish entries are stored without diacritics for OCR resilience (e.g. \"SKLADNIKI\" matches \"składniki\").\n   103→ */\n   104→const SECTION_LABELS = new Set([\n   105→  // English\n   106→  \"ingredients\", \"directions\", \"instructions\", \"method\", \"preparation\",\n   107→  \"steps\", \"notes\", \"tip\", \"tips\", \"variations\", \"variation\",\n   108→  \"garnish\", \"topping\", \"toppings\", \"frosting\", \"filling\",\n   109→  // Polish — recipe section labels (stored without diacritics for OCR resilience)\n   110→  \"skladniki\", \"przygotowanie\", \"sposob przygotowania\", \"sposob wykonania\",\n   111→  \"wykonanie\", \"wskazowki\", \"podpowiedz\", \"warianty\",\n   112→  \"sos\", \"nadzienie\", \"polewa\", \"lukier\", \"ciasto\",  // ciasto = dough/pastry base (recipe-internal section AND chapter label)\n   113→  // Polish — recipe-book chapter/category labels (food groups, meal types)\n   114→  \"warzywa\",          // vegetables\n   115→  \"mieso\",            // meat (mięso)\n   116→  \"miesa\",            // meats (mięsa)\n   117→  \"ryby\",             // fish\n   118→  \"owoce morza\",      // seafood\n   119→  \"zupy\",             // soups\n   120→  \"salatki\",          // salads (sałatki)\n   121→  \"desery\",           // desserts\n   122→  \"napoje\",           // drinks\n   123→  \"pieczywo\",         // bread/baked goods\n   124→  \"przekaski\",        // appetizers/snacks\n   125→  \"sniadania\",        // breakfasts (śniadania)\n   126→  \"obiady\",           // dinners/lunches\n   127→  \"kolacje\",          // suppers\n   128→  \"makarony\",         // pasta dishes\n   129→  \"kasza\",            // groats/grains\n   130→  \"kasze\",            // groats/grains (plural)\n   131→  \"dania glowne\",     // main courses (dania główne)\n   132→  \"przystawki\",       // starters\n   133→  \"dodatki\",          // side dishes\n   134→  \"przetwory\",        // preserves\n   135→  \"wypieki\",          // baked goods\n   136→  \"ciasta\",           // cakes (plural)\n   137→  \"ciastka\",          // cookies\n   138→  \"torty\",            // layer cakes\n   139→  \"placki\",           // pancakes/flatbreads\n   140→  \"koktajle\",         // cocktails/smoothies\n   141→]);\n   142→\n   143→function isSectionLabel(text: string): boolean {\n   144→  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n   145→  return SECTION_LABELS.has(normalized);\n   146→}\n   147→\n   148→function isAllCaps(line: string): boolean {\n   149→  const letters = line.replace(/[^a-zA-Z]/g, \"\");\n   150→  return letters.length > 0 && letters === letters.toUpperCase();\n   151→}\n   152→\n   153→function looksLikeMetadata(text: string): boolean {\n   154→  return METADATA_PATTERNS.some((pattern) => pattern.test(text.trim()));\n   155→}\n   156→\n   157→function isLikelyGarbled(text: string): boolean {\n   158→  const letters = text.replace(/[^a-zA-Z]/g, \"\");\n   159→  if (letters.length < 2) return true;\n   160→\n   161→  // Check vowel ratio — English/Polish text typically has 30–50% vowels\n   162→  const vowels = letters.replace(/[^aeiouAEIOUyYąęóĄĘÓ]/g, \"\").length;\n   163→  const vowelRatio = vowels / letters.length;\n   164→  if (vowelRatio < 0.15 || vowelRatio > 0.85) return true;\n   165→\n   166→  // Single orphaned word ≤3 letters that isn't a common word\n   167→  const words = text.trim().split(/\\s+/);\n   168→  const COMMON_SHORT = new Set([\n   169→    \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"had\", \"her\",\n   170→    \"was\", \"one\", \"our\", \"out\", \"are\", \"has\", \"his\", \"how\", \"its\", \"may\",\n   171→    \"new\", \"now\", \"old\", \"see\", \"way\", \"who\", \"did\", \"get\", \"let\", \"say\",\n   172→    \"she\", \"too\", \"use\",\n   173→  ]);\n   174→  if (words.length === 1 && letters.length <= 3 && !COMMON_SHORT.has(text.trim().toLowerCase())) {\n   175→    return true;\n   176→  }\n   177→\n   178→  // Single word with internal lowercase→uppercase transition — OCR noise (e.g., \"UuIw\", \"aBC\")\n   179→  // No recipe title uses this pattern as a standalone single-word candidate.\n   180→  if (words.length === 1 && /[a-z][A-Z]/.test(text.trim())) {\n   181→    return true;\n   182→  }\n   183→\n   184→  // Recipe titles never start with a lowercase letter\n   185→  if (/^[a-z]/.test(text.trim())) {\n   186→    return true;\n   187→  }\n   188→\n   189→  // Mid-text sentence boundary (\". \" followed by a letter) — body text fragment spliced from multiple sentences\n   190→  const trimmed = text.trim();\n   191→  if (/\\.\\s+[a-zA-Z]/.test(trimmed) && !trimmed.endsWith(\")\")) {\n   192→    return true;\n   193→  }\n   194→\n   195→  // Multi-word candidate containing a garbled OCR fragment: a short lowercase word that isn't a known short word\n   196→  if (words.length >= 2) {\n   197→    const commonShort2 = new Set([\n   198→      \"a\", \"i\", \"of\", \"or\", \"to\", \"in\", \"on\", \"is\", \"it\", \"an\",\n   199→      \"as\", \"at\", \"by\", \"do\", \"go\", \"if\", \"no\", \"so\", \"up\", \"we\",\n   200→      \"w\", \"z\",  // Polish prepositions\n   201→    ]);\n   202→    const hasGarbledWord = words.some(\n   203→      (w) =>\n   204→        /^[a-z]/.test(w) &&\n   205→        w.replace(/[^a-z]/g, \"\").length <= 2 &&\n   206→        !commonShort2.has(w.toLowerCase())\n   207→    );\n   208→    if (hasGarbledWord) {\n   209→      return true;\n   210→    }\n   211→  }\n   212→\n   213→  return false;\n   214→}\n   215→\n   216→function passesHardFilters(text: string): boolean {\n   217→  if (text.length < 3 || text.length > 80) return false;\n   218→  if (looksLikeIngredient(text)) return false;\n   219→  if (startsWithNumber(text)) return false;\n   220→  if (looksLikeMetadata(text)) return false;\n   221→  if (isLikelyGarbled(text)) return false;\n   222→  // Pipe-separated lines are book category/chapter headers, not recipe titles\n   223→  if (text.includes(\" | \")) return false;\n   224→  // Slash-separated breadcrumbs (e.g., \"/ Jesien / Zupy\") are navigation, not titles\n   225→  // Only filter when 2+ slashes are present — single-slash lines like\n   226→  // \"TITLE / SUBTITLE\" are legitimate continuation-merged titles\n   227→  if ((text.match(/\\//g) || []).length >= 2) return false;\n   228→  // Bullet-list items (ingredients or instruction steps) are never titles\n   229→  if (/^\\s*[-•*]\\s/.test(text)) return false;\n   230→  // Known recipe section labels are structural headers, not titles\n   231→  if (isSectionLabel(text)) return false;\n   232→  // Single-word non-title fragments\n   233→  const words = text.trim().split(/\\s+/);\n   234→  if (words.length === 1 && NON_TITLE_WORDS.has(text.trim().toLowerCase())) return false;\n   235→  return true;\n   236→}\n   237→\n   238→/**\n   239→ * Detect initial burst of short garbled lines.\n   240→ * Returns the index of the first non-garbled or long line.\n   241→ */\n   242→function findBurstEnd(lines: Array<{ text: string }>): number {\n   243→  let i = 0;\n   244→  while (i < lines.length && lines[i].text.length < 20 && isLikelyGarbled(lines[i].text)) {\n   245→    i++;\n   246→  }\n   247→  return i;\n   248→}\n   249→\n   250→function wordCount(text: string): number {\n   251→  return text.split(/\\s+/).filter((w) => w.length > 0).length;\n   252→}\n   253→\n   254→/**\n   255→ * Build candidate strings from lines: single lines plus multi-line joins (2-3 consecutive).\n   256→ * Skips initial burst of short garbled lines. Scans all remaining lines. Caps at 25.\n   257→ */\n   258→export type CandidateOrigin = \"single\" | \"2-line\" | \"3-line\";\n   259→\n   260→function buildCandidates(\n   261→  lines: Array<string>\n   262→): Array<{ text: string; position: number; origin: CandidateOrigin }> {\n   263→  const nonEmptyLines: Array<{ text: string; index: number }> = [];\n   264→\n   265→  for (let i = 0; i < lines.length; i++) {\n   266→    const trimmed = lines[i].trim();\n   267→    if (trimmed.length > 0) {\n   268→      nonEmptyLines.push({ text: trimmed, index: i });\n   269→    }\n   270→  }\n   271→\n   272→  const burstEnd = findBurstEnd(nonEmptyLines);\n   273→\n   274→  // Pre-merge consecutive short ALL_CAPS lines (OCR-fragmented headings).\n   275→  // When a sequence of 2+ ALL_CAPS lines each has ≤2 words and ≤25 chars, they are\n   276→  // almost certainly OCR fragments of a single heading. Merge them into one line so\n   277→  // the complete title enters the candidate pool without hitting the 3-line join ceiling.\n   278→  const capsCoalesced: Array<{ text: string; index: number }> = [];\n   279→  let ci = burstEnd;\n   280→  while (ci < nonEmptyLines.length) {\n   281→    const line = nonEmptyLines[ci];\n   282→    if (\n   283→      isAllCaps(line.text) &&\n   284→      wordCount(line.text) <= 2 &&\n   285→      line.text.length <= 25 &&\n   286→      !isSectionLabel(line.text) &&\n   287→      !looksLikeMetadata(line.text)\n   288→    ) {\n   289→      let merged = line.text;\n   290→      const startIndex = line.index;\n   291→      let j = ci + 1;\n   292→      while (j < nonEmptyLines.length) {\n   293→        const next = nonEmptyLines[j];\n   294→        if (\n   295→          isAllCaps(next.text) &&\n   296→          wordCount(next.text) <= 2 &&\n   297→          next.text.length <= 25 &&\n   298→          !isSectionLabel(next.text) &&\n   299→          !looksLikeMetadata(next.text) &&\n   300→          (merged + \" \" + next.text).length <= 80\n   301→        ) {\n   302→          merged += \" \" + next.text;\n   303→          j++;\n   304→        } else {\n   305→          break;\n   306→        }\n   307→      }\n   308→      if (j > ci + 1) {\n   309→        capsCoalesced.push({ text: merged, index: startIndex });\n   310→        ci = j;\n   311→        continue;\n   312→      }\n   313→    }\n   314→    capsCoalesced.push(line);\n   315→    ci++;\n   316→  }\n   317→\n   318→  // Pre-merge continuation lines: a line starting with /&+:( is never a standalone title.\n   319→  // Merge it into the preceding line so the complete title enters the pool as a single candidate,\n   320→  // avoiding the fragile chain of conditions required by the downstream join survival logic.\n   321→  // Limitation: only one continuation line per preceding line is merged. Titles split across\n   322→  // three or more lines with continuation tokens (rare in practice) are not handled here —\n   323→  // the downstream 2-line and 3-line join candidates cover those cases instead.\n   324→  const mergedLines: Array<{ text: string; index: number }> = [];\n   325→  for (let i = 0; i < capsCoalesced.length; i++) {\n   326→    const line = capsCoalesced[i];\n   327→    if (i + 1 < capsCoalesced.length) {\n   328→      const nextText = capsCoalesced[i + 1].text;\n   329→      if (/^[/&+:(]/.test(nextText)) {\n   330→        mergedLines.push({ text: `${line.text} ${nextText}`, index: line.index });\n   331→        i++;\n   332→        continue;\n   333→      }\n   334→    }\n   335→    mergedLines.push(line);\n   336→  }\n   337→\n   338→  const candidates: Array<{ text: string; position: number; origin: CandidateOrigin }> = [];\n   339→  const seen = new Set<string>();\n   340→\n   341→  // Build a set of positions to skip: short ALL_CAPS lines immediately following metadata\n   342→  const metadataContinuationPositions = new Set<number>();\n   343→  for (let i = 0; i < mergedLines.length - 1; i++) {\n   344→    if (looksLikeMetadata(mergedLines[i].text)) {\n   345→      const next = mergedLines[i + 1];\n   346→      if (isAllCaps(next.text) && wordCount(next.text) <= 2 && next.text.length <= 15) {\n   347→        metadataContinuationPositions.add(next.index);\n   348→      }\n   349→    }\n   350→  }\n   351→\n   352→  for (let i = 0; i < mergedLines.length; i++) {\n   353→    const line = mergedLines[i];\n   354→\n   355→    // Skip metadata continuation fragments\n   356→    if (metadataContinuationPositions.has(line.index)) continue;\n   357→\n   358→    // Single line\n   359→    if (passesHardFilters(line.text)) {\n   360→      const norm = line.text.toLowerCase();\n   361→      if (!seen.has(norm)) {\n   362→        seen.add(norm);\n   363→        candidates.push({ text: line.text, position: line.index, origin: \"single\" });\n   364→      }\n   365→    }\n   366→\n   367→    // 2-line join — skip if first line is a section label (prevents \"INGREDIENTS TITLE\" joins)\n   368→    if (i + 1 < mergedLines.length && !isSectionLabel(line.text)) {\n   369→      const joined2 = `${line.text} ${mergedLines[i + 1].text}`;\n   370→      if (passesHardFilters(joined2)) {\n   371→        const norm = joined2.toLowerCase();\n   372→        if (!seen.has(norm)) {\n   373→          seen.add(norm);\n   374→          candidates.push({ text: joined2, position: line.index, origin: \"2-line\" });\n   375→        }\n   376→      }\n   377→    }\n   378→\n   379→    // 3-line join — skip if first line is a section label\n   380→    if (i + 2 < mergedLines.length && !isSectionLabel(line.text)) {\n   381→      const joined3 = `${line.text} ${mergedLines[i + 1].text} ${mergedLines[i + 2].text}`;\n   382→      if (passesHardFilters(joined3)) {\n   383→        const norm = joined3.toLowerCase();\n   384→        if (!seen.has(norm)) {\n   385→          seen.add(norm);\n   386→          candidates.push({ text: joined3, position: line.index, origin: \"3-line\" });\n   387→        }\n   388→      }\n   389→    }\n   390→  }\n   391→\n   392→  // Pre-filter to 25 before embedding calls: prefer ALL_CAPS and short candidates.\n   393→  // Position-based scoring handles final ranking.\n   394→  if (candidates.length > 25) {\n   395→    const prioritized = candidates.slice().sort((a, b) => {\n   396→      const aAllCaps = isAllCaps(a.text) ? 0 : 1;\n   397→      const bAllCaps = isAllCaps(b.text) ? 0 : 1;\n   398→      if (aAllCaps !== bAllCaps) return aAllCaps - bAllCaps;\n   399→      const aShort = wordCount(a.text) <= 5 ? 0 : 1;\n   400→      const bShort = wordCount(b.text) <= 5 ? 0 : 1;\n   401→      return aShort - bShort;\n   402→    });\n   403→    return prioritized.slice(0, 25);\n   404→  }\n   405→\n   406→  return candidates;\n   407→}\n   408→\n   409→// Module-level cache for reference embeddings\n   410→let cachedTitleRefEmbedding: Array<number> | null = null;\n   411→let cachedHeaderRefEmbedding: Array<number> | null = null;\n   412→let cachedNoiseRefEmbedding: Array<number> | null = null;\n   413→\n   414→export function _resetEmbeddingCacheForTests(): void {\n   415→  cachedTitleRefEmbedding = null;\n   416→  cachedHeaderRefEmbedding = null;\n   417→  cachedNoiseRefEmbedding = null;\n   418→}\n   419→\n   420→export async function extractTitleWithEmbeddings(\n   421→  text: string,\n   422→  embed: EmbedFn\n   423→): Promise<string | undefined> {\n   424→  if (!text || text.trim().length === 0) {\n   425→    return undefined;\n   426→  }\n   427→\n   428→  const lines = text.split(\"\\n\");\n   429→  const candidates = buildCandidates(lines);\n   430→\n   431→  if (candidates.length === 0) {\n   432→    return undefined;\n   433→  }\n   434→\n   435→  // Cache reference embeddings\n   436→  if (!cachedTitleRefEmbedding) {\n   437→    cachedTitleRefEmbedding = await embed(TITLE_REFERENCE);\n   438→  }\n   439→  if (!cachedHeaderRefEmbedding) {\n   440→    cachedHeaderRefEmbedding = await embed(HEADER_REFERENCE);\n   441→  }\n   442→  if (!cachedNoiseRefEmbedding) {\n   443→    cachedNoiseRefEmbedding = await embed(NOISE_REFERENCE);\n   444→  }\n   445→\n   446→  // Find ALL_CAPS candidates with ≥2 words where every significant word has ≥4 alpha letters.\n   447→  // Insignificant tokens (≤1 alpha letter: \"/\", \"&\", \"+\", \":\", \"D)\", etc.) are filtered before\n   448→  // the check so that multi-line joins with continuation punctuation still qualify.\n   449→  const isStructuralHeading = (c: { text: string }): boolean => {\n   450→    if (!isAllCaps(c.text) || wordCount(c.text) < 2) return false;\n   451→    const sigWords = c.text.trim().split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length > 1);\n   452→    return sigWords.length >= 2 && sigWords.every((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   453→  };\n   454→\n   455→  // Pass 1: compute rawScore for all candidates (embedding quality signal)\n   456→  const rawScored: Array<{ text: string; position: number; origin: CandidateOrigin; rawScore: number; embedding: Array<number> }> = [];\n   457→  for (const candidate of candidates) {\n   458→    const embedding = await embed(candidate.text);\n   459→    const titleSim = cosineSimilarity(embedding, cachedTitleRefEmbedding);\n   460→    const headerSim = cosineSimilarity(embedding, cachedHeaderRefEmbedding);\n   461→    const noiseSim = cosineSimilarity(embedding, cachedNoiseRefEmbedding);\n   462→    const rawScore = titleSim - Math.max(headerSim, noiseSim);\n   463→    rawScored.push({ text: candidate.text, position: candidate.position, origin: candidate.origin, rawScore, embedding });\n   464→  }\n   465→\n   466→  // Select baseHeading by embedding quality (rawScore), not position.\n   467→  // This prevents OCR-garbled fragments from claiming the structural heading slot.\n   468→  const structuralCandidates = rawScored.filter((s) => isStructuralHeading(s));\n   469→\n   470→  // Penalize structural headings with truncated OCR words:\n   471→  // if \"FRON\" appears and another heading has \"SAFFRON\", \"FRON\" is likely garbled.\n   472→  for (const sc of structuralCandidates) {\n   473→    const sigWords = sc.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   474→    for (const other of structuralCandidates) {\n   475→      if (other === sc) continue;\n   476→      const otherSigWords = other.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   477→      const hasTruncation = sigWords.some((w) =>\n   478→        otherSigWords.some((ow) => ow !== w && ow.length > w.length && ow.endsWith(w))\n   479→      );\n   480→      if (hasTruncation) {\n   481→        sc.rawScore = -1.0;  // Hard disqualification — truncated OCR artifact\n   482→        break;\n   483→      }\n   484→    }\n   485→  }\n   486→\n   487→  const bestStructural = structuralCandidates.length > 0\n   488→    ? structuralCandidates.reduce((a, b) => {\n   489→        const scoreDiff = a.rawScore - b.rawScore;\n   490→        if (Math.abs(scoreDiff) > 0.03) return scoreDiff > 0 ? a : b;\n   491→        // Tiebreak: single-line origin beats multi-line joins (avoids conflating two separate headings)\n   492→        if (a.origin === \"single\" && b.origin !== \"single\") return a;\n   493→        if (b.origin === \"single\" && a.origin !== \"single\") return b;\n   494→        // Tiebreak: more words (more specific) → better\n   495→        const wcDiff = wordCount(b.text) - wordCount(a.text);\n   496→        if (wcDiff !== 0) return wcDiff > 0 ? b : a;\n   497→        // Tiebreak: earlier position → better\n   498→        return a.position < b.position ? a : b;\n   499→      })\n   500→    : null;\n   501→  const baseHeading = bestStructural ?? undefined;\n   502→\n   503→  // When the best structural heading has a continuation on the next line introduced by a\n   504→  // punctuation token (/, &, +, :, or parenthesis), prefer the longer 2-line join as the\n   505→  // complete heading. E.g. \"SAFFRON WHEAT BUNS WITH QUARK\" + \"/ COTTAGE CHEESE (VARIATION D)\".\n   506→  // Guard: the remainder after the prefix must start with a continuation character to avoid\n   507→  // merging two separate consecutive recipe titles (FINNISH MILK FLATBREADS stays separate\n   508→  // from FINNISH POTATO FLATBREADS because \"FINNISH\" does not start with a continuation token).\n   509→  let firstStructuralHeading = baseHeading && (\n   510→    rawScored.find((c) => {\n   511→      if (!isStructuralHeading(c)) return false;\n   512→      const hLower = baseHeading.text.toLowerCase();\n   513→      const cLower = c.text.toLowerCase();\n   514→      return cLower.startsWith(hLower + \" \") && /^[/&+:(]/.test(cLower.slice(hLower.length + 1));\n   515→    }) ?? baseHeading\n   516→  );\n   517→\n   518→  // Pass 2: apply bonuses\n   519→  const scored: Array<{ text: string; position: number; origin: CandidateOrigin; score: number; rawScore: number; baseScore: number; thresholdScore: number }> = rawScored.map((rs) => {\n   520→    // Position factor: multiplicative tiebreaker — amplifies existing signal, doesn't replace it\n   521→    const relativePosition = rs.position / lines.length;\n   522→    const positionFactor = relativePosition < 0.5\n   523→      ? 1.0 + 0.12 * (1 - relativePosition * 2)\n   524→      : 1.0;\n   525→\n   526→    // ALL_CAPS bonus: recipe books use ALL_CAPS for titles and section headings.\n   527→    // Single-word ALL_CAPS terms are overwhelmingly section/category labels, not recipe titles;\n   528→    // real recipe titles in ALL_CAPS are almost always multi-word. Reduce the bonus for single words.\n   529→    const allCapsBonus = isAllCaps(rs.text) && rs.text.replace(/[^a-zA-Z]/g, \"\").length >= 4\n   530→      ? (wordCount(rs.text) >= 2 ? 0.08 : 0.03)\n   531→      : 0;\n   532→\n   533→    // Structural heading bonus: best ALL_CAPS heading (or its continuation join) is almost always the recipe title\n   534→    const structuralBonus = firstStructuralHeading && rs.text === firstStructuralHeading.text ? 0.10 : 0;\n   535→\n   536→    // thresholdScore excludes structural bonus so the bonus doesn't inflate the threshold\n   537→    // and prevent equally-valid structural headings from passing on multi-recipe pages.\n   538→    const thresholdScore = rs.rawScore + allCapsBonus;\n   539→    // baseScore excludes position factor — used for diagnostics and ranking\n   540→    const baseScore = rs.rawScore + allCapsBonus + structuralBonus;\n   541→    const score = rs.rawScore * positionFactor + allCapsBonus + structuralBonus;\n   542→    return { text: rs.text, position: rs.position, origin: rs.origin, score, rawScore: rs.rawScore, baseScore, thresholdScore };\n   543→  });\n   544→\n   545→  if (scored.length === 0) {\n   546→    return undefined;\n   547→  }\n   548→\n   549→  // --- Pre-threshold bilingual title detection ---\n   550→  // When a mixed-case candidate at position 0 is followed by an ALL_CAPS candidate\n   551→  // at position ≤ 2 that is semantically similar to it, this is a bilingual recipe\n   552→  // page (e.g., Polish title + ALL_CAPS Korean romanization). Suppress confirmed\n   553→  // translation candidates before computing threshold so their bonuses don't inflate\n   554→  // the threshold beyond the mixed-case title's reach.\n   555→  // Note: we check position ≤ 2 (local proximity), not global ALL_CAPS count, so\n   556→  // section headers later in the document (SKŁADNIKI, WARZYWA, etc.) are irrelevant.\n   557→  let translationCandidates: typeof scored = [];\n   558→  let scoredForThreshold = scored;\n   559→  const prePos0 = scored.find((s) => s.position === 0 && !isAllCaps(s.text));\n   560→  if (prePos0) {\n   561→    const nearbyAllCaps = scored.filter(\n   562→      (s) => isAllCaps(s.text) && s.position >= 1 && s.position <= 2 && s.origin === \"single\"\n   563→    );\n   564→    const pos0Embedding = rawScored.find((r) => r.text === prePos0.text)?.embedding;\n   565→\n   566→    // Method 1: embedding similarity (works for related languages)\n   567→    if (pos0Embedding && nearbyAllCaps.length > 0) {\n   568→      translationCandidates = nearbyAllCaps.filter((cap) => {\n   569→        const capEmbedding = rawScored.find((r) => r.text === cap.text)?.embedding;\n   570→        if (!capEmbedding) return false;\n   571→        return cosineSimilarity(pos0Embedding, capEmbedding) > 0.4;\n   572→      });\n   573→    }\n   574→\n   575→    // Method 2: layout-based detection (cross-lingual fallback).\n   576→    // When embedding similarity is insufficient (e.g. Polish ↔ Korean romanization),\n   577→    // detect bilingual layout by position and word overlap:\n   578→    // mixed-case ≥2 words at pos 0 + ALL_CAPS ≥2 words at pos 1-2 with no shared words.\n   579→    if (translationCandidates.length === 0 && wordCount(prePos0.text) >= 2) {\n   580→      const pos0Words = new Set(\n   581→        prePos0.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2)\n   582→      );\n   583→      translationCandidates = nearbyAllCaps.filter((cap) => {\n   584→        if (wordCount(cap.text) < 2) return false;\n   585→        const capWords = cap.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2);\n   586→        return !capWords.some((w) => pos0Words.has(w));\n   587→      });\n   588→    }\n   589→\n   590→    if (translationCandidates.length > 0) {\n   591→      // Suppress standalone translations and any multi-line joins that embed the translation\n   592→      // as a suffix or substring (e.g. \"Smażona zielona fasolka GREEN BEANS BORKEUM\" ends with\n   593→      // the translation; \"Title GREEN BEANS BORKEUM 그린빈\" includes it as a substring).\n   594→      scoredForThreshold = scored.filter((s) => {\n   595→        const sLower = s.text.toLowerCase();\n   596→        return !translationCandidates.some((t) => {\n   597→          const tLower = t.text.toLowerCase();\n   598→          return sLower.startsWith(tLower) ||\n   599→                 sLower.endsWith(\" \" + tLower) ||\n   600→                 sLower.includes(\" \" + tLower);\n   601→        });\n   602→      });\n   603→    }\n   604→  }\n   605→\n   606→  // Fix 2: If the structural heading was identified as a bilingual translation, reassign it.\n   607→  // This prevents the translation's ALL_CAPS bonus from inflating the threshold and ensures\n   608→  // the fallback path in scored also uses the correct heading.\n   609→  if (\n   610→    translationCandidates.length > 0 &&\n   611→    firstStructuralHeading &&\n   612→    translationCandidates.some((t) => t.text === firstStructuralHeading!.text)\n   613→  ) {\n   614→    const nonTranslationStructural = structuralCandidates.filter(\n   615→      (sc) => !translationCandidates.some((t) => t.text === sc.text)\n   616→    );\n   617→    const newHeading = nonTranslationStructural.length > 0\n   618→      ? nonTranslationStructural.reduce((a, b) => a.rawScore > b.rawScore ? a : b)\n   619→      : undefined;\n   620→\n   621→    // Patch scored array: remove old structural bonus, apply new one\n   622→    for (const s of scored) {\n   623→      if (s.text === firstStructuralHeading.text) {\n   624→        s.score -= 0.10;\n   625→        s.baseScore -= 0.10;\n   626→      }\n   627→      if (newHeading && s.text === newHeading.text) {\n   628→        s.score += 0.10;\n   629→        s.baseScore += 0.10;\n   630→      }\n   631→    }\n   632→    // Update reference for downstream prefix-removal logic\n   633→    firstStructuralHeading = newHeading ?? undefined;\n   634→  }\n   635→\n   636→  // Use thresholdScore (excludes structural bonus) so the structural bonus doesn't inflate\n   637→  // the threshold and block equally-valid headings on multi-recipe pages.\n   638→  const bestThresholdScore = Math.max(...scoredForThreshold.map((s) => s.thresholdScore));\n   639→  const threshold = Math.max(0.08, bestThresholdScore * 0.7);\n   640→\n   641→  // Filter candidates above threshold\n   642→  let selected = scoredForThreshold.filter((s) => s.score >= threshold);\n   643→\n   644→  // Empty-pool fallback: when threshold filtering discards every candidate,\n   645→  // the hard filters' structural verdict should not be overruled by weak\n   646→  // embedding differentiation. Return the best positional candidate.\n   647→  if (selected.length === 0 && scored.length > 0) {\n   648→    const fallback = scored\n   649→      .slice()\n   650→      .sort((a, b) => a.position - b.position || b.score - a.score);\n   651→    selected = [fallback[0]];\n   652→  }\n   653→\n   654→  // Remove word-boundary prefixes of firstStructuralHeading when the heading itself survived\n   655→  // the threshold. Cases:\n   656→  //   ARAYES case:  firstStructuralHeading = \"ARAYES SHRAK\" (2-word join qualifies; \"ARAYES\"\n   657→  //     alone = 1 word, so it never qualified). Filter removes \"ARAYES\" so dedup keeps the join.\n   658→  //   SAFFRON case: baseHeading was the partial line; continuation logic above upgraded\n   659→  //     firstStructuralHeading to the full join. Filter removes the partial so dedup keeps join.\n   660→  // Safety: only fires when the complete heading itself is in selected (passed the threshold).\n   661→  if (firstStructuralHeading && selected.some((s) => s.text === firstStructuralHeading.text)) {\n   662→    const fshLower = firstStructuralHeading.text.toLowerCase();\n   663→    selected = selected.filter((s) => {\n   664→      if (s.text === firstStructuralHeading.text) return true;\n   665→      const sLower = s.text.toLowerCase();\n   666→      // Remove s if it is a space-delimited prefix of the structural heading\n   667→      return !fshLower.startsWith(sLower + \" \");\n   668→    });\n   669→  }\n   670→\n   671→  // Protect continuation joins: when a multi-line join (2-line or 3-line) survived the threshold\n   672→  // and its second part starts with a continuation character, remove the single-line prefix/suffix\n   673→  // so the dedup \"shorter wins\" rule doesn't destroy the complete join.\n   674→  // Note: the pre-merge step above already handles the common Baked Eggs case (&/continuation\n   675→  // on next line) by turning it into a single candidate — this block covers the rarer case where\n   676→  // a continuation-character join was generated as a 2-line/3-line candidate and the prefix\n   677→  // single also survived threshold independently (e.g. from a different code path or OCR layout).\n   678→  // Safety: only fires for joins whose continuation starts with /&+:( — digit continuations\n   679→  // like \"Pierogi Ruskie 200g mąki\" are NOT protected, so dedup correctly keeps the shorter form.\n   680→  const survivingJoins = selected.filter((s) => s.origin === \"2-line\" || s.origin === \"3-line\");\n   681→  if (survivingJoins.length > 0) {\n   682→    selected = selected.filter((s) => {\n   683→      if (s.origin !== \"single\") return true;\n   684→      const sLower = s.text.toLowerCase();\n   685→      // Remove PREFIX singles whose continuation join also survived\n   686→      const isPrefixOfJoin = survivingJoins.some((j) => {\n   687→        const jLower = j.text.toLowerCase();\n   688→        if (!jLower.startsWith(sLower + \" \")) return false;\n   689→        const remainder = jLower.slice(sLower.length + 1);\n   690→        return /^[/&+:(]/.test(remainder);\n   691→      });\n   692→      if (isPrefixOfJoin) return false;\n   693→      // Remove SUFFIX singles (e.g. \"& Coriander\") whose parent join also survived\n   694→      const isSuffixOfJoin = survivingJoins.some((j) => {\n   695→        const jLower = j.text.toLowerCase();\n   696→        if (!jLower.endsWith(\" \" + sLower)) return false;\n   697→        // Only remove if the suffix starts with a continuation character\n   698→        return /^[/&+:(]/.test(sLower);\n   699→      });\n   700→      if (isSuffixOfJoin) return false;\n   701→      return true;\n   702→    });\n   703→  }\n   704→\n   705→  // Pre-dedup: remove sub-section headers that are substrings of other surviving candidates.\n   706→  // A sub-section header is an ALL_CAPS candidate followed by ingredient-like lines in the source.\n   707→  // Example: \"CHLEBEK\" (bread section header, followed by \"500 g mąki\") is a substring of\n   708→  // \"CHLEBEK Z WARZYWAMI I BOCZKIEM\" (the real title). Without this filter, dedup kills the title.\n   709→  selected = selected.filter((candidate) => {\n   710→    if (!isAllCaps(candidate.text)) return true;\n   711→    // Check if this candidate is immediately followed by ingredient-like content\n   712→    const nextSourceLines = lines.slice(candidate.position + 1, candidate.position + 2);\n   713→    const followedByIngredients = nextSourceLines.some(\n   714→      (l) => looksLikeIngredient(l.trim()) || startsWithNumber(l.trim())\n   715→    );\n   716→    if (!followedByIngredients) return true;\n   717→    // Only remove if a longer candidate contains this one as a substring\n   718→    const candidateLower = candidate.text.toLowerCase();\n   719→    const hasLongerParent = rawScored.some(\n   720→      (other) =>\n   721→        other.text !== candidate.text &&\n   722→        other.text.length > candidate.text.length &&\n   723→        other.text.toLowerCase().includes(candidateLower)\n   724→    );\n   725→    return !hasLongerParent;\n   726→  });\n   727→\n   728→  // Deduplicate: if one title is a substring of another, keep the shorter (more focused) one.\n   729→  // DO NOT CHANGE THIS LOGIC — it has been incorrectly \"improved\" by the title-loop 5 times.\n   730→  // The tests require shorter wins: \"Pierogi Ruskie\" over \"Pierogi Ruskie 200g mąki 3 ziemniaki\".\n   731→  // The pre-filter above handles the conflicting case (structural heading prefix removal) so that\n   732→  // the incomplete prefix line is never present here when the complete join is in selected.\n   733→  selected = selected.filter((a) => {\n   734→    const aLower = a.text.toLowerCase();\n   735→    return !selected.some(\n   736→      (b) =>\n   737→        b !== a &&\n   738→        aLower.includes(b.text.toLowerCase()) &&\n   739→        b.text.length < a.text.length\n   740→    );\n   741→  });\n   742→\n   743→  // Multi-title guard: only join multiple candidates with \"+\" when there is\n   744→  // structural evidence of a multi-recipe page (≥2 ALL_CAPS headings).\n   745→  // A single ALL_CAPS title among mixed-case survivors is a single-recipe page —\n   746→  // collapse to the highest-scoring candidate.\n   747→  // Zero ALL_CAPS survivors → mixed-case multi-title page → keep all.\n   748→  if (selected.length > 1) {\n   749→    const allCapsSelected = selected.filter((s) => isAllCaps(s.text));\n   750→    if (allCapsSelected.length >= 2) {\n   751→      // Check whether non-first ALL_CAPS headings are section headers within one recipe\n   752→      // (followed immediately by ingredient-like content) rather than separate recipe titles.\n   753→      // A multi-recipe page has body text between titles; a single-recipe page has\n   754→      // ingredient lines immediately after each section heading.\n   755→      const sortedCaps = [...allCapsSelected].sort((a, b) => a.position - b.position);\n   756→      const isSubHeader = sortedCaps.slice(1).every((cap) => {\n   757→        const nextLines = lines.slice(cap.position + 1, cap.position + 3);\n   758→        return nextLines.some(\n   759→          (l) => looksLikeIngredient(l.trim()) || /^\\s*\\d/.test(l.trim())\n   760→        );\n   761→      });\n   762→      if (isSubHeader) {\n   763→        selected = [sortedCaps[0]];\n   764→      } else {\n   765→        selected = allCapsSelected;\n   766→      }\n   767→    } else if (allCapsSelected.length === 1) {\n   768→      const theCapCandidate = allCapsSelected[0];\n   769→      // Use non-empty line count so the 75% threshold is consistent regardless of blank-line density.\n   770→      const nonEmptyCount = lines.filter((l) => l.trim().length > 0).length;\n   771→      const capRelPos = theCapCandidate.position / Math.max(nonEmptyCount, 1);\n   772→      // If the sole ALL_CAPS candidate is in the last 25% of the document,\n   773→      // it's likely a category footer, not a title. Prefer the best earlier candidate.\n   774→      if (capRelPos > 0.75) {\n   775→        const earlierCandidates = selected.filter(\n   776→          (s) => s.position / Math.max(nonEmptyCount, 1) <= 0.75\n   777→        );\n   778→        if (earlierCandidates.length > 0) {\n   779→          selected = [earlierCandidates.reduce((a, b) => (a.score > b.score ? a : b))];\n   780→        } else {\n   781→          // All candidates are in the last 25% — no positional basis to prefer one over another;\n   782→          // fall back to score, accepting that the guard cannot help here.\n   783→          selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n   784→        }\n   785→      } else {\n   786→        selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n   787→      }\n   788→    }\n   789→  }\n   790→\n   791→  // Cap at 3, sort by document position\n   792→  selected.sort((a, b) => a.position - b.position);\n   793→  selected = selected.slice(0, 3);\n   794→\n   795→  if (selected.length === 0) {\n   796→    return undefined;\n   797→  }\n   798→\n   799→  return selected.map((s) => s.text).join(\" + \");\n   800→}\n   801→\n   802→/**\n   803→ * Extract potential recipe title from OCR text (sync heuristic fallback)\n   804→ */\n   805→export function extractTitle(text: string): string | undefined {\n   806→  if (!text || text.trim().length === 0) {\n   807→    return undefined;\n   808→  }\n   809→\n   810→  const lines = text.split(\"\\n\").map((line) => line.trim());\n   811→\n   812→  for (const line of lines) {\n   813→    if (line.length === 0) continue;\n   814→    if (line.length < 3 || line.length > 50) continue;\n   815→    if (looksLikeIngredient(line)) continue;\n   816→    if (isAllCaps(line)) continue;\n   817→    if (startsWithNumber(line)) continue;\n   818→    return line;\n   819→  }\n   820→\n   821→  return undefined;\n   822→}\n   823→"}]},"parent_tool_use_id":null,"session_id":"fc97eaa2-7481-42f4-b7bf-89f7efc643c7","uuid":"dc547c1c-5e05-4b5a-9c10-493ae929364e","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/title-extractor.ts","content":"/**\n * Title Extraction\n * Extracts potential recipe title from OCR text using heuristics or semantic embeddings\n */\n\nimport { cosineSimilarity } from \"./embeddings\";\n\nexport type EmbedFn = (text: string) => Promise<Array<number>>;\n\nconst TITLE_REFERENCE =\n  \"recipe name, dish title, name of the food, nazwa przepisu, nazwa dania\";\nconst HEADER_REFERENCE =\n  \"ingredients list, cooking directions, section heading, składniki, przygotowanie, sposób wykonania\";\nconst NOISE_REFERENCE =\n  \"page number, table of contents, book footer, garbled text\";\n\n/**\n * Measurement units commonly found in ingredient lists\n */\nconst MEASUREMENT_PATTERNS = [\n  // English\n  \"cup\",\n  \"cups\",\n  \"tbsp\",\n  \"tsp\",\n  \"tablespoon\",\n  \"teaspoon\",\n  // \"oz\" and \"lb\" are matched with word boundaries in looksLikeIngredient\n  // to avoid false positives (\"oz\" in \"mozzarella\", \"lb\" in \"albacore\")\n  \"gram\",\n  \"grams\",\n  \"kg\",\n  \"ml\",\n  \"liter\",\n  \"pinch\",\n  \"dash\",\n  \"handful\",\n  // Polish\n  \"łyżka\", \"łyżki\", \"łyżek\",           // tablespoon(s)\n  \"łyżeczka\", \"łyżeczki\", \"łyżeczek\",   // teaspoon(s)\n  \"szklanka\", \"szklanki\", \"szklanek\",    // cup(s)\n  \"szczypta\",                            // pinch\n  \"garść\",                               // handful\n  \"opakowanie\", \"opakowania\",            // package(s)\n  \"plasterek\", \"plasterki\",             // slice(s)\n];\n\n/**\n * Patterns that identify recipe metadata lines (not titles)\n */\nconst METADATA_PATTERNS = [\n  /^(SERVES?|MAKES?|YIELDS?)\\b/i,\n  /^(PREP(ARATION)?|COOK(ING)?|PROOF|RISING|FERMENTATION|REST(ING)?)\\s*(AND\\s*)?(COOK(ING)?)?\\s*TIME/i,\n  /^SAMPLE\\s+SCHEDULE\\b/i,\n  /^BULK\\s+FERMENTATION\\b/i,\n  /^(THIS\\s+RECIPE\\s+)?MAKES\\b/i,\n  // Polish serving-size patterns: \"NA 3 PAPRYKI\", \"NA OKOŁO 1 KG\", \"DLA 4 OSÓB\"\n  /^NA\\s+(\\d|OKOŁO)\\b/i,\n  /^DLA\\s+\\d/i,\n  // OCR-resilient: \"DLA\" + any token + serving-unit word (handles DLA & OSOB, DLA § OSOB, etc.)\n  /^DLA\\s+\\S+\\s+OSOB/i,\n  // OCR-resilient: \"DLA\" + single non-alphanumeric char (common digit→symbol OCR error)\n  /^DLA\\s+[^a-zA-Z0-9\\s]\\s/i,\n  // Time-unit metadata: any line containing \"N MIN\" or \"N GODZ\" is prep/cook/rest time,\n  // regardless of OCR-corrupted prefix (catches PRZYGOTOWANTE, GOTOMANTE, etc.)\n  /\\b\\d+\\s*MIN\\b/i,\n  /\\b\\d+\\s*GODZ/i,\n];\n\n/**\n * Single-word non-title words — standalone OCR fragments unlikely to be recipe titles\n */\nconst NON_TITLE_WORDS = new Set([\n  \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"are\", \"was\",\n  \"has\", \"his\", \"her\", \"its\", \"our\", \"who\", \"how\", \"may\", \"new\", \"now\",\n  \"old\", \"see\", \"way\", \"did\", \"get\", \"let\", \"say\", \"she\", \"too\", \"use\",\n  \"buns\", \"with\",\n]);\n\nfunction looksLikeIngredient(line: string): boolean {\n  const lowerLine = line.toLowerCase();\n  if (MEASUREMENT_PATTERNS.some((pattern) => lowerLine.includes(pattern))) return true;\n  // Compact metric: \"100g\", \"50ml\", \"250g\" — digit immediately followed by g/ml/kg\n  if (/\\b\\d+\\s*(?:g|ml|kg)\\b/i.test(line)) return true;\n  // \"to taste\" / \"do smaku\" — qualitative ingredient with no unit\n  if (/\\bto taste\\b/i.test(line) || /\\bdo smaku\\b/i.test(line)) return true;\n  return false;\n}\n\nfunction startsWithNumber(line: string): boolean {\n  // Match lines starting with a digit, or bullet-then-digit (e.g., \"- 2 jajka\")\n  return /^\\s*(?:[-•*]\\s*)?\\d/.test(line);\n}\n\nfunction stripDiacritics(text: string): string {\n  return text.normalize(\"NFKD\").replace(/[\\u0300-\\u036f]/g, \"\");\n}\n\n/**\n * Known recipe section labels — these are structural headers, not recipe titles.\n * Matched case-insensitively after trimming, stripping trailing punctuation, and stripping diacritics.\n * Polish entries are stored without diacritics for OCR resilience (e.g. \"SKLADNIKI\" matches \"składniki\").\n */\nconst SECTION_LABELS = new Set([\n  // English\n  \"ingredients\", \"directions\", \"instructions\", \"method\", \"preparation\",\n  \"steps\", \"notes\", \"tip\", \"tips\", \"variations\", \"variation\",\n  \"garnish\", \"topping\", \"toppings\", \"frosting\", \"filling\",\n  // Polish — recipe section labels (stored without diacritics for OCR resilience)\n  \"skladniki\", \"przygotowanie\", \"sposob przygotowania\", \"sposob wykonania\",\n  \"wykonanie\", \"wskazowki\", \"podpowiedz\", \"warianty\",\n  \"sos\", \"nadzienie\", \"polewa\", \"lukier\", \"ciasto\",  // ciasto = dough/pastry base (recipe-internal section AND chapter label)\n  // Polish — recipe-book chapter/category labels (food groups, meal types)\n  \"warzywa\",          // vegetables\n  \"mieso\",            // meat (mięso)\n  \"miesa\",            // meats (mięsa)\n  \"ryby\",             // fish\n  \"owoce morza\",      // seafood\n  \"zupy\",             // soups\n  \"salatki\",          // salads (sałatki)\n  \"desery\",           // desserts\n  \"napoje\",           // drinks\n  \"pieczywo\",         // bread/baked goods\n  \"przekaski\",        // appetizers/snacks\n  \"sniadania\",        // breakfasts (śniadania)\n  \"obiady\",           // dinners/lunches\n  \"kolacje\",          // suppers\n  \"makarony\",         // pasta dishes\n  \"kasza\",            // groats/grains\n  \"kasze\",            // groats/grains (plural)\n  \"dania glowne\",     // main courses (dania główne)\n  \"przystawki\",       // starters\n  \"dodatki\",          // side dishes\n  \"przetwory\",        // preserves\n  \"wypieki\",          // baked goods\n  \"ciasta\",           // cakes (plural)\n  \"ciastka\",          // cookies\n  \"torty\",            // layer cakes\n  \"placki\",           // pancakes/flatbreads\n  \"koktajle\",         // cocktails/smoothies\n]);\n\nfunction isSectionLabel(text: string): boolean {\n  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n  return SECTION_LABELS.has(normalized);\n}\n\nfunction isAllCaps(line: string): boolean {\n  const letters = line.replace(/[^a-zA-Z]/g, \"\");\n  return letters.length > 0 && letters === letters.toUpperCase();\n}\n\nfunction looksLikeMetadata(text: string): boolean {\n  return METADATA_PATTERNS.some((pattern) => pattern.test(text.trim()));\n}\n\nfunction isLikelyGarbled(text: string): boolean {\n  const letters = text.replace(/[^a-zA-Z]/g, \"\");\n  if (letters.length < 2) return true;\n\n  // Check vowel ratio — English/Polish text typically has 30–50% vowels\n  const vowels = letters.replace(/[^aeiouAEIOUyYąęóĄĘÓ]/g, \"\").length;\n  const vowelRatio = vowels / letters.length;\n  if (vowelRatio < 0.15 || vowelRatio > 0.85) return true;\n\n  // Single orphaned word ≤3 letters that isn't a common word\n  const words = text.trim().split(/\\s+/);\n  const COMMON_SHORT = new Set([\n    \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"had\", \"her\",\n    \"was\", \"one\", \"our\", \"out\", \"are\", \"has\", \"his\", \"how\", \"its\", \"may\",\n    \"new\", \"now\", \"old\", \"see\", \"way\", \"who\", \"did\", \"get\", \"let\", \"say\",\n    \"she\", \"too\", \"use\",\n  ]);\n  if (words.length === 1 && letters.length <= 3 && !COMMON_SHORT.has(text.trim().toLowerCase())) {\n    return true;\n  }\n\n  // Single word with internal lowercase→uppercase transition — OCR noise (e.g., \"UuIw\", \"aBC\")\n  // No recipe title uses this pattern as a standalone single-word candidate.\n  if (words.length === 1 && /[a-z][A-Z]/.test(text.trim())) {\n    return true;\n  }\n\n  // Recipe titles never start with a lowercase letter\n  if (/^[a-z]/.test(text.trim())) {\n    return true;\n  }\n\n  // Mid-text sentence boundary (\". \" followed by a letter) — body text fragment spliced from multiple sentences\n  const trimmed = text.trim();\n  if (/\\.\\s+[a-zA-Z]/.test(trimmed) && !trimmed.endsWith(\")\")) {\n    return true;\n  }\n\n  // Multi-word candidate containing a garbled OCR fragment: a short lowercase word that isn't a known short word\n  if (words.length >= 2) {\n    const commonShort2 = new Set([\n      \"a\", \"i\", \"of\", \"or\", \"to\", \"in\", \"on\", \"is\", \"it\", \"an\",\n      \"as\", \"at\", \"by\", \"do\", \"go\", \"if\", \"no\", \"so\", \"up\", \"we\",\n      \"w\", \"z\",  // Polish prepositions\n    ]);\n    const hasGarbledWord = words.some(\n      (w) =>\n        /^[a-z]/.test(w) &&\n        w.replace(/[^a-z]/g, \"\").length <= 2 &&\n        !commonShort2.has(w.toLowerCase())\n    );\n    if (hasGarbledWord) {\n      return true;\n    }\n  }\n\n  return false;\n}\n\nfunction passesHardFilters(text: string): boolean {\n  if (text.length < 3 || text.length > 80) return false;\n  if (looksLikeIngredient(text)) return false;\n  if (startsWithNumber(text)) return false;\n  if (looksLikeMetadata(text)) return false;\n  if (isLikelyGarbled(text)) return false;\n  // Pipe-separated lines are book category/chapter headers, not recipe titles\n  if (text.includes(\" | \")) return false;\n  // Slash-separated breadcrumbs (e.g., \"/ Jesien / Zupy\") are navigation, not titles\n  // Only filter when 2+ slashes are present — single-slash lines like\n  // \"TITLE / SUBTITLE\" are legitimate continuation-merged titles\n  if ((text.match(/\\//g) || []).length >= 2) return false;\n  // Bullet-list items (ingredients or instruction steps) are never titles\n  if (/^\\s*[-•*]\\s/.test(text)) return false;\n  // Known recipe section labels are structural headers, not titles\n  if (isSectionLabel(text)) return false;\n  // Single-word non-title fragments\n  const words = text.trim().split(/\\s+/);\n  if (words.length === 1 && NON_TITLE_WORDS.has(text.trim().toLowerCase())) return false;\n  return true;\n}\n\n/**\n * Detect initial burst of short garbled lines.\n * Returns the index of the first non-garbled or long line.\n */\nfunction findBurstEnd(lines: Array<{ text: string }>): number {\n  let i = 0;\n  while (i < lines.length && lines[i].text.length < 20 && isLikelyGarbled(lines[i].text)) {\n    i++;\n  }\n  return i;\n}\n\nfunction wordCount(text: string): number {\n  return text.split(/\\s+/).filter((w) => w.length > 0).length;\n}\n\n/**\n * Build candidate strings from lines: single lines plus multi-line joins (2-3 consecutive).\n * Skips initial burst of short garbled lines. Scans all remaining lines. Caps at 25.\n */\nexport type CandidateOrigin = \"single\" | \"2-line\" | \"3-line\";\n\nfunction buildCandidates(\n  lines: Array<string>\n): Array<{ text: string; position: number; origin: CandidateOrigin }> {\n  const nonEmptyLines: Array<{ text: string; index: number }> = [];\n\n  for (let i = 0; i < lines.length; i++) {\n    const trimmed = lines[i].trim();\n    if (trimmed.length > 0) {\n      nonEmptyLines.push({ text: trimmed, index: i });\n    }\n  }\n\n  const burstEnd = findBurstEnd(nonEmptyLines);\n\n  // Pre-merge consecutive short ALL_CAPS lines (OCR-fragmented headings).\n  // When a sequence of 2+ ALL_CAPS lines each has ≤2 words and ≤25 chars, they are\n  // almost certainly OCR fragments of a single heading. Merge them into one line so\n  // the complete title enters the candidate pool without hitting the 3-line join ceiling.\n  const capsCoalesced: Array<{ text: string; index: number }> = [];\n  let ci = burstEnd;\n  while (ci < nonEmptyLines.length) {\n    const line = nonEmptyLines[ci];\n    if (\n      isAllCaps(line.text) &&\n      wordCount(line.text) <= 2 &&\n      line.text.length <= 25 &&\n      !isSectionLabel(line.text) &&\n      !looksLikeMetadata(line.text)\n    ) {\n      let merged = line.text;\n      const startIndex = line.index;\n      let j = ci + 1;\n      while (j < nonEmptyLines.length) {\n        const next = nonEmptyLines[j];\n        if (\n          isAllCaps(next.text) &&\n          wordCount(next.text) <= 2 &&\n          next.text.length <= 25 &&\n          !isSectionLabel(next.text) &&\n          !looksLikeMetadata(next.text) &&\n          (merged + \" \" + next.text).length <= 80\n        ) {\n          merged += \" \" + next.text;\n          j++;\n        } else {\n          break;\n        }\n      }\n      if (j > ci + 1) {\n        capsCoalesced.push({ text: merged, index: startIndex });\n        ci = j;\n        continue;\n      }\n    }\n    capsCoalesced.push(line);\n    ci++;\n  }\n\n  // Pre-merge continuation lines: a line starting with /&+:( is never a standalone title.\n  // Merge it into the preceding line so the complete title enters the pool as a single candidate,\n  // avoiding the fragile chain of conditions required by the downstream join survival logic.\n  // Limitation: only one continuation line per preceding line is merged. Titles split across\n  // three or more lines with continuation tokens (rare in practice) are not handled here —\n  // the downstream 2-line and 3-line join candidates cover those cases instead.\n  const mergedLines: Array<{ text: string; index: number }> = [];\n  for (let i = 0; i < capsCoalesced.length; i++) {\n    const line = capsCoalesced[i];\n    if (i + 1 < capsCoalesced.length) {\n      const nextText = capsCoalesced[i + 1].text;\n      if (/^[/&+:(]/.test(nextText)) {\n        mergedLines.push({ text: `${line.text} ${nextText}`, index: line.index });\n        i++;\n        continue;\n      }\n    }\n    mergedLines.push(line);\n  }\n\n  const candidates: Array<{ text: string; position: number; origin: CandidateOrigin }> = [];\n  const seen = new Set<string>();\n\n  // Build a set of positions to skip: short ALL_CAPS lines immediately following metadata\n  const metadataContinuationPositions = new Set<number>();\n  for (let i = 0; i < mergedLines.length - 1; i++) {\n    if (looksLikeMetadata(mergedLines[i].text)) {\n      const next = mergedLines[i + 1];\n      if (isAllCaps(next.text) && wordCount(next.text) <= 2 && next.text.length <= 15) {\n        metadataContinuationPositions.add(next.index);\n      }\n    }\n  }\n\n  for (let i = 0; i < mergedLines.length; i++) {\n    const line = mergedLines[i];\n\n    // Skip metadata continuation fragments\n    if (metadataContinuationPositions.has(line.index)) continue;\n\n    // Single line\n    if (passesHardFilters(line.text)) {\n      const norm = line.text.toLowerCase();\n      if (!seen.has(norm)) {\n        seen.add(norm);\n        candidates.push({ text: line.text, position: line.index, origin: \"single\" });\n      }\n    }\n\n    // 2-line join — skip if first line is a section label (prevents \"INGREDIENTS TITLE\" joins)\n    if (i + 1 < mergedLines.length && !isSectionLabel(line.text)) {\n      const joined2 = `${line.text} ${mergedLines[i + 1].text}`;\n      if (passesHardFilters(joined2)) {\n        const norm = joined2.toLowerCase();\n        if (!seen.has(norm)) {\n          seen.add(norm);\n          candidates.push({ text: joined2, position: line.index, origin: \"2-line\" });\n        }\n      }\n    }\n\n    // 3-line join — skip if first line is a section label\n    if (i + 2 < mergedLines.length && !isSectionLabel(line.text)) {\n      const joined3 = `${line.text} ${mergedLines[i + 1].text} ${mergedLines[i + 2].text}`;\n      if (passesHardFilters(joined3)) {\n        const norm = joined3.toLowerCase();\n        if (!seen.has(norm)) {\n          seen.add(norm);\n          candidates.push({ text: joined3, position: line.index, origin: \"3-line\" });\n        }\n      }\n    }\n  }\n\n  // Pre-filter to 25 before embedding calls: prefer ALL_CAPS and short candidates.\n  // Position-based scoring handles final ranking.\n  if (candidates.length > 25) {\n    const prioritized = candidates.slice().sort((a, b) => {\n      const aAllCaps = isAllCaps(a.text) ? 0 : 1;\n      const bAllCaps = isAllCaps(b.text) ? 0 : 1;\n      if (aAllCaps !== bAllCaps) return aAllCaps - bAllCaps;\n      const aShort = wordCount(a.text) <= 5 ? 0 : 1;\n      const bShort = wordCount(b.text) <= 5 ? 0 : 1;\n      return aShort - bShort;\n    });\n    return prioritized.slice(0, 25);\n  }\n\n  return candidates;\n}\n\n// Module-level cache for reference embeddings\nlet cachedTitleRefEmbedding: Array<number> | null = null;\nlet cachedHeaderRefEmbedding: Array<number> | null = null;\nlet cachedNoiseRefEmbedding: Array<number> | null = null;\n\nexport function _resetEmbeddingCacheForTests(): void {\n  cachedTitleRefEmbedding = null;\n  cachedHeaderRefEmbedding = null;\n  cachedNoiseRefEmbedding = null;\n}\n\nexport async function extractTitleWithEmbeddings(\n  text: string,\n  embed: EmbedFn\n): Promise<string | undefined> {\n  if (!text || text.trim().length === 0) {\n    return undefined;\n  }\n\n  const lines = text.split(\"\\n\");\n  const candidates = buildCandidates(lines);\n\n  if (candidates.length === 0) {\n    return undefined;\n  }\n\n  // Cache reference embeddings\n  if (!cachedTitleRefEmbedding) {\n    cachedTitleRefEmbedding = await embed(TITLE_REFERENCE);\n  }\n  if (!cachedHeaderRefEmbedding) {\n    cachedHeaderRefEmbedding = await embed(HEADER_REFERENCE);\n  }\n  if (!cachedNoiseRefEmbedding) {\n    cachedNoiseRefEmbedding = await embed(NOISE_REFERENCE);\n  }\n\n  // Find ALL_CAPS candidates with ≥2 words where every significant word has ≥4 alpha letters.\n  // Insignificant tokens (≤1 alpha letter: \"/\", \"&\", \"+\", \":\", \"D)\", etc.) are filtered before\n  // the check so that multi-line joins with continuation punctuation still qualify.\n  const isStructuralHeading = (c: { text: string }): boolean => {\n    if (!isAllCaps(c.text) || wordCount(c.text) < 2) return false;\n    const sigWords = c.text.trim().split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length > 1);\n    return sigWords.length >= 2 && sigWords.every((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n  };\n\n  // Pass 1: compute rawScore for all candidates (embedding quality signal)\n  const rawScored: Array<{ text: string; position: number; origin: CandidateOrigin; rawScore: number; embedding: Array<number> }> = [];\n  for (const candidate of candidates) {\n    const embedding = await embed(candidate.text);\n    const titleSim = cosineSimilarity(embedding, cachedTitleRefEmbedding);\n    const headerSim = cosineSimilarity(embedding, cachedHeaderRefEmbedding);\n    const noiseSim = cosineSimilarity(embedding, cachedNoiseRefEmbedding);\n    const rawScore = titleSim - Math.max(headerSim, noiseSim);\n    rawScored.push({ text: candidate.text, position: candidate.position, origin: candidate.origin, rawScore, embedding });\n  }\n\n  // Select baseHeading by embedding quality (rawScore), not position.\n  // This prevents OCR-garbled fragments from claiming the structural heading slot.\n  const structuralCandidates = rawScored.filter((s) => isStructuralHeading(s));\n\n  // Penalize structural headings with truncated OCR words:\n  // if \"FRON\" appears and another heading has \"SAFFRON\", \"FRON\" is likely garbled.\n  for (const sc of structuralCandidates) {\n    const sigWords = sc.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n    for (const other of structuralCandidates) {\n      if (other === sc) continue;\n      const otherSigWords = other.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n      const hasTruncation = sigWords.some((w) =>\n        otherSigWords.some((ow) => ow !== w && ow.length > w.length && ow.endsWith(w))\n      );\n      if (hasTruncation) {\n        sc.rawScore = -1.0;  // Hard disqualification — truncated OCR artifact\n        break;\n      }\n    }\n  }\n\n  const bestStructural = structuralCandidates.length > 0\n    ? structuralCandidates.reduce((a, b) => {\n        const scoreDiff = a.rawScore - b.rawScore;\n        if (Math.abs(scoreDiff) > 0.03) return scoreDiff > 0 ? a : b;\n        // Tiebreak: single-line origin beats multi-line joins (avoids conflating two separate headings)\n        if (a.origin === \"single\" && b.origin !== \"single\") return a;\n        if (b.origin === \"single\" && a.origin !== \"single\") return b;\n        // Tiebreak: more words (more specific) → better\n        const wcDiff = wordCount(b.text) - wordCount(a.text);\n        if (wcDiff !== 0) return wcDiff > 0 ? b : a;\n        // Tiebreak: earlier position → better\n        return a.position < b.position ? a : b;\n      })\n    : null;\n  const baseHeading = bestStructural ?? undefined;\n\n  // When the best structural heading has a continuation on the next line introduced by a\n  // punctuation token (/, &, +, :, or parenthesis), prefer the longer 2-line join as the\n  // complete heading. E.g. \"SAFFRON WHEAT BUNS WITH QUARK\" + \"/ COTTAGE CHEESE (VARIATION D)\".\n  // Guard: the remainder after the prefix must start with a continuation character to avoid\n  // merging two separate consecutive recipe titles (FINNISH MILK FLATBREADS stays separate\n  // from FINNISH POTATO FLATBREADS because \"FINNISH\" does not start with a continuation token).\n  let firstStructuralHeading = baseHeading && (\n    rawScored.find((c) => {\n      if (!isStructuralHeading(c)) return false;\n      const hLower = baseHeading.text.toLowerCase();\n      const cLower = c.text.toLowerCase();\n      return cLower.startsWith(hLower + \" \") && /^[/&+:(]/.test(cLower.slice(hLower.length + 1));\n    }) ?? baseHeading\n  );\n\n  // Pass 2: apply bonuses\n  const scored: Array<{ text: string; position: number; origin: CandidateOrigin; score: number; rawScore: number; baseScore: number; thresholdScore: number }> = rawScored.map((rs) => {\n    // Position factor: multiplicative tiebreaker — amplifies existing signal, doesn't replace it\n    const relativePosition = rs.position / lines.length;\n    const positionFactor = relativePosition < 0.5\n      ? 1.0 + 0.12 * (1 - relativePosition * 2)\n      : 1.0;\n\n    // ALL_CAPS bonus: recipe books use ALL_CAPS for titles and section headings.\n    // Single-word ALL_CAPS terms are overwhelmingly section/category labels, not recipe titles;\n    // real recipe titles in ALL_CAPS are almost always multi-word. Reduce the bonus for single words.\n    const allCapsBonus = isAllCaps(rs.text) && rs.text.replace(/[^a-zA-Z]/g, \"\").length >= 4\n      ? (wordCount(rs.text) >= 2 ? 0.08 : 0.03)\n      : 0;\n\n    // Structural heading bonus: best ALL_CAPS heading (or its continuation join) is almost always the recipe title\n    const structuralBonus = firstStructuralHeading && rs.text === firstStructuralHeading.text ? 0.10 : 0;\n\n    // thresholdScore excludes structural bonus so the bonus doesn't inflate the threshold\n    // and prevent equally-valid structural headings from passing on multi-recipe pages.\n    const thresholdScore = rs.rawScore + allCapsBonus;\n    // baseScore excludes position factor — used for diagnostics and ranking\n    const baseScore = rs.rawScore + allCapsBonus + structuralBonus;\n    const score = rs.rawScore * positionFactor + allCapsBonus + structuralBonus;\n    return { text: rs.text, position: rs.position, origin: rs.origin, score, rawScore: rs.rawScore, baseScore, thresholdScore };\n  });\n\n  if (scored.length === 0) {\n    return undefined;\n  }\n\n  // --- Pre-threshold bilingual title detection ---\n  // When a mixed-case candidate at position 0 is followed by an ALL_CAPS candidate\n  // at position ≤ 2 that is semantically similar to it, this is a bilingual recipe\n  // page (e.g., Polish title + ALL_CAPS Korean romanization). Suppress confirmed\n  // translation candidates before computing threshold so their bonuses don't inflate\n  // the threshold beyond the mixed-case title's reach.\n  // Note: we check position ≤ 2 (local proximity), not global ALL_CAPS count, so\n  // section headers later in the document (SKŁADNIKI, WARZYWA, etc.) are irrelevant.\n  let translationCandidates: typeof scored = [];\n  let scoredForThreshold = scored;\n  const prePos0 = scored.find((s) => s.position === 0 && !isAllCaps(s.text));\n  if (prePos0) {\n    const nearbyAllCaps = scored.filter(\n      (s) => isAllCaps(s.text) && s.position >= 1 && s.position <= 2 && s.origin === \"single\"\n    );\n    const pos0Embedding = rawScored.find((r) => r.text === prePos0.text)?.embedding;\n\n    // Method 1: embedding similarity (works for related languages)\n    if (pos0Embedding && nearbyAllCaps.length > 0) {\n      translationCandidates = nearbyAllCaps.filter((cap) => {\n        const capEmbedding = rawScored.find((r) => r.text === cap.text)?.embedding;\n        if (!capEmbedding) return false;\n        return cosineSimilarity(pos0Embedding, capEmbedding) > 0.4;\n      });\n    }\n\n    // Method 2: layout-based detection (cross-lingual fallback).\n    // When embedding similarity is insufficient (e.g. Polish ↔ Korean romanization),\n    // detect bilingual layout by position and word overlap:\n    // mixed-case ≥2 words at pos 0 + ALL_CAPS ≥2 words at pos 1-2 with no shared words.\n    if (translationCandidates.length === 0 && wordCount(prePos0.text) >= 2) {\n      const pos0Words = new Set(\n        prePos0.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2)\n      );\n      translationCandidates = nearbyAllCaps.filter((cap) => {\n        if (wordCount(cap.text) < 2) return false;\n        const capWords = cap.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2);\n        return !capWords.some((w) => pos0Words.has(w));\n      });\n    }\n\n    if (translationCandidates.length > 0) {\n      // Suppress standalone translations and any multi-line joins that embed the translation\n      // as a suffix or substring (e.g. \"Smażona zielona fasolka GREEN BEANS BORKEUM\" ends with\n      // the translation; \"Title GREEN BEANS BORKEUM 그린빈\" includes it as a substring).\n      scoredForThreshold = scored.filter((s) => {\n        const sLower = s.text.toLowerCase();\n        return !translationCandidates.some((t) => {\n          const tLower = t.text.toLowerCase();\n          return sLower.startsWith(tLower) ||\n                 sLower.endsWith(\" \" + tLower) ||\n                 sLower.includes(\" \" + tLower);\n        });\n      });\n    }\n  }\n\n  // Fix 2: If the structural heading was identified as a bilingual translation, reassign it.\n  // This prevents the translation's ALL_CAPS bonus from inflating the threshold and ensures\n  // the fallback path in scored also uses the correct heading.\n  if (\n    translationCandidates.length > 0 &&\n    firstStructuralHeading &&\n    translationCandidates.some((t) => t.text === firstStructuralHeading!.text)\n  ) {\n    const nonTranslationStructural = structuralCandidates.filter(\n      (sc) => !translationCandidates.some((t) => t.text === sc.text)\n    );\n    const newHeading = nonTranslationStructural.length > 0\n      ? nonTranslationStructural.reduce((a, b) => a.rawScore > b.rawScore ? a : b)\n      : undefined;\n\n    // Patch scored array: remove old structural bonus, apply new one\n    for (const s of scored) {\n      if (s.text === firstStructuralHeading.text) {\n        s.score -= 0.10;\n        s.baseScore -= 0.10;\n      }\n      if (newHeading && s.text === newHeading.text) {\n        s.score += 0.10;\n        s.baseScore += 0.10;\n      }\n    }\n    // Update reference for downstream prefix-removal logic\n    firstStructuralHeading = newHeading ?? undefined;\n  }\n\n  // Use thresholdScore (excludes structural bonus) so the structural bonus doesn't inflate\n  // the threshold and block equally-valid headings on multi-recipe pages.\n  const bestThresholdScore = Math.max(...scoredForThreshold.map((s) => s.thresholdScore));\n  const threshold = Math.max(0.08, bestThresholdScore * 0.7);\n\n  // Filter candidates above threshold\n  let selected = scoredForThreshold.filter((s) => s.score >= threshold);\n\n  // Empty-pool fallback: when threshold filtering discards every candidate,\n  // the hard filters' structural verdict should not be overruled by weak\n  // embedding differentiation. Return the best positional candidate.\n  if (selected.length === 0 && scored.length > 0) {\n    const fallback = scored\n      .slice()\n      .sort((a, b) => a.position - b.position || b.score - a.score);\n    selected = [fallback[0]];\n  }\n\n  // Remove word-boundary prefixes of firstStructuralHeading when the heading itself survived\n  // the threshold. Cases:\n  //   ARAYES case:  firstStructuralHeading = \"ARAYES SHRAK\" (2-word join qualifies; \"ARAYES\"\n  //     alone = 1 word, so it never qualified). Filter removes \"ARAYES\" so dedup keeps the join.\n  //   SAFFRON case: baseHeading was the partial line; continuation logic above upgraded\n  //     firstStructuralHeading to the full join. Filter removes the partial so dedup keeps join.\n  // Safety: only fires when the complete heading itself is in selected (passed the threshold).\n  if (firstStructuralHeading && selected.some((s) => s.text === firstStructuralHeading.text)) {\n    const fshLower = firstStructuralHeading.text.toLowerCase();\n    selected = selected.filter((s) => {\n      if (s.text === firstStructuralHeading.text) return true;\n      const sLower = s.text.toLowerCase();\n      // Remove s if it is a space-delimited prefix of the structural heading\n      return !fshLower.startsWith(sLower + \" \");\n    });\n  }\n\n  // Protect continuation joins: when a multi-line join (2-line or 3-line) survived the threshold\n  // and its second part starts with a continuation character, remove the single-line prefix/suffix\n  // so the dedup \"shorter wins\" rule doesn't destroy the complete join.\n  // Note: the pre-merge step above already handles the common Baked Eggs case (&/continuation\n  // on next line) by turning it into a single candidate — this block covers the rarer case where\n  // a continuation-character join was generated as a 2-line/3-line candidate and the prefix\n  // single also survived threshold independently (e.g. from a different code path or OCR layout).\n  // Safety: only fires for joins whose continuation starts with /&+:( — digit continuations\n  // like \"Pierogi Ruskie 200g mąki\" are NOT protected, so dedup correctly keeps the shorter form.\n  const survivingJoins = selected.filter((s) => s.origin === \"2-line\" || s.origin === \"3-line\");\n  if (survivingJoins.length > 0) {\n    selected = selected.filter((s) => {\n      if (s.origin !== \"single\") return true;\n      const sLower = s.text.toLowerCase();\n      // Remove PREFIX singles whose continuation join also survived\n      const isPrefixOfJoin = survivingJoins.some((j) => {\n        const jLower = j.text.toLowerCase();\n        if (!jLower.startsWith(sLower + \" \")) return false;\n        const remainder = jLower.slice(sLower.length + 1);\n        return /^[/&+:(]/.test(remainder);\n      });\n      if (isPrefixOfJoin) return false;\n      // Remove SUFFIX singles (e.g. \"& Coriander\") whose parent join also survived\n      const isSuffixOfJoin = survivingJoins.some((j) => {\n        const jLower = j.text.toLowerCase();\n        if (!jLower.endsWith(\" \" + sLower)) return false;\n        // Only remove if the suffix starts with a continuation character\n        return /^[/&+:(]/.test(sLower);\n      });\n      if (isSuffixOfJoin) return false;\n      return true;\n    });\n  }\n\n  // Pre-dedup: remove sub-section headers that are substrings of other surviving candidates.\n  // A sub-section header is an ALL_CAPS candidate followed by ingredient-like lines in the source.\n  // Example: \"CHLEBEK\" (bread section header, followed by \"500 g mąki\") is a substring of\n  // \"CHLEBEK Z WARZYWAMI I BOCZKIEM\" (the real title). Without this filter, dedup kills the title.\n  selected = selected.filter((candidate) => {\n    if (!isAllCaps(candidate.text)) return true;\n    // Check if this candidate is immediately followed by ingredient-like content\n    const nextSourceLines = lines.slice(candidate.position + 1, candidate.position + 2);\n    const followedByIngredients = nextSourceLines.some(\n      (l) => looksLikeIngredient(l.trim()) || startsWithNumber(l.trim())\n    );\n    if (!followedByIngredients) return true;\n    // Only remove if a longer candidate contains this one as a substring\n    const candidateLower = candidate.text.toLowerCase();\n    const hasLongerParent = rawScored.some(\n      (other) =>\n        other.text !== candidate.text &&\n        other.text.length > candidate.text.length &&\n        other.text.toLowerCase().includes(candidateLower)\n    );\n    return !hasLongerParent;\n  });\n\n  // Deduplicate: if one title is a substring of another, keep the shorter (more focused) one.\n  // DO NOT CHANGE THIS LOGIC — it has been incorrectly \"improved\" by the title-loop 5 times.\n  // The tests require shorter wins: \"Pierogi Ruskie\" over \"Pierogi Ruskie 200g mąki 3 ziemniaki\".\n  // The pre-filter above handles the conflicting case (structural heading prefix removal) so that\n  // the incomplete prefix line is never present here when the complete join is in selected.\n  selected = selected.filter((a) => {\n    const aLower = a.text.toLowerCase();\n    return !selected.some(\n      (b) =>\n        b !== a &&\n        aLower.includes(b.text.toLowerCase()) &&\n        b.text.length < a.text.length\n    );\n  });\n\n  // Multi-title guard: only join multiple candidates with \"+\" when there is\n  // structural evidence of a multi-recipe page (≥2 ALL_CAPS headings).\n  // A single ALL_CAPS title among mixed-case survivors is a single-recipe page —\n  // collapse to the highest-scoring candidate.\n  // Zero ALL_CAPS survivors → mixed-case multi-title page → keep all.\n  if (selected.length > 1) {\n    const allCapsSelected = selected.filter((s) => isAllCaps(s.text));\n    if (allCapsSelected.length >= 2) {\n      // Check whether non-first ALL_CAPS headings are section headers within one recipe\n      // (followed immediately by ingredient-like content) rather than separate recipe titles.\n      // A multi-recipe page has body text between titles; a single-recipe page has\n      // ingredient lines immediately after each section heading.\n      const sortedCaps = [...allCapsSelected].sort((a, b) => a.position - b.position);\n      const isSubHeader = sortedCaps.slice(1).every((cap) => {\n        const nextLines = lines.slice(cap.position + 1, cap.position + 3);\n        return nextLines.some(\n          (l) => looksLikeIngredient(l.trim()) || /^\\s*\\d/.test(l.trim())\n        );\n      });\n      if (isSubHeader) {\n        selected = [sortedCaps[0]];\n      } else {\n        selected = allCapsSelected;\n      }\n    } else if (allCapsSelected.length === 1) {\n      const theCapCandidate = allCapsSelected[0];\n      // Use non-empty line count so the 75% threshold is consistent regardless of blank-line density.\n      const nonEmptyCount = lines.filter((l) => l.trim().length > 0).length;\n      const capRelPos = theCapCandidate.position / Math.max(nonEmptyCount, 1);\n      // If the sole ALL_CAPS candidate is in the last 25% of the document,\n      // it's likely a category footer, not a title. Prefer the best earlier candidate.\n      if (capRelPos > 0.75) {\n        const earlierCandidates = selected.filter(\n          (s) => s.position / Math.max(nonEmptyCount, 1) <= 0.75\n        );\n        if (earlierCandidates.length > 0) {\n          selected = [earlierCandidates.reduce((a, b) => (a.score > b.score ? a : b))];\n        } else {\n          // All candidates are in the last 25% — no positional basis to prefer one over another;\n          // fall back to score, accepting that the guard cannot help here.\n          selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n        }\n      } else {\n        selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n      }\n    }\n  }\n\n  // Cap at 3, sort by document position\n  selected.sort((a, b) => a.position - b.position);\n  selected = selected.slice(0, 3);\n\n  if (selected.length === 0) {\n    return undefined;\n  }\n\n  return selected.map((s) => s.text).join(\" + \");\n}\n\n/**\n * Extract potential recipe title from OCR text (sync heuristic fallback)\n */\nexport function extractTitle(text: string): string | undefined {\n  if (!text || text.trim().length === 0) {\n    return undefined;\n  }\n\n  const lines = text.split(\"\\n\").map((line) => line.trim());\n\n  for (const line of lines) {\n    if (line.length === 0) continue;\n    if (line.length < 3 || line.length > 50) continue;\n    if (looksLikeIngredient(line)) continue;\n    if (isAllCaps(line)) continue;\n    if (startsWithNumber(line)) continue;\n    return line;\n  }\n\n  return undefined;\n}\n","numLines":823,"startLine":1,"totalLines":823}}}
