{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0165iM1PAsoyzVTmuDrnMtqn","type":"tool_result","content":"     1→import {\n     2→  extractTitle,\n     3→  extractTitleWithEmbeddings,\n     4→  _resetEmbeddingCacheForTests,\n     5→} from \"../title-extractor\";\n     6→\n     7→/**\n     8→ * Creates a mock embed function that returns predictable vectors.\n     9→ * Words matching titleWords get a vector pointing \"toward titles\",\n    10→ * words matching headerWords get a vector pointing \"toward headers\",\n    11→ * and everything else gets a neutral vector.\n    12→ */\n    13→function createMockEmbed(\n    14→  titleWords: Array<string>,\n    15→  headerWords: Array<string>\n    16→): (text: string) => Promise<Array<number>> {\n    17→  // Reference phrases from the module\n    18→  const TITLE_REF =\n    19→    \"recipe name, dish title, name of the food, nazwa przepisu, nazwa dania\";\n    20→  const HEADER_REF =\n    21→    \"ingredients list, cooking directions, section heading, składniki, przygotowanie, sposób wykonania\";\n    22→  const NOISE_REF =\n    23→    \"page number, table of contents, book footer, garbled text\";\n    24→\n    25→  return async (text: string): Promise<Array<number>> => {\n    26→    const lower = text.toLowerCase();\n    27→\n    28→    // Title reference → unit vector in dimension 0\n    29→    if (lower === TITLE_REF.toLowerCase()) {\n    30→      return [1, 0, 0];\n    31→    }\n    32→    // Header reference → unit vector in dimension 1\n    33→    if (lower === HEADER_REF.toLowerCase()) {\n    34→      return [0, 1, 0];\n    35→    }\n    36→    // Noise reference → unit vector in dimension 2 (orthogonal)\n    37→    if (lower === NOISE_REF.toLowerCase()) {\n    38→      return [0, 0, 1];\n    39→    }\n    40→\n    41→    // Check if text contains title-like words → high cosine with title ref\n    42→    const isTitle = titleWords.some((w) => lower.includes(w.toLowerCase()));\n    43→    // Check if text contains header-like words → high cosine with header ref\n    44→    const isHeader = headerWords.some((w) => lower.includes(w.toLowerCase()));\n    45→\n    46→    if (isTitle && !isHeader) {\n    47→      return [0.9, 0.1, 0]; // High title similarity, low header similarity\n    48→    }\n    49→    if (isHeader && !isTitle) {\n    50→      return [0.1, 0.9, 0]; // Low title similarity, high header similarity\n    51→    }\n    52→    if (isTitle && isHeader) {\n    53→      return [0.5, 0.5, 0]; // Ambiguous\n    54→    }\n    55→    // Neutral\n    56→    return [0.3, 0.3, 0.7];\n    57→  };\n    58→}\n    59→\n    60→describe(\"extractTitle (heuristic)\", () => {\n    61→  it(\"returns undefined for empty text\", () => {\n    62→    expect(extractTitle(\"\")).toBeUndefined();\n    63→    expect(extractTitle(\"  \")).toBeUndefined();\n    64→  });\n    65→\n    66→  it(\"returns the first valid line\", () => {\n    67→    expect(extractTitle(\"Chicken Soup\\nIngredients\\n1 cup water\")).toBe(\n    68→      \"Chicken Soup\"\n    69→    );\n    70→  });\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"e0a6e160-3b91-497d-9241-2e1e08478664","uuid":"c42d9d73-665d-4e0d-88f6-4f2e5175102f","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/__tests__/title-extractor.test.ts","content":"import {\n  extractTitle,\n  extractTitleWithEmbeddings,\n  _resetEmbeddingCacheForTests,\n} from \"../title-extractor\";\n\n/**\n * Creates a mock embed function that returns predictable vectors.\n * Words matching titleWords get a vector pointing \"toward titles\",\n * words matching headerWords get a vector pointing \"toward headers\",\n * and everything else gets a neutral vector.\n */\nfunction createMockEmbed(\n  titleWords: Array<string>,\n  headerWords: Array<string>\n): (text: string) => Promise<Array<number>> {\n  // Reference phrases from the module\n  const TITLE_REF =\n    \"recipe name, dish title, name of the food, nazwa przepisu, nazwa dania\";\n  const HEADER_REF =\n    \"ingredients list, cooking directions, section heading, składniki, przygotowanie, sposób wykonania\";\n  const NOISE_REF =\n    \"page number, table of contents, book footer, garbled text\";\n\n  return async (text: string): Promise<Array<number>> => {\n    const lower = text.toLowerCase();\n\n    // Title reference → unit vector in dimension 0\n    if (lower === TITLE_REF.toLowerCase()) {\n      return [1, 0, 0];\n    }\n    // Header reference → unit vector in dimension 1\n    if (lower === HEADER_REF.toLowerCase()) {\n      return [0, 1, 0];\n    }\n    // Noise reference → unit vector in dimension 2 (orthogonal)\n    if (lower === NOISE_REF.toLowerCase()) {\n      return [0, 0, 1];\n    }\n\n    // Check if text contains title-like words → high cosine with title ref\n    const isTitle = titleWords.some((w) => lower.includes(w.toLowerCase()));\n    // Check if text contains header-like words → high cosine with header ref\n    const isHeader = headerWords.some((w) => lower.includes(w.toLowerCase()));\n\n    if (isTitle && !isHeader) {\n      return [0.9, 0.1, 0]; // High title similarity, low header similarity\n    }\n    if (isHeader && !isTitle) {\n      return [0.1, 0.9, 0]; // Low title similarity, high header similarity\n    }\n    if (isTitle && isHeader) {\n      return [0.5, 0.5, 0]; // Ambiguous\n    }\n    // Neutral\n    return [0.3, 0.3, 0.7];\n  };\n}\n\ndescribe(\"extractTitle (heuristic)\", () => {\n  it(\"returns undefined for empty text\", () => {\n    expect(extractTitle(\"\")).toBeUndefined();\n    expect(extractTitle(\"  \")).toBeUndefined();\n  });\n\n  it(\"returns the first valid line\", () => {\n    expect(extractTitle(\"Chicken Soup\\nIngredients\\n1 cup water\")).toBe(\n      \"Chicken Soup\"\n    );\n  });","numLines":70,"startLine":1,"totalLines":196}}}
