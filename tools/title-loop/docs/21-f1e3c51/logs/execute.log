{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012MmLtRTgg7qdrhPcqBBWek","type":"tool_result","content":"   649→\n   650→  if (scored.length === 0) {\n   651→    return undefined;\n   652→  }\n   653→\n   654→  // --- Pre-threshold bilingual title detection ---\n   655→  // When a mixed-case candidate at position 0 is followed by an ALL_CAPS candidate\n   656→  // at position ≤ 2 that is semantically similar to it, this is a bilingual recipe\n   657→  // page (e.g., Polish title + ALL_CAPS Korean romanization). Suppress confirmed\n   658→  // translation candidates before computing threshold so their bonuses don't inflate\n   659→  // the threshold beyond the mixed-case title's reach.\n   660→  // Note: we check position ≤ 2 (local proximity), not global ALL_CAPS count, so\n   661→  // section headers later in the document (SKŁADNIKI, WARZYWA, etc.) are irrelevant.\n   662→  let translationCandidates: typeof scored = [];\n   663→  let scoredForThreshold = scored;\n   664→  const prePos0 = scored.find((s) => s.position === 0 && !isAllCaps(s.text));\n   665→  if (prePos0) {\n   666→    const nearbyAllCaps = scored.filter(\n   667→      (s) => isAllCaps(s.text) && s.position >= 1 && s.position <= 2 && s.origin === \"single\"\n   668→    );\n   669→    const pos0Embedding = rawScored.find((r) => r.text === prePos0.text)?.embedding;\n   670→\n   671→    // Method 1: embedding similarity (works for related languages)\n   672→    if (pos0Embedding && nearbyAllCaps.length > 0) {\n   673→      translationCandidates = nearbyAllCaps.filter((cap) => {\n   674→        const capEmbedding = rawScored.find((r) => r.text === cap.text)?.embedding;\n   675→        if (!capEmbedding) return false;\n   676→        return cosineSimilarity(pos0Embedding, capEmbedding) > 0.4;\n   677→      });\n   678→    }\n   679→\n   680→    // Method 2: layout-based detection (cross-lingual fallback).\n   681→    // When embedding similarity is insufficient (e.g. Polish ↔ Korean romanization),\n   682→    // detect bilingual layout by position and word overlap:\n   683→    // mixed-case ≥2 words at pos 0 + ALL_CAPS ≥2 words at pos 1-2 with no shared words.\n   684→    if (translationCandidates.length === 0 && wordCount(prePos0.text) >= 2) {\n   685→      const pos0Words = new Set(\n   686→        prePos0.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2)\n   687→      );\n   688→      translationCandidates = nearbyAllCaps.filter((cap) => {\n   689→        if (wordCount(cap.text) < 2) return false;\n   690→        const capWords = cap.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2);\n   691→        return !capWords.some((w) => pos0Words.has(w));\n   692→      });\n   693→    }\n   694→\n   695→    if (translationCandidates.length > 0) {\n   696→      // Suppress standalone translations and any multi-line joins that embed the translation\n   697→      // as a suffix or substring (e.g. \"Smażona zielona fasolka GREEN BEANS BORKEUM\" ends with\n   698→      // the translation; \"Title GREEN BEANS BORKEUM 그린빈\" includes it as a substring).\n   699→      scoredForThreshold = scored.filter((s) => {\n   700→        const sLower = s.text.toLowerCase();\n   701→        return !translationCandidates.some((t) => {\n   702→          const tLower = t.text.toLowerCase();\n   703→          return sLower.startsWith(tLower) ||\n   704→                 sLower.endsWith(\" \" + tLower) ||\n   705→                 sLower.includes(\" \" + tLower);\n   706→        });\n   707→      });\n   708→    }\n   709→  }\n   710→\n   711→  // Fix 2: If the structural heading was identified as a bilingual translation, reassign it.\n   712→  // This prevents the translation's ALL_CAPS bonus from inflating the threshold and ensures\n   713→  // the fallback path in scored also uses the correct heading.\n   714→  if (\n   715→    translationCandidates.length > 0 &&\n   716→    firstStructuralHeading &&\n   717→    translationCandidates.some((t) => t.text === firstStructuralHeading!.text)\n   718→  ) {\n   719→    const nonTranslationStructural = structuralCandidates.filter(\n   720→      (sc) => !translationCandidates.some((t) => t.text === sc.text)\n   721→    );\n   722→    const newHeading = nonTranslationStructural.length > 0\n   723→      ? nonTranslationStructural.reduce((a, b) => a.rawScore > b.rawScore ? a : b)\n   724→      : undefined;\n   725→\n   726→    // Patch scored array: remove old structural bonus, apply new one\n   727→    for (const s of scored) {\n   728→      if (s.text === firstStructuralHeading.text) {\n   729→        s.score -= 0.10;\n   730→        s.baseScore -= 0.10;\n   731→      }\n   732→      if (newHeading && s.text === newHeading.text) {\n   733→        s.score += 0.10;\n   734→        s.baseScore += 0.10;\n   735→      }\n   736→    }\n   737→    // Update reference for downstream prefix-removal logic\n   738→    firstStructuralHeading = newHeading ?? undefined;\n   739→  }\n   740→\n   741→  // Use thresholdScore (excludes structural bonus) so the structural bonus doesn't inflate\n   742→  // the threshold and block equally-valid headings on multi-recipe pages.\n   743→  const bestThresholdScore = Math.max(...scoredForThreshold.map((s) => s.thresholdScore));\n   744→  const threshold = Math.max(0.08, bestThresholdScore * 0.7);\n   745→\n   746→  // Filter candidates above threshold\n   747→  let selected = scoredForThreshold.filter((s) => s.score >= threshold);\n   748→\n   749→  // Empty-pool fallback: when threshold filtering discards every candidate,\n   750→  // the hard filters' structural verdict should not be overruled by weak\n   751→  // embedding differentiation. Return the best positional candidate.\n   752→  if (selected.length === 0 && scored.length > 0) {\n   753→    const fallback = scored\n   754→      .slice()\n   755→      .sort((a, b) => a.position - b.position || b.score - a.score);\n   756→    selected = [fallback[0]];\n   757→  }\n   758→\n   759→  // Remove word-boundary prefixes of firstStructuralHeading when the heading itself survived\n   760→  // the threshold. Cases:\n   761→  //   ARAYES case:  firstStructuralHeading = \"ARAYES SHRAK\" (2-word join qualifies; \"ARAYES\"\n   762→  //     alone = 1 word, so it never qualified). Filter removes \"ARAYES\" so dedup keeps the join.\n   763→  //   SAFFRON case: baseHeading was the partial line; continuation logic above upgraded\n   764→  //     firstStructuralHeading to the full join. Filter removes the partial so dedup keeps join.\n   765→  // Safety: only fires when the complete heading itself is in selected (passed the threshold).\n   766→  if (firstStructuralHeading && selected.some((s) => s.text === firstStructuralHeading.text)) {\n   767→    const fshLower = firstStructuralHeading.text.toLowerCase();\n   768→    selected = selected.filter((s) => {\n   769→      if (s.text === firstStructuralHeading.text) return true;\n   770→      const sLower = s.text.toLowerCase();\n   771→      // Remove s if it is a space-delimited prefix of the structural heading\n   772→      return !fshLower.startsWith(sLower + \" \");\n   773→    });\n   774→  }\n   775→\n   776→  // Protect continuation joins: when a multi-line join (2-line or 3-line) survived the threshold\n   777→  // and its second part starts with a continuation character, remove the single-line prefix/suffix\n   778→  // so the dedup \"shorter wins\" rule doesn't destroy the complete join.\n   779→  // Note: the pre-merge step above already handles the common Baked Eggs case (&/continuation\n   780→  // on next line) by turning it into a single candidate — this block covers the rarer case where\n   781→  // a continuation-character join was generated as a 2-line/3-line candidate and the prefix\n   782→  // single also survived threshold independently (e.g. from a different code path or OCR layout).\n   783→  // Safety: only fires for joins whose continuation starts with /&+:( — digit continuations\n   784→  // like \"Pierogi Ruskie 200g mąki\" are NOT protected, so dedup correctly keeps the shorter form.\n   785→  const survivingJoins = selected.filter((s) => s.origin === \"2-line\" || s.origin === \"3-line\");\n   786→  if (survivingJoins.length > 0) {\n   787→    selected = selected.filter((s) => {\n   788→      if (s.origin !== \"single\") return true;\n   789→      const sLower = s.text.toLowerCase();\n   790→      // Remove PREFIX singles whose continuation join also survived\n   791→      const isPrefixOfJoin = survivingJoins.some((j) => {\n   792→        const jLower = j.text.toLowerCase();\n   793→        if (!jLower.startsWith(sLower + \" \")) return false;\n   794→        const remainder = jLower.slice(sLower.length + 1);\n   795→        return /^[/&+:(]/.test(remainder);\n   796→      });\n   797→      if (isPrefixOfJoin) return false;\n   798→      // Remove SUFFIX singles (e.g. \"& Coriander\") whose parent join also survived\n   799→      const isSuffixOfJoin = survivingJoins.some((j) => {\n   800→        const jLower = j.text.toLowerCase();\n   801→        if (!jLower.endsWith(\" \" + sLower)) return false;\n   802→        // Only remove if the suffix starts with a continuation character\n   803→        return /^[/&+:(]/.test(sLower);\n   804→      });\n   805→      if (isSuffixOfJoin) return false;\n   806→      return true;\n   807→    });\n   808→  }\n   809→\n   810→  // Pre-dedup: remove sub-section headers that are substrings of other surviving candidates.\n   811→  // A sub-section header is an ALL_CAPS candidate followed by ingredient-like lines in the source.\n   812→  // Example: \"CHLEBEK\" (bread section header, followed by \"500 g mąki\") is a substring of\n   813→  // \"CHLEBEK Z WARZYWAMI I BOCZKIEM\" (the real title). Without this filter, dedup kills the title.\n   814→  selected = selected.filter((candidate) => {\n   815→    if (!isAllCaps(candidate.text)) return true;\n   816→    // Check if this candidate is immediately followed by ingredient-like content\n   817→    const nextSourceLines = lines.slice(candidate.position + 1, candidate.position + 2);\n   818→    const followedByIngredients = nextSourceLines.some(\n   819→      (l) => looksLikeIngredient(l.trim()) || startsWithNumber(l.trim())\n   820→    );\n   821→    if (!followedByIngredients) return true;\n   822→    // Only remove if a longer candidate contains this one as a substring\n   823→    const candidateLower = candidate.text.toLowerCase();\n   824→    const hasLongerParent = rawScored.some(\n   825→      (other) =>\n   826→        other.text !== candidate.text &&\n   827→        other.text.length > candidate.text.length &&\n   828→        other.text.toLowerCase().includes(candidateLower)\n   829→    );\n   830→    return !hasLongerParent;\n   831→  });\n   832→\n   833→  // Protect multi-line joins from being destroyed by their own component singles.\n   834→  // When \"Lamb Stew\" (2-line join) survives AND both \"Lamb\" and \"Stew\" (singles) also survive,\n   835→  // the join is the intended title — remove the singles.\n   836→  const joinsToProtect = selected.filter((s) => s.origin === \"2-line\" || s.origin === \"3-line\");\n   837→  if (joinsToProtect.length > 0) {\n   838→    const singlesToRemove = new Set<string>();\n   839→    for (const join of joinsToProtect) {\n   840→      const joinWords = join.text.split(/\\s+/);\n   841→      const componentSingles = selected.filter(\n   842→        (s) => s.origin === \"single\" && joinWords.some((w) => s.text.toLowerCase() === w.toLowerCase())\n   843→      );\n   844→      if (componentSingles.length >= Math.min(joinWords.length, 2)) {\n   845→        componentSingles.forEach((s) => singlesToRemove.add(s.text));\n   846→      }\n   847→    }\n   848→    if (singlesToRemove.size > 0) {\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"a5bfc1c9-4aac-4af0-806b-8a2590b8aad5","uuid":"8bd7d9c6-4c21-4c13-928f-40d614dc65df","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/title-extractor.ts","content":"\n  if (scored.length === 0) {\n    return undefined;\n  }\n\n  // --- Pre-threshold bilingual title detection ---\n  // When a mixed-case candidate at position 0 is followed by an ALL_CAPS candidate\n  // at position ≤ 2 that is semantically similar to it, this is a bilingual recipe\n  // page (e.g., Polish title + ALL_CAPS Korean romanization). Suppress confirmed\n  // translation candidates before computing threshold so their bonuses don't inflate\n  // the threshold beyond the mixed-case title's reach.\n  // Note: we check position ≤ 2 (local proximity), not global ALL_CAPS count, so\n  // section headers later in the document (SKŁADNIKI, WARZYWA, etc.) are irrelevant.\n  let translationCandidates: typeof scored = [];\n  let scoredForThreshold = scored;\n  const prePos0 = scored.find((s) => s.position === 0 && !isAllCaps(s.text));\n  if (prePos0) {\n    const nearbyAllCaps = scored.filter(\n      (s) => isAllCaps(s.text) && s.position >= 1 && s.position <= 2 && s.origin === \"single\"\n    );\n    const pos0Embedding = rawScored.find((r) => r.text === prePos0.text)?.embedding;\n\n    // Method 1: embedding similarity (works for related languages)\n    if (pos0Embedding && nearbyAllCaps.length > 0) {\n      translationCandidates = nearbyAllCaps.filter((cap) => {\n        const capEmbedding = rawScored.find((r) => r.text === cap.text)?.embedding;\n        if (!capEmbedding) return false;\n        return cosineSimilarity(pos0Embedding, capEmbedding) > 0.4;\n      });\n    }\n\n    // Method 2: layout-based detection (cross-lingual fallback).\n    // When embedding similarity is insufficient (e.g. Polish ↔ Korean romanization),\n    // detect bilingual layout by position and word overlap:\n    // mixed-case ≥2 words at pos 0 + ALL_CAPS ≥2 words at pos 1-2 with no shared words.\n    if (translationCandidates.length === 0 && wordCount(prePos0.text) >= 2) {\n      const pos0Words = new Set(\n        prePos0.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2)\n      );\n      translationCandidates = nearbyAllCaps.filter((cap) => {\n        if (wordCount(cap.text) < 2) return false;\n        const capWords = cap.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2);\n        return !capWords.some((w) => pos0Words.has(w));\n      });\n    }\n\n    if (translationCandidates.length > 0) {\n      // Suppress standalone translations and any multi-line joins that embed the translation\n      // as a suffix or substring (e.g. \"Smażona zielona fasolka GREEN BEANS BORKEUM\" ends with\n      // the translation; \"Title GREEN BEANS BORKEUM 그린빈\" includes it as a substring).\n      scoredForThreshold = scored.filter((s) => {\n        const sLower = s.text.toLowerCase();\n        return !translationCandidates.some((t) => {\n          const tLower = t.text.toLowerCase();\n          return sLower.startsWith(tLower) ||\n                 sLower.endsWith(\" \" + tLower) ||\n                 sLower.includes(\" \" + tLower);\n        });\n      });\n    }\n  }\n\n  // Fix 2: If the structural heading was identified as a bilingual translation, reassign it.\n  // This prevents the translation's ALL_CAPS bonus from inflating the threshold and ensures\n  // the fallback path in scored also uses the correct heading.\n  if (\n    translationCandidates.length > 0 &&\n    firstStructuralHeading &&\n    translationCandidates.some((t) => t.text === firstStructuralHeading!.text)\n  ) {\n    const nonTranslationStructural = structuralCandidates.filter(\n      (sc) => !translationCandidates.some((t) => t.text === sc.text)\n    );\n    const newHeading = nonTranslationStructural.length > 0\n      ? nonTranslationStructural.reduce((a, b) => a.rawScore > b.rawScore ? a : b)\n      : undefined;\n\n    // Patch scored array: remove old structural bonus, apply new one\n    for (const s of scored) {\n      if (s.text === firstStructuralHeading.text) {\n        s.score -= 0.10;\n        s.baseScore -= 0.10;\n      }\n      if (newHeading && s.text === newHeading.text) {\n        s.score += 0.10;\n        s.baseScore += 0.10;\n      }\n    }\n    // Update reference for downstream prefix-removal logic\n    firstStructuralHeading = newHeading ?? undefined;\n  }\n\n  // Use thresholdScore (excludes structural bonus) so the structural bonus doesn't inflate\n  // the threshold and block equally-valid headings on multi-recipe pages.\n  const bestThresholdScore = Math.max(...scoredForThreshold.map((s) => s.thresholdScore));\n  const threshold = Math.max(0.08, bestThresholdScore * 0.7);\n\n  // Filter candidates above threshold\n  let selected = scoredForThreshold.filter((s) => s.score >= threshold);\n\n  // Empty-pool fallback: when threshold filtering discards every candidate,\n  // the hard filters' structural verdict should not be overruled by weak\n  // embedding differentiation. Return the best positional candidate.\n  if (selected.length === 0 && scored.length > 0) {\n    const fallback = scored\n      .slice()\n      .sort((a, b) => a.position - b.position || b.score - a.score);\n    selected = [fallback[0]];\n  }\n\n  // Remove word-boundary prefixes of firstStructuralHeading when the heading itself survived\n  // the threshold. Cases:\n  //   ARAYES case:  firstStructuralHeading = \"ARAYES SHRAK\" (2-word join qualifies; \"ARAYES\"\n  //     alone = 1 word, so it never qualified). Filter removes \"ARAYES\" so dedup keeps the join.\n  //   SAFFRON case: baseHeading was the partial line; continuation logic above upgraded\n  //     firstStructuralHeading to the full join. Filter removes the partial so dedup keeps join.\n  // Safety: only fires when the complete heading itself is in selected (passed the threshold).\n  if (firstStructuralHeading && selected.some((s) => s.text === firstStructuralHeading.text)) {\n    const fshLower = firstStructuralHeading.text.toLowerCase();\n    selected = selected.filter((s) => {\n      if (s.text === firstStructuralHeading.text) return true;\n      const sLower = s.text.toLowerCase();\n      // Remove s if it is a space-delimited prefix of the structural heading\n      return !fshLower.startsWith(sLower + \" \");\n    });\n  }\n\n  // Protect continuation joins: when a multi-line join (2-line or 3-line) survived the threshold\n  // and its second part starts with a continuation character, remove the single-line prefix/suffix\n  // so the dedup \"shorter wins\" rule doesn't destroy the complete join.\n  // Note: the pre-merge step above already handles the common Baked Eggs case (&/continuation\n  // on next line) by turning it into a single candidate — this block covers the rarer case where\n  // a continuation-character join was generated as a 2-line/3-line candidate and the prefix\n  // single also survived threshold independently (e.g. from a different code path or OCR layout).\n  // Safety: only fires for joins whose continuation starts with /&+:( — digit continuations\n  // like \"Pierogi Ruskie 200g mąki\" are NOT protected, so dedup correctly keeps the shorter form.\n  const survivingJoins = selected.filter((s) => s.origin === \"2-line\" || s.origin === \"3-line\");\n  if (survivingJoins.length > 0) {\n    selected = selected.filter((s) => {\n      if (s.origin !== \"single\") return true;\n      const sLower = s.text.toLowerCase();\n      // Remove PREFIX singles whose continuation join also survived\n      const isPrefixOfJoin = survivingJoins.some((j) => {\n        const jLower = j.text.toLowerCase();\n        if (!jLower.startsWith(sLower + \" \")) return false;\n        const remainder = jLower.slice(sLower.length + 1);\n        return /^[/&+:(]/.test(remainder);\n      });\n      if (isPrefixOfJoin) return false;\n      // Remove SUFFIX singles (e.g. \"& Coriander\") whose parent join also survived\n      const isSuffixOfJoin = survivingJoins.some((j) => {\n        const jLower = j.text.toLowerCase();\n        if (!jLower.endsWith(\" \" + sLower)) return false;\n        // Only remove if the suffix starts with a continuation character\n        return /^[/&+:(]/.test(sLower);\n      });\n      if (isSuffixOfJoin) return false;\n      return true;\n    });\n  }\n\n  // Pre-dedup: remove sub-section headers that are substrings of other surviving candidates.\n  // A sub-section header is an ALL_CAPS candidate followed by ingredient-like lines in the source.\n  // Example: \"CHLEBEK\" (bread section header, followed by \"500 g mąki\") is a substring of\n  // \"CHLEBEK Z WARZYWAMI I BOCZKIEM\" (the real title). Without this filter, dedup kills the title.\n  selected = selected.filter((candidate) => {\n    if (!isAllCaps(candidate.text)) return true;\n    // Check if this candidate is immediately followed by ingredient-like content\n    const nextSourceLines = lines.slice(candidate.position + 1, candidate.position + 2);\n    const followedByIngredients = nextSourceLines.some(\n      (l) => looksLikeIngredient(l.trim()) || startsWithNumber(l.trim())\n    );\n    if (!followedByIngredients) return true;\n    // Only remove if a longer candidate contains this one as a substring\n    const candidateLower = candidate.text.toLowerCase();\n    const hasLongerParent = rawScored.some(\n      (other) =>\n        other.text !== candidate.text &&\n        other.text.length > candidate.text.length &&\n        other.text.toLowerCase().includes(candidateLower)\n    );\n    return !hasLongerParent;\n  });\n\n  // Protect multi-line joins from being destroyed by their own component singles.\n  // When \"Lamb Stew\" (2-line join) survives AND both \"Lamb\" and \"Stew\" (singles) also survive,\n  // the join is the intended title — remove the singles.\n  const joinsToProtect = selected.filter((s) => s.origin === \"2-line\" || s.origin === \"3-line\");\n  if (joinsToProtect.length > 0) {\n    const singlesToRemove = new Set<string>();\n    for (const join of joinsToProtect) {\n      const joinWords = join.text.split(/\\s+/);\n      const componentSingles = selected.filter(\n        (s) => s.origin === \"single\" && joinWords.some((w) => s.text.toLowerCase() === w.toLowerCase())\n      );\n      if (componentSingles.length >= Math.min(joinWords.length, 2)) {\n        componentSingles.forEach((s) => singlesToRemove.add(s.text));\n      }\n    }\n    if (singlesToRemove.size > 0) {","numLines":200,"startLine":649,"totalLines":989}}}
