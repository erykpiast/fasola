{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QDhUMjtWdfr2SW3zTfm7jy","type":"tool_result","content":"<persisted-output>\nOutput too large (57.3KB). Full output saved to: /Users/eryk.napierala/.claude/projects/-Users-eryk-napierala-Projects-fasola/a5bfc1c9-4aac-4af0-806b-8a2590b8aad5/tool-results/toolu_01QDhUMjtWdfr2SW3zTfm7jy.txt\n\nPreview (first 2KB):\n     1→     1→/**\n     2→     2→ * Title Extraction\n     3→     3→ * Extracts potential recipe title from OCR text using heuristics or semantic embeddings\n     4→     4→ */\n     5→     5→\n     6→     6→import { cosineSimilarity } from \"./embeddings\";\n     7→     7→\n     8→     8→export type EmbedFn = (text: string) => Promise<Array<number>>;\n     9→     9→\n    10→    10→const TITLE_REFERENCE =\n    11→    11→  \"recipe name, dish title, name of the food, nazwa przepisu, nazwa dania\";\n    12→    12→const HEADER_REFERENCE =\n    13→    13→  \"ingredients list, cooking directions, section heading, składniki, przygotowanie, sposób wykonania\";\n    14→    14→const NOISE_REFERENCE =\n    15→    15→  \"page number, table of contents, book footer, garbled text\";\n    16→    16→\n    17→    17→/**\n    18→    18→ * Measurement units commonly found in ingredient lists\n    19→    19→ */\n    20→    20→const MEASUREMENT_PATTERNS = [\n    21→    21→  // English\n    22→    22→  \"cup\",\n    23→    23→  \"cups\",\n    24→    24→  \"tbsp\",\n    25→    25→  \"tsp\",\n    26→    26→  \"tablespoon\",\n    27→    27→  \"teaspoon\",\n    28→    28→  // \"oz\" and \"lb\" are matched with word boundaries in looksLikeIngredient\n    29→    29→  // to avoid false positives (\"oz\" in \"mozzarella\", \"lb\" in \"albacore\")\n    30→    30→  \"gram\",\n    31→    31→  \"grams\",\n    32→    32→  \"kg\",\n    33→    33→  \"ml\",\n    34→    34→  \"liter\",\n    35→    35→  \"pinch\",\n    36→    36→  \"dash\",\n    37→    37→  \"handful\",\n    38→    38→  // Polish\n    39→    39→  \"łyżka\", \"łyżki\", \"łyżek\",           // tablespoon(s)\n    40→    40→  \"łyżeczka\", \"łyżeczki\", \"łyżeczek\",   // teaspoon(s)\n    41→    41→  \"szklanka\", \"szklanki\", \"szklanek\",    // cup(s)\n    42→    42→  \"szczypta\",                            // pinch\n    43→    43→  \"garść\",                               // handful\n    44→    44→  \"opakowanie\", \"opakowania\",            // package(s)\n    45→    45→  \"plasterek\", \"plasterki\",             // slice(s)\n    46→    46→];\n    47→    47→\n...\n</persisted-output>"}]},"parent_tool_use_id":null,"session_id":"a5bfc1c9-4aac-4af0-806b-8a2590b8aad5","uuid":"47a8c2c5-c74b-4827-abd2-83dcdc67b1b1","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/.claude/projects/-Users-eryk-napierala-Projects-fasola/a5bfc1c9-4aac-4af0-806b-8a2590b8aad5/tool-results/toolu_017U3eFgVJVGEZ2bWz1p2beJ.txt","content":"     1→/**\n     2→ * Title Extraction\n     3→ * Extracts potential recipe title from OCR text using heuristics or semantic embeddings\n     4→ */\n     5→\n     6→import { cosineSimilarity } from \"./embeddings\";\n     7→\n     8→export type EmbedFn = (text: string) => Promise<Array<number>>;\n     9→\n    10→const TITLE_REFERENCE =\n    11→  \"recipe name, dish title, name of the food, nazwa przepisu, nazwa dania\";\n    12→const HEADER_REFERENCE =\n    13→  \"ingredients list, cooking directions, section heading, składniki, przygotowanie, sposób wykonania\";\n    14→const NOISE_REFERENCE =\n    15→  \"page number, table of contents, book footer, garbled text\";\n    16→\n    17→/**\n    18→ * Measurement units commonly found in ingredient lists\n    19→ */\n    20→const MEASUREMENT_PATTERNS = [\n    21→  // English\n    22→  \"cup\",\n    23→  \"cups\",\n    24→  \"tbsp\",\n    25→  \"tsp\",\n    26→  \"tablespoon\",\n    27→  \"teaspoon\",\n    28→  // \"oz\" and \"lb\" are matched with word boundaries in looksLikeIngredient\n    29→  // to avoid false positives (\"oz\" in \"mozzarella\", \"lb\" in \"albacore\")\n    30→  \"gram\",\n    31→  \"grams\",\n    32→  \"kg\",\n    33→  \"ml\",\n    34→  \"liter\",\n    35→  \"pinch\",\n    36→  \"dash\",\n    37→  \"handful\",\n    38→  // Polish\n    39→  \"łyżka\", \"łyżki\", \"łyżek\",           // tablespoon(s)\n    40→  \"łyżeczka\", \"łyżeczki\", \"łyżeczek\",   // teaspoon(s)\n    41→  \"szklanka\", \"szklanki\", \"szklanek\",    // cup(s)\n    42→  \"szczypta\",                            // pinch\n    43→  \"garść\",                               // handful\n    44→  \"opakowanie\", \"opakowania\",            // package(s)\n    45→  \"plasterek\", \"plasterki\",             // slice(s)\n    46→];\n    47→\n    48→/**\n    49→ * Patterns that identify recipe metadata lines (not titles)\n    50→ */\n    51→const METADATA_PATTERNS = [\n    52→  /^(SERVES?|MAKES?|YIELDS?)\\b/i,\n    53→  /^(PREP(ARATION)?|COOK(ING)?|PROOF|RISING|FERMENTATION|REST(ING)?)\\s*(AND\\s*)?(COOK(ING)?)?\\s*TIME/i,\n    54→  /^SAMPLE\\s+SCHEDULE\\b/i,\n    55→  /^BULK\\s+FERMENTATION\\b/i,\n    56→  /^(THIS\\s+RECIPE\\s+)?MAKES\\b/i,\n    57→  // Polish serving-size patterns: \"NA 3 PAPRYKI\", \"NA OKOŁO 1 KG\", \"DLA 4 OSÓB\"\n    58→  /^NA\\s+(\\d|OKOŁO)\\b/i,\n    59→  /^DLA\\s+\\d/i,\n    60→  // OCR-resilient: \"DLA\" + any token + serving-unit word (handles DLA & OSOB, DLA § OSOB, etc.)\n    61→  /^DLA\\s+\\S+\\s+OSOB/i,\n    62→  // OCR-resilient: \"DLA\" + single non-alphanumeric char (common digit→symbol OCR error)\n    63→  /^DLA\\s+[^a-zA-Z0-9\\s]\\s/i,\n    64→  // Time-unit metadata: any line containing \"N MIN\" or \"N GODZ\" is prep/cook/rest time,\n    65→  // regardless of OCR-corrupted prefix (catches PRZYGOTOWANTE, GOTOMANTE, etc.)\n    66→  /\\b\\d+\\s*MIN\\b/i,\n    67→  /\\b\\d+\\s*GODZ/i,\n    68→  // Season/category indicators\n    69→  /^SEZON\\s*:/i,\n    70→  /^KATEGORIA\\s*:/i,\n    71→  /^RODZAJ\\s*:/i,\n    72→  /^PORCJI\\s*:/i,       // Polish serving count\n    73→  /^PORTIONS?\\s*:/i,    // English serving count\n    74→  /^CZ[ĘE]Ś[ĆC]\\s*\\d/i,   // CZĘŚĆ 1: ... (Polish \"Part 1:\")\n    75→  /^PART\\s+\\d/i,             // PART 1: ... (English)\n    76→];\n    77→\n    78→/**\n    79→ * Single-word non-title words — standalone OCR fragments unlikely to be recipe titles\n    80→ */\n    81→const NON_TITLE_WORDS = new Set([\n    82→  \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"are\", \"was\",\n    83→  \"has\", \"his\", \"her\", \"its\", \"our\", \"who\", \"how\", \"may\", \"new\", \"now\",\n    84→  \"old\", \"see\", \"way\", \"did\", \"get\", \"let\", \"say\", \"she\", \"too\", \"use\",\n    85→  \"buns\", \"with\",\n    86→]);\n    87→\n    88→function looksLikeIngredient(line: string): boolean {\n    89→  const lowerLine = line.toLowerCase();\n    90→  if (MEASUREMENT_PATTERNS.some((pattern) => lowerLine.includes(pattern))) return true;\n    91→  // Compact metric: \"100g\", \"50ml\", \"250g\" — digit immediately followed by g/ml/kg\n    92→  if (/\\b\\d+\\s*(?:g|ml|kg)\\b/i.test(line)) return true;\n    93→  // \"to taste\" / \"do smaku\" — qualitative ingredient with no unit\n    94→  if (/\\bto taste\\b/i.test(line) || /\\bdo smaku\\b/i.test(line)) return true;\n    95→  return false;\n    96→}\n    97→\n    98→function startsWithNumber(line: string): boolean {\n    99→  // Match lines starting with a digit, or bullet-then-digit (e.g., \"- 2 jajka\")\n   100→  return /^\\s*(?:[-•*]\\s*)?\\d/.test(line);\n   101→}\n   102→\n   103→function stripDiacritics(text: string): string {\n   104→  return text.normalize(\"NFKD\").replace(/[\\u0300-\\u036f]/g, \"\");\n   105→}\n   106→\n   107→/**\n   108→ * Known recipe section labels — these are structural headers, not recipe titles.\n   109→ * Matched case-insensitively after trimming, stripping trailing punctuation, and stripping diacritics.\n   110→ * Polish entries are stored without diacritics for OCR resilience (e.g. \"SKLADNIKI\" matches \"składniki\").\n   111→ */\n   112→const SECTION_LABELS = new Set([\n   113→  // English\n   114→  \"ingredients\", \"directions\", \"instructions\", \"method\", \"preparation\",\n   115→  \"steps\", \"notes\", \"tip\", \"tips\", \"variations\", \"variation\",\n   116→  \"garnish\", \"topping\", \"toppings\", \"frosting\", \"filling\",\n   117→  \"serving suggestion\", \"serving suggestions\", \"serving\",\n   118→  \"glaze\", \"for the sauce\", \"for the filling\", \"for the dough\",\n   119→  \"for the topping\", \"for the glaze\", \"for the pasta dough\",\n   120→  \"for the pasta\", \"for the crust\",\n   121→  // Polish — recipe section labels (stored without diacritics for OCR resilience)\n   122→  \"skladniki\", \"przygotowanie\", \"sposob przygotowania\", \"sposob wykonania\",\n   123→  \"wykonanie\", \"wskazowki\", \"podpowiedz\", \"warianty\",\n   124→  \"sos\", \"nadzienie\", \"polewa\", \"lukier\", \"ciasto\",  // ciasto = dough/pastry base (recipe-internal section AND chapter label)\n   125→  \"instrukcje\",       // instructions\n   126→  \"uwagi\",            // notes/remarks\n   127→  \"notatki\",          // notes\n   128→  \"podawanie\",        // serving\n   129→  \"przechowywanie\",   // storage\n   130→  // Polish — recipe-book chapter/category labels (food groups, meal types)\n   131→  \"warzywa\",          // vegetables\n   132→  \"mieso\",            // meat (mięso)\n   133→  \"miesa\",            // meats (mięsa)\n   134→  \"ryby\",             // fish\n   135→  \"owoce morza\",      // seafood\n   136→  \"zupy\",             // soups\n   137→  \"salatki\",          // salads (sałatki)\n   138→  \"desery\",           // desserts\n   139→  \"napoje\",           // drinks\n   140→  \"pieczywo\",         // bread/baked goods\n   141→  \"przekaski\",        // appetizers/snacks\n   142→  \"sniadania\",        // breakfasts (śniadania)\n   143→  \"obiady\",           // dinners/lunches\n   144→  \"kolacje\",          // suppers\n   145→  \"makarony\",         // pasta dishes\n   146→  \"kasza\",            // groats/grains\n   147→  \"kasze\",            // groats/grains (plural)\n   148→  \"dania glowne\",     // main courses (dania główne)\n   149→  \"przystawki\",       // starters\n   150→  \"dodatki\",          // side dishes\n   151→  \"przetwory\",        // preserves\n   152→  \"wypieki\",          // baked goods\n   153→  \"ciasta\",           // cakes (plural)\n   154→  \"ciastka\",          // cookies\n   155→  \"torty\",            // layer cakes\n   156→  \"placki\",           // pancakes/flatbreads\n   157→  \"koktajle\",         // cocktails/smoothies\n   158→]);\n   159→\n   160→function isSectionLabel(text: string): boolean {\n   161→  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n   162→  return SECTION_LABELS.has(normalized);\n   163→}\n   164→\n   165→/**\n   166→ * Recipe-internal section labels that should ALWAYS block multi-line joins,\n   167→ * even when the combined word count is ≥ 3.\n   168→ * Category labels (\"zupy\", \"placki\", etc.) are NOT in this set — they can\n   169→ * legitimately start a multi-word recipe title like \"Zupy Zimowe Warzywne\".\n   170→ */\n   171→const ALWAYS_BLOCK_JOIN_LABELS = new Set([\n   172→  \"ingredients\", \"directions\", \"instructions\", \"method\", \"preparation\",\n   173→  \"steps\", \"notes\", \"tip\", \"tips\", \"variations\", \"variation\",\n   174→  \"garnish\", \"topping\", \"toppings\", \"frosting\", \"filling\",\n   175→  \"serving suggestion\", \"serving suggestions\", \"serving\",\n   176→  \"glaze\", \"instrukcje\", \"uwagi\", \"notatki\", \"podawanie\", \"przechowywanie\",\n   177→  \"skladniki\", \"przygotowanie\", \"sposob przygotowania\", \"sposob wykonania\",\n   178→  \"wykonanie\", \"wskazowki\", \"podpowiedz\", \"warianty\",\n   179→  \"sos\", \"nadzienie\", \"polewa\", \"lukier\", \"ciasto\",\n   180→]);\n   181→\n   182→function isAlwaysBlockJoinLabel(text: string): boolean {\n   183→  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n   184→  return ALWAYS_BLOCK_JOIN_LABELS.has(normalized);\n   185→}\n   186→\n   187→function isAllCaps(line: string): boolean {\n   188→  const letters = line.replace(/[^a-zA-Z]/g, \"\");\n   189→  return letters.length > 0 && letters === letters.toUpperCase();\n   190→}\n   191→\n   192→function looksLikeMetadata(text: string): boolean {\n   193→  return METADATA_PATTERNS.some((pattern) => pattern.test(text.trim()));\n   194→}\n   195→\n   196→function isLikelyGarbled(text: string): boolean {\n   197→  const letters = text.replace(/[^a-zA-Z]/g, \"\");\n   198→  if (letters.length < 2) return true;\n   199→\n   200→  // Check vowel ratio — English/Polish text typically has 30–50% vowels\n   201→  const vowels = letters.replace(/[^aeiouAEIOUyYąęóĄĘÓ]/g, \"\").length;\n   202→  const vowelRatio = vowels / letters.length;\n   203→  if (vowelRatio < 0.10 || vowelRatio > 0.85) return true;\n   204→\n   205→  // Single orphaned word ≤3 letters that isn't a common word\n   206→  const words = text.trim().split(/\\s+/);\n   207→  const COMMON_SHORT = new Set([\n   208→    \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"had\", \"her\",\n   209→    \"was\", \"one\", \"our\", \"out\", \"are\", \"has\", \"his\", \"how\", \"its\", \"may\",\n   210→    \"new\", \"now\", \"old\", \"see\", \"way\", \"who\", \"did\", \"get\", \"let\", \"say\",\n   211→    \"she\", \"too\", \"use\",\n   212→  ]);\n   213→  // Count all Unicode letters (not just ASCII) so Polish words like \"Żur\" (3 letters) pass\n   214→  const unicodeLetters = text.trim().replace(/[^a-zA-ZąćęłńóśźżĄĆĘŁŃÓŚŹŻ]/g, \"\");\n   215→  if (words.length === 1 && unicodeLetters.length <= 3 && !COMMON_SHORT.has(text.trim().toLowerCase())) {\n   216→    return true;\n   217→  }\n   218→\n   219→  // Single word with internal lowercase→uppercase transition — OCR noise (e.g., \"UuIw\", \"aBC\")\n   220→  // No recipe title uses this pattern as a standalone single-word candidate.\n   221→  if (words.length === 1 && /[a-z][A-Z]/.test(text.trim())) {\n   222→    return true;\n   223→  }\n   224→\n   225→  // Recipe titles never start with a lowercase letter\n   226→  if (/^[a-z]/.test(text.trim())) {\n   227→    return true;\n   228→  }\n   229→\n   230→  // Mid-text sentence boundary (\". \" followed by a letter) — body text fragment spliced from multiple sentences\n   231→  const trimmed = text.trim();\n   232→  if (/\\.\\s+[a-zA-Z]/.test(trimmed) && !trimmed.endsWith(\")\")) {\n   233→    return true;\n   234→  }\n   235→\n   236→  // Multi-word candidate containing a garbled OCR fragment: a short lowercase word that isn't a known short word\n   237→  if (words.length >= 2) {\n   238→    const commonShort2 = new Set([\n   239→      \"a\", \"i\", \"of\", \"or\", \"to\", \"in\", \"on\", \"is\", \"it\", \"an\",\n   240→      \"as\", \"at\", \"by\", \"do\", \"go\", \"if\", \"no\", \"so\", \"up\", \"we\",\n   241→      \"w\", \"z\",   // Polish prepositions (basic)\n   242→      \"ze\", \"bo\", \"na\", \"ni\", \"po\", \"ku\", \"od\", \"za\", \"co\",  // Polish prepositions (extended)\n   243→    ]);\n   244→    const hasGarbledWord = words.some(\n   245→      (w) =>\n   246→        /^[a-z]/.test(w) &&\n   247→        w.replace(/[^a-z]/g, \"\").length <= 2 &&\n   248→        !commonShort2.has(w.toLowerCase())\n   249→    );\n   250→    if (hasGarbledWord) {\n   251→      return true;\n   252→    }\n   253→  }\n   254→\n   255→  return false;\n   256→}\n   257→\n   258→const COOKING_INSTRUCTION_STARTS = /^(beat|fold|stir|mix|add|pour|bake|cook|cool|remove|place|combine|whisk|knead|roll|spread|brush|slice|chop|dice|mince|drain|rinse|peel|grate|melt|simmer|boil|fry|sauté|saute|roast|grill|broil|steam|let|set|transfer|serve|garnish|arrange|sprinkle|season|preheat|cover|uncover|reduce|bring|toss|cut|trim|shape|form)\\b/i;\n   259→\n   260→// Polish imperative cooking verbs (with OCR-resilient forms — no diacritics required).\n   261→// These cover the most common recipe instruction starters. Includes common OCR-corrupted\n   262→// forms (e.g., \"Smaż\" → \"Smaz\", \"Dodaj\" → \"Dodaj\").\n   263→// Note: only verbs that NEVER start a recipe title. \"Piecz\" (bake) is excluded because\n   264→// \"Pieczeń\" (roast) and \"Pieczarki\" (mushrooms) share the prefix.\n   265→const POLISH_COOKING_INSTRUCTION_STARTS = /^(podawaj|dodaj|dodawaj|sma[zż]|gotuj|odced[zź]|wymieszaj|mieszaj|wlej|nalej|przygotuj|zagotuj|pokr[oó]j|obierz|wrzuc|wrzuć|usma[zż]|podsma[zż]|prze[lł][oó][zż]|zblenduj|ubij|roztrzepaj|rozprowad[zź]|wyrob|zamieszaj|posyp|polej|odstaw|na[lł][oó][zż]|przykryj|odkryj|wstaw|zdejmij|ods[aą]cz|rozgrzej|posiekaj|zetrzyj|wy[lł][oó][zż]|wyjmij|ukr[oó]j|przekr[oó]j|formuj|ugniataj|rozwałkuj)\\b/i;\n   266→\n   267→function looksLikeCookingInstruction(text: string): boolean {\n   268→  const words = text.trim().split(/\\s+/);\n   269→  if (words.length < 4) return false;  // Instructions are multi-word sentences\n   270→  if (COOKING_INSTRUCTION_STARTS.test(text.trim())) return true;\n   271→  if (POLISH_COOKING_INSTRUCTION_STARTS.test(text.trim())) return true;\n   272→  return false;\n   273→}\n   274→\n   275→function passesHardFilters(text: string): boolean {\n   276→  if (text.length < 3 || text.length > 80) return false;\n   277→  if (looksLikeIngredient(text)) return false;\n   278→  if (startsWithNumber(text)) return false;\n   279→  if (looksLikeMetadata(text)) return false;\n   280→  if (isLikelyGarbled(text)) return false;\n   281→  if (looksLikeCookingInstruction(text)) return false;\n   282→  // Pipe-separated lines are book category/chapter headers, not recipe titles\n   283→  if (text.includes(\" | \")) return false;\n   284→  // Trailing page number (e.g. \"VEGETABLE SIDES                         145\")\n   285→  if (/\\s{3,}\\d{1,4}\\s*$/.test(text)) return false;\n   286→  // Slash-separated breadcrumbs (e.g., \"/ Jesien / Zupy\") are navigation, not titles\n   287→  // Only filter when 2+ slashes are present — single-slash lines like\n   288→  // \"TITLE / SUBTITLE\" are legitimate continuation-merged titles\n   289→  if ((text.match(/\\//g) || []).length >= 2) return false;\n   290→  // Bullet-list items (ingredients or instruction steps) are never titles\n   291→  if (/^\\s*[-•*]\\s/.test(text)) return false;\n   292→  // \"For the sauce:\", \"For the filling:\" etc. are sub-section headers\n   293→  if (/^For the\\s+/i.test(text) && /:\\s*$/.test(text)) return false;\n   294→  // Square-bracket category tags (e.g., \"[CLASSIC FALL SOUPS]\")\n   295→  if (/^\\[.*\\]$/.test(text.trim())) return false;\n   296→  // Known recipe section labels are structural headers, not titles\n   297→  if (isSectionLabel(text)) return false;\n   298→  // Single-word non-title fragments\n   299→  const words = text.trim().split(/\\s+/);\n   300→  if (words.length === 1 && NON_TITLE_WORDS.has(text.trim().toLowerCase())) return false;\n   301→  // Lines with ≥8 words are almost certainly body text, not titles.\n   302→  // Exception: multi-title compounds with \" + \", \" : \", or \" & \" separators are allowed.\n   303→  if (words.length >= 8 && !/ [+:&/] /.test(text)) return false;\n   304→  return true;\n   305→}\n   306→\n   307→/**\n   308→ * Detect initial burst of short garbled lines.\n   309→ * Returns the index of the first non-garbled or long line.\n   310→ */\n   311→function findBurstEnd(lines: Array<{ text: string }>): number {\n   312→  let i = 0;\n   313→  while (i < lines.length && lines[i].text.length < 20 && isLikelyGarbled(lines[i].text)) {\n   314→    i++;\n   315→  }\n   316→  // Skip long instruction-like prologues: if 5+ consecutive lines look like cooking instructions,\n   317→  // skip them to find the actual title region.\n   318→  if (i === 0) {\n   319→    let j = 0;\n   320→    while (j < lines.length && looksLikeCookingInstruction(lines[j].text)) {\n   321→      j++;\n   322→    }\n   323→    if (j >= 5) {\n   324→      i = j;\n   325→    }\n   326→  }\n   327→  return i;\n   328→}\n   329→\n   330→function stripParentheticalGloss(text: string): string {\n   331→  // Strip trailing English-gloss parentheticals from ALL_CAPS titles.\n   332→  // e.g. \"PIEROGI RUSKIE (Boiled Dumplings with Potato and Cheese)\" → \"PIEROGI RUSKIE\"\n   333→  // Keep if parenthetical is ALL_CAPS (variation/subtitle in same language).\n   334→  // Keep if both base and paren are mixed-case (both are part of the title).\n   335→  const match = text.match(/^(.+?)\\s*\\(([^)]+)\\)\\s*$/);\n   336→  if (!match) return text;\n   337→  const [, base, paren] = match;\n   338→  if (isAllCaps(paren)) return text;\n   339→  if (!isAllCaps(base) && !isAllCaps(paren)) return text;\n   340→  return base.trim();\n   341→}\n   342→\n   343→function stripPageNumber(text: string): string {\n   344→  // \"34  Berry Jam\" → \"Berry Jam\" (2+ spaces distinguishes from \"2 eggs\")\n   345→  const match = text.match(/^\\d{1,3}\\s{2,}(.+)$/);\n   346→  return match ? match[1] : text;\n   347→}\n   348→\n   349→function wordCount(text: string): number {\n   350→  return text.split(/\\s+/).filter((w) => w.length > 0).length;\n   351→}\n   352→\n   353→/**\n   354→ * Build candidate strings from lines: single lines plus multi-line joins (2-3 consecutive).\n   355→ * Skips initial burst of short garbled lines. Scans all remaining lines. Caps at 25.\n   356→ */\n   357→export type CandidateOrigin = \"single\" | \"2-line\" | \"3-line\";\n   358→\n   359→function buildCandidates(\n   360→  lines: Array<string>\n   361→): Array<{ text: string; position: number; origin: CandidateOrigin }> {\n   362→  const nonEmptyLines: Array<{ text: string; index: number }> = [];\n   363→\n   364→  for (let i = 0; i < lines.length; i++) {\n   365→    const trimmed = lines[i].trim();\n   366→    if (trimmed.length > 0) {\n   367→      nonEmptyLines.push({ text: trimmed, index: i });\n   368→    }\n   369→  }\n   370→\n   371→  const burstEnd = findBurstEnd(nonEmptyLines);\n   372→\n   373→  // Pre-merge consecutive short ALL_CAPS lines (OCR-fragmented headings).\n   374→  // When a sequence of 2+ ALL_CAPS lines each has ≤2 words and ≤25 chars, they are\n   375→  // almost certainly OCR fragments of a single heading. Merge them into one line so\n   376→  // the complete title enters the candidate pool without hitting the 3-line join ceiling.\n   377→  const capsCoalesced: Array<{ text: string; index: number }> = [];\n   378→  let ci = burstEnd;\n   379→  while (ci < nonEmptyLines.length) {\n   380→    const line = nonEmptyLines[ci];\n   381→    if (\n   382→      isAllCaps(line.text) &&\n   383→      wordCount(line.text) <= 2 &&\n   384→      line.text.length <= 25 &&\n   385→      !isSectionLabel(line.text) &&\n   386→      !looksLikeMetadata(line.text)\n   387→    ) {\n   388→      let merged = line.text;\n   389→      const startIndex = line.index;\n   390→      let j = ci + 1;\n   391→      while (j < nonEmptyLines.length) {\n   392→        const next = nonEmptyLines[j];\n   393→        if (\n   394→          isAllCaps(next.text) &&\n   395→          wordCount(next.text) <= 2 &&\n   396→          next.text.length <= 25 &&\n   397→          !isSectionLabel(next.text) &&\n   398→          !looksLikeMetadata(next.text) &&\n   399→          (merged + \" \" + next.text).length <= 80\n   400→        ) {\n   401→          merged += \" \" + next.text;\n   402→          j++;\n   403→        } else {\n   404→          break;\n   405→        }\n   406→      }\n   407→      if (j > ci + 1) {\n   408→        capsCoalesced.push({ text: merged, index: startIndex });\n   409→        ci = j;\n   410→        continue;\n   411→      }\n   412→    }\n   413→    capsCoalesced.push(line);\n   414→    ci++;\n   415→  }\n   416→\n   417→  // Pre-merge continuation lines: a line starting with /&+:( is never a standalone title.\n   418→  // Merge it into the preceding line so the complete title enters the pool as a single candidate,\n   419→  // avoiding the fragile chain of conditions required by the downstream join survival logic.\n   420→  // Limitation: only one continuation line per preceding line is merged. Titles split across\n   421→  // three or more lines with continuation tokens (rare in practice) are not handled here —\n   422→  // the downstream 2-line and 3-line join candidates cover those cases instead.\n   423→  const mergedLines: Array<{ text: string; index: number }> = [];\n   424→  for (let i = 0; i < capsCoalesced.length; i++) {\n   425→    const line = capsCoalesced[i];\n   426→    if (i + 1 < capsCoalesced.length) {\n   427→      const nextText = capsCoalesced[i + 1].text;\n   428→      if (/^[/&+:(]/.test(nextText)) {\n   429→        mergedLines.push({ text: `${line.text} ${nextText}`, index: line.index });\n   430→        i++;\n   431→        continue;\n   432→      }\n   433→    }\n   434→    mergedLines.push(line);\n   435→  }\n   436→\n   437→  const candidates: Array<{ text: string; position: number; origin: CandidateOrigin }> = [];\n   438→  const seen = new Set<string>();\n   439→\n   440→  // Build a set of positions to skip: short ALL_CAPS lines immediately following metadata\n   441→  const metadataContinuationPositions = new Set<number>();\n   442→  for (let i = 0; i < mergedLines.length - 1; i++) {\n   443→    if (looksLikeMetadata(mergedLines[i].text)) {\n   444→      const next = mergedLines[i + 1];\n   445→      if (isAllCaps(next.text) && wordCount(next.text) <= 2 && next.text.length <= 15) {\n   446→        metadataContinuationPositions.add(next.index);\n   447→      }\n   448→    }\n   449→  }\n   450→\n   451→  for (let i = 0; i < mergedLines.length; i++) {\n   452→    const line = mergedLines[i];\n   453→\n   454→    // Skip metadata continuation fragments\n   455→    if (metadataContinuationPositions.has(line.index)) continue;\n   456→\n   457→    // Single line — strip page-number prefixes and parenthetical glosses before scoring\n   458→    const singleText = stripParentheticalGloss(stripPageNumber(line.text));\n   459→    if (passesHardFilters(singleText)) {\n   460→      const norm = singleText.toLowerCase();\n   461→      if (!seen.has(norm)) {\n   462→        seen.add(norm);\n   463→        candidates.push({ text: singleText, position: line.index, origin: \"single\" });\n   464→      }\n   465→    }\n   466→\n   467→    // 2-line join — skip if first line is a section label AND join would be ≤2 words\n   468→    // (a section label followed by modifiers is likely a recipe title, not a category header)\n   469→    if (i + 1 < mergedLines.length) {\n   470→      const joined2 = `${line.text} ${mergedLines[i + 1].text}`;\n   471→      const shouldBlock2 = isSectionLabel(line.text) &&\n   472→        (wordCount(joined2) <= 2 || isAlwaysBlockJoinLabel(line.text));\n   473→      if (!shouldBlock2 && passesHardFilters(joined2)) {\n   474→        const norm = joined2.toLowerCase();\n   475→        if (!seen.has(norm)) {\n   476→          seen.add(norm);\n   477→          candidates.push({ text: joined2, position: line.index, origin: \"2-line\" });\n   478→        }\n   479→      }\n   480→    }\n   481→\n   482→    // 3-line join — skip if first line is a section label AND join would be ≤2 words\n   483→    if (i + 2 < mergedLines.length) {\n   484→      const joined3 = `${line.text} ${mergedLines[i + 1].text} ${mergedLines[i + 2].text}`;\n   485→      const shouldBlock3 = isSectionLabel(line.text) &&\n   486→        (wordCount(joined3) <= 2 || isAlwaysBlockJoinLabel(line.text));\n   487→      if (!shouldBlock3 && passesHardFilters(joined3)) {\n   488→        const norm = joined3.toLowerCase();\n   489→        if (!seen.has(norm)) {\n   490→          seen.add(norm);\n   491→          candidates.push({ text: joined3, position: line.index, origin: \"3-line\" });\n   492→        }\n   493→      }\n   494→    }\n   495→  }\n   496→\n   497→  // Pre-filter to 25 before embedding calls: prefer ALL_CAPS and short candidates.\n   498→  // Position-based scoring handles final ranking.\n   499→  if (candidates.length > 25) {\n   500→    const prioritized = candidates.slice().sort((a, b) => {\n   501→      const aAllCaps = isAllCaps(a.text) ? 0 : 1;\n   502→      const bAllCaps = isAllCaps(b.text) ? 0 : 1;\n   503→      if (aAllCaps !== bAllCaps) return aAllCaps - bAllCaps;\n   504→      const aShort = wordCount(a.text) <= 5 ? 0 : 1;\n   505→      const bShort = wordCount(b.text) <= 5 ? 0 : 1;\n   506→      return aShort - bShort;\n   507→    });\n   508→    return prioritized.slice(0, 25);\n   509→  }\n   510→\n   511→  return candidates;\n   512→}\n   513→\n   514→// Module-level cache for reference embeddings\n   515→let cachedTitleRefEmbedding: Array<number> | null = null;\n   516→let cachedHeaderRefEmbedding: Array<number> | null = null;\n   517→let cachedNoiseRefEmbedding: Array<number> | null = null;\n   518→\n   519→export function _resetEmbeddingCacheForTests(): void {\n   520→  cachedTitleRefEmbedding = null;\n   521→  cachedHeaderRefEmbedding = null;\n   522→  cachedNoiseRefEmbedding = null;\n   523→}\n   524→\n   525→export async function extractTitleWithEmbeddings(\n   526→  text: string,\n   527→  embed: EmbedFn\n   528→): Promise<string | undefined> {\n   529→  if (!text || text.trim().length === 0) {\n   530→    return undefined;\n   531→  }\n   532→\n   533→  const lines = text.split(\"\\n\");\n   534→  const candidates = buildCandidates(lines);\n   535→\n   536→  if (candidates.length === 0) {\n   537→    return undefined;\n   538→  }\n   539→\n   540→  // Cache reference embeddings\n   541→  if (!cachedTitleRefEmbedding) {\n   542→    cachedTitleRefEmbedding = await embed(TITLE_REFERENCE);\n   543→  }\n   544→  if (!cachedHeaderRefEmbedding) {\n   545→    cachedHeaderRefEmbedding = await embed(HEADER_REFERENCE);\n   546→  }\n   547→  if (!cachedNoiseRefEmbedding) {\n   548→    cachedNoiseRefEmbedding = await embed(NOISE_REFERENCE);\n   549→  }\n   550→\n   551→  // Find ALL_CAPS candidates with ≥2 words where every significant word has ≥4 alpha letters.\n   552→  // Insignificant tokens (≤1 alpha letter: \"/\", \"&\", \"+\", \":\", \"D)\", etc.) are filtered before\n   553→  // the check so that multi-line joins with continuation punctuation still qualify.\n   554→  const isStructuralHeading = (c: { text: string }): boolean => {\n   555→    if (!isAllCaps(c.text) || wordCount(c.text) < 2) return false;\n   556→    const sigWords = c.text.trim().split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length > 1);\n   557→    return sigWords.length >= 2 && sigWords.every((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   558→  };\n   559→\n   560→  // Pass 1: compute rawScore for all candidates (embedding quality signal)\n   561→  const rawScored: Array<{ text: string; position: number; origin: CandidateOrigin; rawScore: number; embedding: Array<number> }> = [];\n   562→  for (const candidate of candidates) {\n   563→    const embedding = await embed(candidate.text);\n   564→    const titleSim = cosineSimilarity(embedding, cachedTitleRefEmbedding);\n   565→    const headerSim = cosineSimilarity(embedding, cachedHeaderRefEmbedding);\n   566→    const noiseSim = cosineSimilarity(embedding, cachedNoiseRefEmbedding);\n   567→    const rawScore = titleSim - Math.max(headerSim, noiseSim);\n   568→    rawScored.push({ text: candidate.text, position: candidate.position, origin: candidate.origin, rawScore, embedding });\n   569→  }\n   570→\n   571→  // Select baseHeading by embedding quality (rawScore), not position.\n   572→  // This prevents OCR-garbled fragments from claiming the structural heading slot.\n   573→  const structuralCandidates = rawScored.filter((s) => isStructuralHeading(s));\n   574→\n   575→  // Penalize structural headings with truncated OCR words:\n   576→  // if \"FRON\" appears and another heading has \"SAFFRON\", \"FRON\" is likely garbled.\n   577→  for (const sc of structuralCandidates) {\n   578→    const sigWords = sc.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   579→    for (const other of structuralCandidates) {\n   580→      if (other === sc) continue;\n   581→      const otherSigWords = other.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   582→      const hasTruncation = sigWords.some((w) =>\n   583→        otherSigWords.some((ow) => ow !== w && ow.length > w.length && ow.endsWith(w))\n   584→      );\n   585→      if (hasTruncation) {\n   586→        sc.rawScore = -1.0;  // Hard disqualification — truncated OCR artifact\n   587→        break;\n   588→      }\n   589→    }\n   590→  }\n   591→\n   592→  const bestStructural = structuralCandidates.length > 0\n   593→    ? structuralCandidates.reduce((a, b) => {\n   594→        const scoreDiff = a.rawScore - b.rawScore;\n   595→        if (Math.abs(scoreDiff) > 0.03) return scoreDiff > 0 ? a : b;\n   596→        // Tiebreak: single-line origin beats multi-line joins (avoids conflating two separate headings)\n   597→        if (a.origin === \"single\" && b.origin !== \"single\") return a;\n   598→        if (b.origin === \"single\" && a.origin !== \"single\") return b;\n   599→        // Tiebreak: more words (more specific) → better\n   600→        const wcDiff = wordCount(b.text) - wordCount(a.text);\n   601→        if (wcDiff !== 0) return wcDiff > 0 ? b : a;\n   602→        // Tiebreak: earlier position → better\n   603→        return a.position < b.position ? a : b;\n   604→      })\n   605→    : null;\n   606→  const baseHeading = bestStructural ?? undefined;\n   607→\n   608→  // When the best structural heading has a continuation on the next line introduced by a\n   609→  // punctuation token (/, &, +, :, or parenthesis), prefer the longer 2-line join as the\n   610→  // complete heading. E.g. \"SAFFRON WHEAT BUNS WITH QUARK\" + \"/ COTTAGE CHEESE (VARIATION D)\".\n   611→  // Guard: the remainder after the prefix must start with a continuation character to avoid\n   612→  // merging two separate consecutive recipe titles (FINNISH MILK FLATBREADS stays separate\n   613→  // from FINNISH POTATO FLATBREADS because \"FINNISH\" does not start with a continuation token).\n   614→  let firstStructuralHeading = baseHeading && (\n   615→    rawScored.find((c) => {\n   616→      if (!isStructuralHeading(c)) return false;\n   617→      const hLower = baseHeading.text.toLowerCase();\n   618→      const cLower = c.text.toLowerCase();\n   619→      return cLower.startsWith(hLower + \" \") && /^[/&+:(]/.test(cLower.slice(hLower.length + 1));\n   620→    }) ?? baseHeading\n   621→  );\n   622→\n   623→  // Pass 2: apply bonuses\n   624→  const scored: Array<{ text: string; position: number; origin: CandidateOrigin; score: number; rawScore: number; baseScore: number; thresholdScore: number }> = rawScored.map((rs) => {\n   625→    // Position factor: multiplicative tiebreaker — amplifies existing signal, doesn't replace it\n   626→    const relativePosition = rs.position / lines.length;\n   627→    const positionFactor = relativePosition < 0.5\n   628→      ? 1.0 + 0.12 * (1 - relativePosition * 2)\n   629→      : 1.0;\n   630→\n   631→    // ALL_CAPS bonus: recipe books use ALL_CAPS for titles and section headings.\n   632→    // Single-word ALL_CAPS terms are overwhelmingly section/category labels, not recipe titles;\n   633→    // real recipe titles in ALL_CAPS are almost always multi-word. Reduce the bonus for single words.\n   634→    const allCapsBonus = isAllCaps(rs.text) && rs.text.replace(/[^a-zA-Z]/g, \"\").length >= 4\n   635→      ? (wordCount(rs.text) >= 2 ? 0.08 : 0.03)\n   636→      : 0;\n   637→\n   638→    // Structural heading bonus: best ALL_CAPS heading (or its continuation join) is almost always the recipe title\n   639→    const structuralBonus = firstStructuralHeading && rs.text === firstStructuralHeading.text ? 0.10 : 0;\n   640→\n   641→    // thresholdScore excludes structural bonus so the bonus doesn't inflate the threshold\n   642→    // and prevent equally-valid structural headings from passing on multi-recipe pages.\n   643→    const thresholdScore = rs.rawScore + allCapsBonus;\n   644→    // baseScore excludes position factor — used for diagnostics and ranking\n   645→    const baseScore = rs.rawScore + allCapsBonus + structuralBonus;\n   646→    const score = rs.rawScore * positionFactor + allCapsBonus + structuralBonus;\n   647→    return { text: rs.text, position: rs.position, origin: rs.origin, score, rawScore: rs.rawScore, baseScore, thresholdScore };\n   648→  });\n   649→\n   650→  if (scored.length === 0) {\n   651→    return undefined;\n   652→  }\n   653→\n   654→  // --- Pre-threshold bilingual title detection ---\n   655→  // When a mixed-case candidate at position 0 is followed by an ALL_CAPS candidate\n   656→  // at position ≤ 2 that is semantically similar to it, this is a bilingual recipe\n   657→  // page (e.g., Polish title + ALL_CAPS Korean romanization). Suppress confirmed\n   658→  // translation candidates before computing threshold so their bonuses don't inflate\n   659→  // the threshold beyond the mixed-case title's reach.\n   660→  // Note: we check position ≤ 2 (local proximity), not global ALL_CAPS count, so\n   661→  // section headers later in the document (SKŁADNIKI, WARZYWA, etc.) are irrelevant.\n   662→  let translationCandidates: typeof scored = [];\n   663→  let scoredForThreshold = scored;\n   664→  const prePos0 = scored.find((s) => s.position === 0 && !isAllCaps(s.text));\n   665→  if (prePos0) {\n   666→    const nearbyAllCaps = scored.filter(\n   667→      (s) => isAllCaps(s.text) && s.position >= 1 && s.position <= 2 && s.origin === \"single\"\n   668→    );\n   669→    const pos0Embedding = rawScored.find((r) => r.text === prePos0.text)?.embedding;\n   670→\n   671→    // Method 1: embedding similarity (works for related languages)\n   672→    if (pos0Embedding && nearbyAllCaps.length > 0) {\n   673→      translationCandidates = nearbyAllCaps.filter((cap) => {\n   674→        const capEmbedding = rawScored.find((r) => r.text === cap.text)?.embedding;\n   675→        if (!capEmbedding) return false;\n   676→        return cosineSimilarity(pos0Embedding, capEmbedding) > 0.4;\n   677→      });\n   678→    }\n   679→\n   680→    // Method 2: layout-based detection (cross-lingual fallback).\n   681→    // When embedding similarity is insufficient (e.g. Polish ↔ Korean romanization),\n   682→    // detect bilingual layout by position and word overlap:\n   683→    // mixed-case ≥2 words at pos 0 + ALL_CAPS ≥2 words at pos 1-2 with no shared words.\n   684→    if (translationCandidates.length === 0 && wordCount(prePos0.text) >= 2) {\n   685→      const pos0Words = new Set(\n   686→        prePos0.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2)\n   687→      );\n   688→      translationCandidates = nearbyAllCaps.filter((cap) => {\n   689→        if (wordCount(cap.text) < 2) return false;\n   690→        const capWords = cap.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2);\n   691→        return !capWords.some((w) => pos0Words.has(w));\n   692→      });\n   693→    }\n   694→\n   695→    if (translationCandidates.length > 0) {\n   696→      // Suppress standalone translations and any multi-line joins that embed the translation\n   697→      // as a suffix or substring (e.g. \"Smażona zielona fasolka GREEN BEANS BORKEUM\" ends with\n   698→      // the translation; \"Title GREEN BEANS BORKEUM 그린빈\" includes it as a substring).\n   699→      scoredForThreshold = scored.filter((s) => {\n   700→        const sLower = s.text.toLowerCase();\n   701→        return !translationCandidates.some((t) => {\n   702→          const tLower = t.text.toLowerCase();\n   703→          return sLower.startsWith(tLower) ||\n   704→                 sLower.endsWith(\" \" + tLower) ||\n   705→                 sLower.includes(\" \" + tLower);\n   706→        });\n   707→      });\n   708→    }\n   709→  }\n   710→\n   711→  // Fix 2: If the structural heading was identified as a bilingual translation, reassign it.\n   712→  // This prevents the translation's ALL_CAPS bonus from inflating the threshold and ensures\n   713→  // the fallback path in scored also uses the correct heading.\n   714→  if (\n   715→    translationCandidates.length > 0 &&\n   716→    firstStructuralHeading &&\n   717→    translationCandidates.some((t) => t.text === firstStructuralHeading!.text)\n   718→  ) {\n   719→    const nonTranslationStructural = structuralCandidates.filter(\n   720→      (sc) => !translationCandidates.some((t) => t.text === sc.text)\n   721→    );\n   722→    const newHeading = nonTranslationStructural.length > 0\n   723→      ? nonTranslationStructural.reduce((a, b) => a.rawScore > b.rawScore ? a : b)\n   724→      : undefined;\n   725→\n   726→    // Patch scored array: remove old structural bonus, apply new one\n   727→    for (const s of scored) {\n   728→      if (s.text === firstStructuralHeading.text) {\n   729→        s.score -= 0.10;\n   730→        s.baseScore -= 0.10;\n   731→      }\n   732→      if (newHeading && s.text === newHeading.text) {\n   733→        s.score += 0.10;\n   734→        s.baseScore += 0.10;\n   735→      }\n   736→    }\n   737→    // Update reference for downstream prefix-removal logic\n   738→    firstStructuralHeading = newHeading ?? undefined;\n   739→  }\n   740→\n   741→  // Use thresholdScore (excludes structural bonus) so the structural bonus doesn't inflate\n   742→  // the threshold and block equally-valid headings on multi-recipe pages.\n   743→  const bestThresholdScore = Math.max(...scoredForThreshold.map((s) => s.thresholdScore));\n   744→  const threshold = Math.max(0.08, bestThresholdScore * 0.7);\n   745→\n   746→  // Filter candidates above threshold\n   747→  let selected = scoredForThreshold.filter((s) => s.score >= threshold);\n   748→\n   749→  // Empty-pool fallback: when threshold filtering discards every candidate,\n   750→  // the hard filters' structural verdict should not be overruled by weak\n   751→  // embedding differentiation. Return the best positional candidate.\n   752→  if (selected.length === 0 && scored.length > 0) {\n   753→    const fallback = scored\n   754→      .slice()\n   755→      .sort((a, b) => a.position - b.position || b.score - a.score);\n   756→    selected = [fallback[0]];\n   757→  }\n   758→\n   759→  // Remove word-boundary prefixes of firstStructuralHeading when the heading itself survived\n   760→  // the threshold. Cases:\n   761→  //   ARAYES case:  firstStructuralHeading = \"ARAYES SHRAK\" (2-word join qualifies; \"ARAYES\"\n   762→  //     alone = 1 word, so it never qualified). Filter removes \"ARAYES\" so dedup keeps the join.\n   763→  //   SAFFRON case: baseHeading was the partial line; continuation logic above upgraded\n   764→  //     firstStructuralHeading to the full join. Filter removes the partial so dedup keeps join.\n   765→  // Safety: only fires when the complete heading itself is in selected (passed the threshold).\n   766→  if (firstStructuralHeading && selected.some((s) => s.text === firstStructuralHeading.text)) {\n   767→    const fshLower = firstStructuralHeading.text.toLowerCase();\n   768→    selected = selected.filter((s) => {\n   769→      if (s.text === firstStructuralHeading.text) return true;\n   770→      const sLower = s.text.toLowerCase();\n   771→      // Remove s if it is a space-delimited prefix of the structural heading\n   772→      return !fshLower.startsWith(sLower + \" \");\n   773→    });\n   774→  }\n   775→\n   776→  // Protect continuation joins: when a multi-line join (2-line or 3-line) survived the threshold\n   777→  // and its second part starts with a continuation character, remove the single-line prefix/suffix\n   778→  // so the dedup \"shorter wins\" rule doesn't destroy the complete join.\n   779→  // Note: the pre-merge step above already handles the common Baked Eggs case (&/continuation\n   780→  // on next line) by turning it into a single candidate — this block covers the rarer case where\n   781→  // a continuation-character join was generated as a 2-line/3-line candidate and the prefix\n   782→  // single also survived threshold independently (e.g. from a different code path or OCR layout).\n   783→  // Safety: only fires for joins whose continuation starts with /&+:( — digit continuations\n   784→  // like \"Pierogi Ruskie 200g mąki\" are NOT protected, so dedup correctly keeps the shorter form.\n   785→  const survivingJoins = selected.filter((s) => s.origin === \"2-line\" || s.origin === \"3-line\");\n   786→  if (survivingJoins.length > 0) {\n   787→    selected = selected.filter((s) => {\n   788→      if (s.origin !== \"single\") return true;\n   789→      const sLower = s.text.toLowerCase();\n   790→      // Remove PREFIX singles whose continuation join also survived\n   791→      const isPrefixOfJoin = survivingJoins.some((j) => {\n   792→        const jLower = j.text.toLowerCase();\n   793→        if (!jLower.startsWith(sLower + \" \")) return false;\n   794→        const remainder = jLower.slice(sLower.length + 1);\n   795→        return /^[/&+:(]/.test(remainder);\n   796→      });\n   797→      if (isPrefixOfJoin) return false;\n   798→      // Remove SUFFIX singles (e.g. \"& Coriander\") whose parent join also survived\n   799→      const isSuffixOfJoin = survivingJoins.some((j) => {\n   800→        const jLower = j.text.toLowerCase();\n   801→        if (!jLower.endsWith(\" \" + sLower)) return false;\n   802→        // Only remove if the suffix starts with a continuation character\n   803→        return /^[/&+:(]/.test(sLower);\n   804→      });\n   805→      if (isSuffixOfJoin) return false;\n   806→      return true;\n   807→    });\n   808→  }\n   809→\n   810→  // Pre-dedup: remove sub-section headers that are substrings of other surviving candidates.\n   811→  // A sub-section header is an ALL_CAPS candidate followed by ingredient-like lines in the source.\n   812→  // Example: \"CHLEBEK\" (bread section header, followed by \"500 g mąki\") is a substring of\n   813→  // \"CHLEBEK Z WARZYWAMI I BOCZKIEM\" (the real title). Without this filter, dedup kills the title.\n   814→  selected = selected.filter((candidate) => {\n   815→    if (!isAllCaps(candidate.text)) return true;\n   816→    // Check if this candidate is immediately followed by ingredient-like content\n   817→    const nextSourceLines = lines.slice(candidate.position + 1, candidate.position + 2);\n   818→    const followedByIngredients = nextSourceLines.some(\n   819→      (l) => looksLikeIngredient(l.trim()) || startsWithNumber(l.trim())\n   820→    );\n   821→    if (!followedByIngredients) return true;\n   822→    // Only remove if a longer candidate contains this one as a substring\n   823→    const candidateLower = candidate.text.toLowerCase();\n   824→    const hasLongerParent = rawScored.some(\n   825→      (other) =>\n   826→        other.text !== candidate.text &&\n   827→        other.text.length > candidate.text.length &&\n   828→        other.text.toLowerCase().includes(candidateLower)\n   829→    );\n   830→    return !hasLongerParent;\n   831→  });\n   832→\n   833→  // Protect multi-line joins from being destroyed by their own component singles.\n   834→  // When \"Lamb Stew\" (2-line join) survives AND both \"Lamb\" and \"Stew\" (singles) also survive,\n   835→  // the join is the intended title — remove the singles.\n   836→  const joinsToProtect = selected.filter((s) => s.origin === \"2-line\" || s.origin === \"3-line\");\n   837→  if (joinsToProtect.length > 0) {\n   838→    const singlesToRemove = new Set<string>();\n   839→    for (const join of joinsToProtect) {\n   840→      const joinWords = join.text.split(/\\s+/);\n   841→      const componentSingles = selected.filter(\n   842→        (s) => s.origin === \"single\" && joinWords.some((w) => s.text.toLowerCase() === w.toLowerCase())\n   843→      );\n   844→      if (componentSingles.length >= Math.min(joinWords.length, 2)) {\n   845→        componentSingles.forEach((s) => singlesToRemove.add(s.text));\n   846→      }\n   847→    }\n   848→    if (singlesToRemove.size > 0) {\n   849→      selected = selected.filter((s) => s.origin !== \"single\" || !singlesToRemove.has(s.text));\n   850→    }\n   851→  }\n   852→\n   853→  // Protect position-0 compound titles from distant sub-section headers.\n   854→  // When a position-0 compound title is longer and contains a shorter candidate\n   855→  // that appears > 10 lines later, remove the distant candidate so the dedup\n   856→  // (shorter-wins rule) doesn't destroy the compound title.\n   857→  const pos0Compounds = selected.filter((s) => s.position === 0);\n   858→  if (pos0Compounds.length > 0) {\n   859→    selected = selected.filter((s) => {\n   860→      if (s.position === 0) return true;\n   861→      const sLower = s.text.toLowerCase();\n   862→      return !pos0Compounds.some(\n   863→        (p0) =>\n   864→          p0.position + 10 < s.position &&\n   865→          s.text.length < p0.text.length &&\n   866→          p0.text.toLowerCase().includes(sLower)\n   867→      );\n   868→    });\n   869→  }\n   870→\n   871→  // Deduplicate: if one title is a substring of another, keep the shorter (more focused) one.\n   872→  // DO NOT CHANGE THIS LOGIC — it has been incorrectly \"improved\" by the title-loop 5 times.\n   873→  // The tests require shorter wins: \"Pierogi Ruskie\" over \"Pierogi Ruskie 200g mąki 3 ziemniaki\".\n   874→  // The pre-filter above handles the conflicting case (structural heading prefix removal) so that\n   875→  // the incomplete prefix line is never present here when the complete join is in selected.\n   876→  selected = selected.filter((a) => {\n   877→    const aLower = a.text.toLowerCase();\n   878→    return !selected.some(\n   879→      (b) =>\n   880→        b !== a &&\n   881→        aLower.includes(b.text.toLowerCase()) &&\n   882→        b.text.length < a.text.length\n   883→    );\n   884→  });\n   885→\n   886→  // Multi-title guard: only join multiple candidates with \"+\" when there is\n   887→  // structural evidence of a multi-recipe page (≥2 ALL_CAPS headings).\n   888→  // A single ALL_CAPS title among mixed-case survivors is a single-recipe page —\n   889→  // collapse to the highest-scoring candidate.\n   890→  // Zero ALL_CAPS survivors → apply positional tiebreak only when candidates are\n   891→  // spread far apart (>10 lines), which indicates body-text leakage. Closely-\n   892→  // positioned candidates are likely genuine multi-recipe content.\n   893→  if (selected.length > 1) {\n   894→    const allCapsSelected = selected.filter((s) => isAllCaps(s.text));\n   895→    if (allCapsSelected.length >= 2) {\n   896→      // Check whether non-first ALL_CAPS headings are section headers within one recipe\n   897→      // (followed immediately by ingredient-like content) rather than separate recipe titles.\n   898→      // A multi-recipe page has body text between titles; a single-recipe page has\n   899→      // ingredient lines immediately after each section heading.\n   900→      const sortedCaps = [...allCapsSelected].sort((a, b) => a.position - b.position);\n   901→      const isSubHeader = sortedCaps.slice(1).every((cap) => {\n   902→        const nextLines = lines.slice(cap.position + 1, cap.position + 3);\n   903→        return nextLines.some(\n   904→          (l) => looksLikeIngredient(l.trim()) || /^\\s*\\d/.test(l.trim())\n   905→        );\n   906→      });\n   907→      if (isSubHeader) {\n   908→        selected = [sortedCaps[0]];\n   909→      } else {\n   910→        selected = allCapsSelected;\n   911→      }\n   912→    } else if (allCapsSelected.length === 1) {\n   913→      const theCapCandidate = allCapsSelected[0];\n   914→      // Use non-empty line count so the 75% threshold is consistent regardless of blank-line density.\n   915→      const nonEmptyCount = lines.filter((l) => l.trim().length > 0).length;\n   916→      const capRelPos = theCapCandidate.position / Math.max(nonEmptyCount, 1);\n   917→      // If the sole ALL_CAPS candidate is in the last 25% of the document,\n   918→      // it's likely a category footer, not a title. Prefer the best earlier candidate.\n   919→      if (capRelPos > 0.75) {\n   920→        const earlierCandidates = selected.filter(\n   921→          (s) => s.position / Math.max(nonEmptyCount, 1) <= 0.75\n   922→        );\n   923→        if (earlierCandidates.length > 0) {\n   924→          selected = [earlierCandidates.reduce((a, b) => (a.score > b.score ? a : b))];\n   925→        } else {\n   926→          // All candidates are in the last 25% — no positional basis to prefer one over another;\n   927→          // fall back to score, accepting that the guard cannot help here.\n   928→          selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n   929→        }\n   930→      } else {\n   931→        selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n   932→      }\n   933→    } else {\n   934→      // Zero ALL_CAPS survivors → mixed-case page.\n   935→      // If all survivors are closely positioned (within 10 lines of each other), keep them all —\n   936→      // they're likely genuine multi-recipe content on a single page.\n   937→      // If any survivor is far from the earliest, apply a positional tiebreak: the real title\n   938→      // is almost always the earliest candidate; distant survivors are likely body-text leakage.\n   939→      selected.sort((a, b) => a.position - b.position);\n   940→      const earliest = selected[0];\n   941→      const farthest = selected[selected.length - 1];\n   942→      if (farthest.position - earliest.position > 10) {\n   943→        // Large span → body-text leakage. Collapse to one: prefer the highest-scoring\n   944→        // candidate within 3 positions of the earliest (position tolerance for OCR gaps),\n   945→        // falling back to the earliest itself if none score higher.\n   946→        const closeCompetitors = selected.filter(\n   947→          (s) => s.position <= earliest.position + 3 && s.score > earliest.score\n   948→        );\n   949→        selected = closeCompetitors.length > 0\n   950→          ? [closeCompetitors.reduce((a, b) => (a.score > b.score ? a : b))]\n   951→          : [earliest];\n   952→      }\n   953→      // Span ≤ 10 → all survivors are closely positioned; fall through keeping all.\n   954→    }\n   955→  }\n   956→\n   957→  // Cap at 3, sort by document position\n   958→  selected.sort((a, b) => a.position - b.position);\n   959→  selected = selected.slice(0, 3);\n   960→\n   961→  if (selected.length === 0) {\n   962→    return undefined;\n   963→  }\n   964→\n   965→  return selected.map((s) => s.text).join(\" + \");\n   966→}\n   967→\n   968→/**\n   969→ * Extract potential recipe title from OCR text (sync heuristic fallback)\n   970→ */\n   971→export function extractTitle(text: string): string | undefined {\n   972→  if (!text || text.trim().length === 0) {\n   973→    return undefined;\n   974→  }\n   975→\n   976→  const lines = text.split(\"\\n\").map((line) => line.trim());\n   977→\n   978→  for (const line of lines) {\n   979→    if (line.length === 0) continue;\n   980→    if (line.length < 3 || line.length > 50) continue;\n   981→    if (looksLikeIngredient(line)) continue;\n   982→    if (isAllCaps(line)) continue;\n   983→    if (startsWithNumber(line)) continue;\n   984→    return line;\n   985→  }\n   986→\n   987→  return undefined;\n   988→}\n   989→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n","numLines":994,"startLine":1,"totalLines":994}}}
