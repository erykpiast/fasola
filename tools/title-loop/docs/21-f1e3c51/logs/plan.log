{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Xj88Cq2rC7GSE8cQHsyvAK","type":"tool_result","content":"1-#!/usr/bin/env python3\n2-\"\"\"\n3:Self-improving title extraction loop.\n4-\n5:Iteratively evaluates and improves the title extraction algorithm by:\n6-1. Running extraction against real and generated OCR input files\n7-2. Using Claude Code headless for analysis, planning, and implementation\n8-3. Committing improvements and tracking accuracy across iterations\n9-\n10-Fully resumable: detects which step of an iteration was last completed\n11-and picks up from there.\n12-\n13:Usage: python3 tools/title-loop/title-loop.py\n14-\"\"\"\n15-\n16-import glob\n17-import json\n18-import os\n--\n28-MAX_ITERATIONS = 40\n29-ACCURACY_THRESHOLD = 0.95  # \"close to 100%\"\n30-CLAUDE_TIMEOUT = 900  # 15 minutes per Claude invocation\n31-CLAUDE_STALL_TIMEOUT = 60  # kill if no output for N seconds (default)\n32-CLAUDE_STALL_TIMEOUT_BY_MODEL = {\"opus\": 180, \"sonnet\": 120, \"haiku\": 60}\n33:CLAUDE_MAX_RETRIES = 3  # max retries per stage on stall/failure\n34-EXTRACT_TIMEOUT = 120  # 2 minutes per file extraction\n35-\n36-PROJECT_ROOT = Path(__file__).resolve().parent.parent.parent\n37-LOOP_DIR = Path(__file__).resolve().parent\n38-INPUT_DIR = LOOP_DIR / \"input\"\n39-DOCS_DIR = LOOP_DIR / \"docs\"\n40:EXTRACT_SCRIPT = LOOP_DIR / \"extract-title.ts\"\n41-ITER_LOG = DOCS_DIR / \"iter.txt\"\n42-\n43-# Number of recent output lines to show in live display\n44-\n45-\n46-# --- Resume state detection ---\n47-\n48-def find_iter_dir(iteration: int) -> Path | None:\n49-    \"\"\"Find the iteration directory for a given iteration number (hash may vary).\"\"\"\n50:    matches = sorted(DOCS_DIR.glob(f\"{iteration}-*\"))\n51:    matches = [m for m in matches if re.match(rf\"^{iteration}-[a-f0-9]+$\", m.name)]\n52:    return matches[0] if matches else None\n53-\n54-\n55-def get_logged_accuracy(iteration: int) -> float | None:\n56-    \"\"\"Read the accuracy logged for a specific iteration from iter.txt.\"\"\"\n57-    if not ITER_LOG.exists():\n58-        return None\n59-    for line in ITER_LOG.read_text().strip().splitlines():\n60:        m = re.match(r\"^(\\d+)\\s*-\\s*([\\d.]+)%\", line)\n61-        if m and int(m.group(1)) == iteration:\n62-            return float(m.group(2)) / 100\n63-    return None\n64-\n65-\n--\n67-    \"\"\"Read iter.txt to find the last logged iteration number. Returns 0 if none.\"\"\"\n68-    if not ITER_LOG.exists():\n69-        return 0\n70-    last = 0\n71-    for line in ITER_LOG.read_text().strip().splitlines():\n72:        m = re.match(r\"^(\\d+)\\s*-\\s*\", line)\n73-        if m:\n74-            last = int(m.group(1))\n75-    return last\n76-\n77-\n--\n107-\n108-\n109-# --- Core helpers ---\n110-\n111-def normalize(s: str) -> str:\n112:    \"\"\"Normalize whitespace, hyphens, and case for comparison.\"\"\"\n113-    return \" \".join(s.lower().replace(\"-\", \" \").split())\n114-\n115-\n116-def normalize_separators(s: str) -> str:\n117-    \"\"\"Normalize filesystem-substituted characters (: replaces / in filenames).\"\"\"\n118-    return s.replace(\":\", \"/\")\n119-\n120-\n121:# Map stripped ASCII to Polish diacritics for fuzzy filename matching.\n122-# Generated filenames often drop diacritics (e.g., \"Zaby\" for \"Żaby\").\n123-_POLISH_DIACRITICS = str.maketrans(\n124-    \"ąćęłńóśźżĄĆĘŁŃÓŚŹŻ\",\n125-    \"acelnoszzACELNOSZZ\",\n126-)\n--\n129-def _strip_diacritics(s: str) -> str:\n130-    \"\"\"Strip Polish diacritics to ASCII equivalents.\"\"\"\n131-    return s.translate(_POLISH_DIACRITICS)\n132-\n133-\n134:def titles_match(extracted: str, expected: str) -> bool:\n135-    \"\"\"\n136:    Binary match: does the extracted title contain all expected title parts?\n137:    Expected may contain multiple titles separated by '+'.\n\n[Showing results with pagination = limit: 100, offset: 0]"}]},"parent_tool_use_id":null,"session_id":"8b8858bc-a11e-49e9-aee6-802d54bbaef0","uuid":"1db77590-