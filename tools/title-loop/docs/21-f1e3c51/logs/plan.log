n from iter.txt.\"\"\"\n57-    if not ITER_LOG.exists():\n58-        return None\n59-    for line in ITER_LOG.read_text().strip().splitlines():\n60:        m = re.match(r\"^(\\d+)\\s*-\\s*([\\d.]+)%\", line)\n61-        if m and int(m.group(1)) == iteration:\n62-            return float(m.group(2)) / 100\n63-    return None\n64-\n65-\n--\n67-    \"\"\"Read iter.txt to find the last logged iteration number. Returns 0 if none.\"\"\"\n68-    if not ITER_LOG.exists():\n69-        return 0\n70-    last = 0\n71-    for line in ITER_LOG.read_text().strip().splitlines():\n72:        m = re.match(r\"^(\\d+)\\s*-\\s*\", line)\n73-        if m:\n74-            last = int(m.group(1))\n75-    return last\n76-\n77-\n--\n107-\n108-\n109-# --- Core helpers ---\n110-\n111-def normalize(s: str) -> str:\n112:    \"\"\"Normalize whitespace, hyphens, and case for comparison.\"\"\"\n113-    return \" \".join(s.lower().replace(\"-\", \" \").split())\n114-\n115-\n116-def normalize_separators(s: str) -> str:\n117-    \"\"\"Normalize filesystem-substituted characters (: replaces / in filenames).\"\"\"\n118-    return s.replace(\":\", \"/\")\n119-\n120-\n121:# Map stripped ASCII to Polish diacritics for fuzzy filename matching.\n122-# Generated filenames often drop diacritics (e.g., \"Zaby\" for \"Żaby\").\n123-_POLISH_DIACRITICS = str.maketrans(\n124-    \"ąćęłńóśźżĄĆĘŁŃÓŚŹŻ\",\n125-    \"acelnoszzACELNOSZZ\",\n126-)\n--\n129-def _strip_diacritics(s: str) -> str:\n130-    \"\"\"Strip Polish diacritics to ASCII equivalents.\"\"\"\n131-    return s.translate(_POLISH_DIACRITICS)\n132-\n133-\n134:def titles_match(extracted: str, expected: str) -> bool:\n135-    \"\"\"\n136:    Binary match: does the extracted title contain all expected title parts?\n137:    Expected may contain multiple titles separated by '+'.","numLines":100,"appliedLimit":100}}
