{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GLqHqte99ogvF4vDjbVRMS","type":"tool_result","content":"   800→    selected = selected.filter((s) => {\n   801→      if (s.text === firstStructuralHeading.text) return true;\n   802→      const sLower = s.text.toLowerCase();\n   803→      // Remove s if it is a space-delimited prefix of the structural heading\n   804→      return !fshLower.startsWith(sLower + \" \");\n   805→    });\n   806→  }\n   807→\n   808→  // Protect continuation joins: when a multi-line join (2-line or 3-line) survived the threshold\n   809→  // and its second part starts with a continuation character, remove the single-line prefix/suffix\n   810→  // so the dedup \"shorter wins\" rule doesn't destroy the complete join.\n   811→  // Note: the pre-merge step above already handles the common Baked Eggs case (&/continuation\n   812→  // on next line) by turning it into a single candidate — this block covers the rarer case where\n   813→  // a continuation-character join was generated as a 2-line/3-line candidate and the prefix\n   814→  // single also survived threshold independently (e.g. from a different code path or OCR layout).\n   815→  // Safety: only fires for joins whose continuation starts with /&+:( — digit continuations\n   816→  // like \"Pierogi Ruskie 200g mąki\" are NOT protected, so dedup correctly keeps the shorter form.\n   817→  const survivingJoins = selected.filter((s) => s.origin === \"2-line\" || s.origin === \"3-line\");\n   818→  if (survivingJoins.length > 0) {\n   819→    selected = selected.filter((s) => {\n   820→      if (s.origin !== \"single\") return true;\n   821→      const sLower = s.text.toLowerCase();\n   822→      // Remove PREFIX singles whose continuation join also survived\n   823→      const isPrefixOfJoin = survivingJoins.some((j) => {\n   824→        const jLower = j.text.toLowerCase();\n   825→        if (!jLower.startsWith(sLower + \" \")) return false;\n   826→        const remainder = jLower.slice(sLower.length + 1);\n   827→        return /^[/&+:(]/.test(remainder);\n   828→      });\n   829→      if (isPrefixOfJoin) return false;\n   830→      // Remove SUFFIX singles (e.g. \"& Coriander\") whose parent join also survived\n   831→      const isSuffixOfJoin = survivingJoins.some((j) => {\n   832→        const jLower = j.text.toLowerCase();\n   833→        if (!jLower.endsWith(\" \" + sLower)) return false;\n   834→        // Only remove if the suffix starts with a continuation character\n   835→        return /^[/&+:(]/.test(sLower);\n   836→      });\n   837→      if (isSuffixOfJoin) return false;\n   838→      return true;\n   839→    });\n   840→  }\n   841→\n   842→  // Pre-dedup: remove sub-section headers that are substrings of other surviving candidates.\n   843→  // A sub-section header is an ALL_CAPS candidate followed by ingredient-like lines in the source.\n   844→  // Example: \"CHLEBEK\" (bread section header, followed by \"500 g mąki\") is a substring of\n   845→  // \"CHLEBEK Z WARZYWAMI I BOCZKIEM\" (the real title). Without this filter, dedup kills the title.\n   846→  selected = selected.filter((candidate) => {\n   847→    if (!isAllCaps(candidate.text)) return true;\n   848→    // Check if this candidate is immediately followed by ingredient-like content\n   849→    const nextSourceLines = lines.slice(candidate.position + 1, candidate.position + 2);\n   850→    const followedByIngredients = nextSourceLines.some(\n   851→      (l) => looksLikeIngredient(l.trim()) || startsWithNumber(l.trim())\n   852→    );\n   853→    if (!followedByIngredients) return true;\n   854→    // Only remove if a longer candidate contains this one as a substring\n   855→    const candidateLower = candidate.text.toLowerCase();\n   856→    const hasLongerParent = rawScored.some(\n   857→      (other) =>\n   858→        other.text !== candidate.text &&\n   859→        other.text.length > candidate.text.length &&\n   860→        other.text.toLowerCase().includes(candidateLower)\n   861→    );\n   862→    return !hasLongerParent;\n   863→  });\n   864→\n   865→  // Protect multi-line joins from being destroyed by their own component singles.\n   866→  // When \"Lamb Stew\" (2-line join) survives AND both \"Lamb\" and \"Stew\" (singles) also survive,\n   867→  // the join is the intended title — remove the singles.\n   868→  const joinsToProtect = selected.filter((s) => s.origin === \"2-line\" || s.origin === \"3-line\");\n   869→  if (joinsToProtect.length > 0) {\n   870→    const singlesToRemove = new Set<string>();\n   871→    for (const join of joinsToProtect) {\n   872→      const joinWords = join.text.split(/\\s+/);\n   873→      const componentSingles = selected.filter(\n   874→        (s) => s.origin === \"single\" && joinWords.some((w) => s.text.toLowerCase() === w.toLowerCase())\n   875→      );\n   876→      if (componentSingles.length >= Math.min(joinWords.length, 2)) {\n   877→        componentSingles.forEach((s) => singlesToRemove.add(s.text));\n   878→      }\n   879→    }\n   880→    if (singlesToRemove.size > 0) {\n   881→      selected = selected.filter((s) => s.origin !== \"single\" || !singlesToRemove.has(s.text));\n   882→    }\n   883→  }\n   884→\n   885→  // Protect position-0 compound titles from distant sub-section headers.\n   886→  // When a position-0 compound title is longer and contains a shorter candidate\n   887→  // that appears > 10 lines later, remove the distant candidate so the dedup\n   888→  // (shorter-wins rule) doesn't destroy the compound title.\n   889→  const pos0Compounds = selected.filter((s) => s.position === 0);\n   890→  if (pos0Compounds.length > 0) {\n   891→    selected = selected.filter((s) => {\n   892→      if (s.position === 0) return true;\n   893→      const sLower = s.text.toLowerCase();\n   894→      return !pos0Compounds.some(\n   895→        (p0) =>\n   896→          p0.position + 10 < s.position &&\n   897→          s.text.length < p0.text.length &&\n   898→          p0.text.toLowerCase().includes(sLower)\n   899→      );\n   900→    });\n   901→  }\n   902→\n   903→  // Deduplicate: if one title is a substring of another, keep the shorter (more focused) one.\n   904→  // DO NOT CHANGE THIS LOGIC — it has been incorrectly \"improved\" by the title-loop 5 times.\n   905→  // The tests require shorter wins: \"Pierogi Ruskie\" over \"Pierogi Ruskie 200g mąki 3 ziemniaki\".\n   906→  // The pre-filter above handles the conflicting case (structural heading prefix removal) so that\n   907→  // the incomplete prefix line is never present here when the complete join is in selected.\n   908→  selected = selected.filter((a) => {\n   909→    const aLower = a.text.toLowerCase();\n   910→    return !selected.some(\n   911→      (b) =>\n   912→        b !== a &&\n   913→        aLower.includes(b.text.toLowerCase()) &&\n   914→        b.text.length < a.text.length\n   915→    );\n   916→  });\n   917→\n   918→  // Multi-title guard: only join multiple candidates with \"+\" when there is\n   919→  // structural evidence of a multi-recipe page (≥2 ALL_CAPS headings).\n   920→  // A single ALL_CAPS title among mixed-case survivors is a single-recipe page —\n   921→  // collapse to the highest-scoring candidate.\n   922→  // Zero ALL_CAPS survivors → apply positional tiebreak only when candidates are\n   923→  // spread far apart (>10 lines), which indicates body-text leakage. Closely-\n   924→  // positioned candidates are likely genuine multi-recipe content.\n   925→  if (selected.length > 1) {\n   926→    const allCapsSelected = selected.filter((s) => isAllCaps(s.text));\n   927→    if (allCapsSelected.length >= 2) {\n   928→      // Check whether non-first ALL_CAPS headings are section headers within one recipe\n   929→      // (followed immediately by ingredient-like content) rather than separate recipe titles.\n   930→      // A multi-recipe page has body text between titles; a single-recipe page has\n   931→      // ingredient lines immediately after each section heading.\n   932→      const sortedCaps = [...allCapsSelected].sort((a, b) => a.position - b.position);\n   933→      const isSubHeader = sortedCaps.slice(1).every((cap) => {\n   934→        const nextLines = lines.slice(cap.position + 1, cap.position + 3);\n   935→        return nextLines.some(\n   936→          (l) => looksLikeIngredient(l.trim()) || /^\\s*\\d/.test(l.trim())\n   937→        );\n   938→      });\n   939→      if (isSubHeader) {\n   940→        selected = [sortedCaps[0]];\n   941→      } else {\n   942→        selected = allCapsSelected;\n   943→      }\n   944→    } else if (allCapsSelected.length === 1) {\n   945→      const theCapCandidate = allCapsSelected[0];\n   946→      // Use non-empty line count so the 75% threshold is consistent regardless of blank-line density.\n   947→      const nonEmptyCount = lines.filter((l) => l.trim().length > 0).length;\n   948→      const capRelPos = theCapCandidate.position / Math.max(nonEmptyCount, 1);\n   949→      // If the sole ALL_CAPS candidate is in the last 25% of the document,\n   950→      // it's likely a category footer, not a title. Prefer the best earlier candidate.\n   951→      if (capRelPos > 0.75) {\n   952→        const earlierCandidates = selected.filter(\n   953→          (s) => s.position / Math.max(nonEmptyCount, 1) <= 0.75\n   954→        );\n   955→        if (earlierCandidates.length > 0) {\n   956→          selected = [earlierCandidates.reduce((a, b) => (a.score > b.score ? a : b))];\n   957→        } else {\n   958→          // All candidates are in the last 25% — no positional basis to prefer one over another;\n   959→          // fall back to score, accepting that the guard cannot help here.\n   960→          selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n   961→        }\n   962→      } else {\n   963→        selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n   964→      }\n   965→    } else {\n   966→      // Zero ALL_CAPS survivors → mixed-case page.\n   967→      // If all survivors are closely positioned (within 10 lines of each other), keep them all —\n   968→      // they're likely genuine multi-recipe content on a single page.\n   969→      // If any survivor is far from the earliest, apply a positional tiebreak: the real title\n   970→      // is almost always the earliest candidate; distant survivors are likely body-text leakage.\n   971→      selected.sort((a, b) => a.position - b.position);\n   972→      const earliest = selected[0];\n   973→      const farthest = selected[selected.length - 1];\n   974→      if (farthest.position - earliest.position > 10) {\n   975→        // Large span → body-text leakage. Collapse to one: prefer the highest-scoring\n   976→        // candidate within 3 positions of the earliest (position tolerance for OCR gaps),\n   977→        // falling back to the earliest itself if none score higher.\n   978→        const closeCompetitors = selected.filter(\n   979→          (s) => s.position <= earliest.position + 3 && s.score > earliest.score\n   980→        );\n   981→        selected = closeCompetitors.length > 0\n   982→          ? [closeCompetitors.reduce((a, b) => (a.score > b.score ? a : b))]\n   983→          : [earliest];\n   984→      }\n   985→      // Span ≤ 10 → all survivors are closely positioned; fall through keeping all.\n   986→    }\n   987→  }\n   988→\n   989→  // Cap at 3, sort by document position\n   990→  selected.sort((a, b) => a.position - b.position);\n   991→  selected = selected.slice(0, 3);\n   992→\n   993→  if (selected.length === 0) {\n   994→    return undefined;\n   995→  }\n   996→\n   997→  const result = selected.map((s) => s.text.normalize(\"NFC\").trim()).join(\" + \");\n   998→\n   999→  // Compound variant: \"A : B\" where both sides share the same first word → return only A."}]},"parent_tool_use_id":null,"session_id":"52c225dd-138d-420c-8852-ee28a481d2ae","uuid":"8866a10a-46e9-4ca6-9a26-51507bf67116","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/title-extractor.ts","content":"    selected = selected.filter((s) => {\n      if (s.text === firstStructuralHeading.text) return true;\n      const sLower = s.text.toLowerCase();\n      // Remove s if it is a space-delimited prefix of the structural heading\n      return !fshLower.startsWith(sLower + \" \");\n    });\n  }\n\n  // Protect continuation joins: when a multi-line join (2-line or 3-line) survived the threshold\n  // and its second part starts with a continuation character, remove the single-line prefix/suffix\n  // so the dedup \"shorter wins\" rule doesn't destroy the complete join.\n  // Note: the pre-merge step above already handles the common Baked Eggs case (&/continuation\n  // on next line) by turning it into a single candidate — this block covers the rarer case where\n  // a continuation-character join was generated as a 2-line/3-line candidate and the prefix\n  // single also survived threshold independently (e.g. from a different code path or OCR layout).\n  // Safety: only fires for joins whose continuation starts with /&+:( — digit continuations\n  // like \"Pierogi Ruskie 200g mąki\" are NOT protected, so dedup correctly keeps the shorter form.\n  const survivingJoins = selected.filter((s) => s.origin === \"2-line\" || s.origin === \"3-line\");\n  if (survivingJoins.length > 0) {\n    selected = selected.filter((s) => {\n      if (s.origin !== \"single\") return true;\n      const sLower = s.text.toLowerCase();\n      // Remove PREFIX singles whose continuation join also survived\n      const isPrefixOfJoin = survivingJoins.some((j) => {\n        const jLower = j.text.toLowerCase();\n        if (!jLower.startsWith(sLower + \" \")) return false;\n        const remainder = jLower.slice(sLower.length + 1);\n        return /^[/&+:(]/.test(remainder);\n      });\n      if (isPrefixOfJoin) return false;\n      // Remove SUFFIX singles (e.g. \"& Coriander\") whose parent join also survived\n      const isSuffixOfJoin = survivingJoins.some((j) => {\n        const jLower = j.text.toLowerCase();\n        if (!jLower.endsWith(\" \" + sLower)) return false;\n        // Only remove if the suffix starts with a continuation character\n        return /^[/&+:(]/.test(sLower);\n      });\n      if (isSuffixOfJoin) return false;\n      return true;\n    });\n  }\n\n  // Pre-dedup: remove sub-section headers that are substrings of other surviving candidates.\n  // A sub-section header is an ALL_CAPS candidate followed by ingredient-like lines in the source.\n  // Example: \"CHLEBEK\" (bread section header, followed by \"500 g mąki\") is a substring of\n  // \"CHLEBEK Z WARZYWAMI I BOCZKIEM\" (the real title). Without this filter, dedup kills the title.\n  selected = selected.filter((candidate) => {\n    if (!isAllCaps(candidate.text)) return true;\n    // Check if this candidate is immediately followed by ingredient-like content\n    const nextSourceLines = lines.slice(candidate.position + 1, candidate.position + 2);\n    const followedByIngredients = nextSourceLines.some(\n      (l) => looksLikeIngredient(l.trim()) || startsWithNumber(l.trim())\n    );\n    if (!followedByIngredients) return true;\n    // Only remove if a longer candidate contains this one as a substring\n    const candidateLower = candidate.text.toLowerCase();\n    const hasLongerParent = rawScored.some(\n      (other) =>\n        other.text !== candidate.text &&\n        other.text.length > candidate.text.length &&\n        other.text.toLowerCase().includes(candidateLower)\n    );\n    return !hasLongerParent;\n  });\n\n  // Protect multi-line joins from being destroyed by their own component singles.\n  // When \"Lamb Stew\" (2-line join) survives AND both \"Lamb\" and \"Stew\" (singles) also survive,\n  // the join is the intended title — remove the singles.\n  const joinsToProtect = selected.filter((s) => s.origin === \"2-line\" || s.origin === \"3-line\");\n  if (joinsToProtect.length > 0) {\n    const singlesToRemove = new Set<string>();\n    for (const join of joinsToProtect) {\n      const joinWords = join.text.split(/\\s+/);\n      const componentSingles = selected.filter(\n        (s) => s.origin === \"single\" && joinWords.some((w) => s.text.toLowerCase() === w.toLowerCase())\n      );\n      if (componentSingles.length >= Math.min(joinWords.length, 2)) {\n        componentSingles.forEach((s) => singlesToRemove.add(s.text));\n      }\n    }\n    if (singlesToRemove.size > 0) {\n      selected = selected.filter((s) => s.origin !== \"single\" || !singlesToRemove.has(s.text));\n    }\n  }\n\n  // Protect position-0 compound titles from distant sub-section headers.\n  // When a position-0 compound title is longer and contains a shorter candidate\n  // that appears > 10 lines later, remove the distant candidate so the dedup\n  // (shorter-wins rule) doesn't destroy the compound title.\n  const pos0Compounds = selected.filter((s) => s.position === 0);\n  if (pos0Compounds.length > 0) {\n    selected = selected.filter((s) => {\n      if (s.position === 0) return true;\n      const sLower = s.text.toLowerCase();\n      return !pos0Compounds.some(\n        (p0) =>\n          p0.position + 10 < s.position &&\n          s.text.length < p0.text.length &&\n          p0.text.toLowerCase().includes(sLower)\n      );\n    });\n  }\n\n  // Deduplicate: if one title is a substring of another, keep the shorter (more focused) one.\n  // DO NOT CHANGE THIS LOGIC — it has been incorrectly \"improved\" by the title-loop 5 times.\n  // The tests require shorter wins: \"Pierogi Ruskie\" over \"Pierogi Ruskie 200g mąki 3 ziemniaki\".\n  // The pre-filter above handles the conflicting case (structural heading prefix removal) so that\n  // the incomplete prefix line is never present here when the complete join is in selected.\n  selected = selected.filter((a) => {\n    const aLower = a.text.toLowerCase();\n    return !selected.some(\n      (b) =>\n        b !== a &&\n        aLower.includes(b.text.toLowerCase()) &&\n        b.text.length < a.text.length\n    );\n  });\n\n  // Multi-title guard: only join multiple candidates with \"+\" when there is\n  // structural evidence of a multi-recipe page (≥2 ALL_CAPS headings).\n  // A single ALL_CAPS title among mixed-case survivors is a single-recipe page —\n  // collapse to the highest-scoring candidate.\n  // Zero ALL_CAPS survivors → apply positional tiebreak only when candidates are\n  // spread far apart (>10 lines), which indicates body-text leakage. Closely-\n  // positioned candidates are likely genuine multi-recipe content.\n  if (selected.length > 1) {\n    const allCapsSelected = selected.filter((s) => isAllCaps(s.text));\n    if (allCapsSelected.length >= 2) {\n      // Check whether non-first ALL_CAPS headings are section headers within one recipe\n      // (followed immediately by ingredient-like content) rather than separate recipe titles.\n      // A multi-recipe page has body text between titles; a single-recipe page has\n      // ingredient lines immediately after each section heading.\n      const sortedCaps = [...allCapsSelected].sort((a, b) => a.position - b.position);\n      const isSubHeader = sortedCaps.slice(1).every((cap) => {\n        const nextLines = lines.slice(cap.position + 1, cap.position + 3);\n        return nextLines.some(\n          (l) => looksLikeIngredient(l.trim()) || /^\\s*\\d/.test(l.trim())\n        );\n      });\n      if (isSubHeader) {\n        selected = [sortedCaps[0]];\n      } else {\n        selected = allCapsSelected;\n      }\n    } else if (allCapsSelected.length === 1) {\n      const theCapCandidate = allCapsSelected[0];\n      // Use non-empty line count so the 75% threshold is consistent regardless of blank-line density.\n      const nonEmptyCount = lines.filter((l) => l.trim().length > 0).length;\n      const capRelPos = theCapCandidate.position / Math.max(nonEmptyCount, 1);\n      // If the sole ALL_CAPS candidate is in the last 25% of the document,\n      // it's likely a category footer, not a title. Prefer the best earlier candidate.\n      if (capRelPos > 0.75) {\n        const earlierCandidates = selected.filter(\n          (s) => s.position / Math.max(nonEmptyCount, 1) <= 0.75\n        );\n        if (earlierCandidates.length > 0) {\n          selected = [earlierCandidates.reduce((a, b) => (a.score > b.score ? a : b))];\n        } else {\n          // All candidates are in the last 25% — no positional basis to prefer one over another;\n          // fall back to score, accepting that the guard cannot help here.\n          selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n        }\n      } else {\n        selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n      }\n    } else {\n      // Zero ALL_CAPS survivors → mixed-case page.\n      // If all survivors are closely positioned (within 10 lines of each other), keep them all —\n      // they're likely genuine multi-recipe content on a single page.\n      // If any survivor is far from the earliest, apply a positional tiebreak: the real title\n      // is almost always the earliest candidate; distant survivors are likely body-text leakage.\n      selected.sort((a, b) => a.position - b.position);\n      const earliest = selected[0];\n      const farthest = selected[selected.length - 1];\n      if (farthest.position - earliest.position > 10) {\n        // Large span → body-text leakage. Collapse to one: prefer the highest-scoring\n        // candidate within 3 positions of the earliest (position tolerance for OCR gaps),\n        // falling back to the earliest itself if none score higher.\n        const closeCompetitors = selected.filter(\n          (s) => s.position <= earliest.position + 3 && s.score > earliest.score\n        );\n        selected = closeCompetitors.length > 0\n          ? [closeCompetitors.reduce((a, b) => (a.score > b.score ? a : b))]\n          : [earliest];\n      }\n      // Span ≤ 10 → all survivors are closely positioned; fall through keeping all.\n    }\n  }\n\n  // Cap at 3, sort by document position\n  selected.sort((a, b) => a.position - b.position);\n  selected = selected.slice(0, 3);\n\n  if (selected.length === 0) {\n    return undefined;\n  }\n\n  const result = selected.map((s) => s.text.normalize(\"NFC\").trim()).join(\" + \");\n\n  // Compound variant: \"A : B\" where both sides share the same first word → return only A.","numLines":200,"startLine":800,"totalLines":1035}}}
