{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015JLiEaZw3N2yHTto7L3PHg","type":"tool_result","content":"   999→  // Compound variant: \"A : B\" where both sides share the same first word → return only A.\n  1000→  // This handles pages with \"TITLE VARIANT1 : TITLE VARIANT2\" where only the first is wanted.\n  1001→  const colonMatch = result.match(/^(.+?)\\s*:\\s*(.+)$/);\n  1002→  if (colonMatch) {\n  1003→    const [, first, second] = colonMatch;\n  1004→    const firstWord = first.trim().toLowerCase().split(/\\s+/)[0];\n  1005→    const secondWord = second.trim().toLowerCase().split(/\\s+/)[0];\n  1006→    if (firstWord && firstWord === secondWord) {\n  1007→      return first.trim().normalize(\"NFC\");\n  1008→    }\n  1009→  }\n  1010→\n  1011→  return result;\n  1012→}\n  1013→\n  1014→/**\n  1015→ * Extract potential recipe title from OCR text (sync heuristic fallback)\n  1016→ */\n  1017→export function extractTitle(text: string): string | undefined {\n  1018→  if (!text || text.trim().length === 0) {\n  1019→    return undefined;\n  1020→  }\n  1021→\n  1022→  const lines = text.split(\"\\n\").map((line) => line.trim());\n  1023→\n  1024→  for (const line of lines) {\n  1025→    if (line.length === 0) continue;\n  1026→    if (line.length < 3 || line.length > 50) continue;\n  1027→    if (looksLikeIngredient(line)) continue;\n  1028→    if (isAllCaps(line)) continue;\n  1029→    if (startsWithNumber(line)) continue;\n  1030→    return line;\n  1031→  }\n  1032→\n  1033→  return undefined;\n  1034→}\n  1035→"}]},"parent_tool_use_id":null,"session_id":"52c225dd-138d-420c-8852-ee28a481d2ae","uuid":"deb5cbb7-b126-47ff-9ba7-49394f946c10","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/title-extractor.ts","content":"  // Compound variant: \"A : B\" where both sides share the same first word → return only A.\n  // This handles pages with \"TITLE VARIANT1 : TITLE VARIANT2\" where only the first is wanted.\n  const colonMatch = result.match(/^(.+?)\\s*:\\s*(.+)$/);\n  if (colonMatch) {\n    const [, first, second] = colonMatch;\n    const firstWord = first.trim().toLowerCase().split(/\\s+/)[0];\n    const secondWord = second.trim().toLowerCase().split(/\\s+/)[0];\n    if (firstWord && firstWord === secondWord) {\n      return first.trim().normalize(\"NFC\");\n    }\n  }\n\n  return result;\n}\n\n/**\n * Extract potential recipe title from OCR text (sync heuristic fallback)\n */\nexport function extractTitle(text: string): string | undefined {\n  if (!text || text.trim().length === 0) {\n    return undefined;\n  }\n\n  const lines = text.split(\"\\n\").map((line) => line.trim());\n\n  for (const line of lines) {\n    if (line.length === 0) continue;\n    if (line.length < 3 || line.length > 50) continue;\n    if (looksLikeIngredient(line)) continue;\n    if (isAllCaps(line)) continue;\n    if (startsWithNumber(line)) continue;\n    return line;\n  }\n\n  return undefined;\n}\n","numLines":37,"startLine":999,"totalLines":1035}}}
