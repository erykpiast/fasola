{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018WkDyryqw4mPQUUSKjFJcs","type":"tool_result","content":"<persisted-output>\nOutput too large (66KB). Full output saved to: /Users/eryk.napierala/.claude/projects/-Users-eryk-napierala-Projects-fasola/52c225dd-138d-420c-8852-ee28a481d2ae/tool-results/toolu_018WkDyryqw4mPQUUSKjFJcs.txt\n\nPreview (first 2KB):\n     1→     1→     1→/**\n     2→     2→     2→ * Title Extraction\n     3→     3→     3→ * Extracts potential recipe title from OCR text using heuristics or semantic embeddings\n     4→     4→     4→ */\n     5→     5→     5→\n     6→     6→     6→import { cosineSimilarity } from \"./embeddings\";\n     7→     7→     7→\n     8→     8→     8→export type EmbedFn = (text: string) => Promise<Array<number>>;\n     9→     9→     9→\n    10→    10→    10→const TITLE_REFERENCE =\n    11→    11→    11→  \"recipe name, dish title, name of the food, nazwa przepisu, nazwa dania\";\n    12→    12→    12→const HEADER_REFERENCE =\n    13→    13→    13→  \"ingredients list, cooking directions, section heading, składniki, przygotowanie, sposób wykonania\";\n    14→    14→    14→const NOISE_REFERENCE =\n    15→    15→    15→  \"page number, table of contents, book footer, garbled text\";\n    16→    16→    16→\n    17→    17→    17→/**\n    18→    18→    18→ * Measurement units commonly found in ingredient lists\n    19→    19→    19→ */\n    20→    20→    20→const MEASUREMENT_PATTERNS = [\n    21→    21→    21→  // English\n    22→    22→    22→  \"cup\",\n    23→    23→    23→  \"cups\",\n    24→    24→    24→  \"tbsp\",\n    25→    25→    25→  \"tsp\",\n    26→    26→    26→  \"tablespoon\",\n    27→    27→    27→  \"teaspoon\",\n    28→    28→    28→  // \"oz\" and \"lb\" are matched with word boundaries in looksLikeIngredient\n    29→    29→    29→  // to avoid false positives (\"oz\" in \"mozzarella\", \"lb\" in \"albacore\")\n    30→    30→    30→  \"gram\",\n    31→    31→    31→  \"grams\",\n    32→    32→    32→  \"kg\",\n    33→    33→    33→  \"ml\",\n    34→    34→    34→  \"liter\",\n    35→    35→    35→  \"pinch\",\n    36→    36→    36→  \"dash\",\n    37→    37→    37→  \"handful\",\n    38→    38→    38→  // Polish\n    39→    39→    39→  \"łyżka\", \"łyżki\", \"łyżek\",           // tablespoon(s)\n    40→    40→    40→  \"łyżeczka\", \"łyżeczki\", \"łyżeczek\",   // teaspoon(s)\n    41→    41→    41→  \"szklanka\", \"szklanki\", \"szklanek\",    // cup(s)\n...\n</persisted-output>"}]},"parent_tool_use_id":null,"session_id":"52c225dd-138d-420c-8852-ee28a481d2ae","uuid":"ea82316b-610d-4679-a27b-81deecc73ecc","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/.claude/projects/-Users-eryk-napierala-Projects-fasola/52c225dd-138d-420c-8852-ee28a481d2ae/tool-results/toolu_013fRcrMWcjcL7J5zaQS8EwA.txt","content":"     1→     1→/**\n     2→     2→ * Title Extraction\n     3→     3→ * Extracts potential recipe title from OCR text using heuristics or semantic embeddings\n     4→     4→ */\n     5→     5→\n     6→     6→import { cosineSimilarity } from \"./embeddings\";\n     7→     7→\n     8→     8→export type EmbedFn = (text: string) => Promise<Array<number>>;\n     9→     9→\n    10→    10→const TITLE_REFERENCE =\n    11→    11→  \"recipe name, dish title, name of the food, nazwa przepisu, nazwa dania\";\n    12→    12→const HEADER_REFERENCE =\n    13→    13→  \"ingredients list, cooking directions, section heading, składniki, przygotowanie, sposób wykonania\";\n    14→    14→const NOISE_REFERENCE =\n    15→    15→  \"page number, table of contents, book footer, garbled text\";\n    16→    16→\n    17→    17→/**\n    18→    18→ * Measurement units commonly found in ingredient lists\n    19→    19→ */\n    20→    20→const MEASUREMENT_PATTERNS = [\n    21→    21→  // English\n    22→    22→  \"cup\",\n    23→    23→  \"cups\",\n    24→    24→  \"tbsp\",\n    25→    25→  \"tsp\",\n    26→    26→  \"tablespoon\",\n    27→    27→  \"teaspoon\",\n    28→    28→  // \"oz\" and \"lb\" are matched with word boundaries in looksLikeIngredient\n    29→    29→  // to avoid false positives (\"oz\" in \"mozzarella\", \"lb\" in \"albacore\")\n    30→    30→  \"gram\",\n    31→    31→  \"grams\",\n    32→    32→  \"kg\",\n    33→    33→  \"ml\",\n    34→    34→  \"liter\",\n    35→    35→  \"pinch\",\n    36→    36→  \"dash\",\n    37→    37→  \"handful\",\n    38→    38→  // Polish\n    39→    39→  \"łyżka\", \"łyżki\", \"łyżek\",           // tablespoon(s)\n    40→    40→  \"łyżeczka\", \"łyżeczki\", \"łyżeczek\",   // teaspoon(s)\n    41→    41→  \"szklanka\", \"szklanki\", \"szklanek\",    // cup(s)\n    42→    42→  \"szczypta\",                            // pinch\n    43→    43→  \"garść\",                               // handful\n    44→    44→  \"opakowanie\", \"opakowania\",            // package(s)\n    45→    45→  \"plasterek\", \"plasterki\",             // slice(s)\n    46→    46→];\n    47→    47→\n    48→    48→/**\n    49→    49→ * Patterns that identify recipe metadata lines (not titles)\n    50→    50→ */\n    51→    51→const METADATA_PATTERNS = [\n    52→    52→  /^(SERVES?|MAKES?|YIELDS?)\\b/i,\n    53→    53→  /^(PREP(ARATION)?|COOK(ING)?|PROOF|RISING|FERMENTATION|REST(ING)?)\\s*(AND\\s*)?(COOK(ING)?)?\\s*TIME/i,\n    54→    54→  /^SAMPLE\\s+SCHEDULE\\b/i,\n    55→    55→  /^BULK\\s+FERMENTATION\\b/i,\n    56→    56→  /^(THIS\\s+RECIPE\\s+)?MAKES\\b/i,\n    57→    57→  // Polish serving-size patterns: \"NA 3 PAPRYKI\", \"NA OKOŁO 1 KG\", \"DLA 4 OSÓB\"\n    58→    58→  /^NA\\s+(\\d|OKOŁO)\\b/i,\n    59→    59→  /^DLA\\s+\\d/i,\n    60→    60→  // OCR-resilient: \"DLA\" + any token + serving-unit word (handles DLA & OSOB, DLA § OSOB, etc.)\n    61→    61→  /^DLA\\s+\\S+\\s+OSOB/i,\n    62→    62→  // OCR-resilient: \"DLA\" + single non-alphanumeric char (common digit→symbol OCR error)\n    63→    63→  /^DLA\\s+[^a-zA-Z0-9\\s]\\s/i,\n    64→    64→  // Time-unit metadata: any line containing \"N MIN\" or \"N GODZ\" is prep/cook/rest time,\n    65→    65→  // regardless of OCR-corrupted prefix (catches PRZYGOTOWANTE, GOTOMANTE, etc.)\n    66→    66→  /\\b\\d+\\s*MIN\\b/i,\n    67→    67→  /\\b\\d+\\s*GODZ/i,\n    68→    68→  // Season/category indicators\n    69→    69→  /^SEZON\\s*:/i,\n    70→    70→  /^KATEGORIA\\s*:/i,\n    71→    71→  /^RODZAJ\\s*:/i,\n    72→    72→  /^PORCJI\\s*:/i,       // Polish serving count\n    73→    73→  /^PORTIONS?\\s*:/i,    // English serving count\n    74→    74→  /^CZ[ĘE]Ś[ĆC]\\s*\\d/i,   // CZĘŚĆ 1: ... (Polish \"Part 1:\")\n    75→    75→  /^PART\\s+\\d/i,             // PART 1: ... (English)\n    76→    76→];\n    77→    77→\n    78→    78→/**\n    79→    79→ * Single-word non-title words — standalone OCR fragments unlikely to be recipe titles\n    80→    80→ */\n    81→    81→const NON_TITLE_WORDS = new Set([\n    82→    82→  \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"are\", \"was\",\n    83→    83→  \"has\", \"his\", \"her\", \"its\", \"our\", \"who\", \"how\", \"may\", \"new\", \"now\",\n    84→    84→  \"old\", \"see\", \"way\", \"did\", \"get\", \"let\", \"say\", \"she\", \"too\", \"use\",\n    85→    85→  \"buns\", \"with\",\n    86→    86→]);\n    87→    87→\n    88→    88→function looksLikeIngredient(line: string): boolean {\n    89→    89→  const lowerLine = line.toLowerCase();\n    90→    90→  if (MEASUREMENT_PATTERNS.some((pattern) => lowerLine.includes(pattern))) return true;\n    91→    91→  // Compact metric: \"100g\", \"50ml\", \"250g\" — digit immediately followed by g/ml/kg\n    92→    92→  if (/\\b\\d+\\s*(?:g|ml|kg)\\b/i.test(line)) return true;\n    93→    93→  // \"to taste\" / \"do smaku\" — qualitative ingredient with no unit\n    94→    94→  if (/\\bto taste\\b/i.test(line) || /\\bdo smaku\\b/i.test(line)) return true;\n    95→    95→  return false;\n    96→    96→}\n    97→    97→\n    98→    98→function startsWithNumber(line: string): boolean {\n    99→    99→  // Match lines starting with a digit, or bullet-then-digit (e.g., \"- 2 jajka\")\n   100→   100→  return /^\\s*(?:[-•*]\\s*)?\\d/.test(line);\n   101→   101→}\n   102→   102→\n   103→   103→function stripDiacritics(text: string): string {\n   104→   104→  return text.normalize(\"NFKD\").replace(/[\\u0300-\\u036f]/g, \"\");\n   105→   105→}\n   106→   106→\n   107→   107→/**\n   108→   108→ * Known recipe section labels — these are structural headers, not recipe titles.\n   109→   109→ * Matched case-insensitively after trimming, stripping trailing punctuation, and stripping diacritics.\n   110→   110→ * Polish entries are stored without diacritics for OCR resilience (e.g. \"SKLADNIKI\" matches \"składniki\").\n   111→   111→ */\n   112→   112→const SECTION_LABELS = new Set([\n   113→   113→  // English\n   114→   114→  \"ingredients\", \"directions\", \"instructions\", \"method\", \"preparation\",\n   115→   115→  \"steps\", \"notes\", \"tip\", \"tips\", \"variations\", \"variation\",\n   116→   116→  \"garnish\", \"topping\", \"toppings\", \"frosting\", \"filling\",\n   117→   117→  \"serving suggestion\", \"serving suggestions\", \"serving\",\n   118→   118→  \"glaze\", \"for the sauce\", \"for the filling\", \"for the dough\",\n   119→   119→  \"for the topping\", \"for the glaze\", \"for the pasta dough\",\n   120→   120→  \"for the pasta\", \"for the crust\",\n   121→   121→  // Polish — recipe section labels (stored without diacritics for OCR resilience)\n   122→   122→  \"skladniki\", \"przygotowanie\", \"sposob przygotowania\", \"sposob wykonania\",\n   123→   123→  \"wykonanie\", \"wskazowki\", \"podpowiedz\", \"warianty\",\n   124→   124→  \"sos\", \"nadzienie\", \"polewa\", \"lukier\", \"ciasto\",  // ciasto = dough/pastry base (recipe-internal section AND chapter label)\n   125→   125→  \"instrukcje\",       // instructions\n   126→   126→  \"uwagi\",            // notes/remarks\n   127→   127→  \"notatki\",          // notes\n   128→   128→  \"podawanie\",        // serving\n   129→   129→  \"przechowywanie\",   // storage\n   130→   130→  // Polish — recipe-book chapter/category labels (food groups, meal types)\n   131→   131→  \"warzywa\",          // vegetables\n   132→   132→  \"mieso\",            // meat (mięso)\n   133→   133→  \"miesa\",            // meats (mięsa)\n   134→   134→  \"ryby\",             // fish\n   135→   135→  \"owoce morza\",      // seafood\n   136→   136→  \"zupy\",             // soups\n   137→   137→  \"salatki\",          // salads (sałatki)\n   138→   138→  \"desery\",           // desserts\n   139→   139→  \"napoje\",           // drinks\n   140→   140→  \"pieczywo\",         // bread/baked goods\n   141→   141→  \"przekaski\",        // appetizers/snacks\n   142→   142→  \"sniadania\",        // breakfasts (śniadania)\n   143→   143→  \"obiady\",           // dinners/lunches\n   144→   144→  \"kolacje\",          // suppers\n   145→   145→  \"makarony\",         // pasta dishes\n   146→   146→  \"kasza\",            // groats/grains\n   147→   147→  \"kasze\",            // groats/grains (plural)\n   148→   148→  \"dania glowne\",     // main courses (dania główne)\n   149→   149→  \"przystawki\",       // starters\n   150→   150→  \"dodatki\",          // side dishes\n   151→   151→  \"przetwory\",        // preserves\n   152→   152→  \"wypieki\",          // baked goods\n   153→   153→  \"ciasta\",           // cakes (plural)\n   154→   154→  \"ciastka\",          // cookies\n   155→   155→  \"torty\",            // layer cakes\n   156→   156→  \"placki\",           // pancakes/flatbreads\n   157→   157→  \"koktajle\",         // cocktails/smoothies\n   158→   158→]);\n   159→   159→\n   160→   160→function isSectionLabel(text: string): boolean {\n   161→   161→  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n   162→   162→  return SECTION_LABELS.has(normalized);\n   163→   163→}\n   164→   164→\n   165→   165→/**\n   166→   166→ * Recipe-internal section labels that should ALWAYS block multi-line joins,\n   167→   167→ * even when the combined word count is ≥ 3.\n   168→   168→ * Category labels (\"zupy\", \"placki\", etc.) are NOT in this set — they can\n   169→   169→ * legitimately start a multi-word recipe title like \"Zupy Zimowe Warzywne\".\n   170→   170→ */\n   171→   171→const ALWAYS_BLOCK_JOIN_LABELS = new Set([\n   172→   172→  \"ingredients\", \"directions\", \"instructions\", \"method\", \"preparation\",\n   173→   173→  \"steps\", \"notes\", \"tip\", \"tips\", \"variations\", \"variation\",\n   174→   174→  \"garnish\", \"topping\", \"toppings\", \"frosting\", \"filling\",\n   175→   175→  \"serving suggestion\", \"serving suggestions\", \"serving\",\n   176→   176→  \"glaze\", \"instrukcje\", \"uwagi\", \"notatki\", \"podawanie\", \"przechowywanie\",\n   177→   177→  \"skladniki\", \"przygotowanie\", \"sposob przygotowania\", \"sposob wykonania\",\n   178→   178→  \"wykonanie\", \"wskazowki\", \"podpowiedz\", \"warianty\",\n   179→   179→  \"sos\", \"nadzienie\", \"polewa\", \"lukier\", \"ciasto\",\n   180→   180→]);\n   181→   181→\n   182→   182→function isAlwaysBlockJoinLabel(text: string): boolean {\n   183→   183→  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n   184→   184→  return ALWAYS_BLOCK_JOIN_LABELS.has(normalized);\n   185→   185→}\n   186→   186→\n   187→   187→function isAllCaps(line: string): boolean {\n   188→   188→  const letters = line.replace(/[^a-zA-Z]/g, \"\");\n   189→   189→  return letters.length > 0 && letters === letters.toUpperCase();\n   190→   190→}\n   191→   191→\n   192→   192→function looksLikeMetadata(text: string): boolean {\n   193→   193→  return METADATA_PATTERNS.some((pattern) => pattern.test(text.trim()));\n   194→   194→}\n   195→   195→\n   196→   196→function isLikelyGarbled(text: string): boolean {\n   197→   197→  const letters = text.replace(/[^a-zA-Z]/g, \"\");\n   198→   198→  if (letters.length < 2) return true;\n   199→   199→\n   200→   200→  // Check vowel ratio — English/Polish text typically has 30–50% vowels\n   201→   201→  const vowels = letters.replace(/[^aeiouAEIOUyYąęóĄĘÓ]/g, \"\").length;\n   202→   202→  const vowelRatio = vowels / letters.length;\n   203→   203→  if (vowelRatio < 0.10 || vowelRatio > 0.85) return true;\n   204→   204→\n   205→   205→  // Single orphaned word ≤3 letters that isn't a common word\n   206→   206→  const words = text.trim().split(/\\s+/);\n   207→   207→  const COMMON_SHORT = new Set([\n   208→   208→    \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"had\", \"her\",\n   209→   209→    \"was\", \"one\", \"our\", \"out\", \"are\", \"has\", \"his\", \"how\", \"its\", \"may\",\n   210→   210→    \"new\", \"now\", \"old\", \"see\", \"way\", \"who\", \"did\", \"get\", \"let\", \"say\",\n   211→   211→    \"she\", \"too\", \"use\",\n   212→   212→  ]);\n   213→   213→  // Count all Unicode letters (not just ASCII) so Polish words like \"Żur\" (3 letters) pass\n   214→   214→  const unicodeLetters = text.trim().replace(/[^a-zA-ZąćęłńóśźżĄĆĘŁŃÓŚŹŻ]/g, \"\");\n   215→   215→  if (words.length === 1 && unicodeLetters.length <= 3 && !COMMON_SHORT.has(text.trim().toLowerCase())) {\n   216→   216→    return true;\n   217→   217→  }\n   218→   218→\n   219→   219→  // Single word with internal lowercase→uppercase transition — OCR noise (e.g., \"UuIw\", \"aBC\")\n   220→   220→  // No recipe title uses this pattern as a standalone single-word candidate.\n   221→   221→  if (words.length === 1 && /[a-z][A-Z]/.test(text.trim())) {\n   222→   222→    return true;\n   223→   223→  }\n   224→   224→\n   225→   225→  // Recipe titles never start with a lowercase letter\n   226→   226→  if (/^[a-z]/.test(text.trim())) {\n   227→   227→    return true;\n   228→   228→  }\n   229→   229→\n   230→   230→  // Mid-text sentence boundary (\". \" followed by a letter) — body text fragment spliced from multiple sentences\n   231→   231→  const trimmed = text.trim();\n   232→   232→  if (/\\.\\s+[a-zA-Z]/.test(trimmed) && !trimmed.endsWith(\")\")) {\n   233→   233→    return true;\n   234→   234→  }\n   235→   235→\n   236→   236→  // Multi-word candidate containing a garbled OCR fragment: a short lowercase word that isn't a known short word\n   237→   237→  if (words.length >= 2) {\n   238→   238→    const commonShort2 = new Set([\n   239→   239→      \"a\", \"i\", \"of\", \"or\", \"to\", \"in\", \"on\", \"is\", \"it\", \"an\",\n   240→   240→      \"as\", \"at\", \"by\", \"do\", \"go\", \"if\", \"no\", \"so\", \"up\", \"we\",\n   241→   241→      \"w\", \"z\",   // Polish prepositions (basic)\n   242→   242→      \"ze\", \"bo\", \"na\", \"ni\", \"po\", \"ku\", \"od\", \"za\", \"co\",  // Polish prepositions (extended)\n   243→   243→    ]);\n   244→   244→    const hasGarbledWord = words.some(\n   245→   245→      (w) =>\n   246→   246→        /^[a-z]/.test(w) &&\n   247→   247→        w.replace(/[^a-z]/g, \"\").length <= 2 &&\n   248→   248→        !commonShort2.has(w.toLowerCase())\n   249→   249→    );\n   250→   250→    if (hasGarbledWord) {\n   251→   251→      return true;\n   252→   252→    }\n   253→   253→  }\n   254→   254→\n   255→   255→  return false;\n   256→   256→}\n   257→   257→\n   258→   258→const COOKING_INSTRUCTION_STARTS = /^(beat|fold|stir|mix|add|pour|bake|cook|cool|remove|place|combine|whisk|knead|roll|spread|brush|slice|chop|dice|mince|drain|rinse|peel|grate|melt|simmer|boil|fry|sauté|saute|roast|grill|broil|steam|let|set|transfer|serve|garnish|arrange|sprinkle|season|preheat|cover|uncover|reduce|bring|toss|cut|trim|shape|form)\\b/i;\n   259→   259→\n   260→   260→// Polish imperative cooking verbs (with OCR-resilient forms — no diacritics required).\n   261→   261→// These cover the most common recipe instruction starters. Includes common OCR-corrupted\n   262→   262→// forms (e.g., \"Smaż\" → \"Smaz\", \"Dodaj\" → \"Dodaj\").\n   263→   263→// Note: only verbs that NEVER start a recipe title. \"Piecz\" (bake) is excluded because\n   264→   264→// \"Pieczeń\" (roast) and \"Pieczarki\" (mushrooms) share the prefix.\n   265→   265→const POLISH_COOKING_INSTRUCTION_STARTS = /^(podawaj|dodaj|dodawaj|sma[zż]|gotuj|odced[zź]|wymieszaj|mieszaj|wlej|nalej|przygotuj|zagotuj|pokr[oó]j|obierz|wrzuc|wrzuć|usma[zż]|podsma[zż]|prze[lł][oó][zż]|zblenduj|ubij|roztrzepaj|rozprowad[zź]|wyrob|zamieszaj|posyp|polej|odstaw|na[lł][oó][zż]|przykryj|odkryj|wstaw|zdejmij|ods[aą]cz|rozgrzej|posiekaj|zetrzyj|wy[lł][oó][zż]|wyjmij|ukr[oó]j|przekr[oó]j|formuj|ugniataj|rozwałkuj)\\b/i;\n   266→   266→\n   267→   267→function looksLikeCookingInstruction(text: string): boolean {\n   268→   268→  const words = text.trim().split(/\\s+/);\n   269→   269→  if (words.length < 4) return false;  // Instructions are multi-word sentences\n   270→   270→  if (COOKING_INSTRUCTION_STARTS.test(text.trim())) return true;\n   271→   271→  if (POLISH_COOKING_INSTRUCTION_STARTS.test(text.trim())) return true;\n   272→   272→  return false;\n   273→   273→}\n   274→   274→\n   275→   275→function passesHardFilters(text: string): boolean {\n   276→   276→  if (text.length < 3 || text.length > 80) return false;\n   277→   277→  if (looksLikeIngredient(text)) return false;\n   278→   278→  if (startsWithNumber(text)) return false;\n   279→   279→  if (looksLikeMetadata(text)) return false;\n   280→   280→  if (isLikelyGarbled(text)) return false;\n   281→   281→  if (looksLikeCookingInstruction(text)) return false;\n   282→   282→  // Pipe-separated lines are book category/chapter headers, not recipe titles\n   283→   283→  if (text.includes(\" | \")) return false;\n   284→   284→  // Trailing page number (e.g. \"VEGETABLE SIDES                         145\")\n   285→   285→  if (/\\s{3,}\\d{1,4}\\s*$/.test(text)) return false;\n   286→   286→  // Slash-separated breadcrumbs (e.g., \"/ Jesien / Zupy\") are navigation, not titles\n   287→   287→  // Only filter when 2+ slashes are present — single-slash lines like\n   288→   288→  // \"TITLE / SUBTITLE\" are legitimate continuation-merged titles\n   289→   289→  if ((text.match(/\\//g) || []).length >= 2) return false;\n   290→   290→  // Bullet-list items (ingredients or instruction steps) are never titles\n   291→   291→  if (/^\\s*[-•*]\\s/.test(text)) return false;\n   292→   292→  // \"For the sauce:\", \"For the filling:\" etc. are sub-section headers\n   293→   293→  if (/^For the\\s+/i.test(text) && /:\\s*$/.test(text)) return false;\n   294→   294→  // Square-bracket category tags (e.g., \"[CLASSIC FALL SOUPS]\")\n   295→   295→  if (/^\\[.*\\]$/.test(text.trim())) return false;\n   296→   296→  // Known recipe section labels are structural headers, not titles\n   297→   297→  if (isSectionLabel(text)) return false;\n   298→   298→  // Single-word non-title fragments\n   299→   299→  const words = text.trim().split(/\\s+/);\n   300→   300→  if (words.length === 1 && NON_TITLE_WORDS.has(text.trim().toLowerCase())) return false;\n   301→   301→  // Lines with ≥8 words are almost certainly body text, not titles.\n   302→   302→  // Exception: multi-title compounds with \" + \", \" : \", or \" & \" separators are allowed.\n   303→   303→  if (words.length >= 8 && !/ [+:&/] /.test(text)) return false;\n   304→   304→  return true;\n   305→   305→}\n   306→   306→\n   307→   307→/**\n   308→   308→ * Detect initial burst of short garbled lines.\n   309→   309→ * Returns the index of the first non-garbled or long line.\n   310→   310→ */\n   311→   311→function findBurstEnd(lines: Array<{ text: string }>): number {\n   312→   312→  let i = 0;\n   313→   313→  while (i < lines.length && lines[i].text.length < 20 && isLikelyGarbled(lines[i].text) && !isAllCaps(lines[i].text)) {\n   314→   314→    i++;\n   315→   315→  }\n   316→   316→  // Skip long instruction-like prologues: if 5+ consecutive lines look like cooking instructions,\n   317→   317→  // skip them to find the actual title region.\n   318→   318→  if (i === 0) {\n   319→   319→    let j = 0;\n   320→   320→    while (j < lines.length && looksLikeCookingInstruction(lines[j].text)) {\n   321→   321→      j++;\n   322→   322→    }\n   323→   323→    if (j >= 5) {\n   324→   324→      i = j;\n   325→   325→    }\n   326→   326→  }\n   327→   327→  // Skip prose prologues: mid-recipe body text before the actual title.\n   328→   328→  // If 3+ consecutive lines look like running body text (lowercase start, continuation,\n   329→   329→  // or sentence-ending with many words), skip them.\n   330→   330→  if (i === 0) {\n   331→   331→    let j = 0;\n   332→   332→    while (j < lines.length) {\n   333→   333→      const t = lines[j].text;\n   334→   334→      const isBodyText = (\n   335→   335→        /^[a-ząćęłńóśźż]/.test(t) ||\n   336→   336→        t.endsWith(\",\") ||\n   337→   337→        (t.endsWith(\".\") && wordCount(t) > 4)\n   338→   338→      ) && wordCount(t) >= 4;\n   339→   339→      if (isBodyText) j++;\n   340→   340→      else break;\n   341→   341→    }\n   342→   342→    if (j >= 3) i = j;\n   343→   343→  }\n   344→   344→  return i;\n   345→   345→}\n   346→   346→\n   347→   347→function stripParentheticalGloss(text: string): string {\n   348→   348→  // Strip trailing English-gloss parentheticals from ALL_CAPS titles.\n   349→   349→  // e.g. \"PIEROGI RUSKIE (Boiled Dumplings with Potato and Cheese)\" → \"PIEROGI RUSKIE\"\n   350→   350→  // Keep if parenthetical is ALL_CAPS (variation/subtitle in same language).\n   351→   351→  // Keep if both base and paren are mixed-case (both are part of the title).\n   352→   352→  const match = text.match(/^(.+?)\\s*\\(([^)]+)\\)\\s*$/);\n   353→   353→  if (!match) return text;\n   354→   354→  const [, base, paren] = match;\n   355→   355→  if (isAllCaps(paren)) return text;\n   356→   356→  if (!isAllCaps(base) && !isAllCaps(paren)) return text;\n   357→   357→  return base.trim();\n   358→   358→}\n   359→   359→\n   360→   360→function stripPageNumber(text: string): string {\n   361→   361→  // \"34  Berry Jam\" → \"Berry Jam\" (2+ spaces distinguishes from \"2 eggs\")\n   362→   362→  const match = text.match(/^\\d{1,3}\\s{2,}(.+)$/);\n   363→   363→  return match ? match[1] : text;\n   364→   364→}\n   365→   365→\n   366→   366→function wordCount(text: string): number {\n   367→   367→  return text.split(/\\s+/).filter((w) => w.length > 0).length;\n   368→   368→}\n   369→   369→\n   370→   370→/**\n   371→   371→ * Build candidate strings from lines: single lines plus multi-line joins (2-3 consecutive).\n   372→   372→ * Skips initial burst of short garbled lines. Scans all remaining lines. Caps at 25.\n   373→   373→ */\n   374→   374→export type CandidateOrigin = \"single\" | \"2-line\" | \"3-line\";\n   375→   375→\n   376→   376→function buildCandidates(\n   377→   377→  lines: Array<string>\n   378→   378→): Array<{ text: string; position: number; origin: CandidateOrigin }> {\n   379→   379→  const nonEmptyLines: Array<{ text: string; index: number }> = [];\n   380→   380→\n   381→   381→  for (let i = 0; i < lines.length; i++) {\n   382→   382→    const trimmed = lines[i].trim();\n   383→   383→    if (trimmed.length > 0) {\n   384→   384→      nonEmptyLines.push({ text: trimmed, index: i });\n   385→   385→    }\n   386→   386→  }\n   387→   387→\n   388→   388→  const burstEnd = findBurstEnd(nonEmptyLines);\n   389→   389→\n   390→   390→  // Pre-merge consecutive short ALL_CAPS lines (OCR-fragmented headings).\n   391→   391→  // When a sequence of 2+ ALL_CAPS lines each has ≤2 words and ≤25 chars, they are\n   392→   392→  // almost certainly OCR fragments of a single heading. Merge them into one line so\n   393→   393→  // the complete title enters the candidate pool without hitting the 3-line join ceiling.\n   394→   394→  const capsCoalesced: Array<{ text: string; index: number }> = [];\n   395→   395→  let ci = burstEnd;\n   396→   396→  while (ci < nonEmptyLines.length) {\n   397→   397→    const line = nonEmptyLines[ci];\n   398→   398→    if (\n   399→   399→      isAllCaps(line.text) &&\n   400→   400→      wordCount(line.text) <= 2 &&\n   401→   401→      line.text.length <= 25 &&\n   402→   402→      !isSectionLabel(line.text) &&\n   403→   403→      !looksLikeMetadata(line.text)\n   404→   404→    ) {\n   405→   405→      let merged = line.text;\n   406→   406→      const startIndex = line.index;\n   407→   407→      let j = ci + 1;\n   408→   408→      while (j < nonEmptyLines.length) {\n   409→   409→        const next = nonEmptyLines[j];\n   410→   410→        if (\n   411→   411→          isAllCaps(next.text) &&\n   412→   412→          wordCount(next.text) <= 2 &&\n   413→   413→          next.text.length <= 25 &&\n   414→   414→          !isSectionLabel(next.text) &&\n   415→   415→          !looksLikeMetadata(next.text) &&\n   416→   416→          (merged + \" \" + next.text).length <= 80\n   417→   417→        ) {\n   418→   418→          merged += \" \" + next.text;\n   419→   419→          j++;\n   420→   420→        } else {\n   421→   421→          break;\n   422→   422→        }\n   423→   423→      }\n   424→   424→      if (j > ci + 1) {\n   425→   425→        capsCoalesced.push({ text: merged, index: startIndex });\n   426→   426→        ci = j;\n   427→   427→        continue;\n   428→   428→      }\n   429→   429→    }\n   430→   430→    capsCoalesced.push(line);\n   431→   431→    ci++;\n   432→   432→  }\n   433→   433→\n   434→   434→  // Pre-merge continuation lines: a line starting with /&+:( is never a standalone title.\n   435→   435→  // Merge it into the preceding line so the complete title enters the pool as a single candidate,\n   436→   436→  // avoiding the fragile chain of conditions required by the downstream join survival logic.\n   437→   437→  // Limitation: only one continuation line per preceding line is merged. Titles split across\n   438→   438→  // three or more lines with continuation tokens (rare in practice) are not handled here —\n   439→   439→  // the downstream 2-line and 3-line join candidates cover those cases instead.\n   440→   440→  const mergedLines: Array<{ text: string; index: number }> = [];\n   441→   441→  for (let i = 0; i < capsCoalesced.length; i++) {\n   442→   442→    const line = capsCoalesced[i];\n   443→   443→    if (i + 1 < capsCoalesced.length) {\n   444→   444→      const nextText = capsCoalesced[i + 1].text;\n   445→   445→      if (/^[/&+:(]/.test(nextText)) {\n   446→   446→        mergedLines.push({ text: `${line.text} ${nextText}`, index: line.index });\n   447→   447→        i++;\n   448→   448→        continue;\n   449→   449→      }\n   450→   450→    }\n   451→   451→    mergedLines.push(line);\n   452→   452→  }\n   453→   453→\n   454→   454→  const candidates: Array<{ text: string; position: number; origin: CandidateOrigin }> = [];\n   455→   455→  const seen = new Set<string>();\n   456→   456→\n   457→   457→  // Build a set of positions to skip: short ALL_CAPS lines immediately following metadata\n   458→   458→  const metadataContinuationPositions = new Set<number>();\n   459→   459→  for (let i = 0; i < mergedLines.length - 1; i++) {\n   460→   460→    if (looksLikeMetadata(mergedLines[i].text)) {\n   461→   461→      const next = mergedLines[i + 1];\n   462→   462→      if (isAllCaps(next.text) && wordCount(next.text) <= 2 && next.text.length <= 15) {\n   463→   463→        metadataContinuationPositions.add(next.index);\n   464→   464→      }\n   465→   465→    }\n   466→   466→  }\n   467→   467→\n   468→   468→  for (let i = 0; i < mergedLines.length; i++) {\n   469→   469→    const line = mergedLines[i];\n   470→   470→\n   471→   471→    // Skip metadata continuation fragments\n   472→   472→    if (metadataContinuationPositions.has(line.index)) continue;\n   473→   473→\n   474→   474→    // Single line — strip page-number prefixes and parenthetical glosses before scoring\n   475→   475→    const singleText = stripParentheticalGloss(stripPageNumber(line.text));\n   476→   476→    if (passesHardFilters(singleText)) {\n   477→   477→      const norm = singleText.toLowerCase();\n   478→   478→      if (!seen.has(norm)) {\n   479→   479→        seen.add(norm);\n   480→   480→        candidates.push({ text: singleText, position: line.index, origin: \"single\" });\n   481→   481→      }\n   482→   482→    }\n   483→   483→\n   484→   484→    // 2-line join — skip if first line is a section label AND join would be ≤2 words\n   485→   485→    // (a section label followed by modifiers is likely a recipe title, not a category header)\n   486→   486→    if (i + 1 < mergedLines.length) {\n   487→   487→      const joined2 = `${line.text} ${mergedLines[i + 1].text}`;\n   488→   488→      const shouldBlock2 = isSectionLabel(line.text) &&\n   489→   489→        (wordCount(joined2) <= 2 || isAlwaysBlockJoinLabel(line.text));\n   490→   490→      if (!shouldBlock2 && passesHardFilters(joined2)) {\n   491→   491→        const norm = joined2.toLowerCase();\n   492→   492→        if (!seen.has(norm)) {\n   493→   493→          seen.add(norm);\n   494→   494→          candidates.push({ text: joined2, position: line.index, origin: \"2-line\" });\n   495→   495→        }\n   496→   496→      }\n   497→   497→    }\n   498→   498→\n   499→   499→    // 3-line join — skip if first line is a section label AND join would be ≤2 words\n   500→   500→    if (i + 2 < mergedLines.length) {\n   501→   501→      const joined3 = `${line.text} ${mergedLines[i + 1].text} ${mergedLines[i + 2].text}`;\n   502→   502→      const shouldBlock3 = isSectionLabel(line.text) &&\n   503→   503→        (wordCount(joined3) <= 2 || isAlwaysBlockJoinLabel(line.text));\n   504→   504→      if (!shouldBlock3 && passesHardFilters(joined3)) {\n   505→   505→        const norm = joined3.toLowerCase();\n   506→   506→        if (!seen.has(norm)) {\n   507→   507→          seen.add(norm);\n   508→   508→          candidates.push({ text: joined3, position: line.index, origin: \"3-line\" });\n   509→   509→        }\n   510→   510→      }\n   511→   511→    }\n   512→   512→  }\n   513→   513→\n   514→   514→  // Pre-filter to 25 before embedding calls: prefer ALL_CAPS and short candidates.\n   515→   515→  // Position-based scoring handles final ranking.\n   516→   516→  if (candidates.length > 25) {\n   517→   517→    const prioritized = candidates.slice().sort((a, b) => {\n   518→   518→      const aAllCaps = isAllCaps(a.text) ? 0 : 1;\n   519→   519→      const bAllCaps = isAllCaps(b.text) ? 0 : 1;\n   520→   520→      if (aAllCaps !== bAllCaps) return aAllCaps - bAllCaps;\n   521→   521→      const aShort = wordCount(a.text) <= 5 ? 0 : 1;\n   522→   522→      const bShort = wordCount(b.text) <= 5 ? 0 : 1;\n   523→   523→      return aShort - bShort;\n   524→   524→    });\n   525→   525→    return prioritized.slice(0, 25);\n   526→   526→  }\n   527→   527→\n   528→   528→  return candidates;\n   529→   529→}\n   530→   530→\n   531→   531→// Module-level cache for reference embeddings\n   532→   532→let cachedTitleRefEmbedding: Array<number> | null = null;\n   533→   533→let cachedHeaderRefEmbedding: Array<number> | null = null;\n   534→   534→let cachedNoiseRefEmbedding: Array<number> | null = null;\n   535→   535→\n   536→   536→export function _resetEmbeddingCacheForTests(): void {\n   537→   537→  cachedTitleRefEmbedding = null;\n   538→   538→  cachedHeaderRefEmbedding = null;\n   539→   539→  cachedNoiseRefEmbedding = null;\n   540→   540→}\n   541→   541→\n   542→   542→export async function extractTitleWithEmbeddings(\n   543→   543→  text: string,\n   544→   544→  embed: EmbedFn\n   545→   545→): Promise<string | undefined> {\n   546→   546→  if (!text || text.trim().length === 0) {\n   547→   547→    return undefined;\n   548→   548→  }\n   549→   549→\n   550→   550→  const lines = text.split(\"\\n\");\n   551→   551→  const candidates = buildCandidates(lines);\n   552→   552→\n   553→   553→  if (candidates.length === 0) {\n   554→   554→    return undefined;\n   555→   555→  }\n   556→   556→\n   557→   557→  // Cache reference embeddings\n   558→   558→  if (!cachedTitleRefEmbedding) {\n   559→   559→    cachedTitleRefEmbedding = await embed(TITLE_REFERENCE);\n   560→   560→  }\n   561→   561→  if (!cachedHeaderRefEmbedding) {\n   562→   562→    cachedHeaderRefEmbedding = await embed(HEADER_REFERENCE);\n   563→   563→  }\n   564→   564→  if (!cachedNoiseRefEmbedding) {\n   565→   565→    cachedNoiseRefEmbedding = await embed(NOISE_REFERENCE);\n   566→   566→  }\n   567→   567→\n   568→   568→  // Find ALL_CAPS candidates with ≥2 words where every significant word has ≥4 alpha letters.\n   569→   569→  // Insignificant tokens (≤1 alpha letter: \"/\", \"&\", \"+\", \":\", \"D)\", etc.) are filtered before\n   570→   570→  // the check so that multi-line joins with continuation punctuation still qualify.\n   571→   571→  const isStructuralHeading = (c: { text: string }): boolean => {\n   572→   572→    if (!isAllCaps(c.text) || wordCount(c.text) < 2) return false;\n   573→   573→    const sigWords = c.text.trim().split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length > 1);\n   574→   574→    return sigWords.length >= 2 && sigWords.every((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   575→   575→  };\n   576→   576→\n   577→   577→  // Pass 1: compute rawScore for all candidates (embedding quality signal)\n   578→   578→  const rawScored: Array<{ text: string; position: number; origin: CandidateOrigin; rawScore: number; embedding: Array<number> }> = [];\n   579→   579→  for (const candidate of candidates) {\n   580→   580→    const embedding = await embed(candidate.text);\n   581→   581→    const titleSim = cosineSimilarity(embedding, cachedTitleRefEmbedding);\n   582→   582→    const headerSim = cosineSimilarity(embedding, cachedHeaderRefEmbedding);\n   583→   583→    const noiseSim = cosineSimilarity(embedding, cachedNoiseRefEmbedding);\n   584→   584→    const rawScore = titleSim - Math.max(headerSim, noiseSim);\n   585→   585→    rawScored.push({ text: candidate.text, position: candidate.position, origin: candidate.origin, rawScore, embedding });\n   586→   586→  }\n   587→   587→\n   588→   588→  // Select baseHeading by embedding quality (rawScore), not position.\n   589→   589→  // This prevents OCR-garbled fragments from claiming the structural heading slot.\n   590→   590→  const structuralCandidates = rawScored.filter((s) => isStructuralHeading(s));\n   591→   591→\n   592→   592→  // Penalize structural headings with truncated OCR words:\n   593→   593→  // if \"FRON\" appears and another heading has \"SAFFRON\", \"FRON\" is likely garbled.\n   594→   594→  for (const sc of structuralCandidates) {\n   595→   595→    const sigWords = sc.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   596→   596→    for (const other of structuralCandidates) {\n   597→   597→      if (other === sc) continue;\n   598→   598→      const otherSigWords = other.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   599→   599→      const hasTruncation = sigWords.some((w) =>\n   600→   600→        otherSigWords.some((ow) => ow !== w && ow.length > w.length && ow.endsWith(w))\n   601→   601→      );\n   602→   602→      if (hasTruncation) {\n   603→   603→        sc.rawScore = -1.0;  // Hard disqualification — truncated OCR artifact\n   604→   604→        break;\n   605→   605→      }\n   606→   606→    }\n   607→   607→  }\n   608→   608→\n   609→   609→  const bestStructural = structuralCandidates.length > 0\n   610→   610→    ? structuralCandidates.reduce((a, b) => {\n   611→   611→        const scoreDiff = a.rawScore - b.rawScore;\n   612→   612→        if (Math.abs(scoreDiff) > 0.03) return scoreDiff > 0 ? a : b;\n   613→   613→        // Tiebreak: single-line origin beats multi-line joins (avoids conflating two separate headings)\n   614→   614→        if (a.origin === \"single\" && b.origin !== \"single\") return a;\n   615→   615→        if (b.origin === \"single\" && a.origin !== \"single\") return b;\n   616→   616→        // Tiebreak: more words (more specific) → better\n   617→   617→        const wcDiff = wordCount(b.text) - wordCount(a.text);\n   618→   618→        if (wcDiff !== 0) return wcDiff > 0 ? b : a;\n   619→   619→        // Tiebreak: earlier position → better\n   620→   620→        return a.position < b.position ? a : b;\n   621→   621→      })\n   622→   622→    : null;\n   623→   623→  const baseHeading = bestStructural ?? undefined;\n   624→   624→\n   625→   625→  // When the best structural heading has a continuation on the next line introduced by a\n   626→   626→  // punctuation token (/, &, +, :, or parenthesis), prefer the longer 2-line join as the\n   627→   627→  // complete heading. E.g. \"SAFFRON WHEAT BUNS WITH QUARK\" + \"/ COTTAGE CHEESE (VARIATION D)\".\n   628→   628→  // Guard: the remainder after the prefix must start with a continuation character to avoid\n   629→   629→  // merging two separate consecutive recipe titles (FINNISH MILK FLATBREADS stays separate\n   630→   630→  // from FINNISH POTATO FLATBREADS because \"FINNISH\" does not start with a continuation token).\n   631→   631→  let firstStructuralHeading = baseHeading && (\n   632→   632→    rawScored.find((c) => {\n   633→   633→      if (!isStructuralHeading(c)) return false;\n   634→   634→      const hLower = baseHeading.text.toLowerCase();\n   635→   635→      const cLower = c.text.toLowerCase();\n   636→   636→      return cLower.startsWith(hLower + \" \") && /^[/&+:(]/.test(cLower.slice(hLower.length + 1));\n   637→   637→    }) ?? baseHeading\n   638→   638→  );\n   639→   639→\n   640→   640→  // Pass 2: apply bonuses\n   641→   641→  const scored: Array<{ text: string; position: number; origin: CandidateOrigin; score: number; rawScore: number; baseScore: number; thresholdScore: number }> = rawScored.map((rs) => {\n   642→   642→    // Position factor: multiplicative tiebreaker — amplifies existing signal, doesn't replace it\n   643→   643→    const relativePosition = rs.position / lines.length;\n   644→   644→    const positionFactor = relativePosition < 0.5\n   645→   645→      ? 1.0 + 0.12 * (1 - relativePosition * 2)\n   646→   646→      : 1.0;\n   647→   647→\n   648→   648→    // ALL_CAPS bonus: recipe books use ALL_CAPS for titles and section headings.\n   649→   649→    // Single-word ALL_CAPS terms are overwhelmingly section/category labels, not recipe titles;\n   650→   650→    // real recipe titles in ALL_CAPS are almost always multi-word. Reduce the bonus for single words.\n   651→   651→    const allCapsBonus = isAllCaps(rs.text) && rs.text.replace(/[^a-zA-Z]/g, \"\").length >= 4\n   652→   652→      ? (wordCount(rs.text) >= 2 ? 0.08 : 0.03)\n   653→   653→      : 0;\n   654→   654→\n   655→   655→    // Structural heading bonus: best ALL_CAPS heading (or its continuation join) is almost always the recipe title\n   656→   656→    const structuralBonus = firstStructuralHeading && rs.text === firstStructuralHeading.text ? 0.10 : 0;\n   657→   657→\n   658→   658→    // thresholdScore excludes structural bonus so the bonus doesn't inflate the threshold\n   659→   659→    // and prevent equally-valid structural headings from passing on multi-recipe pages.\n   660→   660→    const thresholdScore = rs.rawScore + allCapsBonus;\n   661→   661→    // baseScore excludes position factor — used for diagnostics and ranking\n   662→   662→    const baseScore = rs.rawScore + allCapsBonus + structuralBonus;\n   663→   663→    const score = rs.rawScore * positionFactor + allCapsBonus + structuralBonus;\n   664→   664→    return { text: rs.text, position: rs.position, origin: rs.origin, score, rawScore: rs.rawScore, baseScore, thresholdScore };\n   665→   665→  });\n   666→   666→\n   667→   667→  if (scored.length === 0) {\n   668→   668→    return undefined;\n   669→   669→  }\n   670→   670→\n   671→   671→  // --- Pre-threshold bilingual title detection ---\n   672→   672→  // When a mixed-case candidate at position 0 is followed by an ALL_CAPS candidate\n   673→   673→  // at position ≤ 2 that is semantically similar to it, this is a bilingual recipe\n   674→   674→  // page (e.g., Polish title + ALL_CAPS Korean romanization). Suppress confirmed\n   675→   675→  // translation candidates before computing threshold so their bonuses don't inflate\n   676→   676→  // the threshold beyond the mixed-case title's reach.\n   677→   677→  // Note: we check position ≤ 2 (local proximity), not global ALL_CAPS count, so\n   678→   678→  // section headers later in the document (SKŁADNIKI, WARZYWA, etc.) are irrelevant.\n   679→   679→  let translationCandidates: typeof scored = [];\n   680→   680→  let scoredForThreshold = scored;\n   681→   681→  const prePos0 = scored.find((s) => s.position === 0 && !isAllCaps(s.text));\n   682→   682→  if (prePos0) {\n   683→   683→    const nearbyAllCaps = scored.filter(\n   684→   684→      (s) => isAllCaps(s.text) && s.position >= 1 && s.position <= 2 && s.origin === \"single\"\n   685→   685→    );\n   686→   686→    const pos0Embedding = rawScored.find((r) => r.text === prePos0.text)?.embedding;\n   687→   687→\n   688→   688→    // Method 1: embedding similarity (works for related languages)\n   689→   689→    if (pos0Embedding && nearbyAllCaps.length > 0) {\n   690→   690→      translationCandidates = nearbyAllCaps.filter((cap) => {\n   691→   691→        const capEmbedding = rawScored.find((r) => r.text === cap.text)?.embedding;\n   692→   692→        if (!capEmbedding) return false;\n   693→   693→        return cosineSimilarity(pos0Embedding, capEmbedding) > 0.4;\n   694→   694→      });\n   695→   695→    }\n   696→   696→\n   697→   697→    // Method 2: layout-based detection (cross-lingual fallback).\n   698→   698→    // When embedding similarity is insufficient (e.g. Polish ↔ Korean romanization),\n   699→   699→    // detect bilingual layout by position and word overlap:\n   700→   700→    // mixed-case ≥2 words at pos 0 + ALL_CAPS ≥2 words at pos 1-2 with no shared words.\n   701→   701→    if (translationCandidates.length === 0 && wordCount(prePos0.text) >= 2) {\n   702→   702→      const pos0Words = new Set(\n   703→   703→        prePos0.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2)\n   704→   704→      );\n   705→   705→      translationCandidates = nearbyAllCaps.filter((cap) => {\n   706→   706→        if (wordCount(cap.text) < 2) return false;\n   707→   707→        const capWords = cap.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2);\n   708→   708→        return !capWords.some((w) => pos0Words.has(w));\n   709→   709→      });\n   710→   710→    }\n   711→   711→\n   712→   712→    if (translationCandidates.length > 0) {\n   713→   713→      // Suppress standalone translations and any multi-line joins that embed the translation\n   714→   714→      // as a suffix or substring (e.g. \"Smażona zielona fasolka GREEN BEANS BORKEUM\" ends with\n   715→   715→      // the translation; \"Title GREEN BEANS BORKEUM 그린빈\" includes it as a substring).\n   716→   716→      scoredForThreshold = scored.filter((s) => {\n   717→   717→        const sLower = s.text.toLowerCase();\n   718→   718→        return !translationCandidates.some((t) => {\n   719→   719→          const tLower = t.text.toLowerCase();\n   720→   720→          return sLower.startsWith(tLower) ||\n   721→   721→                 sLower.endsWith(\" \" + tLower) ||\n   722→   722→                 sLower.includes(\" \" + tLower);\n   723→   723→        });\n   724→   724→      });\n   725→   725→    }\n   726→   726→  }\n   727→   727→\n   728→   728→  // Fix 2: If the structural heading was identified as a bilingual translation, reassign it.\n   729→   729→  // This prevents the translation's ALL_CAPS bonus from inflating the threshold and ensures\n   730→   730→  // the fallback path in scored also uses the correct heading.\n   731→   731→  if (\n   732→   732→    translationCandidates.length > 0 &&\n   733→   733→    firstStructuralHeading &&\n   734→   734→    translationCandidates.some((t) => t.text === firstStructuralHeading!.text)\n   735→   735→  ) {\n   736→   736→    const nonTranslationStructural = structuralCandidates.filter(\n   737→   737→      (sc) => !translationCandidates.some((t) => t.text === sc.text)\n   738→   738→    );\n   739→   739→    const newHeading = nonTranslationStructural.length > 0\n   740→   740→      ? nonTranslationStructural.reduce((a, b) => a.rawScore > b.rawScore ? a : b)\n   741→   741→      : undefined;\n   742→   742→\n   743→   743→    // Patch scored array: remove old structural bonus, apply new one\n   744→   744→    for (const s of scored) {\n   745→   745→      if (s.text === firstStructuralHeading.text) {\n   746→   746→        s.score -= 0.10;\n   747→   747→        s.baseScore -= 0.10;\n   748→   748→      }\n   749→   749→      if (newHeading && s.text === newHeading.text) {\n   750→   750→        s.score += 0.10;\n   751→   751→        s.baseScore += 0.10;\n   752→   752→      }\n   753→   753→    }\n   754→   754→    // Update reference for downstream prefix-removal logic\n   755→   755→    firstStructuralHeading = newHeading ?? undefined;\n   756→   756→  }\n   757→   757→\n   758→   758→  // Subtitle suppression: when a short mixed-case title at position 0 is followed by a\n   759→   759→  // longer mixed-case candidate at position 1-2, the longer one is a subtitle/translation.\n   760→   760→  // Apply a penalty so the primary title (position 0) wins.\n   761→   761→  const pos0Primary = scored.find((s) => s.position === 0 && !isAllCaps(s.text) && wordCount(s.text) <= 5);\n   762→   762→  if (pos0Primary) {\n   763→   763→    const subtitleCandidates = scored.filter((s) =>\n   764→   764→      s.position >= 1 && s.position <= 2 &&\n   765→   765→      !isAllCaps(s.text) &&\n   766→   766→      wordCount(s.text) > wordCount(pos0Primary.text) + 2\n   767→   767→    );\n   768→   768→    for (const sub of subtitleCandidates) {\n   769→   769→      sub.score -= 0.15;\n   770→   770→    }\n   771→   771→  }\n   772→   772→\n   773→   773→  // Use thresholdScore (excludes structural bonus) so the structural bonus doesn't inflate\n   774→   774→  // the threshold and block equally-valid headings on multi-recipe pages.\n   775→   775→  const bestThresholdScore = Math.max(...scoredForThreshold.map((s) => s.thresholdScore));\n   776→   776→  const threshold = Math.max(0.08, bestThresholdScore * 0.7);\n   777→   777→\n   778→   778→  // Filter candidates above threshold\n   779→   779→  let selected = scoredForThreshold.filter((s) => s.score >= threshold);\n   780→   780→\n   781→   781→  // Empty-pool fallback: when threshold filtering discards every candidate,\n   782→   782→  // the hard filters' structural verdict should not be overruled by weak\n   783→   783→  // embedding differentiation. Return the best positional candidate.\n   784→   784→  if (selected.length === 0 && scored.length > 0) {\n   785→   785→    const fallback = scored\n   786→   786→      .slice()\n   787→   787→      .sort((a, b) => a.position - b.position || b.score - a.score);\n   788→   788→    selected = [fallback[0]];\n   789→   789→  }\n   790→   790→\n   791→   791→  // Remove word-boundary prefixes of firstStructuralHeading when the heading itself survived\n   792→   792→  // the threshold. Cases:\n   793→   793→  //   ARAYES case:  firstStructuralHeading = \"ARAYES SHRAK\" (2-word join qualifies; \"ARAYES\"\n   794→   794→  //     alone = 1 word, so it never qualified). Filter removes \"ARAYES\" so dedup keeps the join.\n   795→   795→  //   SAFFRON case: baseHeading was the partial line; continuation logic above upgraded\n   796→   796→  //     firstStructuralHeading to the full join. Filter removes the partial so dedup keeps join.\n   797→   797→  // Safety: only fires when the complete heading itself is in selected (passed the threshold).\n   798→   798→  if (firstStructuralHeading && selected.some((s) => s.text === firstStructuralHeading.text)) {\n   799→   799→    const fshLower = firstStructuralHeading.text.toLowerCase();\n   800→   800→    selected = selected.filter((s) => {\n   801→   801→      if (s.text === firstStructuralHeading.text) return true;\n   802→   802→      const sLower = s.text.toLowerCase();\n   803→   803→      // Remove s if it is a space-delimited prefix of the structural heading\n   804→   804→      return !fshLower.startsWith(sLower + \" \");\n   805→   805→    });\n   806→   806→  }\n   807→   807→\n   808→   808→  // Protect continuation joins: when a multi-line join (2-line or 3-line) survived the threshold\n   809→   809→  // and its second part starts with a continuation character, remove the single-line prefix/suffix\n   810→   810→  // so the dedup \"shorter wins\" rule doesn't destroy the complete join.\n   811→   811→  // Note: the pre-merge step above already handles the common Baked Eggs case (&/continuation\n   812→   812→  // on next line) by turning it into a single candidate — this block covers the rarer case where\n   813→   813→  // a continuation-character join was generated as a 2-line/3-line candidate and the prefix\n   814→   814→  // single also survived threshold independently (e.g. from a different code path or OCR layout).\n   815→   815→  // Safety: only fires for joins whose continuation starts with /&+:( — digit continuations\n   816→   816→  // like \"Pierogi Ruskie 200g mąki\" are NOT protected, so dedup correctly keeps the shorter form.\n   817→   817→  const survivingJoins = selected.filter((s) => s.origin === \"2-line\" || s.origin === \"3-line\");\n   818→   818→  if (survivingJoins.length > 0) {\n   819→   819→    selected = selected.filter((s) => {\n   820→   820→      if (s.origin !== \"single\") return true;\n   821→   821→      const sLower = s.text.toLowerCase();\n   822→   822→      // Remove PREFIX singles whose continuation join also survived\n   823→   823→      const isPrefixOfJoin = survivingJoins.some((j) => {\n   824→   824→        const jLower = j.text.toLowerCase();\n   825→   825→        if (!jLower.startsWith(sLower + \" \")) return false;\n   826→   826→        const remainder = jLower.slice(sLower.length + 1);\n   827→   827→        return /^[/&+:(]/.test(remainder);\n   828→   828→      });\n   829→   829→      if (isPrefixOfJoin) return false;\n   830→   830→      // Remove SUFFIX singles (e.g. \"& Coriander\") whose parent join also survived\n   831→   831→      const isSuffixOfJoin = survivingJoins.some((j) => {\n   832→   832→        const jLower = j.text.toLowerCase();\n   833→   833→        if (!jLower.endsWith(\" \" + sLower)) return false;\n   834→   834→        // Only remove if the suffix starts with a continuation character\n   835→   835→        return /^[/&+:(]/.test(sLower);\n   836→   836→      });\n   837→   837→      if (isSuffixOfJoin) return false;\n   838→   838→      return true;\n   839→   839→    });\n   840→   840→  }\n   841→   841→\n   842→   842→  // Pre-dedup: remove sub-section headers that are substrings of other surviving candidates.\n   843→   843→  // A sub-section header is an ALL_CAPS candidate followed by ingredient-like lines in the source.\n   844→   844→  // Example: \"CHLEBEK\" (bread section header, followed by \"500 g mąki\") is a substring of\n   845→   845→  // \"CHLEBEK Z WARZYWAMI I BOCZKIEM\" (the real title). Without this filter, dedup kills the title.\n   846→   846→  selected = selected.filter((candidate) => {\n   847→   847→    if (!isAllCaps(candidate.text)) return true;\n   848→   848→    // Check if this candidate is immediately followed by ingredient-like content\n   849→   849→    const nextSourceLines = lines.slice(candidate.position + 1, candidate.position + 2);\n   850→   850→    const followedByIngredients = nextSourceLines.some(\n   851→   851→      (l) => looksLikeIngredient(l.trim()) || startsWithNumber(l.trim())\n   852→   852→    );\n   853→   853→    if (!followedByIngredients) return true;\n   854→   854→    // Only remove if a longer candidate contains this one as a substring\n   855→   855→    const candidateLower = candidate.text.toLowerCase();\n   856→   856→    const hasLongerParent = rawScored.some(\n   857→   857→      (other) =>\n   858→   858→        other.text !== candidate.text &&\n   859→   859→        other.text.length > candidate.text.length &&\n   860→   860→        other.text.toLowerCase().includes(candidateLower)\n   861→   861→    );\n   862→   862→    return !hasLongerParent;\n   863→   863→  });\n   864→   864→\n   865→   865→  // Protect multi-line joins from being destroyed by their own component singles.\n   866→   866→  // When \"Lamb Stew\" (2-line join) survives AND both \"Lamb\" and \"Stew\" (singles) also survive,\n   867→   867→  // the join is the intended title — remove the singles.\n   868→   868→  const joinsToProtect = selected.filter((s) => s.origin === \"2-line\" || s.origin === \"3-line\");\n   869→   869→  if (joinsToProtect.length > 0) {\n   870→   870→    const singlesToRemove = new Set<string>();\n   871→   871→    for (const join of joinsToProtect) {\n   872→   872→      const joinWords = join.text.split(/\\s+/);\n   873→   873→      const componentSingles = selected.filter(\n   874→   874→        (s) => s.origin === \"single\" && joinWords.some((w) => s.text.toLowerCase() === w.toLowerCase())\n   875→   875→      );\n   876→   876→      if (componentSingles.length >= Math.min(joinWords.length, 2)) {\n   877→   877→        componentSingles.forEach((s) => singlesToRemove.add(s.text));\n   878→   878→      }\n   879→   879→    }\n   880→   880→    if (singlesToRemove.size > 0) {\n   881→   881→      selected = selected.filter((s) => s.origin !== \"single\" || !singlesToRemove.has(s.text));\n   882→   882→    }\n   883→   883→  }\n   884→   884→\n   885→   885→  // Protect position-0 compound titles from distant sub-section headers.\n   886→   886→  // When a position-0 compound title is longer and contains a shorter candidate\n   887→   887→  // that appears > 10 lines later, remove the distant candidate so the dedup\n   888→   888→  // (shorter-wins rule) doesn't destroy the compound title.\n   889→   889→  const pos0Compounds = selected.filter((s) => s.position === 0);\n   890→   890→  if (pos0Compounds.length > 0) {\n   891→   891→    selected = selected.filter((s) => {\n   892→   892→      if (s.position === 0) return true;\n   893→   893→      const sLower = s.text.toLowerCase();\n   894→   894→      return !pos0Compounds.some(\n   895→   895→        (p0) =>\n   896→   896→          p0.position + 10 < s.position &&\n   897→   897→          s.text.length < p0.text.length &&\n   898→   898→          p0.text.toLowerCase().includes(sLower)\n   899→   899→      );\n   900→   900→    });\n   901→   901→  }\n   902→   902→\n   903→   903→  // Deduplicate: if one title is a substring of another, keep the shorter (more focused) one.\n   904→   904→  // DO NOT CHANGE THIS LOGIC — it has been incorrectly \"improved\" by the title-loop 5 times.\n   905→   905→  // The tests require shorter wins: \"Pierogi Ruskie\" over \"Pierogi Ruskie 200g mąki 3 ziemniaki\".\n   906→   906→  // The pre-filter above handles the conflicting case (structural heading prefix removal) so that\n   907→   907→  // the incomplete prefix line is never present here when the complete join is in selected.\n   908→   908→  selected = selected.filter((a) => {\n   909→   909→    const aLower = a.text.toLowerCase();\n   910→   910→    return !selected.some(\n   911→   911→      (b) =>\n   912→   912→        b !== a &&\n   913→   913→        aLower.includes(b.text.toLowerCase()) &&\n   914→   914→        b.text.length < a.text.length\n   915→   915→    );\n   916→   916→  });\n   917→   917→\n   918→   918→  // Multi-title guard: only join multiple candidates with \"+\" when there is\n   919→   919→  // structural evidence of a multi-recipe page (≥2 ALL_CAPS headings).\n   920→   920→  // A single ALL_CAPS title among mixed-case survivors is a single-recipe page —\n   921→   921→  // collapse to the highest-scoring candidate.\n   922→   922→  // Zero ALL_CAPS survivors → apply positional tiebreak only when candidates are\n   923→   923→  // spread far apart (>10 lines), which indicates body-text leakage. Closely-\n   924→   924→  // positioned candidates are likely genuine multi-recipe content.\n   925→   925→  if (selected.length > 1) {\n   926→   926→    const allCapsSelected = selected.filter((s) => isAllCaps(s.text));\n   927→   927→    if (allCapsSelected.length >= 2) {\n   928→   928→      // Check whether non-first ALL_CAPS headings are section headers within one recipe\n   929→   929→      // (followed immediately by ingredient-like content) rather than separate recipe titles.\n   930→   930→      // A multi-recipe page has body text between titles; a single-recipe page has\n   931→   931→      // ingredient lines immediately after each section heading.\n   932→   932→      const sortedCaps = [...allCapsSelected].sort((a, b) => a.position - b.position);\n   933→   933→      const isSubHeader = sortedCaps.slice(1).every((cap) => {\n   934→   934→        const nextLines = lines.slice(cap.position + 1, cap.position + 3);\n   935→   935→        return nextLines.some(\n   936→   936→          (l) => looksLikeIngredient(l.trim()) || /^\\s*\\d/.test(l.trim())\n   937→   937→        );\n   938→   938→      });\n   939→   939→      if (isSubHeader) {\n   940→   940→        selected = [sortedCaps[0]];\n   941→   941→      } else {\n   942→   942→        selected = allCapsSelected;\n   943→   943→      }\n   944→   944→    } else if (allCapsSelected.length === 1) {\n   945→   945→      const theCapCandidate = allCapsSelected[0];\n   946→   946→      // Use non-empty line count so the 75% threshold is consistent regardless of blank-line density.\n   947→   947→      const nonEmptyCount = lines.filter((l) => l.trim().length > 0).length;\n   948→   948→      const capRelPos = theCapCandidate.position / Math.max(nonEmptyCount, 1);\n   949→   949→      // If the sole ALL_CAPS candidate is in the last 25% of the document,\n   950→   950→      // it's likely a category footer, not a title. Prefer the best earlier candidate.\n   951→   951→      if (capRelPos > 0.75) {\n   952→   952→        const earlierCandidates = selected.filter(\n   953→   953→          (s) => s.position / Math.max(nonEmptyCount, 1) <= 0.75\n   954→   954→        );\n   955→   955→        if (earlierCandidates.length > 0) {\n   956→   956→          selected = [earlierCandidates.reduce((a, b) => (a.score > b.score ? a : b))];\n   957→   957→        } else {\n   958→   958→          // All candidates are in the last 25% — no positional basis to prefer one over another;\n   959→   959→          // fall back to score, accepting that the guard cannot help here.\n   960→   960→          selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n   961→   961→        }\n   962→   962→      } else {\n   963→   963→        selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n   964→   964→      }\n   965→   965→    } else {\n   966→   966→      // Zero ALL_CAPS survivors → mixed-case page.\n   967→   967→      // If all survivors are closely positioned (within 10 lines of each other), keep them all —\n   968→   968→      // they're likely genuine multi-recipe content on a single page.\n   969→   969→      // If any survivor is far from the earliest, apply a positional tiebreak: the real title\n   970→   970→      // is almost always the earliest candidate; distant survivors are likely body-text leakage.\n   971→   971→      selected.sort((a, b) => a.position - b.position);\n   972→   972→      const earliest = selected[0];\n   973→   973→      const farthest = selected[selected.length - 1];\n   974→   974→      if (farthest.position - earliest.position > 10) {\n   975→   975→        // Large span → body-text leakage. Collapse to one: prefer the highest-scoring\n   976→   976→        // candidate within 3 positions of the earliest (position tolerance for OCR gaps),\n   977→   977→        // falling back to the earliest itself if none score higher.\n   978→   978→        const closeCompetitors = selected.filter(\n   979→   979→          (s) => s.position <= earliest.position + 3 && s.score > earliest.score\n   980→   980→        );\n   981→   981→        selected = closeCompetitors.length > 0\n   982→   982→          ? [closeCompetitors.reduce((a, b) => (a.score > b.score ? a : b))]\n   983→   983→          : [earliest];\n   984→   984→      }\n   985→   985→      // Span ≤ 10 → all survivors are closely positioned; fall through keeping all.\n   986→   986→    }\n   987→   987→  }\n   988→   988→\n   989→   989→  // Cap at 3, sort by document position\n   990→   990→  selected.sort((a, b) => a.position - b.position);\n   991→   991→  selected = selected.slice(0, 3);\n   992→   992→\n   993→   993→  if (selected.length === 0) {\n   994→   994→    return undefined;\n   995→   995→  }\n   996→   996→\n   997→   997→  const result = selected.map((s) => s.text.normalize(\"NFC\").trim()).join(\" + \");\n   998→   998→\n   999→   999→  // Compound variant: \"A : B\" where both sides share the same first word → return only A.\n  1000→  1000→  // This handles pages with \"TITLE VARIANT1 : TITLE VARIANT2\" where only the first is wanted.\n  1001→  1001→  const colonMatch = result.match(/^(.+?)\\s*:\\s*(.+)$/);\n  1002→  1002→  if (colonMatch) {\n  1003→  1003→    const [, first, second] = colonMatch;\n  1004→  1004→    const firstWord = first.trim().toLowerCase().split(/\\s+/)[0];\n  1005→  1005→    const secondWord = second.trim().toLowerCase().split(/\\s+/)[0];\n  1006→  1006→    if (firstWord && firstWord === secondWord) {\n  1007→  1007→      return first.trim().normalize(\"NFC\");\n  1008→  1008→    }\n  1009→  1009→  }\n  1010→  1010→\n  1011→  1011→  return result;\n  1012→  1012→}\n  1013→  1013→\n  1014→  1014→/**\n  1015→  1015→ * Extract potential recipe title from OCR text (sync heuristic fallback)\n  1016→  1016→ */\n  1017→  1017→export function extractTitle(text: string): string | undefined {\n  1018→  1018→  if (!text || text.trim().length === 0) {\n  1019→  1019→    return undefined;\n  1020→  1020→  }\n  1021→  1021→\n  1022→  1022→  const lines = text.split(\"\\n\").map((line) => line.trim());\n  1023→  1023→\n  1024→  1024→  for (const line of lines) {\n  1025→  1025→    if (line.length === 0) continue;\n  1026→  1026→    if (line.length < 3 || line.length > 50) continue;\n  1027→  1027→    if (looksLikeIngredient(line)) continue;\n  1028→  1028→    if (isAllCaps(line)) continue;\n  1029→  1029→    if (startsWithNumber(line)) continue;\n  1030→  1030→    return line;\n  1031→  1031→  }\n  1032→  1032→\n  1033→  1033→  return undefined;\n  1034→  1034→}\n  1035→  1035→","numLines":1035,"startLine":1,"totalLines":1035}}}
