{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Y4ZLxsK9xPYayE8KzTvP2a","type":"tool_result","content":"  1018→  1018→  // Protect position-0 compound titles from distant sub-section headers.\n  1019→  1019→  // When a position-0 compound title is longer and contains a shorter candidate\n  1020→  1020→  // that appears > 10 lines later, remove the distant candidate so the dedup\n  1021→  1021→  // (shorter-wins rule) doesn't destroy the compound title.\n  1022→  1022→  const pos0Compounds = selected.filter((s) => s.position === 0);\n  1023→  1023→  if (pos0Compounds.length > 0) {\n  1024→  1024→    selected = selected.filter((s) => {\n  1025→  1025→      if (s.position === 0) return true;\n  1026→  1026→      const sLower = s.text.toLowerCase();\n  1027→  1027→      return !pos0Compounds.some(\n  1028→  1028→        (p0) =>\n  1029→  1029→          p0.position + 10 < s.position &&\n  1030→  1030→          s.text.length < p0.text.length &&\n  1031→  1031→          p0.text.toLowerCase().includes(sLower)\n  1032→  1032→      );\n  1033→  1033→    });\n  1034→  1034→  }\n  1035→  1035→\n  1036→  1036→  // Deduplicate: if one title is a substring of another, keep the shorter (more focused) one.\n  1037→  1037→  // DO NOT CHANGE THIS LOGIC — it has been incorrectly \"improved\" by the title-loop 5 times.\n  1038→  1038→  // The tests require shorter wins: \"Pierogi Ruskie\" over \"Pierogi Ruskie 200g mąki 3 ziemniaki\".\n  1039→  1039→  // The pre-filter above handles the conflicting case (structural heading prefix removal) so that\n  1040→  1040→  // the incomplete prefix line is never present here when the complete join is in selected.\n  1041→  1041→  selected = selected.filter((a) => {\n  1042→  1042→    const aLower = a.text.toLowerCase();\n  1043→  1043→    return !selected.some(\n  1044→  1044→      (b) =>\n  1045→  1045→        b !== a &&\n  1046→  1046→        aLower.includes(b.text.toLowerCase()) &&\n  1047→  1047→        b.text.length < a.text.length\n  1048→  1048→    );\n  1049→  1049→  });\n  1050→  1050→\n  1051→  1051→  // Multi-title guard: only join multiple candidates with \"+\" when there is\n  1052→  1052→  // structural evidence of a multi-recipe page (≥2 ALL_CAPS headings).\n  1053→  1053→  // A single ALL_CAPS title among mixed-case survivors is a single-recipe page —\n  1054→  1054→  // collapse to the highest-scoring candidate.\n  1055→  1055→  // Zero ALL_CAPS survivors → apply positional tiebreak only when candidates are\n  1056→  1056→  // spread far apart (>10 lines), which indicates body-text leakage. Closely-\n  1057→  1057→  // positioned candidates are likely genuine multi-recipe content.\n  1058→  1058→  if (selected.length > 1) {\n  1059→  1059→    const allCapsSelected = selected.filter((s) => isAllCaps(s.text));\n  1060→  1060→    if (allCapsSelected.length >= 2) {\n  1061→  1061→      // Check whether non-first ALL_CAPS headings are section headers within one recipe\n  1062→  1062→      // (followed immediately by ingredient-like content) rather than separate recipe titles.\n  1063→  1063→      // A multi-recipe page has body text between titles; a single-recipe page has\n  1064→  1064→      // ingredient lines immediately after each section heading.\n  1065→  1065→      const sortedCaps = [...allCapsSelected].sort((a, b) => a.position - b.position);\n  1066→  1066→      const isSubHeader = sortedCaps.slice(1).every((cap) => {\n  1067→  1067→        const nextLines = lines.slice(cap.position + 1, cap.position + 3);\n  1068→  1068→        return nextLines.some(\n  1069→  1069→          (l) => looksLikeIngredient(l.trim()) || /^\\s*\\d/.test(l.trim())\n  1070→  1070→        );\n  1071→  1071→      });\n  1072→  1072→      if (isSubHeader) {\n  1073→  1073→        selected = [sortedCaps[0]];\n  1074→  1074→      } else {\n  1075→  1075→        selected = allCapsSelected;\n  1076→  1076→      }\n  1077→  1077→    } else if (allCapsSelected.length === 1) {\n\n<system-remin