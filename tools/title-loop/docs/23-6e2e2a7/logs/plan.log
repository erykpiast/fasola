e Case, using a small-words list.\n   585→ * Preserves Polish/French diacritics.\n   586→ */\n   587→function toTitleCase(text: string): string {\n   588→  const smallWords = new Set([\n   589→    \"a\", \"an\", \"the\", \"and\", \"but\", \"or\", \"for\", \"nor\",\n   590→    \"in\", \"on\", \"at\", \"to\", \"of\", \"by\", \"with\", \"from\",\n   591→    \"z\", \"w\", \"i\", \"ze\", \"na\", \"do\", \"od\", \"za\", \"po\",\n   592→  ]);\n   593→  return text.split(/(\\s+)/).map((word, idx) => {\n   594→    if (/^\\s+$/.test(word)) return word;\n   595→    const lower = word.toLowerCase();\n   596→    if (idx === 0 || !smallWords.has(lower)) {\n   597→      return lower.charAt(0).toUpperCase() + lower.slice(1);\n   598→    }\n   599→    return lower;\n   600→  }).join(\"\");\n   601→}\n   602→\n   603→/**\n   604→ * Post-processing normalization for OCR-extracted titles.\n   605→ * Strips stray section markers and substitutes common OCR digit-for-letter artifacts.\n   606→ * Title-case conversion is applied only when a substitution was actually made, so\n   607→ * clean ALL_CAPS titles (e.g. \"CHOCOLATE CAKE\") are returned unchanged.\n   608→ */\n   609→function normalizeOcrTitle(raw: string): string {\n   610→  let text = raw;\n   611→\n   612→  // Step 1: Strip trailing section markers greedily appended to the title.\n   613→  // e.g. \"MAKOWIEC ZE ŚLIWKAMI + SERVING AND STORAGE:\" → \"MAKOWIEC ZE ŚLIWKAMI\"\n   614→  text = text.replace(\n   615→    /\\s*\\+\\s*(?:SERV[IÍ1]NG(?:\\s+AND\\s+STORAGE)?|TOPPING|NOTES?|TIPS?)\\s*:?\\s*$/i,\n   616→    \"\"\n   617→  );\n   618→\n   619→  // Step 2: OCR character substitution.\n   620→  // For ALL_CAPS text, apply digit-for-letter substitutions.\n   621→  const beforeSub = text;\n   622→  if (isAllCaps(text)) {\n   623→    text = text\n   624→      .replace(/1/g, \"I\")\n   625→      .replace(/0(?=[A-ZÀ-Ż])/g, \"O\")\n   626→      .replace(/(?<=[A-ZÀ-Ż])0/g, \"O\")\n   627→      .replace(/4(?=[A-ZÀ-Ż])/g, \"A\")\n   628→      .replace(/(?<=[A-ZÀ-Ż])4/g, \"A\")\n   629→      .replace(/5(?=[A-ZÀ-Ż])/g, \"S\")\n   630→      .replace(/(?<=[A-ZÀ-Ż])5/g, \"S\")\n   631→      .replace(/¡/g, \"I\")\n   632→      .replace(/€/g, \"E\")\n   633→      .replace(/[ÍÌ]/g, \"I\");\n   634→  } else {\n   635→    // Mixed-case: fix per-word (digits between lowercase letters)\n   636→    text = text.split(/(\\s+)/).map((token) => {\n   637→      if (/^\\s+$/.test(token)) return token;\n   638→      if (isAllCaps(token) && token.length > 1) {\n   639→        return token\n   640→          .replace(/1/g, \"I\")\n   641→          .replace(/0(?=[A-Z])/g, \"O\")\n   642→          .replace(/(?<=[A-Z])0/g, \"O\");\n   643→      }\n   644→      return token\n   645→        .replace(/(?<=[a-zà-ż])1/g, \"l\")\n   646→        .replace(/1(?=[a-zà-ż])/g, \"l\")\n   647→        .replace(/¡/g, \"i\")\n   648→        .replace(/€/g, \"e\");\n   649→    }).join(\"\");\n   650→  }\n   651→\n   652→  // Step 3: Title-case conversion — ONLY when OCR substitution changed the text.\n   653→  // This preserves clean ALL_CAPS titles (e.g. \"CHOCOLATE CAKE\") as-is.\n   654→  if (text !== beforeSub && isAllCaps(text)) {\n   655→    text = toTitleCase(text);\n   656→  }\n   657→\n   658→  return text.trim();\n   659→}\n   660→\n   661→// Module-level cache for reference embeddings\n   662→let cachedTitleRefEmbedding: Array<number> | null = null;\n   663→let cachedHeaderRefEmbedding: Array<number> | null = null;\n   664→let cachedNoiseRefEmbedding: Array<number> | null = null;\n   665→\n   666→export function _resetEmbeddingCacheForTests(): void {\n   667→  cachedTitleRefEmbedding = null;\n   668→  cachedHeaderRefEmbedding = null;\n   669→  cachedNoiseRefEmbedding = null;\n   670→}\n   671→\n   672→export async function extractTitleWithEmbeddings(\n   673→  text: string,\n   674→  embed: EmbedFn\n   675→): Promise<string | undefined> {\n   676→  if (!text || text.trim().length === 0) {\n   677→    return undefined;\n   678→  }\n   679→\n   680→  const lines = text.split(\"\\n\");\n   681→  const candidates = buildCandidates(lines);\n   682→\n   683→  if (candidates.length === 0) {\n   684→    return undefined;\n   685→  }\n   686→\n   687→  // Cache reference embeddings\n   688→  if (!cachedTitleRefEmbedding) {\n   689→    cachedTitleRefEmbedding = await embed(TITLE_REFERENCE);\n   690→  }\n   691→  if (!cachedHeaderRefEmbedding) {\n   692→    cachedHeaderRefEmbedding = await embed(HEADER_REFERENCE);\n   693→  }\n   694→  if (!cachedNoiseRefEmbedding) {\n   695→    cachedNoiseRefEmbedding = await embed(NOISE_REFERENCE);\n   696→  }\n   697→\n   698→  // Find ALL_CAPS candidates with ≥2 words where every significant word has ≥4 alpha letters.\n   699→  // Insignificant tokens (≤1 alpha letter: \"/\", \"&\", \"+\", \":\", \"D)\", etc.) are filtered before"}]},"parent_tool_use_id":null,"session_id":"1c607690-947d-4a99-99f9-d42643539da8","uuid":"27d36c80-a15e-4c28-8b29-2a295e66355a","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/title-extractor.ts","content":"        continue;\n      }\n    }\n    mergedLines.push(line);\n  }\n\n  const candidates: Array<{ text: string; position: number; origin: CandidateOrigin }> = [];\n  const seen = new Set<string>();\n\n  // Build a set of positions to skip: short ALL_CAPS lines immediately following metadata\n  const metadataContinuationPositions = new Set<number>();\n  for (let i = 0; i < mergedLines.length - 1; i++) {\n    if (looksLikeMetadata(mergedLines[i].text)) {\n      const next = mergedLines[i + 1];\n      if (isAllCaps(next.text) && wordCount(next.text) <= 2 && next.text.length <= 15) {\n        metadataContinuationPositions.add(next.index);\n      }\n    }\n  }\n\n  for (let i = 0; i < mergedLines.length; i++) {\n    const line = mergedLines[i];\n\n    // Skip metadata continuation fragments\n    if (metadataContinuationPositions.has(line.index)) continue;\n\n    // Single line —