{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013zpqv7Bsgi7xR8ePrekbkq","type":"tool_result","content":"   850→          return sLower.startsWith(tLower) ||\n   851→                 sLower.endsWith(\" \" + tLower) ||\n   852→                 sLower.includes(\" \" + tLower);\n   853→        });\n   854→      });\n   855→    }\n   856→  }\n   857→\n   858→  // Fix 2: If the structural heading was identified as a bilingual translation, reassign it.\n   859→  // This prevents the translation's ALL_CAPS bonus from inflating the threshold and ensures\n   860→  // the fallback path in scored also uses the correct heading.\n   861→  if (\n   862→    translationCandidates.length > 0 &&\n   863→    firstStructuralHeading &&\n   864→    translationCandidates.some((t) => t.text === firstStructuralHeading!.text)\n   865→  ) {\n   866→    const nonTranslationStructural = structuralCandidates.filter(\n   867→      (sc) => !translationCandidates.some((t) => t.text === sc.text)\n   868→    );\n   869→    const newHeading = nonTranslationStructural.length > 0\n   870→      ? nonTranslationStructural.reduce((a, b) => a.rawScore > b.rawScore ? a : b)\n   871→      : undefined;\n   872→\n   873→    // Patch scored array: remove old structural bonus, apply new one\n   874→    for (const s of scored) {\n   875→      if (s.text === firstStructuralHeading.text) {\n   876→        s.score -= 0.10;\n   877→        s.baseScore -= 0.10;\n   878→      }\n   879→      if (newHeading && s.text === newHeading.text) {\n   880→        s.score += 0.10;\n   881→        s.baseScore += 0.10;\n   882→      }\n   883→    }\n   884→    // Update reference for downstream prefix-removal logic\n   885→    firstStructuralHeading = newHeading ?? undefined;\n   886→  }\n   887→\n   888→  // Subtitle suppression: when a short mixed-case title at position 0 is followed by a\n   889→  // longer mixed-case candidate at position 1-2, the longer one is a subtitle/translation.\n   890→  // Apply a penalty so the primary title (position 0) wins.\n   891→  const pos0Primary = scored.find((s) => s.position === 0 && !isAllCaps(s.text) && wordCount(s.text) <= 5);\n   892→  if (pos0Primary) {\n   893→    const subtitleCandidates = scored.filter((s) =>\n   894→      s.position >= 1 && s.position <= 2 &&\n   895→      !isAllCaps(s.text) &&\n   896→      wordCount(s.text) > wordCount(pos0Primary.text) + 2\n   897→    );\n   898→    for (const sub of subtitleCandidates) {\n   899→      sub.score -= 0.15;\n   900→    }\n   901→  }\n   902→\n   903→  // Use thresholdScore (excludes structural bonus) so the structural bonus doesn't inflate\n   904→  // the threshold and block equally-valid headings on multi-recipe pages.\n   905→  const bestThresholdScore = Math.max(...scoredForThreshold.map((s) => s.thresholdScore));\n   906→  const threshold = Math.max(0.08, bestThresholdScore * 0.7);\n   907→\n   908→  // Filter candidates above threshold\n   909→  let selected = scoredForThreshold.filter((s) => s.score >= threshold);\n   910→\n   911→  // Empty-pool fallback: when threshold filtering discards every candidate,\n   912→  // the hard filters' structural verdict should not be overruled by weak\n   913→  // embedding differentiation. Return the best positional candidate only\n   914→  // if it has a meaningful positive raw score (avoids ingredient-list leakage).\n   915→  if (selected.length === 0 && scored.length > 0) {\n   916→    const fallback = scored\n   917→      .slice()\n   918→      .sort((a, b) => a.position - b.position || b.score - a.score);\n   919→    // Position-0 candidates that passed hard filters are very likely titles even with\n   920→    // weak embedding signal. Relax the rawScore guard for early-position candidates.\n   921→    const rawScoreThreshold = fallback[0].position <= 2 ? -0.05 : 0.02;\n   922→    if (fallback[0].rawScore > rawScoreThreshold) {\n   923→      selected = [fallback[0]];\n   924→    }\n   925→  }\n   926→\n   927→  // Remove word-boundary prefixes of firstStructuralHeading when the heading itself survived\n   928→  // the threshold. Cases:\n   929→  //   ARAYES case:  firstStructuralHeading = \"ARAYES SHRAK\" (2-word join qualifies; \"ARAYES\"\n   930→  //     alone = 1 word, so it never qualified). Filter removes \"ARAYES\" so dedup keeps the join.\n   931→  //   SAFFRON case: baseHeading was the partial line; continuation logic above upgraded\n   932→  //     firstStructuralHeading to the full join. Filter removes the partial so dedup keeps join.\n   933→  // Safety: only fires when the complete heading itself is in selected (passed the threshold).\n   934→  if (firstStructuralHeading && selected.some((s) => s.text === firstStructuralHeading.text)) {\n   935→    const fshLower = firstStructuralHeading.text.toLowerCase();\n   936→    selected = selected.filter((s) => {\n   937→      if (s.text === firstStructuralHeading.text) return true;\n   938→      const sLower = s.text.toLowerCase();\n   939→      // Remove s if it is a space-delimited prefix of the structural heading\n   940→      return !fshLower.startsWith(sLower + \" \");\n   941→    });\n   942→  }\n   943→\n   944→  // Protect continuation joins: when a multi-line join (2-line or 3-line) survived the threshold\n   945→  // and its second part starts with a continuation character, remove the single-line prefix/suffix\n   946→  // so the dedup \"shorter wins\" rule doesn't destroy the complete join.\n   947→  // Note: the pre-merge step above already handles the common Baked Eggs case (&/continuation\n   948→  // on next line) by turning it into a single candidate — this block covers the rarer case where\n   949→  // a continuation-character join was generated as a 2-line/3-line candidate and the prefix\n   950→  // single also survived threshold independently (e.g. from a different code path or OCR layout).\n   951→  // Safety: only fires for joins whose continuation starts with /&+:( — digit continuations\n   952→  // like