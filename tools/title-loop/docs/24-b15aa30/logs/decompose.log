{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SQnFixggd7PoL9SeG4vKdr","type":"tool_result","content":"   609→function normalizeOcrTitle(raw: string): string {\n   610→  let text = raw;\n   611→\n   612→  // Step 1: Strip trailing section markers greedily appended to the title.\n   613→  // e.g. \"MAKOWIEC ZE ŚLIWKAMI + SERVING AND STORAGE:\" → \"MAKOWIEC ZE ŚLIWKAMI\"\n   614→  text = text.replace(\n   615→    /\\s*\\+\\s*(?:SERV[IÍ1]NG(?:\\s+AND\\s+STORAGE)?|TOPPING|NOTES?|TIPS?)\\s*:?\\s*$/i,\n   616→    \"\"\n   617→  );\n   618→\n   619→  // Step 2: OCR character substitution.\n   620→  // For ALL_CAPS text, apply digit-for-letter substitutions.\n   621→  const beforeSub = text;\n   622→  if (isAllCaps(text)) {\n   623→    text = text\n   624→      .replace(/1/g, \"I\")\n   625→      .replace(/0(?=[A-ZÀ-Ż])/g, \"O\")\n   626→      .replace(/(?<=[A-ZÀ-Ż])0/g, \"O\")\n   627→      .replace(/4(?=[A-ZÀ-Ż])/g, \"A\")\n   628→      .replace(/(?<=[A-ZÀ-Ż])4/g, \"A\")\n   629→      .replace(/5(?=[A-ZÀ-Ż])/g, \"S\")\n   630→      .replace(/(?<=[A-ZÀ-Ż])5/g, \"S\")\n   631→      .replace(/¡/g, \"I\")\n   632→      .replace(/€/g, \"E\")\n   633→      .replace(/[ÍÌ]/g, \"I\");\n   634→  } else {\n   635→    // Mixed-case: fix per-word (digits between lowercase letters)\n   636→    text = text.split(/(\\s+)/).map((token) => {\n   637→      if (/^\\s+$/.test(token)) return token;\n   638→      if (isAllCaps(token) && token.length > 1) {\n   639→        return token\n   640→          .replace(/1/g, \"I\")\n   641→          .replace(/0(?=[A-Z])/g, \"O\")\n   642→          .replace(/(?<=[A-Z])0/g, \"O\");\n   643→      }\n   644→      return token\n   645→        .replace(/(?<=[a-zà-ż])1/g, \"l\")\n   646→        .replace(/1(?=[a-zà-ż])/g, \"l\")\n   647→        .replace(/¡/g, \"i\")\n   648→        .replace(/€/g, \"e\");\n   649→    }).join(\"\");\n   650→  }\n   651→\n   652→  // Step 3: Title-case conversion — ONLY when OCR substitution changed the text.\n   653→  // This preserves clean ALL_CAPS titles (e.g. \"CHOCOLATE CAKE\") as-is.\n   654→  if (text !== beforeSub && isAllCaps(text)) {\n   655→    text = toTitleCase(text);\n   656→  }\n   657→\n   658→  return text.trim();\n   659→}\n   660→\n   661→// Module-level cache for reference embeddings\n   662→let cachedTitleRefEmbedding: Array<number> | null = null;\n   663→let cachedHeaderRefEmbedding: Array<number> | null = null;\n   664→let cachedNoiseRefEmbedding: Array<number> | null = null;\n   665→\n   666→export function _resetEmbeddingCacheForTests(): void {\n   667→  cachedTitleRefEmbedding = null;\n   668→  cachedHeaderRefEmbedding = null;\n   669→  cachedNoiseRefEmbedding = null;\n   670→}\n   671→\n   672→export async function extractTitleWithEmbeddings(\n   673→  text: string,\n   674→  embed: EmbedFn\n   675→): Promise<string | undefined> {\n   676→  if (!text || text.trim().length === 0) {\n   677→    return undefined;\n   678→  }\n   679→\n   680→  const lines = text.split(\"\\n\");\n   681→  const candidates = buildCandidates(lines);\n   682→\n   683→  if (candidates.length === 0) {\n   684→    return undefined;\n   685→  }\n   686→\n   687→  // Cache reference embeddings\n   688→  if (!cachedTitleRefEmbedding) {\n   689→    cachedTitleRefEmbedding = await embed(TITLE_REFERENCE);\n   690→  }\n   691→  if (!cachedHeaderRefEmbedding) {\n   692→    cachedHeaderRefEmbedding = await embed(HEADER_REFERENCE);\n   693→  }"}]},"parent_tool_use_id":"toolu_01GsxFTdnusREzqhYRYQdp1A","session_id":"992d880b-e463-4199-be8a-c9ca68db2e09","uuid":"c2990b2e-3dc4-48cb-b986-fb64ea8b06fb"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019gGwNw8szdFqZaKm2MEF6q","type":"tool_result","content":"   672→export async function extractTitleWithEmbeddings(\n   673→  text: string,\n   674→  embed: EmbedFn\n   675→): Promise<string | undefined> {\n   676→  if (!text || text.trim().length === 0) {\n   677→    return undefined;\n   678→  }\n   679→\n   680→  const lines = text.split(\"\\n\");\n   681→  const candidates = buildCandidates(lines);\n   682→\n   683→  if (candidates.length === 0) {\n   684→    return undefined;\n   685→  }\n   686→\n   687→  // Cache reference embeddings\n   688→  if (!cachedTitleRefEmbedding) {\n   689→    cachedTitleRefEmbedding = await embed(TITLE_REFERENCE);\n   690→  }\n   691→  if (!cachedHeaderRefEmbedding) {\n   692→    cachedHeaderRefEmbedding = await embed(HEADER_REFERENCE);\n   693→  }\n   694→  if (!cachedNoiseRefEmbedding) {\n   695→    cachedNoiseRefEmbedding = await embed(NOISE_REFERENCE);\n   696→  }\n   697→\n   698→  // Find ALL_CAPS candidates with ≥2 words where every significant word has ≥4 alpha letters.\n   699→  // Insignificant tokens (≤1 alpha letter: \"/\", \"&\", \"+\", \":\", \"D)\", etc.) are filtered before\n   700→  // the check so that multi-line joins with continuation punctuation still qualify.\n   701→  const isStructuralHeading = (c: { text: string }): boolean => {\n   702→    if (!isAllCaps(c.text) || wordCount(c.text) < 2) return false;\n   703→    const sigWords = c.text.trim().split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length > 1);\n   704→    return sigWords.length >= 2 && sigWords.every((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   705→  };\n   706→\n   707→  // Pass 1: compute rawScore for all candidates (embedding quality signal)\n   708→  const rawScored: Array<{ text: string; position: number; origin: CandidateOrigin; rawScore: number; embedding: Array<number> }> = [];\n   709→  for (const candidate of candidates) {\n   710→    const embedding = await embed(candidate.text);\n   711→    const titleSim = cosineSimilarity(embedding, cachedTitleRefEmbedding);\n   712→    const headerSim = cosineSimilarity(embedding, cachedHeaderRefEmbedding);\n   713→    const noiseSim = cosineSimilarity(embedding, cachedNoiseRefEmbedding);\n   714→    const rawScore = titleSim - Math.max(headerSim, noiseSim);\n   715→    rawScored.push({ text: candidate.text, position: candidate.position, origin: candidate.origin, rawScore, embedding });\n   716→  }\n   717→\n   718→  // Select baseHeading by embedding quality (rawScore), not position.\n   719→  // This prevents OCR-garbled fragments from claiming the structural heading slot.\n   720→  const structuralCandidates = rawScored.filter((s) => isStructuralHeading(s));\n   721→\n   722→  // Penalize structural headings with truncated OCR words:\n   723→  // if \"FRON\" appears and another heading has \"SAFFRON\", \"FRON\" is likely garbled.\n   724→  for (const sc of structuralCandidates) {\n   725→    const sigWords = sc.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   726→    for (const other of structuralCandidates) {\n   727→      if (other === sc) continue;\n   728→      const otherSigWords = other.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   729→      const hasTruncation = sigWords.some((w) =>\n   730→        otherSigWords.some((ow) => ow !== w && ow.length > w.length && ow.endsWith(w))\n   731→      );\n   732→      if (hasTruncation) {\n   733→        sc.rawScore = -1.0;  // Hard disqualification — truncated OCR artifact\n   734→        break;\n   735→      }\n   736→    }\n   737→  }\n   738→\n   739→  const bestStructural = structuralCandidates.length > 0\n   740→    ? structuralCandidates.reduce((a, b) => {\n   741→        const scoreDiff = a.rawScore - b.rawScore;\n   742→        if (Math.abs(scoreDiff) > 0.03) return scoreDiff > 0 ? a : b;\n   743→        // Tiebreak: single-line origin beats multi-line joins (avoids conflating two separate headings)\n   744→        if (a.origin === \"single\" && b.origin !== \"single\") return a;\n   745→        if (b.origin === \"single\" && a.origin !== \"single\") return b;\n   746→        // Tiebreak: more words (more specific) → better\n   747→        const wcDiff = wordCount(b.text) - wordCount(a.text);\n   748→        if (wcDiff !== 0) return wcDiff > 0 ? b : a;\n   749→        // Tiebreak: earlier position → better\n   750→        return a.position < b.position ? a : b;\n   751→      })\n   752→    : null;\n   753→  const baseHeading = bestStructural ?? undefined;\n   754→\n   755→  // When the best structural heading has a continuation on the next line introduced by a\n   756→  // punctuation token (/, &, +, :, or parenthesis), prefer the longer 2-line join as the\n   757→  // complete heading. E.g. \"SAFFRON WHEAT BUNS WITH QUARK\" + \"/ COTTAGE CHEESE (VARIATION D)\".\n   758→  // Guard: the remainder after the prefix must start with a continuation character to avoid\n   759→  // merging two separate consecutive recipe titles (FINNISH MILK FLATBREADS stays separate\n   760→  // from FINNISH POTATO FLATBREADS because \"FINNISH\" does not start with a continuation token).\n   761→  let firstStructuralHeading = baseHeading && (\n   762→    rawScored.find((c) => {\n   763→      if (!isStructuralHeading(c)) return false;\n   764→      const hLower = baseHeading.text.toLowerCase();\n   765→      const cLower = c.text.toLowerCase();\n   766→      return cLower.startsWith(hLower + \" \") && /^[/&+:(]/.test(cLower.slice(hLower.length + 1));\n   767→    }) ?? baseHeading\n   768→  );\n   769→\n   770→  // Pass 2: apply bonuses\n   771→  const scored: Array<{ text: string; position: number; origin: CandidateOrigin; score: number; rawScore: number; baseScore: number; thresholdScore: number }> = rawScored.map((rs) => {\n   772→    // Position factor: multiplicative tiebreaker — amplifies existing signal, doesn't replace it\n   773→    const relativePosition = rs.position / lines.length;\n   774→    const positionFactor = relativePosition < 0.5\n   775→      ? 1.0 + 0.12 * (1 - relativePosition * 2)\n   776→      : 1.0;\n   777→\n   778→    // ALL_CAPS bonus: recipe books use ALL_CAPS for titles and section headings.\n   779→    // Single-word ALL_CAPS terms are overwhelmingly section/category labels, not recipe titles;\n   780→    // real recipe titles in ALL_CAPS are almost always multi-word. Reduce the bonus for single words.\n   781→    const allCapsBonus = isAllCaps(rs.text) && rs.text.replace(/[^a-zA-Z]/g, \"\").length >= 4\n   782→      ? (wordCount(rs.text) >= 2 ? 0.08 : 0.03)\n   783→      : 0;\n   784→\n   785→    // Structural heading bonus: best ALL_CAPS heading (or its continuation join) is almost always the recipe title\n   786→    const structuralBonus = firstStructuralHeading && rs.text === firstStructuralHeading.text ? 0.10 : 0;\n   787→\n   788→    // thresholdScore excludes structural bonus so the bonus doesn't inflate the threshold\n   789→    // and prevent equally-valid structural headings from passing on multi-recipe pages.\n   790→    const thresholdScore = rs.rawScore + allCapsBonus;\n   791→    // baseScore excludes position factor — used for diagnostics and ranking\n   792→    const baseScore = rs.rawScore + allCapsBonus + structuralBonus;\n   793→    const score = rs.rawScore * positionFactor + allCapsBonus + structuralBonus;\n   794→    return { text: rs.text, position: rs.position, origin: rs.origin, score, rawScore: rs.rawScore, baseScore, thresholdScore };\n   795→  });\n   796→\n   797→  if (scored.length === 0) {\n   798→    return undefined;\n   799→  }\n   800→\n   801→  // --- Pre-threshold bilingual title detection ---\n   802→  // When a mixed-case candidate at position 0 is followed by an ALL_CAPS candidate\n   803→  // at position ≤ 2 that is semantically similar to it, this is a bilingual recipe\n   804→  // page (e.g., Polish title + ALL_CAPS Korean romanization). Suppress confirmed\n   805→  // translation candidates before computing threshold so their bonuses don't inflate\n   806→  // the threshold beyond the mixed-case title's reach.\n   807→  // Note: we check position ≤ 2 (local proximity), not global ALL_CAPS count, so\n   808→  // section headers later in the document (SKŁADNIKI, WARZYWA, etc.) are irrelevant.\n   809→  let translationCandidates: typeof scored = [];\n   810→  let scoredForThreshold = scored;\n   811→  const prePos0 = scored.find((s) => s.position === 0 && !isAllCaps(s.text));\n   812→  if (prePos0) {\n   813→    const nearbyAllCaps = scored.filter(\n   814→      (s) => isAllCaps(s.text) && s.position >= 1 && s.position <= 2 && s.origin === \"single\"\n   815→    );\n   816→    const pos0Embedding = rawScored.find((r) => r.text === prePos0.text)?.embedding;\n   817→\n   818→    // Method 1: embedding similarity (works for related languages)\n   819→    if (pos0Embedding && nearbyAllCaps.length > 0) {\n   820→      translationCandidates = nearbyAllCaps.filter((cap) => {\n   821→        const capEmbedding = rawScored.find((r) => r.text === cap.text)?.embedding;\n   822→        if (!capEmbedding) return false;\n   823→        return cosineSimilarity(pos0Embedding, capEmbedding) > 0.4;\n   824→      });\n   825→    }\n   826→\n   827→    // Method 2: layout-based detection (cross-lingual fallback).\n   828→    // When embedding similarity is insufficient (e.g. Polish ↔ Korean romanization),\n   829→    // detect bilingual layout by position and word overlap:\n   830→    // mixed-case ≥2 words at pos 0 + ALL_CAPS ≥2 words at pos 1-2 with no shared words.\n   831→    if (translationCandidates.length === 0 && wordCount(prePos0.text) >= 2) {\n   832→      const pos0Words = new Set(\n   833→        prePos0.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2)\n   834→      );\n   835→      translationCandidates = nearbyAllCaps.filter((cap) => {\n   836→        if (wordCount(cap.text) < 2) return false;\n   837→        const capWords = cap.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2);\n   838→        return !capWords.some((w) => pos0Words.has(w));\n   839→      });\n   840→    }\n   841→\n   842→    if (translationCandidates.length > 0) {\n   843→      // Suppress standalone translations and any multi-line joins that embed the translation\n   844→      // as a suffix or substring (e.g. \"Smażona zielona fasolka GREEN BEANS BORKEUM\" ends with\n   845→      // the translation; \"Title GREEN BEANS BORKEUM 그린빈\" includes it as a substring).\n   846→      scoredForThreshold = scored.filter((s) => {\n   847→        const sLower = s.text.toLowerCase();\n   848→        return !translationCandidates.some((t) => {\n   849→          const tLower = t.text.toLowerCase();\n   850→          return sLower.startsWith(tLower) ||\n   851→                 sLower.endsWith(\" \" + tLower) ||"}]},"parent_tool_use_id":"toolu_01GsxFTdnusREzqhYRYQdp1A","session_id":"992d880b-e463-4199-be8a-c9ca68db2e09","uuid":"8644f8ec-9e51-40a8-a8ad-87375805c672"}
