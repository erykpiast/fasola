-like content\n   985→    const nextSourceLines = lines.slice(candidate.position + 1, candidate.position + 2);\n   986→    const followedByIngredients = nextSourceLines.some(\n   987→      (l) => looksLikeIngredient(l.trim()) || startsWithNumber(l.trim())\n   988→    );\n   989→    if (!followedByIngredients) return true;\n   990→    // Only remove if a longer candidate contains this one as a substring\n   991→    const candidateLower = candidate.text.toLowerCase();\n   992→    const hasLongerParent = rawScored.some(\n   993→      (other) =>\n   994→        other.text !== candidate.text &&\n   995→        other.text.length > candidate.text.length &&\n   996→        other.text.toLowerCase().includes(candidateLower)\n   997→    );\n   998→    return !hasLongerParent;\n   999→  });\n  1000→\n  1001→  // Protect multi-line joins from being destroyed by their own component singles.\n  1002→  // When \"Lamb Stew\" (2-line join) survives AND both \"Lamb\" and \"Stew\" (singles) also survive,\n  1003→  // the join is the intended title — remove the singles.\n  1004→  const joinsToProtect = selected.filter((s) => s.origin === \"2-line\" || s.origin === \"3-line\");\n  1005→  if (joinsToProtect.length > 0) {\n  1006→    const singlesToRemove = new Set<string>();\n  1007→    for (const join of joinsToProtect) {\n  1008→      const joinWords = join.text.split(/\\s+/);\n  1009→      const componentSingles = selected.filter(\n  1010→        (s) => s.origin === \"single\" && joinWords.some((w) => s.text.toLowerCase() === w.toLowerCase())\n  1011→      );\n  1012→      if (componentSingles.length >= Math.min(joinWords.length, 2)) {\n  1013→        componentSingles.forEach((s) => singlesToRemove.add(s.text));\n  1014→      }\n  1015→    }\n  1016→    if (singlesToRemove.size > 0) {\n  1017→      selected = selected.filter((s) => s.origin !== \"single\" || !singlesToRemove.has(s.text));\n  1018→    }\n  1019→  }\n  1020→\n  1021→  // Protect position-0 compound titles from distant sub-section headers.\n  1022→  // When a position-0 compound title is longer and contains a shorter candidate\n  1023→  // that appears > 10 lines later, remove the distant candidate so the dedup\n  1024→  // (shorter-wins rule) doesn't destroy the compound title.\n  1025→  const pos0Compounds = selected.filter((s) => s.position === 0);\n  1026→  if (pos0Compounds.length > 0) {\n  1027→    selected = selected.filter((s) => {\n  1028→      if (s.position === 0) return true;\n  1029→      const sLower = s.text.toLowerCase();\n  1030→      return !pos0Compounds.some(\n  1031→        (p0) =>\n  1032→          p0.position + 10 < s.position &&\n  1033→          s.text.length < p0.text.length &&\n  1034→          p0.text.toLowerCase().includes(sLower)\n  1035→      );\n  1036→    });\n  1037→  }\n  1038→\n  1039→  // Deduplicate: if one title is a substring of another, keep the shorter (more focused) one.\n  1040→  // DO NOT CHANGE THIS LOGIC — it has been incorrectly \"improved\" by the title-loop 5 times.\n  1041→  // The tests require shorter wins: \"Pierogi Ruskie\" over \"Pierogi Ruskie 200g mąki 3 ziemniaki\".\n  1042→  // The pre-filter above handles the conflicting case (structural heading prefix removal) so that\n  1043→  // the incomplete prefix line is never present here when the complete join is in selected.\n  1044→  selected = selected.filter((a) => {\n  1045→    const aLower = a.text.toLowerCase();\n  1046→    return !selected.some(\n  1047→      (b) =>\n  1048→        b !== a &&\n  1049→        aLower.includes(b.text.toLowerCase()) &&"}]},"parent_tool_use_id":"toolu_01GsxFTdnusREzqhYRYQdp1A","session_id":"992d880b-e463-4199-be8a-c9ca68db2e09","uuid":"656808ca-e96b-4f59-8d40-7e34384e8ed1"}
