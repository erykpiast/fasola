{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XDwgn48VJzvdG8cBcqJGgq","type":"tool_result","content":"  1044→  selected = selected.filter((a) => {\n  1045→    const aLower = a.text.toLowerCase();\n  1046→    return !selected.some(\n  1047→      (b) =>\n  1048→        b !== a &&\n  1049→        aLower.includes(b.text.toLowerCase()) &&\n  1050→        b.text.length < a.text.length\n  1051→    );\n  1052→  });\n  1053→\n  1054→  // Multi-title guard: only join multiple candidates with \"+\" when there is\n  1055→  // structural evidence of a multi-recipe page (≥2 ALL_CAPS headings).\n  1056→  // A single ALL_CAPS title among mixed-case survivors is a single-recipe page —\n  1057→  // collapse to the highest-scoring candidate.\n  1058→  // Zero ALL_CAPS survivors → apply positional tiebreak only when candidates are\n  1059→  // spread far apart (>10 lines), which indicates body-text leakage. Closely-\n  1060→  // positioned candidates are likely genuine multi-recipe content.\n  1061→  if (selected.length > 1) {\n  1062→    const allCapsSelected = selected.filter((s) => isAllCaps(s.text));\n  1063→    if (allCapsSelected.length >= 2) {\n  1064→      // Check whether non-first ALL_CAPS headings are section headers within one recipe\n  1065→      // (followed immediately by ingredient-like content) rather than separate recipe titles.\n  1066→      // A multi-recipe page has body text between titles; a single-recipe page has\n  1067→      // ingredient lines immediately after each section heading.\n  1068→      const sortedCaps = [...allCapsSelected].sort((a, b) => a.position - b.position);\n  1069→      const isSubHeader = sortedCaps.slice(1).every((cap) => {\n  1070→        const nextLines = lines.slice(cap.position + 1, cap.position + 3);\n  1071→        return nextLines.some(\n  1072→          (l) => looksLikeIngredient(l.trim()) || /^\\s*\\d/.test(l.trim())\n  1073→        );\n  1074→      });\n  1075→      if (isSubHeader) {\n  1076→        selected = [sortedCaps[0]];\n  1077→      } else {\n  1078→        selected = allCapsSelected;\n  1079→      }\n  1080→    } else if (allCapsSelected.length === 1) {\n  1081→      const theCapCandidate = allCapsSelected[0];\n  1082→      // Use non-empty line count so the 75% threshold is consistent regardless of blank-line density.\n  1083→      const nonEmptyCount = lines.filter((l) => l.trim().length > 0).length;\n  1084→      const capRelPos = theCapCandidate.position / Math.max(nonEmptyCount, 1);\n  1085→      // If the sole ALL_CAPS candidate is in the last 25% of the document,\n  1086→      // it's likely a category footer, not a title. Prefer the best earlier candidate.\n  1087→      if (capRelPos > 0.75) {\n  1088→        const earlierCandidates = selected.filter(\n  1089→          (s) => s.position / Math.max(nonEmptyCount, 1) <= 0.75\n  1090→        );\n  1091→        if (earlierCandidates.length > 0) {\n  1092→          selected = [earlierCandidates.reduce((a, b) => (a.score > b.score ? a : b))];\n  1093→        } else {\n  1094→          // All candidates are in the last 25% — no positional basis to prefer one over another;\n  1095→          // fall back to score, accepting that the guard cannot help here.\n  1096→          selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n  1097→        }\n  1098→      } else {\n  1099→        selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n  1100→      }\n  1101→    } else {\n  1102→      // Zero ALL_CAPS survivors → mixed-case page.\n  1103→      // If all survivors are closely positioned (within 10 lines of each other), keep them all —\n  1104→      // they're likely genuine multi-recipe content on a single page.\n  1105→      // If any survivor is far from the earliest, apply a positional tiebreak: the real title\n  1106→      // is almost always the earliest candidate; distant survivors are likely body-text leakage.\n  1107→      selected.sort((a, b) => a.position - b.position);\n  1108→      const earliest = selected[0];\n  1109→      const farthest = selected[selected.length - 1];\n  1110→      if (farthest.position - earliest.position > 10) {\n  1111→        // Large span → body-text leakage. Collapse to one: prefer the highest-scoring\n  1112→        // candidate within 3 positions of the earliest (position tolerance for OCR gaps),\n  1113→        // falling back to the earliest itself if none score higher.\n  1114→        const closeCompetitors = selected.filter(\n  1115→          (s) => s.position <= earliest.position + 3 && s.score > earliest.score\n  1116→        );\n  1117→        selected = closeCompetitors.length > 0\n  1118→          ? [closeCompetitors.reduce((a, b) => (a.score > b.score ? a : b))]\n  1119→          : [earliest];\n  1120→      }\n  1121→      // Span ≤ 10 → all survivors are closely positioned; fall through keeping all.\n  1122→    }\n  1123→  }\n  1124→\n  1125→  // Cap at 3, sort by document position\n  1126→  selected.sort((a, b) => a.position - b.position);\n  1127→  selected = selected.slice(0, 3);\n  1128→\n  1129→  if (selected.length === 0) {\n  1130→    // Last resort: embedding scoring provided no usable signal.\n  1131→    // Return the earliest candidate that passed hard filters — it already survived\n  1132→    // ingredient, metadata, garbled, section-label, and cooking-instruction checks.\n  1133→    // Position 0 in a recipe file is overwhelmingly the title.\n  1134→    // Exclude hard-disqualified candidates (rawScore -1.0 = truncated OCR artifact).\n  1135→    const lastResort = scored\n  1136→      .slice()\n  1137→      .filter((s) => s.rawScore > -0.5)\n  1138→      .sort((a, b) => a.position - b.position || b.score - a.score);\n  1139→    if (lastResort.length > 0) {\n  1140→      return normalizeOcrTitle(lastResort[0].text.normalize(\"NFC\").trim());\n  1141→    }\n  1142→    return undefined;\n  1143→  }\n  1144→\n  1145→  const result = selected.map((s) => normalizeOcrTitle(s.text.normalize(\"NFC\").trim())).join(\" + \");\n  1146→\n  1147→  return result;\n  1148→}\n  1149→\n  1150→/**\n  1151→ * Extract potential recipe title from OCR text (sync heuristic fallback)\n  1152→ */\n  1153→export function extractTitle(text: string): string | undefined {\n  1154→  if (!text || text.trim().length === 0) {\n  1155→    return undefined;\n  1156→  }\n  1157→\n  1158→  const lines = text.split(\"\\n\").map((line) => line.trim());\n  1159→\n  1160→  for (const line of lines) {\n  1161→    if (line.length === 0) continue;\n  1162→    if (line.length < 3 || line.length > 50) continue;\n  1163→    if (looksLikeIngredient(line)) continue;\n  1164→    if (isAllCaps(line)) continue;\n  1165→    if (startsWithNumber(line)) continue;\n  1166→    return line;\n  1167→  }\n  1168→\n  1169→  return undefined;\n  1170→}\n  1171→"}]},"parent_tool_use_id":"toolu_01GsxFTdnusREzqhYRYQdp1A","session_id":"992d880b-e463-4199-be8a-c9ca68db2e09","uuid":"33babdba-0d18-4a07-9c6e-76c5d32ebeab"}
