{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DP4pq455ufVdpv7m4fAMdz","type":"tool_result","content":"   285→function passesHardFilters(text: string): boolean {\n   286→  if (text.length < 3 || text.length > 80) return false;\n   287→  if (looksLikeIngredient(text)) return false;\n   288→  if (startsWithNumber(text)) return false;\n   289→  if (looksLikeMetadata(text)) return false;\n   290→  if (isLikelyGarbled(text)) return false;\n   291→  if (looksLikeCookingInstruction(text)) return false;\n   292→  // Pipe-separated lines are book category/chapter headers, not recipe titles\n   293→  if (text.includes(\" | \")) return false;\n   294→  // Trailing page number (e.g. \"VEGETABLE SIDES                         145\")\n   295→  if (/\\s{3,}\\d{1,4}\\s*$/.test(text)) return false;\n   296→  // Slash-separated breadcrumbs (e.g., \"/ Jesien / Zupy\") are navigation, not titles\n   297→  // Only filter when 2+ slashes are present — single-slash lines like\n   298→  // \"TITLE / SUBTITLE\" are legitimate continuation-merged titles\n   299→  if ((text.match(/\\//g) || []).length >= 2) return false;\n   300→  // Bullet-list items (ingredients or instruction steps) are never titles\n   301→  if (/^\\s*[-•*]\\s/.test(text)) return false;\n   302→  // \"For the sauce:\", \"For the filling:\" etc. are sub-section headers\n   303→  if (/^For the\\s+/i.test(text) && /:\\s*$/.test(text)) return false;\n   304→  // Lines ending with \":\" are recipe sub-section headers, not titles.\n   305→  // Exception: compound titles using \" : \" as a title separator (e.g. \"LEMON CURD : LEMON CURD WITH THYME\").\n   306→  if (/:\\s*$/.test(text.trim()) && !/ : /.test(text)) return false;\n   307→  // Page references are navigation markers, not recipe titles\n   308→  if (/^Page\\s+\\d+/i.test(text.trim())) return false;\n   309→  if (/^Strona\\s+\\d+/i.test(text.trim())) return false;\n   310→  // Corrupted spillover annotations from synthetic multi-page OCR\n   311→  if (/^\\[CORRUPTED\\s+SPILLOVER/i.test(text.trim())) return false;\n   312→  // Parenthetical OCR annotation lines describing corruption artifacts\n   313→  if (/^\\(OCR\\b/i.test(text.trim())) return false;\n   314→  if (/^\\(.*\\bcorruption\\b/i.test(text.trim())) return false;\n   315→  // Square-bracket category tags (e.g., \"[CLASSIC FALL SOUPS]\")\n   316→  if (/^\\[.*\\]$/.test(text.trim())) return false;\n   317→  // Known recipe section labels are structural headers, not titles\n   318→  if (isSectionLabel(text)) return false;\n   319→  // Single-word non-title fragments\n   320→  const words = text.trim().split(/\\s+/);\n   321→  if (words.length === 1 && NON_TITLE_WORDS.has(text.trim().toLowerCase())) return false;\n   322→  // Lines with ≥8 words are almost certainly body text, not titles.\n   323→  // Exception: multi-title compounds with \" + \", \" : \", or \" & \" separators are allowed.\n   324→  if (words.length >= 8 && !/ [+:&/] /.test(text)) return false;\n   325→  return true;\n   326→}\n   327→\n   328→/**\n   329→ * Detect initial burst of short garbled lines.\n   330→ * Returns the index of the first non-garbled or long line.\n   331→ */\n   332→function findBurstEnd(lines: Array<{ text: string }>): number {\n   333→  let i = 0;\n   334→\n   335→  // Skip overflow preambles: blocks introduced by \"PREVIOUS RECIPE OVERFLOW\",\n   336→  // \"PREVIOUS PAGE CONTENT\", \"CORRUPTED SECTION\", etc. that precede the actual recipe.\n   337→  const OVERFLOW_MARKERS = /\\b(PREVIOUS\\s+(RECIPE|PAGE)\\s+(OVERFLOW|CONTENT)|SPILLOVER|CONTINUATION|CORRUPTED\\s+SECTION)\\b/i;\n   338→  let overflowEnd = 0;\n   339→  for (let k = 0; k < lines.length && k < 30; k++) {\n   340→    if (OVERFLOW_MARKERS.test(lines[k].text)) {\n   341→      // Skip forward past the overflow block to the next visual separator or blank cluster\n   342→      let m = k + 1;\n   343→      while (m < lines.length) {\n   344→        if (/^[=\\-]{4,}$/.test(lines[m].text) || lines[m].text.length === 0) {\n   345→          overflowEnd = m + 1;\n   346→          break;\n   347→        }\n   348→        m++;\n   349→      }\n   350→      if (overflowEnd === 0) overflowEnd = k + 1;\n   351→    }\n   352→  }\n   353→  if (overflowEnd > 0) i = overflowEnd;\n   354→\n   355→  while (i < lines.length && lines[i].text.length < 20 && isLikelyGarbled(lines[i].text) && !isAllCaps(lines[i].text)) {\n   356→    i++;\n   357→  }\n   358→  // Skip long instruction-like prologues: if 5+ consecutive lines look like cooking instructions,\n   359→  // skip them to find the actual title region.\n   360→  if (i === 0) {\n   361→    let j = 0;\n   362→    while (j < lines.length && looksLikeCookingInstruction(lines[j].text)) {\n   363→      j++;\n   364→    }\n   365→    if (j >= 5) {\n   366→      i = j;\n   367→    }\n   368→  }\n   369→  // Skip prose prologues: mid-recipe body text before the actual title.\n   370→  // If 3+ consecutive lines look like running body text (lowercase start, continuation,\n   371→  // or sentence-ending with many words), skip them.\n   372→  if (i === 0) {\n   373→    let j = 0;\n   374→    while (j < lines.length) {\n   375→      const t = lines[j].text;\n   376→      const isBodyText = (\n   377→        /^[a-ząćęłńóśźż]/.test(t) ||\n   378→        t.endsWith(\",\") ||\n   379→        (t.endsWith(\".\") && wordCount(t) > 4)\n   380→      ) && wordCount(t) >= 4;\n   381→      if (isBodyText) j++;\n   382→      else break;\n   383→    }\n   384→    if (j >= 3) i = j;\n   385→  }\n   386→  return i;\n   387→}\n   388→\n   389→function stripParentheticalGloss(text: string): string {\n   390→  // Strip trailing English-gloss parentheticals from ALL_CAPS titles.\n   391→  // e.g. \"PIEROGI RUSKIE (Boiled Dumplings with Potato and Cheese)\" → \"PIEROGI RUSKIE\"\n   392→  // Keep if parenthetical is ALL_CAPS (variation/subtitle in same language).\n   393→  // Keep if both base and paren are mixed-case (both are part of the title).\n   394→  const match = text.match(/^(.+?)\\s*\\(([^)]+)\\)\\s*$/);\n   395→  if (!match) return text;\n   396→  const [, base, paren] = match;\n   397→  if (isAllCaps(paren)) return text;\n   398→  if (!isAllCaps(base) && !isAllCaps(paren)) return text;\n   399→  return base.trim();\n   400→}\n   401→\n   402→function stripPageNumber(text: string): string {\n   403→  // \"34  Berry Jam\" → \"Berry Jam\" (2+ spaces distinguishes from \"2 eggs\")\n   404→  const match = text.match(/^\\d{1,3}\\s{2,}(.+)$/);\n   405→  return match ? match[1] : text;\n   406→}\n   407→\n   408→function wordCount(text: string): number {\n   409→  return text.split(/\\s+/).filter((w) => w.length > 0).length;\n   410→}\n   411→\n   412→/**\n   413→ * Build candidate strings from lines: single lines plus multi-line joins (2-3 consecutive).\n   414→ * Skips initial burst of short garbled lines. Scans all remaining lines. Caps at 25.\n   415→ */\n   416→export type CandidateOrigin = \"single\" | \"2-line\" | \"3-line\";\n   417→\n   418→function buildCandidates(\n   419→  lines: Array<string>"}]},"parent_tool_use_id":"toolu_01GsxFTdnusREzqhYRYQdp1A","session_id":"992d880b-e463-4199-be8a-c9ca68db2e09","uuid":"fa6864be-42de-44df-99be-ac54b3e8b543"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EjWRtgNLRSMDh1tW9Fc41Y","type":"tool_result","content":"   418→function buildCandidates(\n   419→  lines: Array<string>\n   420→): Array<{ text: string; position: number; origin: CandidateOrigin }> {\n   421→  const nonEmptyLines: Array<{ text: string; index: number }> = [];\n   422→\n   423→  for (let i = 0; i < lines.length; i++) {\n   424→    const trimmed = lines[i].trim();\n   425→    if (trimmed.length > 0) {\n   426→      nonEmptyLines.push({ text: trimmed, index: i });\n   427→    }\n   428→  }\n   429→\n   430→  const burstEnd = findBurstEnd(nonEmptyLines);\n   431→\n   432→  // Pre-join hyphen-broken lines: \"ROASTED CHICKEN WITH ROOT VEGET-\" + \"ABLES\" → single line.\n   433→  // Only applies within the candidate region (after burst end).\n   434→  for (let hi = burstEnd; hi < nonEmptyLines.length - 1; hi++) {\n   435→    if (nonEmptyLines[hi].text.endsWith(\"-\")) {\n   436→      const joined = nonEmptyLines[hi].text.slice(0, -1) + nonEmptyLines[hi + 1].text;\n   437→      nonEmptyLines[hi] = { text: joined, index: nonEmptyLines[hi].index };\n   438→      nonEmptyLines.splice(hi + 1, 1);\n   439→    }\n   440→  }\n   441→\n   442→  // Pre-merge consecutive short ALL_CAPS lines (OCR-fragmented headings).\n   443→  // When a sequence of 2+ ALL_CAPS lines each has ≤2 words and ≤25 chars, they are\n   444→  // almost certainly OCR fragments of a single heading. Merge them into one line so\n   445→  // the complete title enters the candidate pool without hitting the 3-line join ceiling.\n   446→  const capsCoalesced: Array<{ text: string; index: number }> = [];\n   447→  let ci = burstEnd;\n   448→  while (ci < nonEmptyLines.length) {\n   449→    const line = nonEmptyLines[ci];\n   450→    if (\n   451→      isAllCaps(line.text) &&\n   452→      wordCount(line.text) <= 2 &&\n   453→      line.text.length <= 25 &&\n   454→      !isSectionLabel(line.text) &&\n   455→      !looksLikeMetadata(line.text)\n   456→    ) {\n   457→      let merged = line.text;\n   458→      const startIndex = line.index;\n   459→      let j = ci + 1;\n   460→      while (j < nonEmptyLines.length) {\n   461→        const next = nonEmptyLines[j];\n   462→        if (\n   463→          isAllCaps(next.text) &&\n   464→          wordCount(next.text) <= 2 &&\n   465→          next.text.length <= 25 &&\n   466→          !isSectionLabel(next.text) &&\n   467→          !looksLikeMetadata(next.text) &&\n   468→          (merged + \" \" + next.text).length <= 80\n   469→        ) {\n   470→          merged += \" \" + next.text;\n   471→          j++;\n   472→        } else {\n   473→          break;\n   474→        }\n   475→      }\n   476→      if (j > ci + 1) {\n   477→        capsCoalesced.push({ text: merged, index: startIndex });\n   478→        ci = j;\n   479→        continue;\n   480→      }\n   481→    }\n   482→    capsCoalesced.push(line);\n   483→    ci++;\n   484→  }\n   485→\n   486→  // Pre-merge continuation lines: a line starting with /&+:( is never a standalone title.\n   487→  // Merge it into the preceding line so the complete title enters the pool as a single candidate,\n   488→  // avoiding the fragile chain of conditions required by the downstream join survival logic.\n   489→  // Limitation: only one continuation line per preceding line is merged. Titles split across\n   490→  // three or more lines with continuation tokens (rare in practice) are not handled here —\n   491→  // the downstream 2-line and 3-line join candidates cover those cases instead.\n   492→  const mergedLines: Array<{ text: string; index: number }> = [];\n   493→  for (let i = 0; i < capsCoalesced.length; i++) {\n   494→    const line = capsCoalesced[i];\n   495→    if (i + 1 < capsCoalesced.length) {\n   496→      const nextText = capsCoalesced[i + 1].text;\n   497→      if (/^[/&+:(]/.test(nextText)) {\n   498→        mergedLines.push({ text: `${line.text} ${nextText}`, index: line.index });\n   499→        i++;\n   500→        continue;\n   501→      }\n   502→    }\n   503→    mergedLines.push(line);\n   504→  }\n   505→\n   506→  const candidates: Array<{ text: string; position: number; origin: CandidateOrigin }> = [];\n   507→  const seen = new Set<string>();\n   508→\n   509→  // Build a set of positions to skip: short ALL_CAPS lines immediately following metadata\n   510→  const metadataContinuationPositions = new Set<number>();\n   511→  for (let i = 0; i < mergedLines.length - 1; i++) {\n   512→    if (looksLikeMetadata(mergedLines[i].text)) {\n   513→      const next = mergedLines[i + 1];\n   514→      if (isAllCaps(next.text) && wordCount(next.text) <= 2 && next.text.length <= 15) {\n   515→        metadataContinuationPositions.add(next.index);\n   516→      }\n   517→    }\n   518→  }\n   519→\n   520→  for (let i = 0; i < mergedLines.length; i++) {\n   521→    const line = mergedLines[i];\n   522→\n   523→    // Skip metadata continuation fragments\n   524→    if (metadataContinuationPositions.has(line.index)) continue;\n   525→\n   526→    // Single line — strip page-number prefixes and parenthetical glosses before scoring\n   527→    const singleText = stripParentheticalGloss(stripPageNumber(line.text));\n   528→    if (passesHardFilters(singleText)) {\n   529→      const norm = singleText.toLowerCase();\n   530→      if (!seen.has(norm)) {\n   531→        seen.add(norm);\n   532→        candidates.push({ text: singleText, position: line.index, origin: \"single\" });\n   533→      }\n   534→    }\n   535→\n   536→    // 2-line join — skip if first line is a section label AND join would be ≤2 words\n   537→    // (a section label followed by modifiers is likely a recipe title, not a category header)\n   538→    if (i + 1 < mergedLines.length) {\n   539→      const joined2 = `${line.text} ${mergedLines[i + 1].text}`;\n   540→      const shouldBlock2 = isSectionLabel(line.text) &&\n   541→        (wordCount(joined2) <= 2 || isAlwaysBlockJoinLabel(line.text));\n   542→      if (!shouldBlock2 && passesHardFilters(joined2)) {\n   543→        const norm = joined2.toLowerCase();\n   544→        if (!seen.has(norm)) {\n   545→          seen.add(norm);\n   546→          candidates.push({ text: joined2, position: line.index, origin: \"2-line\" });\n   547→        }\n   548→      }\n   549→    }\n   550→\n   551→    // 3-line join — skip if first line is a section label AND join would be ≤2 words\n   552→    if (i + 2 < mergedLines.length) {\n   553→      const joined3 = `${line.text} ${mergedLines[i + 1].text} ${mergedLines[i + 2].text}`;\n   554→      const shouldBlock3 = isSectionLabel(line.text) &&\n   555→        (wordCount(joined3) <= 2 || isAlwaysBlockJoinLabel(line.text));\n   556→      if (!shouldBlock3 && passesHardFilters(joined3)) {\n   557→        const norm = joined3.toLowerCase();\n   558→        if (!seen.has(norm)) {\n   559→          seen.add(norm);\n   560→          candidates.push({ text: joined3, position: line.index, origin: \"3-line\" });\n   561→        }\n   562→      }\n   563→    }\n   564→  }\n   565→\n   566→  // Pre-filter to 25 before embedding calls: prefer ALL_CAPS and short candidates.\n   567→  // Position-based scoring handles final ranking.\n   568→  if (candidates.length > 25) {\n   569→    const prioritized = candidates.slice().sort((a, b) => {\n   570→      const aAllCaps = isAllCaps(a.text) ? 0 : 1;\n   571→      const bAllCaps = isAllCaps(b.text) ? 0 : 1;\n   572→      if (aAllCaps !== bAllCaps) return aAllCaps - bAllCaps;\n   573→      const aShort = wordCount(a.text) <= 5 ? 0 : 1;\n   574→      const bShort = wordCount(b.text) <= 5 ? 0 : 1;\n   575→      return aShort - bShort;\n   576→    });\n   577→    return prioritized.slice(0, 25);\n   578→  }\n   579→\n   580→  return candidates;\n   581→}\n   582→\n   583→/**\n   584→ * Convert an ALL_CAPS string to Title Case, using a small-words list.\n   585→ * Preserves Polish/French diacritics.\n   586→ */\n   587→function toTitleCase(text: string): string {\n   588→  const smallWords = new Set([\n   589→    \"a\", \"an\", \"the\", \"and\", \"but\", \"or\", \"for\", \"nor\",\n   590→    \"in\", \"on\", \"at\", \"to\", \"of\", \"by\", \"with\", \"from\",\n   591→    \"z\", \"w\", \"i\", \"ze\", \"na\", \"do\", \"od\", \"za\", \"po\",\n   592→  ]);\n   593→  return text.split(/(\\s+)/).map((word, idx) => {\n   594→    if (/^\\s+$/.test(word)) return word;\n   595→    const lower = word.toLowerCase();\n   596→    if (idx === 0 || !smallWords.has(lower)) {\n   597→      return lower.charAt(0).toUpperCase() + lower.slice(1);\n   598→    }\n   599→    return lower;\n   600→  }).join(\"\");\n   601→}\n   602→\n   603→/**\n   604→ * Post-processing normalization for OCR-extracted titles.\n   605→ * Strips stray section markers and substitutes common OCR digit-for-letter artifacts.\n   606→ * Title-case conversion is applied only when a substitution was actually made, so\n   607→ * clean ALL_CAPS titles (e.g. \"CHOCOLATE CAKE\") are returned unchanged."}]},"parent_tool_use_id":"toolu_01GsxFTdnusREzqhYRYQdp1A","session_id":"992d880b-e463-4199-be8a-c9ca68db2e09","uuid":"c303c8e2-f98d-4fe4-879c-f02781e2f55f"}
