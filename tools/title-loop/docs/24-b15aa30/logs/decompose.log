{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FsW2U416E8xSEKS3xrxRR3","type":"tool_result","content":"   206→function isLikelyGarbled(text: string): boolean {\n   207→  const letters = text.replace(/[^a-zA-Z]/g, \"\");\n   208→  if (letters.length < 2) return true;\n   209→\n   210→  // Check vowel ratio — English/Polish text typically has 30–50% vowels\n   211→  const vowels = letters.replace(/[^aeiouAEIOUyYąęóĄĘÓ]/g, \"\").length;\n   212→  const vowelRatio = vowels / letters.length;\n   213→  if (vowelRatio < 0.10 || vowelRatio > 0.85) return true;\n   214→\n   215→  // Single orphaned word ≤3 letters that isn't a common word\n   216→  const words = text.trim().split(/\\s+/);\n   217→  const COMMON_SHORT = new Set([\n   218→    \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"had\", \"her\",\n   219→    \"was\", \"one\", \"our\", \"out\", \"are\", \"has\", \"his\", \"how\", \"its\", \"may\",\n   220→    \"new\", \"now\", \"old\", \"see\", \"way\", \"who\", \"did\", \"get\", \"let\", \"say\",\n   221→    \"she\", \"too\", \"use\",\n   222→  ]);\n   223→  // Count all Unicode letters (not just ASCII) so Polish words like \"Żur\" (3 letters) pass\n   224→  const unicodeLetters = text.trim().replace(/[^a-zA-ZąćęłńóśźżĄĆĘŁŃÓŚŹŻ]/g, \"\");\n   225→  if (words.length === 1 && unicodeLetters.length <= 3 && !COMMON_SHORT.has(text.trim().toLowerCase())) {\n   226→    return true;\n   227→  }\n   228→\n   229→  // Single word with internal lowercase→uppercase transition — OCR noise (e.g., \"UuIw\", \"aBC\")\n   230→  // No recipe title uses this pattern as a standalone single-word candidate.\n   231→  if (words.length === 1 && /[a-z][A-Z]/.test(text.trim())) {\n   232→    return true;\n   233→  }\n   234→\n   235→  // Recipe titles never start with a lowercase letter\n   236→  if (/^[a-z]/.test(text.trim())) {\n   237→    return true;\n   238→  }\n   239→\n   240→  // Mid-text sentence boundary (\". \" followed by a letter) — body text fragment spliced from multiple sentences\n   241→  const trimmed = text.trim();\n   242→  if (/\\.\\s+[a-zA-Z]/.test(trimmed) && !trimmed.endsWith(\")\")) {\n   243→    return true;\n   244→  }\n   245→\n   246→  // Multi-word candidate containing a garbled OCR fragment: a short lowercase word that isn't a known short word\n   247→  if (words.length >= 2) {\n   248→    const commonShort2 = new Set([\n   249→      \"a\", \"i\", \"of\", \"or\", \"to\", \"in\", \"on\", \"is\", \"it\", \"an\",\n   250→      \"as\", \"at\", \"by\", \"do\", \"go\", \"if\", \"no\", \"so\", \"up\", \"we\",\n   251→      \"w\", \"z\",   // Polish prepositions (basic)\n   252→      \"ze\", \"bo\", \"na\", \"ni\", \"po\", \"ku\", \"od\", \"za\", \"co\",  // Polish prepositions (extended)\n   253→    ]);\n   254→    const hasGarbledWord = words.some(\n   255→      (w) =>\n   256→        /^[a-z]/.test(w) &&\n   257→        w.replace(/[^a-z]/g, \"\").length <= 2 &&\n   258→        !commonShort2.has(w.toLowerCase())\n   259→    );\n   260→    if (hasGarbledWord) {\n   261→      return true;\n   262→    }\n   263→  }\n   264→\n   265→  return false;"}]},"parent_tool_use_id":"toolu_01GsxFTdnusREzqhYRYQdp1A","session_id":"992d880b-e463-4199-be8a-c9ca68db2e09","uuid":"31b14a47-5933-424e-9331-50490a5be910"}
