{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EecYUaCvmos49aYSETTZaB","type":"tool_result","content":"   604→/**\n   605→ * OCR digit→letter substitution map.\n   606→ * Each key is a character that OCR commonly confuses; values are possible correct letters.\n   607→ */\n   608→const OCR_SUBSTITUTIONS: Record<string, string[]> = {\n   609→  \"0\": [\"o\"],\n   610→  \"1\": [\"i\", \"l\"],\n   611→  \"4\": [\"a\"],\n   612→  \"5\": [\"s\"],\n   613→  \"¡\": [\"i\"],\n   614→  \"í\": [\"i\"],\n   615→  \"€\": [\"e\"],\n   616→};\n   617→\n   618→const OCR_ARTIFACT_PATTERN = /[0-9¡Íí€]/;\n   619→\n   620→/**\n   621→ * Attempt to repair a single OCR-corrupted word using dictionary lookup.\n   622→ * Returns the repaired word if a dictionary match is found, otherwise returns the original.\n   623→ */\n   624→function repairOcrWord(word: string): string {\n   625→  if (!OCR_ARTIFACT_PATTERN.test(word)) return word;\n   626→\n   627→  const lower = word.toLowerCase();\n   628→\n   629→  const positions: { index: number; replacements: string[] }[] = [];\n   630→  for (let i = 0; i < lower.length; i++) {\n   631→    const replacements = OCR_SUBSTITUTIONS[lower[i]];\n   632→    if (replacements) {\n   633→      positions.push({ index: i, replacements });\n   634→    }\n   635→  }\n   636→\n   637→  if (positions.length === 0 || positions.length > 8) return word;\n   638→\n   639→  const candidates = generateSubstitutions(lower, positions, 0);\n   640→\n   641→  for (const candidate of candidates) {\n   642→    if (FOOD_DICTIONARY.has(candidate)) {\n   643→      if (word === word.toUpperCase()) return candidate.toUpperCase();\n   644→      if (word[0] === word[0].toUpperCase()) {\n   645→        return candidate[0].toUpperCase() + candidate.slice(1);\n   646→      }\n   647→      return candidate;\n   648→    }\n   649→  }\n   650→\n   651→  return word;\n   652→}\n   653→\n   654→/**\n   655→ * Recursively generate all substitution variants for OCR artifact positions.\n   656→ */\n   657→function generateSubstitutions(\n   658→  base: string,\n   659→  positions: { index: number; replacements: string[] }[],\n   660→  posIdx: number,\n   661→): string[] {\n   662→  if (posIdx >= positions.length) return [base];\n   663→\n   664→  const { index, replacements } = positions[posIdx];\n   665→  const results: string[] = [];\n   666→\n   667→  for (const replacement of replacements) {\n   668→    const variant = base.slice(0, index) + replacement + base.slice(index + 1);\n   669→    results.push(...generateSubstitutions(variant, positions, posIdx + 1));\n   670→  }\n   671→\n   672→  return results;\n   673→}\n   674→\n   675→/**\n   676→ * Apply dictionary-guided OCR repair to all words in a text string.\n   677→ */\n   678→function repairOcrText(text: string): string {\n   679→  return text\n   680→    .split(/\\s+/)\n   681→    .map((word) => {\n   682→      const match = word.match(/^([^a-zA-Z0-9À-ÿ]*)(.*?)([^a-zA-Z0-9À-ÿ]*)$/);\n   683→      if (!match) return word;\n   684→      const [, prefix, core, suffix] = match;\n   685→      if (!core) return word;\n   686→      const repaired = repairOcrWord(core);\n   687→      return prefix + repaired + suffix;\n   688→    })\n   689→    .join(\" \");\n   690→}\n   691→\n   692→/**\n   693→ * Post-processing normalization for OCR-extracted titles.\n   694→ * Strips stray section markers and substitutes common OCR digit-for-letter artifacts.\n   695→ * Title-case conversion is applied only when a substitution was actually made, so\n   696→ * clean ALL_CAPS titles (e.g. \"CHOCOLATE CAKE\") are returned unchanged.\n   697→ */\n   698→function normalizeOcrTitle(raw: string): string {\n   699→  let text = raw.trim();\n   700→\n   701→  // Step 0: Dictionary-guided OCR repair — resolve ambiguous substitutions\n   702→  // using word-level context before applying blind character replacements.\n   703→  text = repairOcrText(text);\n   704→\n   705→  // Step 1: Strip trailing section markers greedily appended to the title.\n   706→  // e.g. \"MAKOWIEC ZE ŚLIWKAMI + SERVING AND STORAGE:\" → \"MAKOWIEC ZE ŚLIWKAMI\"\n   707→  text = text.replace(\n   708→    /\\s*\\+\\s*(?:SERV[IÍ1]NG(?:\\s+AND\\s+STORAGE)?|TOPPING|NOTES?|TIPS?)\\s*:?\\s*$/i,\n   709→    \"\"\n   710→  );\n   711→\n   712→  // Step 2: OCR character substitution.\n   713→  // For ALL_CAPS text, apply digit-for-letter substitutions.\n   714→  const beforeSub = text;\n   715→  if (isAllCaps(text)) {\n   716→    text = text\n   717→      .replace(/1/g, \"I\")\n   718→      .replace(/0(?=[A-ZÀ-Ż])/g, \"O\")\n   719→      .replace(/(?<=[A-ZÀ-Ż])0/g, \"O\")\n   720→      .replace(/4(?=[A-ZÀ-Ż])/g, \"A\")\n   721→      .replace(/(?<=[A-ZÀ-Ż])4/g, \"A\")\n   722→      .replace(/5(?=[A-ZÀ-Ż])/g, \"S\")\n   723→      .replace(/(?<=[A-ZÀ-Ż])5/g, \"S\")\n   724→      .replace(/¡/g, \"I\")\n   725→      .replace(/€/g, \"E\")\n   726→      .replace(/[ÍÌ]/g, \"I\");\n   727→  } else {\n   728→    // Mixed-case: fix per-word (digits between lowercase letters)\n   729→    text = text.split(/(\\s+)/).map((token) => {\n   730→      if (/^\\s+$/.test(token)) return token;\n   731→      if (isAllCaps(token) && token.length > 1) {\n   732→        return token\n   733→          .replace(/1/g, \"I\")\n   734→          .replace(/0(?=[A-Z])/g, \"O\")\n   735→          .replace(/(?<=[A-Z])0/g, \"O\");\n   736→      }\n   737→      return token\n   738→        .replace(/(?<=[a-zà-ż])1/g, \"l\")\n   739→        .replace(/1(?=[a-zà-ż])/g, \"l\")\n   740→        .replace(/¡/g, \"i\")\n   741→        .replace(/€/g, \"e\");\n   742→    }).join(\"\");\n   743→  }\n   744→\n   745→  // Step 3: Title-case conversion — ONLY when OCR substitution changed the text.\n   746→  // This preserves clean ALL_CAPS titles (e.g. \"CHOCOLATE CAKE\") as-is.\n   747→  if (text !== beforeSub && isAllCaps(text)) {\n   748→    text = toTitleCase(text);\n   749→  }\n   750→\n   751→  return text.trim();\n   752→}\n   753→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"92a60a35-3fb6-4325-aecf-45d5cd420095","uuid":"026dba65-0cbc-49ca-9ffe-e5a76c917fd6","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/title-extractor.ts","content":"/**\n * OCR digit→letter substitution map.\n * Each key is a character that OCR commonly confuses; values are possible correct letters.\n */\nconst OCR_SUBSTITUTIONS: Record<string, string[]> = {\n  \"0\": [\"o\"],\n  \"1\": [\"i\", \"l\"],\n  \"4\": [\"a\"],\n  \"5\": [\"s\"],\n  \"¡\": [\"i\"],\n  \"í\": [\"i\"],\n  \"€\": [\"e\"],\n};\n\nconst OCR_ARTIFACT_PATTERN = /[0-9¡Íí€]/;\n\n/**\n * Attempt to repair a single OCR-corrupted word using dictionary lookup.\n * Returns the repaired word if a dictionary match is found, otherwise returns the original.\n */\nfunction repairOcrWord(word: string): string {\n  if (!OCR_ARTIFACT_PATTERN.test(word)) return word;\n\n  const lower = word.toLowerCase();\n\n  const positions: { index: number; replacements: string[] }[] = [];\n  for (let i = 0; i < lower.length; i++) {\n    const replacements = OCR_SUBSTITUTIONS[lower[i]];\n    if (replacements) {\n      positions.push({ index: i, replacements });\n    }\n  }\n\n  if (positions.length === 0 || positions.length > 8) return word;\n\n  const candidates = generateSubstitutions(lower, positions, 0);\n\n  for (const candidate of candidates) {\n    if (FOOD_DICTIONARY.has(candidate)) {\n      if (word === word.toUpperCase()) return candidate.toUpperCase();\n      if (word[0] === word[0].toUpperCase()) {\n        return candidate[0].toUpperCase() + candidate.slice(1);\n      }\n      return candidate;\n    }\n  }\n\n  return word;\n}\n\n/**\n * Recursively generate all substitution variants for OCR artifact positions.\n */\nfunction generateSubstitutions(\n  base: string,\n  positions: { index: number; replacements: string[] }[],\n  posIdx: number,\n): string[] {\n  if (posIdx >= positions.length) return [base];\n\n  const { index, replacements } = positions[posIdx];\n  const results: string[] = [];\n\n  for (const replacement of replacements) {\n    const variant = base.slice(0, index) + replacement + base.slice(index + 1);\n    results.push(...generateSubstitutions(variant, positions, posIdx + 1));\n  }\n\n  return results;\n}\n\n/**\n * Apply dictionary-guided OCR repair to all words in a text string.\n */\nfunction repairOcrText(text: string): string {\n  return text\n    .split(/\\s+/)\n    .map((word) => {\n      const match = word.match(/^([^a-zA-Z0-9À-ÿ]*)(.*?)([^a-zA-Z0-9À-ÿ]*)$/);\n      if (!match) return word;\n      const [, prefix, core, suffix] = match;\n      if (!core) return word;\n      const repaired = repairOcrWord(core);\n      return prefix + repaired + suffix;\n    })\n    .join(\" \");\n}\n\n/**\n * Post-processing normalization for OCR-extracted titles.\n * Strips stray section markers and substitutes common OCR digit-for-letter artifacts.\n * Title-case conversion is applied only when a substitution was actually made, so\n * clean ALL_CAPS titles (e.g. \"CHOCOLATE CAKE\") are returned unchanged.\n */\nfunction normalizeOcrTitle(raw: string): string {\n  let text = raw.trim();\n\n  // Step 0: Dictionary-guided OCR repair — resolve ambiguous substitutions\n  // using word-level context before applying blind character replacements.\n  text = repairOcrText(text);\n\n  // Step 1: Strip trailing section markers greedily appended to the title.\n  // e.g. \"MAKOWIEC ZE ŚLIWKAMI + SERVING AND STORAGE:\" → \"MAKOWIEC ZE ŚLIWKAMI\"\n  text = text.replace(\n    /\\s*\\+\\s*(?:SERV[IÍ1]NG(?:\\s+AND\\s+STORAGE)?|TOPPING|NOTES?|TIPS?)\\s*:?\\s*$/i,\n    \"\"\n  );\n\n  // Step 2: OCR character substitution.\n  // For ALL_CAPS text, apply digit-for-letter substitutions.\n  const beforeSub = text;\n  if (isAllCaps(text)) {\n    text = text\n      .replace(/1/g, \"I\")\n      .replace(/0(?=[A-ZÀ-Ż])/g, \"O\")\n      .replace(/(?<=[A-ZÀ-Ż])0/g, \"O\")\n      .replace(/4(?=[A-ZÀ-Ż])/g, \"A\")\n      .replace(/(?<=[A-ZÀ-Ż])4/g, \"A\")\n      .replace(/5(?=[A-ZÀ-Ż])/g, \"S\")\n      .replace(/(?<=[A-ZÀ-Ż])5/g, \"S\")\n      .replace(/¡/g, \"I\")\n      .replace(/€/g, \"E\")\n      .replace(/[ÍÌ]/g, \"I\");\n  } else {\n    // Mixed-case: fix per-word (digits between lowercase letters)\n    text = text.split(/(\\s+)/).map((token) => {\n      if (/^\\s+$/.test(token)) return token;\n      if (isAllCaps(token) && token.length > 1) {\n        return token\n          .replace(/1/g, \"I\")\n          .replace(/0(?=[A-Z])/g, \"O\")\n          .replace(/(?<=[A-Z])0/g, \"O\");\n      }\n      return token\n        .replace(/(?<=[a-zà-ż])1/g, \"l\")\n        .replace(/1(?=[a-zà-ż])/g, \"l\")\n        .replace(/¡/g, \"i\")\n        .replace(/€/g, \"e\");\n    }).join(\"\");\n  }\n\n  // Step 3: Title-case conversion — ONLY when OCR substitution changed the text.\n  // This preserves clean ALL_CAPS titles (e.g. \"CHOCOLATE CAKE\") as-is.\n  if (text !== beforeSub && isAllCaps(text)) {\n    text = toTitleCase(text);\n  }\n\n  return text.trim();\n}\n","numLines":150,"startLine":604,"totalLines":1264}}}
