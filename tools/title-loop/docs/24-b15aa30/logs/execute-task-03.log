{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01T4fVBbAKpBvn4TjmLr1eQB","type":"tool_result","content":"   799→\n   800→  // Pass 1: compute rawScore for all candidates (embedding quality signal)\n   801→  const rawScored: Array<{ text: string; position: number; origin: CandidateOrigin; rawScore: number; embedding: Array<number> }> = [];\n   802→  for (const candidate of candidates) {\n   803→    const embedding = await embed(candidate.text);\n   804→    const titleSim = cosineSimilarity(embedding, cachedTitleRefEmbedding);\n   805→    const headerSim = cosineSimilarity(embedding, cachedHeaderRefEmbedding);\n   806→    const noiseSim = cosineSimilarity(embedding, cachedNoiseRefEmbedding);\n   807→    const rawScore = titleSim - Math.max(headerSim, noiseSim);\n   808→    rawScored.push({ text: candidate.text, position: candidate.position, origin: candidate.origin, rawScore, embedding });\n   809→  }\n   810→\n   811→  // Select baseHeading by embedding quality (rawScore), not position.\n   812→  // This prevents OCR-garbled fragments from claiming the structural heading slot.\n   813→  const structuralCandidates = rawScored.filter((s) => isStructuralHeading(s));\n   814→\n   815→  // Penalize structural headings with truncated OCR words:\n   816→  // if \"FRON\" appears and another heading has \"SAFFRON\", \"FRON\" is likely garbled.\n   817→  for (const sc of structuralCandidates) {\n   818→    const sigWords = sc.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   819→    for (const other of structuralCandidates) {\n   820→      if (other === sc) continue;\n   821→      const otherSigWords = other.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   822→      const hasTruncation = sigWords.some((w) =>\n   823→        otherSigWords.some((ow) => ow !== w && ow.length > w.length && ow.endsWith(w))\n   824→      );\n   825→      if (hasTruncation) {\n   826→        sc.rawScore = -1.0;  // Hard disqualification — truncated OCR artifact\n   827→        break;\n   828→      }\n   829→    }\n   830→  }\n   831→\n   832→  const bestStructural = structuralCandidates.length > 0\n   833→    ? structuralCandidates.reduce((a, b) => {\n   834→        const scoreDiff = a.rawScore - b.rawScore;\n   835→        if (Math.abs(scoreDiff) > 0.03) return scoreDiff > 0 ? a : b;\n   836→        // Tiebreak: single-line origin beats multi-line joins (avoids conflating two separate headings)\n   837→        if (a.origin === \"single\" && b.origin !== \"single\") return a;\n   838→        if (b.origin === \"single\" && a.origin !== \"single\") return b;\n   839→        // Tiebreak: more words (more specific) → better\n   840→        const wcDiff = wordCount(b.text) - wordCount(a.text);\n   841→        if (wcDiff !== 0) return wcDiff > 0 ? b : a;\n   842→        // Tiebreak: earlier position → better\n   843→        return a.position < b.position ? a : b;\n   844→      })\n   845→    : null;\n   846→  const baseHeading = bestStructural ?? undefined;\n   847→\n   848→  // When the best structural heading has a continuation on the next line introduced by a\n   849→  // punctuation token (/, &, +, :, or parenthesis), prefer the longer 2-line join as the\n   850→  // complete heading. E.g. \"SAFFRON WHEAT BUNS WITH QUARK\" + \"/ COTTAGE CHEESE (VARIATION D)\".\n   851→  // Guard: the remainder after the prefix must start with a continuation character to avoid\n   852→  // merging two separate consecutive recipe titles (FINNISH MILK FLATBREADS stays separate\n   853→  // from FINNISH POTATO FLATBREADS because \"FINNISH\" does not start with a continuation token).\n   854→  let firstStructuralHeading = baseHeading && (\n   855→    rawScored.find((c) => {\n   856→      if (!isStructuralHeading(c)) return false;\n   857→      const hLower = baseHeading.text.toLowerCase();\n   858→      const cLower = c.text.toLowerCase();\n   859→      return cLower.startsWith(hLower + \" \") && /^[/&+:(]/.test(cLower.slice(hLower.length + 1));\n   860→    }) ?? baseHeading\n   861→  );\n   862→\n   863→  // Pass 2: apply bonuses\n   864→  const scored: Array<{ text: string; position: number; origin: CandidateOrigin; score: number; rawScore: number; baseScore: number; thresholdScore: number }> = rawScored.map((rs) => {\n   865→    // Position factor: multiplicative tiebreaker — amplifies existing signal, doesn't replace it\n   866→    const relativePosition = rs.position / lines.length;\n   867→    const positionFactor = relativePosition < 0.5\n   868→      ? 1.0 + 0.12 * (1 - relativePosition * 2)\n   869→      : 1.0;\n   870→\n   871→    // ALL_CAPS bonus: recipe books use ALL_CAPS for titles and section headings.\n   872→    // Single-word ALL_CAPS terms are overwhelmingly section/category labels, not recipe titles;\n   873→    // real recipe titles in ALL_CAPS are almost always multi-word. Reduce the bonus for single words.\n   874→    const allCapsBonus = isAllCaps(rs.text) && rs.text.replace(/[^a-zA-Z]/g, \"\").length >= 4\n   875→      ? (wordCount(rs.text) >= 2 ? 0.08 : 0.03)\n   876→      : 0;\n   877→\n   878→    // Structural heading bonus: best ALL_CAPS heading (or its continuation join) is almost always the recipe title\n   879→    const structuralBonus = firstStructuralHeading && rs.text === firstStructuralHeading.text ? 0.10 : 0;\n   880→\n   881→    // thresholdScore excludes structural bonus so the bonus doesn't inflate the threshold\n   882→    // and prevent equally-valid structural headings from passing on multi-recipe pages.\n   883→    const thresholdScore = rs.rawScore + allCapsBonus;\n   884→    // baseScore excludes position factor — used for diagnostics and ranking\n   885→    const baseScore = rs.rawScore + allCapsBonus + structuralBonus;\n   886→    const score = rs.rawScore * positionFactor + allCapsBonus + structuralBonus;\n   887→    return { text: rs.text, position: rs.position, origin: rs.origin, score, rawScore: rs.rawScore, baseScore, thresholdScore };\n   888→  });\n   889→\n   890→  if (scored.length === 0) {\n   891→    return undefined;\n   892→  }\n   893→\n   894→  // --- Pre-threshold bilingual title detection ---\n   895→  // When a mixed-case candidate at position 0 is followed by an ALL_CAPS candidate\n   896→  // at position ≤ 2 that is semantically similar to it, this is a bilingual recipe\n   897→  // page (e.g., Polish title + ALL_CAPS Korean romanization). Suppress confirmed\n   898→  // translation candidates before computing threshold so their bonuses don't inflate\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"92a60a35-3fb6-4325-aecf-45d5cd420095","uuid":"86d168ce-c203-4156-9828-2f807a465f36","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/title-extractor.ts","content":"\n  // Pass 1: compute rawScore for all candidates (embedding quality signal)\n  const rawScored: Array<{ text: string; position: number; origin: CandidateOrigin; rawScore: number; embedding: Array<number> }> = [];\n  for (const candidate of candidates) {\n    const embedding = await embed(candidate.text);\n    const titleSim = cosineSimilarity(embedding, cachedTitleRefEmbedding);\n    const headerSim = cosineSimilarity(embedding, cachedHeaderRefEmbedding);\n    const noiseSim = cosineSimilarity(embedding, cachedNoiseRefEmbedding);\n    const rawScore = titleSim - Math.max(headerSim, noiseSim);\n    rawScored.push({ text: candidate.text, position: candidate.position, origin: candidate.origin, rawScore, embedding });\n  }\n\n  // Select baseHeading by embedding quality (rawScore), not position.\n  // This prevents OCR-garbled fragments from claiming the structural heading slot.\n  const structuralCandidates = rawScored.filter((s) => isStructuralHeading(s));\n\n  // Penalize structural headings with truncated OCR words:\n  // if \"FRON\" appears and another heading has \"SAFFRON\", \"FRON\" is likely garbled.\n  for (const sc of structuralCandidates) {\n    const sigWords = sc.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n    for (const other of structuralCandidates) {\n      if (other === sc) continue;\n      const otherSigWords = other.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n      const hasTruncation = sigWords.some((w) =>\n        otherSigWords.some((ow) => ow !== w && ow.length > w.length && ow.endsWith(w))\n      );\n      if (hasTruncation) {\n        sc.rawScore = -1.0;  // Hard disqualification — truncated OCR artifact\n        break;\n      }\n    }\n  }\n\n  const bestStructural = structuralCandidates.length > 0\n    ? structuralCandidates.reduce((a, b) => {\n        const scoreDiff = a.rawScore - b.rawScore;\n        if (Math.abs(scoreDiff) > 0.03) return scoreDiff > 0 ? a : b;\n        // Tiebreak: single-line origin beats multi-line joins (avoids conflating two separate headings)\n        if (a.origin === \"single\" && b.origin !== \"single\") return a;\n        if (b.origin === \"single\" && a.origin !== \"single\") return b;\n        // Tiebreak: more words (more specific) → better\n        const wcDiff = wordCount(b.text) - wordCount(a.text);\n        if (wcDiff !== 0) return wcDiff > 0 ? b : a;\n        // Tiebreak: earlier position → better\n        return a.position < b.position ? a : b;\n      })\n    : null;\n  const baseHeading = bestStructural ?? undefined;\n\n  // When the best structural heading has a continuation on the next line introduced by a\n  // punctuation token (/, &, +, :, or parenthesis), prefer the longer 2-line join as the\n  // complete heading. E.g. \"SAFFRON WHEAT BUNS WITH QUARK\" + \"/ COTTAGE CHEESE (VARIATION D)\".\n  // Guard: the remainder after the prefix must start with a continuation character to avoid\n  // merging two separate consecutive recipe titles (FINNISH MILK FLATBREADS stays separate\n  // from FINNISH POTATO FLATBREADS because \"FINNISH\" does not start with a continuation token).\n  let firstStructuralHeading = baseHeading && (\n    rawScored.find((c) => {\n      if (!isStructuralHeading(c)) return false;\n      const hLower = baseHeading.text.toLowerCase();\n      const cLower = c.text.toLowerCase();\n      return cLower.startsWith(hLower + \" \") && /^[/&+:(]/.test(cLower.slice(hLower.length + 1));\n    }) ?? baseHeading\n  );\n\n  // Pass 2: apply bonuses\n  const scored: Array<{ text: string; position: number; origin: CandidateOrigin; score: number; rawScore: number; baseScore: number; thresholdScore: number }> = rawScored.map((rs) => {\n    // Position factor: multiplicative tiebreaker — amplifies existing signal, doesn't replace it\n    const relativePosition = rs.position / lines.length;\n    const positionFactor = relativePosition < 0.5\n      ? 1.0 + 0.12 * (1 - relativePosition * 2)\n      : 1.0;\n\n    // ALL_CAPS bonus: recipe books use ALL_CAPS for titles and section headings.\n    // Single-word ALL_CAPS terms are overwhelmingly section/category labels, not recipe titles;\n    // real recipe titles in ALL_CAPS are almost always multi-word. Reduce the bonus for single words.\n    const allCapsBonus = isAllCaps(rs.text) && rs.text.replace(/[^a-zA-Z]/g, \"\").length >= 4\n      ? (wordCount(rs.text) >= 2 ? 0.08 : 0.03)\n      : 0;\n\n    // Structural heading bonus: best ALL_CAPS heading (or its continuation join) is almost always the recipe title\n    const structuralBonus = firstStructuralHeading && rs.text === firstStructuralHeading.text ? 0.10 : 0;\n\n    // thresholdScore excludes structural bonus so the bonus doesn't inflate the threshold\n    // and prevent equally-valid structural headings from passing on multi-recipe pages.\n    const thresholdScore = rs.rawScore + allCapsBonus;\n    // baseScore excludes position factor — used for diagnostics and ranking\n    const baseScore = rs.rawScore + allCapsBonus + structuralBonus;\n    const score = rs.rawScore * positionFactor + allCapsBonus + structuralBonus;\n    return { text: rs.text, position: rs.position, origin: rs.origin, score, rawScore: rs.rawScore, baseScore, thresholdScore };\n  });\n\n  if (scored.length === 0) {\n    return undefined;\n  }\n\n  // --- Pre-threshold bilingual title detection ---\n  // When a mixed-case candidate at position 0 is followed by an ALL_CAPS candidate\n  // at position ≤ 2 that is semantically similar to it, this is a bilingual recipe\n  // page (e.g., Polish title + ALL_CAPS Korean romanization). Suppress confirmed\n  // translation candidates before computing threshold so their bonuses don't inflate","numLines":100,"startLine":799,"totalLines":1264}}}
