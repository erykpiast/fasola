{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GcPtcnBpnTEn6Ar9mwgzSW","type":"tool_result","content":"   760→// Module-level cache for reference embeddings\n   761→let cachedTitleRefEmbedding: Array<number> | null = null;\n   762→let cachedHeaderRefEmbedding: Array<number> | null = null;\n   763→let cachedNoiseRefEmbedding: Array<number> | null = null;\n   764→\n   765→export function _resetEmbeddingCacheForTests(): void {\n   766→  cachedTitleRefEmbedding = null;\n   767→  cachedHeaderRefEmbedding = null;\n   768→  cachedNoiseRefEmbedding = null;\n   769→}\n   770→\n   771→export async function extractTitleWithEmbeddings(\n   772→  text: string,\n   773→  embed: EmbedFn\n   774→): Promise<string | undefined> {\n   775→  if (!text || text.trim().length === 0) {\n   776→    return undefined;\n   777→  }\n   778→\n   779→  const lines = text.split(\"\\n\");\n   780→  const candidates = buildCandidates(lines);\n   781→\n   782→  if (candidates.length === 0) {\n   783→    return undefined;\n   784→  }\n   785→\n   786→  // Cache reference embeddings\n   787→  if (!cachedTitleRefEmbedding) {\n   788→    cachedTitleRefEmbedding = await embed(TITLE_REFERENCE);\n   789→  }\n   790→  if (!cachedHeaderRefEmbedding) {\n   791→    cachedHeaderRefEmbedding = await embed(HEADER_REFERENCE);\n   792→  }\n   793→  if (!cachedNoiseRefEmbedding) {\n   794→    cachedNoiseRefEmbedding = await embed(NOISE_REFERENCE);\n   795→  }\n   796→\n   797→  // Find ALL_CAPS candidates with ≥2 words where every significant word has ≥4 alpha letters.\n   798→  // Insignificant tokens (≤1 alpha letter: \"/\", \"&\", \"+\", \":\", \"D)\", etc.) are filtered before\n   799→  // the check so that multi-line joins with continuation punctuation still qualify.\n   800→  const isStructuralHeading = (c: { text: string }): boolean => {\n   801→    if (!isAllCaps(c.text) || wordCount(c.text) < 2) return false;\n   802→    const sigWords = c.text.trim().split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length > 1);\n   803→    return sigWords.length >= 2 && sigWords.every((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   804→  };\n   805→\n   806→  // Pass 1: compute rawScore for all candidates (embedding quality signal)\n   807→  const rawScored: Array<{ text: string; position: number; origin: CandidateOrigin; rawScore: number; embedding: Array<number> }> = [];\n   808→  for (const candidate of candidates) {\n   809→    const embedding = await embed(candidate.text);\n   810→    const titleSim = cosineSimilarity(embedding, cachedTitleRefEmbedding);\n   811→    const headerSim = cosineSimilarity(embedding, cachedHeaderRefEmbedding);\n   812→    const noiseSim = cosineSimilarity(embedding, cachedNoiseRefEmbedding);\n   813→    const rawScore = titleSim - Math.max(headerSim, noiseSim);\n   814→    rawScored.push({ text: candidate.text, position: candidate.position, origin: candidate.origin, rawScore, embedding });\n   815→  }\n   816→\n   817→  // Select baseHeading by embedding quality (rawScore), not position.\n   818→  // This prevents OCR-garbled fragments from claiming the structural heading slot.\n   819→  const structuralCandidates = rawScored.filter((s) => isStructuralHeading(s));\n   820→\n   821→  // Penalize structural headings with truncated OCR words:\n   822→  // if \"FRON\" appears and another heading has \"SAFFRON\", \"FRON\" is likely garbled.\n   823→  for (const sc of structuralCandidates) {\n   824→    const sigWords = sc.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   825→    for (const other of structuralCandidates) {\n   826→      if (other === sc) continue;\n   827→      const otherSigWords = other.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   828→      const hasTruncation = sigWords.some((w) =>\n   829→        otherSigWords.some((ow) => ow !== w && ow.length > w.length && ow.endsWith(w))\n   830→      );\n   831→      if (hasTruncation) {\n   832→        sc.rawScore = -1.0;  // Hard disqualification — truncated OCR artifact\n   833→        break;\n   834→      }\n   835→    }\n   836→  }\n   837→\n   838→  const bestStructural = structuralCandidates.length > 0\n   839→    ? structuralCandidates.reduce((a, b) => {\n   840→        const scoreDiff = a.rawScore - b.rawScore;\n   841→        if (Math.abs(scoreDiff) > 0.03) return scoreDiff > 0 ? a : b;\n   842→        // Tiebreak: single-line origin beats multi-line joins (avoids conflating two separate headings)\n   843→        if (a.origin === \"single\" && b.origin !== \"single\") return a;\n   844→        if (b.origin === \"single\" && a.origin !== \"single\") return b;\n   845→        // Tiebreak: more words (more specific) → better\n   846→        const wcDiff = wordCount(b.text) - wordCount(a.text);\n   847→        if (wcDiff !== 0) return wcDiff > 0 ? b : a;\n   848→        // Tiebreak: earlier position → better\n   849→        return a.position < b.position ? a : b;\n   850→      })\n   851→    : null;\n   852→  const baseHeading = bestStructural ?? undefined;\n   853→\n   854→  // When the best structural heading has a continuation on the next line introduced by a\n   855→  // punctuation token (/, &, +, :, or parenthesis), prefer the longer 2-line join as the\n   856→  // complete heading. E.g. \"SAFFRON WHEAT BUNS WITH QUARK\" + \"/ COTTAGE CHEESE (VARIATION D)\".\n   857→  // Guard: the remainder after the prefix must start with a continuation character to avoid\n   858→  // merging two separate consecutive recipe titles (FINNISH MILK FLATBREADS stays separate\n   859→  // from FINNISH POTATO FLATBREADS because \"FINNISH\" does not start with a continuation token).\n   860→  let firstStructuralHeading = baseHeading && (\n   861→    rawScored.find((c) => {\n   862→      if (!isStructuralHeading(c)) return false;\n   863→      const hLower = baseHeading.text.toLowerCase();\n   864→      const cLower = c.text.toLowerCase();\n   865→      return cLower.startsWith(hLower + \" \") && /^[/&+:(]/.test(cLower.slice(hLower.length + 1));\n   866→    }) ?? baseHeading\n   867→  );\n   868→\n   869→  // Pass 2: apply bonuses\n   870→  const scored: Array<{ text: string; position: number; origin: CandidateOrigin; score: number; rawScore: number; baseScore: number; thresholdScore: number }> = rawScored.map((rs) => {\n   871→    // Position factor: multiplicative tiebreaker — amplifies existing signal, doesn't replace it\n   872→    const relativePosition = rs.position / lines.length;\n   873→    const positionFactor = relativePosition < 0.5\n   874→      ? 1.0 + 0.12 * (1 - relativePosition * 2)\n   875→      : 1.0;\n   876→\n   877→    // ALL_CAPS bonus: recipe books use ALL_CAPS for titles and section headings.\n   878→    // Single-word ALL_CAPS terms are overwhelmingly section/category labels, not recipe titles;\n   879→    // real recipe titles in ALL_CAPS are almost always multi-word. Reduce the bonus for single words.\n   880→    const allCapsBonus = isAllCaps(rs.text) && rs.text.replace(/[^a-zA-Z]/g, \"\").length >= 4\n   881→      ? (wordCount(rs.text) >= 2 ? 0.08 : 0.03)\n   882→      : 0;\n   883→\n   884→    // Structural heading bonus: best ALL_CAPS heading (or its continuation join) is almost always the recipe title\n   885→    const structuralBonus = firstStructuralHeading && rs.text === firstStructuralHeading.text ? 0.10 : 0;\n   886→\n   887→    // thresholdScore excludes structural bonus so the bonus doesn't inflate the threshold\n   888→    // and prevent equally-valid structural headings from passing on multi-recipe pages.\n   889→    const thresholdScore = rs.rawScore + allCapsBonus;\n   890→    // baseScore excludes position factor — used for diagnostics and ranking\n   891→    const baseScore = rs.rawScore + allCapsBonus + structuralBonus;\n   892→    const score = rs.rawScore * positionFactor + allCapsBonus + structuralBonus;\n   893→    return { text: rs.text, position: rs.position, origin: rs.origin, score, rawScore: rs.rawScore, baseScore, thresholdScore };\n   894→  });\n   895→\n   896→  if (scored.length === 0) {\n   897→    return undefined;\n   898→  }\n   899→\n   900→  // --- Pre-threshold bilingual title detection ---\n   901→  // When a mixed-case candidate at position 0 is followed by an ALL_CAPS candidate\n   902→  // at position ≤ 2 that is semantically similar to it, this is a bilingual recipe\n   903→  // page (e.g., Polish title + ALL_CAPS Korean romanization). Suppress confirmed\n   904→  // translation candidates before computing threshold so their bonuses don't inflate\n   905→  // the threshold beyond the mixed-case title's reach.\n   906→  // Note: we check position ≤ 2 (local proximity), not global ALL_CAPS count, so\n   907→  // section headers later in the document (SKŁADNIKI, WARZYWA, etc.) are irrelevant.\n   908→  let translationCandidates: typeof scored = [];\n   909→  let scoredForThreshold = scored;\n   910→  const prePos0 = scored.find((s) => s.position === 0 && !isAllCaps(s.text));\n   911→  if (prePos0) {\n   912→    const nearbyAllCaps = scored.filter(\n   913→      (s) => isAllCaps(s.text) && s.position >= 1 && s.position <= 2 && s.origin === \"single\"\n   914→    );\n   915→    const pos0Embedding = rawScored.find((r) => r.text === prePos0.text)?.embedding;\n   916→\n   917→    // Method 1: embedding similarity (works for related languages)\n   918→    if (pos0Embedding && nearbyAllCaps.length > 0) {\n   919→      translationCandidates = nearbyAllCaps.filter((cap) => {\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"7be50479-d25c-4053-a6c4-4687141d6376","uuid":"b1d526fb-f0a9-449f-b7c9-7b4738da1fd7","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/title-extractor.ts","content":"// Module-level cache for reference embeddings\nlet cachedTitleRefEmbedding: Array<number> | null = null;\nlet cachedHeaderRefEmbedding: Array<number> | null = null;\nlet cachedNoiseRefEmbedding: Array<number> | null = null;\n\nexport function _resetEmbeddingCacheForTests(): void {\n  cachedTitleRefEmbedding = null;\n  cachedHeaderRefEmbedding = null;\n  cachedNoiseRefEmbedding = null;\n}\n\nexport async function extractTitleWithEmbeddings(\n  text: string,\n  embed: EmbedFn\n): Promise<string | undefined> {\n  if (!text || text.trim().length === 0) {\n    return undefined;\n  }\n\n  const lines = text.split(\"\\n\");\n  const candidates = buildCandidates(lines);\n\n  if (candidates.length === 0) {\n    return undefined;\n  }\n\n  // Cache reference embeddings\n  if (!cachedTitleRefEmbedding) {\n    cachedTitleRefEmbedding = await embed(TITLE_REFERENCE);\n  }\n  if (!cachedHeaderRefEmbedding) {\n    cachedHeaderRefEmbedding = await embed(HEADER_REFERENCE);\n  }\n  if (!cachedNoiseRefEmbedding) {\n    cachedNoiseRefEmbedding = await embed(NOISE_REFERENCE);\n  }\n\n  // Find ALL_CAPS candidates with ≥2 words where every significant word has ≥4 alpha letters.\n  // Insignificant tokens (≤1 alpha letter: \"/\", \"&\", \"+\", \":\", \"D)\", etc.) are filtered before\n  // the check so that multi-line joins with continuation punctuation still qualify.\n  const isStructuralHeading = (c: { text: string }): boolean => {\n    if (!isAllCaps(c.text) || wordCount(c.text) < 2) return false;\n    const sigWords = c.text.trim().split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length > 1);\n    return sigWords.length >= 2 && sigWords.every((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n  };\n\n  // Pass 1: compute rawScore for all candidates (embedding quality signal)\n  const rawScored: Array<{ text: string; position: number; origin: CandidateOrigin; rawScore: number; embedding: Array<number> }> = [];\n  for (const candidate of candidates) {\n    const embedding = await embed(candidate.text);\n    const titleSim = cosineSimilarity(embedding, cachedTitleRefEmbedding);\n    const headerSim = cosineSimilarity(embedding, cachedHeaderRefEmbedding);\n    const noiseSim = cosineSimilarity(embedding, cachedNoiseRefEmbedding);\n    const rawScore = titleSim - Math.max(headerSim, noiseSim);\n    rawScored.push({ text: candidate.text, position: candidate.position, origin: candidate.origin, rawScore, embedding });\n  }\n\n  // Select baseHeading by embedding quality (rawScore), not position.\n  // This prevents OCR-garbled fragments from claiming the structural heading slot.\n  const structuralCandidates = rawScored.filter((s) => isStructuralHeading(s));\n\n  // Penalize structural headings with truncated OCR words:\n  // if \"FRON\" appears and another heading has \"SAFFRON\", \"FRON\" is likely garbled.\n  for (const sc of structuralCandidates) {\n    const sigWords = sc.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n    for (const other of structuralCandidates) {\n      if (other === sc) continue;\n      const otherSigWords = other.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n      const hasTruncation = sigWords.some((w) =>\n        otherSigWords.some((ow) => ow !== w && ow.length > w.length && ow.endsWith(w))\n      );\n      if (hasTruncation) {\n        sc.rawScore = -1.0;  // Hard disqualification — truncated OCR artifact\n        break;\n      }\n    }\n  }\n\n  const bestStructural = structuralCandidates.length > 0\n    ? structuralCandidates.reduce((a, b) => {\n        const scoreDiff = a.rawScore - b.rawScore;\n        if (Math.abs(scoreDiff) > 0.03) return scoreDiff > 0 ? a : b;\n        // Tiebreak: single-line origin beats multi-line joins (avoids conflating two separate headings)\n        if (a.origin === \"single\" && b.origin !== \"single\") return a;\n        if (b.origin === \"single\" && a.origin !== \"single\") return b;\n        // Tiebreak: more words (more specific) → better\n        const wcDiff = wordCount(b.text) - wordCount(a.text);\n        if (wcDiff !== 0) return wcDiff > 0 ? b : a;\n        // Tiebreak: earlier position → better\n        return a.position < b.position ? a : b;\n      })\n    : null;\n  const baseHeading = bestStructural ?? undefined;\n\n  // When the best structural heading has a continuation on the next line introduced by a\n  // punctuation token (/, &, +, :, or parenthesis), prefer the longer 2-line join as the\n  // complete heading. E.g. \"SAFFRON WHEAT BUNS WITH QUARK\" + \"/ COTTAGE CHEESE (VARIATION D)\".\n  // Guard: the remainder after the prefix must start with a continuation character to avoid\n  // merging two separate consecutive recipe titles (FINNISH MILK FLATBREADS stays separate\n  // from FINNISH POTATO FLATBREADS because \"FINNISH\" does not start with a continuation token).\n  let firstStructuralHeading = baseHeading && (\n    rawScored.find((c) => {\n      if (!isStructuralHeading(c)) return false;\n      const hLower = baseHeading.text.toLowerCase();\n      const cLower = c.text.toLowerCase();\n      return cLower.startsWith(hLower + \" \") && /^[/&+:(]/.test(cLower.slice(hLower.length + 1));\n    }) ?? baseHeading\n  );\n\n  // Pass 2: apply bonuses\n  const scored: Array<{ text: string; position: number; origin: CandidateOrigin; score: number; rawScore: number; baseScore: number; thresholdScore: number }> = rawScored.map((rs) => {\n    // Position factor: multiplicative tiebreaker — amplifies existing signal, doesn't replace it\n    const relativePosition = rs.position / lines.length;\n    const positionFactor = relativePosition < 0.5\n      ? 1.0 + 0.12 * (1 - relativePosition * 2)\n      : 1.0;\n\n    // ALL_CAPS bonus: recipe books use ALL_CAPS for titles and section headings.\n    // Single-word ALL_CAPS terms are overwhelmingly section/category labels, not recipe titles;\n    // real recipe titles in ALL_CAPS are almost always multi-word. Reduce the bonus for single words.\n    const allCapsBonus = isAllCaps(rs.text) && rs.text.replace(/[^a-zA-Z]/g, \"\").length >= 4\n      ? (wordCount(rs.text) >= 2 ? 0.08 : 0.03)\n      : 0;\n\n    // Structural heading bonus: best ALL_CAPS heading (or its continuation join) is almost always the recipe title\n    const structuralBonus = firstStructuralHeading && rs.text === firstStructuralHeading.text ? 0.10 : 0;\n\n    // thresholdScore excludes structural bonus so the bonus doesn't inflate the threshold\n    // and prevent equally-valid structural headings from passing on multi-recipe pages.\n    const thresholdScore = rs.rawScore + allCapsBonus;\n    // baseScore excludes position factor — used for diagnostics and ranking\n    const baseScore = rs.rawScore + allCapsBonus + structuralBonus;\n    const score = rs.rawScore * positionFactor + allCapsBonus + structuralBonus;\n    return { text: rs.text, position: rs.position, origin: rs.origin, score, rawScore: rs.rawScore, baseScore, thresholdScore };\n  });\n\n  if (scored.length === 0) {\n    return undefined;\n  }\n\n  // --- Pre-threshold bilingual title detection ---\n  // When a mixed-case candidate at position 0 is followed by an ALL_CAPS candidate\n  // at position ≤ 2 that is semantically similar to it, this is a bilingual recipe\n  // page (e.g., Polish title + ALL_CAPS Korean romanization). Suppress confirmed\n  // translation candidates before computing threshold so their bonuses don't inflate\n  // the threshold beyond the mixed-case title's reach.\n  // Note: we check position ≤ 2 (local proximity), not global ALL_CAPS count, so\n  // section headers later in the document (SKŁADNIKI, WARZYWA, etc.) are irrelevant.\n  let translationCandidates: typeof scored = [];\n  let scoredForThreshold = scored;\n  const prePos0 = scored.find((s) => s.position === 0 && !isAllCaps(s.text));\n  if (prePos0) {\n    const nearbyAllCaps = scored.filter(\n      (s) => isAllCaps(s.text) && s.position >= 1 && s.position <= 2 && s.origin === \"single\"\n    );\n    const pos0Embedding = rawScored.find((r) => r.text === prePos0.text)?.embedding;\n\n    // Method 1: embedding similarity (works for related languages)\n    if (pos0Embedding && nearbyAllCaps.length > 0) {\n      translationCandidates = nearbyAllCaps.filter((cap) => {","numLines":160,"startLine":760,"totalLines":1270}}}
