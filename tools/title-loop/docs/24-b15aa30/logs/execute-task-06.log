{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01R4wgPfqnnEfBc9yciyqv5A","type":"tool_result","content":"<persisted-output>\nOutput too large (72.8KB). Full output saved to: /Users/eryk.napierala/.claude/projects/-Users-eryk-napierala-Projects-fasola/7d4a7cfe-a284-48ae-a32b-0160fa2411e9/tool-results/toolu_01R4wgPfqnnEfBc9yciyqv5A.txt\n\nPreview (first 2KB):\n     1→     1→/**\n     2→     2→ * Title Extraction\n     3→     3→ * Extracts potential recipe title from OCR text using heuristics or semantic embeddings\n     4→     4→ */\n     5→     5→\n     6→     6→import { cosineSimilarity } from \"./embeddings\";\n     7→     7→import { FOOD_DICTIONARY } from \"./food-dictionary\";\n     8→     8→\n     9→     9→export type EmbedFn = (text: string) => Promise<Array<number>>;\n    10→    10→\n    11→    11→const TITLE_REFERENCE =\n    12→    12→  \"recipe name, dish title, name of the food, nazwa przepisu, nazwa dania\";\n    13→    13→const HEADER_REFERENCE =\n    14→    14→  \"ingredients list, cooking directions, section heading, składniki, przygotowanie, sposób wykonania\";\n    15→    15→const NOISE_REFERENCE =\n    16→    16→  \"page number, table of contents, book footer, garbled text\";\n    17→    17→\n    18→    18→/**\n    19→    19→ * Measurement units commonly found in ingredient lists\n    20→    20→ */\n    21→    21→const MEASUREMENT_PATTERNS = [\n    22→    22→  // English\n    23→    23→  \"cup\",\n    24→    24→  \"cups\",\n    25→    25→  \"tbsp\",\n    26→    26→  \"tsp\",\n    27→    27→  \"tablespoon\",\n    28→    28→  \"teaspoon\",\n    29→    29→  // \"oz\" and \"lb\" are matched with word boundaries in looksLikeIngredient\n    30→    30→  // to avoid false positives (\"oz\" in \"mozzarella\", \"lb\" in \"albacore\")\n    31→    31→  \"gram\",\n    32→    32→  \"grams\",\n    33→    33→  \"kg\",\n    34→    34→  \"ml\",\n    35→    35→  \"liter\",\n    36→    36→  \"pinch\",\n    37→    37→  \"dash\",\n    38→    38→  \"handful\",\n    39→    39→  // Polish\n    40→    40→  \"łyżka\", \"łyżki\", \"łyżek\",           // tablespoon(s)\n    41→    41→  \"łyżeczka\", \"łyżeczki\", \"łyżeczek\",   // teaspoon(s)\n    42→    42→  \"szklanka\", \"szklanki\", \"szklanek\",    // cup(s)\n    43→    43→  \"szczypta\",                            // pinch\n    44→    44→  \"garść\",                               // handful\n    45→    45→  \"opakowanie\", \"opakowania\",            // package(s)\n...\n</persisted-output>"}]},"parent_tool_use_id":null,"session_id":"7d4a7cfe-a284-48ae-a32b-0160fa2411e9","uuid":"f12eb3a3-24f4-470d-8e9c-794da3a7ec74","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/.claude/projects/-Users-eryk-napierala-Projects-fasola/7d4a7cfe-a284-48ae-a32b-0160fa2411e9/tool-results/toolu_01QftLuhxU5yK1qNFLXPKy6K.txt","content":"     1→/**\n     2→ * Title Extraction\n     3→ * Extracts potential recipe title from OCR text using heuristics or semantic embeddings\n     4→ */\n     5→\n     6→import { cosineSimilarity } from \"./embeddings\";\n     7→import { FOOD_DICTIONARY } from \"./food-dictionary\";\n     8→\n     9→export type EmbedFn = (text: string) => Promise<Array<number>>;\n    10→\n    11→const TITLE_REFERENCE =\n    12→  \"recipe name, dish title, name of the food, nazwa przepisu, nazwa dania\";\n    13→const HEADER_REFERENCE =\n    14→  \"ingredients list, cooking directions, section heading, składniki, przygotowanie, sposób wykonania\";\n    15→const NOISE_REFERENCE =\n    16→  \"page number, table of contents, book footer, garbled text\";\n    17→\n    18→/**\n    19→ * Measurement units commonly found in ingredient lists\n    20→ */\n    21→const MEASUREMENT_PATTERNS = [\n    22→  // English\n    23→  \"cup\",\n    24→  \"cups\",\n    25→  \"tbsp\",\n    26→  \"tsp\",\n    27→  \"tablespoon\",\n    28→  \"teaspoon\",\n    29→  // \"oz\" and \"lb\" are matched with word boundaries in looksLikeIngredient\n    30→  // to avoid false positives (\"oz\" in \"mozzarella\", \"lb\" in \"albacore\")\n    31→  \"gram\",\n    32→  \"grams\",\n    33→  \"kg\",\n    34→  \"ml\",\n    35→  \"liter\",\n    36→  \"pinch\",\n    37→  \"dash\",\n    38→  \"handful\",\n    39→  // Polish\n    40→  \"łyżka\", \"łyżki\", \"łyżek\",           // tablespoon(s)\n    41→  \"łyżeczka\", \"łyżeczki\", \"łyżeczek\",   // teaspoon(s)\n    42→  \"szklanka\", \"szklanki\", \"szklanek\",    // cup(s)\n    43→  \"szczypta\",                            // pinch\n    44→  \"garść\",                               // handful\n    45→  \"opakowanie\", \"opakowania\",            // package(s)\n    46→  \"plasterek\", \"plasterki\",             // slice(s)\n    47→];\n    48→\n    49→/**\n    50→ * Patterns that identify recipe metadata lines (not titles)\n    51→ */\n    52→const METADATA_PATTERNS = [\n    53→  /^(SERVES?|MAKES?|YIELDS?)\\b/i,\n    54→  /^(PREP(ARATION)?|COOK(ING)?|PROOF|RISING|FERMENTATION|REST(ING)?)\\s*(AND\\s*)?(COOK(ING)?)?\\s*TIME/i,\n    55→  /^SAMPLE\\s+SCHEDULE\\b/i,\n    56→  /^BULK\\s+FERMENTATION\\b/i,\n    57→  /^(THIS\\s+RECIPE\\s+)?MAKES\\b/i,\n    58→  // Polish serving-size patterns: \"NA 3 PAPRYKI\", \"NA OKOŁO 1 KG\", \"DLA 4 OSÓB\"\n    59→  /^NA\\s+(\\d|OKOŁO)\\b/i,\n    60→  /^DLA\\s+\\d/i,\n    61→  // OCR-resilient: \"DLA\" + any token + serving-unit word (handles DLA & OSOB, DLA § OSOB, etc.)\n    62→  /^DLA\\s+\\S+\\s+OSOB/i,\n    63→  // OCR-resilient: \"DLA\" + single non-alphanumeric char (common digit→symbol OCR error)\n    64→  /^DLA\\s+[^a-zA-Z0-9\\s]\\s/i,\n    65→  // Time-unit metadata: any line containing \"N MIN\" or \"N GODZ\" is prep/cook/rest time,\n    66→  // regardless of OCR-corrupted prefix (catches PRZYGOTOWANTE, GOTOMANTE, etc.)\n    67→  /\\b\\d+\\s*MIN\\b/i,\n    68→  /\\b\\d+\\s*GODZ/i,\n    69→  // Season/category indicators\n    70→  /^SEZON\\s*:/i,\n    71→  /^KATEGORIA\\s*:/i,\n    72→  /^RODZAJ\\s*:/i,\n    73→  /^PORCJI\\s*:/i,       // Polish serving count\n    74→  /^PORTIONS?\\s*:/i,    // English serving count\n    75→  /^CZ[ĘE]Ś[ĆC]\\s*\\d/i,   // CZĘŚĆ 1: ... (Polish \"Part 1:\")\n    76→  /^PART\\s+\\d/i,             // PART 1: ... (English)\n    77→];\n    78→\n    79→/**\n    80→ * Single-word non-title words — standalone OCR fragments unlikely to be recipe titles\n    81→ */\n    82→const NON_TITLE_WORDS = new Set([\n    83→  \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"are\", \"was\",\n    84→  \"has\", \"his\", \"her\", \"its\", \"our\", \"who\", \"how\", \"may\", \"new\", \"now\",\n    85→  \"old\", \"see\", \"way\", \"did\", \"get\", \"let\", \"say\", \"she\", \"too\", \"use\",\n    86→  \"buns\", \"with\",\n    87→]);\n    88→\n    89→function looksLikeIngredient(line: string): boolean {\n    90→  const lowerLine = line.toLowerCase();\n    91→  if (MEASUREMENT_PATTERNS.some((pattern) => lowerLine.includes(pattern))) return true;\n    92→  // Compact metric: \"100g\", \"50ml\", \"250g\" — digit immediately followed by g/ml/kg\n    93→  if (/\\b\\d+\\s*(?:g|ml|kg)\\b/i.test(line)) return true;\n    94→  // \"to taste\" / \"do smaku\" — qualitative ingredient with no unit\n    95→  if (/\\bto taste\\b/i.test(line) || /\\bdo smaku\\b/i.test(line)) return true;\n    96→  return false;\n    97→}\n    98→\n    99→function startsWithNumber(line: string): boolean {\n   100→  // Match lines starting with a digit, or bullet-then-digit (e.g., \"- 2 jajka\")\n   101→  return /^\\s*(?:[-•*]\\s*)?\\d/.test(line);\n   102→}\n   103→\n   104→function stripDiacritics(text: string): string {\n   105→  return text.normalize(\"NFKD\").replace(/[\\u0300-\\u036f]/g, \"\");\n   106→}\n   107→\n   108→/**\n   109→ * Known recipe section labels — these are structural headers, not recipe titles.\n   110→ * Matched case-insensitively after trimming, stripping trailing punctuation, and stripping diacritics.\n   111→ * Polish entries are stored without diacritics for OCR resilience (e.g. \"SKLADNIKI\" matches \"składniki\").\n   112→ */\n   113→const SECTION_LABELS = new Set([\n   114→  // English\n   115→  \"ingredients\", \"directions\", \"instructions\", \"method\", \"preparation\",\n   116→  \"steps\", \"notes\", \"tip\", \"tips\", \"variations\", \"variation\",\n   117→  \"garnish\", \"topping\", \"toppings\", \"frosting\", \"filling\",\n   118→  \"serving suggestion\", \"serving suggestions\", \"serving\",\n   119→  \"glaze\", \"for the sauce\", \"for the filling\", \"for the dough\",\n   120→  \"for the topping\", \"for the glaze\", \"for the pasta dough\",\n   121→  \"for the pasta\", \"for the crust\",\n   122→  // Polish — recipe section labels (stored without diacritics for OCR resilience)\n   123→  \"skladniki\", \"przygotowanie\", \"sposob przygotowania\", \"sposob wykonania\",\n   124→  \"wykonanie\", \"wskazowki\", \"podpowiedz\", \"warianty\",\n   125→  \"sos\", \"nadzienie\", \"polewa\", \"lukier\", \"ciasto\",  // ciasto = dough/pastry base (recipe-internal section AND chapter label)\n   126→  \"instrukcje\",       // instructions\n   127→  \"uwagi\",            // notes/remarks\n   128→  \"notatki\",          // notes\n   129→  \"podawanie\",        // serving\n   130→  \"przechowywanie\",   // storage\n   131→  // Polish — recipe-book chapter/category labels (food groups, meal types)\n   132→  \"warzywa\",          // vegetables\n   133→  \"mieso\",            // meat (mięso)\n   134→  \"miesa\",            // meats (mięsa)\n   135→  \"ryby\",             // fish\n   136→  \"owoce morza\",      // seafood\n   137→  \"zupy\",             // soups\n   138→  \"salatki\",          // salads (sałatki)\n   139→  \"desery\",           // desserts\n   140→  \"napoje\",           // drinks\n   141→  \"pieczywo\",         // bread/baked goods\n   142→  \"przekaski\",        // appetizers/snacks\n   143→  \"sniadania\",        // breakfasts (śniadania)\n   144→  \"obiady\",           // dinners/lunches\n   145→  \"kolacje\",          // suppers\n   146→  \"makarony\",         // pasta dishes\n   147→  \"kasza\",            // groats/grains\n   148→  \"kasze\",            // groats/grains (plural)\n   149→  \"dania glowne\",     // main courses (dania główne)\n   150→  \"przystawki\",       // starters\n   151→  \"dodatki\",          // side dishes\n   152→  \"przetwory\",        // preserves\n   153→  \"wypieki\",          // baked goods\n   154→  \"ciasta\",           // cakes (plural)\n   155→  \"ciastka\",          // cookies\n   156→  \"torty\",            // layer cakes\n   157→  // \"placki\" removed — it commonly starts recipe titles like \"Placki Ziemniaczane\", \"Placki Żółte z Kukurydzą\"\n   158→  \"koktajle\",         // cocktails/smoothies\n   159→  // English — recipe-book chapter/category labels\n   160→  \"vegetables\", \"seafood\", \"fish\", \"soups\", \"salads\", \"desserts\",\n   161→  \"appetizers\", \"breads\", \"breakfast\", \"pasta\", \"grains\",\n   162→  \"main courses\", \"side dishes\", \"preserves\", \"baked goods\",\n   163→  \"fish & seafood\", \"soups & broths\", \"desserts & baked goods\",\n   164→  \"meats\", \"poultry\", \"game\",\n   165→]);\n   166→\n   167→function isSectionLabel(text: string): boolean {\n   168→  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n   169→  if (SECTION_LABELS.has(normalized)) return true;\n   170→  // OCR variant: leading \"l\" may be OCR-corrupted \"I\" (e.g. \"lngredients\" → \"ingredients\")\n   171→  const ocrNormalized = normalized.replace(/^l/, \"i\");\n   172→  if (ocrNormalized !== normalized && SECTION_LABELS.has(ocrNormalized)) return true;\n   173→  return false;\n   174→}\n   175→\n   176→/**\n   177→ * Recipe-internal section labels that should ALWAYS block multi-line joins,\n   178→ * even when the combined word count is ≥ 3.\n   179→ * Category labels (\"zupy\", \"placki\", etc.) are NOT in this set — they can\n   180→ * legitimately start a multi-word recipe title like \"Zupy Zimowe Warzywne\".\n   181→ */\n   182→const ALWAYS_BLOCK_JOIN_LABELS = new Set([\n   183→  \"ingredients\", \"directions\", \"instructions\", \"method\", \"preparation\",\n   184→  \"steps\", \"notes\", \"tip\", \"tips\", \"variations\", \"variation\",\n   185→  \"garnish\", \"topping\", \"toppings\", \"frosting\", \"filling\",\n   186→  \"serving suggestion\", \"serving suggestions\", \"serving\",\n   187→  \"glaze\", \"instrukcje\", \"uwagi\", \"notatki\", \"podawanie\", \"przechowywanie\",\n   188→  \"skladniki\", \"przygotowanie\", \"sposob przygotowania\", \"sposob wykonania\",\n   189→  \"wykonanie\", \"wskazowki\", \"podpowiedz\", \"warianty\",\n   190→  \"sos\", \"nadzienie\", \"polewa\", \"lukier\", \"ciasto\",\n   191→]);\n   192→\n   193→function isAlwaysBlockJoinLabel(text: string): boolean {\n   194→  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n   195→  return ALWAYS_BLOCK_JOIN_LABELS.has(normalized);\n   196→}\n   197→\n   198→function isAllCaps(line: string): boolean {\n   199→  const letters = line.replace(/[^a-zA-Z]/g, \"\");\n   200→  return letters.length > 0 && letters === letters.toUpperCase();\n   201→}\n   202→\n   203→function looksLikeMetadata(text: string): boolean {\n   204→  return METADATA_PATTERNS.some((pattern) => pattern.test(text.trim()));\n   205→}\n   206→\n   207→function isLikelyGarbled(text: string): boolean {\n   208→  const letters = text.replace(/[^a-zA-Z]/g, \"\");\n   209→  if (letters.length < 2) return true;\n   210→\n   211→  // Pipe embedded in words = OCR artifact (e.g., \"Sp|aszcz\", \"pa|ką\")\n   212→  if (/[a-zA-ZÀ-ÿа-яА-Я]\\|[a-zA-ZÀ-ÿа-яА-Я]/.test(text)) return true;\n   213→\n   214→  // Mixed Latin + Cyrillic = OCR corruption\n   215→  if (/[а-яА-ЯёЁіІїЇєЄґҐ]/.test(text) && /[a-zA-Z]/.test(text)) return true;\n   216→\n   217→  // Check vowel ratio — English/Polish text typically has 30–50% vowels\n   218→  const vowels = letters.replace(/[^aeiouAEIOUyYąęóĄĘÓ]/g, \"\").length;\n   219→  const vowelRatio = vowels / letters.length;\n   220→  if (vowelRatio < 0.10 || vowelRatio > 0.85) return true;\n   221→\n   222→  // Single orphaned word ≤3 letters that isn't a common word\n   223→  const words = text.trim().split(/\\s+/);\n   224→  const COMMON_SHORT = new Set([\n   225→    \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"had\", \"her\",\n   226→    \"was\", \"one\", \"our\", \"out\", \"are\", \"has\", \"his\", \"how\", \"its\", \"may\",\n   227→    \"new\", \"now\", \"old\", \"see\", \"way\", \"who\", \"did\", \"get\", \"let\", \"say\",\n   228→    \"she\", \"too\", \"use\",\n   229→  ]);\n   230→  // Count all Unicode letters (not just ASCII) so Polish words like \"Żur\" (3 letters) pass\n   231→  const unicodeLetters = text.trim().replace(/[^a-zA-ZąćęłńóśźżĄĆĘŁŃÓŚŹŻ]/g, \"\");\n   232→  if (words.length === 1 && unicodeLetters.length <= 3 && !COMMON_SHORT.has(text.trim().toLowerCase())) {\n   233→    return true;\n   234→  }\n   235→\n   236→  // Single word with internal lowercase→uppercase transition — OCR noise (e.g., \"UuIw\", \"aBC\")\n   237→  // No recipe title uses this pattern as a standalone single-word candidate.\n   238→  if (words.length === 1 && /[a-z][A-Z]/.test(text.trim())) {\n   239→    return true;\n   240→  }\n   241→\n   242→  // Recipe titles never start with a lowercase letter\n   243→  if (/^[a-z]/.test(text.trim())) {\n   244→    return true;\n   245→  }\n   246→\n   247→  // Mid-text sentence boundary (\". \" followed by a letter) — body text fragment spliced from multiple sentences\n   248→  const trimmed = text.trim();\n   249→  if (/\\.\\s+[a-zA-Z]/.test(trimmed) && !trimmed.endsWith(\")\")) {\n   250→    return true;\n   251→  }\n   252→\n   253→  // Multi-word candidate containing a garbled OCR fragment: a short lowercase word that isn't a known short word\n   254→  if (words.length >= 2) {\n   255→    const commonShort2 = new Set([\n   256→      \"a\", \"i\", \"of\", \"or\", \"to\", \"in\", \"on\", \"is\", \"it\", \"an\",\n   257→      \"as\", \"at\", \"by\", \"do\", \"go\", \"if\", \"no\", \"so\", \"up\", \"we\",\n   258→      \"w\", \"z\",   // Polish prepositions (basic)\n   259→      \"ze\", \"bo\", \"na\", \"ni\", \"po\", \"ku\", \"od\", \"za\", \"co\",  // Polish prepositions (extended)\n   260→    ]);\n   261→    const hasGarbledWord = words.some(\n   262→      (w) =>\n   263→        /^[a-z]/.test(w) &&\n   264→        w.replace(/[^a-z]/g, \"\").length <= 2 &&\n   265→        !commonShort2.has(w.toLowerCase())\n   266→    );\n   267→    if (hasGarbledWord) {\n   268→      return true;\n   269→    }\n   270→  }\n   271→\n   272→  return false;\n   273→}\n   274→\n   275→const COOKING_INSTRUCTION_STARTS = /^(beat|fold|stir|mix|add|pour|bake|cook|cool|remove|place|combine|whisk|knead|roll|spread|brush|slice|chop|dice|mince|drain|rinse|peel|grate|melt|simmer|boil|fry|sauté|saute|roast|grill|broil|steam|let|set|transfer|serve|garnish|arrange|sprinkle|season|preheat|cover|uncover|reduce|bring|toss|cut|trim|shape|form)\\b/i;\n   276→\n   277→// Polish imperative cooking verbs (with OCR-resilient forms — no diacritics required).\n   278→// These cover the most common recipe instruction starters. Includes common OCR-corrupted\n   279→// forms (e.g., \"Smaż\" → \"Smaz\", \"Dodaj\" → \"Dodaj\").\n   280→// Note: only verbs that NEVER start a recipe title. \"Piecz\" (bake) is excluded because\n   281→// \"Pieczeń\" (roast) and \"Pieczarki\" (mushrooms) share the prefix.\n   282→const POLISH_COOKING_INSTRUCTION_STARTS = /^(podawaj|dodaj|dodawaj|sma[zż]|gotuj|odced[zź]|wymieszaj|mieszaj|wlej|nalej|przygotuj|zagotuj|pokr[oó]j|obierz|wrzuc|wrzuć|usma[zż]|podsma[zż]|prze[lł][oó][zż]|zblenduj|ubij|roztrzepaj|rozprowad[zź]|wyrob|zamieszaj|posyp|polej|odstaw|na[lł][oó][zż]|przykryj|odkryj|wstaw|zdejmij|ods[aą]cz|rozgrzej|posiekaj|zetrzyj|wy[lł][oó][zż]|wyjmij|ukr[oó]j|przekr[oó]j|formuj|ugniataj|rozwałkuj)\\b/i;\n   283→\n   284→function looksLikeCookingInstruction(text: string): boolean {\n   285→  const words = text.trim().split(/\\s+/);\n   286→  if (words.length < 4) return false;  // Instructions are multi-word sentences\n   287→  if (COOKING_INSTRUCTION_STARTS.test(text.trim())) return true;\n   288→  if (POLISH_COOKING_INSTRUCTION_STARTS.test(text.trim())) return true;\n   289→  return false;\n   290→}\n   291→\n   292→function passesHardFilters(text: string): boolean {\n   293→  if (text.length < 3 || text.length > 80) return false;\n   294→  if (looksLikeIngredient(text)) return false;\n   295→  if (startsWithNumber(text)) return false;\n   296→  if (looksLikeMetadata(text)) return false;\n   297→  if (isLikelyGarbled(text)) return false;\n   298→  if (looksLikeCookingInstruction(text)) return false;\n   299→  // Pipe-separated lines are book category/chapter headers, not recipe titles\n   300→  if (text.includes(\" | \")) return false;\n   301→  // Trailing page number (e.g. \"VEGETABLE SIDES                         145\")\n   302→  if (/\\s{3,}\\d{1,4}\\s*$/.test(text)) return false;\n   303→  // Slash-separated breadcrumbs (e.g., \"/ Jesien / Zupy\") are navigation, not titles\n   304→  // Only filter when 2+ slashes are present — single-slash lines like\n   305→  // \"TITLE / SUBTITLE\" are legitimate continuation-merged titles\n   306→  if ((text.match(/\\//g) || []).length >= 2) return false;\n   307→  // Bullet-list items (ingredients or instruction steps) are never titles\n   308→  if (/^\\s*[-•*]\\s/.test(text)) return false;\n   309→  // \"For the sauce:\", \"For the filling:\" etc. are sub-section headers\n   310→  if (/^For the\\s+/i.test(text) && /:\\s*$/.test(text)) return false;\n   311→  // Lines ending with \":\" are recipe sub-section headers, not titles.\n   312→  // Exception: compound titles using \" : \" as a title separator (e.g. \"LEMON CURD : LEMON CURD WITH THYME\").\n   313→  if (/:\\s*$/.test(text.trim()) && !/ : /.test(text)) return false;\n   314→  // Page references are navigation markers, not recipe titles\n   315→  if (/^Page\\s+\\d+/i.test(text.trim())) return false;\n   316→  if (/^Strona\\s+\\d+/i.test(text.trim())) return false;\n   317→  // Corrupted spillover annotations from synthetic multi-page OCR\n   318→  if (/^\\[CORRUPTED\\s+SPILLOVER/i.test(text.trim())) return false;\n   319→  // Parenthetical OCR annotation lines describing corruption artifacts\n   320→  if (/^\\(OCR\\b/i.test(text.trim())) return false;\n   321→  if (/^\\(.*\\bcorruption\\b/i.test(text.trim())) return false;\n   322→  // Square-bracket category tags (e.g., \"[CLASSIC FALL SOUPS]\")\n   323→  if (/^\\[.*\\]$/.test(text.trim())) return false;\n   324→  // Known recipe section labels are structural headers, not titles\n   325→  if (isSectionLabel(text)) return false;\n   326→  // Single-word non-title fragments\n   327→  const words = text.trim().split(/\\s+/);\n   328→  if (words.length === 1 && NON_TITLE_WORDS.has(text.trim().toLowerCase())) return false;\n   329→  // Lines with ≥8 words are almost certainly body text, not titles.\n   330→  // Exception: multi-title compounds with \" + \", \" : \", or \" & \" separators are allowed.\n   331→  if (words.length >= 8 && !/ [+:&/] /.test(text)) return false;\n   332→  return true;\n   333→}\n   334→\n   335→/**\n   336→ * Detect initial burst of short garbled lines.\n   337→ * Returns the index of the first non-garbled or long line.\n   338→ */\n   339→function findBurstEnd(lines: Array<{ text: string }>): number {\n   340→  let i = 0;\n   341→\n   342→  // Skip overflow preambles: blocks introduced by \"PREVIOUS RECIPE OVERFLOW\",\n   343→  // \"PREVIOUS PAGE CONTENT\", \"CORRUPTED SECTION\", etc. that precede the actual recipe.\n   344→  const OVERFLOW_MARKERS = /\\b(PREVIOUS\\s+(RECIPE|PAGE)\\s+(OVERFLOW|CONTENT)|SPILLOVER|CONTINUATION|CORRUPTED\\s+SECTION)\\b/i;\n   345→  let overflowEnd = 0;\n   346→  for (let k = 0; k < lines.length && k < 30; k++) {\n   347→    if (OVERFLOW_MARKERS.test(lines[k].text)) {\n   348→      // Skip forward past the overflow block to the next visual separator or blank cluster\n   349→      let m = k + 1;\n   350→      while (m < lines.length) {\n   351→        if (/^[=\\-]{4,}$/.test(lines[m].text) || lines[m].text.length === 0) {\n   352→          overflowEnd = m + 1;\n   353→          break;\n   354→        }\n   355→        m++;\n   356→      }\n   357→      if (overflowEnd === 0) overflowEnd = k + 1;\n   358→    }\n   359→  }\n   360→  if (overflowEnd > 0) i = overflowEnd;\n   361→\n   362→  while (i < lines.length && lines[i].text.length < 20 && isLikelyGarbled(lines[i].text) && !isAllCaps(lines[i].text)) {\n   363→    i++;\n   364→  }\n   365→  // Skip long instruction-like prologues: if 5+ consecutive lines look like cooking instructions,\n   366→  // skip them to find the actual title region.\n   367→  if (i === 0) {\n   368→    let j = 0;\n   369→    while (j < lines.length && looksLikeCookingInstruction(lines[j].text)) {\n   370→      j++;\n   371→    }\n   372→    if (j >= 5) {\n   373→      i = j;\n   374→    }\n   375→  }\n   376→  // Skip prose prologues: mid-recipe body text before the actual title.\n   377→  // If 3+ consecutive lines look like running body text (lowercase start, continuation,\n   378→  // or sentence-ending with many words), skip them.\n   379→  if (i === 0) {\n   380→    let j = 0;\n   381→    while (j < lines.length) {\n   382→      const t = lines[j].text;\n   383→      const isBodyText = (\n   384→        /^[a-ząćęłńóśźż]/.test(t) ||\n   385→        t.endsWith(\",\") ||\n   386→        (t.endsWith(\".\") && wordCount(t) > 4)\n   387→      ) && wordCount(t) >= 4;\n   388→      if (isBodyText) j++;\n   389→      else break;\n   390→    }\n   391→    if (j >= 3) i = j;\n   392→  }\n   393→  return i;\n   394→}\n   395→\n   396→function stripParentheticalGloss(text: string): string {\n   397→  // Strip trailing English-gloss parentheticals from ALL_CAPS titles.\n   398→  // e.g. \"PIEROGI RUSKIE (Boiled Dumplings with Potato and Cheese)\" → \"PIEROGI RUSKIE\"\n   399→  // Keep if parenthetical is ALL_CAPS (variation/subtitle in same language).\n   400→  // Keep if both base and paren are mixed-case (both are part of the title).\n   401→  const match = text.match(/^(.+?)\\s*\\(([^)]+)\\)\\s*$/);\n   402→  if (!match) return text;\n   403→  const [, base, paren] = match;\n   404→  if (isAllCaps(paren)) return text;\n   405→  if (!isAllCaps(base) && !isAllCaps(paren)) return text;\n   406→  return base.trim();\n   407→}\n   408→\n   409→function stripPageNumber(text: string): string {\n   410→  // \"34  Berry Jam\" → \"Berry Jam\" (2+ spaces distinguishes from \"2 eggs\")\n   411→  const match = text.match(/^\\d{1,3}\\s{2,}(.+)$/);\n   412→  return match ? match[1] : text;\n   413→}\n   414→\n   415→function wordCount(text: string): number {\n   416→  return text.split(/\\s+/).filter((w) => w.length > 0).length;\n   417→}\n   418→\n   419→/**\n   420→ * Build candidate strings from lines: single lines plus multi-line joins (2-3 consecutive).\n   421→ * Skips initial burst of short garbled lines. Scans all remaining lines. Caps at 25.\n   422→ */\n   423→export type CandidateOrigin = \"single\" | \"2-line\" | \"3-line\";\n   424→\n   425→function buildCandidates(\n   426→  lines: Array<string>\n   427→): Array<{ text: string; position: number; origin: CandidateOrigin }> {\n   428→  const nonEmptyLines: Array<{ text: string; index: number }> = [];\n   429→\n   430→  for (let i = 0; i < lines.length; i++) {\n   431→    const trimmed = lines[i].trim();\n   432→    if (trimmed.length > 0) {\n   433→      nonEmptyLines.push({ text: trimmed, index: i });\n   434→    }\n   435→  }\n   436→\n   437→  const burstEnd = findBurstEnd(nonEmptyLines);\n   438→\n   439→  // Pre-join hyphen-broken lines: \"ROASTED CHICKEN WITH ROOT VEGET-\" + \"ABLES\" → single line.\n   440→  // Only applies within the candidate region (after burst end).\n   441→  for (let hi = burstEnd; hi < nonEmptyLines.length - 1; hi++) {\n   442→    if (nonEmptyLines[hi].text.endsWith(\"-\")) {\n   443→      const joined = nonEmptyLines[hi].text.slice(0, -1) + nonEmptyLines[hi + 1].text;\n   444→      nonEmptyLines[hi] = { text: joined, index: nonEmptyLines[hi].index };\n   445→      nonEmptyLines.splice(hi + 1, 1);\n   446→    }\n   447→  }\n   448→\n   449→  // Pre-merge consecutive short ALL_CAPS lines (OCR-fragmented headings).\n   450→  // When a sequence of 2+ ALL_CAPS lines each has ≤2 words and ≤25 chars, they are\n   451→  // almost certainly OCR fragments of a single heading. Merge them into one line so\n   452→  // the complete title enters the candidate pool without hitting the 3-line join ceiling.\n   453→  const capsCoalesced: Array<{ text: string; index: number }> = [];\n   454→  let ci = burstEnd;\n   455→  while (ci < nonEmptyLines.length) {\n   456→    const line = nonEmptyLines[ci];\n   457→    if (\n   458→      isAllCaps(line.text) &&\n   459→      wordCount(line.text) <= 2 &&\n   460→      line.text.length <= 25 &&\n   461→      !isSectionLabel(line.text) &&\n   462→      !looksLikeMetadata(line.text)\n   463→    ) {\n   464→      let merged = line.text;\n   465→      const startIndex = line.index;\n   466→      let j = ci + 1;\n   467→      while (j < nonEmptyLines.length) {\n   468→        const next = nonEmptyLines[j];\n   469→        if (\n   470→          isAllCaps(next.text) &&\n   471→          wordCount(next.text) <= 2 &&\n   472→          next.text.length <= 25 &&\n   473→          !isSectionLabel(next.text) &&\n   474→          !looksLikeMetadata(next.text) &&\n   475→          (merged + \" \" + next.text).length <= 80\n   476→        ) {\n   477→          merged += \" \" + next.text;\n   478→          j++;\n   479→        } else {\n   480→          break;\n   481→        }\n   482→      }\n   483→      if (j > ci + 1) {\n   484→        capsCoalesced.push({ text: merged, index: startIndex });\n   485→        ci = j;\n   486→        continue;\n   487→      }\n   488→    }\n   489→    capsCoalesced.push(line);\n   490→    ci++;\n   491→  }\n   492→\n   493→  // Pre-merge continuation lines: a line starting with /&+:( is never a standalone title.\n   494→  // Merge it into the preceding line so the complete title enters the pool as a single candidate,\n   495→  // avoiding the fragile chain of conditions required by the downstream join survival logic.\n   496→  // Limitation: only one continuation line per preceding line is merged. Titles split across\n   497→  // three or more lines with continuation tokens (rare in practice) are not handled here —\n   498→  // the downstream 2-line and 3-line join candidates cover those cases instead.\n   499→  const mergedLines: Array<{ text: string; index: number }> = [];\n   500→  for (let i = 0; i < capsCoalesced.length; i++) {\n   501→    const line = capsCoalesced[i];\n   502→    if (i + 1 < capsCoalesced.length) {\n   503→      const nextText = capsCoalesced[i + 1].text;\n   504→      if (/^[/&+:(]/.test(nextText)) {\n   505→        mergedLines.push({ text: `${line.text} ${nextText}`, index: line.index });\n   506→        i++;\n   507→        continue;\n   508→      }\n   509→    }\n   510→    mergedLines.push(line);\n   511→  }\n   512→\n   513→  const candidates: Array<{ text: string; position: number; origin: CandidateOrigin }> = [];\n   514→  const seen = new Set<string>();\n   515→\n   516→  // Build a set of positions to skip: short ALL_CAPS lines immediately following metadata\n   517→  const metadataContinuationPositions = new Set<number>();\n   518→  for (let i = 0; i < mergedLines.length - 1; i++) {\n   519→    if (looksLikeMetadata(mergedLines[i].text)) {\n   520→      const next = mergedLines[i + 1];\n   521→      if (isAllCaps(next.text) && wordCount(next.text) <= 2 && next.text.length <= 15) {\n   522→        metadataContinuationPositions.add(next.index);\n   523→      }\n   524→    }\n   525→  }\n   526→\n   527→  for (let i = 0; i < mergedLines.length; i++) {\n   528→    const line = mergedLines[i];\n   529→\n   530→    // Skip metadata continuation fragments\n   531→    if (metadataContinuationPositions.has(line.index)) continue;\n   532→\n   533→    // Single line — strip page-number prefixes and parenthetical glosses before scoring\n   534→    const singleText = repairOcrText(stripParentheticalGloss(stripPageNumber(line.text)));\n   535→    if (passesHardFilters(singleText)) {\n   536→      const norm = singleText.toLowerCase();\n   537→      if (!seen.has(norm)) {\n   538→        seen.add(norm);\n   539→        candidates.push({ text: singleText, position: line.index, origin: \"single\" });\n   540→      }\n   541→    }\n   542→\n   543→    // 2-line join — skip if first line is a section label AND join would be ≤2 words\n   544→    // (a section label followed by modifiers is likely a recipe title, not a category header)\n   545→    if (i + 1 < mergedLines.length) {\n   546→      const joined2 = repairOcrText(`${line.text} ${mergedLines[i + 1].text}`);\n   547→      const shouldBlock2 = isSectionLabel(line.text) &&\n   548→        (wordCount(joined2) <= 2 || isAlwaysBlockJoinLabel(line.text));\n   549→      if (!shouldBlock2 && passesHardFilters(joined2)) {\n   550→        const norm = joined2.toLowerCase();\n   551→        if (!seen.has(norm)) {\n   552→          seen.add(norm);\n   553→          candidates.push({ text: joined2, position: line.index, origin: \"2-line\" });\n   554→        }\n   555→      }\n   556→    }\n   557→\n   558→    // 3-line join — skip if first line is a section label AND join would be ≤2 words\n   559→    if (i + 2 < mergedLines.length) {\n   560→      const joined3 = repairOcrText(`${line.text} ${mergedLines[i + 1].text} ${mergedLines[i + 2].text}`);\n   561→      const shouldBlock3 = isSectionLabel(line.text) &&\n   562→        (wordCount(joined3) <= 2 || isAlwaysBlockJoinLabel(line.text));\n   563→      if (!shouldBlock3 && passesHardFilters(joined3)) {\n   564→        const norm = joined3.toLowerCase();\n   565→        if (!seen.has(norm)) {\n   566→          seen.add(norm);\n   567→          candidates.push({ text: joined3, position: line.index, origin: \"3-line\" });\n   568→        }\n   569→      }\n   570→    }\n   571→  }\n   572→\n   573→  // Pre-filter to 25 before embedding calls: prefer ALL_CAPS and short candidates.\n   574→  // Position-based scoring handles final ranking.\n   575→  if (candidates.length > 25) {\n   576→    const prioritized = candidates.slice().sort((a, b) => {\n   577→      const aAllCaps = isAllCaps(a.text) ? 0 : 1;\n   578→      const bAllCaps = isAllCaps(b.text) ? 0 : 1;\n   579→      if (aAllCaps !== bAllCaps) return aAllCaps - bAllCaps;\n   580→      const aShort = wordCount(a.text) <= 5 ? 0 : 1;\n   581→      const bShort = wordCount(b.text) <= 5 ? 0 : 1;\n   582→      return aShort - bShort;\n   583→    });\n   584→    return prioritized.slice(0, 25);\n   585→  }\n   586→\n   587→  return candidates;\n   588→}\n   589→\n   590→/**\n   591→ * Convert an ALL_CAPS string to Title Case, using a small-words list.\n   592→ * Preserves Polish/French diacritics.\n   593→ */\n   594→function toTitleCase(text: string): string {\n   595→  const smallWords = new Set([\n   596→    \"a\", \"an\", \"the\", \"and\", \"but\", \"or\", \"for\", \"nor\",\n   597→    \"in\", \"on\", \"at\", \"to\", \"of\", \"by\", \"with\", \"from\",\n   598→    \"z\", \"w\", \"i\", \"ze\", \"na\", \"do\", \"od\", \"za\", \"po\",\n   599→  ]);\n   600→  return text.split(/(\\s+)/).map((word, idx) => {\n   601→    if (/^\\s+$/.test(word)) return word;\n   602→    const lower = word.toLowerCase();\n   603→    if (idx === 0 || !smallWords.has(lower)) {\n   604→      return lower.charAt(0).toUpperCase() + lower.slice(1);\n   605→    }\n   606→    return lower;\n   607→  }).join(\"\");\n   608→}\n   609→\n   610→/**\n   611→ * OCR digit→letter substitution map.\n   612→ * Each key is a character that OCR commonly confuses; values are possible correct letters.\n   613→ */\n   614→const OCR_SUBSTITUTIONS: Record<string, string[]> = {\n   615→  \"0\": [\"o\"],\n   616→  \"1\": [\"i\", \"l\"],\n   617→  \"4\": [\"a\"],\n   618→  \"5\": [\"s\"],\n   619→  \"¡\": [\"i\"],\n   620→  \"í\": [\"i\"],\n   621→  \"€\": [\"e\"],\n   622→};\n   623→\n   624→const OCR_ARTIFACT_PATTERN = /[0-9¡Íí€]/;\n   625→\n   626→/**\n   627→ * Attempt to repair a single OCR-corrupted word using dictionary lookup.\n   628→ * Returns the repaired word if a dictionary match is found, otherwise returns the original.\n   629→ */\n   630→function repairOcrWord(word: string): string {\n   631→  if (!OCR_ARTIFACT_PATTERN.test(word)) return word;\n   632→\n   633→  const lower = word.toLowerCase();\n   634→\n   635→  const positions: { index: number; replacements: string[] }[] = [];\n   636→  for (let i = 0; i < lower.length; i++) {\n   637→    const replacements = OCR_SUBSTITUTIONS[lower[i]];\n   638→    if (replacements) {\n   639→      positions.push({ index: i, replacements });\n   640→    }\n   641→  }\n   642→\n   643→  if (positions.length === 0 || positions.length > 8) return word;\n   644→\n   645→  const candidates = generateSubstitutions(lower, positions, 0);\n   646→\n   647→  for (const candidate of candidates) {\n   648→    if (FOOD_DICTIONARY.has(candidate)) {\n   649→      if (word === word.toUpperCase()) return candidate.toUpperCase();\n   650→      if (word[0] === word[0].toUpperCase()) {\n   651→        return candidate[0].toUpperCase() + candidate.slice(1);\n   652→      }\n   653→      return candidate;\n   654→    }\n   655→  }\n   656→\n   657→  return word;\n   658→}\n   659→\n   660→/**\n   661→ * Recursively generate all substitution variants for OCR artifact positions.\n   662→ */\n   663→function generateSubstitutions(\n   664→  base: string,\n   665→  positions: { index: number; replacements: string[] }[],\n   666→  posIdx: number,\n   667→): string[] {\n   668→  if (posIdx >= positions.length) return [base];\n   669→\n   670→  const { index, replacements } = positions[posIdx];\n   671→  const results: string[] = [];\n   672→\n   673→  for (const replacement of replacements) {\n   674→    const variant = base.slice(0, index) + replacement + base.slice(index + 1);\n   675→    results.push(...generateSubstitutions(variant, positions, posIdx + 1));\n   676→  }\n   677→\n   678→  return results;\n   679→}\n   680→\n   681→/**\n   682→ * Apply dictionary-guided OCR repair to all words in a text string.\n   683→ */\n   684→function repairOcrText(text: string): string {\n   685→  return text\n   686→    .split(/\\s+/)\n   687→    .map((word) => {\n   688→      const match = word.match(/^([^a-zA-Z0-9À-ÿ]*)(.*?)([^a-zA-Z0-9À-ÿ]*)$/);\n   689→      if (!match) return word;\n   690→      const [, prefix, core, suffix] = match;\n   691→      if (!core) return word;\n   692→      const repaired = repairOcrWord(core);\n   693→      return prefix + repaired + suffix;\n   694→    })\n   695→    .join(\" \");\n   696→}\n   697→\n   698→/**\n   699→ * Post-processing normalization for OCR-extracted titles.\n   700→ * Strips stray section markers and substitutes common OCR digit-for-letter artifacts.\n   701→ * Title-case conversion is applied only when a substitution was actually made, so\n   702→ * clean ALL_CAPS titles (e.g. \"CHOCOLATE CAKE\") are returned unchanged.\n   703→ */\n   704→function normalizeOcrTitle(raw: string): string {\n   705→  let text = raw.trim();\n   706→\n   707→  // Step 0: Dictionary-guided OCR repair — resolve ambiguous substitutions\n   708→  // using word-level context before applying blind character replacements.\n   709→  text = repairOcrText(text);\n   710→\n   711→  // Step 1: Strip trailing section markers greedily appended to the title.\n   712→  // e.g. \"MAKOWIEC ZE ŚLIWKAMI + SERVING AND STORAGE:\" → \"MAKOWIEC ZE ŚLIWKAMI\"\n   713→  text = text.replace(\n   714→    /\\s*\\+\\s*(?:SERV[IÍ1]NG(?:\\s+AND\\s+STORAGE)?|TOPPING|NOTES?|TIPS?)\\s*:?\\s*$/i,\n   715→    \"\"\n   716→  );\n   717→\n   718→  // Step 2: OCR character substitution.\n   719→  // For ALL_CAPS text, apply digit-for-letter substitutions.\n   720→  const beforeSub = text;\n   721→  if (isAllCaps(text)) {\n   722→    text = text\n   723→      .replace(/1/g, \"I\")\n   724→      .replace(/0(?=[A-ZÀ-Ż])/g, \"O\")\n   725→      .replace(/(?<=[A-ZÀ-Ż])0/g, \"O\")\n   726→      .replace(/4(?=[A-ZÀ-Ż])/g, \"A\")\n   727→      .replace(/(?<=[A-ZÀ-Ż])4/g, \"A\")\n   728→      .replace(/5(?=[A-ZÀ-Ż])/g, \"S\")\n   729→      .replace(/(?<=[A-ZÀ-Ż])5/g, \"S\")\n   730→      .replace(/¡/g, \"I\")\n   731→      .replace(/€/g, \"E\")\n   732→      .replace(/[ÍÌ]/g, \"I\");\n   733→  } else {\n   734→    // Mixed-case: fix per-word (digits between lowercase letters)\n   735→    text = text.split(/(\\s+)/).map((token) => {\n   736→      if (/^\\s+$/.test(token)) return token;\n   737→      if (isAllCaps(token) && token.length > 1) {\n   738→        return token\n   739→          .replace(/1/g, \"I\")\n   740→          .replace(/0(?=[A-Z])/g, \"O\")\n   741→          .replace(/(?<=[A-Z])0/g, \"O\");\n   742→      }\n   743→      return token\n   744→        .replace(/(?<=[a-zà-ż])1/g, \"l\")\n   745→        .replace(/1(?=[a-zà-ż])/g, \"l\")\n   746→        .replace(/¡/g, \"i\")\n   747→        .replace(/€/g, \"e\");\n   748→    }).join(\"\");\n   749→  }\n   750→\n   751→  // Step 3: Title-case conversion — ONLY when OCR substitution changed the text.\n   752→  // This preserves clean ALL_CAPS titles (e.g. \"CHOCOLATE CAKE\") as-is.\n   753→  if (text !== beforeSub && isAllCaps(text)) {\n   754→    text = toTitleCase(text);\n   755→  }\n   756→\n   757→  return text.trim();\n   758→}\n   759→\n   760→// Module-level cache for reference embeddings\n   761→let cachedTitleRefEmbedding: Array<number> | null = null;\n   762→let cachedHeaderRefEmbedding: Array<number> | null = null;\n   763→let cachedNoiseRefEmbedding: Array<number> | null = null;\n   764→\n   765→export function _resetEmbeddingCacheForTests(): void {\n   766→  cachedTitleRefEmbedding = null;\n   767→  cachedHeaderRefEmbedding = null;\n   768→  cachedNoiseRefEmbedding = null;\n   769→}\n   770→\n   771→export async function extractTitleWithEmbeddings(\n   772→  text: string,\n   773→  embed: EmbedFn\n   774→): Promise<string | undefined> {\n   775→  if (!text || text.trim().length === 0) {\n   776→    return undefined;\n   777→  }\n   778→\n   779→  const lines = text.split(\"\\n\");\n   780→  const candidates = buildCandidates(lines);\n   781→\n   782→  if (candidates.length === 0) {\n   783→    return undefined;\n   784→  }\n   785→\n   786→  // Cache reference embeddings\n   787→  if (!cachedTitleRefEmbedding) {\n   788→    cachedTitleRefEmbedding = await embed(TITLE_REFERENCE);\n   789→  }\n   790→  if (!cachedHeaderRefEmbedding) {\n   791→    cachedHeaderRefEmbedding = await embed(HEADER_REFERENCE);\n   792→  }\n   793→  if (!cachedNoiseRefEmbedding) {\n   794→    cachedNoiseRefEmbedding = await embed(NOISE_REFERENCE);\n   795→  }\n   796→\n   797→  // Find ALL_CAPS candidates with ≥2 words where every significant word has ≥4 alpha letters.\n   798→  // Insignificant tokens (≤1 alpha letter: \"/\", \"&\", \"+\", \":\", \"D)\", etc.) are filtered before\n   799→  // the check so that multi-line joins with continuation punctuation still qualify.\n   800→  const isStructuralHeading = (c: { text: string }): boolean => {\n   801→    if (!isAllCaps(c.text) || wordCount(c.text) < 2) return false;\n   802→    const sigWords = c.text.trim().split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length > 1);\n   803→    return sigWords.length >= 2 && sigWords.every((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   804→  };\n   805→\n   806→  // Pass 1: compute rawScore for all candidates (embedding quality signal)\n   807→  const rawScored: Array<{ text: string; position: number; origin: CandidateOrigin; rawScore: number; embedding: Array<number> }> = [];\n   808→  for (const candidate of candidates) {\n   809→    const embedding = await embed(candidate.text);\n   810→    const titleSim = cosineSimilarity(embedding, cachedTitleRefEmbedding);\n   811→    const headerSim = cosineSimilarity(embedding, cachedHeaderRefEmbedding);\n   812→    const noiseSim = cosineSimilarity(embedding, cachedNoiseRefEmbedding);\n   813→    const rawScore = titleSim - Math.max(headerSim, noiseSim);\n   814→    rawScored.push({ text: candidate.text, position: candidate.position, origin: candidate.origin, rawScore, embedding });\n   815→  }\n   816→\n   817→  // Select baseHeading by embedding quality (rawScore), not position.\n   818→  // This prevents OCR-garbled fragments from claiming the structural heading slot.\n   819→  const structuralCandidates = rawScored.filter((s) => isStructuralHeading(s));\n   820→\n   821→  // Penalize structural headings with truncated OCR words:\n   822→  // if \"FRON\" appears and another heading has \"SAFFRON\", \"FRON\" is likely garbled.\n   823→  for (const sc of structuralCandidates) {\n   824→    const sigWords = sc.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   825→    for (const other of structuralCandidates) {\n   826→      if (other === sc) continue;\n   827→      const otherSigWords = other.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   828→      const hasTruncation = sigWords.some((w) =>\n   829→        otherSigWords.some((ow) => ow !== w && ow.length > w.length && ow.endsWith(w))\n   830→      );\n   831→      if (hasTruncation) {\n   832→        sc.rawScore = -1.0;  // Hard disqualification — truncated OCR artifact\n   833→        break;\n   834→      }\n   835→    }\n   836→  }\n   837→\n   838→  const bestStructural = structuralCandidates.length > 0\n   839→    ? structuralCandidates.reduce((a, b) => {\n   840→        const scoreDiff = a.rawScore - b.rawScore;\n   841→        if (Math.abs(scoreDiff) > 0.03) return scoreDiff > 0 ? a : b;\n   842→        // Tiebreak: single-line origin beats multi-line joins (avoids conflating two separate headings)\n   843→        if (a.origin === \"single\" && b.origin !== \"single\") return a;\n   844→        if (b.origin === \"single\" && a.origin !== \"single\") return b;\n   845→        // Tiebreak: more words (more specific) → better\n   846→        const wcDiff = wordCount(b.text) - wordCount(a.text);\n   847→        if (wcDiff !== 0) return wcDiff > 0 ? b : a;\n   848→        // Tiebreak: earlier position → better\n   849→        return a.position < b.position ? a : b;\n   850→      })\n   851→    : null;\n   852→  const baseHeading = bestStructural ?? undefined;\n   853→\n   854→  // When the best structural heading has a continuation on the next line introduced by a\n   855→  // punctuation token (/, &, +, :, or parenthesis), prefer the longer 2-line join as the\n   856→  // complete heading. E.g. \"SAFFRON WHEAT BUNS WITH QUARK\" + \"/ COTTAGE CHEESE (VARIATION D)\".\n   857→  // Guard: the remainder after the prefix must start with a continuation character to avoid\n   858→  // merging two separate consecutive recipe titles (FINNISH MILK FLATBREADS stays separate\n   859→  // from FINNISH POTATO FLATBREADS because \"FINNISH\" does not start with a continuation token).\n   860→  let firstStructuralHeading = baseHeading && (\n   861→    rawScored.find((c) => {\n   862→      if (!isStructuralHeading(c)) return false;\n   863→      const hLower = baseHeading.text.toLowerCase();\n   864→      const cLower = c.text.toLowerCase();\n   865→      return cLower.startsWith(hLower + \" \") && /^[/&+:(]/.test(cLower.slice(hLower.length + 1));\n   866→    }) ?? baseHeading\n   867→  );\n   868→\n   869→  // Pass 2: apply bonuses\n   870→  const scored: Array<{ text: string; position: number; origin: CandidateOrigin; score: number; rawScore: number; baseScore: number; thresholdScore: number }> = rawScored.map((rs, candidateIndex) => {\n   871→    // Position factor: multiplicative tiebreaker — amplifies existing signal, doesn't replace it.\n   872→    // Use candidate-relative position (rank among candidates that passed hard filters) rather than\n   873→    // raw line position, so filtered preamble lines don't penalize the first real candidate.\n   874→    const candidateRelativePosition = candidateIndex / rawScored.length;\n   875→    const positionFactor = candidateRelativePosition < 0.5\n   876→      ? 1.0 + 0.12 * (1 - candidateRelativePosition * 2)\n   877→      : 1.0;\n   878→\n   879→    // ALL_CAPS bonus: recipe books use ALL_CAPS for titles and section headings.\n   880→    // Single-word ALL_CAPS terms are overwhelmingly section/category labels, not recipe titles;\n   881→    // real recipe titles in ALL_CAPS are almost always multi-word. Reduce the bonus for single words.\n   882→    const allCapsBonus = isAllCaps(rs.text) && rs.text.replace(/[^a-zA-Z]/g, \"\").length >= 4\n   883→      ? (wordCount(rs.text) >= 2 ? 0.08 : 0.03)\n   884→      : 0;\n   885→\n   886→    // Structural heading bonus: best ALL_CAPS heading (or its continuation join) is almost always the recipe title\n   887→    const structuralBonus = firstStructuralHeading && rs.text === firstStructuralHeading.text ? 0.10 : 0;\n   888→\n   889→    // thresholdScore excludes structural bonus so the bonus doesn't inflate the threshold\n   890→    // and prevent equally-valid structural headings from passing on multi-recipe pages.\n   891→    const thresholdScore = rs.rawScore + allCapsBonus;\n   892→    // baseScore excludes position factor — used for diagnostics and ranking\n   893→    const baseScore = rs.rawScore + allCapsBonus + structuralBonus;\n   894→    const score = rs.rawScore * positionFactor + allCapsBonus + structuralBonus;\n   895→    return { text: rs.text, position: rs.position, origin: rs.origin, score, rawScore: rs.rawScore, baseScore, thresholdScore };\n   896→  });\n   897→\n   898→  if (scored.length === 0) {\n   899→    return undefined;\n   900→  }\n   901→\n   902→  // First-after-preamble bonus (Pattern 3): when lines before the first candidate were all\n   903→  // filtered/empty, the first surviving candidate occupies the structural \"title position\".\n   904→  // E.g. \"FISH & SEAFOOD\\nHalibut with Saffron Cream Sauce\\n...\" — \"FISH & SEAFOOD\" is filtered\n   905→  // as a section label, so \"Halibut...\" is the first candidate and gets this boost.\n   906→  const firstCandidate = scored[0];\n   907→  if (firstCandidate.position > 0) {\n   908→    const allPrecedingFiltered = lines\n   909→      .slice(0, firstCandidate.position)\n   910→      .every((line) => {\n   911→        const trimmed = line.trim();\n   912→        return trimmed === \"\" || !passesHardFilters(trimmed);\n   913→      });\n   914→    if (allPrecedingFiltered) {\n   915→      firstCandidate.score += 0.08;\n   916→      firstCandidate.baseScore += 0.08;\n   917→      firstCandidate.thresholdScore += 0.08;\n   918→    }\n   919→  }\n   920→\n   921→  // --- Pre-threshold bilingual title detection ---\n   922→  // When a mixed-case candidate at position 0 is followed by an ALL_CAPS candidate\n   923→  // at position ≤ 2 that is semantically similar to it, this is a bilingual recipe\n   924→  // page (e.g., Polish title + ALL_CAPS Korean romanization). Suppress confirmed\n   925→  // translation candidates before computing threshold so their bonuses don't inflate\n   926→  // the threshold beyond the mixed-case title's reach.\n   927→  // Note: we check position ≤ 2 (local proximity), not global ALL_CAPS count, so\n   928→  // section headers later in the document (SKŁADNIKI, WARZYWA, etc.) are irrelevant.\n   929→  let translationCandidates: typeof scored = [];\n   930→  let scoredForThreshold = scored;\n   931→  const prePos0 = scored.find((s) => s.position === 0 && !isAllCaps(s.text));\n   932→  if (prePos0) {\n   933→    const nearbyAllCaps = scored.filter(\n   934→      (s) => isAllCaps(s.text) && s.position >= 1 && s.position <= 2 && s.origin === \"single\"\n   935→    );\n   936→    const pos0Embedding = rawScored.find((r) => r.text === prePos0.text)?.embedding;\n   937→\n   938→    // Method 1: embedding similarity (works for related languages)\n   939→    if (pos0Embedding && nearbyAllCaps.length > 0) {\n   940→      translationCandidates = nearbyAllCaps.filter((cap) => {\n   941→        const capEmbedding = rawScored.find((r) => r.text === cap.text)?.embedding;\n   942→        if (!capEmbedding) return false;\n   943→        return cosineSimilarity(pos0Embedding, capEmbedding) > 0.4;\n   944→      });\n   945→    }\n   946→\n   947→    // Method 2: layout-based detection (cross-lingual fallback).\n   948→    // When embedding similarity is insufficient (e.g. Polish ↔ Korean romanization),\n   949→    // detect bilingual layout by position and word overlap:\n   950→    // mixed-case ≥2 words at pos 0 + ALL_CAPS ≥2 words at pos 1-2 with no shared words.\n   951→    if (translationCandidates.length === 0 && wordCount(prePos0.text) >= 2) {\n   952→      const pos0Words = new Set(\n   953→        prePos0.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2)\n   954→      );\n   955→      translationCandidates = nearbyAllCaps.filter((cap) => {\n   956→        if (wordCount(cap.text) < 2) return false;\n   957→        const capWords = cap.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2);\n   958→        return !capWords.some((w) => pos0Words.has(w));\n   959→      });\n   960→    }\n   961→\n   962→    if (translationCandidates.length > 0) {\n   963→      // Suppress standalone translations and any multi-line joins that embed the translation\n   964→      // as a suffix or substring (e.g. \"Smażona zielona fasolka GREEN BEANS BORKEUM\" ends with\n   965→      // the translation; \"Title GREEN BEANS BORKEUM 그린빈\" includes it as a substring).\n   966→      scoredForThreshold = scored.filter((s) => {\n   967→        const sLower = s.text.toLowerCase();\n   968→        return !translationCandidates.some((t) => {\n   969→          const tLower = t.text.toLowerCase();\n   970→          return sLower.startsWith(tLower) ||\n   971→                 sLower.endsWith(\" \" + tLower) ||\n   972→                 sLower.includes(\" \" + tLower);\n   973→        });\n   974→      });\n   975→    }\n   976→  }\n   977→\n   978→  // Fix 2: If the structural heading was identified as a bilingual translation, reassign it.\n   979→  // This prevents the translation's ALL_CAPS bonus from inflating the threshold and ensures\n   980→  // the fallback path in scored also uses the correct heading.\n   981→  if (\n   982→    translationCandidates.length > 0 &&\n   983→    firstStructuralHeading &&\n   984→    translationCandidates.some((t) => t.text === firstStructuralHeading!.text)\n   985→  ) {\n   986→    const nonTranslationStructural = structuralCandidates.filter(\n   987→      (sc) => !translationCandidates.some((t) => t.text === sc.text)\n   988→    );\n   989→    const newHeading = nonTranslationStructural.length > 0\n   990→      ? nonTranslationStructural.reduce((a, b) => a.rawScore > b.rawScore ? a : b)\n   991→      : undefined;\n   992→\n   993→    // Patch scored array: remove old structural bonus, apply new one\n   994→    for (const s of scored) {\n   995→      if (s.text === firstStructuralHeading.text) {\n   996→        s.score -= 0.10;\n   997→        s.baseScore -= 0.10;\n   998→      }\n   999→      if (newHeading && s.text === newHeading.text) {\n  1000→        s.score += 0.10;\n  1001→        s.baseScore += 0.10;\n  1002→      }\n  1003→    }\n  1004→    // Update reference for downstream prefix-removal logic\n  1005→    firstStructuralHeading = newHeading ?? undefined;\n  1006→  }\n  1007→\n  1008→  // Subtitle suppression: when a short mixed-case title at position 0 is followed by a\n  1009→  // longer mixed-case candidate at position 1-2, the longer one is a subtitle/translation.\n  1010→  // Apply a penalty so the primary title (position 0) wins.\n  1011→  const pos0Primary = scored.find((s) => s.position === 0 && !isAllCaps(s.text) && wordCount(s.text) <= 5);\n  1012→  if (pos0Primary) {\n  1013→    const subtitleCandidates = scored.filter((s) =>\n  1014→      s.position >= 1 && s.position <= 2 &&\n  1015→      !isAllCaps(s.text) &&\n  1016→      wordCount(s.text) > wordCount(pos0Primary.text) + 2\n  1017→    );\n  1018→    for (const sub of subtitleCandidates) {\n  1019→      sub.score -= 0.15;\n  1020→    }\n  1021→  }\n  1022→\n  1023→  // Use thresholdScore (excludes structural bonus) so the structural bonus doesn't inflate\n  1024→  // the threshold and block equally-valid headings on multi-recipe pages.\n  1025→  const bestThresholdScore = Math.max(...scoredForThreshold.map((s) => s.thresholdScore));\n  1026→  const threshold = Math.max(0.08, bestThresholdScore * 0.7);\n  1027→\n  1028→  // Filter candidates above threshold\n  1029→  let selected = scoredForThreshold.filter((s) => s.score >= threshold);\n  1030→\n  1031→  // Empty-pool fallback: when threshold filtering discards every candidate,\n  1032→  // the hard filters' structural verdict should not be overruled by weak\n  1033→  // embedding differentiation. Return the best positional candidate only\n  1034→  // if it has a meaningful positive raw score (avoids ingredient-list leakage).\n  1035→  if (selected.length === 0 && scored.length > 0) {\n  1036→    const fallback = scored\n  1037→      .slice()\n  1038→      .sort((a, b) => a.position - b.position || b.score - a.score);\n  1039→    // Position-0 candidates that passed hard filters are very likely titles even with\n  1040→    // weak embedding signal. Relax the rawScore guard for early-position candidates.\n  1041→    const rawScoreThreshold = fallback[0].position <= 2 ? -0.05 : 0.02;\n  1042→    if (fallback[0].rawScore > rawScoreThreshold) {\n  1043→      selected = [fallback[0]];\n  1044→    }\n  1045→  }\n  1046→\n  1047→  // Remove word-boundary prefixes of firstStructuralHeading when the heading itself survived\n  1048→  // the threshold. Cases:\n  1049→  //   ARAYES case:  firstStructuralHeading = \"ARAYES SHRAK\" (2-word join qualifies; \"ARAYES\"\n  1050→  //     alone = 1 word, so it never qualified). Filter removes \"ARAYES\" so dedup keeps the join.\n  1051→  //   SAFFRON case: baseHeading was the partial line; continuation logic above upgraded\n  1052→  //     firstStructuralHeading to the full join. Filter removes the partial so dedup keeps join.\n  1053→  // Safety: only fires when the complete heading itself is in selected (passed the threshold).\n  1054→  if (firstStructuralHeading && selected.some((s) => s.text === firstStructuralHeading.text)) {\n  1055→    const fshLower = firstStructuralHeading.text.toLowerCase();\n  1056→    selected = selected.filter((s) => {\n  1057→      if (s.text === firstStructuralHeading.text) return true;\n  1058→      const sLower = s.text.toLowerCase();\n  1059→      // Remove s if it is a space-delimited prefix of the structural heading\n  1060→      return !fshLower.startsWith(sLower + \" \");\n  1061→    });\n  1062→  }\n  1063→\n  1064→  // Protect continuation joins: when a multi-line join (2-line or 3-line) survived the threshold\n  1065→  // and its second part starts with a continuation character, remove the single-line prefix/suffix\n  1066→  // so the dedup \"shorter wins\" rule doesn't destroy the complete join.\n  1067→  // Note: the pre-merge step above already handles the common Baked Eggs case (&/continuation\n  1068→  // on next line) by turning it into a single candidate — this block covers the rarer case where\n  1069→  // a continuation-character join was generated as a 2-line/3-line candidate and the prefix\n  1070→  // single also survived threshold independently (e.g. from a different code path or OCR layout).\n  1071→  // Safety: only fires for joins whose continuation starts with /&+:( — digit continuations\n  1072→  // like \"Pierogi Ruskie 200g mąki\" are NOT protected, so dedup correctly keeps the shorter form.\n  1073→  const survivingJoins = selected.filter((s) => s.origin === \"2-line\" || s.origin === \"3-line\");\n  1074→  if (survivingJoins.length > 0) {\n  1075→    selected = selected.filter((s) => {\n  1076→      if (s.origin !== \"single\") return true;\n  1077→      const sLower = s.text.toLowerCase();\n  1078→      // Remove PREFIX singles whose continuation join also survived\n  1079→      const isPrefixOfJoin = survivingJoins.some((j) => {\n  1080→        const jLower = j.text.toLowerCase();\n  1081→        if (!jLower.startsWith(sLower + \" \")) return false;\n  1082→        const remainder = jLower.slice(sLower.length + 1);\n  1083→        return /^[/&+:(]/.test(remainder);\n  1084→      });\n  1085→      if (isPrefixOfJoin) return false;\n  1086→      // Remove SUFFIX singles (e.g. \"& Coriander\") whose parent join also survived\n  1087→      const isSuffixOfJoin = survivingJoins.some((j) => {\n  1088→        const jLower = j.text.toLowerCase();\n  1089→        if (!jLower.endsWith(\" \" + sLower)) return false;\n  1090→        // Only remove if the suffix starts with a continuation character\n  1091→        return /^[/&+:(]/.test(sLower);\n  1092→      });\n  1093→      if (isSuffixOfJoin) return false;\n  1094→      return true;\n  1095→    });\n  1096→  }\n  1097→\n  1098→  // Pre-dedup: remove sub-section headers that are substrings of other surviving candidates.\n  1099→  // A sub-section header is an ALL_CAPS candidate followed by ingredient-like lines in the source.\n  1100→  // Example: \"CHLEBEK\" (bread section header, followed by \"500 g mąki\") is a substring of\n  1101→  // \"CHLEBEK Z WARZYWAMI I BOCZKIEM\" (the real title). Without this filter, dedup kills the title.\n  1102→  selected = selected.filter((candidate) => {\n  1103→    if (!isAllCaps(candidate.text)) return true;\n  1104→    // Check if this candidate is immediately followed by ingredient-like content\n  1105→    const nextSourceLines = lines.slice(candidate.position + 1, candidate.position + 2);\n  1106→    const followedByIngredients = nextSourceLines.some(\n  1107→      (l) => looksLikeIngredient(l.trim()) || startsWithNumber(l.trim())\n  1108→    );\n  1109→    if (!followedByIngredients) return true;\n  1110→    // Only remove if a longer candidate contains this one as a substring\n  1111→    const candidateLower = candidate.text.toLowerCase();\n  1112→    const hasLongerParent = rawScored.some(\n  1113→      (other) =>\n  1114→        other.text !== candidate.text &&\n  1115→        other.text.length > candidate.text.length &&\n  1116→        other.text.toLowerCase().includes(candidateLower)\n  1117→    );\n  1118→    return !hasLongerParent;\n  1119→  });\n  1120→\n  1121→  // Protect multi-line joins from being destroyed by their own component singles.\n  1122→  // When \"Lamb Stew\" (2-line join) survives AND both \"Lamb\" and \"Stew\" (singles) also survive,\n  1123→  // the join is the intended title — remove the singles.\n  1124→  const joinsToProtect = selected.filter((s) => s.origin === \"2-line\" || s.origin === \"3-line\");\n  1125→  if (joinsToProtect.length > 0) {\n  1126→    const singlesToRemove = new Set<string>();\n  1127→    for (const join of joinsToProtect) {\n  1128→      const joinWords = join.text.split(/\\s+/);\n  1129→      const componentSingles = selected.filter(\n  1130→        (s) => s.origin === \"single\" && joinWords.some((w) => s.text.toLowerCase() === w.toLowerCase())\n  1131→      );\n  1132→      if (componentSingles.length >= Math.min(joinWords.length, 2)) {\n  1133→        componentSingles.forEach((s) => singlesToRemove.add(s.text));\n  1134→      }\n  1135→    }\n  1136→    if (singlesToRemove.size > 0) {\n  1137→      selected = selected.filter((s) => s.origin !== \"single\" || !singlesToRemove.has(s.text));\n  1138→    }\n  1139→  }\n  1140→\n  1141→  // Protect position-0 compound titles from distant sub-section headers.\n  1142→  // When a position-0 compound title is longer and contains a shorter candidate\n  1143→  // that appears > 10 lines later, remove the distant candidate so the dedup\n  1144→  // (shorter-wins rule) doesn't destroy the compound title.\n  1145→  const pos0Compounds = selected.filter((s) => s.position === 0);\n  1146→  if (pos0Compounds.length > 0) {\n  1147→    selected = selected.filter((s) => {\n  1148→      if (s.position === 0) return true;\n  1149→      const sLower = s.text.toLowerCase();\n  1150→      return !pos0Compounds.some(\n  1151→        (p0) =>\n  1152→          p0.position + 10 < s.position &&\n  1153→          s.text.length < p0.text.length &&\n  1154→          p0.text.toLowerCase().includes(sLower)\n  1155→      );\n  1156→    });\n  1157→  }\n  1158→\n  1159→  // Deduplicate: if one title is a substring of another, keep the shorter (more focused) one.\n  1160→  // DO NOT CHANGE THIS LOGIC — it has been incorrectly \"improved\" by the title-loop 5 times.\n  1161→  // The tests require shorter wins: \"Pierogi Ruskie\" over \"Pierogi Ruskie 200g mąki 3 ziemniaki\".\n  1162→  // The pre-filter above handles the conflicting case (structural heading prefix removal) so that\n  1163→  // the incomplete prefix line is never present here when the complete join is in selected.\n  1164→  selected = selected.filter((a) => {\n  1165→    const aLower = a.text.toLowerCase();\n  1166→    return !selected.some(\n  1167→      (b) =>\n  1168→        b !== a &&\n  1169→        aLower.includes(b.text.toLowerCase()) &&\n  1170→        b.text.length < a.text.length\n  1171→    );\n  1172→  });\n  1173→\n  1174→  // Multi-title guard: only join multiple candidates with \"+\" when there is\n  1175→  // structural evidence of a multi-recipe page (≥2 ALL_CAPS headings).\n  1176→  // A single ALL_CAPS title among mixed-case survivors is a single-recipe page —\n  1177→  // collapse to the highest-scoring candidate.\n  1178→  // Zero ALL_CAPS survivors → apply positional tiebreak only when candidates are\n  1179→  // spread far apart (>10 lines), which indicates body-text leakage. Closely-\n  1180→  // positioned candidates are likely genuine multi-recipe content.\n  1181→  if (selected.length > 1) {\n  1182→    const allCapsSelected = selected.filter((s) => isAllCaps(s.text));\n  1183→    if (allCapsSelected.length >= 2) {\n  1184→      // Check whether non-first ALL_CAPS headings are section headers within one recipe\n  1185→      // (followed immediately by ingredient-like content) rather than separate recipe titles.\n  1186→      // A multi-recipe page has body text between titles; a single-recipe page has\n  1187→      // ingredient lines immediately after each section heading.\n  1188→      const sortedCaps = [...allCapsSelected].sort((a, b) => a.position - b.position);\n  1189→      const isSubHeader = sortedCaps.slice(1).every((cap) => {\n  1190→        const nextLines = lines.slice(cap.position + 1, cap.position + 3);\n  1191→        return nextLines.some(\n  1192→          (l) => looksLikeIngredient(l.trim()) || /^\\s*\\d/.test(l.trim())\n  1193→        );\n  1194→      });\n  1195→      if (isSubHeader) {\n  1196→        selected = [sortedCaps[0]];\n  1197→      } else {\n  1198→        selected = allCapsSelected;\n  1199→      }\n  1200→    } else if (allCapsSelected.length === 1) {\n  1201→      const theCapCandidate = allCapsSelected[0];\n  1202→      // Use non-empty line count so the 75% threshold is consistent regardless of blank-line density.\n  1203→      const nonEmptyCount = lines.filter((l) => l.trim().length > 0).length;\n  1204→      const capRelPos = theCapCandidate.position / Math.max(nonEmptyCount, 1);\n  1205→      // If the sole ALL_CAPS candidate is in the last 25% of the document,\n  1206→      // it's likely a category footer, not a title. Prefer the best earlier candidate.\n  1207→      if (capRelPos > 0.75) {\n  1208→        const earlierCandidates = selected.filter(\n  1209→          (s) => s.position / Math.max(nonEmptyCount, 1) <= 0.75\n  1210→        );\n  1211→        if (earlierCandidates.length > 0) {\n  1212→          selected = [earlierCandidates.reduce((a, b) => (a.score > b.score ? a : b))];\n  1213→        } else {\n  1214→          // All candidates are in the last 25% — no positional basis to prefer one over another;\n  1215→          // fall back to score, accepting that the guard cannot help here.\n  1216→          selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n  1217→        }\n  1218→      } else {\n  1219→        selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n  1220→      }\n  1221→    } else {\n  1222→      // Zero ALL_CAPS survivors → mixed-case page.\n  1223→      // If all survivors are closely positioned (within 10 lines of each other), keep them all —\n  1224→      // they're likely genuine multi-recipe content on a single page.\n  1225→      // If any survivor is far from the earliest, apply a positional tiebreak: the real title\n  1226→      // is almost always the earliest candidate; distant survivors are likely body-text leakage.\n  1227→      selected.sort((a, b) => a.position - b.position);\n  1228→      const earliest = selected[0];\n  1229→      const farthest = selected[selected.length - 1];\n  1230→      if (farthest.position - earliest.position > 10) {\n  1231→        // Large span → body-text leakage. Collapse to one: prefer the highest-scoring\n  1232→        // candidate within 3 positions of the earliest (position tolerance for OCR gaps),\n  1233→        // falling back to the earliest itself if none score higher.\n  1234→        const closeCompetitors = selected.filter(\n  1235→          (s) => s.position <= earliest.position + 3 && s.score > earliest.score\n  1236→        );\n  1237→        selected = closeCompetitors.length > 0\n  1238→          ? [closeCompetitors.reduce((a, b) => (a.score > b.score ? a : b))]\n  1239→          : [earliest];\n  1240→      }\n  1241→      // Span ≤ 10 → all survivors are closely positioned; fall through keeping all.\n  1242→    }\n  1243→  }\n  1244→\n  1245→  // Cap at 3, sort by document position\n  1246→  selected.sort((a, b) => a.position - b.position);\n  1247→  selected = selected.slice(0, 3);\n  1248→\n  1249→  if (selected.length === 0) {\n  1250→    // Last resort: embedding scoring provided no usable signal.\n  1251→    // Return the earliest candidate that passed hard filters — it already survived\n  1252→    // ingredient, metadata, garbled, section-label, and cooking-instruction checks.\n  1253→    // Position 0 in a recipe file is overwhelmingly the title.\n  1254→    // Exclude hard-disqualified candidates (rawScore -1.0 = truncated OCR artifact).\n  1255→    const lastResort = scored\n  1256→      .slice()\n  1257→      .filter((s) => s.rawScore > -0.5)\n  1258→      .sort((a, b) => a.position - b.position || b.score - a.score);\n  1259→    if (lastResort.length > 0) {\n  1260→      return normalizeOcrTitle(lastResort[0].text.normalize(\"NFC\").trim());\n  1261→    }\n  1262→    return undefined;\n  1263→  }\n  1264→\n  1265→  const result = selected.map((s) => normalizeOcrTitle(s.text.normalize(\"NFC\").trim())).join(\" + \");\n  1266→\n  1267→  return result;\n  1268→}\n  1269→\n  1270→/**\n  1271→ * Extract potential recipe title from OCR text (sync heuristic fallback)\n  1272→ */\n  1273→export function extractTitle(text: string): string | undefined {\n  1274→  if (!text || text.trim().length === 0) {\n  1275→    return undefined;\n  1276→  }\n  1277→\n  1278→  const lines = text.split(\"\\n\").map((line) => line.trim());\n  1279→\n  1280→  for (const line of lines) {\n  1281→    if (line.length === 0) continue;\n  1282→    if (line.length < 3 || line.length > 50) continue;\n  1283→    if (looksLikeIngredient(line)) continue;\n  1284→    if (isAllCaps(line)) continue;\n  1285→    if (startsWithNumber(line)) continue;\n  1286→    return line;\n  1287→  }\n  1288→\n  1289→  return undefined;\n  1290→}\n  1291→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n","numLines":1296,"startLine":1,"totalLines":1296}}}
