2)\n   954→      );\n   955→      translationCandidates = nearbyAllCaps.filter((cap) => {\n   956→        if (wordCount(cap.text) < 2) return false;\n   957→        const capWords = cap.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2);\n   958→        return !capWords.some((w) => pos0Words.has(w));\n   959→      });\n   960→    }\n   961→\n   962→    if (translationCandidates.length > 0) {\n   963→      // Suppress standalone translations and any multi-line joins that embed the translation\n   964→      // as a suffix or substring (e.g. \"Smażona zielona fasolka GREEN BEANS BORKEUM\" ends with\n   965→      // the translation; \"Title GREEN BEANS BORKEUM 그린빈\" includes it as a substring).\n   966→      scoredForThreshold = scored.filter((s) => {\n   967→        const sLower = s.text.toLowerCase();\n   968→        return !translationCandidates.some((t) => {\n   969→          const tLower = t.text.toLowerCase();\n   970→          return sLower.startsWith(tLower) ||\n   971→                 sLower.endsWith(\" \" + tLower) ||\n   972→                 sLower.includes(\" \" + tLower);\n   973→        });\n   974→      });\n   975→    }\n   976→  }\n   977→\n   978→  // Fix 2: If the structural heading was identified as a bilingual translation, reassign it.\n   979→  // This prevents the translation's ALL_CAPS bonus from inflating the threshold and ensures\n   980→  // the fallback path in scored also uses the correct heading.\n   981→  if (\n   982→    translationCandidates.length > 0 &&\n   983→    firstStructuralHeading &&\n   984→    translationCandidates.some((t) => t.text === firstStructuralHeading!.text)\n   985→  ) {\n   986→    const nonTranslationStructural = structuralCandidates.filter(\n   987→      (sc) => !translationCandidates.some((t) => t.text === sc.text)\n   988→    );\n   989→    const newHeading = nonTranslationStructural.length > 0\n   990→      ? nonTranslationStructural.reduce((a, b) => a.rawScore > b.rawScore ? a : b)\n   991→      : un