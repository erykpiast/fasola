{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0159k4PfS1QwCwrJW2BQW7nz","type":"tool_result","content":"   771→export async function extractTitleWithEmbeddings(\n   772→  text: string,\n   773→  embed: EmbedFn\n   774→): Promise<string | undefined> {\n   775→  if (!text || text.trim().length === 0) {\n   776→    return undefined;\n   777→  }\n   778→\n   779→  const lines = text.split(\"\\n\");\n   780→  const candidates = buildCandidates(lines);\n   781→\n   782→  if (candidates.length === 0) {\n   783→    return undefined;\n   784→  }\n   785→\n   786→  // Cache reference embeddings\n   787→  if (!cachedTitleRefEmbedding) {\n   788→    cachedTitleRefEmbedding = await embed(TITLE_REFERENCE);\n   789→  }\n   790→  if (!cachedHeaderRefEmbedding) {\n   791→    cachedHeaderRefEmbedding = await embed(HEADER_REFERENCE);\n   792→  }\n   793→  if (!cachedNoiseRefEmbedding) {\n   794→    cachedNoiseRefEmbedding = await embed(NOISE_REFERENCE);\n   795→  }\n   796→\n   797→  // Find ALL_CAPS candidates with ≥2 words where every significant word has ≥4 alpha letters.\n   798→  // Insignificant tokens (≤1 alpha letter: \"/\", \"&\", \"+\", \":\", \"D)\", etc.) are filtered before\n   799→  // the check so that multi-line joins with continuation punctuation still qualify.\n   800→  const isStructuralHeading = (c: { text: string }): boolean => {\n   801→    if (!isAllCaps(c.text) || wordCount(c.text) < 2) return false;\n   802→    const sigWords = c.text.trim().split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length > 1);\n   803→    return sigWords.length >= 2 && sigWords.every((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   804→  };\n   805→\n   806→  // Pass 1: compute rawScore for all candidates (embedding quality signal)\n   807→  const rawScored: Array<{ text: string; position: number; origin: CandidateOrigin; rawScore: number; embedding: Array<number> }> = [];\n   808→  for (const candidate of candidates) {\n   809→    const embedding = await embed(candidate.text);\n   810→    const titleSim = cosineSimilarity(embedding, cachedTitleRefEmbedding);\n   811→    const headerSim = cosineSimilarity(embedding, cachedHeaderRefEmbedding);\n   812→    const noiseSim = cosineSimilarity(embedding, cachedNoiseRefEmbedding);\n   813→    const rawScore = titleSim - Math.max(headerSim, noiseSim);\n   814→    rawScored.push({ text: candidate.text, position: candidate.position, origin: candidate.origin, rawScore, embedding });\n   815→  }\n   816→\n   817→  // Select baseHeading by embedding quality (rawScore), not position.\n   818→  // This prevents OCR-garbled fragments from claiming the structural heading slot.\n   819→  const structuralCandidates = rawScored.filter((s) => isStructuralHeading(s));\n   820→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"7d4a7cfe-a284-48ae-a32b-0160fa2411e9","uuid":"66a69a6f-4e11-4c34-802b-e0feddc0235e","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/title-extractor.ts","content":"export async function extractTitleWithEmbeddings(\n  text: string,\n  embed: EmbedFn\n): Promise<string | undefined> {\n  if (!text || text.trim().length === 0) {\n    return undefined;\n  }\n\n  const lines = text.split(\"\\n\");\n  const candidates = buildCandidates(lines);\n\n  if (candidates.length === 0) {\n    return undefined;\n  }\n\n  // Cache reference embeddings\n  if (!cachedTitleRefEmbedding) {\n    cachedTitleRefEmbedding = await embed(TITLE_REFERENCE);\n  }\n  if (!cachedHeaderRefEmbedding) {\n    cachedHeaderRefEmbedding = await embed(HEADER_REFERENCE);\n  }\n  if (!cachedNoiseRefEmbedding) {\n    cachedNoiseRefEmbedding = await embed(NOISE_REFERENCE);\n  }\n\n  // Find ALL_CAPS candidates with ≥2 words where every significant word has ≥4 alpha letters.\n  // Insignificant tokens (≤1 alpha letter: \"/\", \"&\", \"+\", \":\", \"D)\", etc.) are filtered before\n  // the check so that multi-line joins with continuation punctuation still qualify.\n  const isStructuralHeading = (c: { text: string }): boolean => {\n    if (!isAllCaps(c.text) || wordCount(c.text) < 2) return false;\n    const sigWords = c.text.trim().split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length > 1);\n    return sigWords.length >= 2 && sigWords.every((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n  };\n\n  // Pass 1: compute rawScore for all candidates (embedding quality signal)\n  const rawScored: Array<{ text: string; position: number; origin: CandidateOrigin; rawScore: number; embedding: Array<number> }> = [];\n  for (const candidate of candidates) {\n    const embedding = await embed(candidate.text);\n    const titleSim = cosineSimilarity(embedding, cachedTitleRefEmbedding);\n    const headerSim = cosineSimilarity(embedding, cachedHeaderRefEmbedding);\n    const noiseSim = cosineSimilarity(embedding, cachedNoiseRefEmbedding);\n    const rawScore = titleSim - Math.max(headerSim, noiseSim);\n    rawScored.push({ text: candidate.text, position: candidate.position, origin: candidate.origin, rawScore, embedding });\n  }\n\n  // Select baseHeading by embedding quality (rawScore), not position.\n  // This prevents OCR-garbled fragments from claiming the structural heading slot.\n  const structuralCandidates = rawScored.filter((s) => isStructuralHeading(s));\n","numLines":50,"startLine":771,"totalLines":1291}}}
