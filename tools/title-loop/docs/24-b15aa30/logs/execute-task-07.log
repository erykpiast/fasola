{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Wij9mMvZdDDpjwGX6qSWdM","type":"tool_result","content":"   280→// Note: only verbs that NEVER start a recipe title. \"Piecz\" (bake) is excluded because\n   281→// \"Pieczeń\" (roast) and \"Pieczarki\" (mushrooms) share the prefix.\n   282→const POLISH_COOKING_INSTRUCTION_STARTS = /^(podawaj|dodaj|dodawaj|sma[zż]|gotuj|odced[zź]|wymieszaj|mieszaj|wlej|nalej|przygotuj|zagotuj|pokr[oó]j|obierz|wrzuc|wrzuć|usma[zż]|podsma[zż]|prze[lł][oó][zż]|zblenduj|ubij|roztrzepaj|rozprowad[zź]|wyrob|zamieszaj|posyp|polej|odstaw|na[lł][oó][zż]|przykryj|odkryj|wstaw|zdejmij|ods[aą]cz|rozgrzej|posiekaj|zetrzyj|wy[lł][oó][zż]|wyjmij|ukr[oó]j|przekr[oó]j|formuj|ugniataj|rozwałkuj)\\b/i;\n   283→\n   284→function looksLikeCookingInstruction(text: string): boolean {\n   285→  const words = text.trim().split(/\\s+/);\n   286→  if (words.length < 4) return false;  // Instructions are multi-word sentences\n   287→  if (COOKING_INSTRUCTION_STARTS.test(text.trim())) return true;\n   288→  if (POLISH_COOKING_INSTRUCTION_STARTS.test(text.trim())) return true;\n   289→  return false;\n   290→}\n   291→\n   292→/**\n   293→ * Detect pages where the OCR capture starts mid-recipe with no title present.\n   294→ * Returns true if the first 3 non-empty lines are all ingredients or cooking instructions.\n   295→ */\n   296→function isTitleAbsentPage(lines: string[]): boolean {\n   297→  const nonEmptyLines = lines.map(l => l.trim()).filter(l => l.length > 0);\n   298→\n   299→  if (nonEmptyLines.length < 3) return false;\n   300→\n   301→  const first3 = nonEmptyLines.slice(0, 3);\n   302→\n   303→  return first3.every(line => looksLikeIngredient(line) || looksLikeCookingInstruction(line));\n   304→}\n   305→\n   306→function passesHardFilters(text: string): boolean {\n   307→  if (text.length < 3 || text.length > 80) return false;\n   308→  if (looksLikeIngredient(text)) return false;\n   309→  if (startsWithNumber(text)) return false;\n   310→  if (looksLikeMetadata(text)) return false;\n   311→  if (isLikelyGarbled(text)) return false;\n   312→  if (looksLikeCookingInstruction(text)) return false;\n   313→  // Pipe-separated lines are book category/chapter headers, not recipe titles\n   314→  if (text.includes(\" | \")) return false;\n   315→  // Trailing page number (e.g. \"VEGETABLE SIDES                         145\")\n   316→  if (/\\s{3,}\\d{1,4}\\s*$/.test(text)) return false;\n   317→  // Slash-separated breadcrumbs (e.g., \"/ Jesien / Zupy\") are navigation, not titles\n   318→  // Only filter when 2+ slashes are present — single-slash lines like\n   319→  // \"TITLE / SUBTITLE\" are legitimate continuation-merged titles\n   320→  if ((text.match(/\\//g) || []).length >= 2) return false;\n   321→  // Bullet-list items (ingredients or instruction steps) are never titles\n   322→  if (/^\\s*[-•*]\\s/.test(text)) return false;\n   323→  // \"For the sauce:\", \"For the filling:\" etc. are sub-section headers\n   324→  if (/^For the\\s+/i.test(text) && /:\\s*$/.test(text)) return false;\n   325→  // Lines ending with \":\" are recipe sub-section headers, not titles.\n   326→  // Exception: compound titles using \" : \" as a title separator (e.g. \"LEMON CURD : LEMON CURD WITH THYME\").\n   327→  if (/:\\s*$/.test(text.trim()) && !/ : /.test(text)) return false;\n   328→  // Page references are navigation markers, not recipe titles\n   329→  if (/^Page\\s+\\d+/i.test(text.trim())) return false;\n   330→  if (/^Strona\\s+\\d+/i.test(text.trim())) return false;\n   331→  // Corrupted spillover annotations from synthetic multi-page OCR\n   332→  if (/^\\[CORRUPTED\\s+SPILLOVER/i.test(text.trim())) return false;\n   333→  // Parenthetical OCR annotation lines describing corruption artifacts\n   334→  if (/^\\(OCR\\b/i.test(text.trim())) return false;\n   335→  if (/^\\(.*\\bcorruption\\b/i.test(text.trim())) return false;\n   336→  // Square-bracket category tags (e.g., \"[CLASSIC FALL SOUPS]\")\n   337→  if (/^\\[.*\\]$/.test(text.trim())) return false;\n   338→  // Known recipe section labels are structural headers, not titles\n   339→  if (isSectionLabel(text)) return false;\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"7a79a908-8d4c-4852-8920-c5c4df3c5fbb","uuid":"f720bff9-0202-446f-8348-b8d562a205d1","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/title-extractor.ts","content":"// Note: only verbs that NEVER start a recipe title. \"Piecz\" (bake) is excluded because\n// \"Pieczeń\" (roast) and \"Pieczarki\" (mushrooms) share the prefix.\nconst POLISH_COOKING_INSTRUCTION_STARTS = /^(podawaj|dodaj|dodawaj|sma[zż]|gotuj|odced[zź]|wymieszaj|mieszaj|wlej|nalej|przygotuj|zagotuj|pokr[oó]j|obierz|wrzuc|wrzuć|usma[zż]|podsma[zż]|prze[lł][oó][zż]|zblenduj|ubij|roztrzepaj|rozprowad[zź]|wyrob|zamieszaj|posyp|polej|odstaw|na[lł][oó][zż]|przykryj|odkryj|wstaw|zdejmij|ods[aą]cz|rozgrzej|posiekaj|zetrzyj|wy[lł][oó][zż]|wyjmij|ukr[oó]j|przekr[oó]j|formuj|ugniataj|rozwałkuj)\\b/i;\n\nfunction looksLikeCookingInstruction(text: string): boolean {\n  const words = text.trim().split(/\\s+/);\n  if (words.length < 4) return false;  // Instructions are multi-word sentences\n  if (COOKING_INSTRUCTION_STARTS.test(text.trim())) return true;\n  if (POLISH_COOKING_INSTRUCTION_STARTS.test(text.trim())) return true;\n  return false;\n}\n\n/**\n * Detect pages where the OCR capture starts mid-recipe with no title present.\n * Returns true if the first 3 non-empty lines are all ingredients or cooking instructions.\n */\nfunction isTitleAbsentPage(lines: string[]): boolean {\n  const nonEmptyLines = lines.map(l => l.trim()).filter(l => l.length > 0);\n\n  if (nonEmptyLines.length < 3) return false;\n\n  const first3 = nonEmptyLines.slice(0, 3);\n\n  return first3.every(line => looksLikeIngredient(line) || looksLikeCookingInstruction(line));\n}\n\nfunction passesHardFilters(text: string): boolean {\n  if (text.length < 3 || text.length > 80) return false;\n  if (looksLikeIngredient(text)) return false;\n  if (startsWithNumber(text)) return false;\n  if (looksLikeMetadata(text)) return false;\n  if (isLikelyGarbled(text)) return false;\n  if (looksLikeCookingInstruction(text)) return false;\n  // Pipe-separated lines are book category/chapter headers, not recipe titles\n  if (text.includes(\" | \")) return false;\n  // Trailing page number (e.g. \"VEGETABLE SIDES                         145\")\n  if (/\\s{3,}\\d{1,4}\\s*$/.test(text)) return false;\n  // Slash-separated breadcrumbs (e.g., \"/ Jesien / Zupy\") are navigation, not titles\n  // Only filter when 2+ slashes are present — single-slash lines like\n  // \"TITLE / SUBTITLE\" are legitimate continuation-merged titles\n  if ((text.match(/\\//g) || []).length >= 2) return false;\n  // Bullet-list items (ingredients or instruction steps) are never titles\n  if (/^\\s*[-•*]\\s/.test(text)) return false;\n  // \"For the sauce:\", \"For the filling:\" etc. are sub-section headers\n  if (/^For the\\s+/i.test(text) && /:\\s*$/.test(text)) return false;\n  // Lines ending with \":\" are recipe sub-section headers, not titles.\n  // Exception: compound titles using \" : \" as a title separator (e.g. \"LEMON CURD : LEMON CURD WITH THYME\").\n  if (/:\\s*$/.test(text.trim()) && !/ : /.test(text)) return false;\n  // Page references are navigation markers, not recipe titles\n  if (/^Page\\s+\\d+/i.test(text.trim())) return false;\n  if (/^Strona\\s+\\d+/i.test(text.trim())) return false;\n  // Corrupted spillover annotations from synthetic multi-page OCR\n  if (/^\\[CORRUPTED\\s+SPILLOVER/i.test(text.trim())) return false;\n  // Parenthetical OCR annotation lines describing corruption artifacts\n  if (/^\\(OCR\\b/i.test(text.trim())) return false;\n  if (/^\\(.*\\bcorruption\\b/i.test(text.trim())) return false;\n  // Square-bracket category tags (e.g., \"[CLASSIC FALL SOUPS]\")\n  if (/^\\[.*\\]$/.test(text.trim())) return false;\n  // Known recipe section labels are structural headers, not titles\n  if (isSectionLabel(text)) return false;","numLines":60,"startLine":280,"totalLines":1316}}}
