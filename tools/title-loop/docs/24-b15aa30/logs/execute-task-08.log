{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JDjAnXhqBP2C9XeMZxgvJn","type":"tool_result","content":"<persisted-output>\nOutput too large (74.7KB). Full output saved to: /Users/eryk.napierala/.claude/projects/-Users-eryk-napierala-Projects-fasola/da66d640-08e5-4551-9d04-aa2649fd8c8b/tool-results/toolu_01JDjAnXhqBP2C9XeMZxgvJn.txt\n\nPreview (first 2KB):\n     1→     1→/**\n     2→     2→ * Title Extraction\n     3→     3→ * Extracts potential recipe title from OCR text using heuristics or semantic embeddings\n     4→     4→ */\n     5→     5→\n     6→     6→import { cosineSimilarity } from \"./embeddings\";\n     7→     7→import { FOOD_DICTIONARY } from \"./food-dictionary\";\n     8→     8→\n     9→     9→export type EmbedFn = (text: string) => Promise<Array<number>>;\n    10→    10→\n    11→    11→const TITLE_REFERENCE =\n    12→    12→  \"recipe name, dish title, name of the food, nazwa przepisu, nazwa dania\";\n    13→    13→const HEADER_REFERENCE =\n    14→    14→  \"ingredients list, cooking directions, section heading, składniki, przygotowanie, sposób wykonania\";\n    15→    15→const NOISE_REFERENCE =\n    16→    16→  \"page number, table of contents, book footer, garbled text\";\n    17→    17→\n    18→    18→/**\n    19→    19→ * Measurement units commonly found in ingredient lists\n    20→    20→ */\n    21→    21→const MEASUREMENT_PATTERNS = [\n    22→    22→  // English\n    23→    23→  \"cup\",\n    24→    24→  \"cups\",\n    25→    25→  \"tbsp\",\n    26→    26→  \"tsp\",\n    27→    27→  \"tablespoon\",\n    28→    28→  \"teaspoon\",\n    29→    29→  // \"oz\" and \"lb\" are matched with word boundaries in looksLikeIngredient\n    30→    30→  // to avoid false positives (\"oz\" in \"mozzarella\", \"lb\" in \"albacore\")\n    31→    31→  \"gram\",\n    32→    32→  \"grams\",\n    33→    33→  \"kg\",\n    34→    34→  \"ml\",\n    35→    35→  \"liter\",\n    36→    36→  \"pinch\",\n    37→    37→  \"dash\",\n    38→    38→  \"handful\",\n    39→    39→  // Polish\n    40→    40→  \"łyżka\", \"łyżki\", \"łyżek\",           // tablespoon(s)\n    41→    41→  \"łyżeczka\", \"łyżeczki\", \"łyżeczek\",   // teaspoon(s)\n    42→    42→  \"szklanka\", \"szklanki\", \"szklanek\",    // cup(s)\n    43→    43→  \"szczypta\",                            // pinch\n    44→    44→  \"garść\",                               // handful\n    45→    45→  \"opakowanie\", \"opakowania\",            // package(s)\n...\n</persisted-output>"}]},"parent_tool_use_id":null,"session_id":"da66d640-08e5-4551-9d04-aa2649fd8c8b","uuid":"0bb56b98-4409-4d07-9a77-c2e8cd8160fb","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/.claude/projects/-Users-eryk-napierala-Projects-fasola/da66d640-08e5-4551-9d04-aa2649fd8c8b/tool-results/toolu_01AfrgKNX2r199p7mWzf1Fqs.txt","content":"     1→/**\n     2→ * Title Extraction\n     3→ * Extracts potential recipe title from OCR text using heuristics or semantic embeddings\n     4→ */\n     5→\n     6→import { cosineSimilarity } from \"./embeddings\";\n     7→import { FOOD_DICTIONARY } from \"./food-dictionary\";\n     8→\n     9→export type EmbedFn = (text: string) => Promise<Array<number>>;\n    10→\n    11→const TITLE_REFERENCE =\n    12→  \"recipe name, dish title, name of the food, nazwa przepisu, nazwa dania\";\n    13→const HEADER_REFERENCE =\n    14→  \"ingredients list, cooking directions, section heading, składniki, przygotowanie, sposób wykonania\";\n    15→const NOISE_REFERENCE =\n    16→  \"page number, table of contents, book footer, garbled text\";\n    17→\n    18→/**\n    19→ * Measurement units commonly found in ingredient lists\n    20→ */\n    21→const MEASUREMENT_PATTERNS = [\n    22→  // English\n    23→  \"cup\",\n    24→  \"cups\",\n    25→  \"tbsp\",\n    26→  \"tsp\",\n    27→  \"tablespoon\",\n    28→  \"teaspoon\",\n    29→  // \"oz\" and \"lb\" are matched with word boundaries in looksLikeIngredient\n    30→  // to avoid false positives (\"oz\" in \"mozzarella\", \"lb\" in \"albacore\")\n    31→  \"gram\",\n    32→  \"grams\",\n    33→  \"kg\",\n    34→  \"ml\",\n    35→  \"liter\",\n    36→  \"pinch\",\n    37→  \"dash\",\n    38→  \"handful\",\n    39→  // Polish\n    40→  \"łyżka\", \"łyżki\", \"łyżek\",           // tablespoon(s)\n    41→  \"łyżeczka\", \"łyżeczki\", \"łyżeczek\",   // teaspoon(s)\n    42→  \"szklanka\", \"szklanki\", \"szklanek\",    // cup(s)\n    43→  \"szczypta\",                            // pinch\n    44→  \"garść\",                               // handful\n    45→  \"opakowanie\", \"opakowania\",            // package(s)\n    46→  \"plasterek\", \"plasterki\",             // slice(s)\n    47→];\n    48→\n    49→/**\n    50→ * Patterns that identify recipe metadata lines (not titles)\n    51→ */\n    52→const METADATA_PATTERNS = [\n    53→  /^(SERVES?|MAKES?|YIELDS?)\\b/i,\n    54→  /^(PREP(ARATION)?|COOK(ING)?|PROOF|RISING|FERMENTATION|REST(ING)?)\\s*(AND\\s*)?(COOK(ING)?)?\\s*TIME/i,\n    55→  /^SAMPLE\\s+SCHEDULE\\b/i,\n    56→  /^BULK\\s+FERMENTATION\\b/i,\n    57→  /^(THIS\\s+RECIPE\\s+)?MAKES\\b/i,\n    58→  // Polish serving-size patterns: \"NA 3 PAPRYKI\", \"NA OKOŁO 1 KG\", \"DLA 4 OSÓB\"\n    59→  /^NA\\s+(\\d|OKOŁO)\\b/i,\n    60→  /^DLA\\s+\\d/i,\n    61→  // OCR-resilient: \"DLA\" + any token + serving-unit word (handles DLA & OSOB, DLA § OSOB, etc.)\n    62→  /^DLA\\s+\\S+\\s+OSOB/i,\n    63→  // OCR-resilient: \"DLA\" + single non-alphanumeric char (common digit→symbol OCR error)\n    64→  /^DLA\\s+[^a-zA-Z0-9\\s]\\s/i,\n    65→  // Time-unit metadata: any line containing \"N MIN\" or \"N GODZ\" is prep/cook/rest time,\n    66→  // regardless of OCR-corrupted prefix (catches PRZYGOTOWANTE, GOTOMANTE, etc.)\n    67→  /\\b\\d+\\s*MIN\\b/i,\n    68→  /\\b\\d+\\s*GODZ/i,\n    69→  // Season/category indicators\n    70→  /^SEZON\\s*:/i,\n    71→  /^KATEGORIA\\s*:/i,\n    72→  /^RODZAJ\\s*:/i,\n    73→  /^PORCJI\\s*:/i,       // Polish serving count\n    74→  /^PORTIONS?\\s*:/i,    // English serving count\n    75→  /^CZ[ĘE]Ś[ĆC]\\s*\\d/i,   // CZĘŚĆ 1: ... (Polish \"Part 1:\")\n    76→  /^PART\\s+\\d/i,             // PART 1: ... (English)\n    77→  /^MAIN\\s+RECIPE\\s*:/i,    // \"MAIN RECIPE: ...\" structural prefix lines\n    78→  /^--\\s*\\w/,               // \"--VARIATION:\", \"--WERSJA NOWOCZESNA\" sub-section headers\n    79→];\n    80→\n    81→/**\n    82→ * Single-word non-title words — standalone OCR fragments unlikely to be recipe titles\n    83→ */\n    84→const NON_TITLE_WORDS = new Set([\n    85→  \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"are\", \"was\",\n    86→  \"has\", \"his\", \"her\", \"its\", \"our\", \"who\", \"how\", \"may\", \"new\", \"now\",\n    87→  \"old\", \"see\", \"way\", \"did\", \"get\", \"let\", \"say\", \"she\", \"too\", \"use\",\n    88→  \"buns\", \"with\",\n    89→]);\n    90→\n    91→function looksLikeIngredient(line: string): boolean {\n    92→  const lowerLine = line.toLowerCase();\n    93→  if (MEASUREMENT_PATTERNS.some((pattern) => lowerLine.includes(pattern))) return true;\n    94→  // Compact metric: \"100g\", \"50ml\", \"250g\" — digit immediately followed by g/ml/kg\n    95→  if (/\\b\\d+\\s*(?:g|ml|kg)\\b/i.test(line)) return true;\n    96→  // \"to taste\" / \"do smaku\" — qualitative ingredient with no unit\n    97→  if (/\\bto taste\\b/i.test(line) || /\\bdo smaku\\b/i.test(line)) return true;\n    98→  return false;\n    99→}\n   100→\n   101→function startsWithNumber(line: string): boolean {\n   102→  // Match lines starting with a digit, or bullet-then-digit (e.g., \"- 2 jajka\")\n   103→  return /^\\s*(?:[-•*]\\s*)?\\d/.test(line);\n   104→}\n   105→\n   106→function stripDiacritics(text: string): string {\n   107→  return text.normalize(\"NFKD\").replace(/[\\u0300-\\u036f]/g, \"\");\n   108→}\n   109→\n   110→/**\n   111→ * Known recipe section labels — these are structural headers, not recipe titles.\n   112→ * Matched case-insensitively after trimming, stripping trailing punctuation, and stripping diacritics.\n   113→ * Polish entries are stored without diacritics for OCR resilience (e.g. \"SKLADNIKI\" matches \"składniki\").\n   114→ */\n   115→const SECTION_LABELS = new Set([\n   116→  // English\n   117→  \"ingredients\", \"directions\", \"instructions\", \"method\", \"preparation\",\n   118→  \"steps\", \"notes\", \"tip\", \"tips\", \"variations\", \"variation\",\n   119→  \"garnish\", \"topping\", \"toppings\", \"frosting\", \"filling\",\n   120→  \"serving suggestion\", \"serving suggestions\", \"serving\",\n   121→  \"glaze\", \"for the sauce\", \"for the filling\", \"for the dough\",\n   122→  \"for the topping\", \"for the glaze\", \"for the pasta dough\",\n   123→  \"for the pasta\", \"for the crust\",\n   124→  // Polish — recipe section labels (stored without diacritics for OCR resilience)\n   125→  \"skladniki\", \"przygotowanie\", \"sposob przygotowania\", \"sposob wykonania\",\n   126→  \"wykonanie\", \"wskazowki\", \"podpowiedz\", \"warianty\",\n   127→  \"sos\", \"nadzienie\", \"polewa\", \"lukier\", \"ciasto\",  // ciasto = dough/pastry base (recipe-internal section AND chapter label)\n   128→  \"instrukcje\",       // instructions\n   129→  \"uwagi\",            // notes/remarks\n   130→  \"notatki\",          // notes\n   131→  \"podawanie\",        // serving\n   132→  \"przechowywanie\",   // storage\n   133→  // Polish — recipe-book chapter/category labels (food groups, meal types)\n   134→  \"warzywa\",          // vegetables\n   135→  \"mieso\",            // meat (mięso)\n   136→  \"miesa\",            // meats (mięsa)\n   137→  \"ryby\",             // fish\n   138→  \"owoce morza\",      // seafood\n   139→  \"zupy\",             // soups\n   140→  \"salatki\",          // salads (sałatki)\n   141→  \"desery\",           // desserts\n   142→  \"napoje\",           // drinks\n   143→  \"pieczywo\",         // bread/baked goods\n   144→  \"przekaski\",        // appetizers/snacks\n   145→  \"sniadania\",        // breakfasts (śniadania)\n   146→  \"obiady\",           // dinners/lunches\n   147→  \"kolacje\",          // suppers\n   148→  \"makarony\",         // pasta dishes\n   149→  \"kasza\",            // groats/grains\n   150→  \"kasze\",            // groats/grains (plural)\n   151→  \"dania glowne\",     // main courses (dania główne)\n   152→  \"przystawki\",       // starters\n   153→  \"dodatki\",          // side dishes\n   154→  \"przetwory\",        // preserves\n   155→  \"wypieki\",          // baked goods\n   156→  \"ciasta\",           // cakes (plural)\n   157→  \"ciastka\",          // cookies\n   158→  \"torty\",            // layer cakes\n   159→  // \"placki\" removed — it commonly starts recipe titles like \"Placki Ziemniaczane\", \"Placki Żółte z Kukurydzą\"\n   160→  \"koktajle\",         // cocktails/smoothies\n   161→  // English — recipe-book chapter/category labels\n   162→  \"vegetables\", \"seafood\", \"fish\", \"soups\", \"salads\", \"desserts\",\n   163→  \"appetizers\", \"breads\", \"breakfast\", \"pasta\", \"grains\",\n   164→  \"main courses\", \"side dishes\", \"preserves\", \"baked goods\",\n   165→  \"fish & seafood\", \"soups & broths\", \"desserts & baked goods\",\n   166→  \"meats\", \"poultry\", \"game\",\n   167→]);\n   168→\n   169→function isSectionLabel(text: string): boolean {\n   170→  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n   171→  if (SECTION_LABELS.has(normalized)) return true;\n   172→  // OCR variant: leading \"l\" may be OCR-corrupted \"I\" (e.g. \"lngredients\" → \"ingredients\")\n   173→  const ocrNormalized = normalized.replace(/^l/, \"i\");\n   174→  if (ocrNormalized !== normalized && SECTION_LABELS.has(ocrNormalized)) return true;\n   175→  return false;\n   176→}\n   177→\n   178→/**\n   179→ * Recipe-internal section labels that should ALWAYS block multi-line joins,\n   180→ * even when the combined word count is ≥ 3.\n   181→ * Category labels (\"zupy\", \"placki\", etc.) are NOT in this set — they can\n   182→ * legitimately start a multi-word recipe title like \"Zupy Zimowe Warzywne\".\n   183→ */\n   184→const ALWAYS_BLOCK_JOIN_LABELS = new Set([\n   185→  \"ingredients\", \"directions\", \"instructions\", \"method\", \"preparation\",\n   186→  \"steps\", \"notes\", \"tip\", \"tips\", \"variations\", \"variation\",\n   187→  \"garnish\", \"topping\", \"toppings\", \"frosting\", \"filling\",\n   188→  \"serving suggestion\", \"serving suggestions\", \"serving\",\n   189→  \"glaze\", \"instrukcje\", \"uwagi\", \"notatki\", \"podawanie\", \"przechowywanie\",\n   190→  \"skladniki\", \"przygotowanie\", \"sposob przygotowania\", \"sposob wykonania\",\n   191→  \"wykonanie\", \"wskazowki\", \"podpowiedz\", \"warianty\",\n   192→  \"sos\", \"nadzienie\", \"polewa\", \"lukier\", \"ciasto\",\n   193→]);\n   194→\n   195→function isAlwaysBlockJoinLabel(text: string): boolean {\n   196→  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n   197→  return ALWAYS_BLOCK_JOIN_LABELS.has(normalized);\n   198→}\n   199→\n   200→function isAllCaps(line: string): boolean {\n   201→  const letters = line.replace(/[^a-zA-Z]/g, \"\");\n   202→  return letters.length > 0 && letters === letters.toUpperCase();\n   203→}\n   204→\n   205→function looksLikeMetadata(text: string): boolean {\n   206→  return METADATA_PATTERNS.some((pattern) => pattern.test(text.trim()));\n   207→}\n   208→\n   209→function isLikelyGarbled(text: string): boolean {\n   210→  const letters = text.replace(/[^a-zA-Z]/g, \"\");\n   211→  if (letters.length < 2) return true;\n   212→\n   213→  // Pipe embedded in words = OCR artifact (e.g., \"Sp|aszcz\", \"pa|ką\")\n   214→  if (/[a-zA-ZÀ-ÿа-яА-Я]\\|[a-zA-ZÀ-ÿа-яА-Я]/.test(text)) return true;\n   215→\n   216→  // Mixed Latin + Cyrillic = OCR corruption\n   217→  if (/[а-яА-ЯёЁіІїЇєЄґҐ]/.test(text) && /[a-zA-Z]/.test(text)) return true;\n   218→\n   219→  // Check vowel ratio — English/Polish text typically has 30–50% vowels\n   220→  const vowels = letters.replace(/[^aeiouAEIOUyYąęóĄĘÓ]/g, \"\").length;\n   221→  const vowelRatio = vowels / letters.length;\n   222→  if (vowelRatio < 0.10 || vowelRatio > 0.85) return true;\n   223→\n   224→  // Single orphaned word ≤3 letters that isn't a common word\n   225→  const words = text.trim().split(/\\s+/);\n   226→  const COMMON_SHORT = new Set([\n   227→    \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"had\", \"her\",\n   228→    \"was\", \"one\", \"our\", \"out\", \"are\", \"has\", \"his\", \"how\", \"its\", \"may\",\n   229→    \"new\", \"now\", \"old\", \"see\", \"way\", \"who\", \"did\", \"get\", \"let\", \"say\",\n   230→    \"she\", \"too\", \"use\",\n   231→  ]);\n   232→  // Count all Unicode letters (not just ASCII) so Polish words like \"Żur\" (3 letters) pass\n   233→  const unicodeLetters = text.trim().replace(/[^a-zA-ZąćęłńóśźżĄĆĘŁŃÓŚŹŻ]/g, \"\");\n   234→  if (words.length === 1 && unicodeLetters.length <= 3 && !COMMON_SHORT.has(text.trim().toLowerCase())) {\n   235→    return true;\n   236→  }\n   237→\n   238→  // Single word with internal lowercase→uppercase transition — OCR noise (e.g., \"UuIw\", \"aBC\")\n   239→  // No recipe title uses this pattern as a standalone single-word candidate.\n   240→  if (words.length === 1 && /[a-z][A-Z]/.test(text.trim())) {\n   241→    return true;\n   242→  }\n   243→\n   244→  // Recipe titles never start with a lowercase letter\n   245→  if (/^[a-z]/.test(text.trim())) {\n   246→    return true;\n   247→  }\n   248→\n   249→  // Mid-text sentence boundary (\". \" followed by a letter) — body text fragment spliced from multiple sentences\n   250→  const trimmed = text.trim();\n   251→  if (/\\.\\s+[a-zA-Z]/.test(trimmed) && !trimmed.endsWith(\")\")) {\n   252→    return true;\n   253→  }\n   254→\n   255→  // Multi-word candidate containing a garbled OCR fragment: a short lowercase word that isn't a known short word\n   256→  if (words.length >= 2) {\n   257→    const commonShort2 = new Set([\n   258→      \"a\", \"i\", \"of\", \"or\", \"to\", \"in\", \"on\", \"is\", \"it\", \"an\",\n   259→      \"as\", \"at\", \"by\", \"do\", \"go\", \"if\", \"no\", \"so\", \"up\", \"we\",\n   260→      \"w\", \"z\",   // Polish prepositions (basic)\n   261→      \"ze\", \"bo\", \"na\", \"ni\", \"po\", \"ku\", \"od\", \"za\", \"co\",  // Polish prepositions (extended)\n   262→    ]);\n   263→    const hasGarbledWord = words.some(\n   264→      (w) =>\n   265→        /^[a-z]/.test(w) &&\n   266→        w.replace(/[^a-z]/g, \"\").length <= 2 &&\n   267→        !commonShort2.has(w.toLowerCase())\n   268→    );\n   269→    if (hasGarbledWord) {\n   270→      return true;\n   271→    }\n   272→  }\n   273→\n   274→  return false;\n   275→}\n   276→\n   277→const COOKING_INSTRUCTION_STARTS = /^(beat|fold|stir|mix|add|pour|bake|cook|cool|remove|place|combine|whisk|knead|roll|spread|brush|slice|chop|dice|mince|drain|rinse|peel|grate|melt|simmer|boil|fry|sauté|saute|roast|grill|broil|steam|let|set|transfer|serve|garnish|arrange|sprinkle|season|preheat|cover|uncover|reduce|bring|toss|cut|trim|shape|form)\\b/i;\n   278→\n   279→// Polish imperative cooking verbs (with OCR-resilient forms — no diacritics required).\n   280→// These cover the most common recipe instruction starters. Includes common OCR-corrupted\n   281→// forms (e.g., \"Smaż\" → \"Smaz\", \"Dodaj\" → \"Dodaj\").\n   282→// Note: only verbs that NEVER start a recipe title. \"Piecz\" (bake) is excluded because\n   283→// \"Pieczeń\" (roast) and \"Pieczarki\" (mushrooms) share the prefix.\n   284→const POLISH_COOKING_INSTRUCTION_STARTS = /^(podawaj|dodaj|dodawaj|sma[zż]|gotuj|odced[zź]|wymieszaj|mieszaj|wlej|nalej|przygotuj|zagotuj|pokr[oó]j|obierz|wrzuc|wrzuć|usma[zż]|podsma[zż]|prze[lł][oó][zż]|zblenduj|ubij|roztrzepaj|rozprowad[zź]|wyrob|zamieszaj|posyp|polej|odstaw|na[lł][oó][zż]|przykryj|odkryj|wstaw|zdejmij|ods[aą]cz|rozgrzej|posiekaj|zetrzyj|wy[lł][oó][zż]|wyjmij|ukr[oó]j|przekr[oó]j|formuj|ugniataj|rozwałkuj)\\b/i;\n   285→\n   286→function looksLikeCookingInstruction(text: string): boolean {\n   287→  const words = text.trim().split(/\\s+/);\n   288→  if (words.length < 4) return false;  // Instructions are multi-word sentences\n   289→  if (COOKING_INSTRUCTION_STARTS.test(text.trim())) return true;\n   290→  if (POLISH_COOKING_INSTRUCTION_STARTS.test(text.trim())) return true;\n   291→  return false;\n   292→}\n   293→\n   294→/**\n   295→ * Detect pages where the OCR capture starts mid-recipe with no title present.\n   296→ * Returns true if the first 3 non-empty lines are all ingredients or cooking instructions.\n   297→ */\n   298→function isTitleAbsentPage(lines: string[]): boolean {\n   299→  const nonEmptyLines = lines.map(l => l.trim()).filter(l => l.length > 0);\n   300→\n   301→  if (nonEmptyLines.length < 3) return false;\n   302→\n   303→  const first3 = nonEmptyLines.slice(0, 3);\n   304→\n   305→  return first3.every(line => looksLikeIngredient(line) || looksLikeCookingInstruction(line));\n   306→}\n   307→\n   308→function passesHardFilters(text: string): boolean {\n   309→  if (text.length < 3 || text.length > 80) return false;\n   310→  if (looksLikeIngredient(text)) return false;\n   311→  if (startsWithNumber(text)) return false;\n   312→  if (looksLikeMetadata(text)) return false;\n   313→  if (isLikelyGarbled(text)) return false;\n   314→  if (looksLikeCookingInstruction(text)) return false;\n   315→  // Pipe-separated lines are book category/chapter headers, not recipe titles\n   316→  if (text.includes(\" | \")) return false;\n   317→  // Trailing page number (e.g. \"VEGETABLE SIDES                         145\")\n   318→  if (/\\s{3,}\\d{1,4}\\s*$/.test(text)) return false;\n   319→  // Slash-separated breadcrumbs (e.g., \"/ Jesien / Zupy\") are navigation, not titles\n   320→  // Only filter when 2+ slashes are present — single-slash lines like\n   321→  // \"TITLE / SUBTITLE\" are legitimate continuation-merged titles\n   322→  if ((text.match(/\\//g) || []).length >= 2) return false;\n   323→  // Bullet-list items (ingredients or instruction steps) are never titles\n   324→  if (/^\\s*[-•*]\\s/.test(text)) return false;\n   325→  // Lines starting with \"--\" are sub-section headers (e.g., \"--VARIATION:\", \"--WERSJA NOWOCZESNA\")\n   326→  if (/^--\\s*\\w/.test(text)) return false;\n   327→  // \"For the sauce:\", \"For the filling:\" etc. are sub-section headers\n   328→  if (/^For the\\s+/i.test(text) && /:\\s*$/.test(text)) return false;\n   329→  // Lines ending with \":\" are recipe sub-section headers, not titles.\n   330→  // Exception: compound titles using \" : \" as a title separator (e.g. \"LEMON CURD : LEMON CURD WITH THYME\").\n   331→  if (/:\\s*$/.test(text.trim()) && !/ : /.test(text)) return false;\n   332→  // Page references are navigation markers, not recipe titles\n   333→  if (/^Page\\s+\\d+/i.test(text.trim())) return false;\n   334→  if (/^Strona\\s+\\d+/i.test(text.trim())) return false;\n   335→  // Corrupted spillover annotations from synthetic multi-page OCR\n   336→  if (/^\\[CORRUPTED\\s+SPILLOVER/i.test(text.trim())) return false;\n   337→  // Parenthetical OCR annotation lines describing corruption artifacts\n   338→  if (/^\\(OCR\\b/i.test(text.trim())) return false;\n   339→  if (/^\\(.*\\bcorruption\\b/i.test(text.trim())) return false;\n   340→  // Square-bracket category tags (e.g., \"[CLASSIC FALL SOUPS]\")\n   341→  if (/^\\[.*\\]$/.test(text.trim())) return false;\n   342→  // Known recipe section labels are structural headers, not titles\n   343→  if (isSectionLabel(text)) return false;\n   344→  // Single-word non-title fragments\n   345→  const words = text.trim().split(/\\s+/);\n   346→  if (words.length === 1 && NON_TITLE_WORDS.has(text.trim().toLowerCase())) return false;\n   347→  // Lines with ≥8 words are almost certainly body text, not titles.\n   348→  // Exception: multi-title compounds with \" + \", \" : \", or \" & \" separators are allowed.\n   349→  if (words.length >= 8 && !/ [+:&/] /.test(text)) return false;\n   350→  return true;\n   351→}\n   352→\n   353→/**\n   354→ * Detect initial burst of short garbled lines.\n   355→ * Returns the index of the first non-garbled or long line.\n   356→ */\n   357→function findBurstEnd(lines: Array<{ text: string }>): number {\n   358→  let i = 0;\n   359→\n   360→  // Skip overflow preambles: blocks introduced by \"PREVIOUS RECIPE OVERFLOW\",\n   361→  // \"PREVIOUS PAGE CONTENT\", \"CORRUPTED SECTION\", etc. that precede the actual recipe.\n   362→  const OVERFLOW_MARKERS = /\\b(PREVIOUS\\s+(RECIPE|PAGE)\\s+(OVERFLOW|CONTENT)|SPILLOVER|CONTINUATION|CORRUPTED\\s+SECTION)\\b/i;\n   363→  let overflowEnd = 0;\n   364→  for (let k = 0; k < lines.length && k < 30; k++) {\n   365→    if (OVERFLOW_MARKERS.test(lines[k].text)) {\n   366→      // Skip forward past the overflow block to the next visual separator or blank cluster\n   367→      let m = k + 1;\n   368→      while (m < lines.length) {\n   369→        if (/^[=\\-]{4,}$/.test(lines[m].text) || lines[m].text.length === 0) {\n   370→          overflowEnd = m + 1;\n   371→          break;\n   372→        }\n   373→        m++;\n   374→      }\n   375→      if (overflowEnd === 0) overflowEnd = k + 1;\n   376→    }\n   377→  }\n   378→  if (overflowEnd > 0) i = overflowEnd;\n   379→\n   380→  while (i < lines.length && lines[i].text.length < 20 && isLikelyGarbled(lines[i].text) && !isAllCaps(lines[i].text)) {\n   381→    i++;\n   382→  }\n   383→  // Skip long instruction-like prologues: if 5+ consecutive lines look like cooking instructions,\n   384→  // skip them to find the actual title region.\n   385→  if (i === 0) {\n   386→    let j = 0;\n   387→    while (j < lines.length && looksLikeCookingInstruction(lines[j].text)) {\n   388→      j++;\n   389→    }\n   390→    if (j >= 5) {\n   391→      i = j;\n   392→    }\n   393→  }\n   394→  // Skip prose prologues: mid-recipe body text before the actual title.\n   395→  // If 3+ consecutive lines look like running body text (lowercase start, continuation,\n   396→  // or sentence-ending with many words), skip them.\n   397→  if (i === 0) {\n   398→    let j = 0;\n   399→    while (j < lines.length) {\n   400→      const t = lines[j].text;\n   401→      const isBodyText = (\n   402→        /^[a-ząćęłńóśźż]/.test(t) ||\n   403→        t.endsWith(\",\") ||\n   404→        (t.endsWith(\".\") && wordCount(t) > 4)\n   405→      ) && wordCount(t) >= 4;\n   406→      if (isBodyText) j++;\n   407→      else break;\n   408→    }\n   409→    if (j >= 3) i = j;\n   410→  }\n   411→  return i;\n   412→}\n   413→\n   414→function stripParentheticalGloss(text: string): string {\n   415→  // Strip trailing English-gloss parentheticals from ALL_CAPS titles.\n   416→  // e.g. \"PIEROGI RUSKIE (Boiled Dumplings with Potato and Cheese)\" → \"PIEROGI RUSKIE\"\n   417→  // Keep if parenthetical is ALL_CAPS (variation/subtitle in same language).\n   418→  // Keep if both base and paren are mixed-case (both are part of the title).\n   419→  const match = text.match(/^(.+?)\\s*\\(([^)]+)\\)\\s*$/);\n   420→  if (!match) return text;\n   421→  const [, base, paren] = match;\n   422→  if (isAllCaps(paren)) return text;\n   423→  if (!isAllCaps(base) && !isAllCaps(paren)) return text;\n   424→  return base.trim();\n   425→}\n   426→\n   427→function stripPageNumber(text: string): string {\n   428→  // \"34  Berry Jam\" → \"Berry Jam\" (2+ spaces distinguishes from \"2 eggs\")\n   429→  const match = text.match(/^\\d{1,3}\\s{2,}(.+)$/);\n   430→  return match ? match[1] : text;\n   431→}\n   432→\n   433→function wordCount(text: string): number {\n   434→  return text.split(/\\s+/).filter((w) => w.length > 0).length;\n   435→}\n   436→\n   437→/**\n   438→ * Build candidate strings from lines: single lines plus multi-line joins (2-3 consecutive).\n   439→ * Skips initial burst of short garbled lines. Scans all remaining lines. Caps at 25.\n   440→ */\n   441→export type CandidateOrigin = \"single\" | \"2-line\" | \"3-line\";\n   442→\n   443→function buildCandidates(\n   444→  lines: Array<string>\n   445→): Array<{ text: string; position: number; origin: CandidateOrigin }> {\n   446→  const nonEmptyLines: Array<{ text: string; index: number }> = [];\n   447→\n   448→  for (let i = 0; i < lines.length; i++) {\n   449→    const trimmed = lines[i].trim();\n   450→    if (trimmed.length > 0) {\n   451→      nonEmptyLines.push({ text: trimmed, index: i });\n   452→    }\n   453→  }\n   454→\n   455→  const burstEnd = findBurstEnd(nonEmptyLines);\n   456→\n   457→  // Pre-join hyphen-broken lines: \"ROASTED CHICKEN WITH ROOT VEGET-\" + \"ABLES\" → single line.\n   458→  // Only applies within the candidate region (after burst end).\n   459→  for (let hi = burstEnd; hi < nonEmptyLines.length - 1; hi++) {\n   460→    if (nonEmptyLines[hi].text.endsWith(\"-\")) {\n   461→      const joined = nonEmptyLines[hi].text.slice(0, -1) + nonEmptyLines[hi + 1].text;\n   462→      nonEmptyLines[hi] = { text: joined, index: nonEmptyLines[hi].index };\n   463→      nonEmptyLines.splice(hi + 1, 1);\n   464→    }\n   465→  }\n   466→\n   467→  // Pre-merge consecutive short ALL_CAPS lines (OCR-fragmented headings).\n   468→  // When a sequence of 2+ ALL_CAPS lines each has ≤2 words and ≤25 chars, they are\n   469→  // almost certainly OCR fragments of a single heading. Merge them into one line so\n   470→  // the complete title enters the candidate pool without hitting the 3-line join ceiling.\n   471→  const capsCoalesced: Array<{ text: string; index: number }> = [];\n   472→  let ci = burstEnd;\n   473→  while (ci < nonEmptyLines.length) {\n   474→    const line = nonEmptyLines[ci];\n   475→    if (\n   476→      isAllCaps(line.text) &&\n   477→      wordCount(line.text) <= 2 &&\n   478→      line.text.length <= 25 &&\n   479→      !isSectionLabel(line.text) &&\n   480→      !looksLikeMetadata(line.text)\n   481→    ) {\n   482→      let merged = line.text;\n   483→      const startIndex = line.index;\n   484→      let j = ci + 1;\n   485→      while (j < nonEmptyLines.length) {\n   486→        const next = nonEmptyLines[j];\n   487→        if (\n   488→          isAllCaps(next.text) &&\n   489→          wordCount(next.text) <= 2 &&\n   490→          next.text.length <= 25 &&\n   491→          !isSectionLabel(next.text) &&\n   492→          !looksLikeMetadata(next.text) &&\n   493→          (merged + \" \" + next.text).length <= 80\n   494→        ) {\n   495→          merged += \" \" + next.text;\n   496→          j++;\n   497→        } else {\n   498→          break;\n   499→        }\n   500→      }\n   501→      if (j > ci + 1) {\n   502→        capsCoalesced.push({ text: merged, index: startIndex });\n   503→        ci = j;\n   504→        continue;\n   505→      }\n   506→    }\n   507→    capsCoalesced.push(line);\n   508→    ci++;\n   509→  }\n   510→\n   511→  // Pre-merge continuation lines: a line starting with /&+:( is never a standalone title.\n   512→  // Merge it into the preceding line so the complete title enters the pool as a single candidate,\n   513→  // avoiding the fragile chain of conditions required by the downstream join survival logic.\n   514→  // Limitation: only one continuation line per preceding line is merged. Titles split across\n   515→  // three or more lines with continuation tokens (rare in practice) are not handled here —\n   516→  // the downstream 2-line and 3-line join candidates cover those cases instead.\n   517→  const mergedLines: Array<{ text: string; index: number }> = [];\n   518→  for (let i = 0; i < capsCoalesced.length; i++) {\n   519→    const line = capsCoalesced[i];\n   520→    if (i + 1 < capsCoalesced.length) {\n   521→      const nextText = capsCoalesced[i + 1].text;\n   522→      if (/^[/&+:(]/.test(nextText)) {\n   523→        mergedLines.push({ text: `${line.text} ${nextText}`, index: line.index });\n   524→        i++;\n   525→        continue;\n   526→      }\n   527→    }\n   528→    mergedLines.push(line);\n   529→  }\n   530→\n   531→  const candidates: Array<{ text: string; position: number; origin: CandidateOrigin }> = [];\n   532→  const seen = new Set<string>();\n   533→\n   534→  // Build a set of positions to skip: short ALL_CAPS lines immediately following metadata\n   535→  const metadataContinuationPositions = new Set<number>();\n   536→  for (let i = 0; i < mergedLines.length - 1; i++) {\n   537→    if (looksLikeMetadata(mergedLines[i].text)) {\n   538→      const next = mergedLines[i + 1];\n   539→      if (isAllCaps(next.text) && wordCount(next.text) <= 2 && next.text.length <= 15) {\n   540→        metadataContinuationPositions.add(next.index);\n   541→      }\n   542→    }\n   543→  }\n   544→\n   545→  for (let i = 0; i < mergedLines.length; i++) {\n   546→    const line = mergedLines[i];\n   547→\n   548→    // Skip metadata continuation fragments\n   549→    if (metadataContinuationPositions.has(line.index)) continue;\n   550→\n   551→    // Single line — strip page-number prefixes and parenthetical glosses before scoring\n   552→    const singleText = repairOcrText(stripParentheticalGloss(stripPageNumber(line.text)));\n   553→    if (passesHardFilters(singleText)) {\n   554→      const norm = singleText.toLowerCase();\n   555→      if (!seen.has(norm)) {\n   556→        seen.add(norm);\n   557→        candidates.push({ text: singleText, position: line.index, origin: \"single\" });\n   558→      }\n   559→    }\n   560→\n   561→    // 2-line join — skip if first line is a section label AND join would be ≤2 words\n   562→    // (a section label followed by modifiers is likely a recipe title, not a category header)\n   563→    if (i + 1 < mergedLines.length) {\n   564→      const joined2 = repairOcrText(`${line.text} ${mergedLines[i + 1].text}`);\n   565→      const shouldBlock2 = isSectionLabel(line.text) &&\n   566→        (wordCount(joined2) <= 2 || isAlwaysBlockJoinLabel(line.text));\n   567→      if (!shouldBlock2 && passesHardFilters(joined2)) {\n   568→        const norm = joined2.toLowerCase();\n   569→        if (!seen.has(norm)) {\n   570→          seen.add(norm);\n   571→          candidates.push({ text: joined2, position: line.index, origin: \"2-line\" });\n   572→        }\n   573→      }\n   574→    }\n   575→\n   576→    // 3-line join — skip if first line is a section label AND join would be ≤2 words\n   577→    if (i + 2 < mergedLines.length) {\n   578→      const joined3 = repairOcrText(`${line.text} ${mergedLines[i + 1].text} ${mergedLines[i + 2].text}`);\n   579→      const shouldBlock3 = isSectionLabel(line.text) &&\n   580→        (wordCount(joined3) <= 2 || isAlwaysBlockJoinLabel(line.text));\n   581→      if (!shouldBlock3 && passesHardFilters(joined3)) {\n   582→        const norm = joined3.toLowerCase();\n   583→        if (!seen.has(norm)) {\n   584→          seen.add(norm);\n   585→          candidates.push({ text: joined3, position: line.index, origin: \"3-line\" });\n   586→        }\n   587→      }\n   588→    }\n   589→  }\n   590→\n   591→  // Pre-filter to 25 before embedding calls: prefer ALL_CAPS and short candidates.\n   592→  // Position-based scoring handles final ranking.\n   593→  if (candidates.length > 25) {\n   594→    const prioritized = candidates.slice().sort((a, b) => {\n   595→      const aAllCaps = isAllCaps(a.text) ? 0 : 1;\n   596→      const bAllCaps = isAllCaps(b.text) ? 0 : 1;\n   597→      if (aAllCaps !== bAllCaps) return aAllCaps - bAllCaps;\n   598→      const aShort = wordCount(a.text) <= 5 ? 0 : 1;\n   599→      const bShort = wordCount(b.text) <= 5 ? 0 : 1;\n   600→      return aShort - bShort;\n   601→    });\n   602→    return prioritized.slice(0, 25);\n   603→  }\n   604→\n   605→  return candidates;\n   606→}\n   607→\n   608→/**\n   609→ * Convert an ALL_CAPS string to Title Case, using a small-words list.\n   610→ * Preserves Polish/French diacritics.\n   611→ */\n   612→function toTitleCase(text: string): string {\n   613→  const smallWords = new Set([\n   614→    \"a\", \"an\", \"the\", \"and\", \"but\", \"or\", \"for\", \"nor\",\n   615→    \"in\", \"on\", \"at\", \"to\", \"of\", \"by\", \"with\", \"from\",\n   616→    \"z\", \"w\", \"i\", \"ze\", \"na\", \"do\", \"od\", \"za\", \"po\",\n   617→  ]);\n   618→  return text.split(/(\\s+)/).map((word, idx) => {\n   619→    if (/^\\s+$/.test(word)) return word;\n   620→    const lower = word.toLowerCase();\n   621→    if (idx === 0 || !smallWords.has(lower)) {\n   622→      return lower.charAt(0).toUpperCase() + lower.slice(1);\n   623→    }\n   624→    return lower;\n   625→  }).join(\"\");\n   626→}\n   627→\n   628→/**\n   629→ * OCR digit→letter substitution map.\n   630→ * Each key is a character that OCR commonly confuses; values are possible correct letters.\n   631→ */\n   632→const OCR_SUBSTITUTIONS: Record<string, string[]> = {\n   633→  \"0\": [\"o\"],\n   634→  \"1\": [\"i\", \"l\"],\n   635→  \"4\": [\"a\"],\n   636→  \"5\": [\"s\"],\n   637→  \"¡\": [\"i\"],\n   638→  \"í\": [\"i\"],\n   639→  \"€\": [\"e\"],\n   640→};\n   641→\n   642→const OCR_ARTIFACT_PATTERN = /[0-9¡Íí€]/;\n   643→\n   644→/**\n   645→ * Attempt to repair a single OCR-corrupted word using dictionary lookup.\n   646→ * Returns the repaired word if a dictionary match is found, otherwise returns the original.\n   647→ */\n   648→function repairOcrWord(word: string): string {\n   649→  if (!OCR_ARTIFACT_PATTERN.test(word)) return word;\n   650→\n   651→  const lower = word.toLowerCase();\n   652→\n   653→  const positions: { index: number; replacements: string[] }[] = [];\n   654→  for (let i = 0; i < lower.length; i++) {\n   655→    const replacements = OCR_SUBSTITUTIONS[lower[i]];\n   656→    if (replacements) {\n   657→      positions.push({ index: i, replacements });\n   658→    }\n   659→  }\n   660→\n   661→  if (positions.length === 0 || positions.length > 8) return word;\n   662→\n   663→  const candidates = generateSubstitutions(lower, positions, 0);\n   664→\n   665→  for (const candidate of candidates) {\n   666→    if (FOOD_DICTIONARY.has(candidate)) {\n   667→      if (word === word.toUpperCase()) return candidate.toUpperCase();\n   668→      if (word[0] === word[0].toUpperCase()) {\n   669→        return candidate[0].toUpperCase() + candidate.slice(1);\n   670→      }\n   671→      return candidate;\n   672→    }\n   673→  }\n   674→\n   675→  return word;\n   676→}\n   677→\n   678→/**\n   679→ * Recursively generate all substitution variants for OCR artifact positions.\n   680→ */\n   681→function generateSubstitutions(\n   682→  base: string,\n   683→  positions: { index: number; replacements: string[] }[],\n   684→  posIdx: number,\n   685→): string[] {\n   686→  if (posIdx >= positions.length) return [base];\n   687→\n   688→  const { index, replacements } = positions[posIdx];\n   689→  const results: string[] = [];\n   690→\n   691→  for (const replacement of replacements) {\n   692→    const variant = base.slice(0, index) + replacement + base.slice(index + 1);\n   693→    results.push(...generateSubstitutions(variant, positions, posIdx + 1));\n   694→  }\n   695→\n   696→  return results;\n   697→}\n   698→\n   699→/**\n   700→ * Apply dictionary-guided OCR repair to all words in a text string.\n   701→ */\n   702→function repairOcrText(text: string): string {\n   703→  return text\n   704→    .split(/\\s+/)\n   705→    .map((word) => {\n   706→      const match = word.match(/^([^a-zA-Z0-9À-ÿ]*)(.*?)([^a-zA-Z0-9À-ÿ]*)$/);\n   707→      if (!match) return word;\n   708→      const [, prefix, core, suffix] = match;\n   709→      if (!core) return word;\n   710→      const repaired = repairOcrWord(core);\n   711→      return prefix + repaired + suffix;\n   712→    })\n   713→    .join(\" \");\n   714→}\n   715→\n   716→/**\n   717→ * Post-processing normalization for OCR-extracted titles.\n   718→ * Strips stray section markers and substitutes common OCR digit-for-letter artifacts.\n   719→ * Title-case conversion is applied only when a substitution was actually made, so\n   720→ * clean ALL_CAPS titles (e.g. \"CHOCOLATE CAKE\") are returned unchanged.\n   721→ */\n   722→function normalizeOcrTitle(raw: string): string {\n   723→  let text = raw.trim();\n   724→\n   725→  // Step 0: Dictionary-guided OCR repair — resolve ambiguous substitutions\n   726→  // using word-level context before applying blind character replacements.\n   727→  text = repairOcrText(text);\n   728→\n   729→  // Step 1: Strip trailing section markers greedily appended to the title.\n   730→  // e.g. \"MAKOWIEC ZE ŚLIWKAMI + SERVING AND STORAGE:\" → \"MAKOWIEC ZE ŚLIWKAMI\"\n   731→  text = text.replace(\n   732→    /\\s*\\+\\s*(?:SERV[IÍ1]NG(?:\\s+AND\\s+STORAGE)?|TOPPING|NOTES?|TIPS?)\\s*:?\\s*$/i,\n   733→    \"\"\n   734→  );\n   735→\n   736→  // Step 2: OCR character substitution.\n   737→  // For ALL_CAPS text, apply digit-for-letter substitutions.\n   738→  const beforeSub = text;\n   739→  if (isAllCaps(text)) {\n   740→    text = text\n   741→      .replace(/1/g, \"I\")\n   742→      .replace(/0(?=[A-ZÀ-Ż])/g, \"O\")\n   743→      .replace(/(?<=[A-ZÀ-Ż])0/g, \"O\")\n   744→      .replace(/4(?=[A-ZÀ-Ż])/g, \"A\")\n   745→      .replace(/(?<=[A-ZÀ-Ż])4/g, \"A\")\n   746→      .replace(/5(?=[A-ZÀ-Ż])/g, \"S\")\n   747→      .replace(/(?<=[A-ZÀ-Ż])5/g, \"S\")\n   748→      .replace(/¡/g, \"I\")\n   749→      .replace(/€/g, \"E\")\n   750→      .replace(/[ÍÌ]/g, \"I\");\n   751→  } else {\n   752→    // Mixed-case: fix per-word (digits between lowercase letters)\n   753→    text = text.split(/(\\s+)/).map((token) => {\n   754→      if (/^\\s+$/.test(token)) return token;\n   755→      if (isAllCaps(token) && token.length > 1) {\n   756→        return token\n   757→          .replace(/1/g, \"I\")\n   758→          .replace(/0(?=[A-Z])/g, \"O\")\n   759→          .replace(/(?<=[A-Z])0/g, \"O\");\n   760→      }\n   761→      return token\n   762→        .replace(/(?<=[a-zà-ż])1/g, \"l\")\n   763→        .replace(/1(?=[a-zà-ż])/g, \"l\")\n   764→        .replace(/¡/g, \"i\")\n   765→        .replace(/€/g, \"e\");\n   766→    }).join(\"\");\n   767→  }\n   768→\n   769→  // Step 3: Title-case conversion — ONLY when OCR substitution changed the text.\n   770→  // This preserves clean ALL_CAPS titles (e.g. \"CHOCOLATE CAKE\") as-is.\n   771→  if (text !== beforeSub && isAllCaps(text)) {\n   772→    text = toTitleCase(text);\n   773→  }\n   774→\n   775→  return text.trim();\n   776→}\n   777→\n   778→// Module-level cache for reference embeddings\n   779→let cachedTitleRefEmbedding: Array<number> | null = null;\n   780→let cachedHeaderRefEmbedding: Array<number> | null = null;\n   781→let cachedNoiseRefEmbedding: Array<number> | null = null;\n   782→\n   783→export function _resetEmbeddingCacheForTests(): void {\n   784→  cachedTitleRefEmbedding = null;\n   785→  cachedHeaderRefEmbedding = null;\n   786→  cachedNoiseRefEmbedding = null;\n   787→}\n   788→\n   789→export async function extractTitleWithEmbeddings(\n   790→  text: string,\n   791→  embed: EmbedFn\n   792→): Promise<string | undefined> {\n   793→  if (!text || text.trim().length === 0) {\n   794→    return undefined;\n   795→  }\n   796→\n   797→  const lines = text.split(\"\\n\");\n   798→  const candidates = buildCandidates(lines);\n   799→  const titleAbsent = isTitleAbsentPage(lines);\n   800→\n   801→  if (candidates.length === 0) {\n   802→    return undefined;\n   803→  }\n   804→\n   805→  // Cache reference embeddings\n   806→  if (!cachedTitleRefEmbedding) {\n   807→    cachedTitleRefEmbedding = await embed(TITLE_REFERENCE);\n   808→  }\n   809→  if (!cachedHeaderRefEmbedding) {\n   810→    cachedHeaderRefEmbedding = await embed(HEADER_REFERENCE);\n   811→  }\n   812→  if (!cachedNoiseRefEmbedding) {\n   813→    cachedNoiseRefEmbedding = await embed(NOISE_REFERENCE);\n   814→  }\n   815→\n   816→  // Find ALL_CAPS candidates with ≥2 words where every significant word has ≥4 alpha letters.\n   817→  // Insignificant tokens (≤1 alpha letter: \"/\", \"&\", \"+\", \":\", \"D)\", etc.) are filtered before\n   818→  // the check so that multi-line joins with continuation punctuation still qualify.\n   819→  const isStructuralHeading = (c: { text: string }): boolean => {\n   820→    if (!isAllCaps(c.text) || wordCount(c.text) < 2) return false;\n   821→    const sigWords = c.text.trim().split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length > 1);\n   822→    return sigWords.length >= 2 && sigWords.every((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   823→  };\n   824→\n   825→  // Pass 1: compute rawScore for all candidates (embedding quality signal)\n   826→  const rawScored: Array<{ text: string; position: number; origin: CandidateOrigin; rawScore: number; embedding: Array<number> }> = [];\n   827→  for (const candidate of candidates) {\n   828→    const embedding = await embed(candidate.text);\n   829→    const titleSim = cosineSimilarity(embedding, cachedTitleRefEmbedding);\n   830→    const headerSim = cosineSimilarity(embedding, cachedHeaderRefEmbedding);\n   831→    const noiseSim = cosineSimilarity(embedding, cachedNoiseRefEmbedding);\n   832→    const rawScore = titleSim - Math.max(headerSim, noiseSim);\n   833→    rawScored.push({ text: candidate.text, position: candidate.position, origin: candidate.origin, rawScore, embedding });\n   834→  }\n   835→\n   836→  // Select baseHeading by embedding quality (rawScore), not position.\n   837→  // This prevents OCR-garbled fragments from claiming the structural heading slot.\n   838→  const structuralCandidates = rawScored.filter((s) => isStructuralHeading(s));\n   839→\n   840→  // Penalize structural headings with truncated OCR words:\n   841→  // if \"FRON\" appears and another heading has \"SAFFRON\", \"FRON\" is likely garbled.\n   842→  for (const sc of structuralCandidates) {\n   843→    const sigWords = sc.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   844→    for (const other of structuralCandidates) {\n   845→      if (other === sc) continue;\n   846→      const otherSigWords = other.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   847→      const hasTruncation = sigWords.some((w) =>\n   848→        otherSigWords.some((ow) => ow !== w && ow.length > w.length && ow.endsWith(w))\n   849→      );\n   850→      if (hasTruncation) {\n   851→        sc.rawScore = -1.0;  // Hard disqualification — truncated OCR artifact\n   852→        break;\n   853→      }\n   854→    }\n   855→  }\n   856→\n   857→  const bestStructural = structuralCandidates.length > 0\n   858→    ? structuralCandidates.reduce((a, b) => {\n   859→        const scoreDiff = a.rawScore - b.rawScore;\n   860→        if (Math.abs(scoreDiff) > 0.03) return scoreDiff > 0 ? a : b;\n   861→        // Tiebreak: single-line origin beats multi-line joins (avoids conflating two separate headings)\n   862→        if (a.origin === \"single\" && b.origin !== \"single\") return a;\n   863→        if (b.origin === \"single\" && a.origin !== \"single\") return b;\n   864→        // Tiebreak: more words (more specific) → better\n   865→        const wcDiff = wordCount(b.text) - wordCount(a.text);\n   866→        if (wcDiff !== 0) return wcDiff > 0 ? b : a;\n   867→        // Tiebreak: earlier position → better\n   868→        return a.position < b.position ? a : b;\n   869→      })\n   870→    : null;\n   871→  const baseHeading = bestStructural ?? undefined;\n   872→\n   873→  // When the best structural heading has a continuation on the next line introduced by a\n   874→  // punctuation token (/, &, +, :, or parenthesis), prefer the longer 2-line join as the\n   875→  // complete heading. E.g. \"SAFFRON WHEAT BUNS WITH QUARK\" + \"/ COTTAGE CHEESE (VARIATION D)\".\n   876→  // Guard: the remainder after the prefix must start with a continuation character to avoid\n   877→  // merging two separate consecutive recipe titles (FINNISH MILK FLATBREADS stays separate\n   878→  // from FINNISH POTATO FLATBREADS because \"FINNISH\" does not start with a continuation token).\n   879→  let firstStructuralHeading = baseHeading && (\n   880→    rawScored.find((c) => {\n   881→      if (!isStructuralHeading(c)) return false;\n   882→      const hLower = baseHeading.text.toLowerCase();\n   883→      const cLower = c.text.toLowerCase();\n   884→      return cLower.startsWith(hLower + \" \") && /^[/&+:(]/.test(cLower.slice(hLower.length + 1));\n   885→    }) ?? baseHeading\n   886→  );\n   887→\n   888→  // Pass 2: apply bonuses\n   889→  const scored: Array<{ text: string; position: number; origin: CandidateOrigin; score: number; rawScore: number; baseScore: number; thresholdScore: number }> = rawScored.map((rs, candidateIndex) => {\n   890→    // Position factor: multiplicative tiebreaker — amplifies existing signal, doesn't replace it.\n   891→    // Use candidate-relative position (rank among candidates that passed hard filters) rather than\n   892→    // raw line position, so filtered preamble lines don't penalize the first real candidate.\n   893→    const candidateRelativePosition = candidateIndex / rawScored.length;\n   894→    const positionFactor = candidateRelativePosition < 0.5\n   895→      ? 1.0 + 0.12 * (1 - candidateRelativePosition * 2)\n   896→      : 1.0;\n   897→\n   898→    // ALL_CAPS bonus: recipe books use ALL_CAPS for titles and section headings.\n   899→    // Single-word ALL_CAPS terms are overwhelmingly section/category labels, not recipe titles;\n   900→    // real recipe titles in ALL_CAPS are almost always multi-word. Reduce the bonus for single words.\n   901→    const allCapsBonus = isAllCaps(rs.text) && rs.text.replace(/[^a-zA-Z]/g, \"\").length >= 4\n   902→      ? (wordCount(rs.text) >= 2 ? 0.08 : 0.03)\n   903→      : 0;\n   904→\n   905→    // Structural heading bonus: best ALL_CAPS heading (or its continuation join) is almost always the recipe title\n   906→    const structuralBonus = firstStructuralHeading && rs.text === firstStructuralHeading.text ? 0.10 : 0;\n   907→\n   908→    // thresholdScore excludes structural bonus so the bonus doesn't inflate the threshold\n   909→    // and prevent equally-valid structural headings from passing on multi-recipe pages.\n   910→    const thresholdScore = rs.rawScore + allCapsBonus;\n   911→    // baseScore excludes position factor — used for diagnostics and ranking\n   912→    const baseScore = rs.rawScore + allCapsBonus + structuralBonus;\n   913→    const score = rs.rawScore * positionFactor + allCapsBonus + structuralBonus;\n   914→    return { text: rs.text, position: rs.position, origin: rs.origin, score, rawScore: rs.rawScore, baseScore, thresholdScore };\n   915→  });\n   916→\n   917→  if (scored.length === 0) {\n   918→    return undefined;\n   919→  }\n   920→\n   921→  // First-after-preamble bonus (Pattern 3): when lines before the first candidate were all\n   922→  // filtered/empty, the first surviving candidate occupies the structural \"title position\".\n   923→  // E.g. \"FISH & SEAFOOD\\nHalibut with Saffron Cream Sauce\\n...\" — \"FISH & SEAFOOD\" is filtered\n   924→  // as a section label, so \"Halibut...\" is the first candidate and gets this boost.\n   925→  const firstCandidate = scored[0];\n   926→  if (firstCandidate.position > 0) {\n   927→    const allPrecedingFiltered = lines\n   928→      .slice(0, firstCandidate.position)\n   929→      .every((line) => {\n   930→        const trimmed = line.trim();\n   931→        return trimmed === \"\" || !passesHardFilters(trimmed);\n   932→      });\n   933→    if (allPrecedingFiltered) {\n   934→      firstCandidate.score += 0.08;\n   935→      firstCandidate.baseScore += 0.08;\n   936→      firstCandidate.thresholdScore += 0.08;\n   937→    }\n   938→  }\n   939→\n   940→  // --- Pre-threshold bilingual title detection ---\n   941→  // When a mixed-case candidate at position 0 is followed by an ALL_CAPS candidate\n   942→  // at position ≤ 2 that is semantically similar to it, this is a bilingual recipe\n   943→  // page (e.g., Polish title + ALL_CAPS Korean romanization). Suppress confirmed\n   944→  // translation candidates before computing threshold so their bonuses don't inflate\n   945→  // the threshold beyond the mixed-case title's reach.\n   946→  // Note: we check position ≤ 2 (local proximity), not global ALL_CAPS count, so\n   947→  // section headers later in the document (SKŁADNIKI, WARZYWA, etc.) are irrelevant.\n   948→  let translationCandidates: typeof scored = [];\n   949→  let scoredForThreshold = scored;\n   950→  const prePos0 = scored.find((s) => s.position === 0 && !isAllCaps(s.text));\n   951→  if (prePos0) {\n   952→    const nearbyAllCaps = scored.filter(\n   953→      (s) => isAllCaps(s.text) && s.position >= 1 && s.position <= 2 && s.origin === \"single\"\n   954→    );\n   955→    const pos0Embedding = rawScored.find((r) => r.text === prePos0.text)?.embedding;\n   956→\n   957→    // Method 1: embedding similarity (works for related languages)\n   958→    if (pos0Embedding && nearbyAllCaps.length > 0) {\n   959→      translationCandidates = nearbyAllCaps.filter((cap) => {\n   960→        const capEmbedding = rawScored.find((r) => r.text === cap.text)?.embedding;\n   961→        if (!capEmbedding) return false;\n   962→        return cosineSimilarity(pos0Embedding, capEmbedding) > 0.4;\n   963→      });\n   964→    }\n   965→\n   966→    // Method 2: layout-based detection (cross-lingual fallback).\n   967→    // When embedding similarity is insufficient (e.g. Polish ↔ Korean romanization),\n   968→    // detect bilingual layout by position and word overlap:\n   969→    // mixed-case ≥2 words at pos 0 + ALL_CAPS ≥2 words at pos 1-2 with no shared words.\n   970→    if (translationCandidates.length === 0 && wordCount(prePos0.text) >= 2) {\n   971→      const pos0Words = new Set(\n   972→        prePos0.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2)\n   973→      );\n   974→      translationCandidates = nearbyAllCaps.filter((cap) => {\n   975→        if (wordCount(cap.text) < 2) return false;\n   976→        const capWords = cap.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2);\n   977→        return !capWords.some((w) => pos0Words.has(w));\n   978→      });\n   979→    }\n   980→\n   981→    if (translationCandidates.length > 0) {\n   982→      // Suppress standalone translations and any multi-line joins that embed the translation\n   983→      // as a suffix or substring (e.g. \"Smażona zielona fasolka GREEN BEANS BORKEUM\" ends with\n   984→      // the translation; \"Title GREEN BEANS BORKEUM 그린빈\" includes it as a substring).\n   985→      scoredForThreshold = scored.filter((s) => {\n   986→        const sLower = s.text.toLowerCase();\n   987→        return !translationCandidates.some((t) => {\n   988→          const tLower = t.text.toLowerCase();\n   989→          return sLower.startsWith(tLower) ||\n   990→                 sLower.endsWith(\" \" + tLower) ||\n   991→                 sLower.includes(\" \" + tLower);\n   992→        });\n   993→      });\n   994→    }\n   995→  }\n   996→\n   997→  // Fix 2: If the structural heading was identified as a bilingual translation, reassign it.\n   998→  // This prevents the translation's ALL_CAPS bonus from inflating the threshold and ensures\n   999→  // the fallback path in scored also uses the correct heading.\n  1000→  if (\n  1001→    translationCandidates.length > 0 &&\n  1002→    firstStructuralHeading &&\n  1003→    translationCandidates.some((t) => t.text === firstStructuralHeading!.text)\n  1004→  ) {\n  1005→    const nonTranslationStructural = structuralCandidates.filter(\n  1006→      (sc) => !translationCandidates.some((t) => t.text === sc.text)\n  1007→    );\n  1008→    const newHeading = nonTranslationStructural.length > 0\n  1009→      ? nonTranslationStructural.reduce((a, b) => a.rawScore > b.rawScore ? a : b)\n  1010→      : undefined;\n  1011→\n  1012→    // Patch scored array: remove old structural bonus, apply new one\n  1013→    for (const s of scored) {\n  1014→      if (s.text === firstStructuralHeading.text) {\n  1015→        s.score -= 0.10;\n  1016→        s.baseScore -= 0.10;\n  1017→      }\n  1018→      if (newHeading && s.text === newHeading.text) {\n  1019→        s.score += 0.10;\n  1020→        s.baseScore += 0.10;\n  1021→      }\n  1022→    }\n  1023→    // Update reference for downstream prefix-removal logic\n  1024→    firstStructuralHeading = newHeading ?? undefined;\n  1025→  }\n  1026→\n  1027→  // Subtitle suppression: when a short mixed-case title at position 0 is followed by a\n  1028→  // longer mixed-case candidate at position 1-2, the longer one is a subtitle/translation.\n  1029→  // Apply a penalty so the primary title (position 0) wins.\n  1030→  const pos0Primary = scored.find((s) => s.position === 0 && !isAllCaps(s.text) && wordCount(s.text) <= 5);\n  1031→  if (pos0Primary) {\n  1032→    const subtitleCandidates = scored.filter((s) =>\n  1033→      s.position >= 1 && s.position <= 2 &&\n  1034→      !isAllCaps(s.text) &&\n  1035→      wordCount(s.text) > wordCount(pos0Primary.text) + 2\n  1036→    );\n  1037→    for (const sub of subtitleCandidates) {\n  1038→      sub.score -= 0.15;\n  1039→    }\n  1040→  }\n  1041→\n  1042→  // Use thresholdScore (excludes structural bonus) so the structural bonus doesn't inflate\n  1043→  // the threshold and block equally-valid headings on multi-recipe pages.\n  1044→  const bestThresholdScore = Math.max(...scoredForThreshold.map((s) => s.thresholdScore));\n  1045→  const threshold = Math.max(0.08, bestThresholdScore * 0.7);\n  1046→\n  1047→  // Filter candidates above threshold\n  1048→  let selected = scoredForThreshold.filter((s) => s.score >= threshold);\n  1049→\n  1050→  // Empty-pool fallback: when threshold filtering discards every candidate,\n  1051→  // the hard filters' structural verdict should not be overruled by weak\n  1052→  // embedding differentiation. Return the best positional candidate only\n  1053→  // if it has a meaningful positive raw score (avoids ingredient-list leakage).\n  1054→  if (selected.length === 0 && scored.length > 0) {\n  1055→    const fallback = scored\n  1056→      .slice()\n  1057→      .sort((a, b) => a.position - b.position || b.score - a.score);\n  1058→    // Position-0 candidates that passed hard filters are very likely titles even with\n  1059→    // weak embedding signal. Relax the rawScore guard for early-position candidates.\n  1060→    const rawScoreThreshold = fallback[0].position <= 2 ? -0.05 : 0.02;\n  1061→    if (fallback[0].rawScore > rawScoreThreshold) {\n  1062→      selected = [fallback[0]];\n  1063→    }\n  1064→  }\n  1065→\n  1066→  // Title-absent page guard: when the page starts mid-recipe (all of the first 3 non-empty\n  1067→  // lines are ingredients or cooking instructions), require a much higher rawScore and\n  1068→  // discard candidates deep in the file. This prevents stray body text or adjacent recipe\n  1069→  // titles from being picked up on pages with no title (Pattern 4).\n  1070→  if (titleAbsent) {\n  1071→    const titleAbsentThreshold = 0.10;\n  1072→    selected = selected.filter(s => s.rawScore >= titleAbsentThreshold);\n  1073→    selected = selected.filter(s => s.position <= 2);\n  1074→  }\n  1075→\n  1076→  // Remove word-boundary prefixes of firstStructuralHeading when the heading itself survived\n  1077→  // the threshold. Cases:\n  1078→  //   ARAYES case:  firstStructuralHeading = \"ARAYES SHRAK\" (2-word join qualifies; \"ARAYES\"\n  1079→  //     alone = 1 word, so it never qualified). Filter removes \"ARAYES\" so dedup keeps the join.\n  1080→  //   SAFFRON case: baseHeading was the partial line; continuation logic above upgraded\n  1081→  //     firstStructuralHeading to the full join. Filter removes the partial so dedup keeps join.\n  1082→  // Safety: only fires when the complete heading itself is in selected (passed the threshold).\n  1083→  if (firstStructuralHeading && selected.some((s) => s.text === firstStructuralHeading.text)) {\n  1084→    const fshLower = firstStructuralHeading.text.toLowerCase();\n  1085→    selected = selected.filter((s) => {\n  1086→      if (s.text === firstStructuralHeading.text) return true;\n  1087→      const sLower = s.text.toLowerCase();\n  1088→      // Remove s if it is a space-delimited prefix of the structural heading\n  1089→      return !fshLower.startsWith(sLower + \" \");\n  1090→    });\n  1091→  }\n  1092→\n  1093→  // Protect continuation joins: when a multi-line join (2-line or 3-line) survived the threshold\n  1094→  // and its second part starts with a continuation character, remove the single-line prefix/suffix\n  1095→  // so the dedup \"shorter wins\" rule doesn't destroy the complete join.\n  1096→  // Note: the pre-merge step above already handles the common Baked Eggs case (&/continuation\n  1097→  // on next line) by turning it into a single candidate — this block covers the rarer case where\n  1098→  // a continuation-character join was generated as a 2-line/3-line candidate and the prefix\n  1099→  // single also survived threshold independently (e.g. from a different code path or OCR layout).\n  1100→  // Safety: only fires for joins whose continuation starts with /&+:( — digit continuations\n  1101→  // like \"Pierogi Ruskie 200g mąki\" are NOT protected, so dedup correctly keeps the shorter form.\n  1102→  const survivingJoins = selected.filter((s) => s.origin === \"2-line\" || s.origin === \"3-line\");\n  1103→  if (survivingJoins.length > 0) {\n  1104→    selected = selected.filter((s) => {\n  1105→      if (s.origin !== \"single\") return true;\n  1106→      const sLower = s.text.toLowerCase();\n  1107→      // Remove PREFIX singles whose continuation join also survived\n  1108→      const isPrefixOfJoin = survivingJoins.some((j) => {\n  1109→        const jLower = j.text.toLowerCase();\n  1110→        if (!jLower.startsWith(sLower + \" \")) return false;\n  1111→        const remainder = jLower.slice(sLower.length + 1);\n  1112→        return /^[/&+:(]/.test(remainder);\n  1113→      });\n  1114→      if (isPrefixOfJoin) return false;\n  1115→      // Remove SUFFIX singles (e.g. \"& Coriander\") whose parent join also survived\n  1116→      const isSuffixOfJoin = survivingJoins.some((j) => {\n  1117→        const jLower = j.text.toLowerCase();\n  1118→        if (!jLower.endsWith(\" \" + sLower)) return false;\n  1119→        // Only remove if the suffix starts with a continuation character\n  1120→        return /^[/&+:(]/.test(sLower);\n  1121→      });\n  1122→      if (isSuffixOfJoin) return false;\n  1123→      return true;\n  1124→    });\n  1125→  }\n  1126→\n  1127→  // Pre-dedup: remove sub-section headers that are substrings of other surviving candidates.\n  1128→  // A sub-section header is an ALL_CAPS candidate followed by ingredient-like lines in the source.\n  1129→  // Example: \"CHLEBEK\" (bread section header, followed by \"500 g mąki\") is a substring of\n  1130→  // \"CHLEBEK Z WARZYWAMI I BOCZKIEM\" (the real title). Without this filter, dedup kills the title.\n  1131→  selected = selected.filter((candidate) => {\n  1132→    if (!isAllCaps(candidate.text)) return true;\n  1133→    // Check if this candidate is immediately followed by ingredient-like content\n  1134→    const nextSourceLines = lines.slice(candidate.position + 1, candidate.position + 2);\n  1135→    const followedByIngredients = nextSourceLines.some(\n  1136→      (l) => looksLikeIngredient(l.trim()) || startsWithNumber(l.trim())\n  1137→    );\n  1138→    if (!followedByIngredients) return true;\n  1139→    // Only remove if a longer candidate contains this one as a substring\n  1140→    const candidateLower = candidate.text.toLowerCase();\n  1141→    const hasLongerParent = rawScored.some(\n  1142→      (other) =>\n  1143→        other.text !== candidate.text &&\n  1144→        other.text.length > candidate.text.length &&\n  1145→        other.text.toLowerCase().includes(candidateLower)\n  1146→    );\n  1147→    return !hasLongerParent;\n  1148→  });\n  1149→\n  1150→  // Protect multi-line joins from being destroyed by their own component singles.\n  1151→  // When \"Lamb Stew\" (2-line join) survives AND both \"Lamb\" and \"Stew\" (singles) also survive,\n  1152→  // the join is the intended title — remove the singles.\n  1153→  const joinsToProtect = selected.filter((s) => s.origin === \"2-line\" || s.origin === \"3-line\");\n  1154→  if (joinsToProtect.length > 0) {\n  1155→    const singlesToRemove = new Set<string>();\n  1156→    for (const join of joinsToProtect) {\n  1157→      const joinWords = join.text.split(/\\s+/);\n  1158→      const componentSingles = selected.filter(\n  1159→        (s) => s.origin === \"single\" && joinWords.some((w) => s.text.toLowerCase() === w.toLowerCase())\n  1160→      );\n  1161→      if (componentSingles.length >= Math.min(joinWords.length, 2)) {\n  1162→        componentSingles.forEach((s) => singlesToRemove.add(s.text));\n  1163→      }\n  1164→    }\n  1165→    if (singlesToRemove.size > 0) {\n  1166→      selected = selected.filter((s) => s.origin !== \"single\" || !singlesToRemove.has(s.text));\n  1167→    }\n  1168→  }\n  1169→\n  1170→  // Protect position-0 compound titles from distant sub-section headers.\n  1171→  // When a position-0 compound title is longer and contains a shorter candidate\n  1172→  // that appears > 10 lines later, remove the distant candidate so the dedup\n  1173→  // (shorter-wins rule) doesn't destroy the compound title.\n  1174→  const pos0Compounds = selected.filter((s) => s.position === 0);\n  1175→  if (pos0Compounds.length > 0) {\n  1176→    selected = selected.filter((s) => {\n  1177→      if (s.position === 0) return true;\n  1178→      const sLower = s.text.toLowerCase();\n  1179→      return !pos0Compounds.some(\n  1180→        (p0) =>\n  1181→          p0.position + 10 < s.position &&\n  1182→          s.text.length < p0.text.length &&\n  1183→          p0.text.toLowerCase().includes(sLower)\n  1184→      );\n  1185→    });\n  1186→  }\n  1187→\n  1188→  // Deduplicate: if one title is a substring of another, keep the shorter (more focused) one.\n  1189→  // DO NOT CHANGE THIS LOGIC — it has been incorrectly \"improved\" by the title-loop 5 times.\n  1190→  // The tests require shorter wins: \"Pierogi Ruskie\" over \"Pierogi Ruskie 200g mąki 3 ziemniaki\".\n  1191→  // The pre-filter above handles the conflicting case (structural heading prefix removal) so that\n  1192→  // the incomplete prefix line is never present here when the complete join is in selected.\n  1193→  selected = selected.filter((a) => {\n  1194→    const aLower = a.text.toLowerCase();\n  1195→    // Protect compound titles — these use explicit separators and the full form is intentional\n  1196→    if (/ [+:&] /.test(a.text)) return true;\n  1197→    return !selected.some(\n  1198→      (b) =>\n  1199→        b !== a &&\n  1200→        aLower.includes(b.text.toLowerCase()) &&\n  1201→        b.text.length < a.text.length\n  1202→    );\n  1203→  });\n  1204→\n  1205→  // Multi-title guard: only join multiple candidates with \"+\" when there is\n  1206→  // structural evidence of a multi-recipe page (≥2 ALL_CAPS headings).\n  1207→  // A single ALL_CAPS title among mixed-case survivors is a single-recipe page —\n  1208→  // collapse to the highest-scoring candidate.\n  1209→  // Zero ALL_CAPS survivors → apply positional tiebreak only when candidates are\n  1210→  // spread far apart (>10 lines), which indicates body-text leakage. Closely-\n  1211→  // positioned candidates are likely genuine multi-recipe content.\n  1212→  if (selected.length > 1) {\n  1213→    const allCapsSelected = selected.filter((s) => isAllCaps(s.text));\n  1214→    if (allCapsSelected.length >= 2) {\n  1215→      // Check whether non-first ALL_CAPS headings are section headers within one recipe\n  1216→      // (followed immediately by ingredient-like content) rather than separate recipe titles.\n  1217→      // A multi-recipe page has body text between titles; a single-recipe page has\n  1218→      // ingredient lines immediately after each section heading.\n  1219→      const sortedCaps = [...allCapsSelected].sort((a, b) => a.position - b.position);\n  1220→      const isSubHeader = sortedCaps.slice(1).every((cap) => {\n  1221→        const nextLines = lines.slice(cap.position + 1, cap.position + 3);\n  1222→        return nextLines.some(\n  1223→          (l) => looksLikeIngredient(l.trim()) || /^\\s*\\d/.test(l.trim())\n  1224→        );\n  1225→      });\n  1226→      if (isSubHeader) {\n  1227→        selected = [sortedCaps[0]];\n  1228→      } else {\n  1229→        selected = allCapsSelected;\n  1230→      }\n  1231→    } else if (allCapsSelected.length === 1) {\n  1232→      const theCapCandidate = allCapsSelected[0];\n  1233→      // Use non-empty line count so the 75% threshold is consistent regardless of blank-line density.\n  1234→      const nonEmptyCount = lines.filter((l) => l.trim().length > 0).length;\n  1235→      const capRelPos = theCapCandidate.position / Math.max(nonEmptyCount, 1);\n  1236→      // If the sole ALL_CAPS candidate is in the last 25% of the document,\n  1237→      // it's likely a category footer, not a title. Prefer the best earlier candidate.\n  1238→      if (capRelPos > 0.75) {\n  1239→        const earlierCandidates = selected.filter(\n  1240→          (s) => s.position / Math.max(nonEmptyCount, 1) <= 0.75\n  1241→        );\n  1242→        if (earlierCandidates.length > 0) {\n  1243→          selected = [earlierCandidates.reduce((a, b) => (a.score > b.score ? a : b))];\n  1244→        } else {\n  1245→          // All candidates are in the last 25% — no positional basis to prefer one over another;\n  1246→          // fall back to score, accepting that the guard cannot help here.\n  1247→          selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n  1248→        }\n  1249→      } else {\n  1250→        selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n  1251→      }\n  1252→    } else {\n  1253→      // Zero ALL_CAPS survivors → mixed-case page.\n  1254→      // If all survivors are closely positioned (within 10 lines of each other), keep them all —\n  1255→      // they're likely genuine multi-recipe content on a single page.\n  1256→      // If any survivor is far from the earliest, apply a positional tiebreak: the real title\n  1257→      // is almost always the earliest candidate; distant survivors are likely body-text leakage.\n  1258→      selected.sort((a, b) => a.position - b.position);\n  1259→      const earliest = selected[0];\n  1260→      const farthest = selected[selected.length - 1];\n  1261→      if (farthest.position - earliest.position > 10) {\n  1262→        // Large span → body-text leakage. Collapse to one: prefer the highest-scoring\n  1263→        // candidate within 3 positions of the earliest (position tolerance for OCR gaps),\n  1264→        // falling back to the earliest itself if none score higher.\n  1265→        const closeCompetitors = selected.filter(\n  1266→          (s) => s.position <= earliest.position + 3 && s.score > earliest.score\n  1267→        );\n  1268→        selected = closeCompetitors.length > 0\n  1269→          ? [closeCompetitors.reduce((a, b) => (a.score > b.score ? a : b))]\n  1270→          : [earliest];\n  1271→      }\n  1272→      // Span ≤ 10 → all survivors are closely positioned; fall through keeping all.\n  1273→    }\n  1274→  }\n  1275→\n  1276→  // Cap at 3, sort by document position\n  1277→  selected.sort((a, b) => a.position - b.position);\n  1278→  selected = selected.slice(0, 3);\n  1279→\n  1280→  if (selected.length === 0) {\n  1281→    // Last resort: embedding scoring provided no usable signal.\n  1282→    // Return the earliest candidate that passed hard filters — it already survived\n  1283→    // ingredient, metadata, garbled, section-label, and cooking-instruction checks.\n  1284→    // Position 0 in a recipe file is overwhelmingly the title.\n  1285→    // Exclude hard-disqualified candidates (rawScore -1.0 = truncated OCR artifact).\n  1286→    const lastResort = scored\n  1287→      .slice()\n  1288→      .filter((s) => s.rawScore > -0.5)\n  1289→      .sort((a, b) => a.position - b.position || b.score - a.score);\n  1290→    if (lastResort.length > 0) {\n  1291→      return normalizeOcrTitle(lastResort[0].text.normalize(\"NFC\").trim());\n  1292→    }\n  1293→    return undefined;\n  1294→  }\n  1295→\n  1296→  const result = selected.map((s) => normalizeOcrTitle(s.text.normalize(\"NFC\").trim())).join(\" + \");\n  1297→\n  1298→  return result;\n  1299→}\n  1300→\n  1301→/**\n  1302→ * Extract potential recipe title from OCR text (sync heuristic fallback)\n  1303→ */\n  1304→export function extractTitle(text: string): string | undefined {\n  1305→  if (!text || text.trim().length === 0) {\n  1306→    return undefined;\n  1307→  }\n  1308→\n  1309→  const lines = text.split(\"\\n\").map((line) => line.trim());\n  1310→\n  1311→  for (const line of lines) {\n  1312→    if (line.length === 0) continue;\n  1313→    if (line.length < 3 || line.length > 50) continue;\n  1314→    if (looksLikeIngredient(line)) continue;\n  1315→    if (isAllCaps(line)) continue;\n  1316→    if (startsWithNumber(line)) continue;\n  1317→    return line;\n  1318→  }\n  1319→\n  1320→  return undefined;\n  1321→}\n  1322→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n","numLines":1327,"startLine":1,"totalLines":1327}}}
