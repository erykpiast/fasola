nction.\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":3,"cache_creation_input_tokens":400,"cache_read_input_tokens":36173,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":400},"output_tokens":0,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"da66d640-08e5-4551-9d04-aa2649fd8c8b","uuid":"1bbca3bd-823f-4bbe-aa8c-30ecd367dd0e"}
