{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Lm6Vmz16APHkUdXQyZhFdm","type":"tool_result","content":"   169→function isSectionLabel(text: string): boolean {\n   170→  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n   171→  if (SECTION_LABELS.has(normalized)) return true;\n   172→  // OCR variant: leading \"l\" may be OCR-corrupted \"I\" (e.g. \"lngredients\" → \"ingredients\")\n   173→  const ocrNormalized = normalized.replace(/^l/, \"i\");\n   174→  if (ocrNormalized !== normalized && SECTION_LABELS.has(ocrNormalized)) return true;\n   175→  return false;\n   176→}\n   177→\n   178→/**\n   179→ * Recipe-internal section labels that should ALWAYS block multi-line joins,\n   180→ * even when the combined word count is ≥ 3.\n   181→ * Category labels (\"zupy\", \"placki\", etc.) are NOT in this set — they can\n   182→ * legitimately start a multi-word recipe title like \"Zupy Zimowe Warzywne\".\n   183→ */\n   184→const ALWAYS_BLOCK_JOIN_LABELS = new Set([\n   185→  \"ingredients\", \"directions\", \"instructions\", \"method\", \"preparation\",\n   186→  \"steps\", \"notes\", \"tip\", \"tips\", \"variations\", \"variation\",\n   187→  \"garnish\", \"topping\", \"toppings\", \"frosting\", \"filling\",\n   188→  \"serving suggestion\", \"serving suggestions\", \"serving\",\n   189→  \"glaze\", \"instrukcje\", \"uwagi\", \"notatki\", \"podawanie\", \"przechowywanie\",\n   190→  \"skladniki\", \"przygotowanie\", \"sposob przygotowania\", \"sposob wykonania\",\n   191→  \"wykonanie\", \"wskazowki\", \"podpowiedz\", \"warianty\",\n   192→  \"sos\", \"nadzienie\", \"polewa\", \"lukier\", \"ciasto\",\n   193→]);\n   194→\n   195→function isAlwaysBlockJoinLabel(text: string): boolean {\n   196→  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n   197→  return ALWAYS_BLOCK_JOIN_LABELS.has(normalized);\n   198→}\n   199→\n   200→function isAllCaps(line: string): boolean {\