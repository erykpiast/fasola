itles)\n    50→ */\n    51→const METADATA_PATTERNS = [\n    52→  /^(SERVES?|MAKES?|YIELDS?)\\b/i,\n    53→  /^(PREP(ARATION)?|COOK(ING)?|PROOF|RISING|FERMENTATION|REST(ING)?)\\s*(AND\\s*)?(COOK(ING)?)?\\s*TIME/i,\n    54→  /^SAMPLE\\s+SCHEDULE\\b/i,\n    55→  /^BULK\\s+FERMENTATION\\b/i,\n    56→  /^(THIS\\s+RECIPE\\s+)?MAKES\\b/i,\n    57→  // Polish serving-size patterns: \"NA 3 PAPRYKI\", \"NA OKOŁO 1 KG\", \"DLA 4 OSÓB\"\n    58→  /^NA\\s+(\\d|OKOŁO)\\b/i,\n    59→  /^DLA\\s+\\d/i,\n    60→  // OCR-resilient: \"DLA\" + any token + serving-unit word (handles DLA & OSOB, DLA § OSOB, etc.)\n    61→  /^DLA\\s+\\S+\\s+OSOB/i,\n    62→  // OCR-resilient: \"DLA\" + single non-alphanumeric char (common digit→symbol OCR error)\n    63→  /^DLA\\s+[^a-zA-Z0-9\\s]\\s/i,\n    64→  // Time-unit metadata: any line containing \"N MIN\" or \"N GODZ\" is prep/cook/rest time,\n    65→  // regardless of OCR-corrupted prefix (catches PRZYGOTOWANTE, GOTOMANTE, etc.)\n    66→  /\\b\\d+\\s*MIN\\b/i,\n    67→  /\\b\\d+\\s*GODZ/i,\n    68→  // Season/category indicators\n    69→  /^SEZON\\s*:/i,\n    70→  /^KATEGORIA\\s*:/i,\n    71→  /^RODZAJ\\s*:/i,\n    72→  /^PORCJI\\s*:/i,       // Polish serving count\n    73→  /^PORTIONS?\\s*:/i,    // English serving count\n    74→  /^CZ[ĘE]Ś[ĆC]\\s*\\d/i,   // CZĘŚĆ 1: ... (Polish \"Part 1:\")\n    75→  /^PART\\s+\\d/i,             // PART 1: ... (English)\n    76→];\n    77→\n    78→/**\n    79→ * Single-word non-title words — standalone OCR fragments unlikely to be recipe titles\n    80→ */\n    81→const NON_TITLE_WORDS = new Set([\n    82→  \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"are\", \"was\",\n    83→  \"has\", \"his\", \"her\", \"its\", \"our\", \"who\", \"how\", \"may\", \"new\", \"now\",\n    84→  \"old\", \"see\", \"way\", \"did\", \"get\", \"let\", \"say\", \"she\", \"too\", \"use\",\n    85→  \"buns\", \"with\",\n    86→]);\n    87→\n    88→function looksLikeIngredient(line: string): boolean {\n    89→  const lowerLine = line.toLowerCase();\n    90→  if (MEASUREMENT_PATTERNS.some((pattern) => lowerLine.includes(pattern))) return true;\n    91→  // Compact metric: \"100g\", \"50ml\", \"250g\" — digit immediately followed by g/ml/kg\n    92→  if (/\\b\\d+\\s*(?:g|ml|kg)\\b/i.test(line)) return true;\n    93→  // \"to taste\" / \"do smaku\" — qualitative ingredient with no unit\n    94→  if (/\\bto taste\\b/i.test(line) || /\\bdo smaku\\b/i.test(line)) return true;\n    95→  return false;\n    96→}\n    97→\n    98→function startsWithNumber(line: string): boolean {\n    99→  // Match lines starting with a digit, or bullet-then-digit (e.g., \"- 2 jajka\")\n   100→  return /^\\s*(?:[-•*]\\s*)?\\d/.test(line);\n   101→}\n   102→\n   103→function stripDiacritics(text: string): string {\n   104→  return text.normalize(\"NFKD\").replace(/[\\u0300-\\u036f]/g, \"\");\n   105→}\n   106→\n   107→/**\n   108→ * Known recipe section labels — these are structural headers, not recipe titles.\n   109→ * Matched case-insensitively after trimming, stripping trailing punctuation, and stripping diacritics.\n   110→ * Polish entries are stored without diacritics for OCR resilience (e.g. \"SKLADNIKI\" matches \"składniki\").\n   111→ */\n   112→const SECTION_LABELS = new Set([\n   113→  // English\n   114→  \"ingredients\", \"directions\", \"instructions\", \"method\", \"preparation\",\n   115→  \"steps\", \"notes\", \"tip\", \"tips\", \"variations\", \"variation\",\n   116→  \"garnish\", \"topping\", \"toppings\", \"frosting\", \"filling\",\n   117→  \"serving suggestion\", \"serving suggestions\", \"serving\",\n   118→  \"glaze\", \"for the sauce\", \"for the filling\", \"for the dough\",\n   119→  \"for the topping\", \"for the glaze\", \"for the pasta dough\",\n   120→  \"for the pasta\", \"for the crust\",\n   121→  // Polish — recipe section labels (stored without diacritics for OCR resilience)\n   122→  \"skladniki\", \"przygotowanie\", \"sposob przygotowania\", \"sposob wykonania\",\n   123→  \"wykonanie\", \"wskazowki\", \"podpowiedz\", \"warianty\",\n   124→  \"sos\", \"nadzienie\", \"polewa\", \"lukier\", \"ciasto\",  // ciasto = dough/pastry base (recipe-internal section AND chapter label)\n   125→  \"instrukcje\",       // instructions\n   126→  \"uwagi\",            // notes/remarks\n   127→  \"notatki\",          // notes\n   128→  \"podawanie\",        // serving\n   129→  \"przechowywanie\",   // storage\n   130→  // Polish — recipe-book chapter/category labels (food groups, meal types)\n   131→  \"warzywa\",          // vegetables\n   132→  \"mieso\",            // meat (mięso)\n   133→  \"miesa\",            // meats (mięsa)\n   134→  \"ryby\",             // fish\n   135→  \"owoce morza\",      // seafood\n   136→  \"zupy\",             // soups\n   137→  \"salatki\",          // salads (sałatki)\n   138→  \"desery\",           // desserts\n   139→  \"napoje\",           // drinks\n   140→  \"pieczywo\",         // bread/baked goods\n   141→  \"przekaski\",        // appetizers/snacks\n   142→  \"sniadania\",        // breakfasts (śniadania)\n   143→  \"obiady\",           // dinners/lunches\n   144→  \"kolacje\",          // suppers\n   145→  \"makarony\",         // pasta dishes\n   146→  \"kasza\",            // groats/grains\n   147→  \"kasze\",            // groats/grains (plural)\n   148→  \"dania glowne\",     // main courses (dania główne)\n   149→  \"przystawki\",       // starters\n   150→  \"dodatki\",          // side dishes\n   151→  \"przetwory\",        // preserves\n   152→  \"wypieki\",          // baked goods\n   153→  \"ciasta\",           // cakes (plural)\n   154→  \"ciastka\",          // cookies\n   155→  \"torty\",            // layer cakes\n   156→  // \"placki\" removed — it commonly starts recipe titles like \"Placki Ziemniaczane\", \"Placki Żółte z Kukurydzą\"\n   157→  \"koktajle\",         // cocktails/smoothies\n   158→  // English — recipe-book chapter/category labels\n   159→  \"vegetables\", \"seafood\", \"fish\", \"soups\", \"salads\", \"desserts\",\n   160→  \"appetizers\", \"breads\", \"breakfast\", \"pasta\", \"grains\",\n   161→  \"main courses\", \"side dishes\", \"preserves\", \"baked goods\",\n   162→  \"fish & seafood\", \"soups & broths\", \"desserts & baked goods\",\n   163→  \"meats\", \"poultry\", \"game\",\n   164→]);\n   165→\n   166→function isSectionLabel(text: string): boolean {\n   167→  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n   168→  if (SECTION_LABELS.has(normalized)) return true;\n   169→  // OCR variant: leading \"l\" may be OCR-corrupted \"I\" (e.g. \"lngredients\" → \"ingredients\")\n   170→  const ocrNormalized = normalized.replace(/^l/, \"i\");\n   171→  if (ocrNormalized !== normalized && SECTION_LABELS.has(ocrNormalized)) return true;\n   172→  return false;\n   173→}\n   174→\n   175→/**\n   176→ * Recipe-internal section labels that should ALWAYS block multi-line joins,\n   177→ * even when the combined word count is ≥ 3.\n   178→ * Category labels (\"zupy\", \"placki\", etc.) are NOT in this set — they can\n   179→ * legitimately start a multi-word recipe title like \"Zupy Zimowe Warzywne\".\n   180→ */\n   181→const ALWAYS_BLOCK_JOIN_LABELS = new Set([\n   182→  \"ingredients\", \"directions\", \"instructions\", \"method\", \"preparation\",\n   183→  \"steps\", \"notes\", \"tip\", \"tips\", \"variations\", \"variation\",\n   184→  \"garnish\", \"topping\", \"toppings\", \"frosting\", \"filling\",\n   185→  \"serving suggestion\", \"serving suggestions\", \"serving\",\n   186→  \"glaze\", \"instrukcje\", \"uwagi\", \"notatki\", \"podawanie\", \"przechowywanie\",\n   187→  \"skladniki\", \"przygotowanie\", \"sposob przygotowania\", \"sposob wykonania\",\n   188→  \"wykonanie\", \"wskazowki\", \"podpowiedz\", \"warianty\",\n   189→  \"sos\", \"nadzienie\", \"polewa\", \"lukier\", \"ciasto\",\n   190→]);\n   191→\n   192→function isAlwaysBlockJoinLabel(text: string): boolean {\n   193→  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n   194→  return ALWAYS_BLOCK_JOIN_LABELS.has(normalized);\n   195→}\n   196→\n   197→function isAllCaps(line: string): boolean {\n   198→  const letters = line.replace(/[^a-zA-Z]/g, \"\");\n   199→  return letters.length > 0 && letters === letters.toUpperCase();\n   200→}\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"ae7c1124-3c84-467a-af52-dc284b447f62","uuid":"c1b64485-3a22-4c55-a865-c4e1fde44752","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/title-extractor.ts","content":"/**\n * Title Extraction\n * Extracts potential recipe title from OCR text using heuristics or semantic embeddings\n */\n\nimport { cosineSimilarity } from \"./embeddings\";\n\nexport type EmbedFn = (text: string) => Promise<Array<number>>;\n\nconst TITLE_REFERENCE =\n  \"recipe name, dish title, name of the food, nazwa przepisu, nazwa dania\";\nconst HEADER_REFERENCE =\n  \"ingredients list, cooking directions, section heading, składniki, przygotowanie, sposób wykonania\";\nconst NOISE_REFERENCE =\n  \"page number, table of contents, book footer, garbled text\";\n\n/**\n * Measurement units commonly found in ingredient lists\n */\nconst MEASUREMENT_PATTERNS = [\n  // English\n  \"cup\",\n  \"cups\",\n  \"tbsp\",\n  \"tsp\",\n  \"tablespoon\",\n  \"teaspoon\",\n  // \"oz\" and \"lb\" are matched with word boundaries in looksLikeIngredient\n  // to avoid false positives (\"oz\" in \"mozzarella\", \"lb\" in \"albacore\")\n  \"gram\",\n  \"grams\",\n  \"kg\",\n  \"ml\",\n  \"liter\",\n  \"pinch\",\n  \"dash\",\n  \"handful\",\n  // Polish\n  \"łyżka\", \"łyżki\", \"łyżek\",           // tablespoon(s)\n  \"łyżeczka\", \"łyżeczki\", \"łyżeczek\",   // teaspoon(s)\n  \"szklanka\", \"szklanki\", \"szklanek\",    // cup(s)\n  \"szczypta\",                            // pinch\n  \"garść\",                               // handful\n  \"opakowanie\", \"opakowania\",            // package(s)\n  \"plasterek\", \"plasterki\",             // slice(s)\n];\n\n/**\n * Patterns that identify recipe metadata lines (not titles)\n */\nconst METADATA_PATTERNS = [\n  /^(SERVES?|MAKES?|YIELDS?)\\b/i,\n  /^(PREP(ARATION)?|COOK(ING)?|PROOF|RISING|FERMENTATION|REST(ING)?)\\s*(AND\\s*)?(COOK(ING)?)?\\s*TIME/i,\n  /^SAMPLE\\s+SCHEDULE\\b/i,\n  /^BULK\\s+FERMENTATION\\b/i,\n  /^(THIS\\s+RECIPE\\s+)?MAKES\\b/i,\n  // Polish serving-size patterns: \"NA 3 PAPRYKI\", \"NA OKOŁO 1 KG\", \"DLA 4 OSÓB\"\n  /^NA\\s+(\\d|OKOŁO)\\b/i,\n  /^DLA\\s+\\d/i,\n  // OCR-resilient: \"DLA\" + any token + serving-unit word (handles DLA & OSOB, DLA § OSOB, etc.)\n  /^DLA\\s+\\S+\\s+OSOB/i,\n  // OCR-resilient: \"DLA\" + single non-alphanumeric char (common digit→symbol OCR error)\n  /^DLA\\s+[^a-zA-Z0-9\\s]\\s/i,\n  // Time-unit metadata: any line containing \"N MIN\" or \"N GODZ\" is prep/cook/rest time,\n  // regardless of OCR-corrupted prefix (catches PRZYGOTOWANTE, GOTOMANTE, etc.)\n  /\\b\\d+\\s*MIN\\b/i,\n  /\\b\\d+\\s*GODZ/i,\n  // Season/category indicators\n  /^SEZON\\s*:/i,\n  /^KATEGORIA\\s*:/i,\n  /^RODZAJ\\s*:/i,\n  /^PORCJI\\s*:/i,       // Polish serving count\n  /^PORTIONS?\\s*:/i,    // English serving count\n  /^CZ[ĘE]Ś[ĆC]\\s*\\d/i,   // CZĘŚĆ 1: ... (Polish \"Part 1:\")\n  /^PART\\s+\\d/i,             // PART 1: ... (English)\n];\n\n/**\n * Single-word non-title words — standalone OCR fragments unlikely to be recipe titles\n */\nconst NON_TITLE_WORDS = new Set([\n  \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"are\", \"was\",\n  \"has\", \"his\", \"her\", \"its\", \"our\", \"who\", \"how\", \"may\", \"new\", \"now\",\n  \"old\", \"see\", \"way\", \"did\", \"get\", \"let\", \"say\", \"she\", \"too\", \"use\",\n  \"buns\", \"with\",\n]);\n\nfunction looksLikeIngredient(line: string): boolean {\n  const lowerLine = line.toLowerCase();\n  if (MEASUREMENT_PATTERNS.some((pattern) => lowerLine.includes(pattern))) return true;\n  // Compact metric: \"100g\", \"50ml\", \"250g\" — digit immediately followed by g/ml/kg\n  if (/\\b\\d+\\s*(?:g|ml|kg)\\b/i.test(line)) return true;\n  // \"to taste\" / \"do smaku\" — qualitative ingredient with no unit\n  if (/\\bto taste\\b/i.test(line) || /\\bdo smaku\\b/i.test(line)) return true;\n  return false;\n}\n\nfunction startsWithNumber(line: string): boolean {\n  // Match lines starting with a digit, or bullet-then-digit (e.g., \"- 2 jajka\")\n  return /^\\s*(?:[-•*]\\s*)?\\d/.test(line);\n}\n\nfunction stripDiacritics(text: string): string {\n  return text.normalize(\"NFKD\").replace(/[\\u0300-\\u036f]/g, \"\");\n}\n\n/**\n * Known recipe section labels — these are structural headers, not recipe titles.\n * Matched case-insensitively after trimming, stripping trailing punctuation, and stripping diacritics.\n * Polish entries are stored without diacritics for OCR resilience (e.g. \"SKLADNIKI\" matches \"składniki\").\n */\nconst SECTION_LABELS = new Set([\n  // English\n  \"ingredients\", \"directions\", \"instructions\", \"method\", \"preparation\",\n  \"steps\", \"notes\", \"tip\", \"tips\", \"variations\", \"variation\",\n  \"garnish\", \"topping\", \"toppings\", \"frosting\", \"filling\",\n  \"serving suggestion\", \"serving suggestions\", \"serving\",\n  \"glaze\", \"for the sauce\", \"for the filling\", \"for the dough\",\n  \"for the topping\", \"for the glaze\", \"for the pasta dough\",\n  \"for the pasta\", \"for the crust\",\n  // Polish — recipe section labels (stored without diacritics for OCR resilience)\n  \"skladniki\", \"przygotowanie\", \"sposob przygotowania\", \"sposob wykonania\",\n  \"wykonanie\", \"wskazowki\", \"podpowiedz\", \"warianty\",\n  \"sos\", \"nadzienie\", \"polewa\", \"lukier\", \"ciasto\",  // ciasto = dough/pastry base (recipe-internal section AND chapter label)\n  \"instrukcje\",       // instructions\n  \"uwagi\",            // notes/remarks\n  \"notatki\",          // notes\n  \"podawanie\",        // serving\n  \"przechowywanie\",   // storage\n  // Polish — recipe-book chapter/category labels (food groups, meal types)\n  \"warzywa\",          // vegetables\n  \"mieso\",            // meat (mięso)\n  \"miesa\",            // meats (mięsa)\n  \"ryby\",             // fish\n  \"owoce morza\",      // seafood\n  \"zupy\",             // soups\n  \"salatki\",          // salads (sałatki)\n  \"desery\",           // desserts\n  \"napoje\",           // drinks\n  \"pieczywo\",         // bread/baked goods\n  \"przekaski\",        // appetizers/snacks\n  \"sniadania\",        // breakfasts (śniadania)\n  \"obiady\",           // dinners/lunches\n  \"kolacje\",          // suppers\n  \"makarony\",         // pasta dishes\n  \"kasza\",            // groats/grains\n  \"kasze\",            // groats/grains (plural)\n  \"dania glowne\",     // main courses (dania główne)\n  \"przystawki\",       // starters\n  \"dodatki\",          // side dishes\n  \"przetwory\",        // preserves\n  \"wypieki\",          // baked goods\n  \"ciasta\",           // cakes (plural)\n  \"ciastka\",          // cookies\n  \"torty\",            // layer cakes\n  // \"placki\" removed — it commonly starts recipe titles like \"Placki Ziemniaczane\", \"Placki Żółte z Kukurydzą\"\n  \"koktajle\",         // cocktails/smoothies\n  // English — recipe-book chapter/category labels\n  \"vegetables\", \"seafood\", \"fish\", \"soups\", \"salads\", \"desserts\",\n  \"appetizers\", \"breads\", \"breakfast\", \"pasta\", \"grains\",\n  \"main courses\", \"side dishes\", \"preserves\", \"baked goods\",\n  \"fish & seafood\", \"soups & broths\", \"desserts & baked goods\",\n  \"meats\", \"poultry\", \"game\",\n]);\n\nfunction isSectionLabel(text: string): boolean {\n  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n  if (SECTION_LABELS.has(normalized)) return true;\n  // OCR variant: leading \"l\" may be OCR-corrupted \"I\" (e.g. \"lngredients\" → \"ingredients\")\n  const ocrNormalized = normalized.replace(/^l/, \"i\");\n  if (ocrNormalized !== normalized && SECTION_LABELS.has(ocrNormalized)) return true;\n  return false;\n}\n\n/**\n * Recipe-internal section labels that should ALWAYS block multi-line joins,\n * even when the combined word count is ≥ 3.\n * Category labels (\"zupy\", \"placki\", etc.) are NOT in this set — they can\n * legitimately start a multi-word recipe title like \"Zupy Zimowe Warzywne\".\n */\nconst ALWAYS_BLOCK_JOIN_LABELS = new Set([\n  \"ingredients\", \"directions\", \"instructions\", \"method\", \"preparation\",\n  \"steps\", \"notes\", \"tip\", \"tips\", \"variations\", \"variation\",\n  \"garnish\", \"topping\", \"toppings\", \"frosting\", \"filling\",\n  \"serving suggestion\", \"serving suggestions\", \"serving\",\n  \"glaze\", \"instrukcje\", \"uwagi\", \"notatki\", \"podawanie\", \"przechowywanie\",\n  \"skladniki\", \"przygotowanie\", \"sposob przygotowania\", \"sposob wykonania\",\n  \"wykonanie\", \"wskazowki\", \"podpowiedz\", \"warianty\",\n  \"sos\", \"nadzienie\", \"polewa\", \"lukier\", \"ciasto\",\n]);\n\nfunction isAlwaysBlockJoinLabel(text: string): boolean {\n  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n  return ALWAYS_BLOCK_JOIN_LABELS.has(normalized);\n}\n\nfunction isAllCaps(line: string): boolean {\n  const letters = line.replace(/[^a-zA-Z]/g, \"\");\n  return letters.length > 0 && letters === letters.toUpperCase();\n}","numLines":200,"startLine":1,"totalLines":1171}}}
