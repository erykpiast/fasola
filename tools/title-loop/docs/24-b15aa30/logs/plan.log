{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NBtkhS4ZU7RfQGaFPLtvSQ","type":"tool_result","content":"<persisted-output>\nOutput too large (66.5KB). Full output saved to: /Users/eryk.napierala/.claude/projects/-Users-eryk-napierala-Projects-fasola/06e30cc2-e666-4ba2-b79a-bd76ce637f9b/tool-results/toolu_01NBtkhS4ZU7RfQGaFPLtvSQ.txt\n\nPreview (first 2KB):\n     1→     1→/**\n     2→     2→ * Title Extraction\n     3→     3→ * Extracts potential recipe title from OCR text using heuristics or semantic embeddings\n     4→     4→ */\n     5→     5→\n     6→     6→import { cosineSimilarity } from \"./embeddings\";\n     7→     7→\n     8→     8→export type EmbedFn = (text: string) => Promise<Array<number>>;\n     9→     9→\n    10→    10→const TITLE_REFERENCE =\n    11→    11→  \"recipe name, dish title, name of the food, nazwa przepisu, nazwa dania\";\n    12→    12→const HEADER_REFERENCE =\n    13→    13→  \"ingredients list, cooking directions, section heading, składniki, przygotowanie, sposób wykonania\";\n    14→    14→const NOISE_REFERENCE =\n    15→    15→  \"page number, table of contents, book footer, garbled text\";\n    16→    16→\n    17→    17→/**\n    18→    18→ * Measurement units commonly found in ingredient lists\n    19→    19→ */\n    20→    20→const MEASUREMENT_PATTERNS = [\n    21→    21→  // English\n    22→    22→  \"cup\",\n    23→    23→  \"cups\",\n    24→    24→  \"tbsp\",\n    25→    25→  \"tsp\",\n    26→    26→  \"tablespoon\",\n    27→    27→  \"teaspoon\",\n    28→    28→  // \"oz\" and \"lb\" are matched with word boundaries in looksLikeIngredient\n    29→    29→  // to avoid false positives (\"oz\" in \"mozzarella\", \"lb\" in \"albacore\")\n    30→    30→  \"gram\",\n    31→    31→  \"grams\",\n    32→    32→  \"kg\",\n    33→    33→  \"ml\",\n    34→    34→  \"liter\",\n    35→    35→  \"pinch\",\n    36→    36→  \"dash\",\n    37→    37→  \"handful\",\n    38→    38→  // Polish\n    39→    39→  \"łyżka\", \"łyżki\", \"łyżek\",           // tablespoon(s)\n    40→    40→  \"łyżeczka\", \"łyżeczki\", \"łyżeczek\",   // teaspoon(s)\n    41→    41→  \"szklanka\", \"szklanki\", \"szklanek\",    // cup(s)\n    42→    42→  \"szczypta\",                            // pinch\n    43→    43→  \"garść\",                               // handful\n    44→    44→  \"opakowanie\", \"opakowania\",            // package(s)\n    45→    45→  \"plasterek\", \"plasterki\",             // slice(s)\n    46→    46→];\n    47→    47→\n...\n</persisted-output>"}]},"parent_tool_use_id":null,"session_id":"06e30cc2-e666-4ba2-b79a-bd76ce637f9b","uuid":"551dc191-dde3-45f7-a56d-804d6df0a00a","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/.claude/projects/-Users-eryk-napierala-Projects-fasola/06e30cc2-e666-4ba2-b79a-bd76ce637f9b/tool-results/toolu_01MFh8yVbKJ8ZiYSJZdkYe1H.txt","content":"     1→/**\n     2→ * Title Extraction\n     3→ * Extracts potential recipe title from OCR text using heuristics or semantic embeddings\n     4→ */\n     5→\n     6→import { cosineSimilarity } from \"./embeddings\";\n     7→\n     8→export type EmbedFn = (text: string) => Promise<Array<number>>;\n     9→\n    10→const TITLE_REFERENCE =\n    11→  \"recipe name, dish title, name of the food, nazwa przepisu, nazwa dania\";\n    12→const HEADER_REFERENCE =\n    13→  \"ingredients list, cooking directions, section heading, składniki, przygotowanie, sposób wykonania\";\n    14→const NOISE_REFERENCE =\n    15→  \"page number, table of contents, book footer, garbled text\";\n    16→\n    17→/**\n    18→ * Measurement units commonly found in ingredient lists\n    19→ */\n    20→const MEASUREMENT_PATTERNS = [\n    21→  // English\n    22→  \"cup\",\n    23→  \"cups\",\n    24→  \"tbsp\",\n    25→  \"tsp\",\n    26→  \"tablespoon\",\n    27→  \"teaspoon\",\n    28→  // \"oz\" and \"lb\" are matched with word boundaries in looksLikeIngredient\n    29→  // to avoid false positives (\"oz\" in \"mozzarella\", \"lb\" in \"albacore\")\n    30→  \"gram\",\n    31→  \"grams\",\n    32→  \"kg\",\n    33→  \"ml\",\n    34→  \"liter\",\n    35→  \"pinch\",\n    36→  \"dash\",\n    37→  \"handful\",\n    38→  // Polish\n    39→  \"łyżka\", \"łyżki\", \"łyżek\",           // tablespoon(s)\n    40→  \"łyżeczka\", \"łyżeczki\", \"łyżeczek\",   // teaspoon(s)\n    41→  \"szklanka\", \"szklanki\", \"szklanek\",    // cup(s)\n    42→  \"szczypta\",                            // pinch\n    43→  \"garść\",                               // handful\n    44→  \"opakowanie\", \"opakowania\",            // package(s)\n    45→  \"plasterek\", \"plasterki\",             // slice(s)\n    46→];\n    47→\n    48→/**\n    49→ * Patterns that identify recipe metadata lines (not titles)\n    50→ */\n    51→const METADATA_PATTERNS = [\n    52→  /^(SERVES?|MAKES?|YIELDS?)\\b/i,\n    53→  /^(PREP(ARATION)?|COOK(ING)?|PROOF|RISING|FERMENTATION|REST(ING)?)\\s*(AND\\s*)?(COOK(ING)?)?\\s*TIME/i,\n    54→  /^SAMPLE\\s+SCHEDULE\\b/i,\n    55→  /^BULK\\s+FERMENTATION\\b/i,\n    56→  /^(THIS\\s+RECIPE\\s+)?MAKES\\b/i,\n    57→  // Polish serving-size patterns: \"NA 3 PAPRYKI\", \"NA OKOŁO 1 KG\", \"DLA 4 OSÓB\"\n    58→  /^NA\\s+(\\d|OKOŁO)\\b/i,\n    59→  /^DLA\\s+\\d/i,\n    60→  // OCR-resilient: \"DLA\" + any token + serving-unit word (handles DLA & OSOB, DLA § OSOB, etc.)\n    61→  /^DLA\\s+\\S+\\s+OSOB/i,\n    62→  // OCR-resilient: \"DLA\" + single non-alphanumeric char (common digit→symbol OCR error)\n    63→  /^DLA\\s+[^a-zA-Z0-9\\s]\\s/i,\n    64→  // Time-unit metadata: any line containing \"N MIN\" or \"N GODZ\" is prep/cook/rest time,\n    65→  // regardless of OCR-corrupted prefix (catches PRZYGOTOWANTE, GOTOMANTE, etc.)\n    66→  /\\b\\d+\\s*MIN\\b/i,\n    67→  /\\b\\d+\\s*GODZ/i,\n    68→  // Season/category indicators\n    69→  /^SEZON\\s*:/i,\n    70→  /^KATEGORIA\\s*:/i,\n    71→  /^RODZAJ\\s*:/i,\n    72→  /^PORCJI\\s*:/i,       // Polish serving count\n    73→  /^PORTIONS?\\s*:/i,    // English serving count\n    74→  /^CZ[ĘE]Ś[ĆC]\\s*\\d/i,   // CZĘŚĆ 1: ... (Polish \"Part 1:\")\n    75→  /^PART\\s+\\d/i,             // PART 1: ... (English)\n    76→];\n    77→\n    78→/**\n    79→ * Single-word non-title words — standalone OCR fragments unlikely to be recipe titles\n    80→ */\n    81→const NON_TITLE_WORDS = new Set([\n    82→  \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"are\", \"was\",\n    83→  \"has\", \"his\", \"her\", \"its\", \"our\", \"who\", \"how\", \"may\", \"new\", \"now\",\n    84→  \"old\", \"see\", \"way\", \"did\", \"get\", \"let\", \"say\", \"she\", \"too\", \"use\",\n    85→  \"buns\", \"with\",\n    86→]);\n    87→\n    88→function looksLikeIngredient(line: string): boolean {\n    89→  const lowerLine = line.toLowerCase();\n    90→  if (MEASUREMENT_PATTERNS.some((pattern) => lowerLine.includes(pattern))) return true;\n    91→  // Compact metric: \"100g\", \"50ml\", \"250g\" — digit immediately followed by g/ml/kg\n    92→  if (/\\b\\d+\\s*(?:g|ml|kg)\\b/i.test(line)) return true;\n    93→  // \"to taste\" / \"do smaku\" — qualitative ingredient with no unit\n    94→  if (/\\bto taste\\b/i.test(line) || /\\bdo smaku\\b/i.test(line)) return true;\n    95→  return false;\n    96→}\n    97→\n    98→function startsWithNumber(line: string): boolean {\n    99→  // Match lines starting with a digit, or bullet-then-digit (e.g., \"- 2 jajka\")\n   100→  return /^\\s*(?:[-•*]\\s*)?\\d/.test(line);\n   101→}\n   102→\n   103→function stripDiacritics(text: string): string {\n   104→  return text.normalize(\"NFKD\").replace(/[\\u0300-\\u036f]/g, \"\");\n   105→}\n   106→\n   107→/**\n   108→ * Known recipe section labels — these are structural headers, not recipe titles.\n   109→ * Matched case-insensitively after trimming, stripping trailing punctuation, and stripping diacritics.\n   110→ * Polish entries are stored without diacritics for OCR resilience (e.g. \"SKLADNIKI\" matches \"składniki\").\n   111→ */\n   112→const SECTION_LABELS = new Set([\n   113→  // English\n   114→  \"ingredients\", \"directions\", \"instructions\", \"method\", \"preparation\",\n   115→  \"steps\", \"notes\", \"tip\", \"tips\", \"variations\", \"variation\",\n   116→  \"garnish\", \"topping\", \"toppings\", \"frosting\", \"filling\",\n   117→  \"serving suggestion\", \"serving suggestions\", \"serving\",\n   118→  \"glaze\", \"for the sauce\", \"for the filling\", \"for the dough\",\n   119→  \"for the topping\", \"for the glaze\", \"for the pasta dough\",\n   120→  \"for the pasta\", \"for the crust\",\n   121→  // Polish — recipe section labels (stored without diacritics for OCR resilience)\n   122→  \"skladniki\", \"przygotowanie\", \"sposob przygotowania\", \"sposob wykonania\",\n   123→  \"wykonanie\", \"wskazowki\", \"podpowiedz\", \"warianty\",\n   124→  \"sos\", \"nadzienie\", \"polewa\", \"lukier\", \"ciasto\",  // ciasto = dough/pastry base (recipe-internal section AND chapter label)\n   125→  \"instrukcje\",       // instructions\n   126→  \"uwagi\",            // notes/remarks\n   127→  \"notatki\",          // notes\n   128→  \"podawanie\",        // serving\n   129→  \"przechowywanie\",   // storage\n   130→  // Polish — recipe-book chapter/category labels (food groups, meal types)\n   131→  \"warzywa\",          // vegetables\n   132→  \"mieso\",            // meat (mięso)\n   133→  \"miesa\",            // meats (mięsa)\n   134→  \"ryby\",             // fish\n   135→  \"owoce morza\",      // seafood\n   136→  \"zupy\",             // soups\n   137→  \"salatki\",          // salads (sałatki)\n   138→  \"desery\",           // desserts\n   139→  \"napoje\",           // drinks\n   140→  \"pieczywo\",         // bread/baked goods\n   141→  \"przekaski\",        // appetizers/snacks\n   142→  \"sniadania\",        // breakfasts (śniadania)\n   143→  \"obiady\",           // dinners/lunches\n   144→  \"kolacje\",          // suppers\n   145→  \"makarony\",         // pasta dishes\n   146→  \"kasza\",            // groats/grains\n   147→  \"kasze\",            // groats/grains (plural)\n   148→  \"dania glowne\",     // main courses (dania główne)\n   149→  \"przystawki\",       // starters\n   150→  \"dodatki\",          // side dishes\n   151→  \"przetwory\",        // preserves\n   152→  \"wypieki\",          // baked goods\n   153→  \"ciasta\",           // cakes (plural)\n   154→  \"ciastka\",          // cookies\n   155→  \"torty\",            // layer cakes\n   156→  // \"placki\" removed — it commonly starts recipe titles like \"Placki Ziemniaczane\", \"Placki Żółte z Kukurydzą\"\n   157→  \"koktajle\",         // cocktails/smoothies\n   158→  // English — recipe-book chapter/category labels\n   159→  \"vegetables\", \"seafood\", \"fish\", \"soups\", \"salads\", \"desserts\",\n   160→  \"appetizers\", \"breads\", \"breakfast\", \"pasta\", \"grains\",\n   161→  \"main courses\", \"side dishes\", \"preserves\", \"baked goods\",\n   162→  \"fish & seafood\", \"soups & broths\", \"desserts & baked goods\",\n   163→  \"meats\", \"poultry\", \"game\",\n   164→]);\n   165→\n   166→function isSectionLabel(text: string): boolean {\n   167→  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n   168→  if (SECTION_LABELS.has(normalized)) return true;\n   169→  // OCR variant: leading \"l\" may be OCR-corrupted \"I\" (e.g. \"lngredients\" → \"ingredients\")\n   170→  const ocrNormalized = normalized.replace(/^l/, \"i\");\n   171→  if (ocrNormalized !== normalized && SECTION_LABELS.has(ocrNormalized)) return true;\n   172→  return false;\n   173→}\n   174→\n   175→/**\n   176→ * Recipe-internal section labels that should ALWAYS block multi-line joins,\n   177→ * even when the combined word count is ≥ 3.\n   178→ * Category labels (\"zupy\", \"placki\", etc.) are NOT in this set — they can\n   179→ * legitimately start a multi-word recipe title like \"Zupy Zimowe Warzywne\".\n   180→ */\n   181→const ALWAYS_BLOCK_JOIN_LABELS = new Set([\n   182→  \"ingredients\", \"directions\", \"instructions\", \"method\", \"preparation\",\n   183→  \"steps\", \"notes\", \"tip\", \"tips\", \"variations\", \"variation\",\n   184→  \"garnish\", \"topping\", \"toppings\", \"frosting\", \"filling\",\n   185→  \"serving suggestion\", \"serving suggestions\", \"serving\",\n   186→  \"glaze\", \"instrukcje\", \"uwagi\", \"notatki\", \"podawanie\", \"przechowywanie\",\n   187→  \"skladniki\", \"przygotowanie\", \"sposob przygotowania\", \"sposob wykonania\",\n   188→  \"wykonanie\", \"wskazowki\", \"podpowiedz\", \"warianty\",\n   189→  \"sos\", \"nadzienie\", \"polewa\", \"lukier\", \"ciasto\",\n   190→]);\n   191→\n   192→function isAlwaysBlockJoinLabel(text: string): boolean {\n   193→  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n   194→  return ALWAYS_BLOCK_JOIN_LABELS.has(normalized);\n   195→}\n   196→\n   197→function isAllCaps(line: string): boolean {\n   198→  const letters = line.replace(/[^a-zA-Z]/g, \"\");\n   199→  return letters.length > 0 && letters === letters.toUpperCase();\n   200→}\n   201→\n   202→function looksLikeMetadata(text: string): boolean {\n   203→  return METADATA_PATTERNS.some((pattern) => pattern.test(text.trim()));\n   204→}\n   205→\n   206→function isLikelyGarbled(text: string): boolean {\n   207→  const letters = text.replace(/[^a-zA-Z]/g, \"\");\n   208→  if (letters.length < 2) return true;\n   209→\n   210→  // Check vowel ratio — English/Polish text typically has 30–50% vowels\n   211→  const vowels = letters.replace(/[^aeiouAEIOUyYąęóĄĘÓ]/g, \"\").length;\n   212→  const vowelRatio = vowels / letters.length;\n   213→  if (vowelRatio < 0.10 || vowelRatio > 0.85) return true;\n   214→\n   215→  // Single orphaned word ≤3 letters that isn't a common word\n   216→  const words = text.trim().split(/\\s+/);\n   217→  const COMMON_SHORT = new Set([\n   218→    \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"had\", \"her\",\n   219→    \"was\", \"one\", \"our\", \"out\", \"are\", \"has\", \"his\", \"how\", \"its\", \"may\",\n   220→    \"new\", \"now\", \"old\", \"see\", \"way\", \"who\", \"did\", \"get\", \"let\", \"say\",\n   221→    \"she\", \"too\", \"use\",\n   222→  ]);\n   223→  // Count all Unicode letters (not just ASCII) so Polish words like \"Żur\" (3 letters) pass\n   224→  const unicodeLetters = text.trim().replace(/[^a-zA-ZąćęłńóśźżĄĆĘŁŃÓŚŹŻ]/g, \"\");\n   225→  if (words.length === 1 && unicodeLetters.length <= 3 && !COMMON_SHORT.has(text.trim().toLowerCase())) {\n   226→    return true;\n   227→  }\n   228→\n   229→  // Single word with internal lowercase→uppercase transition — OCR noise (e.g., \"UuIw\", \"aBC\")\n   230→  // No recipe title uses this pattern as a standalone single-word candidate.\n   231→  if (words.length === 1 && /[a-z][A-Z]/.test(text.trim())) {\n   232→    return true;\n   233→  }\n   234→\n   235→  // Recipe titles never start with a lowercase letter\n   236→  if (/^[a-z]/.test(text.trim())) {\n   237→    return true;\n   238→  }\n   239→\n   240→  // Mid-text sentence boundary (\". \" followed by a letter) — body text fragment spliced from multiple sentences\n   241→  const trimmed = text.trim();\n   242→  if (/\\.\\s+[a-zA-Z]/.test(trimmed) && !trimmed.endsWith(\")\")) {\n   243→    return true;\n   244→  }\n   245→\n   246→  // Multi-word candidate containing a garbled OCR fragment: a short lowercase word that isn't a known short word\n   247→  if (words.length >= 2) {\n   248→    const commonShort2 = new Set([\n   249→      \"a\", \"i\", \"of\", \"or\", \"to\", \"in\", \"on\", \"is\", \"it\", \"an\",\n   250→      \"as\", \"at\", \"by\", \"do\", \"go\", \"if\", \"no\", \"so\", \"up\", \"we\",\n   251→      \"w\", \"z\",   // Polish prepositions (basic)\n   252→      \"ze\", \"bo\", \"na\", \"ni\", \"po\", \"ku\", \"od\", \"za\", \"co\",  // Polish prepositions (extended)\n   253→    ]);\n   254→    const hasGarbledWord = words.some(\n   255→      (w) =>\n   256→        /^[a-z]/.test(w) &&\n   257→        w.replace(/[^a-z]/g, \"\").length <= 2 &&\n   258→        !commonShort2.has(w.toLowerCase())\n   259→    );\n   260→    if (hasGarbledWord) {\n   261→      return true;\n   262→    }\n   263→  }\n   264→\n   265→  return false;\n   266→}\n   267→\n   268→const COOKING_INSTRUCTION_STARTS = /^(beat|fold|stir|mix|add|pour|bake|cook|cool|remove|place|combine|whisk|knead|roll|spread|brush|slice|chop|dice|mince|drain|rinse|peel|grate|melt|simmer|boil|fry|sauté|saute|roast|grill|broil|steam|let|set|transfer|serve|garnish|arrange|sprinkle|season|preheat|cover|uncover|reduce|bring|toss|cut|trim|shape|form)\\b/i;\n   269→\n   270→// Polish imperative cooking verbs (with OCR-resilient forms — no diacritics required).\n   271→// These cover the most common recipe instruction starters. Includes common OCR-corrupted\n   272→// forms (e.g., \"Smaż\" → \"Smaz\", \"Dodaj\" → \"Dodaj\").\n   273→// Note: only verbs that NEVER start a recipe title. \"Piecz\" (bake) is excluded because\n   274→// \"Pieczeń\" (roast) and \"Pieczarki\" (mushrooms) share the prefix.\n   275→const POLISH_COOKING_INSTRUCTION_STARTS = /^(podawaj|dodaj|dodawaj|sma[zż]|gotuj|odced[zź]|wymieszaj|mieszaj|wlej|nalej|przygotuj|zagotuj|pokr[oó]j|obierz|wrzuc|wrzuć|usma[zż]|podsma[zż]|prze[lł][oó][zż]|zblenduj|ubij|roztrzepaj|rozprowad[zź]|wyrob|zamieszaj|posyp|polej|odstaw|na[lł][oó][zż]|przykryj|odkryj|wstaw|zdejmij|ods[aą]cz|rozgrzej|posiekaj|zetrzyj|wy[lł][oó][zż]|wyjmij|ukr[oó]j|przekr[oó]j|formuj|ugniataj|rozwałkuj)\\b/i;\n   276→\n   277→function looksLikeCookingInstruction(text: string): boolean {\n   278→  const words = text.trim().split(/\\s+/);\n   279→  if (words.length < 4) return false;  // Instructions are multi-word sentences\n   280→  if (COOKING_INSTRUCTION_STARTS.test(text.trim())) return true;\n   281→  if (POLISH_COOKING_INSTRUCTION_STARTS.test(text.trim())) return true;\n   282→  return false;\n   283→}\n   284→\n   285→function passesHardFilters(text: string): boolean {\n   286→  if (text.length < 3 || text.length > 80) return false;\n   287→  if (looksLikeIngredient(text)) return false;\n   288→  if (startsWithNumber(text)) return false;\n   289→  if (looksLikeMetadata(text)) return false;\n   290→  if (isLikelyGarbled(text)) return false;\n   291→  if (looksLikeCookingInstruction(text)) return false;\n   292→  // Pipe-separated lines are book category/chapter headers, not recipe titles\n   293→  if (text.includes(\" | \")) return false;\n   294→  // Trailing page number (e.g. \"VEGETABLE SIDES                         145\")\n   295→  if (/\\s{3,}\\d{1,4}\\s*$/.test(text)) return false;\n   296→  // Slash-separated breadcrumbs (e.g., \"/ Jesien / Zupy\") are navigation, not titles\n   297→  // Only filter when 2+ slashes are present — single-slash lines like\n   298→  // \"TITLE / SUBTITLE\" are legitimate continuation-merged titles\n   299→  if ((text.match(/\\//g) || []).length >= 2) return false;\n   300→  // Bullet-list items (ingredients or instruction steps) are never titles\n   301→  if (/^\\s*[-•*]\\s/.test(text)) return false;\n   302→  // \"For the sauce:\", \"For the filling:\" etc. are sub-section headers\n   303→  if (/^For the\\s+/i.test(text) && /:\\s*$/.test(text)) return false;\n   304→  // Lines ending with \":\" are recipe sub-section headers, not titles.\n   305→  // Exception: compound titles using \" : \" as a title separator (e.g. \"LEMON CURD : LEMON CURD WITH THYME\").\n   306→  if (/:\\s*$/.test(text.trim()) && !/ : /.test(text)) return false;\n   307→  // Page references are navigation markers, not recipe titles\n   308→  if (/^Page\\s+\\d+/i.test(text.trim())) return false;\n   309→  if (/^Strona\\s+\\d+/i.test(text.trim())) return false;\n   310→  // Corrupted spillover annotations from synthetic multi-page OCR\n   311→  if (/^\\[CORRUPTED\\s+SPILLOVER/i.test(text.trim())) return false;\n   312→  // Parenthetical OCR annotation lines describing corruption artifacts\n   313→  if (/^\\(OCR\\b/i.test(text.trim())) return false;\n   314→  if (/^\\(.*\\bcorruption\\b/i.test(text.trim())) return false;\n   315→  // Square-bracket category tags (e.g., \"[CLASSIC FALL SOUPS]\")\n   316→  if (/^\\[.*\\]$/.test(text.trim())) return false;\n   317→  // Known recipe section labels are structural headers, not titles\n   318→  if (isSectionLabel(text)) return false;\n   319→  // Single-word non-title fragments\n   320→  const words = text.trim().split(/\\s+/);\n   321→  if (words.length === 1 && NON_TITLE_WORDS.has(text.trim().toLowerCase())) return false;\n   322→  // Lines with ≥8 words are almost certainly body text, not titles.\n   323→  // Exception: multi-title compounds with \" + \", \" : \", or \" & \" separators are allowed.\n   324→  if (words.length >= 8 && !/ [+:&/] /.test(text)) return false;\n   325→  return true;\n   326→}\n   327→\n   328→/**\n   329→ * Detect initial burst of short garbled lines.\n   330→ * Returns the index of the first non-garbled or long line.\n   331→ */\n   332→function findBurstEnd(lines: Array<{ text: string }>): number {\n   333→  let i = 0;\n   334→\n   335→  // Skip overflow preambles: blocks introduced by \"PREVIOUS RECIPE OVERFLOW\",\n   336→  // \"PREVIOUS PAGE CONTENT\", \"CORRUPTED SECTION\", etc. that precede the actual recipe.\n   337→  const OVERFLOW_MARKERS = /\\b(PREVIOUS\\s+(RECIPE|PAGE)\\s+(OVERFLOW|CONTENT)|SPILLOVER|CONTINUATION|CORRUPTED\\s+SECTION)\\b/i;\n   338→  let overflowEnd = 0;\n   339→  for (let k = 0; k < lines.length && k < 30; k++) {\n   340→    if (OVERFLOW_MARKERS.test(lines[k].text)) {\n   341→      // Skip forward past the overflow block to the next visual separator or blank cluster\n   342→      let m = k + 1;\n   343→      while (m < lines.length) {\n   344→        if (/^[=\\-]{4,}$/.test(lines[m].text) || lines[m].text.length === 0) {\n   345→          overflowEnd = m + 1;\n   346→          break;\n   347→        }\n   348→        m++;\n   349→      }\n   350→      if (overflowEnd === 0) overflowEnd = k + 1;\n   351→    }\n   352→  }\n   353→  if (overflowEnd > 0) i = overflowEnd;\n   354→\n   355→  while (i < lines.length && lines[i].text.length < 20 && isLikelyGarbled(lines[i].text) && !isAllCaps(lines[i].text)) {\n   356→    i++;\n   357→  }\n   358→  // Skip long instruction-like prologues: if 5+ consecutive lines look like cooking instructions,\n   359→  // skip them to find the actual title region.\n   360→  if (i === 0) {\n   361→    let j = 0;\n   362→    while (j < lines.length && looksLikeCookingInstruction(lines[j].text)) {\n   363→      j++;\n   364→    }\n   365→    if (j >= 5) {\n   366→      i = j;\n   367→    }\n   368→  }\n   369→  // Skip prose prologues: mid-recipe body text before the actual title.\n   370→  // If 3+ consecutive lines look like running body text (lowercase start, continuation,\n   371→  // or sentence-ending with many words), skip them.\n   372→  if (i === 0) {\n   373→    let j = 0;\n   374→    while (j < lines.length) {\n   375→      const t = lines[j].text;\n   376→      const isBodyText = (\n   377→        /^[a-ząćęłńóśźż]/.test(t) ||\n   378→        t.endsWith(\",\") ||\n   379→        (t.endsWith(\".\") && wordCount(t) > 4)\n   380→      ) && wordCount(t) >= 4;\n   381→      if (isBodyText) j++;\n   382→      else break;\n   383→    }\n   384→    if (j >= 3) i = j;\n   385→  }\n   386→  return i;\n   387→}\n   388→\n   389→function stripParentheticalGloss(text: string): string {\n   390→  // Strip trailing English-gloss parentheticals from ALL_CAPS titles.\n   391→  // e.g. \"PIEROGI RUSKIE (Boiled Dumplings with Potato and Cheese)\" → \"PIEROGI RUSKIE\"\n   392→  // Keep if parenthetical is ALL_CAPS (variation/subtitle in same language).\n   393→  // Keep if both base and paren are mixed-case (both are part of the title).\n   394→  const match = text.match(/^(.+?)\\s*\\(([^)]+)\\)\\s*$/);\n   395→  if (!match) return text;\n   396→  const [, base, paren] = match;\n   397→  if (isAllCaps(paren)) return text;\n   398→  if (!isAllCaps(base) && !isAllCaps(paren)) return text;\n   399→  return base.trim();\n   400→}\n   401→\n   402→function stripPageNumber(text: string): string {\n   403→  // \"34  Berry Jam\" → \"Berry Jam\" (2+ spaces distinguishes from \"2 eggs\")\n   404→  const match = text.match(/^\\d{1,3}\\s{2,}(.+)$/);\n   405→  return match ? match[1] : text;\n   406→}\n   407→\n   408→function wordCount(text: string): number {\n   409→  return text.split(/\\s+/).filter((w) => w.length > 0).length;\n   410→}\n   411→\n   412→/**\n   413→ * Build candidate strings from lines: single lines plus multi-line joins (2-3 consecutive).\n   414→ * Skips initial burst of short garbled lines. Scans all remaining lines. Caps at 25.\n   415→ */\n   416→export type CandidateOrigin = \"single\" | \"2-line\" | \"3-line\";\n   417→\n   418→function buildCandidates(\n   419→  lines: Array<string>\n   420→): Array<{ text: string; position: number; origin: CandidateOrigin }> {\n   421→  const nonEmptyLines: Array<{ text: string; index: number }> = [];\n   422→\n   423→  for (let i = 0; i < lines.length; i++) {\n   424→    const trimmed = lines[i].trim();\n   425→    if (trimmed.length > 0) {\n   426→      nonEmptyLines.push({ text: trimmed, index: i });\n   427→    }\n   428→  }\n   429→\n   430→  const burstEnd = findBurstEnd(nonEmptyLines);\n   431→\n   432→  // Pre-join hyphen-broken lines: \"ROASTED CHICKEN WITH ROOT VEGET-\" + \"ABLES\" → single line.\n   433→  // Only applies within the candidate region (after burst end).\n   434→  for (let hi = burstEnd; hi < nonEmptyLines.length - 1; hi++) {\n   435→    if (nonEmptyLines[hi].text.endsWith(\"-\")) {\n   436→      const joined = nonEmptyLines[hi].text.slice(0, -1) + nonEmptyLines[hi + 1].text;\n   437→      nonEmptyLines[hi] = { text: joined, index: nonEmptyLines[hi].index };\n   438→      nonEmptyLines.splice(hi + 1, 1);\n   439→    }\n   440→  }\n   441→\n   442→  // Pre-merge consecutive short ALL_CAPS lines (OCR-fragmented headings).\n   443→  // When a sequence of 2+ ALL_CAPS lines each has ≤2 words and ≤25 chars, they are\n   444→  // almost certainly OCR fragments of a single heading. Merge them into one line so\n   445→  // the complete title enters the candidate pool without hitting the 3-line join ceiling.\n   446→  const capsCoalesced: Array<{ text: string; index: number }> = [];\n   447→  let ci = burstEnd;\n   448→  while (ci < nonEmptyLines.length) {\n   449→    const line = nonEmptyLines[ci];\n   450→    if (\n   451→      isAllCaps(line.text) &&\n   452→      wordCount(line.text) <= 2 &&\n   453→      line.text.length <= 25 &&\n   454→      !isSectionLabel(line.text) &&\n   455→      !looksLikeMetadata(line.text)\n   456→    ) {\n   457→      let merged = line.text;\n   458→      const startIndex = line.index;\n   459→      let j = ci + 1;\n   460→      while (j < nonEmptyLines.length) {\n   461→        const next = nonEmptyLines[j];\n   462→        if (\n   463→          isAllCaps(next.text) &&\n   464→          wordCount(next.text) <= 2 &&\n   465→          next.text.length <= 25 &&\n   466→          !isSectionLabel(next.text) &&\n   467→          !looksLikeMetadata(next.text) &&\n   468→          (merged + \" \" + next.text).length <= 80\n   469→        ) {\n   470→          merged += \" \" + next.text;\n   471→          j++;\n   472→        } else {\n   473→          break;\n   474→        }\n   475→      }\n   476→      if (j > ci + 1) {\n   477→        capsCoalesced.push({ text: merged, index: startIndex });\n   478→        ci = j;\n   479→        continue;\n   480→      }\n   481→    }\n   482→    capsCoalesced.push(line);\n   483→    ci++;\n   484→  }\n   485→\n   486→  // Pre-merge continuation lines: a line starting with /&+:( is never a standalone title.\n   487→  // Merge it into the preceding line so the complete title enters the pool as a single candidate,\n   488→  // avoiding the fragile chain of conditions required by the downstream join survival logic.\n   489→  // Limitation: only one continuation line per preceding line is merged. Titles split across\n   490→  // three or more lines with continuation tokens (rare in practice) are not handled here —\n   491→  // the downstream 2-line and 3-line join candidates cover those cases instead.\n   492→  const mergedLines: Array<{ text: string; index: number }> = [];\n   493→  for (let i = 0; i < capsCoalesced.length; i++) {\n   494→    const line = capsCoalesced[i];\n   495→    if (i + 1 < capsCoalesced.length) {\n   496→      const nextText = capsCoalesced[i + 1].text;\n   497→      if (/^[/&+:(]/.test(nextText)) {\n   498→        mergedLines.push({ text: `${line.text} ${nextText}`, index: line.index });\n   499→        i++;\n   500→        continue;\n   501→      }\n   502→    }\n   503→    mergedLines.push(line);\n   504→  }\n   505→\n   506→  const candidates: Array<{ text: string; position: number; origin: CandidateOrigin }> = [];\n   507→  const seen = new Set<string>();\n   508→\n   509→  // Build a set of positions to skip: short ALL_CAPS lines immediately following metadata\n   510→  const metadataContinuationPositions = new Set<number>();\n   511→  for (let i = 0; i < mergedLines.length - 1; i++) {\n   512→    if (looksLikeMetadata(mergedLines[i].text)) {\n   513→      const next = mergedLines[i + 1];\n   514→      if (isAllCaps(next.text) && wordCount(next.text) <= 2 && next.text.length <= 15) {\n   515→        metadataContinuationPositions.add(next.index);\n   516→      }\n   517→    }\n   518→  }\n   519→\n   520→  for (let i = 0; i < mergedLines.length; i++) {\n   521→    const line = mergedLines[i];\n   522→\n   523→    // Skip metadata continuation fragments\n   524→    if (metadataContinuationPositions.has(line.index)) continue;\n   525→\n   526→    // Single line — strip page-number prefixes and parenthetical glosses before scoring\n   527→    const singleText = stripParentheticalGloss(stripPageNumber(line.text));\n   528→    if (passesHardFilters(singleText)) {\n   529→      const norm = singleText.toLowerCase();\n   530→      if (!seen.has(norm)) {\n   531→        seen.add(norm);\n   532→        candidates.push({ text: singleText, position: line.index, origin: \"single\" });\n   533→      }\n   534→    }\n   535→\n   536→    // 2-line join — skip if first line is a section label AND join would be ≤2 words\n   537→    // (a section label followed by modifiers is likely a recipe title, not a category header)\n   538→    if (i + 1 < mergedLines.length) {\n   539→      const joined2 = `${line.text} ${mergedLines[i + 1].text}`;\n   540→      const shouldBlock2 = isSectionLabel(line.text) &&\n   541→        (wordCount(joined2) <= 2 || isAlwaysBlockJoinLabel(line.text));\n   542→      if (!shouldBlock2 && passesHardFilters(joined2)) {\n   543→        const norm = joined2.toLowerCase();\n   544→        if (!seen.has(norm)) {\n   545→          seen.add(norm);\n   546→          candidates.push({ text: joined2, position: line.index, origin: \"2-line\" });\n   547→        }\n   548→      }\n   549→    }\n   550→\n   551→    // 3-line join — skip if first line is a section label AND join would be ≤2 words\n   552→    if (i + 2 < mergedLines.length) {\n   553→      const joined3 = `${line.text} ${mergedLines[i + 1].text} ${mergedLines[i + 2].text}`;\n   554→      const shouldBlock3 = isSectionLabel(line.text) &&\n   555→        (wordCount(joined3) <= 2 || isAlwaysBlockJoinLabel(line.text));\n   556→      if (!shouldBlock3 && passesHardFilters(joined3)) {\n   557→        const norm = joined3.toLowerCase();\n   558→        if (!seen.has(norm)) {\n   559→          seen.add(norm);\n   560→          candidates.push({ text: joined3, position: line.index, origin: \"3-line\" });\n   561→        }\n   562→      }\n   563→    }\n   564→  }\n   565→\n   566→  // Pre-filter to 25 before embedding calls: prefer ALL_CAPS and short candidates.\n   567→  // Position-based scoring handles final ranking.\n   568→  if (candidates.length > 25) {\n   569→    const prioritized = candidates.slice().sort((a, b) => {\n   570→      const aAllCaps = isAllCaps(a.text) ? 0 : 1;\n   571→      const bAllCaps = isAllCaps(b.text) ? 0 : 1;\n   572→      if (aAllCaps !== bAllCaps) return aAllCaps - bAllCaps;\n   573→      const aShort = wordCount(a.text) <= 5 ? 0 : 1;\n   574→      const bShort = wordCount(b.text) <= 5 ? 0 : 1;\n   575→      return aShort - bShort;\n   576→    });\n   577→    return prioritized.slice(0, 25);\n   578→  }\n   579→\n   580→  return candidates;\n   581→}\n   582→\n   583→/**\n   584→ * Convert an ALL_CAPS string to Title Case, using a small-words list.\n   585→ * Preserves Polish/French diacritics.\n   586→ */\n   587→function toTitleCase(text: string): string {\n   588→  const smallWords = new Set([\n   589→    \"a\", \"an\", \"the\", \"and\", \"but\", \"or\", \"for\", \"nor\",\n   590→    \"in\", \"on\", \"at\", \"to\", \"of\", \"by\", \"with\", \"from\",\n   591→    \"z\", \"w\", \"i\", \"ze\", \"na\", \"do\", \"od\", \"za\", \"po\",\n   592→  ]);\n   593→  return text.split(/(\\s+)/).map((word, idx) => {\n   594→    if (/^\\s+$/.test(word)) return word;\n   595→    const lower = word.toLowerCase();\n   596→    if (idx === 0 || !smallWords.has(lower)) {\n   597→      return lower.charAt(0).toUpperCase() + lower.slice(1);\n   598→    }\n   599→    return lower;\n   600→  }).join(\"\");\n   601→}\n   602→\n   603→/**\n   604→ * Post-processing normalization for OCR-extracted titles.\n   605→ * Strips stray section markers and substitutes common OCR digit-for-letter artifacts.\n   606→ * Title-case conversion is applied only when a substitution was actually made, so\n   607→ * clean ALL_CAPS titles (e.g. \"CHOCOLATE CAKE\") are returned unchanged.\n   608→ */\n   609→function normalizeOcrTitle(raw: string): string {\n   610→  let text = raw;\n   611→\n   612→  // Step 1: Strip trailing section markers greedily appended to the title.\n   613→  // e.g. \"MAKOWIEC ZE ŚLIWKAMI + SERVING AND STORAGE:\" → \"MAKOWIEC ZE ŚLIWKAMI\"\n   614→  text = text.replace(\n   615→    /\\s*\\+\\s*(?:SERV[IÍ1]NG(?:\\s+AND\\s+STORAGE)?|TOPPING|NOTES?|TIPS?)\\s*:?\\s*$/i,\n   616→    \"\"\n   617→  );\n   618→\n   619→  // Step 2: OCR character substitution.\n   620→  // For ALL_CAPS text, apply digit-for-letter substitutions.\n   621→  const beforeSub = text;\n   622→  if (isAllCaps(text)) {\n   623→    text = text\n   624→      .replace(/1/g, \"I\")\n   625→      .replace(/0(?=[A-ZÀ-Ż])/g, \"O\")\n   626→      .replace(/(?<=[A-ZÀ-Ż])0/g, \"O\")\n   627→      .replace(/4(?=[A-ZÀ-Ż])/g, \"A\")\n   628→      .replace(/(?<=[A-ZÀ-Ż])4/g, \"A\")\n   629→      .replace(/5(?=[A-ZÀ-Ż])/g, \"S\")\n   630→      .replace(/(?<=[A-ZÀ-Ż])5/g, \"S\")\n   631→      .replace(/¡/g, \"I\")\n   632→      .replace(/€/g, \"E\")\n   633→      .replace(/[ÍÌ]/g, \"I\");\n   634→  } else {\n   635→    // Mixed-case: fix per-word (digits between lowercase letters)\n   636→    text = text.split(/(\\s+)/).map((token) => {\n   637→      if (/^\\s+$/.test(token)) return token;\n   638→      if (isAllCaps(token) && token.length > 1) {\n   639→        return token\n   640→          .replace(/1/g, \"I\")\n   641→          .replace(/0(?=[A-Z])/g, \"O\")\n   642→          .replace(/(?<=[A-Z])0/g, \"O\");\n   643→      }\n   644→      return token\n   645→        .replace(/(?<=[a-zà-ż])1/g, \"l\")\n   646→        .replace(/1(?=[a-zà-ż])/g, \"l\")\n   647→        .replace(/¡/g, \"i\")\n   648→        .replace(/€/g, \"e\");\n   649→    }).join(\"\");\n   650→  }\n   651→\n   652→  // Step 3: Title-case conversion — ONLY when OCR substitution changed the text.\n   653→  // This preserves clean ALL_CAPS titles (e.g. \"CHOCOLATE CAKE\") as-is.\n   654→  if (text !== beforeSub && isAllCaps(text)) {\n   655→    text = toTitleCase(text);\n   656→  }\n   657→\n   658→  return text.trim();\n   659→}\n   660→\n   661→// Module-level cache for reference embeddings\n   662→let cachedTitleRefEmbedding: Array<number> | null = null;\n   663→let cachedHeaderRefEmbedding: Array<number> | null = null;\n   664→let cachedNoiseRefEmbedding: Array<number> | null = null;\n   665→\n   666→export function _resetEmbeddingCacheForTests(): void {\n   667→  cachedTitleRefEmbedding = null;\n   668→  cachedHeaderRefEmbedding = null;\n   669→  cachedNoiseRefEmbedding = null;\n   670→}\n   671→\n   672→export async function extractTitleWithEmbeddings(\n   673→  text: string,\n   674→  embed: EmbedFn\n   675→): Promise<string | undefined> {\n   676→  if (!text || text.trim().length === 0) {\n   677→    return undefined;\n   678→  }\n   679→\n   680→  const lines = text.split(\"\\n\");\n   681→  const candidates = buildCandidates(lines);\n   682→\n   683→  if (candidates.length === 0) {\n   684→    return undefined;\n   685→  }\n   686→\n   687→  // Cache reference embeddings\n   688→  if (!cachedTitleRefEmbedding) {\n   689→    cachedTitleRefEmbedding = await embed(TITLE_REFERENCE);\n   690→  }\n   691→  if (!cachedHeaderRefEmbedding) {\n   692→    cachedHeaderRefEmbedding = await embed(HEADER_REFERENCE);\n   693→  }\n   694→  if (!cachedNoiseRefEmbedding) {\n   695→    cachedNoiseRefEmbedding = await embed(NOISE_REFERENCE);\n   696→  }\n   697→\n   698→  // Find ALL_CAPS candidates with ≥2 words where every significant word has ≥4 alpha letters.\n   699→  // Insignificant tokens (≤1 alpha letter: \"/\", \"&\", \"+\", \":\", \"D)\", etc.) are filtered before\n   700→  // the check so that multi-line joins with continuation punctuation still qualify.\n   701→  const isStructuralHeading = (c: { text: string }): boolean => {\n   702→    if (!isAllCaps(c.text) || wordCount(c.text) < 2) return false;\n   703→    const sigWords = c.text.trim().split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length > 1);\n   704→    return sigWords.length >= 2 && sigWords.every((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   705→  };\n   706→\n   707→  // Pass 1: compute rawScore for all candidates (embedding quality signal)\n   708→  const rawScored: Array<{ text: string; position: number; origin: CandidateOrigin; rawScore: number; embedding: Array<number> }> = [];\n   709→  for (const candidate of candidates) {\n   710→    const embedding = await embed(candidate.text);\n   711→    const titleSim = cosineSimilarity(embedding, cachedTitleRefEmbedding);\n   712→    const headerSim = cosineSimilarity(embedding, cachedHeaderRefEmbedding);\n   713→    const noiseSim = cosineSimilarity(embedding, cachedNoiseRefEmbedding);\n   714→    const rawScore = titleSim - Math.max(headerSim, noiseSim);\n   715→    rawScored.push({ text: candidate.text, position: candidate.position, origin: candidate.origin, rawScore, embedding });\n   716→  }\n   717→\n   718→  // Select baseHeading by embedding quality (rawScore), not position.\n   719→  // This prevents OCR-garbled fragments from claiming the structural heading slot.\n   720→  const structuralCandidates = rawScored.filter((s) => isStructuralHeading(s));\n   721→\n   722→  // Penalize structural headings with truncated OCR words:\n   723→  // if \"FRON\" appears and another heading has \"SAFFRON\", \"FRON\" is likely garbled.\n   724→  for (const sc of structuralCandidates) {\n   725→    const sigWords = sc.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   726→    for (const other of structuralCandidates) {\n   727→      if (other === sc) continue;\n   728→      const otherSigWords = other.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   729→      const hasTruncation = sigWords.some((w) =>\n   730→        otherSigWords.some((ow) => ow !== w && ow.length > w.length && ow.endsWith(w))\n   731→      );\n   732→      if (hasTruncation) {\n   733→        sc.rawScore = -1.0;  // Hard disqualification — truncated OCR artifact\n   734→        break;\n   735→      }\n   736→    }\n   737→  }\n   738→\n   739→  const bestStructural = structuralCandidates.length > 0\n   740→    ? structuralCandidates.reduce((a, b) => {\n   741→        const scoreDiff = a.rawScore - b.rawScore;\n   742→        if (Math.abs(scoreDiff) > 0.03) return scoreDiff > 0 ? a : b;\n   743→        // Tiebreak: single-line origin beats multi-line joins (avoids conflating two separate headings)\n   744→        if (a.origin === \"single\" && b.origin !== \"single\") return a;\n   745→        if (b.origin === \"single\" && a.origin !== \"single\") return b;\n   746→        // Tiebreak: more words (more specific) → better\n   747→        const wcDiff = wordCount(b.text) - wordCount(a.text);\n   748→        if (wcDiff !== 0) return wcDiff > 0 ? b : a;\n   749→        // Tiebreak: earlier position → better\n   750→        return a.position < b.position ? a : b;\n   751→      })\n   752→    : null;\n   753→  const baseHeading = bestStructural ?? undefined;\n   754→\n   755→  // When the best structural heading has a continuation on the next line introduced by a\n   756→  // punctuation token (/, &, +, :, or parenthesis), prefer the longer 2-line join as the\n   757→  // complete heading. E.g. \"SAFFRON WHEAT BUNS WITH QUARK\" + \"/ COTTAGE CHEESE (VARIATION D)\".\n   758→  // Guard: the remainder after the prefix must start with a continuation character to avoid\n   759→  // merging two separate consecutive recipe titles (FINNISH MILK FLATBREADS stays separate\n   760→  // from FINNISH POTATO FLATBREADS because \"FINNISH\" does not start with a continuation token).\n   761→  let firstStructuralHeading = baseHeading && (\n   762→    rawScored.find((c) => {\n   763→      if (!isStructuralHeading(c)) return false;\n   764→      const hLower = baseHeading.text.toLowerCase();\n   765→      const cLower = c.text.toLowerCase();\n   766→      return cLower.startsWith(hLower + \" \") && /^[/&+:(]/.test(cLower.slice(hLower.length + 1));\n   767→    }) ?? baseHeading\n   768→  );\n   769→\n   770→  // Pass 2: apply bonuses\n   771→  const scored: Array<{ text: string; position: number; origin: CandidateOrigin; score: number; rawScore: number; baseScore: number; thresholdScore: number }> = rawScored.map((rs) => {\n   772→    // Position factor: multiplicative tiebreaker — amplifies existing signal, doesn't replace it\n   773→    const relativePosition = rs.position / lines.length;\n   774→    const positionFactor = relativePosition < 0.5\n   775→      ? 1.0 + 0.12 * (1 - relativePosition * 2)\n   776→      : 1.0;\n   777→\n   778→    // ALL_CAPS bonus: recipe books use ALL_CAPS for titles and section headings.\n   779→    // Single-word ALL_CAPS terms are overwhelmingly section/category labels, not recipe titles;\n   780→    // real recipe titles in ALL_CAPS are almost always multi-word. Reduce the bonus for single words.\n   781→    const allCapsBonus = isAllCaps(rs.text) && rs.text.replace(/[^a-zA-Z]/g, \"\").length >= 4\n   782→      ? (wordCount(rs.text) >= 2 ? 0.08 : 0.03)\n   783→      : 0;\n   784→\n   785→    // Structural heading bonus: best ALL_CAPS heading (or its continuation join) is almost always the recipe title\n   786→    const structuralBonus = firstStructuralHeading && rs.text === firstStructuralHeading.text ? 0.10 : 0;\n   787→\n   788→    // thresholdScore excludes structural bonus so the bonus doesn't inflate the threshold\n   789→    // and prevent equally-valid structural headings from passing on multi-recipe pages.\n   790→    const thresholdScore = rs.rawScore + allCapsBonus;\n   791→    // baseScore excludes position factor — used for diagnostics and ranking\n   792→    const baseScore = rs.rawScore + allCapsBonus + structuralBonus;\n   793→    const score = rs.rawScore * positionFactor + allCapsBonus + structuralBonus;\n   794→    return { text: rs.text, position: rs.position, origin: rs.origin, score, rawScore: rs.rawScore, baseScore, thresholdScore };\n   795→  });\n   796→\n   797→  if (scored.length === 0) {\n   798→    return undefined;\n   799→  }\n   800→\n   801→  // --- Pre-threshold bilingual title detection ---\n   802→  // When a mixed-case candidate at position 0 is followed by an ALL_CAPS candidate\n   803→  // at position ≤ 2 that is semantically similar to it, this is a bilingual recipe\n   804→  // page (e.g., Polish title + ALL_CAPS Korean romanization). Suppress confirmed\n   805→  // translation candidates before computing threshold so their bonuses don't inflate\n   806→  // the threshold beyond the mixed-case title's reach.\n   807→  // Note: we check position ≤ 2 (local proximity), not global ALL_CAPS count, so\n   808→  // section headers later in the document (SKŁADNIKI, WARZYWA, etc.) are irrelevant.\n   809→  let translationCandidates: typeof scored = [];\n   810→  let scoredForThreshold = scored;\n   811→  const prePos0 = scored.find((s) => s.position === 0 && !isAllCaps(s.text));\n   812→  if (prePos0) {\n   813→    const nearbyAllCaps = scored.filter(\n   814→      (s) => isAllCaps(s.text) && s.position >= 1 && s.position <= 2 && s.origin === \"single\"\n   815→    );\n   816→    const pos0Embedding = rawScored.find((r) => r.text === prePos0.text)?.embedding;\n   817→\n   818→    // Method 1: embedding similarity (works for related languages)\n   819→    if (pos0Embedding && nearbyAllCaps.length > 0) {\n   820→      translationCandidates = nearbyAllCaps.filter((cap) => {\n   821→        const capEmbedding = rawScored.find((r) => r.text === cap.text)?.embedding;\n   822→        if (!capEmbedding) return false;\n   823→        return cosineSimilarity(pos0Embedding, capEmbedding) > 0.4;\n   824→      });\n   825→    }\n   826→\n   827→    // Method 2: layout-based detection (cross-lingual fallback).\n   828→    // When embedding similarity is insufficient (e.g. Polish ↔ Korean romanization),\n   829→    // detect bilingual layout by position and word overlap:\n   830→    // mixed-case ≥2 words at pos 0 + ALL_CAPS ≥2 words at pos 1-2 with no shared words.\n   831→    if (translationCandidates.length === 0 && wordCount(prePos0.text) >= 2) {\n   832→      const pos0Words = new Set(\n   833→        prePos0.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2)\n   834→      );\n   835→      translationCandidates = nearbyAllCaps.filter((cap) => {\n   836→        if (wordCount(cap.text) < 2) return false;\n   837→        const capWords = cap.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2);\n   838→        return !capWords.some((w) => pos0Words.has(w));\n   839→      });\n   840→    }\n   841→\n   842→    if (translationCandidates.length > 0) {\n   843→      // Suppress standalone translations and any multi-line joins that embed the translation\n   844→      // as a suffix or substring (e.g. \"Smażona zielona fasolka GREEN BEANS BORKEUM\" ends with\n   845→      // the translation; \"Title GREEN BEANS BORKEUM 그린빈\" includes it as a substring).\n   846→      scoredForThreshold = scored.filter((s) => {\n   847→        const sLower = s.text.toLowerCase();\n   848→        return !translationCandidates.some((t) => {\n   849→          const tLower = t.text.toLowerCase();\n   850→          return sLower.startsWith(tLower) ||\n   851→                 sLower.endsWith(\" \" + tLower) ||\n   852→                 sLower.includes(\" \" + tLower);\n   853→        });\n   854→      });\n   855→    }\n   856→  }\n   857→\n   858→  // Fix 2: If the structural heading was identified as a bilingual translation, reassign it.\n   859→  // This prevents the translation's ALL_CAPS bonus from inflating the threshold and ensures\n   860→  // the fallback path in scored also uses the correct heading.\n   861→  if (\n   862→    translationCandidates.length > 0 &&\n   863→    firstStructuralHeading &&\n   864→    translationCandidates.some((t) => t.text === firstStructuralHeading!.text)\n   865→  ) {\n   866→    const nonTranslationStructural = structuralCandidates.filter(\n   867→      (sc) => !translationCandidates.some((t) => t.text === sc.text)\n   868→    );\n   869→    const newHeading = nonTranslationStructural.length > 0\n   870→      ? nonTranslationStructural.reduce((a, b) => a.rawScore > b.rawScore ? a : b)\n   871→      : undefined;\n   872→\n   873→    // Patch scored array: remove old structural bonus, apply new one\n   874→    for (const s of scored) {\n   875→      if (s.text === firstStructuralHeading.text) {\n   876→        s.score -= 0.10;\n   877→        s.baseScore -= 0.10;\n   878→      }\n   879→      if (newHeading && s.text === newHeading.text) {\n   880→        s.score += 0.10;\n   881→        s.baseScore += 0.10;\n   882→      }\n   883→    }\n   884→    // Update reference for downstream prefix-removal logic\n   885→    firstStructuralHeading = newHeading ?? undefined;\n   886→  }\n   887→\n   888→  // Subtitle suppression: when a short mixed-case title at position 0 is followed by a\n   889→  // longer mixed-case candidate at position 1-2, the longer one is a subtitle/translation.\n   890→  // Apply a penalty so the primary title (position 0) wins.\n   891→  const pos0Primary = scored.find((s) => s.position === 0 && !isAllCaps(s.text) && wordCount(s.text) <= 5);\n   892→  if (pos0Primary) {\n   893→    const subtitleCandidates = scored.filter((s) =>\n   894→      s.position >= 1 && s.position <= 2 &&\n   895→      !isAllCaps(s.text) &&\n   896→      wordCount(s.text) > wordCount(pos0Primary.text) + 2\n   897→    );\n   898→    for (const sub of subtitleCandidates) {\n   899→      sub.score -= 0.15;\n   900→    }\n   901→  }\n   902→\n   903→  // Use thresholdScore (excludes structural bonus) so the structural bonus doesn't inflate\n   904→  // the threshold and block equally-valid headings on multi-recipe pages.\n   905→  const bestThresholdScore = Math.max(...scoredForThreshold.map((s) => s.thresholdScore));\n   906→  const threshold = Math.max(0.08, bestThresholdScore * 0.7);\n   907→\n   908→  // Filter candidates above threshold\n   909→  let selected = scoredForThreshold.filter((s) => s.score >= threshold);\n   910→\n   911→  // Empty-pool fallback: when threshold filtering discards every candidate,\n   912→  // the hard filters' structural verdict should not be overruled by weak\n   913→  // embedding differentiation. Return the best positional candidate only\n   914→  // if it has a meaningful positive raw score (avoids ingredient-list leakage).\n   915→  if (selected.length === 0 && scored.length > 0) {\n   916→    const fallback = scored\n   917→      .slice()\n   918→      .sort((a, b) => a.position - b.position || b.score - a.score);\n   919→    // Position-0 candidates that passed hard filters are very likely titles even with\n   920→    // weak embedding signal. Relax the rawScore guard for early-position candidates.\n   921→    const rawScoreThreshold = fallback[0].position <= 2 ? -0.05 : 0.02;\n   922→    if (fallback[0].rawScore > rawScoreThreshold) {\n   923→      selected = [fallback[0]];\n   924→    }\n   925→  }\n   926→\n   927→  // Remove word-boundary prefixes of firstStructuralHeading when the heading itself survived\n   928→  // the threshold. Cases:\n   929→  //   ARAYES case:  firstStructuralHeading = \"ARAYES SHRAK\" (2-word join qualifies; \"ARAYES\"\n   930→  //     alone = 1 word, so it never qualified). Filter removes \"ARAYES\" so dedup keeps the join.\n   931→  //   SAFFRON case: baseHeading was the partial line; continuation logic above upgraded\n   932→  //     firstStructuralHeading to the full join. Filter removes the partial so dedup keeps join.\n   933→  // Safety: only fires when the complete heading itself is in selected (passed the threshold).\n   934→  if (firstStructuralHeading && selected.some((s) => s.text === firstStructuralHeading.text)) {\n   935→    const fshLower = firstStructuralHeading.text.toLowerCase();\n   936→    selected = selected.filter((s) => {\n   937→      if (s.text === firstStructuralHeading.text) return true;\n   938→      const sLower = s.text.toLowerCase();\n   939→      // Remove s if it is a space-delimited prefix of the structural heading\n   940→      return !fshLower.startsWith(sLower + \" \");\n   941→    });\n   942→  }\n   943→\n   944→  // Protect continuation joins: when a multi-line join (2-line or 3-line) survived the threshold\n   945→  // and its second part starts with a continuation character, remove the single-line prefix/suffix\n   946→  // so the dedup \"shorter wins\" rule doesn't destroy the complete join.\n   947→  // Note: the pre-merge step above already handles the common Baked Eggs case (&/continuation\n   948→  // on next line) by turning it into a single candidate — this block covers the rarer case where\n   949→  // a continuation-character join was generated as a 2-line/3-line candidate and the prefix\n   950→  // single also survived threshold independently (e.g. from a different code path or OCR layout).\n   951→  // Safety: only fires for joins whose continuation starts with /&+:( — digit continuations\n   952→  // like \"Pierogi Ruskie 200g mąki\" are NOT protected, so dedup correctly keeps the shorter form.\n   953→  const survivingJoins = selected.filter((s) => s.origin === \"2-line\" || s.origin === \"3-line\");\n   954→  if (survivingJoins.length > 0) {\n   955→    selected = selected.filter((s) => {\n   956→      if (s.origin !== \"single\") return true;\n   957→      const sLower = s.text.toLowerCase();\n   958→      // Remove PREFIX singles whose continuation join also survived\n   959→      const isPrefixOfJoin = survivingJoins.some((j) => {\n   960→        const jLower = j.text.toLowerCase();\n   961→        if (!jLower.startsWith(sLower + \" \")) return false;\n   962→        const remainder = jLower.slice(sLower.length + 1);\n   963→        return /^[/&+:(]/.test(remainder);\n   964→      });\n   965→      if (isPrefixOfJoin) return false;\n   966→      // Remove SUFFIX singles (e.g. \"& Coriander\") whose parent join also survived\n   967→      const isSuffixOfJoin = survivingJoins.some((j) => {\n   968→        const jLower = j.text.toLowerCase();\n   969→        if (!jLower.endsWith(\" \" + sLower)) return false;\n   970→        // Only remove if the suffix starts with a continuation character\n   971→        return /^[/&+:(]/.test(sLower);\n   972→      });\n   973→      if (isSuffixOfJoin) return false;\n   974→      return true;\n   975→    });\n   976→  }\n   977→\n   978→  // Pre-dedup: remove sub-section headers that are substrings of other surviving candidates.\n   979→  // A sub-section header is an ALL_CAPS candidate followed by ingredient-like lines in the source.\n   980→  // Example: \"CHLEBEK\" (bread section header, followed by \"500 g mąki\") is a substring of\n   981→  // \"CHLEBEK Z WARZYWAMI I BOCZKIEM\" (the real title). Without this filter, dedup kills the title.\n   982→  selected = selected.filter((candidate) => {\n   983→    if (!isAllCaps(candidate.text)) return true;\n   984→    // Check if this candidate is immediately followed by ingredient-like content\n   985→    const nextSourceLines = lines.slice(candidate.position + 1, candidate.position + 2);\n   986→    const followedByIngredients = nextSourceLines.some(\n   987→      (l) => looksLikeIngredient(l.trim()) || startsWithNumber(l.trim())\n   988→    );\n   989→    if (!followedByIngredients) return true;\n   990→    // Only remove if a longer candidate contains this one as a substring\n   991→    const candidateLower = candidate.text.toLowerCase();\n   992→    const hasLongerParent = rawScored.some(\n   993→      (other) =>\n   994→        other.text !== candidate.text &&\n   995→        other.text.length > candidate.text.length &&\n   996→        other.text.toLowerCase().includes(candidateLower)\n   997→    );\n   998→    return !hasLongerParent;\n   999→  });\n  1000→\n  1001→  // Protect multi-line joins from being destroyed by their own component singles.\n  1002→  // When \"Lamb Stew\" (2-line join) survives AND both \"Lamb\" and \"Stew\" (singles) also survive,\n  1003→  // the join is the intended title — remove the singles.\n  1004→  const joinsToProtect = selected.filter((s) => s.origin === \"2-line\" || s.origin === \"3-line\");\n  1005→  if (joinsToProtect.length > 0) {\n  1006→    const singlesToRemove = new Set<string>();\n  1007→    for (const join of joinsToProtect) {\n  1008→      const joinWords = join.text.split(/\\s+/);\n  1009→      const componentSingles = selected.filter(\n  1010→        (s) => s.origin === \"single\" && joinWords.some((w) => s.text.toLowerCase() === w.toLowerCase())\n  1011→      );\n  1012→      if (componentSingles.length >= Math.min(joinWords.length, 2)) {\n  1013→        componentSingles.forEach((s) => singlesToRemove.add(s.text));\n  1014→      }\n  1015→    }\n  1016→    if (singlesToRemove.size > 0) {\n  1017→      selected = selected.filter((s) => s.origin !== \"single\" || !singlesToRemove.has(s.text));\n  1018→    }\n  1019→  }\n  1020→\n  1021→  // Protect position-0 compound titles from distant sub-section headers.\n  1022→  // When a position-0 compound title is longer and contains a shorter candidate\n  1023→  // that appears > 10 lines later, remove the distant candidate so the dedup\n  1024→  // (shorter-wins rule) doesn't destroy the compound title.\n  1025→  const pos0Compounds = selected.filter((s) => s.position === 0);\n  1026→  if (pos0Compounds.length > 0) {\n  1027→    selected = selected.filter((s) => {\n  1028→      if (s.position === 0) return true;\n  1029→      const sLower = s.text.toLowerCase();\n  1030→      return !pos0Compounds.some(\n  1031→        (p0) =>\n  1032→          p0.position + 10 < s.position &&\n  1033→          s.text.length < p0.text.length &&\n  1034→          p0.text.toLowerCase().includes(sLower)\n  1035→      );\n  1036→    });\n  1037→  }\n  1038→\n  1039→  // Deduplicate: if one title is a substring of another, keep the shorter (more focused) one.\n  1040→  // DO NOT CHANGE THIS LOGIC — it has been incorrectly \"improved\" by the title-loop 5 times.\n  1041→  // The tests require shorter wins: \"Pierogi Ruskie\" over \"Pierogi Ruskie 200g mąki 3 ziemniaki\".\n  1042→  // The pre-filter above handles the conflicting case (structural heading prefix removal) so that\n  1043→  // the incomplete prefix line is never present here when the complete join is in selected.\n  1044→  selected = selected.filter((a) => {\n  1045→    const aLower = a.text.toLowerCase();\n  1046→    return !selected.some(\n  1047→      (b) =>\n  1048→        b !== a &&\n  1049→        aLower.includes(b.text.toLowerCase()) &&\n  1050→        b.text.length < a.text.length\n  1051→    );\n  1052→  });\n  1053→\n  1054→  // Multi-title guard: only join multiple candidates with \"+\" when there is\n  1055→  // structural evidence of a multi-recipe page (≥2 ALL_CAPS headings).\n  1056→  // A single ALL_CAPS title among mixed-case survivors is a single-recipe page —\n  1057→  // collapse to the highest-scoring candidate.\n  1058→  // Zero ALL_CAPS survivors → apply positional tiebreak only when candidates are\n  1059→  // spread far apart (>10 lines), which indicates body-text leakage. Closely-\n  1060→  // positioned candidates are likely genuine multi-recipe content.\n  1061→  if (selected.length > 1) {\n  1062→    const allCapsSelected = selected.filter((s) => isAllCaps(s.text));\n  1063→    if (allCapsSelected.length >= 2) {\n  1064→      // Check whether non-first ALL_CAPS headings are section headers within one recipe\n  1065→      // (followed immediately by ingredient-like content) rather than separate recipe titles.\n  1066→      // A multi-recipe page has body text between titles; a single-recipe page has\n  1067→      // ingredient lines immediately after each section heading.\n  1068→      const sortedCaps = [...allCapsSelected].sort((a, b) => a.position - b.position);\n  1069→      const isSubHeader = sortedCaps.slice(1).every((cap) => {\n  1070→        const nextLines = lines.slice(cap.position + 1, cap.position + 3);\n  1071→        return nextLines.some(\n  1072→          (l) => looksLikeIngredient(l.trim()) || /^\\s*\\d/.test(l.trim())\n  1073→        );\n  1074→      });\n  1075→      if (isSubHeader) {\n  1076→        selected = [sortedCaps[0]];\n  1077→      } else {\n  1078→        selected = allCapsSelected;\n  1079→      }\n  1080→    } else if (allCapsSelected.length === 1) {\n  1081→      const theCapCandidate = allCapsSelected[0];\n  1082→      // Use non-empty line count so the 75% threshold is consistent regardless of blank-line density.\n  1083→      const nonEmptyCount = lines.filter((l) => l.trim().length > 0).length;\n  1084→      const capRelPos = theCapCandidate.position / Math.max(nonEmptyCount, 1);\n  1085→      // If the sole ALL_CAPS candidate is in the last 25% of the document,\n  1086→      // it's likely a category footer, not a title. Prefer the best earlier candidate.\n  1087→      if (capRelPos > 0.75) {\n  1088→        const earlierCandidates = selected.filter(\n  1089→          (s) => s.position / Math.max(nonEmptyCount, 1) <= 0.75\n  1090→        );\n  1091→        if (earlierCandidates.length > 0) {\n  1092→          selected = [earlierCandidates.reduce((a, b) => (a.score > b.score ? a : b))];\n  1093→        } else {\n  1094→          // All candidates are in the last 25% — no positional basis to prefer one over another;\n  1095→          // fall back to score, accepting that the guard cannot help here.\n  1096→          selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n  1097→        }\n  1098→      } else {\n  1099→        selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n  1100→      }\n  1101→    } else {\n  1102→      // Zero ALL_CAPS survivors → mixed-case page.\n  1103→      // If all survivors are closely positioned (within 10 lines of each other), keep them all —\n  1104→      // they're likely genuine multi-recipe content on a single page.\n  1105→      // If any survivor is far from the earliest, apply a positional tiebreak: the real title\n  1106→      // is almost always the earliest candidate; distant survivors are likely body-text leakage.\n  1107→      selected.sort((a, b) => a.position - b.position);\n  1108→      const earliest = selected[0];\n  1109→      const farthest = selected[selected.length - 1];\n  1110→      if (farthest.position - earliest.position > 10) {\n  1111→        // Large span → body-text leakage. Collapse to one: prefer the highest-scoring\n  1112→        // candidate within 3 positions of the earliest (position tolerance for OCR gaps),\n  1113→        // falling back to the earliest itself if none score higher.\n  1114→        const closeCompetitors = selected.filter(\n  1115→          (s) => s.position <= earliest.position + 3 && s.score > earliest.score\n  1116→        );\n  1117→        selected = closeCompetitors.length > 0\n  1118→          ? [closeCompetitors.reduce((a, b) => (a.score > b.score ? a : b))]\n  1119→          : [earliest];\n  1120→      }\n  1121→      // Span ≤ 10 → all survivors are closely positioned; fall through keeping all.\n  1122→    }\n  1123→  }\n  1124→\n  1125→  // Cap at 3, sort by document position\n  1126→  selected.sort((a, b) => a.position - b.position);\n  1127→  selected = selected.slice(0, 3);\n  1128→\n  1129→  if (selected.length === 0) {\n  1130→    // Last resort: embedding scoring provided no usable signal.\n  1131→    // Return the earliest candidate that passed hard filters — it already survived\n  1132→    // ingredient, metadata, garbled, section-label, and cooking-instruction checks.\n  1133→    // Position 0 in a recipe file is overwhelmingly the title.\n  1134→    // Exclude hard-disqualified candidates (rawScore -1.0 = truncated OCR artifact).\n  1135→    const lastResort = scored\n  1136→      .slice()\n  1137→      .filter((s) => s.rawScore > -0.5)\n  1138→      .sort((a, b) => a.position - b.position || b.score - a.score);\n  1139→    if (lastResort.length > 0) {\n  1140→      return normalizeOcrTitle(lastResort[0].text.normalize(\"NFC\").trim());\n  1141→    }\n  1142→    return undefined;\n  1143→  }\n  1144→\n  1145→  const result = selected.map((s) => normalizeOcrTitle(s.text.normalize(\"NFC\").trim())).join(\" + \");\n  1146→\n  1147→  return result;\n  1148→}\n  1149→\n  1150→/**\n  1151→ * Extract potential recipe title from OCR text (sync heuristic fallback)\n  1152→ */\n  1153→export function extractTitle(text: string): string | undefined {\n  1154→  if (!text || text.trim().length === 0) {\n  1155→    return undefined;\n  1156→  }\n  1157→\n  1158→  const lines = text.split(\"\\n\").map((line) => line.trim());\n  1159→\n  1160→  for (const line of lines) {\n  1161→    if (line.length === 0) continue;\n  1162→    if (line.length < 3 || line.length > 50) continue;\n  1163→    if (looksLikeIngredient(line)) continue;\n  1164→    if (isAllCaps(line)) continue;\n  1165→    if (startsWithNumber(line)) continue;\n  1166→    return line;\n  1167→  }\n  1168→\n  1169→  return undefined;\n  1170→}\n  1171→","numLines":1171,"startLine":1,"totalLines":1171}}}
