{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KLDFznxaVY66c4rEvoA1ug","type":"tool_result","content":"   400→}\n   401→\n   402→function stripPageNumber(text: string): string {\n   403→  // \"34  Berry Jam\" → \"Berry Jam\" (2+ spaces distinguishes from \"2 eggs\")\n   404→  const match = text.match(/^\\d{1,3}\\s{2,}(.+)$/);\n   405→  return match ? match[1] : text;\n   406→}\n   407→\n   408→function wordCount(text: string): number {\n   409→  return text.split(/\\s+/).filter((w) => w.length > 0).length;\n   410→}\n   411→\n   412→/**\n   413→ * Build candidate strings from lines: single lines plus multi-line joins (2-3 consecutive).\n   414→ * Skips initial burst of short garbled lines. Scans all remaining lines. Caps at 25.\n   415→ */\n   416→export type CandidateOrigin = \"single\" | \"2-line\" | \"3-line\";\n   417→\n   418→function buildCandidates(\n   419→  lines: Array<string>\n   420→): Array<{ text: string; position: number; origin: CandidateOrigin }> {\n   421→  const nonEmptyLines: Array<{ text: string; index: number }> = [];\n   422→\n   423→  for (let i = 0; i < lines.length; i++) {\n   424→    const trimmed = lines[i].trim();\n   425→    if (trimmed.length > 0) {\n   426→      nonEmptyLines.push({ text: trimmed, index: i });\n   427→    }\n   428→  }\n   429→\n   430→  const burstEnd = findBurstEnd(nonEmptyLines);\n   431→\n   432→  // Pre-join hyphen-broken lines: \"ROASTED CHICKEN WITH ROOT VEGET-\" + \"ABLES\" → single line.\n   433→  // Only applies within the candidate region (after burst end).\n   434→  for (let hi = burstEnd; hi < nonEmptyLines.length - 1; hi++) {\n   435→    if (nonEmptyLines[hi].text.endsWith(\"-\")) {\n   436→      const joined = nonEmptyLines[hi].text.slice(0, -1) + nonEmptyLines[hi + 1].text;\n   437→      nonEmptyLines[hi] = { text: joined, index: nonEmptyLines[hi].index };\n   438→      nonEmptyLines.splice(hi + 1, 1);\n   439→    }\n   440→  }\n   441→\n   442→  // Pre-merge consecutive short ALL_CAPS lines (OCR-fragmented headings).\n   443→  // When a sequence of 2+ ALL_CAPS lines each has ≤2 words and ≤25 chars, they are\n   444→  // almost certainly OCR fragments of a single heading. Merge them into one line so\n   445→  // the complete title enters the candidate pool without hitting the 3-line join ceiling.\n   446→  const capsCoalesced: Array<{ text: string; index: number }> = [];\n   447→  let ci = burstEnd;\n   448→  while (ci < nonEmptyLines.length) {\n   449→    const line = nonEmptyLines[ci];\n   450→    if (\n   451→      isAllCaps(line.text) &&\n   452→      wordCount(line.text) <= 2 &&\n   453→      line.text.length <= 25 &&\n   454→      !isSectionLabel(line.text) &&\n   455→      !looksLikeMetadata(line.text)\n   456→    ) {\n   457→      let merged = line.text;\n   458→      const startIndex = line.index;\n   459→      let j = ci + 1;\n   460→      while (j < nonEmptyLines.length) {\n   461→        const next = nonEmptyLines[j];\n   462→        if (\n   463→          isAllCaps(next.text) &&\n   464→          wordCount(next.text) <= 2 &&\n   465→          next.text.length <= 25 &&\n   466→          !isSectionLabel(next.text) &&\n   467→          !looksLikeMetadata(next.text) &&\n   468→          (merged + \" \" + next.text).length <= 80\n   469→        ) {\n   470→          merged += \" \" + next.text;\n   471→          j++;\n   472→        } else {\n   473→          break;\n   474→        }\n   475→      }\n   476→      if (j > ci + 1) {\n   477→        capsCoalesced.push({ text: merged, index: startIndex });\n   478→        ci = j;\n   479→        continue;\n   480→      }\n   481→    }\n   482→    capsCoalesced.push(line);\n   483→    ci++;\n   484→  }\n   485→\n   486→  // Pre-merge continuation lines: a line starting with /&+:( is never a standalone title.\n   487→  // Merge it into the preceding line so the complete title enters the pool as a single candidate,\n   488→  // avoiding the fragile chain of conditions required by the downstream join survival logic.\n   489→  // Limitation: only one continuation line per preceding line is merged. Titles split across\n   490→  // three or more lines with continuation tokens (rare in practice) are not handled here —\n   491→  // the downstream 2-line and 3-line join candidates cover those cases instead.\n   492→  const mergedLines: Array<{ text: string; index: number }> = [];\n   493→  for (let i = 0; i < capsCoalesced.length; i++) {\n   494→    const line = capsCoalesced[i];\n   495→    if (i + 1 < capsCoalesced.length) {\n   496→      const nextText = capsCoalesced[i + 1].text;\n   497→      if (/^[/&+:(]/.test(nextText)) {\n   498→        mergedLines.push({ text: `${line.text} ${nextText}`, index: line.index });\n   499→        i++;\n   500→        continue;\n   501→      }\n   502→    }\n   503→    mergedLines.push(line);\n   504→  }\n   505→\n   506→  const candidates: Array<{ text: string; position: number; origin: CandidateOrigin }> = [];\n   507→  const seen = new Set<string>();\n   508→\n   509→  // Build a set of positions to skip: short ALL_CAPS lines immediately following metadata\n   510→  const metadataContinuationPositions = new Set<number>();\n   511→  for (let i = 0; i < mergedLines.length - 1; i++) {\n   512→    if (looksLikeMetadata(mergedLines[i].text)) {\n   513→      const next = mergedLines[i + 1];\n   514→      if (isAllCaps(next.text) && wordCount(next.text) <= 2 && next.text.length <= 15) {\n   515→        metadataContinuationPositions.add(next.index);\n   516→      }\n   517→    }\n   518→  }\n   519→\n   520→  for (let i = 0; i < mergedLines.length; i++) {\n   521→    const line = mergedLines[i];\n   522→\n   523→    // Skip metadata continuation fragments\n   524→    if (metadataContinuationPositions.has(line.index)) continue;\n   525→\n   526→    // Single line — strip page-number prefixes and parenthetical glosses before scoring\n   527→    const singleText = stripParentheticalGloss(stripPageNumber(line.text));\n   528→    if (passesHardFilters(singleText)) {\n   529→      const norm = singleText.toLowerCase();\n   530→      if (!seen.has(norm)) {\n   531→        seen.add(norm);\n   532→        candidates.push({ text: singleText, position: line.index, origin: \"single\" });\n   533→      }\n   534→    }\n   535→\n   536→    // 2-line join — skip if first line is a section label AND join would be ≤2 words\n   537→    // (a section label followed by modifiers is likely a recipe title, not a category header)\n   538→    if (i + 1 < mergedLines.length) {\n   539→      const joined2 = `${line.text} ${mergedLines[i + 1].text}`;\n   540→      const shouldBlock2 = isSectionLabel(line.text) &&\n   541→        (wordCount(joined2) <= 2 || isAlwaysBlockJoinLabel(line.text));\n   542→      if (!shouldBlock2 && passesHardFilters(joined2)) {\n   543→        const norm = joined2.toLowerCase();\n   544→        if (!seen.has(norm)) {\n   545→          seen.add(norm);\n   546→          candidates.push({ text: joined2, position: line.index, origin: \"2-line\" });\n   547→        }\n   548→      }\n   549→    }\n   550→\n   551→    // 3-line join — skip if first line is a section label AND join would be ≤2 words\n   552→    if (i + 2 < mergedLines.length) {\n   553→      const joined3 = `${line.text} ${mergedLines[i + 1].text} ${mergedLines[i + 2].text}`;\n   554→      const shouldBlock3 = isSectionLabel(line.text) &&\n   555→        (wordCount(joined3) <= 2 || isAlwaysBlockJoinLabel(line.text));\n   556→      if (!shouldBlock3 && passesHardFilters(joined3)) {\n   557→        const norm = joined3.toLowerCase();\n   558→        if (!seen.has(norm)) {\n   559→          seen.add(norm);\n   560→          candidates.push({ text: joined3, position: line.index, origin: \"3-line\" });\n   561→        }\n   562→      }\n   563→    }\n   564→  }\n   565→\n   566→  // Pre-filter to 25 before embedding calls: prefer ALL_CAPS and short candidates.\n   567→  // Position-based scoring handles final ranking.\n   568→  if (candidates.length > 25) {\n   569→    const prioritized = candidates.slice().sort((a, b) => {\n   570→      const aAllCaps = isAllCaps(a.text) ? 0 : 1;\n   571→      const bAllCaps = isAllCaps(b.text) ? 0 : 1;\n   572→      if (aAllCaps !== bAllCaps) return aAllCaps - bAllCaps;\n   573→      const aShort = wordCount(a.text) <= 5 ? 0 : 1;\n   574→      const bShort = wordCount(b.text) <= 5 ? 0 : 1;\n   575→      return aShort - bShort;\n   576→    });\n   577→    return prioritized.slice(0, 25);\n   578→  }\n   579→\n   580→  return candidates;\n   581→}\n   582→\n   583→/**\n   584→ * Convert an ALL_CAPS string to Title Case, using a small-words list.\n   585→ * Preserves Polish/French diacritics.\n   586→ */\n   587→function toTitleCase(text: string): string {\n   588→  const smallWords = new Set([\n   589→    \"a\", \"an\", \"the\", \"and\", \"but\", \"or\", \"for\", \"nor\",\n   590→    \"in\", \"on\", \"at\", \"to\", \"of\", \"by\", \"with\", \"from\",\n   591→    \"z\", \"w\", \"i\", \"ze\", \"na\", \"do\", \"od\", \"za\", \"po\",\n   592→  ]);\n   593→  return text.split(/(\\s+)/).map((word, idx) => {\n   594→    if (/^\\s+$/.test(word)) return word;\n   595→    const lower = word.toLowerCase();\n   596→    if (idx === 0 || !smallWords.has(lower)) {\n   597→      return lower.charAt(0).toUpperCase() + lower.slice(1);\n   598→    }\n   599→    return lower;\n   600→  }).join(\"\");\n   601→}\n   602→\n   603→/**\n   604→ * Post-processing normalization for OCR-extracted titles.\n   605→ * Strips stray section markers and substitutes common OCR digit-for-letter artifacts.\n   606→ * Title-case conversion is applied only when a substitution was actually made, so\n   607→ * clean ALL_CAPS titles (e.g. \"CHOCOLATE CAKE\") are returned unchanged.\n   608→ */\n   609→function normalizeOcrTitle(raw: string): string {\n   610→  let text = raw;\n   611→\n   612→  // Step 1: Strip trailing section markers greedily appended to the title.\n   613→  // e.g. \"MAKOWIEC ZE ŚLIWKAMI + SERVING AND STORAGE:\" → \"MAKOWIEC ZE ŚLIWKAMI\"\n   614→  text = text.replace(\n   615→    /\\s*\\+\\s*(?:SERV[IÍ1]NG(?:\\s+AND\\s+STORAGE)?|TOPPING|NOTES?|TIPS?)\\s*:?\\s*$/i,\n   616→    \"\"\n   617→  );\n   618→\n   619→  // Step 2: OCR character substitution.\n   620→  // For ALL_CAPS text, apply digit-for-letter substitutions.\n   621→  const beforeSub = text;\n   622→  if (isAllCaps(text)) {\n   623→    text = text\n   624→      .replace(/1/g, \"I\")\n   625→      .replace(/0(?=[A-ZÀ-Ż])/g, \"O\")\n   626→      .replace(/(?<=[A-ZÀ-Ż])0/g, \"O\")\n   627→      .replace(/4(?=[A-ZÀ-Ż])/g, \"A\")\n   628→      .replace(/(?<=[A-ZÀ-Ż])4/g, \"A\")\n   629→      .replace(/5(?=[A-ZÀ-Ż])/g, \"S\")\n   630→      .replace(/(?<=[A-ZÀ-Ż])5/g, \"S\")\n   631→      .replace(/¡/g, \"I\")\n   632→      .replace(/€/g, \"E\")\n   633→      .replace(/[ÍÌ]/g, \"I\");\n   634→  } else {\n   635→    // Mixed-case: fix per-word (digits between lowercase letters)\n   636→    text = text.split(/(\\s+)/).map((token) => {\n   637→      if (/^\\s+$/.test(token)) return token;\n   638→      if (isAllCaps(token) && token.length > 1) {\n   639→        return token\n   640→          .replace(/1/g, \"I\")\n   641→          .replace(/0(?=[A-Z])/g, \"O\")\n   642→          .replace(/(?<=[A-Z])0/g, \"O\");\n   643→      }\n   644→      return token\n   645→        .replace(/(?<=[a-zà-ż])1/g, \"l\")\n   646→        .replace(/1(?=[a-zà-ż])/g, \"l\")\n   647→        .replace(/¡/g, \"i\")\n   648→        .replace(/€/g, \"e\");\n   649→    }).join(\"\");\n   650→  }\n   651→\n   652→  // Step 3: Title-case conversion — ONLY when OCR substitution changed the text.\n   653→  // This preserves clean ALL_CAPS titles (e.g. \"CHOCOLATE CAKE\") as-is.\n   654→  if (text !== beforeSub && isAllCaps(text)) {\n   655→    text = toTitleCase(text);\n   656→  }\n   657→\n   658→  return text.trim();\n   659→}\n   660→\n   661→// Module-level cache for reference embeddings\n   662→let cachedTitleRefEmbedding: Array<number> | null = null;\n   663→let cachedHeaderRefEmbedding: Array<number> | null = null;\n   664→let cachedNoiseRefEmbedding: Array<number> | null = null;\n   665→\n   666→export function _resetEmbeddingCacheForTests(): void {\n   667→  cachedTitleRefEmbedding = null;\n   668→  cachedHeaderRefEmbedding = null;\n   669→  cachedNoiseRefEmbedding = null;\n   670→}\n   671→\n   672→export async function extractTitleWithEmbeddings(\n   673→  text: string,\n   674→  embed: EmbedFn\n   675→): Promise<string | undefined> {\n   676→  if (!text || text.trim().length === 0) {\n   677→    return undefined;\n   678→  }\n   679→\n   680→  const lines = text.split(\"\\n\");\n   681→  const candidates = buildCandidates(lines);\n   682→\n   683→  if (candidates.length === 0) {\n   684→    return undefined;\n   685→  }\n   686→\n   687→  // Cache reference embeddings\n   688→  if (!cachedTitleRefEmbedding) {\n   689→    cachedTitleRefEmbedding = await embed(TITLE_REFERENCE);\n   690→  }\n   691→  if (!cachedHeaderRefEmbedding) {\n   692→    cachedHeaderRefEmbedding = await embed(HEADER_REFERENCE);\n   693→  }\n   694→  if (!cachedNoiseRefEmbedding) {\n   695→    cachedNoiseRefEmbedding = await embed(NOISE_REFERENCE);\n   696→  }\n   697→\n   698→  // Find ALL_CAPS candidates with ≥2 words where every significant word has ≥4 alpha letters.\n   699→  // Insignificant tokens (≤1 alpha letter: \"/\", \"&\", \"+\", \":\", \"D)\", etc.) are filtered before\n   700→  // the check so that multi-line joins with continuation punctuation still qualify.\n   701→  const isStructuralHeading = (c: { text: string }): boolean => {\n   702→    if (!isAllCaps(c.text) || wordCount(c.text) < 2) return false;\n   703→    const sigWords = c.text.trim().split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length > 1);\n   704→    return sigWords.length >= 2 && sigWords.every((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   705→  };\n   706→\n   707→  // Pass 1: compute rawScore for all candidates (embedding quality signal)\n   708→  const rawScored: Array<{ text: string; position: number; origin: CandidateOrigin; rawScore: number; embedding: Array<number> }> = [];\n   709→  for (const candidate of candidates) {\n   710→    const embedding = await embed(candidate.text);\n   711→    const titleSim = cosineSimilarity(embedding, cachedTitleRefEmbedding);\n   712→    const headerSim = cosineSimilarity(embedding, cachedHeaderRefEmbedding);\n   713→    const noiseSim = cosineSimilarity(embedding, cachedNoiseRefEmbedding);\n   714→    const rawScore = titleSim - Math.max(headerSim, noiseSim);\n   715→    rawScored.push({ text: candidate.text, position: candidate.position, origin: candidate.origin, rawScore, embedding });\n   716→  }\n   717→\n   718→  // Select baseHeading by embedding quality (rawScore), not position.\n   719→  // This prevents OCR-garbled fragments from claiming the structural heading slot.\n   720→  const structuralCandidates = rawScored.filter((s) => isStructuralHeading(s));\n   721→\n   722→  // Penalize structural headings with truncated OCR words:\n   723→  // if \"FRON\" appears and another heading has \"SAFFRON\", \"FRON\" is likely garbled.\n   724→  for (const sc of structuralCandidates) {\n   725→    const sigWords = sc.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   726→    for (const other of structuralCandidates) {\n   727→      if (other === sc) continue;\n   728→      const otherSigWords = other.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   729→      const hasTruncation = sigWords.some((w) =>\n   730→        otherSigWords.some((ow) => ow !== w && ow.length > w.length && ow.endsWith(w))\n   731→      );\n   732→      if (hasTruncation) {\n   733→        sc.rawScore = -1.0;  // Hard disqualification — truncated OCR artifact\n   734→        break;\n   735→      }\n   736→    }\n   737→  }\n   738→\n   739→  const bestStructural = structuralCandidates.length > 0\n   740→    ? structuralCandidates.reduce((a, b) => {\n   741→        const scoreDiff = a.rawScore - b.rawScore;\n   742→        if (Math.abs(scoreDiff) > 0.03) return scoreDiff > 0 ? a : b;\n   743→        // Tiebreak: single-line origin beats multi-line joins (avoids conflating two separate headings)\n   744→        if (a.origin === \"single\" && b.origin !== \"single\") return a;\n   745→        if (b.origin === \"single\" && a.origin !== \"single\") return b;\n   746→        // Tiebreak: more words (more specific) → better\n   747→        const wcDiff = wordCount(b.text) - wordCount(a.text);\n   748→        if (wcDiff !== 0) return wcDiff > 0 ? b : a;\n   749→        // Tiebreak: earlier position → better\n   750→        return a.position < b.position ? a : b;\n   751→      })\n   752→    : null;\n   753→  const baseHeading = bestStructural ?? undefined;\n   754→\n   755→  // When the best structural heading has a continuation on the next line introduced by a\n   756→  // punctuation token (/, &, +, :, or parenthesis), prefer the longer 2-line join as the\n   757→  // complete heading. E.g. \"SAFFRON WHEAT BUNS WITH QUARK\" + \"/ COTTAGE CHEESE (VARIATION D)\".\n   758→  // Guard: the remainder after the prefix must start with a continuation character to avoid\n   759→  // merging two separate consecutive recipe titles (FINNISH MILK FLATBREADS stays separate\n   760→  // from FINNISH POTATO FLATBREADS because \"FINNISH\" does not start with a continuation token).\n   761→  let firstStructuralHeading = baseHeading && (\n   762→    rawScored.find((c) => {\n   763→      if (!isStructuralHeading(c)) return false;\n   764→      const hLower = baseHeading.text.toLowerCase();\n   765→      const cLower = c.text.toLowerCase();\n   766→      return cLower.startsWith(hLower + \" \") && /^[/&+:(]/.test(cLower.slice(hLower.length + 1));\n   767→    }) ?? baseHeading\n   768→  );\n   769→\n   770→  // Pass 2: apply bonuses\n   771→  const scored: Array<{ text: string; position: number; origin: CandidateOrigin; score: number; rawScore: number; baseScore: number; thresholdScore: number }> = rawScored.map((rs) => {\n   772→    // Position factor: multiplicative tiebreaker — amplifies existing signal, doesn't replace it\n   773→    const relativePosition = rs.position / lines.length;\n   774→    const positionFactor = relativePosition < 0.5\n   775→      ? 1.0 + 0.12 * (1 - relativePosition * 2)\n   776→      : 1.0;\n   777→\n   778→    // ALL_CAPS bonus: recipe books use ALL_CAPS for titles and section headings.\n   779→    // Single-word ALL_CAPS terms are overwhelmingly section/category labels, not recipe titles;\n   780→    // real recipe titles in ALL_CAPS are almost always multi-word. Reduce the bonus for single words.\n   781→    const allCapsBonus = isAllCaps(rs.text) && rs.text.replace(/[^a-zA-Z]/g, \"\").length >= 4\n   782→      ? (wordCount(rs.text) >= 2 ? 0.08 : 0.03)\n   783→      : 0;\n   784→\n   785→    // Structural heading bonus: best ALL_CAPS heading (or its continuation join) is almost always the recipe title\n   786→    const structuralBonus = firstStructuralHeading && rs.text === firstStructuralHeading.text ? 0.10 : 0;\n   787→\n   788→    // thresholdScore excludes structural bonus so the bonus doesn't inflate the threshold\n   789→    // and prevent equally-valid structural headings from passing on multi-recipe pages.\n   790→    const thresholdScore = rs.rawScore + allCapsBonus;\n   791→    // baseScore excludes position factor — used for diagnostics and ranking\n   792→    const baseScore = rs.rawScore + allCapsBonus + structuralBonus;\n   793→    const score = rs.rawScore * positionFactor + allCapsBonus + structuralBonus;\n   794→    return { text: rs.text, position: rs.position, origin: rs.origin, score, rawScore: rs.rawScore, baseScore, thresholdScore };\n   795→  });\n   796→\n   797→  if (scored.length === 0) {\n   798→    return undefined;\n   799→  }"}]},"parent_tool_use_id":null,"session_id":"06e30cc2-e666-4ba2-b79a-bd76ce637f9b","uuid":"6a15df5f-4af5-4c70-b3a5-2f06280f8f05","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/title-extractor.ts","content":"}\n\nfunction stripPageNumber(text: string): string {\n  // \"34  Berry Jam\" → \"Berry Jam\" (2+ spaces distinguishes from \"2 eggs\")\n  const match = text.match(/^\\d{1,3}\\s{2,}(.+)$/);\n  return match ? match[1] : text;\n}\n\nfunction wordCount(text: string): number {\n  return text.split(/\\s+/).filter((w) => w.length > 0).length;\n}\n\n/**\n * Build candidate strings from lines: single lines plus multi-line joins (2-3 consecutive).\n * Skips initial burst of short garbled lines. Scans all remaining lines. Caps at 25.\n */\nexport type CandidateOrigin = \"single\" | \"2-line\" | \"3-line\";\n\nfunction buildCandidates(\n  lines: Array<string>\n): Array<{ text: string; position: number; origin: CandidateOrigin }> {\n  const nonEmptyLines: Array<{ text: string; index: number }> = [];\n\n  for (let i = 0; i < lines.length; i++) {\n    const trimmed = lines[i].trim();\n    if (trimmed.length > 0) {\n      nonEmptyLines.push({ text: trimmed, index: i });\n    }\n  }\n\n  const burstEnd = findBurstEnd(nonEmptyLines);\n\n  // Pre-join hyphen-broken lines: \"ROASTED CHICKEN WITH ROOT VEGET-\" + \"ABLES\" → single line.\n  // Only applies within the candidate region (after burst end).\n  for (let hi = burstEnd; hi < nonEmptyLines.length - 1; hi++) {\n    if (nonEmptyLines[hi].text.endsWith(\"-\")) {\n      const joined = nonEmptyLines[hi].text.slice(0, -1) + nonEmptyLines[hi + 1].text;\n      nonEmptyLines[hi] = { text: joined, index: nonEmptyLines[hi].index };\n      nonEmptyLines.splice(hi + 1, 1);\n    }\n  }\n\n  // Pre-merge consecutive short ALL_CAPS lines (OCR-fragmented headings).\n  // When a sequence of 2+ ALL_CAPS lines each has ≤2 words and ≤25 chars, they are\n  // almost certainly OCR fragments of a single heading. Merge them into one line so\n  // the complete title enters the candidate pool without hitting the 3-line join ceiling.\n  const capsCoalesced: Array<{ text: string; index: number }> = [];\n  let ci = burstEnd;\n  while (ci < nonEmptyLines.length) {\n    const line = nonEmptyLines[ci];\n    if (\n      isAllCaps(line.text) &&\n      wordCount(line.text) <= 2 &&\n      line.text.length <= 25 &&\n      !isSectionLabel(line.text) &&\n      !looksLikeMetadata(line.text)\n    ) {\n      let merged = line.text;\n      const startIndex = line.index;\n      let j = ci + 1;\n      while (j < nonEmptyLines.length) {\n        const next = nonEmptyLines[j];\n        if (\n          isAllCaps(next.text) &&\n          wordCount(next.text) <= 2 &&\n          next.text.length <= 25 &&\n          !isSectionLabel(next.text) &&\n          !looksLikeMetadata(next.text) &&\n          (merged + \" \" + next.text).length <= 80\n        ) {\n          merged += \" \" + next.text;\n          j++;\n        } else {\n          break;\n        }\n      }\n      if (j > ci + 1) {\n        capsCoalesced.push({ text: merged, index: startIndex });\n        ci = j;\n        continue;\n      }\n    }\n    capsCoalesced.push(line);\n    ci++;\n  }\n\n  // Pre-merge continuation lines: a line starting with /&+:( is never a standalone title.\n  // Merge it into the preceding line so the complete title enters the pool as a single candidate,\n  // avoiding the fragile chain of conditions required by the downstream join survival logic.\n  // Limitation: only one continuation line per preceding line is merged. Titles split across\n  // three or more lines with continuation tokens (rare in practice) are not handled here —\n  // the downstream 2-line and 3-line join candidates cover those cases instead.\n  const mergedLines: Array<{ text: string; index: number }> = [];\n  for (let i = 0; i < capsCoalesced.length; i++) {\n    const line = capsCoalesced[i];\n    if (i + 1 < capsCoalesced.length) {\n      const nextText = capsCoalesced[i + 1].text;\n      if (/^[/&+:(]/.test(nextText)) {\n        mergedLines.push({ text: `${line.text} ${nextText}`, index: line.index });\n        i++;\n        continue;\n      }\n    }\n    mergedLines.push(line);\n  }\n\n  const candidates: Array<{ text: string; position: number; origin: CandidateOrigin }> = [];\n  const seen = new Set<string>();\n\n  // Build a set of positions to skip: short ALL_CAPS lines immediately following metadata\n  const metadataContinuationPositions = new Set<number>();\n  for (let i = 0; i < mergedLines.length - 1; i++) {\n    if (looksLikeMetadata(mergedLines[i].text)) {\n      const next = mergedLines[i + 1];\n      if (isAllCaps(next.text) && wordCount(next.text) <= 2 && next.text.length <= 15) {\n        metadataContinuationPositions.add(next.index);\n      }\n    }\n  }\n\n  for (let i = 0; i < mergedLines.length; i++) {\n    const line = mergedLines[i];\n\n    // Skip metadata continuation fragments\n    if (metadataContinuationPositions.has(line.index)) continue;\n\n    // Single line — strip page-number prefixes and parenthetical glosses before scoring\n    const singleText = stripParentheticalGloss(stripPageNumber(line.text));\n    if (passesHardFilters(singleText)) {\n      const norm = singleText.toLowerCase();\n      if (!seen.has(norm)) {\n        seen.add(norm);\n        candidates.push({ text: singleText, position: line.index, origin: \"single\" });\n      }\n    }\n\n    // 2-line join — skip if first line is a section label AND join would be ≤2 words\n    // (a section label followed by modifiers is likely a recipe title, not a category header)\n    if (i + 1 < mergedLines.length) {\n      const joined2 = `${line.text} ${mergedLines[i + 1].text}`;\n      const shouldBlock2 = isSectionLabel(line.text) &&\n        (wordCount(joined2) <= 2 || isAlwaysBlockJoinLabel(line.text));\n      if (!shouldBlock2 && passesHardFilters(joined2)) {\n        const norm = joined2.toLowerCase();\n        if (!seen.has(norm)) {\n          seen.add(norm);\n          candidates.push({ text: joined2, position: line.index, origin: \"2-line\" });\n        }\n      }\n    }\n\n    // 3-line join — skip if first line is a section label AND join would be ≤2 words\n    if (i + 2 < mergedLines.length) {\n      const joined3 = `${line.text} ${mergedLines[i + 1].text} ${mergedLines[i + 2].text}`;\n      const shouldBlock3 = isSectionLabel(line.text) &&\n        (wordCount(joined3) <= 2 || isAlwaysBlockJoinLabel(line.text));\n      if (!shouldBlock3 && passesHardFilters(joined3)) {\n        const norm = joined3.toLowerCase();\n        if (!seen.has(norm)) {\n          seen.add(norm);\n          candidates.push({ text: joined3, position: line.index, origin: \"3-line\" });\n        }\n      }\n    }\n  }\n\n  // Pre-filter to 25 before embedding calls: prefer ALL_CAPS and short candidates.\n  // Position-based scoring handles final ranking.\n  if (candidates.length > 25) {\n    const prioritized = candidates.slice().sort((a, b) => {\n      const aAllCaps = isAllCaps(a.text) ? 0 : 1;\n      const bAllCaps = isAllCaps(b.text) ? 0 : 1;\n      if (aAllCaps !== bAllCaps) return aAllCaps - bAllCaps;\n      const aShort = wordCount(a.text) <= 5 ? 0 : 1;\n      const bShort = wordCount(b.text) <= 5 ? 0 : 1;\n      return aShort - bShort;\n    });\n    return prioritized.slice(0, 25);\n  }\n\n  return candidates;\n}\n\n/**\n * Convert an ALL_CAPS string to Title Case, using a small-words list.\n * Preserves Polish/French diacritics.\n */\nfunction toTitleCase(text: string): string {\n  const smallWords = new Set([\n    \"a\", \"an\", \"the\", \"and\", \"but\", \"or\", \"for\", \"nor\",\n    \"in\", \"on\", \"at\", \"to\", \"of\", \"by\", \"with\", \"from\",\n    \"z\", \"w\", \"i\", \"ze\", \"na\", \"do\", \"od\", \"za\", \"po\",\n  ]);\n  return text.split(/(\\s+)/).map((word, idx) => {\n    if (/^\\s+$/.test(word)) return word;\n    const lower = word.toLowerCase();\n    if (idx === 0 || !smallWords.has(lower)) {\n      return lower.charAt(0).toUpperCase() + lower.slice(1);\n    }\n    return lower;\n  }).join(\"\");\n}\n\n/**\n * Post-processing normalization for OCR-extracted titles.\n * Strips stray section markers and substitutes common OCR digit-for-letter artifacts.\n * Title-case conversion is applied only when a substitution was actually made, so\n * clean ALL_CAPS titles (e.g. \"CHOCOLATE CAKE\") are returned unchanged.\n */\nfunction normalizeOcrTitle(raw: string): string {\n  let text = raw;\n\n  // Step 1: Strip trailing section markers greedily appended to the title.\n  // e.g. \"MAKOWIEC ZE ŚLIWKAMI + SERVING AND STORAGE:\" → \"MAKOWIEC ZE ŚLIWKAMI\"\n  text = text.replace(\n    /\\s*\\+\\s*(?:SERV[IÍ1]NG(?:\\s+AND\\s+STORAGE)?|TOPPING|NOTES?|TIPS?)\\s*:?\\s*$/i,\n    \"\"\n  );\n\n  // Step 2: OCR character substitution.\n  // For ALL_CAPS text, apply digit-for-letter substitutions.\n  const beforeSub = text;\n  if (isAllCaps(text)) {\n    text = text\n      .replace(/1/g, \"I\")\n      .replace(/0(?=[A-ZÀ-Ż])/g, \"O\")\n      .replace(/(?<=[A-ZÀ-Ż])0/g, \"O\")\n      .replace(/4(?=[A-ZÀ-Ż])/g, \"A\")\n      .replace(/(?<=[A-ZÀ-Ż])4/g, \"A\")\n      .replace(/5(?=[A-ZÀ-Ż])/g, \"S\")\n      .replace(/(?<=[A-ZÀ-Ż])5/g, \"S\")\n      .replace(/¡/g, \"I\")\n      .replace(/€/g, \"E\")\n      .replace(/[ÍÌ]/g, \"I\");\n  } else {\n    // Mixed-case: fix per-word (digits between lowercase letters)\n    text = text.split(/(\\s+)/).map((token) => {\n      if (/^\\s+$/.test(token)) return token;\n      if (isAllCaps(token) && token.length > 1) {\n        return token\n          .replace(/1/g, \"I\")\n          .replace(/0(?=[A-Z])/g, \"O\")\n          .replace(/(?<=[A-Z])0/g, \"O\");\n      }\n      return token\n        .replace(/(?<=[a-zà-ż])1/g, \"l\")\n        .replace(/1(?=[a-zà-ż])/g, \"l\")\n        .replace(/¡/g, \"i\")\n        .replace(/€/g, \"e\");\n    }).join(\"\");\n  }\n\n  // Step 3: Title-case conversion — ONLY when OCR substitution changed the text.\n  // This preserves clean ALL_CAPS titles (e.g. \"CHOCOLATE CAKE\") as-is.\n  if (text !== beforeSub && isAllCaps(text)) {\n    text = toTitleCase(text);\n  }\n\n  return text.trim();\n}\n\n// Module-level cache for reference embeddings\nlet cachedTitleRefEmbedding: Array<number> | null = null;\nlet cachedHeaderRefEmbedding: Array<number> | null = null;\nlet cachedNoiseRefEmbedding: Array<number> | null = null;\n\nexport function _resetEmbeddingCacheForTests(): void {\n  cachedTitleRefEmbedding = null;\n  cachedHeaderRefEmbedding = null;\n  cachedNoiseRefEmbedding = null;\n}\n\nexport async function extractTitleWithEmbeddings(\n  text: string,\n  embed: EmbedFn\n): Promise<string | undefined> {\n  if (!text || text.trim().length === 0) {\n    return undefined;\n  }\n\n  const lines = text.split(\"\\n\");\n  const candidates = buildCandidates(lines);\n\n  if (candidates.length === 0) {\n    return undefined;\n  }\n\n  // Cache reference embeddings\n  if (!cachedTitleRefEmbedding) {\n    cachedTitleRefEmbedding = await embed(TITLE_REFERENCE);\n  }\n  if (!cachedHeaderRefEmbedding) {\n    cachedHeaderRefEmbedding = await embed(HEADER_REFERENCE);\n  }\n  if (!cachedNoiseRefEmbedding) {\n    cachedNoiseRefEmbedding = await embed(NOISE_REFERENCE);\n  }\n\n  // Find ALL_CAPS candidates with ≥2 words where every significant word has ≥4 alpha letters.\n  // Insignificant tokens (≤1 alpha letter: \"/\", \"&\", \"+\", \":\", \"D)\", etc.) are filtered before\n  // the check so that multi-line joins with continuation punctuation still qualify.\n  const isStructuralHeading = (c: { text: string }): boolean => {\n    if (!isAllCaps(c.text) || wordCount(c.text) < 2) return false;\n    const sigWords = c.text.trim().split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length > 1);\n    return sigWords.length >= 2 && sigWords.every((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n  };\n\n  // Pass 1: compute rawScore for all candidates (embedding quality signal)\n  const rawScored: Array<{ text: string; position: number; origin: CandidateOrigin; rawScore: number; embedding: Array<number> }> = [];\n  for (const candidate of candidates) {\n    const embedding = await embed(candidate.text);\n    const titleSim = cosineSimilarity(embedding, cachedTitleRefEmbedding);\n    const headerSim = cosineSimilarity(embedding, cachedHeaderRefEmbedding);\n    const noiseSim = cosineSimilarity(embedding, cachedNoiseRefEmbedding);\n    const rawScore = titleSim - Math.max(headerSim, noiseSim);\n    rawScored.push({ text: candidate.text, position: candidate.position, origin: candidate.origin, rawScore, embedding });\n  }\n\n  // Select baseHeading by embedding quality (rawScore), not position.\n  // This prevents OCR-garbled fragments from claiming the structural heading slot.\n  const structuralCandidates = rawScored.filter((s) => isStructuralHeading(s));\n\n  // Penalize structural headings with truncated OCR words:\n  // if \"FRON\" appears and another heading has \"SAFFRON\", \"FRON\" is likely garbled.\n  for (const sc of structuralCandidates) {\n    const sigWords = sc.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n    for (const other of structuralCandidates) {\n      if (other === sc) continue;\n      const otherSigWords = other.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n      const hasTruncation = sigWords.some((w) =>\n        otherSigWords.some((ow) => ow !== w && ow.length > w.length && ow.endsWith(w))\n      );\n      if (hasTruncation) {\n        sc.rawScore = -1.0;  // Hard disqualification — truncated OCR artifact\n        break;\n      }\n    }\n  }\n\n  const bestStructural = structuralCandidates.length > 0\n    ? structuralCandidates.reduce((a, b) => {\n        const scoreDiff = a.rawScore - b.rawScore;\n        if (Math.abs(scoreDiff) > 0.03) return scoreDiff > 0 ? a : b;\n        // Tiebreak: single-line origin beats multi-line joins (avoids conflating two separate headings)\n        if (a.origin === \"single\" && b.origin !== \"single\") return a;\n        if (b.origin === \"single\" && a.origin !== \"single\") return b;\n        // Tiebreak: more words (more specific) → better\n        const wcDiff = wordCount(b.text) - wordCount(a.text);\n        if (wcDiff !== 0) return wcDiff > 0 ? b : a;\n        // Tiebreak: earlier position → better\n        return a.position < b.position ? a : b;\n      })\n    : null;\n  const baseHeading = bestStructural ?? undefined;\n\n  // When the best structural heading has a continuation on the next line introduced by a\n  // punctuation token (/, &, +, :, or parenthesis), prefer the longer 2-line join as the\n  // complete heading. E.g. \"SAFFRON WHEAT BUNS WITH QUARK\" + \"/ COTTAGE CHEESE (VARIATION D)\".\n  // Guard: the remainder after the prefix must start with a continuation character to avoid\n  // merging two separate consecutive recipe titles (FINNISH MILK FLATBREADS stays separate\n  // from FINNISH POTATO FLATBREADS because \"FINNISH\" does not start with a continuation token).\n  let firstStructuralHeading = baseHeading && (\n    rawScored.find((c) => {\n      if (!isStructuralHeading(c)) return false;\n      const hLower = baseHeading.text.toLowerCase();\n      const cLower = c.text.toLowerCase();\n      return cLower.startsWith(hLower + \" \") && /^[/&+:(]/.test(cLower.slice(hLower.length + 1));\n    }) ?? baseHeading\n  );\n\n  // Pass 2: apply bonuses\n  const scored: Array<{ text: string; position: number; origin: CandidateOrigin; score: number; rawScore: number; baseScore: number; thresholdScore: number }> = rawScored.map((rs) => {\n    // Position factor: multiplicative tiebreaker — amplifies existing signal, doesn't replace it\n    const relativePosition = rs.position / lines.length;\n    const positionFactor = relativePosition < 0.5\n      ? 1.0 + 0.12 * (1 - relativePosition * 2)\n      : 1.0;\n\n    // ALL_CAPS bonus: recipe books use ALL_CAPS for titles and section headings.\n    // Single-word ALL_CAPS terms are overwhelmingly section/category labels, not recipe titles;\n    // real recipe titles in ALL_CAPS are almost always multi-word. Reduce the bonus for single words.\n    const allCapsBonus = isAllCaps(rs.text) && rs.text.replace(/[^a-zA-Z]/g, \"\").length >= 4\n      ? (wordCount(rs.text) >= 2 ? 0.08 : 0.03)\n      : 0;\n\n    // Structural heading bonus: best ALL_CAPS heading (or its continuation join) is almost always the recipe title\n    const structuralBonus = firstStructuralHeading && rs.text === firstStructuralHeading.text ? 0.10 : 0;\n\n    // thresholdScore excludes structural bonus so the bonus doesn't inflate the threshold\n    // and prevent equally-valid structural headings from passing on multi-recipe pages.\n    const thresholdScore = rs.rawScore + allCapsBonus;\n    // baseScore excludes position factor — used for diagnostics and ranking\n    const baseScore = rs.rawScore + allCapsBonus + structuralBonus;\n    const score = rs.rawScore * positionFactor + allCapsBonus + structuralBonus;\n    return { text: rs.text, position: rs.position, origin: rs.origin, score, rawScore: rs.rawScore, baseScore, thresholdScore };\n  });\n\n  if (scored.length === 0) {\n    return undefined;\n  }","numLines":400,"startLine":400,"totalLines":1171}}}
