{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GSdFWYVyqwEt2ujr6fHEmc","type":"tool_result","content":"   307→\n   308→function passesHardFilters(text: string): boolean {\n   309→  if (text.length < 3 || text.length > 80) return false;\n   310→  if (looksLikeIngredient(text)) return false;\n   311→  if (startsWithNumber(text)) return false;\n   312→  if (looksLikeMetadata(text)) return false;\n   313→  if (isLikelyGarbled(text)) return false;\n   314→  if (looksLikeCookingInstruction(text)) return false;\n   315→  // Pipe-separated lines are book category/chapter headers, not recipe titles\n   316→  if (text.includes(\" | \")) return false;\n   317→  // Trailing page number (e.g. \"VEGETABLE SIDES                         145\")\n   318→  if (/\\s{3,}\\d{1,4}\\s*$/.test(text)) return false;\n   319→  // Slash-separated breadcrumbs (e.g., \"/ Jesien / Zupy\") are navigation, not titles\n   320→  // Only filter when 2+ slashes are present — single-slash lines like\n   321→  // \"TITLE / SUBTITLE\" are legitimate continuation-merged titles\n   322→  if ((text.match(/\\//g) || []).length >= 2) return false;\n   323→  // Bullet-list items (ingredients or instruction steps) are never titles\n   324→  if (/^\\s*[-•*]\\s/.test(text)) return false;\n   325→  // Lines starting with \"--\" are sub-section headers (e.g., \"--VARIATION:\", \"--WERSJA NOWOCZESNA\")\n   326→  if (/^--\\s*\\w/.test(text)) return false;\n   327→  // \"For the sauce:\", \"For the filling:\" etc. are sub-section headers\n   328→  if (/^For the\\s+/i.test(text) && /:\\s*$/.test(text)) return false;\n   329→  // Lines ending with \":\" are recipe sub-section headers, not titles.\n   330→  // Exception: compound titles using \" : \" as a title separator (e.g. \"LEMON CURD : LEMON CURD WITH THYME\").\n   331→  if (/:\\s*$/.test(text.trim()) && !/ : /.test(text)) return false;\n   332→  // Page references are navigation markers, not recipe titles\n   333→  if (/^Page\\s+\\d+/i.test(text.trim())) return false;\n   334→  if (/^Strona\\s+\\d+/i.test(text.trim())) return false;\n   335→  // Corrupted spillover annotations from synthetic multi-page OCR\n   336→  if (/^\\[CORRUPTED\\s+SPILLOVER/i.test(text.trim())) return false;"}]},"parent_tool_use_id":null,"session_id":"ec54b805-2592-4abe-8e4f-4011b51bb626","uuid":"1bb24197-0ba3-44a5-9313-bd1fe5ebce6c","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/title-extractor.ts","content":"\nfunction passesHardFilters(text: string): boolean {\n  if (text.length < 3 || text.length > 80) return false;\n  if (looksLikeIngredient(text)) return false;\n  if (startsWithNumber(text)) return false;\n  if (looksLikeMetadata(text)) return false;\n  if (isLikelyGarbled(text)) return false;\n  if (looksLikeCookingInstruction(text)) return false;\n  // Pipe-separated lines are book category/chapter headers, not recipe titles\n  if (text.includes(\" | \")) return false;\n  // Trailing page number (e.g. \"VEGETABLE SIDES                         145\")\n  if (/\\s{3,}\\d{1,4}\\s*$/.test(text)) return false;\n  // Slash-separated breadcrumbs (e.g., \"/ Jesien / Zupy\") are navigation, not titles\n  // Only filter when 2+ slashes are present — single-slash lines like\n  // \"TITLE / SUBTITLE\" are legitimate continuation-merged titles\n  if ((text.match(/\\//g) || []).length >= 2) return false;\n  // Bullet-list items (ingredients or instruction steps) are never titles\n  if (/^\\s*[-•*]\\s/.test(text)) return false;\n  // Lines starting with \"--\" are sub-section headers (e.g., \"--VARIATION:\", \"--WERSJA NOWOCZESNA\")\n  if (/^--\\s*\\w/.test(text)) return false;\n  // \"For the sauce:\", \"For the filling:\" etc. are sub-section headers\n  if (/^For the\\s+/i.test(text) && /:\\s*$/.test(text)) return false;\n  // Lines ending with \":\" are recipe sub-section headers, not titles.\n  // Exception: compound titles using \" : \" as a title separator (e.g. \"LEMON CURD : LEMON CURD WITH THYME\").\n  if (/:\\s*$/.test(text.trim()) && !/ : /.test(text)) return false;\n  // Page references are navigation markers, not recipe titles\n  if (/^Page\\s+\\d+/i.test(text.trim())) return false;\n  if (/^Strona\\s+\\d+/i.test(text.trim())) return false;\n  // Corrupted spillover annotations from synthetic multi-page OCR\n  if (/^\\[CORRUPTED\\s+SPILLOVER/i.test(text.trim())) return false;","numLines":30,"startLine":307,"totalLines":1364}}}
