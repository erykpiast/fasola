{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01W9923PoUFTt48g6RPdgRUF","type":"tool_result","content":"   790→  embed: EmbedFn\n   791→): Promise<string | undefined> {\n   792→  if (!text || text.trim().length === 0) {\n   793→    return undefined;\n   794→  }\n   795→\n   796→  const lines = text.split(\"\\n\");\n   797→  const candidates = buildCandidates(lines);\n   798→  const titleAbsent = isTitleAbsentPage(lines);\n   799→\n   800→  if (candidates.length === 0) {\n   801→    return undefined;\n   802→  }\n   803→\n   804→  // Cache reference embeddings\n   805→  if (!cachedTitleRefEmbedding) {\n   806→    cachedTitleRefEmbedding = await embed(TITLE_REFERENCE);\n   807→  }\n   808→  if (!cachedHeaderRefEmbedding) {\n   809→    cachedHeaderRefEmbedding = await embed(HEADER_REFERENCE);\n   810→  }\n   811→  if (!cachedNoiseRefEmbedding) {\n   812→    cachedNoiseRefEmbedding = await embed(NOISE_REFERENCE);\n   813→  }\n   814→\n   815→  // Find ALL_CAPS candidates with ≥2 words where every significant word has ≥4 alpha letters.\n   816→  // Insignificant tokens (≤1 alpha letter: \"/\", \"&\", \"+\", \":\", \"D)\", etc.) are filtered before\n   817→  // the check so that multi-line joins with continuation punctuation still qualify.\n   818→  const isStructuralHeading = (c: { text: string }): boolean => {\n   819→    if (!isAllCaps(c.text) || wordCount(c.text) < 2) return false;\n   820→    const sigWords = c.text.trim().split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length > 1);\n   821→    return sigWords.length >= 2 && sigWords.every((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   822→  };\n   823→\n   824→  // Pass 1: compute rawScore for all candidates (embedding quality signal)\n   825→  const rawScored: Array<{ text: string; position: number; origin: CandidateOrigin; rawScore: number; embedding: Array<number> }> = [];\n   826→  for (const candidate of candidates) {\n   827→    const embedding = await embed(candidate.text);\n   828→    const titleSim = cosineSimilarity(embedding, cachedTitleRefEmbedding);\n   829→    const headerSim = cosineSimilarity(embedding, cachedHeaderRefEmbedding);\n   830→    const noiseSim = cosineSimilarity(embedding, cachedNoiseRefEmbedding);\n   831→    const rawScore = titleSim - Math.max(headerSim, noiseSim);\n   832→    rawScored.push({ text: candidate.text, position: candidate.position, origin: candidate.origin, rawScore, embedding });\n   833→  }\n   834→\n   835→  // Select baseHeading by embedding quality (rawScore), not position.\n   836→  // This prevents OCR-garbled fragments from claiming the structural heading slot.\n   837→  const structuralCandidates = rawScored.filter((s) => isStructuralHeading(s));\n   838→\n   839→  // Penalize structural headings with truncated OCR words:\n   840→  // if \"FRON\" appears and another heading has \"SAFFRON\", \"FRON\" is likely garbled.\n   841→  for (const sc of structuralCandidates) {\n   842→    const sigWords = sc.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   843→    for (const other of structuralCandidates) {\n   844→      if (other === sc) continue;\n   845→      const otherSigWords = other.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   846→      const hasTruncation = sigWords.some((w) =>\n   847→        otherSigWords.some((ow) => ow !== w && ow.length > w.length && ow.endsWith(w))\n   848→      );\n   849→      if (hasTruncation) {"}]},"parent_tool_use_id":"toolu_016vMXm965JDYqz841kU7bii","session_id":"ec54b805-2592-4abe-8e4f-4011b51bb626","uuid":"1c889cbb-8141-454a-87cb-b16d7cdb01ff"}
