{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018rqJfgfuoqf5NsbBs6XvH8","type":"tool_result","content":"     1→/**\n     2→ * Native Text Classifier\n     3→ * Supports both MiniLM embeddings (via TextEmbeddingsModule) and TF-IDF\n     4→ */\n     5→\n     6→import {\n     7→  ALL_MINILM_L6_V2,\n     8→  TextEmbeddingsModule,\n     9→} from \"react-native-executorch\";\n    10→import { classifyWithEmbeddings, type LabelEmbedding } from \"./embeddings\";\n    11→import type {\n    12→  ClassificationMethod,\n    13→  ClassificationResult,\n    14→  TagSuggestion,\n    15→} from \"./index.d\";\n    16→import {\n    17→  ALL_CATEGORY_KEYS,\n    18→  ALL_CUISINE_KEYS,\n    19→  ALL_SEASON_KEYS,\n    20→  CATEGORY_LABELS,\n    21→  CUISINE_LABELS,\n    22→  SEASON_LABELS,\n    23→} from \"./labels\";\n    24→import { classifyWithTfIdf } from \"./tfidf\";\n    25→import {\n    26→  extractTitle,\n    27→  extractTitleWithEmbeddings,\n    28→} from \"./title-extractor\";\n    29→\n    30→/**\n    31→ * Singleton pattern for model and label embeddings\n    32→ */\n    33→class EmbeddingsManager {\n    34→  private static instance: TextEmbeddingsModule | null = null;\n    35→  private static labelEmbeddings: Array<LabelEmbedding> | null = null;\n    36→  private static isInitializing = false;\n    37→\n    38→  static async initialize(): Promise<void> {\n    39→    if (this.instance && this.labelEmbeddings) {\n    40→      return; // Already initialized\n    41→    }\n    42→\n    43→    if (this.isInitializing) {\n    44→      // Wait for ongoing initialization\n    45→      await new Promise((resolve) => setTimeout(resolve, 100));\n    46→      return this.initialize();\n    47→    }\n    48→\n    49→    this.isInitializing = true;\n    50→\n    51→    try {\n    52→      console.log(\"[Text Classifier] Initializing MiniLM model...\");\n    53→\n    54→      // Create and load the model\n    55→      this.instance = new TextEmbeddingsModule();\n    56→      await this.instance.load({\n    57→        modelSource: ALL_MINILM_L6_V2.modelSource,\n    58→        tokenizerSource: ALL_MINILM_L6_V2.tokenizerSource,\n    59→      });\n    60→\n    61→      console.log(\"[Text Classifier] Computing label embeddings...\");\n    62→\n    63→      // Compute embeddings for all labels\n    64→      const embeddings: Array<LabelEmbedding> = [];\n    65→\n    66→      for (const key of ALL_SEASON_KEYS) {\n    67→        const description = SEASON_LABELS[key];\n    68→        const embeddingRaw = await this.instance.forward(description);\n    69→        const embedding = Array.from(embeddingRaw);\n    70→        embeddings.push({ key, category: \"season\", embedding });\n    71→      }\n    72→\n    73→      for (const key of ALL_CUISINE_KEYS) {\n    74→        const description = CUISINE_LABELS[key];\n    75→        const embeddingRaw = await this.instance.forward(description);\n    76→        const embedding = Array.from(embeddingRaw);\n    77→        embeddings.push({ key, category: \"cuisine\", embedding });\n    78→      }\n    79→\n    80→      for (const key of ALL_CATEGORY_KEYS) {\n    81→        const description = CATEGORY_LABELS[key];\n    82→        const embeddingRaw = await this.instance.forward(description);\n    83→        const embedding = Array.from(embeddingRaw);\n    84→        embeddings.push({ key, category: \"food-category\", embedding });\n    85→      }\n    86→\n    87→      this.labelEmbeddings = embeddings;\n    88→      console.log(\n    89→        `[Text Classifier] Initialized with ${embeddings.length} label embeddings`\n    90→      );\n    91→    } finally {\n    92→      this.isInitializing = false;\n    93→    }\n    94→  }\n    95→\n    96→  static async forward(text: string): Promise<Array<number>> {\n    97→    await this.initialize();\n    98→\n    99→    if (!this.instance) {\n   100→      throw new Error(\"Failed to initialize embeddings\");\n   101→    }\n   102→\n   103→    const raw = await this.instance.forward(text);\n   104→    return Array.from(raw);\n   105→  }\n   106→\n   107→  static async classify(text: string): Promise<Array<TagSuggestion>> {\n   108→    await this.initialize();\n   109→\n   110→    if (!this.instance || !this.labelEmbeddings) {\n   111→      throw new Error(\"Failed to initialize embeddings\");\n   112→    }\n   113→\n   114→    // Get text embedding\n   115→    const textEmbeddingRaw = await this.instance.forward(text);\n   116→    const textEmbedding = Array.from(textEmbeddingRaw);\n   117→\n   118→    // Use shared classification function\n   119→    return classifyWithEmbeddings(textEmbedding, this.labelEmbeddings);\n   120→  }\n   121→}\n   122→\n   123→/**\n   124→ * Classify text using TF-IDF scoring\n   125→ */\n   126→function classifyWithTfIdfMethod(text: string): ClassificationResult {\n   127→  const startTime = Date.now();\n   128→\n   129→  try {\n   130→    const title = extractTitle(text);\n   131→    const allSuggestions = classifyWithTfIdf(text);\n   132→\n   133→    // Filter to top suggestions (max 2 per category with confidence >= 0.3)\n   134→    const suggestions: Array<TagSuggestion> = [];\n   135→    const counts = { season: 0, cuisine: 0, \"food-category\": 0 };\n   136→\n   137→    for (const suggestion of allSuggestions) {\n   138→      if (counts[suggestion.category] < 2 && suggestion.confidence >= 0.3) {\n   139→        suggestions.push(suggestion);\n   140→        counts[suggestion.category]++;\n   141→      }\n   142→    }\n   143→\n   144→    return {\n   145→      title,\n   146→      suggestions,\n   147→      processingTimeMs: Date.now() - startTime,\n   148→    };\n   149→  } catch (error) {\n   150→    console.error(\"[Text Classifier] TF-IDF classification failed:\", error);\n   151→    return {\n   152→      title: extractTitle(text),\n   153→      suggestions: [],\n   154→      processingTimeMs: Date.now() - startTime,\n   155→    };\n   156→  }\n   157→}\n   158→\n   159→/**\n   160→ * Classify text using embeddings\n   161→ */\n   162→async function classifyWithEmbeddingsMethod(\n   163→  text: string\n   164→): Promise<ClassificationResult> {\n   165→  const startTime = Date.now();\n   166→\n   167→  try {\n   168→    const title = await extractTitleWithEmbeddings(\n   169→      text,\n   170→      EmbeddingsManager.forward.bind(EmbeddingsManager)\n   171→    );\n   172→    const allSuggestions = await EmbeddingsManager.classify(text);\n   173→\n   174→    // Sort by confidence\n   175→    allSuggestions.sort((a, b) => b.confidence - a.confidence);\n   176→\n   177→    // Filter to top suggestions (max 2 per category)\n   178→    const suggestions: Array<TagSuggestion> = [];\n   179→    const counts = { season: 0, cuisine: 0, \"food-category\": 0 };\n   180→\n   181→    for (const suggestion of allSuggestions) {\n   182→      if (counts[suggestion.category] < 2) {\n   183→        suggestions.push(suggestion);\n   184→        counts[suggestion.category]++;\n   185→      }\n   186→    }\n   187→\n   188→    console.log(\n   189→      `[Text Classifier] Found ${suggestions.length} suggestions in ${\n   190→        Date.now() - startTime\n   191→      }ms`\n   192→    );\n   193→\n   194→    return {\n   195→      title,\n   196→      suggestions,\n   197→      processingTimeMs: Date.now() - startTime,\n   198→    };\n   199→  } catch (error) {\n   200→    console.error(\"[Text Classifier] Embeddings classification failed:\", error);\n   201→    return {\n   202→      title: extractTitle(text),\n   203→      suggestions: [],\n   204→      processingTimeMs: Date.now() - startTime,\n   205→    };\n   206→  }\n   207→}\n   208→\n   209→/**\n   210→ * Classify text and extract recipe metadata\n   211→ */\n   212→export async function classifyText(\n   213→  text: string,\n   214→  method: ClassificationMethod = \"embeddings\"\n   215→): Promise<ClassificationResult> {\n   216→  if (method === \"tfidf\") {\n   217→    return classifyWithTfIdfMethod(text);\n   218→  }\n   219→\n   220→  return classifyWithEmbeddingsMethod(text);\n   221→}\n   222→\n   223→/**\n   224→ * No-op for native platform - no precomputation needed for keyword matching\n   225→ */\n   226→export function useLabelEmbeddings(): {\n   227→  isReady: boolean;\n   228→  error: string | null;\n   229→} {\n   230→  return { isReady: true, error: null };\n   231→}\n   232→"}]},"parent_tool_use_id":"toolu_013RHKQxMrX4xKvSfjN9AJZG","session_id":"ec54b805-2592-4abe-8e4f-4011b51bb626","uuid":"f2f66b35-a7c5-4d13-8801-8d0350a5ede9"}
