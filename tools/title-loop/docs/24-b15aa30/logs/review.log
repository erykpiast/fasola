{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Cg26Vyr6tLRnisPP5diMio","type":"tool_result","content":"   460→      nonEmptyLines[hi] = { text: joined, index: nonEmptyLines[hi].index };\n   461→      nonEmptyLines.splice(hi + 1, 1);\n   462→    }\n   463→  }\n   464→\n   465→  // Pre-merge consecutive short ALL_CAPS lines (OCR-fragmented headings).\n   466→  // When a sequence of 2+ ALL_CAPS lines each has ≤2 words and ≤25 chars, they are\n   467→  // almost certainly OCR fragments of a single heading. Merge them into one line so\n   468→  // the complete title enters the candidate pool without hitting the 3-line join ceiling.\n   469→  const capsCoalesced: Array<{ text: string; index: number }> = [];\n   470→  let ci = burstEnd;\n   471→  while (ci < nonEmptyLines.length) {\n   472→    const line = nonEmptyLines[ci];\n   473→    if (\n   474→      isAllCaps(line.text) &&\n   475→      wordCount(line.text) <= 2 &&\n   476→      line.text.length <= 25 &&\n   477→      !isSectionLabel(line.text) &&\n   478→      !looksLikeMetadata(line.text)\n   479→    ) {\n   480→      let merged = line.text;\n   481→      const startIndex = line.index;\n   482→      let j = ci + 1;\n   483→      while (j < nonEmptyLines.length) {\n   484→        const next = nonEmptyLines[j];\n   485→        if (\n   486→          isAllCaps(next.text) &&\n   487→          wordCount(next.text) <= 2 &&\n   488→          next.text.length <= 25 &&\n   489→          !isSectionLabel(next.text) &&\n   490→          !isSectionLabel(repairOcrText(next.text)) &&\n   491→          !looksLikeMetadata(next.text) &&\n   492→          (merged + \" \" + next.text).length <= 80\n   493→        ) {\n   494→          merged += \" \" + next.text;\n   495→          j++;\n   496→        } else {\n   497→          break;\n   498→        }\n   499→      }\n   500→      if (j > ci + 1) {\n   501→        capsCoalesced.push({ text: merged, index: startIndex });\n   502→        ci = j;\n   503→        continue;\n   504→      }\n   505→    }\n   506→    capsCoalesced.push(line);\n   507→    ci++;\n   508→  }\n   509→\n   510→  // Pre-merge continuation lines: a line starting with /&+:( is never a standalone title.\n   511→  // Merge it into the preceding line so the complete title enters the pool as a single candidate,\n   512→  // avoiding the fragile chain of conditions required by the downstream join survival logic.\n   513→  // Limitation: only one continuation line per preceding line is merged. Titles split across\n   514→  // three or more lines with continuation tokens (rare in practice) are not handled here —\n   515→  // the downstream 2-line and 3-line join candidates cover those cases instead.\n   516→  const mergedLines: Array<{ text: string; index: number }> = [];\n   517→  for (let i = 0; i < capsCoalesced.length; i++) {\n   518→    const line = capsCoalesced[i];\n   519→    if (i + 1 < capsCoalesced.length) {\n   520→      const nextText = capsCoalesced[i + 1].text;\n   521→      if (/^[/&+:(]/.test(nextText)) {\n   522→        mergedLines.push({ text: `${line.text} ${nextText}`, index: line.index });\n   523→        i++;\n   524→        continue;\n   525→      }\n   526→    }\n   527→    mergedLines.push(line);\n   528→  }\n   529→\n   530→  const candidates: Array<{ text: string; position: number; origin: CandidateOrigin }> = [];\n   531→  const seen = new Set<string>();\n   532→\n   533→  // Build a set of positions to skip: short ALL_CAPS lines immediately following metadata\n   534→  const metadataContinuationPositions = new Set<number>();\n   535→  for (let i = 0; i < mergedLines.length - 1; i++) {\n   536→    if (looksLikeMetadata(mergedLines[i].text)) {\n   537→      const next = mergedLines[i + 1];\n   538→      if (isAllCaps(next.text) && wordCount(next.text) <= 2 && next.text.length <= 15) {\n   539→        metadataContinuationPositions.add(next.index);\n   540→      }\n   541→    }\n   542→  }\n   543→\n   544→  for (let i = 0; i < mergedLines.length; i++) {\n   545→    const line = mergedLines[i];\n   546→\n   547→    // Skip metadata continuation fragments\n   548→    if (metadataContinuationPositions.has(line.index)) continue;\n   549→\n   550→    // Single line — strip page-number prefixes and parenthetical glosses before scoring\n   551→    const singleText = repairOcrText(stripParentheticalGloss(stripPageNumber(line.text)));\n   552→    if (passesHardFilters(singleText)) {\n   553→      const norm = singleText.toLowerCase();\n   554→      if (!seen.has(norm)) {\n   555→        seen.add(norm);\n   556→        candidates.push({ text: singleText, position: line.index, origin: \"single\" });\n   557→      }\n   558→    }\n   559→\n   560→    // 2-line join — skip if first line is a section label AND join would be ≤2 words\n   561→    // (a section label followed by modifiers is likely a recipe title, not a category header)\n   562→    if (i + 1 < mergedLines.length) {\n   563→      const joined2 = repairOcrText(`${line.text} ${mergedLines[i + 1].text}`);\n   564→      const shouldBlock2 = isSectionLabel(line.text) &&\n   565→        (wordCount(joined2) <= 2 || isAlwaysBlockJoinLabel(line.text));\n   566→      if (!shouldBlock2 && passesHardFilters(joined2)) {\n   567→        const norm = joined2.toLowerCase();\n   568→        if (!seen.has(norm)) {\n   569→          seen.add(norm);\n   570→          candidates.push({ text: joined2, position: line.index, origin: \"2-line\" });\n   571→        }\n   572→      }\n   573→    }\n   574→\n   575→    // 3-line join — skip if first line is a section label AND join would be ≤2 words\n   576→    if (i + 2 < mergedLines.length) {\n   577→      const joined3 = repairOcrText(`${line.text} ${mergedLines[i + 1].text} ${mergedLines[i + 2].text}`);\n   578→      const shouldBlock3 = isSectionLabel(line.text) &&\n   579→        (wordCount(joined3) <= 2 || isAlwaysBlockJoinLabel(line.text));\n   580→      if (!shouldBlock3 && passesHardFilters(joined3)) {\n   581→        const norm = joined3.toLowerCase();\n   582→        if (!seen.has(norm)) {\n   583→          seen.add(norm);\n   584→          candidates.push({ text: joined3, position: line.index, origin: \"3-line\" });\n   585→        }\n   586→      }\n   587→    }\n   588→  }\n   589→\n   590→  // Pre-filter to 25 before embedding calls: prefer ALL_CAPS and short candidates.\n   591→  // Position-based scoring handles final ranking.\n   592→  if (candidates.length > 25) {\n   593→    const prioritized = candidates.slice().sort((a, b) => {\n   594→      const aAllCaps = isAllCaps(a.text) ? 0 : 1;\n   595→      const bAllCaps = isAllCaps(b.text) ? 0 : 1;\n   596→      if (aAllCaps !== bAllCaps) return aAllCaps - bAllCaps;\n   597→      const aShort = wordCount(a.text) <= 5 ? 0 : 1;\n   598→      const bShort = wordCount(b.text) <= 5 ? 0 : 1;\n   599→      return aShort - bShort;"}]},"parent_tool_use_id":"toolu_016vMXm965JDYqz841kU7bii","session_id":"ec54b805-2592-4abe-8e4f-4011b51bb626","uuid":"4fb61ffe-c2e0-401c-aa61-b1c3a7ee44f9"}
