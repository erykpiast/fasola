{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013dENs7r4wVpY8smQUg5LRZ","type":"tool_result","content":"     1→#!/usr/bin/env node\n     2→\n     3→/**\n     4→ * CLI for testing text classifier in Node.js\n     5→ * Supports both MiniLM embeddings and TF-IDF for comparison\n     6→ * Usage: npx tsx lib/text-classifier/cli.ts <text-file-path> [--method=embeddings|tfidf|both]\n     7→ */\n     8→\n     9→import { readFileSync } from \"fs\";\n    10→import { classifyWithEmbeddings, type LabelEmbedding } from \"./embeddings\";\n    11→import {\n    12→  embedText,\n    13→  loadEmbedder,\n    14→  type FeatureEmbedder,\n    15→} from \"./embedder\";\n    16→import type { ClassificationCategory } from \"./index.d\";\n    17→import {\n    18→  ALL_CATEGORY_KEYS,\n    19→  ALL_CUISINE_KEYS,\n    20→  ALL_SEASON_KEYS,\n    21→  CATEGORY_LABELS,\n    22→  CUISINE_LABELS,\n    23→  SEASON_LABELS,\n    24→} from \"./labels\";\n    25→import { classifyWithTfIdf } from \"./tfidf\";\n    26→import {\n    27→  extractTitle,\n    28→  extractTitleWithEmbeddings,\n    29→} from \"./title-extractor\";\n    30→\n    31→interface TagSuggestion {\n    32→  tag: string;\n    33→  confidence: number;\n    34→  category: ClassificationCategory;\n    35→}\n    36→\n    37→async function computeLabelEmbeddings(\n    38→  embedder: FeatureEmbedder\n    39→): Promise<Array<LabelEmbedding>> {\n    40→  const labelEmbeddings: Array<LabelEmbedding> = [];\n    41→\n    42→  for (const key of ALL_SEASON_KEYS) {\n    43→    const description = SEASON_LABELS[key];\n    44→    const embedding = await embedText(embedder, description);\n    45→    labelEmbeddings.push({ key, category: \"season\", embedding });\n    46→  }\n    47→\n    48→  for (const key of ALL_CUISINE_KEYS) {\n    49→    const description = CUISINE_LABELS[key];\n    50→    const embedding = await embedText(embedder, description);\n    51→    labelEmbeddings.push({ key, category: \"cuisine\", embedding });\n    52→  }\n    53→\n    54→  for (const key of ALL_CATEGORY_KEYS) {\n    55→    const description = CATEGORY_LABELS[key];\n    56→    const embedding = await embedText(embedder, description);\n    57→    labelEmbeddings.push({ key, category: \"food-category\", embedding });\n    58→  }\n    59→\n    60→  return labelEmbeddings;\n    61→}\n    62→\n    63→async function generateEmbeddingAndClassify(\n    64→  embedder: FeatureEmbedder,\n    65→  text: string,\n    66→  labelEmbeddings: Array<LabelEmbedding>\n    67→): Promise<Array<TagSuggestion>> {\n    68→  const textEmbedding = await embedText(embedder, text);\n    69→  return classifyWithEmbeddings(textEmbedding, labelEmbeddings);\n    70→}\n    71→\n    72→function printResults(\n    73→  allSuggestions: Array<TagSuggestion>,\n    74→  methodName: string\n    75→): void {\n    76→  console.log(\"=\".repeat(60));\n    77→  console.log(`RESULTS (${methodName})`);\n    78→  console.log(\"=\".repeat(60));\n    79→  console.log();\n    80→\n    81→  if (allSuggestions.length === 0) {\n    82→    console.log(\"No tags found\");\n    83→  } else {\n    84→    console.log(\"Tag Suggestions (confidence scores):\");\n    85→    console.log();\n    86→\n    87→    const grouped = {\n    88→      season: allSuggestions.filter((s) => s.category === \"season\"),\n    89→      cuisine: allSuggestions.filter((s) => s.category === \"cuisine\"),\n    90→      \"food-category\": allSuggestions.filter(\n    91→        (s) => s.category === \"food-category\"\n    92→      ),\n    93→    };\n    94→\n    95→    for (const [category, suggestions] of Object.entries(grouped)) {\n    96→      if (suggestions.length > 0) {\n    97→        console.log(`  ${category.toUpperCase()}:`);\n    98→        for (const suggestion of suggestions) {\n    99→          const confidence = suggestion.confidence.toFixed(3);\n   100→          const bar = \"█\".repeat(Math.floor(suggestion.confidence * 50));\n   101→          console.log(`    ${suggestion.tag.padEnd(20)} ${confidence} ${bar}`);\n   102→        }\n   103→        console.log();\n   104→      }\n   105→    }\n   106→  }\n   107→}\n   108→\n   109→/**\n   110→ * Run TF-IDF classification\n   111→ */\n   112→async function runTfIdfClassification(text: string): Promise<void> {\n   113→  const startTime = Date.now();\n   114→\n   115→  console.log(\"=\".repeat(60));\n   116→  console.log(\"TEXT CLASSIFIER TEST (TF-IDF)\");\n   117→  console.log(\"=\".repeat(60));\n   118→  console.log();\n   119→\n   120→  console.log(\"Classifying text with TF-IDF...\");\n   121→  const allSuggestions = classifyWithTfIdf(text);\n   122→  allSuggestions.sort((a, b) => b.confidence - a.confidence);\n   123→\n   124→  console.log();\n   125→  printResults(allSuggestions, \"TF-IDF\");\n   126→\n   127→  const totalTime = Date.now() - startTime;\n   128→  console.log(\n   129→    `Processing time: ${totalTime}ms (${(totalTime / 1000).toFixed(1)}s)`\n   130→  );\n   131→  console.log();\n   132→}\n   133→\n   134→async function loadEmbedderWithProgress(): Promise<FeatureEmbedder> {\n   135→  console.log(\"Loading MiniLM embedding model (this may take a moment)...\");\n   136→  const embedder = await loadEmbedder((progress) => {\n   137→    if (\n   138→      progress.status === \"progress\" &&\n   139→      progress.loaded &&\n   140→      progress.total\n   141→    ) {\n   142→      const percent = Math.round((progress.loaded / progress.total) * 100);\n   143→      process.stdout.write(`\\rDownloading: ${percent}%`);\n   144→    } else if (progress.status === \"done\") {\n   145→      process.stdout.write(\"\\rDownload complete!\\n\");\n   146→    }\n   147→  });\n   148→\n   149→  console.log(\"Model loaded!\");\n   150→  console.log();\n   151→  return embedder;\n   152→}\n   153→\n   154→/**\n   155→ * Run embeddings classification\n   156→ */\n   157→async function runEmbeddingsClassification(\n   158→  text: string,\n   159→  existingEmbedder?: FeatureEmbedder\n   160→): Promise<void> {\n   161→  const startTime = Date.now();\n   162→\n   163→  console.log(\"=\".repeat(60));\n   164→  console.log(\"TEXT CLASSIFIER TEST (MiniLM Embeddings)\");\n   165→  console.log(\"=\".repeat(60));\n   166→  console.log();\n   167→\n   168→  const embedder = existingEmbedder ?? (await loadEmbedderWithProgress());\n   169→\n   170→  // Extract semantic title\n   171→  const embed = async (t: string): Promise<Array<number>> =>\n   172→    embedText(embedder, t);\n   173→  console.log(\"Extracting semantic title...\");\n   174→  const semanticTitle = await extractTitleWithEmbeddings(text, embed);\n   175→  console.log(`Semantic Title: ${semanticTitle || \"(none found)\"}`);\n   176→  console.log();\n   177→\n   178→  console.log(\"Computing label embeddings...\");\n   179→  const labelEmbeddings = await computeLabelEmbeddings(embedder);\n   180→  console.log(`Cached ${labelEmbeddings.length} label embeddings`);\n   181→  console.log();\n   182→\n   183→  console.log(\"Classifying text...\");\n   184→  const allSuggestions = await generateEmbeddingAndClassify(\n   185→    embedder,\n   186→    text,\n   187→    labelEmbeddings\n   188→  );\n   189→\n   190→  console.log();\n   191→  printResults(allSuggestions, \"MiniLM Embeddings\");\n   192→\n   193→  const totalTime = Date.now() - startTime;\n   194→  console.log(\n   195→    `Processing time: ${totalTime}ms (${(totalTime / 1000).toFixed(1)}s)`\n   196→  );\n   197→  console.log();\n   198→}\n   199→\n   200→/**\n   201→ * Run both methods for comparison\n   202→ */\n   203→async function runBothMethods(text: string): Promise<void> {\n   204→  console.log(\"=\".repeat(60));\n   205→  console.log(\"TEXT CLASSIFIER COMPARISON TEST\");\n   206→  console.log(\"=\".repeat(60));\n   207→  console.log();\n   208→\n   209→  // Extract heuristic title\n   210→  console.log(\"Extracting title (heuristic)...\");\n   211→  const heuristicTitle = extractTitle(text);\n   212→  console.log(`Heuristic Title: ${heuristicTitle || \"(none found)\"}`);\n   213→\n   214→  // Extract semantic title\n   215→  const embedder = await loadEmbedderWithProgress();\n   216→  const embed = async (t: string): Promise<Array<number>> =>\n   217→    embedText(embedder, t);\n   218→  console.log(\"Extracting title (semantic)...\");\n   219→  const semanticTitle = await extractTitleWithEmbeddings(text, embed);\n   220→  console.log(`Semantic Title:  ${semanticTitle || \"(none found)\"}`);\n   221→  console.log();\n   222→  console.log();\n   223→\n   224→  // Run TF-IDF\n   225→  await runTfIdfClassification(text);\n   226→\n   227→  console.log();\n   228→  console.log();\n   229→\n   230→  // Run Embeddings (reuse already-loaded embedder)\n   231→  await runEmbeddingsClassification(text, embedder);\n   232→}\n   233→\n   234→/**\n   235→ * Main entry point\n   236→ */\n   237→async function main(): Promise<void> {\n   238→  const args = process.argv.slice(2);\n   239→\n   240→  if (args.length === 0) {\n   241→    console.error(\n   242→      \"Usage: npx tsx lib/text-classifier/cli.ts <text-file-path> [--method=embeddings|tfidf|both]\"\n   243→    );\n   244→    console.error(\"\");\n   245→    console.error(\"Examples:\");\n   246→    console.error(\n   247→      \"  npx tsx lib/text-classifier/cli.ts recipe.txt --method=embeddings\"\n   248→    );\n   249→    console.error(\n   250→      \"  npx tsx lib/text-classifier/cli.ts recipe.txt --method=tfidf\"\n   251→    );\n   252→    console.error(\n   253→      \"  npx tsx lib/text-classifier/cli.ts recipe.txt --method=both\"\n   254→    );\n   255→    console.error(\n   256→      \"  npx tsx lib/text-classifier/cli.ts recipe.txt  (defaults to both)\"\n   257→    );\n   258→    process.exit(1);\n   259→  }\n   260→\n   261→  const filePath = args[0];\n   262→  const methodArg = args.find((arg) => arg.startsWith(\"--method=\"));\n   263→  const method = methodArg ? methodArg.split(\"=\")[1] : \"both\";\n   264→\n   265→  if (![\"embeddings\", \"tfidf\", \"both\"].includes(method)) {\n   266→    console.error(\n   267→      `Error: Invalid method '${method}'. Must be 'embeddings', 'tfidf', or 'both'`\n   268→    );\n   269→    process.exit(1);\n   270→  }\n   271→\n   272→  try {\n   273→    const text = readFileSync(filePath, \"utf-8\");\n   274→\n   275→    if (!text.trim()) {\n   276→      console.error(`Error: File '${filePath}' is empty`);\n   277→      process.exit(1);\n   278→    }\n   279→\n   280→    if (method === \"both\") {\n   281→      await runBothMethods(text);\n   282→    } else if (method === \"tfidf\") {\n   283→      console.log(\"Extracting title...\");\n   284→      const title = extractTitle(text);\n   285→      console.log(`Title: ${title || \"(none found)\"}`);\n   286→      console.log();\n   287→      console.log();\n   288→      await runTfIdfClassification(text);\n   289→    } else {\n   290→      // embeddings\n   291→      await runEmbeddingsClassification(text);\n   292→    }\n   293→  } catch (error) {\n   294→    if ((error as NodeJS.ErrnoException).code === \"ENOENT\") {\n   295→      console.error(`Error: File '${filePath}' not found`);\n   296→      process.exit(1);\n   297→    }\n   298→    console.error(\"Error:\", error);\n   299→    process.exit(1);\n   300→  }\n   301→}\n   302→\n   303→main().catch((error) => {\n   304→  console.error(\"Fatal error:\", error);\n   305→  process.exit(1);\n   306→});\n   307→"}]},"parent_tool_use_id":"toolu_013RHKQxMrX4xKvSfjN9AJZG","session_id":"ec54b805-2592-4abe-8e4f-4011b51bb626","uuid":"702c3755-8218-445f-ac9a-877b84ad546c"}
