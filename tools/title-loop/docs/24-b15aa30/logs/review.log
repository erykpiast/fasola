{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018BarjDG1rxUszcMYffCe11","type":"tool_result","content":"  1030→  if (pos0Primary) {\n  1031→    const subtitleCandidates = scored.filter((s) =>\n  1032→      s.position >= 1 && s.position <= 2 &&\n  1033→      !isAllCaps(s.text) &&\n  1034→      wordCount(s.text) > wordCount(pos0Primary.text) + 2\n  1035→    );\n  1036→    for (const sub of subtitleCandidates) {\n  1037→      sub.score -= 0.15;\n  1038→    }\n  1039→  }\n  1040→\n  1041→  // Bilingual layout pattern: [FoodName (≤2 words)]\\n[Translation (2-5 words, mixed-case)]\\n...[Section label]\n  1042→  // Common in bilingual cookbooks: foreign food name at position 0, English translation at position 1-2.\n  1043→  // When detected, boost the position-0 candidate so it clears the threshold.\n  1044→  // Note: the ALL_CAPS bilingual block above (lines 940-995) handles mixed-case + ALL_CAPS pairs.\n  1045→  // This block handles mixed-case + mixed-case translation pairs — the two do not overlap because\n  1046→  // the mixed-case guard (`biSecond.text !== biSecond.text.toUpperCase()`) excludes ALL_CAPS lines.\n  1047→  if (scored.length >= 2) {\n  1048→    const biFirst = scored.find((s) => s.position === 0);\n  1049→    // Restrict to single-line candidates (same guard as the ALL_CAPS bilingual block at line 953)\n  1050→    const biSecond = scored.find((s) => s.position >= 1 && s.position <= 2 && s !== biFirst && s.origin === \"single\");\n  1051→\n  1052→    if (biFirst && biSecond) {\n  1053→      const firstWords = biFirst.text.trim().split(/\\s+/);\n  1054→      const secondWords = biSecond.text.trim().split(/\\s+/);\n  1055→\n  1056→      const isBilingualLayout =\n  1057→        firstWords.length <= 2 &&\n  1058→        secondWords.length >= 2 &&\n  1059→        secondWords.length <= 5 &&\n  1060→        // Second line is mixed-case (not ALL_CAPS, not all-lower)\n  1061→        biSecond.text !== biSecond.text.toUpperCase() &&\n  1062→        biSecond.text !== biSecond.text.toLowerCase() &&\n  1063→        // Second line is not an ingredient or instruction\n  1064→        !looksLikeIngredient(biSecond.text) &&\n  1065→        !looksLikeCookingInstruction(biSecond.text);\n  1066→\n  1067→      if (isBilingualLayout) {\n  1068→        // Check if a section label follows within a few lines after the first candidate\n  1069→        const sectionLabelNearby = lines\n  1070→          .slice(biFirst.position + 1, biFirst.position + 6)\n  1071→          .some((line) => isSectionLabel(line.trim()));\n  1072→\n  1073→        if (sectionLabelNearby) {\n  1074→          biFirst.score += 0.15;\n  1075→          biFirst.baseScore += 0.15;\n  1076→          biFirst.thresholdScore += 0.15;\n  1077→        }\n  1078→      }\n  1079→    }\n  1080→  }\n  1081→\n  1082→  // Use thresholdScore (excludes structural bonus) so the structural bonus doesn't inflate\n  1083→  // the threshold and block equally-valid headings on multi-recipe pages.\n  1084→  const bestThresholdScore = Math.max(...scoredForThreshold.map((s) => s.thresholdScore));\n  1085→  const threshold = Math.max(0.08, bestThresholdScore * 0.7);\n  1086→\n  1087→  // Filter candidates above threshold\n  1088→  let selected = scoredForThreshold.filter((s) => s.score >= threshold);\n  1089→"}]},"parent_tool_use_id":"toolu_016vMXm965JDYqz841kU7bii","session_id":"ec54b805-2592-4abe-8e4f-4011b51bb626","uuid":"b4725332-1f46-4b0d-b1d4-7ee903fe69b9"}
