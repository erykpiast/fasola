{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017t76PGiVtME5pBwRhC1M36","type":"tool_result","content":"   620→    if (idx === 0 || !smallWords.has(lower)) {\n   621→      return lower.charAt(0).toUpperCase() + lower.slice(1);\n   622→    }\n   623→    return lower;\n   624→  }).join(\"\");\n   625→}\n   626→\n   627→/**\n   628→ * OCR digit→letter substitution map.\n   629→ * Each key is a character that OCR commonly confuses; values are possible correct letters.\n   630→ */\n   631→const OCR_SUBSTITUTIONS: Record<string, string[]> = {\n   632→  \"0\": [\"o\"],\n   633→  \"1\": [\"i\", \"l\"],\n   634→  \"4\": [\"a\"],\n   635→  \"5\": [\"s\"],\n   636→  \"¡\": [\"i\"],\n   637→  \"í\": [\"i\", \"l\"],\n   638→  \"€\": [\"e\"],\n   639→};\n   640→\n   641→const OCR_ARTIFACT_PATTERN = /[0-9¡Íí€]/;\n   642→\n   643→/**\n   644→ * Attempt to repair a single OCR-corrupted word using dictionary lookup.\n   645→ * Returns the repaired word if a dictionary match is found, otherwise returns the original.\n   646→ */\n   647→function repairOcrWord(word: string): string {\n   648→  if (!OCR_ARTIFACT_PATTERN.test(word)) return word;\n   649→\n   650→  const lower = word.toLowerCase();\n   651→\n   652→  const positions: Array<{ index: number; replacements: Array<string> }> = [];\n   653→  for (let i = 0; i < lower.length; i++) {\n   654→    const replacements = OCR_SUBSTITUTIONS[lower[i]];\n   655→    if (replacements) {\n   656→      positions.push({ index: i, replacements });\n   657→    }\n   658→  }\n   659→\n   660→  if (positions.length === 0 || positions.length > 8) return word;\n   661→\n   662→  const candidates = generateSubstitutions(lower, positions, 0);\n   663→\n   664→  for (const candidate of candidates) {\n   665→    if (FOOD_DICTIONARY.has(candidate)) {\n   666→      if (word === word.toUpperCase()) return candidate.toUpperCase();\n   667→      if (word[0] === word[0].toUpperCase()) {\n   668→        return candidate[0].toUpperCase() + candidate.slice(1);\n   669→      }\n   670→      return candidate;\n   671→    }\n   672→  }\n   673→\n   674→  return word;\n   675→}\n   676→\n   677→/**\n   678→ * Recursively generate all substitution variants for OCR artifact positions.\n   679→ */\n   680→function generateSubstitutions(\n   681→  base: string,\n   682→  positions: Array<{ index: number; replacements: Array<string> }>,\n   683→  posIdx: number,\n   684→): Array<string> {\n   685→  if (posIdx >= positions.length) return [base];\n   686→\n   687→  const { index, replacements } = positions[posIdx];\n   688→  const results: Array<string> = [];\n   689→\n   690→  for (const replacement of replacements) {\n   691→    const variant = base.slice(0, index) + replacement + base.slice(index + 1);\n   692→    results.push(...generateSubstitutions(variant, positions, posIdx + 1));\n   693→  }\n   694→\n   695→  return results;\n   696→}\n   697→\n   698→/**\n   699→ * Apply dictionary-guided OCR repair to all words in a text string."}]},"parent_tool_use_id":"toolu_016vMXm965JDYqz841kU7bii","session_id":"ec54b805-2592-4abe-8e4f-4011b51bb626","uuid":"ac9ae66f-562d-44dd-a76c-8cde4fb20ec4"}
