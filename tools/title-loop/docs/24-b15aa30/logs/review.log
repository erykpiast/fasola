{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017bHyia3LW6pB6vErgPMqiG","type":"tool_result","content":"  1090→  // Empty-pool fallback: when threshold filtering discards every candidate,\n  1091→  // the hard filters' structural verdict should not be overruled by weak\n  1092→  // embedding differentiation. Return the best positional candidate only\n  1093→  // if it has a meaningful positive raw score (avoids ingredient-list leakage).\n  1094→  if (selected.length === 0 && scored.length > 0) {\n  1095→    const fallback = scored\n  1096→      .slice()\n  1097→      .sort((a, b) => a.position - b.position || b.score - a.score);\n  1098→    // Position-0 candidates that passed hard filters are very likely titles even with\n  1099→    // weak embedding signal. Relax the rawScore guard for early-position candidates.\n  1100→    const rawScoreThreshold = fallback[0].position <= 2 ? -0.05 : 0.02;\n  1101→    if (fallback[0].rawScore > rawScoreThreshold) {\n  1102→      selected = [fallback[0]];\n  1103→    }\n  1104→  }\n  1105→\n  1106→  // Title-absent page guard: when the page starts mid-recipe (all of the first 3 non-empty\n  1107→  // lines are ingredients or cooking instructions), require a much higher rawScore and\n  1108→  // discard candidates deep in the file. This prevents stray body text or adjacent recipe\n  1109→  // titles from being picked up on pages with no title (Pattern 4).\n  1110→  if (titleAbsent) {\n  1111→    const titleAbsentThreshold = 0.10;\n  1112→    selected = selected.filter(s => s.rawScore >= titleAbsentThreshold);\n  1113→    selected = selected.filter(s => s.position <= 2);\n  1114→  }\n  1115→\n  1116→  // Remove word-boundary prefixes of firstStructuralHeading when the heading itself survived\n  1117→  // the threshold. Cases:\n  1118→  //   ARAYES case:  firstStructuralHeading = \"ARAYES SHRAK\" (2-word join qualifies; \"ARAYES\"\n  1119→  //     alone = 1 word, so it never qualified). Filter removes \"ARAYES\" so dedup keeps the join.\n  1120→  //   SAFFRON case: baseHeading was the partial line; continuation logic above upgraded\n  1121→  //     firstStructuralHeading to the full join. Filter removes the partial so dedup keeps join.\n  1122→  // Safety: only fires when the complete heading itself is in selected (passed the threshold).\n  1123→  if (firstStructuralHeading && selected.some((s) => s.text === firstStructuralHeading.text)) {\n  1124→    const fshLower = firstStructuralHeading.text.toLowerCase();\n  1125→    selected = selected.filter((s) => {\n  1126→      if (s.text === firstStructuralHeading.text) return true;\n  1127→      const sLower = s.text.toLowerCase();\n  1128→      // Remove s if it is a space-delimited prefix of the structural heading\n  1129→      return !fshLower.startsWith(sLower + \" \");\n  1130→    });\n  1131→  }\n  1132→\n  1133→  // Protect continuation joins: when a multi-line join (2-line or 3-line) survived the threshold\n  1134→  // and its second part starts with a continuation character, remove the single-line prefix/suffix\n  1135→  // so the dedup \"shorter wins\" rule doesn't destroy the complete join.\n  1136→  // Note: the pre-merge step above already handles the common Baked Eggs case (&/continuation\n  1137→  // on next line) by turning it into a single candidate — this block covers the rarer case where\n  1138→  // a continuation-character join was generated as a 2-line/3-line candidate and the prefix\n  1139→  // single also survived threshold independently (e.g. from a different code path or OCR layout).\n  1140→  // Safety: only fires for joins whose continuation starts with /&+:( — digit continuations\n  1141→  // like \"Pierogi Ruskie 200g mąki\" are NOT protected, so dedup correctly keeps the shorter form.\n  1142→  const survivingJoins = selected.filter((s) => s.origin === \"2-line\" || s.origin === \"3-line\");\n  1143→  if (survivingJoins.length > 0) {\n  1144→    selected = selected.filter((s) => {\n  1145→      if (s.origin !== \"single\") return true;\n  1146→      const sLower = s.text.toLowerCase();\n  1147→      // Remove PREFIX singles whose continuation join also survived\n  1148→      const isPrefixOfJoin = survivingJoins.some((j) => {\n  1149→        const jLower = j.text.toLowerCase();\n  1150→        if (!jLower.startsWith(sLower + \" \")) return false;\n  1151→        const remainder = jLower.slice(sLower.length + 1);\n  1152→        return /^[/&+:(]/.test(remainder);\n  1153→      });\n  1154→      if (isPrefixOfJoin) return false;\n  1155→      // Remove SUFFIX singles (e.g. \"& Coriander\") whose parent join also survived\n  1156→      const isSuffixOfJoin = survivingJoins.some((j) => {\n  1157→        const jLower = j.text.toLowerCase();\n  1158→        if (!jLower.endsWith(\" \" + sLower)) return false;\n  1159→        // Only remove if the suffix starts with a continuation character\n  1160→        return /^[/&+:(]/.test(sLower);\n  1161→      });\n  1162→      if (isSuffixOfJoin) return false;\n  1163→      return true;\n  1164→    });\n  1165→  }\n  1166→\n  1167→  // Pre-dedup: remove sub-section headers that are substrings of other surviving candidates.\n  1168→  // A sub-section header is an ALL_CAPS candidate followed by ingredient-like lines in the source.\n  1169→  // Example: \"CHLEBEK\" (bread section header, followed by \"500 g mąki\") is a substring of\n  1170→  // \"CHLEBEK Z WARZYWAMI I BOCZKIEM\" (the real title). Without this filter, dedup kills the title.\n  1171→  selected = selected.filter((candidate) => {\n  1172→    if (!isAllCaps(candidate.text)) return true;\n  1173→    // Check if this candidate is immediately followed by ingredient-like content\n  1174→    const nextSourceLines = lines.slice(candidate.position + 1, candidate.position + 2);\n  1175→    const followedByIngredients = nextSourceLines.some(\n  1176→      (l) => looksLikeIngredient(l.trim()) || startsWithNumber(l.trim())\n  1177→    );\n  1178→    if (!followedByIngredients) return true;\n  1179→    // Only remove if a longer candidate contains this one as a substring\n  1180→    const candidateLower = candidate.text.toLowerCase();\n  1181→    const hasLongerParent = rawScored.some(\n  1182→      (other) =>\n  1183→        other.text !== candidate.text &&\n  1184→        other.text.length > candidate.text.length &&\n  1185→        other.text.toLowerCase().includes(candidateLower)\n  1186→    );\n  1187→    return !hasLongerParent;\n  1188→  });\n  1189→"}]},"parent_tool_use_id":"toolu_016vMXm965JDYqz841kU7bii","session_id":"ec54b805-2592-4abe-8e4f-4011b51bb626","uuid":"c195f88d-b2a7-464a-82de-69320cc3703b"}
