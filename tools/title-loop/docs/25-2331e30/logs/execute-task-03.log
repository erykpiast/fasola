{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01K3T1pN5UU2pkbbE6x5XjzE","type":"tool_result","content":"  1283→  // spread far apart (>10 lines), which indicates body-text leakage. Closely-\n  1284→  // positioned candidates are likely genuine multi-recipe content.\n  1285→  if (selected.length > 1) {\n  1286→    const allCapsSelected = selected.filter((s) => isAllCaps(s.text));\n  1287→    if (allCapsSelected.length >= 2) {\n  1288→      // Vocabulary corroboration: filter out ALL_CAPS candidates whose content words\n  1289→      // don't appear elsewhere in the document. This catches orphaned OCR artifacts\n  1290→      // (e.g., \"DAT FLATBREADS\" from a preceding page) that look structurally identical\n  1291→      // to real titles but have no vocabulary support in the document body.\n  1292→      const corroboratedCaps = allCapsSelected.filter((cap) => {\n  1293→        const score = corroborationScore(cap.text, cap.position, lines);\n  1294→        const contentWords = cap.text\n  1295→          .split(/\\s+/)\n  1296→          .filter((w) => w.replace(/[^a-zA-ZÀ-ÿ]/g, \"\").length >= 3);\n  1297→        // Short candidates (≤3 content words): require 100% corroboration.\n  1298→        // Longer candidates (>3 content words): require ≥67% corroboration.\n  1299→        const threshold = contentWords.length <= 3 ? 1.0 : 0.67;\n  1300→        return score >= threshold;\n  1301→      });\n  1302→\n  1303→      // Use corroborated candidates if any remain; otherwise fall back to original set\n  1304→      // (don't remove all candidates — that would break legitimate multi-title pages\n  1305→      // where corroboration fails for benign reasons).\n  1306→      const capsToUse = corroboratedCaps.length >= 2 ? corroboratedCaps : allCapsSelected;\n  1307→\n  1308→      // Check whether non-first ALL_CAPS headings are section headers within one recipe\n  1309→      // (followed immediately by ingredient-like content) rather than separate recipe titles.\n  1310→      // A multi-recipe page has body text between titles; a single-recipe page has\n  1311→      // ingredient lines immediately after each section heading.\n  1312→      const sortedCaps = [...capsToUse].sort((a, b) => a.position - b.position);\n  1313→      const isSubHeader = sortedCaps.slice(1).every((cap) => {\n  1314→        const nextLines = lines.slice(cap.position + 1, cap.position + 3);\n  1315→        return nextLines.some(\n  1316→          (l) => looksLikeIngredient(l.trim()) || /^\\s*\\d/.test(l.trim())\n  1317→        );\n  1318→      });\n  1319→      if (isSubHeader) {\n  1320→        selected = [sortedCaps[0]];\n  1321→      } else {\n  1322→        selected = capsToUse;\n  1323→      }\n  1324→    } else if (allCapsSelected.length === 1) {\n  1325→      const theCapCandidate = allCapsSelected[0];\n  1326→      // Use non-empty line count so the 75% threshold is consistent regardless of blank-line density.\n  1327→      const nonEmptyCount = lines.filter((l) => l.trim().length > 0).length;\n  1328→      const capRelPos = theCapCandidate.position / Math.max(nonEmptyCount, 1);\n  1329→      // If the sole ALL_CAPS candidate is in the last 25% of the document,\n  1330→      // it's likely a category footer, not a title. Prefer the best earlier candidate.\n  1331→      if (capRelPos > 0.75) {\n  1332→        const earlierCandidates = selected.filter(\n  1333→          (s) => s.position / Math.max(nonEmptyCount, 1) <= 0.75\n  1334→        );\n  1335→        if (earlierCandidates.length > 0) {\n  1336→          selected = [earlierCandidates.reduce((a, b) => (a.score > b.score ? a : b))];\n  1337→        } else {\n  1338→          // All candidates are in the last 25% — no positional basis to prefer one over another;\n  1339→          // fall back to score, accepting that the guard cannot help here.\n  1340→          selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n  1341→        }\n  1342→      } else {\n  1343→        selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n  1344→      }\n  1345→    } else {\n  1346→      // Zero ALL_CAPS survivors → mixed-case page.\n  1347→      // If all survivors are closely positioned (within 10 lines of each other), keep them all —\n  1348→      // they're likely genuine multi-recipe content on a single page.\n  1349→      // If any survivor is far from the earliest, apply a positional tiebreak: the real title\n  1350→      // is almost always the earliest candidate; distant survivors are likely body-text leakage.\n  1351→      selected.sort((a, b) => a.position - b.position);\n  1352→      const earliest = selected[0];\n  1353→      const farthest = selected[selected.length - 1];\n  1354→      if (farthest.position - earliest.position > 10) {\n  1355→        // Large span → body-text leakage. Collapse to one: prefer the highest-scoring\n  1356→        // candidate within 3 positions of the earliest (position tolerance for OCR gaps),\n  1357→        // falling back to the earliest itself if none score higher.\n  1358→        const closeCompetitors = selected.filter(\n  1359→          (s) => s.position <= earliest.position + 3 && s.score > earliest.score\n  1360→        );\n  1361→        selected = closeCompetitors.length > 0\n  1362→          ? [closeCompetitors.reduce((a, b) => (a.score > b.score ? a : b))]\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_01YAsq2tUUQXMnieJR4QpeJC","session_id":"ae953361-806f-4043-a5a1-bef831914d71","uuid":"7a9d6737-79d6-4b4c-900d-8160c277bfdc"}
