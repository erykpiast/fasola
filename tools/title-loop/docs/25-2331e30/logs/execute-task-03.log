arent describe\n\n    it(\"rejects orphaned OCR artifact in multi-title assembly\", async () => {"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":908,"cache_read_input_tokens":42173,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":908},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"ae953361-806f-4043-a5a1-bef831914d71","uuid":"4a8fc238-a6d4-4833-b877-27f5890fb438"}
