appearing in the body text.\n   391→    const embed = createMockEmbed(\n   392→      [\"dat flatbreads\", \"finnish milk flatbreads\", \"finnish potato flatbreads\"],\n   393→      []\n   394→    );\n   395→    const input = [\n   396→      \"2 cup plus 1 tablespoon mixer fried with for 5 minutes\",\n   397→      \"nto a loured work counter shape into ball\",\n   398→      \"DAT FLATBREADS\",\n   399→      \"le Finnish region of Savo bread more like a\",\n   400→      \"\",\n   401→      \"FINNISH MILK FLATBREADS\",\n   402→      \"\",\n   403→      \"These traditional flatbreads are soft and delicious\",\n   404→      \"served warm with butter and milk\",\n   405→      \"500g flour\",\n   406→      \"300ml milk\",\n   407→      \"1 tsp salt\",\n   408→      \"\",\n   409→      \"Mix the flour and milk together until smooth\",\n   410→      \"Let the dough rest for 30 minutes\",\n   411→      \"\",\n   412→      \"FINNISH POTATO FLATBREADS\",\n   413→      \"\",\n   414→      \"Finnish potato flatbreads are hearty and filling\",\n   415→      \"3 large potatoes\",\n   416→      \"200g flour\",\n   417→      \"butter for frying\",\n   418→      \"\",\n   419→      \"Boil the potatoes until tender then mash\",\n   420→      \"Mix mashed potato with flour and salt\",\n   421→    ].join(\"\\n\");\n   422→\n   423→    const result = await extractTitleWithEmbeddings(input, embed);\n   424→    expect(result).toBe(\"FINNISH MILK FLATBREADS + FINNISH POTATO FLATBREADS\");\n   425→  });\n   426→\n   427→  it(\"keeps legitimate multi-recipe titles that are corroborated\", async () => {\n   428→    // Both CHICKEN SOUP and BEEF STEW have their words in the document body,\n   429→    // so both pass corroboration and are returned.\n   430→    const embed = createMockEmbed([\"chicken soup\", \"beef stew\"], []);\n   431→    const input = [\n   432→      \"CHICKEN SOUP\",\n   433→      \"\",\n   434→      \"A classic chicken soup recipe\",\n   435→      \"1 whole chicken\",\n   436→      \"2 carrots\",\n   437→      \"salt and pepper\",\n   438→      \"\",\n   439→      \"Place the chicken in a large pot\",\n   440→      \"\",\n   441→      \"BEEF STEW\",\n   442→      \"\",\n   443→      \"A hearty beef stew for cold days\",\n   444→      \"500g beef chuck\",\n   445→      \"3 potatoes\",\n   446→      \"2 onions\",\n   447→      \"\",\n   448→      \"Cut the beef into cubes\",\n   449→    ].join(\"\\n\");\n   450→\n   451→    const result = await extractTitleWithEmbeddings(input, embed);\n   452→    expect(result).toBe(\"CHICKEN SOUP + BEEF STEW\");\n   453→  });\n   454→\n   455→  it(\"does not apply corroboration to single-title pages\", async () => {\n   456→    // Corroboration only runs when ≥2 ALL_CAPS candidates are selected.\n   457→    // A single ALL_CAPS title is returned as-is regardless of vocabulary overlap.\n   458→    const embed = createMockEmbed([\"golonka pieczona\"], []);\n   459→    const input = [\n   460→      \"GOLONKA PIECZONA\",\n   461→      \"\",\n   462→      \"Składniki na 4 porcje\",\n   463→      \"1 kg mięsa\",\n   464→      \"2 cebule\",\n   465→      \"3 ząbki czosnku\",\n   466→      \"\",\n   467→      \"Mięso umyć i osuszyć\",\n   468→      \"Cebulę pokroić w plastry\",\n   469→    ].join(\"\\n\");\n   470→\n   471→    const result = await extractTitleWithEmbeddings(input, embed);\n   472→    expect(result).toBe(\"GOLONKA PIECZONA\");\n   473→  });\n   474→});\n   475→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_01YAsq2tUUQXMnieJR4QpeJC","session_id":"ae953361-806f-4043-a5a1-bef831914d71","uuid":"6667445e-4345-44fc-88e8-669f2fe9d6c8"}
