                       // pinch\n    44→  \"garść\",                               // handful\n    45→  \"opakowanie\", \"opakowania\",            // package(s)\n    46→  \"plasterek\", \"plasterki\",             // slice(s)\n    47→];\n    48→\n    49→/**\n    50→ * Patterns that identify recipe metadata lines (not titles)\n    51→ */\n    52→const METADATA_PATTERNS = [\n    53→  /^(SERVES?|MAKES?|YIELDS?)\\b/i,\n...\n</persisted-output>"}]},"parent_tool_use_id":"toolu_01YAsq2tUUQXMnieJR4QpeJC","session_id":"ae953361-806f-4043-a5a1-bef831914d71","uuid":"207eea78-c2e2-4a66-8e03-2c6360fc3bb1"}
