{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018Gw4UqNhuPqkHXmqLeERXt","type":"tool_result","content":"  1240→        aLower.includes(b.text.toLowerCase()) &&\n  1241→        b.text.length < a.text.length\n  1242→    );\n  1243→  });\n  1244→\n  1245→  // Multi-title guard: only join multiple candidates with \"+\" when there is\n  1246→  // structural evidence of a multi-recipe page (≥2 ALL_CAPS headings).\n  1247→  // A single ALL_CAPS title among mixed-case survivors is a single-recipe page —\n  1248→  // collapse to the highest-scoring candidate.\n  1249→  // Zero ALL_CAPS survivors → apply positional tiebreak only when candidates are\n  1250→  // spread far apart (>10 lines), which indicates body-text leakage. Closely-\n  1251→  // positioned candidates are likely genuine multi-recipe content.\n  1252→  if (selected.length > 1) {\n  1253→    const allCapsSelected = selected.filter((s) => isAllCaps(s.text));\n  1254→    if (allCapsSelected.length >= 2) {\n  1255→      // Check whether non-first ALL_CAPS headings are section headers within one recipe\n  1256→      // (followed immediately by ingredient-like content) rather than separate recipe titles.\n  1257→      // A multi-recipe page has body text between titles; a single-recipe page has\n  1258→      // ingredient lines immediately after each section heading.\n  1259→      const sortedCaps = [...allCapsSelected].sort((a, b) => a.position - b.position);\n  1260→      const isSubHeader = sortedCaps.slice(1).every((cap) => {\n  1261→        const nextLines = lines.slice(cap.position + 1, cap.position + 3);\n  1262→        return nextLines.some(\n  1263→          (l) => looksLikeIngredient(l.trim()) || /^\\s*\\d/.test(l.trim())\n  1264→        );\n  1265→      });\n  1266→      if (isSubHeader) {\n  1267→        selected = [sortedCaps[0]];\n  1268→      } else {\n  1269→        selected = allCapsSelected;\n  1270→      }\n  1271→    } else if (allCapsSelected.length === 1) {\n  1272→      const theCapCandidate = allCapsSelected[0];\n  1273→      // Use non-empty line count so the 75% threshold is consistent regardless of blank-line density.\n  1274→      const nonEmptyCount = lines.filter((l) => l.trim().length > 0).length;\n  1275→      const capRelPos = theCapCandidate.position / Math.max(nonEmptyCount, 1);\n  1276→      // If the sole ALL_CAPS candidate is in the last 25% of the document,\n  1277→      // it's likely a category footer, not a title. Prefer the best earlier candidate.\n  1278→      if (capRelPos > 0.75) {\n  1279→        const earlierCandidates = selected.filter(\n  1280→          (s) => s.position / Math.max(nonEmptyCount, 1) <= 0.75\n  1281→        );\n  1282→        if (earlierCandidates.length > 0) {\n  1283→          selected = [earlierCandidates.reduce((a, b) => (a.score > b.score ? a : b))];\n  1284→        } else {\n  1285→          // All candidates are in the last 25% — no positional basis to prefer one over another;\n  1286→          // fall back to score, accepting that the guard cannot help here.\n  1287→          selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n  1288→        }\n  1289→      } else {\n  1290→        selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n  1291→      }\n  1292→    } else {\n  1293→      // Zero ALL_CAPS survivors → mixed-case page.\n  1294→      // If all survivors are closely positioned (within 10 lines of each other), keep them all —\n  1295→      // they're likely genuine multi-recipe content on a single page.\n  1296→      // If any survivor is far from the earliest, apply a positional tiebreak: the real title\n  1297→      // is almost always the earliest candidate; distant survivors are likely body-text leakage.\n  1298→      selected.sort((a, b) => a.position - b.position);\n  1299→      const earliest = selected[0];\n  1300→      const farthest = selected[selected.length - 1];\n  1301→      if (farthest.position - earliest.position > 10) {\n  1302→        // Large span → body-text leakage. Collapse to one: prefer the highest-scoring\n  1303→        // candidate within 3 positions of the earliest (position tolerance for OCR gaps),\n  1304→        // falling back to the earliest itself if none score higher.\n  1305→        const closeCompetitors = selected.filter(\n  1306→          (s) => s.position <= earliest.position + 3 && s.score > earliest.score\n  1307→        );\n  1308→        selected = closeCompetitors.length > 0\n  1309→          ? [closeCompetitors.reduce((a, b) => (a.score > b.score ? a : b))]\n  1310→          : [earliest];\n  1311→      }\n  1312→      // Span ≤ 10 → all survivors are closely positioned; fall through keeping all.\n  1313→    }\n  1314→  }\n  1315→\n  1316→  // Cap at 3, sort by document position\n  1317→  selected.sort((a, b) => a.position - b.position);\n  1318→  selected = selected.slice(0, 3);\n  1319→"}]},"parent_tool_use_id":null,"session_id":"a061f1f0-ad7a-459c-9eae-0adb758ccdd2","uuid":"7384b6a9-cbec-4518-bfcc-354ce2190345","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/title-extractor.ts","content":"        aLower.includes(b.text.toLowerCase()) &&\n        b.text.length < a.text.length\n    );\n  });\n\n  // Multi-title guard: only join multiple candidates with \"+\" when there is\n  // structural evidence of a multi-recipe page (≥2 ALL_CAPS headings).\n  // A single ALL_CAPS title among mixed-case survivors is a single-recipe page —\n  // collapse to the highest-scoring candidate.\n  // Zero ALL_CAPS survivors → apply positional tiebreak only when candidates are\n  // spread far apart (>10 lines), which indicates body-text leakage. Closely-\n  // positioned candidates are likely genuine multi-recipe content.\n  if (selected.length > 1) {\n    const allCapsSelected = selected.filter((s) => isAllCaps(s.text));\n    if (allCapsSelected.length >= 2) {\n      // Check whether non-first ALL_CAPS headings are section headers within one recipe\n      // (followed immediately by ingredient-like content) rather than separate recipe titles.\n      // A multi-recipe page has body text between titles; a single-recipe page has\n      // ingredient lines immediately after each section heading.\n      const sortedCaps = [...allCapsSelected].sort((a, b) => a.position - b.position);\n      const isSubHeader = sortedCaps.slice(1).every((cap) => {\n        const nextLines = lines.slice(cap.position + 1, cap.position + 3);\n        return nextLines.some(\n          (l) => looksLikeIngredient(l.trim()) || /^\\s*\\d/.test(l.trim())\n        );\n      });\n      if (isSubHeader) {\n        selected = [sortedCaps[0]];\n      } else {\n        selected = allCapsSelected;\n      }\n    } else if (allCapsSelected.length === 1) {\n      const theCapCandidate = allCapsSelected[0];\n      // Use non-empty line count so the 75% threshold is consistent regardless of blank-line density.\n      const nonEmptyCount = lines.filter((l) => l.trim().length > 0).length;\n      const capRelPos = theCapCandidate.position / Math.max(nonEmptyCount, 1);\n      // If the sole ALL_CAPS candidate is in the last 25% of the document,\n      // it's likely a category footer, not a title. Prefer the best earlier candidate.\n      if (capRelPos > 0.75) {\n        const earlierCandidates = selected.filter(\n          (s) => s.position / Math.max(nonEmptyCount, 1) <= 0.75\n        );\n        if (earlierCandidates.length > 0) {\n          selected = [earlierCandidates.reduce((a, b) => (a.score > b.score ? a : b))];\n        } else {\n          // All candidates are in the last 25% — no positional basis to prefer one over another;\n          // fall back to score, accepting that the guard cannot help here.\n          selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n        }\n      } else {\n        selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n      }\n    } else {\n      // Zero ALL_CAPS survivors → mixed-case page.\n      // If all survivors are closely positioned (within 10 lines of each other), keep them all —\n      // they're likely genuine multi-recipe content on a single page.\n      // If any survivor is far from the earliest, apply a positional tiebreak: the real title\n      // is almost always the earliest candidate; distant survivors are likely body-text leakage.\n      selected.sort((a, b) => a.position - b.position);\n      const earliest = selected[0];\n      const farthest = selected[selected.length - 1];\n      if (farthest.position - earliest.position > 10) {\n        // Large span → body-text leakage. Collapse to one: prefer the highest-scoring\n        // candidate within 3 positions of the earliest (position tolerance for OCR gaps),\n        // falling back to the earliest itself if none score higher.\n        const closeCompetitors = selected.filter(\n          (s) => s.position <= earliest.position + 3 && s.score > earliest.score\n        );\n        selected = closeCompetitors.length > 0\n          ? [closeCompetitors.reduce((a, b) => (a.score > b.score ? a : b))]\n          : [earliest];\n      }\n      // Span ≤ 10 → all survivors are closely positioned; fall through keeping all.\n    }\n  }\n\n  // Cap at 3, sort by document position\n  selected.sort((a, b) => a.position - b.position);\n  selected = selected.slice(0, 3);\n","numLines":80,"startLine":1240,"totalLines":1362}}}
