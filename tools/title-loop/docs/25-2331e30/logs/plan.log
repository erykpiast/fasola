{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014w5jbaHgowKqVoEvKgvAzu","type":"tool_result","content":"   400→        /^[a-ząćęłńóśźż]/.test(t) ||\n   401→        t.endsWith(\",\") ||\n   402→        (t.endsWith(\".\") && wordCount(t) > 4)\n   403→      ) && wordCount(t) >= 4;\n   404→      if (isBodyText) j++;\n   405→      else break;\n   406→    }\n   407→    if (j >= 3) i = j;\n   408→  }\n   409→  return i;\n   410→}\n   411→\n   412→function stripParentheticalGloss(text: string): string {\n   413→  // Strip trailing English-gloss parentheticals from ALL_CAPS titles.\n   414→  // e.g. \"PIEROGI RUSKIE (Boiled Dumplings with Potato and Cheese)\" → \"PIEROGI RUSKIE\"\n   415→  // Keep if parenthetical is ALL_CAPS (variation/subtitle in same language).\n   416→  // Keep if both base and paren are mixed-case (both are part of the title).\n   417→  const match = text.match(/^(.+?)\\s*\\(([^)]+)\\)\\s*$/);\n   418→  if (!match) return text;\n   419→  const [, base, paren] = match;\n   420→  if (isAllCaps(paren)) return text;\n   421→  if (!isAllCaps(base) && !isAllCaps(paren)) return text;\n   422→  return base.trim();\n   423→}\n   424→\n   425→function stripPageNumber(text: string): string {\n   426→  // \"34  Berry Jam\" → \"Berry Jam\" (2+ spaces distinguishes from \"2 eggs\")\n   427→  const match = text.match(/^\\d{1,3}\\s{2,}(.+)$/);\n   428→  return match ? match[1] : text;\n   429→}\n   430→\n   431→function wordCount(text: string): number {\n   432→  return text.split(/\\s+/).filter((w) => w.length > 0).length;\n   433→}\n   434→\n   435→/**\n   436→ * Build candidate strings from lines: single lines plus multi-line joins (2-3 consecutive).\n   437→ * Skips initial burst of short garbled lines. Scans all remaining lines. Caps at 25.\n   438→ */\n   439→export type CandidateOrigin = \"single\" | \"2-line\" | \"3-line\";\n   440→\n   441→function buildCandidates(\n   442→  lines: Array<string>\n   443→): Array<{ text: string; position: number; origin: CandidateOrigin }> {\n   444→  const nonEmptyLines: Array<{ text: string; index: number }> = [];\n   445→\n   446→  for (let i = 0; i < lines.length; i++) {\n   447→    const trimmed = lines[i].trim();\n   448→    if (trimmed.length > 0) {\n   449→      nonEmptyLines.push({ text: trimmed, index: i });\n   450→    }\n   451→  }\n   452→\n   453→  const burstEnd = findBurstEnd(nonEmptyLines);\n   454→\n   455→  // Pre-join hyphen-broken lines: \"ROASTED CHICKEN WITH ROOT VEGET-\" + \"ABLES\" → single line.\n   456→  // Only applies within the candidate region (after burst end).\n   457→  for (let hi = burstEnd; hi < nonEmptyLines.length - 1; hi++) {\n   458→    if (nonEmptyLines[hi].text.endsWith(\"-\")) {\n   459→      const joined = nonEmptyLines[hi].text.slice(0, -1) + nonEmptyLines[hi + 1].text;\n   460→      nonEmptyLines[hi] = { text: joined, index: nonEmptyLines[hi].index };\n   461→      nonEmptyLines.splice(hi + 1, 1);\n   462→    }\n   463→  }\n   464→\n   465→  // Pre-merge consecutive short ALL_CAPS lines (OCR-fragmented headings).\n   466→  // When a sequence of 2+ ALL_CAPS lines each has ≤2 words and ≤25 chars, they are\n   467→  // almost certainly OCR fragments of a single heading. Merge them into one line so\n   468→  // the complete title enters the candidate pool without hitting the 3-line join ceiling.\n   469→  const capsCoalesced: Array<{ text: string; index: number }> = [];\n   470→  let ci = burstEnd;\n   471→  while (ci < nonEmptyLines.length) {\n   472→    const line = nonEmptyLines[ci];\n   473→    if (\n   474→      isAllCaps(line.text) &&\n   475→      wordCount(line.text) <= 2 &&\n   476→      line.text.length <= 25 &&\n   477→      !isSectionLabel(line.text) &&\n   478→      !looksLikeMetadata(line.text)\n   479→    ) {\n   480→      let merged = line.text;\n   481→      const startIndex = line.index;\n   482→      let j = ci + 1;\n   483→      while (j < nonEmptyLines.length) {\n   484→        const next = nonEmptyLines[j];\n   485→        if (\n   486→          isAllCaps(next.text) &&\n   487→          wordCount(next.text) <= 2 &&\n   488→          next.text.length <= 25 &&\n   489→          !isSectionLabel(next.text) &&\n   490→          !isSectionLabel(repairOcrText(next.text)) &&\n   491→          !looksLikeMetadata(next.text) &&\n   492→          (merged + \" \" + next.text).length <= 80\n   493→        ) {\n   494→          merged += \" \" + next.text;\n   495→          j++;\n   496→        } else {\n   497→          break;\n   498→        }\n   499→      }\n   500→      if (j > ci + 1) {\n   501→        capsCoalesced.push({ text: merged, index: startIndex });\n   502→        ci = j;\n   503→        continue;\n   504→      }\n   505→    }\n   506→    capsCoalesced.push(line);\n   507→    ci++;\n   508→  }\n   509→\n   510→  // Pre-merge continuation lines: a line starting with /&+:( is never a standalone title.\n   511→  // Merge it into the preceding line so the complete title enters the pool as a single candidate,\n   512→  // avoiding the fragile chain of conditions required by the downstream join survival logic.\n   513→  // Limitation: only one continuation line per preceding line is merged. Titles split across\n   514→  // three or more lines with continuation tokens (rare in practice) are not handled here —\n   515→  // the downstream 2-line and 3-line join candidates cover those cases instead.\n   516→  const mergedLines: Array<{ text: string; index: number }> = [];\n   517→  for (let i = 0; i < capsCoalesced.length; i++) {\n   518→    const line = capsCoalesced[i];\n   519→    if (i + 1 < capsCoalesced.length) {\n   520→      const nextText = capsCoalesced[i + 1].text;\n   521→      if (/^[/&+:(]/.test(nextText)) {\n   522→        mergedLines.push({ text: `${line.text} ${nextText}`, index: line.index });\n   523→        i++;\n   524→        continue;\n   525→      }\n   526→    }\n   527→    mergedLines.push(line);\n   528→  }\n   529→\n   530→  const candidates: Array<{ text: string; position: number; origin: CandidateOrigin }> = [];\n   531→  const seen = new Set<string>();\n   532→\n   533→  // Build a set of positions to skip: short ALL_CAPS lines immediately following metadata\n   534→  const metadataContinuationPositions = new Set<number>();\n   535→  for (let i = 0; i < mergedLines.length - 1; i++) {\n   536→    if (looksLikeMetadata(mergedLines[i].text)) {\n   537→      const next = mergedLines[i + 1];\n   538→      if (isAllCaps(next.text) && wordCount(next.text) <= 2 && next.text.length <= 15) {\n   539→        metadataContinuationPositions.add(next.index);\n   540→      }\n   541→    }\n   542→  }\n   543→\n   544→  for (let i = 0; i < mergedLines.length; i++) {\n   545→    const line = mergedLines[i];\n   546→\n   547→    // Skip metadata continuation fragments\n   548→    if (metadataContinuationPositions.has(line.index)) continue;\n   549→\n   550→    // Single line — strip page-number prefixes and parenthetical glosses before scoring\n   551→    const singleText = repairOcrText(stripParentheticalGloss(stripPageNumber(line.text)));\n   552→    if (passesHardFilters(singleText)) {\n   553→      const norm = singleText.toLowerCase();\n   554→      if (!seen.has(norm)) {\n   555→        seen.add(norm);\n   556→        candidates.push({ text: singleText, position: line.index, origin: \"single\" });\n   557→      }\n   558→    }\n   559→\n   560→    // 2-line join — skip if first line is a section label AND join would be ≤2 words\n   561→    // (a section label followed by modifiers is likely a recipe title, not a category header)\n   562→    if (i + 1 < mergedLines.length) {\n   563→      const joined2 = repairOcrText(`${line.text} ${mergedLines[i + 1].text}`);\n   564→      const shouldBlock2 = isSectionLabel(line.text) &&\n   565→        (wordCount(joined2) <= 2 || isAlwaysBlockJoinLabel(line.text));\n   566→      if (!shouldBlock2 && passesHardFilters(joined2)) {\n   567→        const norm = joined2.toLowerCase();\n   568→        if (!seen.has(norm)) {\n   569→          seen.add(norm);\n   570→          candidates.push({ text: joined2, position: line.index, origin: \"2-line\" });\n   571→        }\n   572→      }\n   573→    }\n   574→\n   575→    // 3-line join — skip if first line is a section label AND join would be ≤2 words\n   576→    if (i + 2 < mergedLines.length) {\n   577→      const joined3 = repairOcrText(`${line.text} ${mergedLines[i + 1].text} ${mergedLines[i + 2].text}`);\n   578→      const shouldBlock3 = isSectionLabel(line.text) &&\n   579→        (wordCount(joined3) <= 2 || isAlwaysBlockJoinLabel(line.text));\n   580→      if (!shouldBlock3 && passesHardFilters(joined3)) {\n   581→        const norm = joined3.toLowerCase();\n   582→        if (!seen.has(norm)) {\n   583→          seen.add(norm);\n   584→          candidates.push({ text: joined3, position: line.index, origin: \"3-line\" });\n   585→        }\n   586→      }\n   587→    }\n   588→  }\n   589→\n   590→  // Pre-filter to 25 before embedding calls: prefer ALL_CAPS and short candidates.\n   591→  // Position-based scoring handles final ranking.\n   592→  if (candidates.length > 25) {\n   593→    const prioritized = candidates.slice().sort((a, b) => {\n   594→      const aAllCaps = isAllCaps(a.text) ? 0 : 1;\n   595→      const bAllCaps = isAllCaps(b.text) ? 0 : 1;\n   596→      if (aAllCaps !== bAllCaps) return aAllCaps - bAllCaps;\n   597→      const aShort = wordCount(a.text) <= 5 ? 0 : 1;\n   598→      const bShort = wordCount(b.text) <= 5 ? 0 : 1;\n   599→      return aShort - bShort;\n   600→    });\n   601→    return prioritized.slice(0, 25);\n   602→  }\n   603→\n   604→  return candidates;\n   605→}\n   606→\n   607→/**\n   608→ * Convert an ALL_CAPS string to Title Case, using a small-words list.\n   609→ * Preserves Polish/French diacritics.\n   610→ */\n   611→function toTitleCase(text: string): string {\n   612→  const smallWords = new Set([\n   613→    \"a\", \"an\", \"the\", \"and\", \"but\", \"or\", \"for\", \"nor\",\n   614→    \"in\", \"on\", \"at\", \"to\", \"of\", \"by\", \"with\", \"from\",\n   615→    \"z\", \"w\", \"i\", \"ze\", \"na\", \"do\", \"od\", \"za\", \"po\",\n   616→  ]);\n   617→  return text.split(/(\\s+)/).map((word, idx) => {\n   618→    if (/^\\s+$/.test(word)) return word;\n   619→    const lower = word.toLowerCase();\n   620→    if (idx === 0 || !smallWords.has(lower)) {\n   621→      return lower.charAt(0).toUpperCase() + lower.slice(1);\n   622→    }\n   623→    return lower;\n   624→  }).join(\"\");\n   625→}\n   626→\n   627→/**\n   628→ * OCR digit→letter substitution map.\n   629→ * Each key is a character that OCR commonly confuses; values are possible correct letters.\n   630→ */\n   631→const OCR_SUBSTITUTIONS: Record<string, string[]> = {\n   632→  \"0\": [\"o\"],\n   633→  \"1\": [\"i\", \"l\"],\n   634→  \"4\": [\"a\"],\n   635→  \"5\": [\"s\"],\n   636→  \"¡\": [\"i\"],\n   637→  \"í\": [\"i\", \"l\"],\n   638→  \"€\": [\"e\"],\n   639→};\n   640→\n   641→const OCR_ARTIFACT_PATTERN = /[0-9¡Íí€]/;\n   642→\n   643→/**\n   644→ * Attempt to repair a single OCR-corrupted word using dictionary lookup.\n   645→ * Returns the repaired word if a dictionary match is found, otherwise returns the original.\n   646→ */\n   647→function repairOcrWord(word: string): string {\n   648→  if (!OCR_ARTIFACT_PATTERN.test(word)) return word;\n   649→\n   650→  const lower = word.toLowerCase();\n   651→\n   652→  const positions: Array<{ index: number; replacements: Array<string> }> = [];\n   653→  for (let i = 0; i < lower.length; i++) {\n   654→    const replacements = OCR_SUBSTITUTIONS[lower[i]];\n   655→    if (replacements) {\n   656→      positions.push({ index: i, replacements });\n   657→    }\n   658→  }\n   659→\n   660→  if (positions.length === 0 || positions.length > 8) return word;\n   661→\n   662→  const candidates = generateSubstitutions(lower, positions, 0);\n   663→\n   664→  for (const candidate of candidates) {\n   665→    if (FOOD_DICTIONARY.has(candidate)) {\n   666→      if (word === word.toUpperCase()) return candidate.toUpperCase();\n   667→      if (word[0] === word[0].toUpperCase()) {\n   668→        return candidate[0].toUpperCase() + candidate.slice(1);\n   669→      }\n   670→      return candidate;\n   671→    }\n   672→  }\n   673→\n   674→  return word;\n   675→}\n   676→\n   677→/**\n   678→ * Recursively generate all substitution variants for OCR artifact positions.\n   679→ */\n   680→function generateSubstitutions(\n   681→  base: string,\n   682→  positions: Array<{ index: number; replacements: Array<string> }>,\n   683→  posIdx: number,\n   684→): Array<string> {\n   685→  if (posIdx >= positions.length) return [base];\n   686→\n   687→  const { index, replacements } = positions[posIdx];\n   688→  const results: Array<string> = [];\n   689→\n   690→  for (const replacement of replacements) {\n   691→    const variant = base.slice(0, index) + replacement + base.slice(index + 1);\n   692→    results.push(...generateSubstitutions(variant, positions, posIdx + 1));\n   693→  }\n   694→\n   695→  return results;\n   696→}\n   697→\n   698→/**\n   699→ * Apply dictionary-guided OCR repair to all words in a text string.\n   700→ */\n   701→function repairOcrText(text: string): string {\n   702→  return text\n   703→    .split(/\\s+/)\n   704→    .map((word) => {\n   705→      const match = word.match(/^([^a-zA-Z0-9À-ÿ]*)(.*?)([^a-zA-Z0-9À-ÿ]*)$/);\n   706→      if (!match) return word;\n   707→      const [, prefix, core, suffix] = match;\n   708→      if (!core) return word;\n   709→      const repaired = repairOcrWord(core);\n   710→      return prefix + repaired + suffix;\n   711→    })\n   712→    .join(\" \");\n   713→}\n   714→\n   715→/**\n   716→ * Post-processing normalization for OCR-extracted titles.\n   717→ * Strips stray section markers and substitutes common OCR digit-for-letter artifacts.\n   718→ * Title-case conversion is applied only