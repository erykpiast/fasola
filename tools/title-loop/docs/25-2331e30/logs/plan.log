{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01G7WfB6kVBCBEGEaf6etkYp","type":"tool_result","content":"     1→/**\n     2→ * ~500 common English and Polish food/cooking words for OCR repair.\n     3→ * Words are lowercase, without diacritics (OCR-resilient matching).\n     4→ * Used by repairOcrWord() to resolve ambiguous digit→letter substitutions.\n     5→ */\n     6→export const FOOD_DICTIONARY: Set<string> = new Set([\n     7→  // ── English ingredients ──────────────────────────────────────────────────\n     8→  \"chicken\", \"beef\", \"pork\", \"lamb\", \"veal\", \"duck\", \"turkey\", \"venison\",\n     9→  \"salmon\", \"cod\", \"halibut\", \"tuna\", \"trout\", \"sardine\", \"anchovy\",\n    10→  \"shrimp\", \"prawn\", \"lobster\", \"crab\", \"scallop\", \"mussel\", \"clam\",\n    11→  \"tofu\", \"tempeh\", \"seitan\",\n    12→\n    13→  // Grains & starches\n    14→  \"rice\", \"pasta\", \"bread\", \"noodle\", \"flour\", \"oat\", \"barley\", \"wheat\",\n    15→  \"rye\", \"quinoa\", \"corn\", \"cornmeal\", \"semolina\", \"couscous\", \"polenta\",\n    16→  \"buckwheat\", \"millet\",\n    17→\n    18→  // Dairy & eggs\n    19→  \"butter\", \"cream\", \"cheese\", \"milk\", \"egg\", \"yogurt\", \"ghee\",\n    20→  \"ricotta\", \"mozzarella\", \"parmesan\", \"cheddar\", \"brie\", \"feta\",\n    21→\n    22→  // Fats & condiments\n    23→  \"oil\", \"vinegar\", \"mustard\", \"ketchup\", \"mayo\", \"mayonnaise\",\n    24→  \"soy\", \"sauce\", \"paste\", \"stock\", \"broth\", \"gravy\",\n    25→\n    26→  // Vegetables\n    27→  \"garlic\", \"onion\", \"tomato\", \"potato\", \"carrot\", \"celery\", \"pepper\",\n    28→  \"broccoli\", \"cauliflower\", \"asparagus\", \"artichoke\", \"eggplant\",\n    29→  \"zucchini\", \"squash\", \"pumpkin\", \"cucumber\", \"radish\", \"turnip\",\n    30→  \"beet\", \"mushroom\", \"avocado\", \"olive\", \"bean\", \"lentil\", \"chickpea\",\n    31→  \"arugula\", \"spinach\", \"kale\", \"lettuce\", \"cabbage\", \"leek\", \"fennel\",\n    32→  \"chard\", \"endive\", \"watercress\", \"sprout\", \"pea\", \"edamame\",\n    33→  \"scallion\", \"shallot\", \"chili\", \"jalapeno\", \"poblano\", \"serrano\",\n    34→  \"brukselka\",\n    35→\n    36→  // Fruits\n    37→  \"lemon\", \"lime\", \"orange\", \"apple\", \"berry\", \"blackberry\", \"blueberry\",\n    38→  \"raspberry\", \"strawberry\", \"cherry\", \"peach\", \"pear\", \"plum\", \"grape\",\n    39→  \"banana\", \"mango\", \"pineapple\", \"coconut\", \"fig\", \"date\", \"apricot\",\n    40→  \"pomegranate\", \"melon\", \"watermelon\", \"grapefruit\", \"papaya\", \"kiwi\",\n    41→  \"passion\", \"guava\", \"lychee\",\n    42→\n    43→  // Nuts & seeds\n    44→  \"almond\", \"walnut\", \"pecan\", \"cashew\", \"pistachio\", \"hazelnut\",\n    45→  \"peanut\", \"sesame\", \"flaxseed\", \"chia\", \"sunflower\", \"pumpkinseed\",\n    46→  \"poppy\",\n    47→\n    48→  // Spices & herbs\n    49→  \"ginger\", \"cinnamon\", \"cumin\", \"paprika\", \"turmeric\", \"oregano\",\n    50→  \"basil\", \"thyme\", \"rosemary\", \"parsley\", \"cilantro\", \"dill\", \"mint\",\n    51→  \"sage\", \"chive\", \"tarragon\", \"nutmeg\", \"clove\", \"cardamom\", \"saffron\",\n    52→  \"vanilla\", \"anise\", \"coriander\", \"bay\", \"marjoram\", \"chervil\",\n    53→  \"fenugreek\", \"sumac\", \"caraway\", \"allspice\",\n    54→\n    55→  // Sweeteners & flavourings\n    56→  \"chocolate\", \"cocoa\", \"honey\", \"maple\", \"molasses\", \"sugar\", \"salt\",\n    57→  \"yeast\", \"baking\", \"powder\", \"soda\",\n    58→\n    59→  // Common recipe adjectives / descriptors\n    60→  \"white\", \"red\", \"green\", \"black\", \"brown\", \"sweet\", \"sour\", \"hot\",\n    61→  \"cold\", \"fresh\", \"dried\", \"whole\", \"ground\", \"roasted\", \"grilled\",\n    62→  \"braised\", \"baked\", \"fried\", \"steamed\", \"smoked\", \"stuffed\", \"glazed\",\n    63→  \"caramelized\", \"pickled\", \"fermented\", \"cured\", \"raw\", \"cooked\",\n    64→  \"c