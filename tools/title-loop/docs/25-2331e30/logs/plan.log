name at position 0, English translation at position 1-2.\n  1043→  // When detected, boost the position-0 candidate so it clears the threshold.\n  1044→  // Note: the ALL_CAPS bilingual block above (lines 940-995) handles mixed-case + ALL_CAPS pairs.\n  1045→  // This block handles mixed-case + mixed-case translation pairs — the two do not overlap because\n  1046→  // the mixed-case guard (`biSecond.text !== biSecond.text.toUpperCase()`) excludes ALL_CAPS lines.\n  1047→  if (scored.length >= 2) {\n  1048→    const biFirst = scored.find((s) => s.position === 0);\n  1049→    // Restrict to single-line candidates (same guard as the ALL_CAPS bilingual block at line 953)\n  1050→    const biSecond = scored.find((s) => s.position >= 1 && s.position <= 2 && s !== biFirst && s.origin === \"single\");\n  1051→\n  1052→    if (biFirst && biSecond) {\n  1053→      const firstWords = biFirst.text.trim().split(/\\s+/);\n  1054→      const secondWords = biSecond.text.trim().split(/\\s+/);\n  1055→\n  1056→      const isBilingualLayout =\n  1057→        firstWords.length <= 2 &&\n  1058→        secondWords.length >= 2 &&\n  1059→        secondWords.length <= 5 &&\n  1060→        // Second line is mixed-case (not ALL_CAPS, not all-lower)\n  1061→        biSecond.text !== biSecond.text.toUpperCase() &&\n  1062→        biSecond.text !== biSecond.text.toLowerCase() &&\n  1063→        // Second line is not an ingredient or instruction\n  1064→        !looksLikeIngredient(biSecond.text) &&\n  1065→        !looksLikeCookingInstruction(biSecond.text);\n  1066→\n  1067→      if (isBilingualLayout) {\n  1068→        // Check if a section label follows within a few lines after the first candidate\n  1069→        const sectionLabelNearby = lines\n  1070→          .slice(biFirst.position + 1, biFirst.position + 6)\n  1071→          .some((line) => isSectionLabel(line.trim()));\n  1072→\n  1073→        if (sectionLabelNearby) {\n  1074→          biFirst.score += 0.15;\n  1075→          biFirst