{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NSPyxYo5ZF7yBtDtUvKzo8","type":"tool_result","content":"   900→    const allCapsBonus = isAllCaps(rs.text) && rs.text.replace(/[^a-zA-Z]/g, \"\").length >= 4\n   901→      ? (wordCount(rs.text) >= 2 ? 0.08 : 0.03)\n   902→      : 0;\n   903→\n   904→    // Structural heading bonus: best ALL_CAPS heading (or its continuation join) is almost always the recipe title\n   905→    const structuralBonus = firstStructuralHeading && rs.text === firstStructuralHeading.text ? 0.10 : 0;\n   906→\n   907→    // thresholdScore excludes structural bonus so the bonus doesn't inflate the threshold\n   908→    // and prevent equally-valid structural headings from passing on multi-recipe pages.\n   909→    const thresholdScore = rs.rawScore + allCapsBonus;\n   910→    // baseScore excludes position factor — used for diagnostics and ranking\n   911→    const baseScore = rs.rawScore + allCapsBonus + structuralBonus;\n   912→    const score = rs.rawScore * positionFactor + allCapsBonus + structuralBonus;\n   913→    return { text: rs.text, position: rs.position, origin: rs.origin, score, rawScore: rs.rawScore, baseScore, thresholdScore };\n   914→  });\n   915→\n   916→  if (scored.length === 0) {\n   917→    return undefined;\n   918→  }\n   919→\n   920→  // First-after-preamble bonus (Pattern 3): when lines before the first candidate were all\n   921→  // filtered/empty, the first surviving candidate occupies the structural \"title position\".\n   922→  // E.g. \"FISH & SEAFOOD\\nHalibut with Saffron Cream Sauce\\n...\" — \"FISH & SEAFOOD\" is filtered\n   923→  // as a section label, so \"Halibut...\" is the first candidate and gets this boost.\n   924→  const firstCandidate = scored[0];\n   925→  if (firstCandidate.position > 0) {\n   926→    const allPrecedingFiltered = lines\n   927→      .slice(0, firstCandidate.position)\n   928→      .every((line) => {\n   929→        const trimmed = line.trim();\n   930→        return trimmed === \"\" || !passesHardFilters(trimmed);\n   931→      });\n   932→    if (allPrecedingFiltered) {\n   933→      firstCandidate.score += 0.08;\n   934→      firstCandidate.baseScore += 0.08;\n   935→      firstCandidate.thresholdScore += 0.08;\n   936→    }\n   937→  }\n   938→\n   939→  // --- Pre-threshold bilingual title detection ---\n   940→  // When a mixed-case candidate at position 0 is followed by an ALL_CAPS candidate\n   941→  // at position ≤ 2 that is semantically similar to it, this is a bilingual recipe\n   942→  // page (e.g., Polish title + ALL_CAPS Korean romanization). Suppress confirmed\n   943→  // translation candidates before computing threshold so their bonuses don't inflate\n   944→  // the threshold beyond the mixed-case title's reach.\n   945→  // Note: we check position ≤ 2 (local proximity), not global ALL_CAPS count, so\n   946→  // section headers later in the document (SKŁADNIKI, WARZYWA, etc.) are irrelevant.\n   947→  let translationCandidates: typeof scored = [];\n   948→  let scoredForThreshold = scored;\n   949→  const prePos0 = scored.find((s) => s.position === 0 && !isAllCaps(s.text));\n   950→  if (prePos0) {\n   951→    const nearbyAllCaps = scored.filter(\n   952→      (s) => isAllCaps(s.text) && s.position >= 1 && s.position <= 2 && s.origin === \"single\"\n   953→    );\n   954→    const pos0Embedding = rawScored.find((r) => r.text === prePos0.text)?.embedding;\n   955→\n   956→    // Method 1: embedding similarity (works for related languages)\n   957→    if (pos0Embedding && nearbyAllCaps.length > 0) {\n   958→      translationCandidates = nearbyAllCaps.filter((cap) => {\n   959→        const capEmbedding = rawScored.find((r) => r.text === cap.text)?.embedding;\n   960→        if (!capEmbedding) return false;\n   961→        return cosineSimilarity(pos0Embedding, capEmbedding) > 0.4;\n   962→      });\n   963→    }\n   964→\n   965→    // Method 2: layout-based detection (cross-lingual fallback).\n   966→    // When embedding similarity is insufficient (e.g. Polish ↔ Korean romanization),\n   967→    // detect bilingual layout by position and word overlap:\n   968→    // mixed-case ≥2 words at pos 0 + ALL_CAPS ≥2 words at pos 1-2 with no shared words.\n   969→    if (translationCandidates.length === 0 && wordCount(prePos0.text) >= 2) {\n   970→      const pos0Words = new Set(\n   971→        prePos0.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2)\n   972→      );\n   973→      translationCandidates = nearbyAllCaps.filter((cap) => {\n   974→        if (wordCount(cap.text) < 2) return false;\n   975→        const capWords = cap.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2);\n   976→        return !capWords.some((w) => pos0Words.has(w));\n   977→      });\n   978→    }\n   979→\n   980→    if (translationCandidates.length > 0) {\n   981→      // Suppress standalone translations and any multi-line joins that embed the translation\n   982→      // as a suffix or substring (e.g. \"Smażona zielona fasolka GREEN BEANS BORKEUM\" ends with\n   983→      // the translation; \"Title GREEN BEANS BORKEUM 그린빈\" includes it as a substring).\n   984→      scoredForThreshold = scored.filter((s) => {\n   985→        const sLower = s.text.toLowerCase();\n   986→        return !translationCandidates.some((t) => {\n   987→          const tLower = t.text.toLowerCase();\n   988→          return sLower.startsWith(tLower) ||\n   989→                 sLower.endsWith(\" \" + tLower) ||\n   990→                 sLower.includes(\" \" + tLower);\n   991→        });\n   992→      });\n   993→    }\n   994→  }\n   995→\n   996→  // Fix 2: If the structural heading was identified as a bilingual translation, reassign it.\n   997→  // This prevents the translation's ALL_CAPS bonus from inflating the threshold and ensures\n   998→  // the fallback path in scored also uses the correct heading.\n   999→  if (\n  1000→    translationCandidates.length > 0 &&\n  1001→    