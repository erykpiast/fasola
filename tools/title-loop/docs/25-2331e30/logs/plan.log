{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HF9Wk4E4vwMktwaatgGGDK","type":"tool_result","content":"   130→\n   131→\n   132→def get_pending_tasks(tasks_dir: Path) -> list[Path]:\n   133→    \"\"\"Return task files that don't have a corresponding .done marker.\"\"\"\n   134→    return [t for t in get_task_files(tasks_dir) if not t.with_suffix(\".done\").exists()]\n   135→\n   136→\n   137→# --- Core helpers ---\n   138→\n   139→def normalize(s: str) -> str:\n   140→    \"\"\"Normalize whitespace, hyphens, case, and Unicode form for comparison.\"\"\"\n   141→    s = unicodedata.normalize(\"NFC\", s)\n   142→    s = s.replace(\"\\u00a0\", \" \").replace(\"\\ufeff\", \"\")  # NBSP, BOM\n   143→    return \" \".join(s.lower().replace(\"-\", \" \").split())\n   144→\n   145→\n   146→def normalize_separators(s: str) -> str:\n   147→    \"\"\"Normalize filesystem-substituted characters (: replaces / in filenames).\"\"\"\n   148→    return s.replace(\":\", \"/\")\n   149→\n   150→\n   151→# Map stripped ASCII to Polish diacritics for fuzzy filename matching.\n   152→# Generated filenames often drop diacritics (e.g., \"Zaby\" for \"Żaby\").\n   153→_POLISH_DIACRITICS = str.maketrans(\n   154→    \"ąćęłńóśźżĄĆĘŁŃÓŚŹŻ\",\n   155→    \"acelnoszzACELNOSZZ\",\n   156→)\n   157→\n   158→\n   159→def _strip_diacritics(s: str) -> str:\n   160→    \"\"\"Strip Polish diacritics to ASCII equivalents.\"\"\"\n   161→    return s.translate(_POLISH_DIACRITICS)\n   162→\n   163→\n   164→def _ocr_normalize(s: str) -> str:\n   165→    \"\"\"Normalize common OCR character substitutions.\"\"\"\n   166→    return s.replace(\"0\", \"o\").replace(\"1\", \"i\").replace(\"\\u20ac\", \"e\")\n   167→\n   168→\n   169→def titles_match(extracted: str, expected: str) -> bool:\n   170→    \"\"\"\n   171→    Binary match: does the extracted title contain all expected title parts?\n   172→    Expected may contain multiple titles separated by '+'.\n   173→    Normalizes hyphens→spaces, strips Polish diacritics, and applies OCR\n   174→    character substitution normalization for robustness.\n   175→    \"\"\"\n   176→    if not extracted:\n   177→        return False\n   178→    extracted_norm = _ocr_normalize(_strip_diacritics(normalize_separators(normalize(extracted))))\n   179→    expected_parts = [\n   180→        _ocr_normalize(_strip_diacritics(normalize_separators(normalize(p))))\n   181→        for p in expected.split(\"+\")\n   182→    ]\n   183→    return all(part in extracted_norm for part in expected_parts)\n   184→\n   185→\n   186→def extract_expected_title(filename: str) -> str:\n   187→    \"\"\"Extract expected title from filename like 'Tomato Soup.real.txt'.\"\"\"\n   188→    name = Path(filename).name\n   189→    cleaned = re.sub(r\"\\.(real|generated)\\.txt$\", \"\", name)"}]},"parent_tool_use_id":"toolu_018ueNRHCygGLcmmzQA2fZKw","session_id":"93fcd165-c384-4cf1-b48c-241fa9498df5","uuid":"40c8f63d-aefb-469d-9593-7a5e96a78f2d"}
