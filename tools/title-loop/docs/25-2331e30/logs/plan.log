bsentThreshold = 0.10;\n  1112→    selected = selected.filter(s => s.rawScore >= titleAbsentThreshold);\n  1113→    selected = selected.filter(s => s.position <= 2);\n  1114→  }\n  1115→\n  1116→  // Remove word-boundary prefixes of firstStructuralHeading when the heading itself survived\n  1117→  // the threshold. Cases:\n  1118→  //   ARAYES case:  firstStructuralHeading = \"ARAYES SHRAK\" (2-word join qualifies; \"ARAYES\"\n  1119→  //     alone = 1 word, so it never qualified). Filter removes \"ARAYES\" so dedup keeps the join.\n  1120→  //   SAFFRON case: baseHeading was the partial line; continuation logic above upgraded\n  1121→  //     firstStructuralHeading to the full join. Filter removes the partial so dedup keeps join.\n  1122→  // Safety: only fires when the complete heading itself is in selected (passed the threshold).\n  1123→  if (firstStructuralHeading && selected.some((s) => s.text === firstStructuralHeading.text)) {\n  1124→    const fshLower = firstStructuralHeading.text.toLowerCase();\n  1125→    selected = selected.filter((s) => {\n  1126→      if (s.text === firstStructuralHeading.text) return true;\n  1127→      const sLower = s.text.toLowerCase();\n  1128→      // Remove s if it is a space-delimited prefix of the structural heading\n  1129→      return !fshLower.startsWith(sLower + \" \");\n  1130→    });\n  1131→  }\n  1132→\n  1133→  // Protect continuation joins: when a multi-line join (2-line or 3-line) survived the threshold\n  1134→  // and its second part starts with a continuation character, remove the single-line prefix/suffix\n  1135→  // so the dedup \"shorter wins\" rule doesn't destroy the complete join.\n  1136→  // Note: the pre-merge step above already handles the common Baked Eggs case (&/continuation\n  1137→  // on next line) by turning it into a single candidate — this block covers the rarer case where\n  1138→  // a continuation-character join was generated as a 2-line/3-line candidate and the prefix\n  1139→  // single also survived threshold independently (e.g. from a different code path or OCR layout).\n  1140→  // Safety: only fires for joins whose continuation starts with /&+:( — digit continuations\n  1141→  // like \"Pierogi Ruskie 200g mąki\" are NOT protected, so dedup correctly keeps the shorter form.\n  1142→  const survivingJoins = selected.filter((s) => s.origin === \"2-line\" || s.origin === \"3-line\");\n  1143→  if (survivingJoins.length > 0) {\n  1144→    selected = selected.filter((s) => {\n  1145→      if (s.origin !== \"single\") return true;\n  1146→      const sLower = s.text.toLowerCase();\n  1147→      // Remove PREFIX singles whose continuation join also survived\n  1148→      const isPrefixOfJoin = survivingJoins.some((j) => {\n  1149→        const jLower = j.text.toLowerCase();\n  1150→        if (!jLower.startsWith(sLower + \" \")) return false;\n  1151→        const remainder = jLower.slice(sLower.length + 1);\n  1152→        return /^[/&+:(]/.test(remainder);\n  1153→      });\n  1154→      if (isPrefixOfJoin) return false;\n  1155→      // Remove SUFFIX singles (e.g. \"& Coriander\") whose parent join also survived\n  1156→      const isSuffixOfJoin = survivingJoins.some((j) => {\n  1157→        const jLower = j.text.toLowerCase();\n  1158→        if (!jLower.endsWith(\" \" + sLower)) return false;\n  1159→        // Only remove if the suffix starts with a continuation character\n  1160→        return /^[/&+:(]/.test(sLower);\n  1161→      });\n  1162→      if (isSuffixOfJoin) return false;\n  1163→      return true;\n  1164→    });\n  1165→  }\n  1166→\n  1167→  // Pre-dedup: remove sub-section headers that are substrings of other surviving candidates.\n  1168→  // A sub-section header is an ALL_CAPS candidate followed by ingredient-like lines in the source.\n  1169→  // Example: \"CHLEBEK\" (bread section header, followed by \"500 g mąki\") is a substring of\n  1170→  // \"CHLEBEK Z WARZYWAMI I BOCZKIEM\" (the real title). Without this filter, dedup