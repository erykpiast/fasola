{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018jg8JBHGwjzS43D3wxbLZs","type":"tool_result","content":"     1→/**\n     2→ * TF-IDF (Term Frequency-Inverse Document Frequency) Text Classification\n     3→ * Weights distinctive keywords higher than common ones for better classification\n     4→ */\n     5→\n     6→import type { ClassificationCategory } from \"./index.d\";\n     7→import {\n     8→  ALL_CATEGORY_KEYS,\n     9→  ALL_CUISINE_KEYS,\n    10→  ALL_SEASON_KEYS,\n    11→  CATEGORY_LABELS,\n    12→  CUISINE_LABELS,\n    13→  SEASON_LABELS,\n    14→} from \"./labels\";\n    15→\n    16→interface LabelInfo {\n    17→  key: string;\n    18→  category: ClassificationCategory;\n    19→  keywords: Array<string>;\n    20→}\n    21→\n    22→/**\n    23→ * Precomputed IDF scores for all keywords across all labels\n    24→ */\n    25→let idfScores: Map<string, number> | null = null;\n    26→let allLabels: Array<LabelInfo> | null = null;\n    27→\n    28→/**\n    29→ * Initialize IDF scores by computing how rare each keyword is across all labels\n    30→ */\n    31→function initializeIdfScores(): void {\n    32→  if (idfScores && allLabels) {\n    33→    return; // Already initialized\n    34→  }\n    35→\n    36→  // Collect all labels with their keywords\n    37→  const labels: Array<LabelInfo> = [];\n    38→\n    39→  for (const key of ALL_SEASON_KEYS) {\n    40→    const description = SEASON_LABELS[key];\n    41→    const keywords = description\n    42→      .toLowerCase()\n    43→      .split(/[,\\s]+/)\n    44→      .filter((k) => k.length > 3);\n    45→    labels.push({ key, category: \"season\", keywords });\n    46→  }\n    47→\n    48→  for (const key of ALL_CUISINE_KEYS) {\n    49→    const description = CUISINE_LABELS[key];\n    50→    const keywords = description\n    51→      .toLowerCase()\n    52→      .split(/[,\\s]+/)\n    53→      .filter((k) => k.length > 3);\n    54→    labels.push({ key, category: \"cuisine\", keywords });\n    55→  }\n    56→\n    57→  for (const key of ALL_CATEGORY_KEYS) {\n    58→    const description = CATEGORY_LABELS[key];\n    59→    const keywords = description\n    60→      .toLowerCase()\n    61→      .split(/[,\\s]+/)\n    62→      .filter((k) => k.length > 3);\n    63→    labels.push({ key, category: \"food-category\", keywords });\n    64→  }\n    65→\n    66→  allLabels = labels;\n    67→\n    68→  // Count how many labels each keyword appears in\n    69→  const keywordLabelCounts = new Map<string, number>();\n    70→\n    71→  for (const label of labels) {\n    72→    const uniqueKeywords = new Set(label.keywords);\n    73→    for (const keyword of uniqueKeywords) {\n    74→      keywordLabelCounts.set(\n    75→        keyword,\n    76→        (keywordLabelCounts.get(keyword) || 0) + 1\n    77→      );\n    78→    }\n    79→  }\n    80→\n    81→  // Compute IDF scores: IDF(keyword) = log(totalLabels / labelsContainingKeyword)\n    82→  const totalLabels = labels.length;\n    83→  idfScores = new Map<string, number>();\n    84→\n    85→  for (const [keyword, count] of keywordLabelCounts) {\n    86→    const idf = Math.log(totalLabels / count);\n    87→    idfScores.set(keyword, idf);\n    88→  }\n    89→\n    90→  console.log(\n    91→    `[TF-IDF] Initialized IDF scores for ${idfScores.size} unique keywords across ${totalLabels} labels`\n    92→  );\n    93→}\n    94→\n    95→/**\n    96→ * Compute TF (term frequency) for keywords in text\n    97→ */\n    98→function computeTermFrequency(text: string): Map<string, number> {\n    99→  const lowerText = text.toLowerCase();\n   100→  const words = lowerText.split(/[,\\s]+/).filter((w) => w.length > 3);\n   101→\n   102→  const termFreq = new Map<string, number>();\n   103→  for (const word of words) {\n   104→    termFreq.set(word, (termFreq.get(word) || 0) + 1);\n   105→  }\n   106→\n   107→  return termFreq;\n   108→}\n   109→\n   110→/**\n   111→ * Compute TF-IDF score for a label against the input text\n   112→ */\n   113→function computeLabelScore(\n   114→  textTermFreq: Map<string, number>,\n   115→  label: LabelInfo,\n   116→  idf: Map<string, number>\n   117→): number {\n   118→  let score = 0;\n   119→  let normalization = 0;\n   120→\n   121→  for (const keyword of label.keywords) {\n   122→    const idfScore = idf.get(keyword) || 0;\n   123→    const tf = textTermFreq.get(keyword) || 0;\n   124→\n   125→    if (tf > 0) {\n   126→      score += tf * idfScore;\n   127→    }\n   128→\n   129→    // Normalization: sum of IDF scores for all keywords in the label\n   130→    normalization += idfScore;\n   131→  }\n   132→\n   133→  // Normalize by the sum of IDF scores to handle labels with different keyword counts\n   134→  return normalization > 0 ? score / normalization : 0;\n   135→}\n   136→\n   137→export interface TfIdfSuggestion {\n   138→  tag: `#${string}`;\n   139→  confidence: number;\n   140→  category: ClassificationCategory;\n   141→}\n   142→\n   143→/**\n   144→ * Classify text using TF-IDF scoring\n   145→ */\n   146→export function classifyWithTfIdf(text: string): Array<TfIdfSuggestion> {\n   147→  // Initialize on first use\n   148→  initializeIdfScores();\n   149→\n   150→  if (!idfScores || !allLabels) {\n   151→    console.error(\"[TF-IDF] Failed to initialize IDF scores\");\n   152→    return [];\n   153→  }\n   154→\n   155→  // Compute term frequency for input text\n   156→  const textTermFreq = computeTermFrequency(text);\n   157→\n   158→  // Compute scores for all labels\n   159→  const suggestions: Array<TfIdfSuggestion> = [];\n   160→\n   161→  for (const label of allLabels) {\n   162→    const score = computeLabelScore(textTermFreq, label, idfScores);\n   163→\n   164→    // Only include if we have reasonable confidence\n   165→    // TF-IDF scores are typically lower than simple keyword matching\n   166→    // because they're normalized and weighted\n   167→    if (score > 0.2) {\n   168→      suggestions.push({\n   169→        tag: `#${label.key}` as `#${string}`,\n   170→        confidence: score,\n   171→        category: label.category,\n   172→      });\n   173→    }\n   174→  }\n   175→\n   176→  // Sort by confidence\n   177→  suggestions.sort((a, b) => b.confidence - a.confidence);\n   178→\n   179→  return suggestions;\n   180→}\n   181→"}]},"parent_tool_use_id":"toolu_018ueNRHCygGLcmmzQA2fZKw","session_id":"93fcd165-c384-4cf1-b48c-241fa9498df5","uuid":"a6a24afb-ca0b-4aa9-91a7-70b98f408ce2"}
