{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NZBBcJHzyZCAnhrzGuh7a9","type":"tool_result","content":"   350→\n   351→/**\n   352→ * Detect initial burst of short garbled lines.\n   353→ * Returns the index of the first non-garbled or long line.\n   354→ */\n   355→function findBurstEnd(lines: Array<{ text: string }>): number {\n   356→  let i = 0;\n   357→\n   358→  // Skip overflow preambles: blocks introduced by \"PREVIOUS RECIPE OVERFLOW\",\n   359→  // \"PREVIOUS PAGE CONTENT\", \"CORRUPTED SECTION\", etc. that precede the actual recipe.\n   360→  const OVERFLOW_MARKERS = /\\b(PREVIOUS\\s+(RECIPE|PAGE)\\s+(OVERFLOW|CONTENT)|SPILLOVER|CONTINUATION|CORRUPTED\\s+SECTION)\\b/i;\n   361→  let overflowEnd = 0;\n   362→  for (let k = 0; k < lines.length && k < 30; k++) {\n   363→    if (OVERFLOW_MARKERS.test(lines[k].text)) {\n   364→      // Skip forward past the overflow block to the next visual separator or blank cluster\n   365→      let m = k + 1;\n   366→      while (m < lines.length) {\n   367→        if (/^[=\\-]{4,}$/.test(lines[m].text) || lines[m].text.length === 0) {\n   368→          overflowEnd = m + 1;\n   369→          break;\n   370→        }\n   371→        m++;\n   372→      }\n   373→      if (overflowEnd === 0) overflowEnd = k + 1;\n   374→    }\n   375→  }\n   376→  if (overflowEnd > 0) i = overflowEnd;\n   377→\n   378→  while (i < lines.length && lines[i].text.length < 20 && isLikelyGarbled(lines[i].text) && !isAllCaps(lines[i].text)) {\n   379→    i++;\n   380→  }\n   381→  // Skip long instruction-like prologues: if 5+ consecutive lines look like cooking instructions,\n   382→  // skip them to find the actual title region.\n   383→  if (i === 0) {\n   384→    let j = 0;\n   385→    while (j < lines.length && looksLikeCookingInstruction(lines[j].text)) {\n   386→      j++;\n   387→    }\n   388→    if (j >= 5) {\n   389→      i = j;\n   390→    }\n   391→  }\n   392→  // Skip prose prologues: mid-recipe body text before the actual title.\n   393→  // If 3+ consecutive lines look like running body text (lowercase start, continuation,\n   394→  // or sentence-ending with many words), skip them.\n   395→  if (i === 0) {\n   396→    let j = 0;\n   397→    while (j < lines.length) {\n   398→      const t = lines[j].text;\n   399→      const isBodyText = (\n   400→        /^[a-ząćęłńóśźż]/.test(t) ||\n   401→        t.endsWith(\",\") ||\n   402→        (t.endsWith(\".\") && wordCount(t) > 4)\n   403→      ) && wordCount(t) >= 4;\n   404→      if (isBodyText) j++;\n   405→      else break;\n   406→    }\n   407→    if (j >= 3) i = j;\n   408→  }\n   409→  return i;\n   410→}\n   411→\n   412→function stripParentheticalGloss(text: string): string {\n   413→  // Strip trailing English-gloss parentheticals from ALL_CAPS titles.\n   414→  // e.g. \"PIEROGI RUSKIE (Boiled Dumplings with Potato and Cheese)\" → \"PIEROGI RUSKIE\"\n   415→  // Keep if parenthetical is ALL_CAPS (variation/subtitle in same language).\n   416→  // Keep if both base and paren are mixed-case (both are part of the title).\n   417→  const match = text.match(/^(.+?)\\s*\\(([^)]+)\\)\\s*$/);\n   418→  if (!match) return text;\n   419→  const [, base, paren] = match;\n   420→  if (isAllCaps(paren)) return text;\n   421→  if (!isAllCaps(base) && !isAllCaps(paren)) return text;\n   422→  return base.trim();\n   423→}\n   424→\n   425→function stripPageNumber(text: string): string {\n   426→  // \"34  Berry Jam\" → \"Berry Jam\" (2+ spaces distinguishes from \"2 eggs\")\n   427→  const match = text.match(/^\\d{1,3}\\s{2,}(.+)$/);\n   428→  return match ? match[1] : text;\n   429→}\n   430→\n   431→function wordCount(text: string): number {\n   432→  return text.split(/\\s+/).filter((w) => w.length > 0).length;\n   433→}\n   434→\n   435→/**\n   436→ * Build candidate strings from lines: single lines plus multi-line joins (2-3 consecutive).\n   437→ * Skips initial burst of short garbled lines. Scans all remaining lines. Caps at 25.\n   438→ */\n   439→export type CandidateOrigin = \"single\" | \"2-line\" | \"3-line\";\n   440→\n   441→function buildCandidates(\n   442→  lines: Array<string>\n   443→): Array<{ text: string; position: number; origin: CandidateOrigin }> {\n   444→  const nonEmptyLines: Array<{ text: string; index: number }> = [];\n   445→\n   446→  for (let i = 0; i < lines.length; i++) {\n   447→    const trimmed = lines[i].trim();\n   448→    if (trimmed.length > 0) {\n   449→      nonEmptyLines.push({ text: trimmed, index: i });"}]},"parent_tool_use_id":null,"session_id":"93fcd165-c384-4cf1-b48c-241fa9498df5","uuid":"d6d455ba-64f2-47ea-85af-2b9111352684","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/title-extractor.ts","content":"\n/**\n * Detect initial burst of short garbled lines.\n * Returns the index of the first non-garbled or long line.\n */\nfunction findBurstEnd(lines: Array<{ text: string }>): number {\n  let i = 0;\n\n  // Skip overflow preambles: blocks introduced by \"PREVIOUS RECIPE OVERFLOW\",\n  // \"PREVIOUS PAGE CONTENT\", \"CORRUPTED SECTION\", etc. that precede the actual recipe.\n  const OVERFLOW_MARKERS = /\\b(PREVIOUS\\s+(RECIPE|PAGE)\\s+(OVERFLOW|CONTENT)|SPILLOVER|CONTINUATION|CORRUPTED\\s+SECTION)\\b/i;\n  let overflowEnd = 0;\n  for (let k = 0; k < lines.length && k < 30; k++) {\n    if (OVERFLOW_MARKERS.test(lines[k].text)) {\n      // Skip forward past the overflow block to the next visual separator or blank cluster\n      let m = k + 1;\n      while (m < lines.length) {\n        if (/^[=\\-]{4,}$/.test(lines[m].text) || lines[m].text.length === 0) {\n          overflowEnd = m + 1;\n          break;\n        }\n        m++;\n      }\n      if (overflowEnd === 0) overflowEnd = k + 1;\n    }\n  }\n  if (overflowEnd > 0) i = overflowEnd;\n\n  while (i < lines.length && lines[i].text.length < 20 && isLikelyGarbled(lines[i].text) && !isAllCaps(lines[i].text)) {\n    i++;\n  }\n  // Skip long instruction-like prologues: if 5+ consecutive lines look like cooking instructions,\n  // skip them to find the actual title region.\n  if (i === 0) {\n    let j = 0;\n    while (j < lines.length && looksLikeCookingInstruction(lines[j].text)) {\n      j++;\n    }\n    if (j >= 5) {\n      i = j;\n    }\n  }\n  // Skip prose prologues: mid-recipe body text before the actual title.\n  // If 3+ consecutive lines look like running body text (lowercase start, continuation,\n  // or sentence-ending with many words), skip them.\n  if (i === 0) {\n    let j = 0;\n    while (j < lines.length) {\n      const t = lines[j].text;\n      const isBodyText = (\n        /^[a-ząćęłńóśźż]/.test(t) ||\n        t.endsWith(\",\") ||\n        (t.endsWith(\".\") && wordCount(t) > 4)\n      ) && wordCount(t) >= 4;\n      if (isBodyText) j++;\n      else break;\n    }\n    if (j >= 3) i = j;\n  }\n  return i;\n}\n\nfunction stripParentheticalGloss(text: string): string {\n  // Strip trailing English-gloss parentheticals from ALL_CAPS titles.\n  // e.g. \"PIEROGI RUSKIE (Boiled Dumplings with Potato and Cheese)\" → \"PIEROGI RUSKIE\"\n  // Keep if parenthetical is ALL_CAPS (variation/subtitle in same language).\n  // Keep if both base and paren are mixed-case (both are part of the title).\n  const match = text.match(/^(.+?)\\s*\\(([^)]+)\\)\\s*$/);\n  if (!match) return text;\n  const [, base, paren] = match;\n  if (isAllCaps(paren)) return text;\n  if (!isAllCaps(base) && !isAllCaps(paren)) return text;\n  return base.trim();\n}\n\nfunction stripPageNumber(text: string): string {\n  // \"34  Berry Jam\" → \"Berry Jam\" (2+ spaces distinguishes from \"2 eggs\")\n  const match = text.match(/^\\d{1,3}\\s{2,}(.+)$/);\n  return match ? match[1] : text;\n}\n\nfunction wordCount(text: string): number {\n  return text.split(/\\s+/).filter((w) => w.length > 0).length;\n}\n\n/**\n * Build candidate strings from lines: single lines plus multi-line joins (2-3 consecutive).\n * Skips initial burst of short garbled lines. Scans all remaining lines. Caps at 25.\n */\nexport type CandidateOrigin = \"single\" | \"2-line\" | \"3-line\";\n\nfunction buildCandidates(\n  lines: Array<string>\n): Array<{ text: string; position: number; origin: CandidateOrigin }> {\n  const nonEmptyLines: Array<{ text: string; index: number }> = [];\n\n  for (let i = 0; i < lines.length; i++) {\n    const trimmed = lines[i].trim();\n    if (trimmed.length > 0) {\n      nonEmptyLines.push({ text: trimmed, index: i });","numLines":100,"startLine":350,"totalLines":1362}}}
