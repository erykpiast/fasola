(?=[a-zà-ż])/g, \"l\")\n   763→        .replace(/¡/g, \"i\")\n   764→        .replace(/€/g, \"e\");\n   765→    }).join(\"\");\n   766→  }\n   767→\n   768→  // Step 3: Title-case conversion — ONLY when OCR substitution changed the text.\n   769→  // This preserves clean ALL_CAPS titles (e.g. \"CHOCOLATE CAKE\") as-is.\n   770→  if (text !== beforeSub && isAllCaps(text)) {\n   771→    text = toTitleCase(text);\n   772→  }\n   773→\n   774→  return text.trim();\n   775→}\n   776→\n   777→// Module-level cache for reference embeddings\n   778→let cachedTitleRefEmbedding: Array<number> | null = null;\n   779→let cachedHeaderRefEmbedding: Array<number> | null = null;\n   780→let cachedNoiseRefEmbedding: Array<number> | null = null;\n   781→\n   782→export function _resetEmbeddingCacheForTests(): void {\n   783→  cachedTitleRefEmbedding = null;\n   784→  cachedHeaderRefEmbedding = null;\n   785→  cachedNoiseRefEmbedding = null;\n   786→}\n   787→\n   788→export async function extractTitleWithEmbeddings(\n   789→  text: string,\n   790→  embed: EmbedFn\n   791→): Promise<string | undefined> {\n   792→  if (!text || text.trim().length === 0) {\n   793→    return undefined;\n   794→  }\n   795→\n   796→  const lines = text.split(\"\\n\");\n   797→  const candidates = buildCandidates(lines);\n   798→  const titleAbsent = isTitleAbsentPage(lines);\n   799→\n   800→  if (candidates.length === 0) {\n   801→    return undefined;\n   802→  }\n   803→\n   804→  // Cache reference embeddings\n   805→  if (!cachedTitleRefEmbedding) {\n   806→    cachedTitleRefEmbedding = await embed(TITLE_REFERENCE);\n   807→  }\n   808→  if (!cachedHeaderRefEmbedding) {\n   809→    cachedHeaderRefEmbedding = await embed(HEADER_REFERENCE);\n   810→  }\n   811→  if (!cachedNoiseRefEmbedding) {\n   812→    cachedNoiseRefEmbedding = await embed(NOISE_REFERENCE);\n   813→  }\n   814→\n   815→  // Find ALL_CAPS candidates with ≥2 words where every significant word has ≥4 alpha letters.\n   816→  // Insignificant tokens (≤1 alpha letter: \"/\", \"&\", \"+\", \":\", \"D)\", etc.) are filtered before\n   817→  // the check so that multi-line joins with continuation punctuation still qualify.\n   818→  const isStructuralHeading = (c: { text: string }): boolean => {\n   819→    if (!isAllCaps(c.text) || wordCount(c.text) < 2) return false;\n   820→    const sigWords = c.text.trim().split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length > 1);\n   821→    return sigWords.length >= 2 && sigWords.every((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   822→  };\n   823→\n   824→  // Pass 1: compute rawScore for all candidates (embedding quality signal)\n   825→  const rawScored: Array<{ text: string; position: number; origin: CandidateOrigin; rawScore: number; embedding: Array<number> }> = [];\n   826→  for (const candidate of candidates) {\n   827→    const embedding = await embed(candidate.text);\n   828→    const titleSim = cosineSimilarity(embedding, cachedTitleRefEmbedding);\n   829→    const headerSim = cosineSimilarity(embedding, cachedHeaderRefEmbedding);\n   830→    const noiseSim = cosineSimilarity(embedding, cachedNoiseRefEmbedding);\n   831→    const rawScore = titleSim - Math.max(headerSim, noiseSim);\n   832→    rawScored.push({ text: candidate.text, position: candidate.position, origin: candidate.origin, rawScore, embedding });\n   833→  }\n   834→\n   835→  // Select baseHeading by embedding quality (rawScore), not position.\n   836→  // This prevents OCR-garbled fragments from claiming the structural heading slot.\n   837→  const structuralCandidates = rawScored.filter((s) => isStructuralHeading(s));\n   838→\n   839→  // Penalize structural headings with truncated OCR words:\n   840→  // if \"FRON\" appears and another heading has \"SAFFRON\", \"FRON\" is likely garbled.\n   841→  for (const sc of structuralCandidates) {\n   842→    const sigWords = sc.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   843→    for (const other of structuralCandidates) {\n   844→      if (other === sc) continue;\n   845→      const otherSigWords = other.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   846→      const hasTruncation = sigWords.some((w) =>\n   847→        otherSigWords.some((ow) => ow !== w && ow.length > w.length && ow.endsWith(w))\n   848→      );\n   849→      if (hasTruncation) {\n   850→        sc.rawScore = -1.0;  // Hard disqualification — truncated OCR artifact\n   851→        break;\n   852→      }\n   853→    }\n   854→  }\n   855→\n   856→  const bestStructural = structuralCandidates.length > 0\n   857→    ? structuralCandidates.reduce((a, b) => {\n   858→        const scoreDiff = a.rawScore - b.rawScore;\n   859→        if (Math.abs(scoreDiff) > 0.03) return scoreDiff > 0 ? a : b;\n   860→        // Tiebreak: single-line origin beats multi-line joins (avoids conflating two separate headings)\n   861→        if (a.origin === \"single\" && b.origin !== \"single\") return a;\n   862→        if (b.origin === \"single\" && a.origin !== \"single\") return b;\n   863→        // Tiebreak: more words (more specific) → better\n   864→        const wcDiff = wordCount(b.text) - wordCount(a.text);\n   865→        if (wcDiff !== 0) return wcDiff > 0 ? b : a;\n   866→        // Tiebreak: earlier position → better\n   867→        return a.position < b.position ? a : b;\n   868→      })\n   869→    : null;\n   870→  const baseHeading = bestStructural ?? undefined;\n   871→\n   872→  // When the best structural heading has a continuation on the next line introduced by a\n   873→  // punctuation token (/, &, +, :, or parenthesis), prefer the longer 2-line join as the\n   874→  // complete heading. E.g. \"SAFFRON WHEAT BUNS WITH QUARK\" + \"/ COTTAGE CHEESE (VARIATION D)\".\n   875→  // Guard: the remainder after the prefix must start with a continuation character to avoid\n   876→  // merging two separate consecutive recipe titles (FINNISH MILK FLATBREADS stays separate\n   877→  // from FINNISH POTATO FLATBREADS because \"FINNISH\" does not start with a continuation token).\n   878→  let firstStructuralHeading = baseHeading && (\n   879→    rawScored.find((c) => {\n   880→      if (!isStructuralHeading(c)) return false;\n   881→      const hLower = baseHeading.text.toLowerCase();\n   882→      const cLower = c.text.toLowerCase();\n   883→      return cLower.startsWith(hLower + \" \") && /^[/&+:(]/.test(cLower.slice(hLower.length + 1));\n   884→    }) ?? baseHeading\n   885→  );\n   886→\n   887→  // Pass 2: apply bonuses\n   888→  const scored: Array<{ text: string; position: number; origin: CandidateOrigin; score: number; rawScore: number; baseScore: number; thresholdScore: number }> = rawScored.map((rs, candidateIndex) => {\n   889→    // Position factor: multiplicative tiebreaker — amplifies existing signal, doesn't replace it.\n   890→    // Use candidate-relative position (rank among candidates that passed hard filters) rather than\n   891→    // raw line position, so filtered preamble lines don't penalize the first real candidate.\n   892→    const candidateRelativePosition = candidateIndex / rawScored.length;\n   893→    const positionFactor = candidateRelativePosition < 0.5\n   894→      ? 1.0 + 0.12 * (1 - candidateRelativePosition * 2)\n   895→      : 1.0;\n   896→\n   897→    // ALL_CAPS bonus: recipe books use ALL_CAPS for titles and section headings.\n   898→    // Single-word ALL_CAPS terms are overwhelmingly section/category labels, not recipe titles;\n   899→    // real recipe titles in ALL_CAPS are almost always multi-word. Reduce the bonus for single words."}]},"parent_tool_use_id":"toolu_018ueNRHCygGLcmmzQA2fZKw","session_id":"93fcd165-c384-4cf1-b48c-241fa9498df5","uuid":"c7a01088-73c8-4c35-8185-4de4b30b71e7"}
