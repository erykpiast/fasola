{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013DESaTZT8rfiCB2toUB7J3","type":"tool_result","content":"   209→/**\n   210→ * Measures vocabulary overlap between a candidate title and the rest of the document.\n   211→ * Returns a ratio (0–1) of the candidate's content words (≥3 letters) that appear\n   212→ * in at least one other line. Used to detect orphaned OCR artifacts in multi-title pages.\n   213→ */\n   214→function corroborationScore(\n   215→  candidateText: string,\n   216→  candidatePosition: number,\n   217→  allLines: string[]\n   218→): number {\n   219→  const contentWords = candidateText\n   220→    .split(/\\s+/)\n   221→    .filter((w) => w.replace(/[^a-zA-ZÀ-ÿ]/g, \"\").length >= 3)\n   222→    .map((w) => w.toUpperCase());\n   223→\n   224→  if (contentWords.length === 0) {\n   225→    return 1.0; // No checkable words — pass through\n   226→  }\n   227→\n   228→  let corroboratedCount = 0;\n   229→  for (const word of contentWords) {\n   230→    for (let i = 0; i < allLines.length; i++) {\n   231→      if (i === candidatePosition) continue;\n   232→      if (allLines[i].toUpperCase().includes(word)) {\n   233→        corroboratedCount++;\n   234→        break;\n   235→      }\n   236→    }\n   237→  }\n   238→\n   239→  return corroboratedCount / contentWords.length;\n   240→}\n   241→\n   242→/**\n   243→ * Returns true if the candidate's vocabulary is sufficiently supported by the rest of\n   244→ * the document. Short candidates (≤3 content words) require 100% corroboration;\n   245→ * longer candidates require ≥67%.\n   246→ */\n   247→function passesCorroboration(\n   248→  text: string,\n   249→  position: number,\n   250→  allLines: string[]\n   251→): boolean {\n   252→  const score = corroborationScore(text, position, allLines);\n   253→  const contentWords = text\n   254→    .split(/\\s+/)\n   255→    .filter((w) => w.replace(/[^a-zA-ZÀ-ÿ]/g, \"\").length >= 3);\n   256→  const threshold = contentWords.length <= 3 ? 1.0 : 0.67;\n   257→  return score >= threshold;\n   258→}\n   259→\n   260→function isLikelyGarbled(text: string): boolean {\n   261→  const letters = text.replace(/[^a-zA-Z]/g, \"\");\n   262→  if (letters.length < 2) return true;\n   263→"}]},"parent_tool_use_id":null,"session_id":"85fd2af6-6c55-4da1-a228-07fff6134a1a","uuid":"9cfc7335-520c-4789-bda4-20664aaf52b6","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/title-extractor.ts","content":"/**\n * Measures vocabulary overlap between a candidate title and the rest of the document.\n * Returns a ratio (0–1) of the candidate's content words (≥3 letters) that appear\n * in at least one other line. Used to detect orphaned OCR artifacts in multi-title pages.\n */\nfunction corroborationScore(\n  candidateText: string,\n  candidatePosition: number,\n  allLines: string[]\n): number {\n  const contentWords = candidateText\n    .split(/\\s+/)\n    .filter((w) => w.replace(/[^a-zA-ZÀ-ÿ]/g, \"\").length >= 3)\n    .map((w) => w.toUpperCase());\n\n  if (contentWords.length === 0) {\n    return 1.0; // No checkable words — pass through\n  }\n\n  let corroboratedCount = 0;\n  for (const word of contentWords) {\n    for (let i = 0; i < allLines.length; i++) {\n      if (i === candidatePosition) continue;\n      if (allLines[i].toUpperCase().includes(word)) {\n        corroboratedCount++;\n        break;\n      }\n    }\n  }\n\n  return corroboratedCount / contentWords.length;\n}\n\n/**\n * Returns true if the candidate's vocabulary is sufficiently supported by the rest of\n * the document. Short candidates (≤3 content words) require 100% corroboration;\n * longer candidates require ≥67%.\n */\nfunction passesCorroboration(\n  text: string,\n  position: number,\n  allLines: string[]\n): boolean {\n  const score = corroborationScore(text, position, allLines);\n  const contentWords = text\n    .split(/\\s+/)\n    .filter((w) => w.replace(/[^a-zA-ZÀ-ÿ]/g, \"\").length >= 3);\n  const threshold = contentWords.length <= 3 ? 1.0 : 0.67;\n  return score >= threshold;\n}\n\nfunction isLikelyGarbled(text: string): boolean {\n  const letters = text.replace(/[^a-zA-Z]/g, \"\");\n  if (letters.length < 2) return true;\n","numLines":55,"startLine":209,"totalLines":1447}}}
