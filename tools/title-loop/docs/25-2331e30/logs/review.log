{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QZUaFmnMbt5dtL2S7PYx4K","type":"tool_result","content":"   378→  });\n   379→\n   380→  describe(\"corroboration (multi-title filtering)\", () => {\n   381→    // beforeEach inherited from parent describe\n   382→\n   383→    it(\"rejects orphaned OCR artifact in multi-title assembly\", async () => {\n   384→    // \"DAT FLATBREADS\" is an OCR artifact from a preceding page — \"DAT\" doesn't appear\n   385→    // anywhere else in the document, so it fails the 100% corroboration threshold.\n   386→    // \"FINNISH MILK FLATBREADS\" and \"FINNISH POTATO FLATBREADS\" are both corroborated\n   387→    // by their words appearing in the body text.\n   388→    const embed = createMockEmbed(\n   389→      [\"dat flatbreads\", \"finnish milk flatbreads\", \"finnish potato flatbreads\"],\n   390→      []\n   391→    );\n   392→    const input = [\n   393→      \"2 cup plus 1 tablespoon mixer fried with for 5 minutes\",\n   394→      \"nto a loured work counter shape into ball\",\n   395→      \"DAT FLATBREADS\",\n   396→      \"le Finnish region of Savo bread more like a\",\n   397→      \"\",\n   398→      \"FINNISH MILK FLATBREADS\",\n   399→      \"\",\n   400→      \"These traditional flatbreads are soft and delicious\",\n   401→      \"served warm with butter and milk\",\n   402→      \"500g flour\",\n   403→      \"300ml milk\",\n   404→      \"1 tsp salt\",\n   405→      \"\",\n   406→      \"Mix the flour and milk together until smooth\",\n   407→      \"Let the dough rest for 30 minutes\",\n   408→      \"\",\n   409→      \"FINNISH POTATO FLATBREADS\",\n   410→      \"\",\n   411→      \"Finnish potato flatbreads are hearty and filling\",\n   412→      \"3 large potatoes\",\n   413→      \"200g flour\",\n   414→      \"butter for frying\",\n   415→      \"\",\n   416→      \"Boil the potatoes until tender then mash\",\n   417→      \"Mix mashed potato with flour and salt\",\n   418→    ].join(\"\\n\");\n   419→\n   420→    const result = await extractTitleWithEmbeddings(input, embed);\n   421→    expect(result).toBe(\"FINNISH MILK FLATBREADS + FINNISH POTATO FLATBREADS\");\n   422→  });\n   423→\n   424→  it(\"keeps legitimate multi-recipe titles that are corroborated\", async () => {\n   425→    // Both CHICKEN SOUP and BEEF STEW have their words in the document body,\n   426→    // so both pass corroboration and are returned.\n   427→    const embed = createMockEmbed([\"chicken soup\", \"beef stew\"], []);\n   428→    const input = [\n   429→      \"CHICKEN SOUP\",\n   430→      \"\",\n   431→      \"A classic chicken soup recipe\",\n   432→      \"1 whole chicken\",\n   433→      \"2 carrots\",\n   434→      \"salt and pepper\",\n   435→      \"\",\n   436→      \"Place the chicken in a large pot\",\n   437→      \"\",\n   438→      \"BEEF STEW\",\n   439→      \"\",\n   440→      \"A hearty beef stew for cold days\",\n   441→      \"500g beef chuck\",\n   442→      \"3 potatoes\",\n   443→      \"2 onions\",\n   444→      \"\",\n   445→      \"Cut the beef into cubes\",\n   446→    ].join(\"\\n\");\n   447→\n   448→    const result = await extractTitleWithEmbeddings(input, embed);\n   449→    expect(result).toBe(\"CHICKEN SOUP + BEEF STEW\");\n   450→  });\n   451→\n   452→  it(\"does not apply corroboration to single-title pages\", async () => {\n   453→    // Corroboration only runs when ≥2 ALL_CAPS candidates are selected.\n   454→    // A single ALL_CAPS title is returned as-is regardless of vocabulary overlap.\n   455→    const embed = createMockEmbed([\"golonka pieczona\"], []);\n   456→    const input = [\n   457→      \"GOLONKA PIECZONA\",\n   458→      \"\",\n   459→      \"Składniki na 4 porcje\",\n   460→      \"1 kg mięsa\",\n   461→      \"2 cebule\",\n   462→      \"3 ząbki czosnku\",\n   463→      \"\",\n   464→      \"Mięso umyć i osuszyć\",\n   465→      \"Cebulę pokroić w plastry\",\n   466→    ].join(\"\\n\");\n   467→\n   468→    const result = await extractTitleWithEmbeddings(input, embed);\n   469→    expect(result).toBe(\"GOLONKA PIECZONA\");\n   470→  });\n   471→  });\n   472→});"}]},"parent_tool_use_id":null,"session_id":"85fd2af6-6c55-4da1-a228-07fff6134a1a","uuid":"ed0f97df-4037-4aa1-a085-b3657e1c0158","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/__tests__/title-extractor.test.ts","content":"  });\n\n  describe(\"corroboration (multi-title filtering)\", () => {\n    // beforeEach inherited from parent describe\n\n    it(\"rejects orphaned OCR artifact in multi-title assembly\", async () => {\n    // \"DAT FLATBREADS\" is an OCR artifact from a preceding page — \"DAT\" doesn't appear\n    // anywhere else in the document, so it fails the 100% corroboration threshold.\n    // \"FINNISH MILK FLATBREADS\" and \"FINNISH POTATO FLATBREADS\" are both corroborated\n    // by their words appearing in the body text.\n    const embed = createMockEmbed(\n      [\"dat flatbreads\", \"finnish milk flatbreads\", \"finnish potato flatbreads\"],\n      []\n    );\n    const input = [\n      \"2 cup plus 1 tablespoon mixer fried with for 5 minutes\",\n      \"nto a loured work counter shape into ball\",\n      \"DAT FLATBREADS\",\n      \"le Finnish region of Savo bread more like a\",\n      \"\",\n      \"FINNISH MILK FLATBREADS\",\n      \"\",\n      \"These traditional flatbreads are soft and delicious\",\n      \"served warm with butter and milk\",\n      \"500g flour\",\n      \"300ml milk\",\n      \"1 tsp salt\",\n      \"\",\n      \"Mix the flour and milk together until smooth\",\n      \"Let the dough rest for 30 minutes\",\n      \"\",\n      \"FINNISH POTATO FLATBREADS\",\n      \"\",\n      \"Finnish potato flatbreads are hearty and filling\",\n      \"3 large potatoes\",\n      \"200g flour\",\n      \"butter for frying\",\n      \"\",\n      \"Boil the potatoes until tender then mash\",\n      \"Mix mashed potato with flour and salt\",\n    ].join(\"\\n\");\n\n    const result = await extractTitleWithEmbeddings(input, embed);\n    expect(result).toBe(\"FINNISH MILK FLATBREADS + FINNISH POTATO FLATBREADS\");\n  });\n\n  it(\"keeps legitimate multi-recipe titles that are corroborated\", async () => {\n    // Both CHICKEN SOUP and BEEF STEW have their words in the document body,\n    // so both pass corroboration and are returned.\n    const embed = createMockEmbed([\"chicken soup\", \"beef stew\"], []);\n    const input = [\n      \"CHICKEN SOUP\",\n      \"\",\n      \"A classic chicken soup recipe\",\n      \"1 whole chicken\",\n      \"2 carrots\",\n      \"salt and pepper\",\n      \"\",\n      \"Place the chicken in a large pot\",\n      \"\",\n      \"BEEF STEW\",\n      \"\",\n      \"A hearty beef stew for cold days\",\n      \"500g beef chuck\",\n      \"3 potatoes\",\n      \"2 onions\",\n      \"\",\n      \"Cut the beef into cubes\",\n    ].join(\"\\n\");\n\n    const result = await extractTitleWithEmbeddings(input, embed);\n    expect(result).toBe(\"CHICKEN SOUP + BEEF STEW\");\n  });\n\n  it(\"does not apply corroboration to single-title pages\", async () => {\n    // Corroboration only runs when ≥2 ALL_CAPS candidates are selected.\n    // A single ALL_CAPS title is returned as-is regardless of vocabulary overlap.\n    const embed = createMockEmbed([\"golonka pieczona\"], []);\n    const input = [\n      \"GOLONKA PIECZONA\",\n      \"\",\n      \"Składniki na 4 porcje\",\n      \"1 kg mięsa\",\n      \"2 cebule\",\n      \"3 ząbki czosnku\",\n      \"\",\n      \"Mięso umyć i osuszyć\",\n      \"Cebulę pokroić w plastry\",\n    ].join(\"\\n\");\n\n    const result = await extractTitleWithEmbeddings(input, embed);\n    expect(result).toBe(\"GOLONKA PIECZONA\");\n  });\n  });\n});","numLines":95,"startLine":378,"totalLines":473}}}
