{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01RS8syrrXwSp1dpyXVyUFDS","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01NWBs9n8sSqTBgwHBGu39pZ","name":"Edit","input":{"replace_all":false,"file_path":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/title-extractor.ts","old_string":"  return corroboratedCount / contentWords.length;\n}\n\nfunction isLikelyGarbled","new_string":"  return corroboratedCount / contentWords.length;\n}\n\n/**\n * Returns true if the candidate's vocabulary is sufficiently supported by the rest of\n * the document. Short candidates (≤3 content words) require 100% corroboration;\n * longer candidates require ≥67%.\n */\nfunction passesCorroboration(\n  text: string,\n  position: number,\n  allLines: string[]\n): boolean {\n  const score = corroborationScore(text, position, allLines);\n  const contentWords = text\n    .split(/\\s+/)\n    .filter((w) => w.replace(/[^a-zA-ZÀ-ÿ]/g, \"\").length >= 3);\n  const threshold = contentWords.length <= 3 ? 1.0 : 0.67;\n  return score >= threshold;\n}\n\nfunction isLikelyGarbled"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":3903,"cache_read_input_tokens":43821,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3903},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"85fd2af6-6c55-4da1-a228-07fff6134a1a","uuid":"310b4778-fd67-4580-b7c0-002116a757ba"}
