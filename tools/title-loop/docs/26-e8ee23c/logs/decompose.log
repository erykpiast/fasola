1    // English — recipe-book chapter/category labels\n   162    \"vegetables\", \"seafood\", \"fish\", \"soups\", \"salads\", \"desserts\",\n   163    \"appetizers\", \"breads\", \"breakfast\", \"pasta\", \"grains\",\n   164    \"main courses\", \"side dishes\", \"preserves\", \"baked goods\",\n   165    \"fish & seafood\", \"soups & broths\", \"desserts & baked goods\",\n   166    \"meats\", \"poultry\", \"game\",\n   167  ]);\n```\n\n### `isSectionLabel` function (lines 169–176)\n\n```\n   169  function isSectionLabel(text: string): boolean {\n   170    const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n   171    if (SECTION_LABELS.has(normalized)) return true;\n   172    // OCR variant: leading \"l\" may be OCR-corrupted \"I\" (e.g. \"lngredients\" → \"ingredients\")\n   173    const ocrNormalized = normalized.replace(/^l/, \"i\");\n   174    if (ocrNormalized !== normalized && SECTION_LABELS.has(ocrNormalized)) return true;\n   175    return false;\n   176  }\n```\n\n### `startsWithNumber` function (lines 101–104)\n\n```\n   101  function startsWithNumber(line: string): boolean {\n   102    // Match lines starting with a digit, or bullet-then-digit (e.g., \"- 2 jajka\")\n   103    return /^\\s*(?:[-•*]\\s*)?\\d/.test(line);\n   104  }\n```\n\n### `isTitleAbsentPage` function (lines 338–346)\n\n```\n   338  function isTitleAbsentPage(lines: Array<string>): boolean {\n   339    const nonEmptyLines = lines.map(l => l.trim()).filter(l => l.length > 0);\n   340  \n   341    if (nonEmptyLines.length < 3) return false;\n   342  \n   343    const first3 = nonEmptyLines.slice(0, 3);\n   344  \n   345    return first3.every(line => looksLikeIngredient(line) || looksLikeCookingInstruction(line));\n   346  }\n```\n\n### `passesHardFilters` function (lines 348–389)\n\n```\n   348  function passesHardFilters(text: string): boolean {\n   349    if (text.length < 3 || text.length > 80) return false;\n   350    if (looksLikeIngredient(text)) return false;\n   351    if (startsWithNumber(text)) return false;\n   352    if (looksLikeMetadata(text)) return false;\n   353    if (isLikelyGarbled(text)) return false;\n   354    if (looksLikeCookingInstruction(text)) return false;\n   355    // Pipe-separated lines are book category/chapter headers, not recipe titles\n   356    if (text.includes(\" | \")) return false;\n   357    // Trailing page number (e.g. \"VEGETABLE SIDES                         145\")\n   358    if (/\\s{3,}\\d{1,4}\\s*$/.test(text)) return false;\n   359    // Slash-separated breadcrumbs (e.g., \"/ Jesien / Zupy\") are navigation, not titles\n   360    // Only filter when 2+ slashes are present — single-slash lines like\n   361    // \"TITLE / SUBTITLE\" are legitimate continuation-merged titles\n   362    if ((text.match(/\\//g) || []).length >= 2) return false;\n   363    // Bullet-list items (ingredients or instruction steps) are never titles\n   364    if (/^\\s*[-•*]\\s/.test(text)) return false;\n   365    // \"For the sauce:\", \"For the filling:\" etc. are sub-section headers\n   366    if (/^For the\\s+/i.test(text) && /:\\s*$/.test(text)) return false;\n   367    // Lines ending with \":\" are recipe sub-section headers, not titles.\n   368    // Exception: compound titles using \" : \" as a title separator (e.g. \"LEMON CURD : LEMON CURD WITH THYME\").\n   369    if (/:\\s*$/.test(text.trim()) && !/ : /.test(text)) return false;\n   370    // Page references are navigation markers, not recipe titles\n   371    if (/^Page\\s+\\d+/i.test(text.trim())) return false;\n   372    if (/^Strona\\s+\\d+/i.test(text.trim())) return false;\n   373    // Corrupted spillover annotations from synthetic multi-page OCR\n   374    if (/^\\[CORRUPTED\\s+SPILLOVER/i.test(text.trim())) return false;\n   375    // Parenthetical OCR annotation lines describing corruption artifacts\n   376    if (/^\\(OCR\\b/i.test(text.trim())) return false;\n   377    if (/^\\(.*\\bcorruption\\b/i.test(text.trim())) return false;\n   378    // Square-bracket category tags (e.g., \"[CLASSIC FALL SOUPS]\")\n   379    if (/^\\[.*\\]$/.test(text.trim())) return false;\n   380    // Known recipe section labels are structural headers, not titles\n   381    if (isSectionLabel(text)) return false;\n   382    // Single-word non-title fragments\n   383    const words = text.trim().split(/\\s+/);\n   384    if (words.length === 1 && NON_TITLE_WORDS.has(text.trim().toLowerCase())) return false;\n   385    // Lines with ≥8 words are almost certainly body text, not titles.\n   386    // Exception: multi-title compounds with \" + \", \" : \", or \" & \" separators are allowed.\n   387    if (words.length >= 8 && !/ [+:&/] /.test(text)) return false;\n   388    return true;\n   389  }\n```\n\n### `OVERFLOW_MARKERS` regex and `findBurstEnd` function (lines 395–449)\n\n```\n   395  function findBurstEnd(lines: Array<{ text: string }>): number {\n   396    let i = 0;\n   397  \n   398    // Skip overflow preambles: blocks introduced by \"PREVIOUS RECIPE OVERFLOW\",\n   399    // \"PREVIOUS PAGE CONTENT\", \"CORRUPTED SECTION\", etc. that precede the actual recipe.\n   400    const OVERFLOW_MARKERS = /\\b(PREVIOUS\\s+(RECIPE|PAGE)\\s+(OVERFLOW|CONTENT)|SPILLOVER|CONTINUATION|CORRUPTED\\s+SECTION)\\b/i;\n   401    let overflowEnd = 0;\n   402    for (let k = 0; k < lines.length && k < 30; k++) {\n   403      if (OVERFLOW_MARKERS.test(lines[k].text)) {\n   404        // Skip forward past the overflow block to the next visual separator or blank cluster\n   405        let m = k + 1;\n   406        while (m < lines.length) {\n   407          if (/^[=\\-]{4,}$/.test(lines[m].text) || lines[m].text.length === 0) {\n   408            overflowEnd = m + 1;\n   409            break;\n   410          }\n   411          m++;\n   412        }\n   413        if (overflowEnd === 0) overflowEnd = k + 1;\n   414      }\n   415    }\n   416    if (overflowEnd > 0) i = overflowEnd;\n   417  \n   418    while (i < lines.length && lines[i].text.length < 20 && isLikelyGarbled(lines[i].text) && !isAllCaps(lines[i].text)) {\n   419      i++;\n   420    }\n   421    // Skip long instruction-like prologues: if 5+ consecutive lines look like cooking instructions,\n   422    // skip them to find the actual title region.\n   423    if (i === 0) {\n   424      let j = 0;\n   425      while (j < lines.length && looksLikeCookingInstruction(lines[j].text)) {\n   426        j++;\n   426      }\n   428      if (j >= 5) {\n   429        i = j;\n   430      }\n   431    }\n   432    // Skip prose prologues: mid-recipe body text before the actual title.\n   433    // If 3+ consecutive lines look like running body text (lowercase start, continuation,\n   434    // or sentence-ending with many words), skip them.\n   435    if (i === 0) {\n   436      let j = 0;\n   437      while (j < lines.length) {\n   438        const t = lines[j].text;\n   439        const isBodyText = (\n   440          /^[a-ząćęłńóśźż]/.test(t) ||\n   441          t.endsWith(\",\") ||\n   442          (t.endsWith(\".\") && wordCount(t) > 4)\n   443        ) && wordCount(t) >= 4;\n   444        if (isBodyText) j++;\n   445        else break;\n   446      }\n   447      if (j >= 3) i = j;\n   448    }\n   449    return i;\n```\n\n### Caps-coalescing loop (lines 505–548)\n\n```\n   505  // Pre-merge consecutive short ALL_CAPS lines (OCR-fragmented headings).\n   506  // When a sequence of 2+ ALL_CAPS lines each has ≤2 words and ≤25 chars, they are\n   507  // almost certainly OCR fragments of a single heading. Merge them into one line so\n   508  // the complete title enters the candidate pool without hitting the 3-line join ceiling.\n   509  const capsCoalesced: Array<{ text: string; index: number }> = [];\n   510  let ci = burstEnd;\n   511  while (ci < nonEmptyLines.length) {\n   512    const line = nonEmptyLines[ci];\n   513    if (\n   514      isAllCaps(line.text) &&\n   515      wordCount(line.text) <= 2 &&\n   516      line.text.length <= 25 &&\n   517      !isSectionLabel(line.text) &&\n   518      !looksLikeMetadata(line.text)\n   519    ) {\n   520      let merged = line.text;\n   521      const startIndex = line.index;\n   522      let j = ci + 1;\n   523      while (j < nonEmptyLines.length) {\n   524        const next = nonEmptyLines[j];\n   525        if (\n   526          isAllCaps(next.text) &&\n   527          wordCount(next.text) <= 2 &&\n   528          next.text.length <= 25 &&\n   529          !isSectionLabel(next.text) &&\n   530          !isSectionLabel(repairOcrText(next.text)) &&\n   531          !looksLikeMetadata(next.text) &&\n   532          (merged + \" \" + next.text).length <= 80\n   533        ) {\n   534          merged += \" \" + next.text;\n   535          j++;\n   536        } else {\n   537          break;\n   538        }\n   539      }\n   540      if (j > ci + 1) {\n   541        capsCoalesced.push({ text: merged, index: startIndex });\n   542        ci = j;\n   543        continue;\n   544      }\n   545    }\n   546    capsCoalesced.push(line);\n   547    ci++;\n   548  }\n```\n\n### `repairOcrWord` function (lines 684–715)\n\n```\n   684  /**\n   685   * Attempt to repair a single OCR-corrupted word using dictionary lookup.\n   686   * Returns the repaired word if a dictionary match is found, otherwise returns the original.\n   687   */\n   688  function repairOcrWord(word: string): string {\n   689    if (!OCR_ARTIFACT_PATTERN.test(word)) return word;\n   690  \n   691    const lower = word.toLowerCase();\n   692  \n   693    const positions: Array<{ index: number; replacements: Array<string> }> = [];\n   694    for (let i = 0; i < lower.length; i++) {\n   695      const replacements = OCR_SUBSTITUTIONS[lower[i]];\n   696      if (replacements) {\n   697        positions.push({ index: i, replacements });\n   698      }\n   699    }\n   700  \n   701    if (positions.length === 0 || positions.length > 8) return word;\n   702  \n   703    const candidates = generateSubstitutions(lower, positions, 0);\n   704  \n   705    for (const candidate of candidates) {\n   706      if (FOOD_DICTIONARY.has(candidate)) {\n   707        if (word === word.toUpperCase()) return candidate.toUpperCase();\n   708        if (word[0] === word[0].toUpperCase()) {\n   709          return candidate[0].toUpperCase() + candidate.slice(1);\n   710        }\n   711        return candidate;\n   712      }\n   713    }\n   714  \n   715    return word;\n   716  }\n```\n\n### First-after-preamble bonus (lines 960–977)\n\n```\n   960  // First-after-preamble bonus (Pattern 3): when lines before the first candidate were all\n   961  // filtered/empty, the first surviving candidate occupies the structural \"title position\".\n   962  // E.g. \"FISH & SEAFOOD\\nHalibut with Saffron Cream Sauce\\n...\" — \"FISH & SEAFOOD\" is filtered\n   963  // as a section label, so \"Halibut...\" is the first candidate and gets this boost.\n   964  const firstCandidate = scored[0];\n   965  if (firstCandidate.position > 0) {\n   966    const allPrecedingFiltered = lines\n   967      .slice(0, firstCandidate.position)\n   968      .every((line) => {\n   969        const trimmed = line.trim();\n   970        return trimmed === \"\" || !passesHardFilters(trimmed);\n   971      });\n   972    if (allPrecedingFiltered) {\n   973      firstCandidate.score += 0.08;\n   974      firstCandidate.baseScore += 0.08;\n   975      firstCandidate.thresholdScore += 0.08;\n   976    }\n   977  }\n```"}],"totalDurationMs":120992,"totalTokens":26661,"totalToolUseCount":9,"usage":{"input_tokens":1,"cache_creation_input_tokens":2304,"cache_read_input_tokens":16852,"output_tokens":7504,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":2304},"inference_geo":"","iterations":[],"speed":"standard"}}}
