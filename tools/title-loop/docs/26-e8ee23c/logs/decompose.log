{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VmZxRsxiVWnqDG76sgnhi6","type":"tool_result","content":"     1→/**\n     2→ * Title Extraction\n     3→ * Extracts potential recipe title from OCR text using heuristics or semantic embeddings\n     4→ */\n     5→\n     6→import { cosineSimilarity } from \"./embeddings\";\n     7→import { FOOD_DICTIONARY } from \"./food-dictionary\";\n     8→\n     9→export type EmbedFn = (text: string) => Promise<Array<number>>;\n    10→\n    11→const TITLE_REFERENCE =\n    12→  \"recipe name, dish title, name of the food, nazwa przepisu, nazwa dania\";\n    13→const HEADER_REFERENCE =\n    14→  \"ingredients list, cooking directions, section heading, składniki, przygotowanie, sposób wykonania\";\n    15→const NOISE_REFERENCE =\n    16→  \"page number, table of contents, book footer, garbled text\";\n    17→\n    18→/**\n    19→ * Measurement units commonly found in ingredient lists\n    20→ */\n    21→const MEASUREMENT_PATTERNS = [\n    22→  // English\n    23→  \"cup\",\n    24→  \"cups\",\n    25→  \"tbsp\",\n    26→  \"tsp\",\n    27→  \"tablespoon\",\n    28→  \"teaspoon\",\n    29→  // \"oz\" and \"lb\" are matched with word boundaries in looksLikeIngredient\n    30→  // to avoid false positives (\"oz\" in \"mozzarella\", \"lb\" in \"albacore\")\n    31→  \"gram\",\n    32→  \"grams\",\n    33→  \"kg\",\n    34→  \"ml\",\n    35→  \"liter\",\n    36→  \"pinch\",\n    37→  \"dash\",\n    38→  \"handful\",\n    39→  // Polish\n    40→  \"łyżka\", \"łyżki\", \"łyżek\",           // tablespoon(s)\n    41→  \"łyżeczka\", \"łyżeczki\", \"łyżeczek\",   // teaspoon(s)\n    42→  \"szklanka\", \"szklanki\", \"szklanek\",    // cup(s)\n    43→  \"szczypta\",                            // pinch\n    44→  \"garść\",                               // handful\n    45→  \"opakowanie\", \"opakowania\",            // package(s)\n    46→  \"plasterek\", \"plasterki\",             // slice(s)\n    47→];\n    48→\n    49→/**\n    50→ * Patterns that identify recipe metadata lines (not titles)\n    51→ */\n    52→const METADATA_PATTERNS = [\n    53→  /^(SERVES?|MAKES?|YIELDS?)\\b/i,\n    54→  /^(PREP(ARATION)?|COOK(ING)?|PROOF|RISING|FERMENTATION|REST(ING)?)\\s*(AND\\s*)?(COOK(ING)?)?\\s*TIME/i,\n    55→  /^SAMPLE\\s+SCHEDULE\\b/i,\n    56→  /^BULK\\s+FERMENTATION\\b/i,\n    57→  /^(THIS\\s+RECIPE\\s+)?MAKES\\b/i,\n    58→  // Polish serving-size patterns: \"NA 3 PAPRYKI\", \"NA OKOŁO 1 KG\", \"DLA 4 OSÓB\"\n    59→  /^NA\\s+(\\d|OKOŁO)\\b/i,\n    60→  /^DLA\\s+\\d/i,\n    61→  // OCR-resilient: \"DLA\" + any token + serving-unit word (handles DLA & OSOB, DLA § OSOB, etc.)\n    62→  /^DLA\\s+\\S+\\s+OSOB/i,\n    63→  // OCR-resilient: \"DLA\" + single non-alphanumeric char (common digit→symbol OCR error)\n    64→  /^DLA\\s+[^a-zA-Z0-9\\s]\\s/i,\n    65→  // Time-unit metadata: any line containing \"N MIN\" or \"N GODZ\" is prep/cook/rest time,\n    66→  // regardless of OCR-corrupted prefix (catches PRZYGOTOWANTE, GOTOMANTE, etc.)\n    67→  /\\b\\d+\\s*MIN\\b/i,\n    68→  /\\b\\d+\\s*GODZ/i,\n    69→  // Season/category indicators\n    70→  /^SEZON\\s*:/i,\n    71→  /^KATEGORIA\\s*:/i,\n    72→  /^RODZAJ\\s*:/i,\n    73→  /^PORCJI\\s*:/i,       // Polish serving count\n    74→  /^PORTIONS?\\s*:/i,    // English serving count\n    75→  /^CZ[ĘE]Ś[ĆC]\\s*\\d/i,   // CZĘŚĆ 1: ... (Polish \"Part 1:\")\n    76→  /^PART\\s+\\d/i,             // PART 1: ... (English)\n    77→  /^MAIN\\s+RECIPE\\s*:/i,    // \"MAIN RECIPE: ...\" structural prefix lines\n    78→  /^--\\s*\\w/,               // \"--VARIATION:\", \"--WERSJA NOWOCZESNA\" sub-section headers\n    79→];\n    80→\n    81→/**\n    82→ * Single-word non-title words — standalone OCR fragments unlikely to be recipe titles\n    83→ */\n    84→const NON_TITLE_WORDS = new Set([\n    85→  \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"are\", \"was\",\n    86→  \"has\", \"his\", \"her\", \"its\", \"our\", \"who\", \"how\", \"may\", \"new\", \"now\",\n    87→  \"old\", \"see\", \"way\", \"did\", \"get\", \"let\", \"say\", \"she\", \"too\", \"use\",\n    88→  \"buns\", \"with\",\n    89→]);\n    90→\n    91→function looksLikeIngredient(line: string): boolean {\n    92→  const lowerLine = line.toLowerCase();\n    93→  if (MEASUREMENT_PATTERNS.some((pattern) => lowerLine.includes(pattern))) return true;\n    94→  // Compact metric: \"100g\", \"50ml\", \"250g\" — digit immediately followed by g/ml/kg\n    95→  if (/\\b\\d+\\s*(?:g|ml|kg)\\b/i.test(line)) return true;\n    96→  // \"to taste\" / \"do smaku\" — qualitative ingredient with no unit\n    97→  if (/\\bto taste\\b/i.test(line) || /\\bdo smaku\\b/i.test(line)) return true;\n    98→  return false;\n    99→}\n   100→\n   101→function startsWithNumber(line: string): boolean {\n   102→  // Match lines starting with a digit, or bullet-then-digit (e.g., \"- 2 jajka\")\n   103→  return /^\\s*(?:[-•*]\\s*)?\\d/.test(line);\n   104→}\n   105→\n   106→function stripDiacritics(text: string): string {\n   107→  return text.normalize(\"NFKD\").replace(/[\\u0300-\\u036f]/g, \"\");\n   108→}\n   109→\n   110→/**\n   111→ * Known recipe section labels — these are structural headers, not recipe titles.\n   112→ * Matched case-insensitively after trimming, stripping trailing punctuation, and stripping diacritics.\n   113→ * Polish entries are stored without diacritics for OCR resilience (e.g. \"SKLADNIKI\" matches \"składniki\").\n   114→ */\n   115→const SECTION_LABELS = new Set([\n   116→  // English\n   117→  \"ingredients\", \"directions\", \"instructions\", \"method\", \"preparation\",\n   118→  \"steps\", \"notes\", \"tip\", \"tips\", \"variations\", \"variation\",\n   119→  \"garnish\", \"topping\", \"toppings\", \"frosting\", \"filling\",\n   120→  \"serving suggestion\", \"serving suggestions\", \"serving\",\n   121→  \"glaze\", \"for the sauce\", \"for the filling\", \"for the dough\",\n   122→  \"for the topping\", \"for the glaze\", \"for the pasta dough\",\n   123→  \"for the pasta\", \"for the crust\",\n   124→  // Polish — recipe section labels (stored without diacritics for OCR resilience)\n   125→  \"skladniki\", \"przygotowanie\", \"sposob przygotowania\", \"sposob wykonania\",\n   126→  \"wykonanie\", \"wskazowki\", \"podpowiedz\", \"warianty\",\n   127→  \"sos\", \"nadzienie\", \"polewa\", \"lukier\", \"ciasto\",  // ciasto = dough/pastry base (recipe-internal section AND chapter label)\n   128→  \"instrukcje\",       // instructions\n   129→  \"uwagi\",            // notes/remarks\n   130→  \"notatki\",          // notes"}]},"parent_tool_use_id":"toolu_01JaDnF4qj57zraQmGUntama","session_id":"45df4770-9767-477d-a65f-eaa50cfc39f0","uuid":"f44813ec-c5c3-44b1-bf31-e51a9dec85c5"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01R1MNtZ18RPLjbNBynC6P7k","type":"tool_result","content":"   330→  if (POLISH_COOKING_INSTRUCTION_STARTS.test(text.trim())) return true;\n   331→  return false;\n   332→}\n   333→\n   334→/**\n   335→ * Detect pages where the OCR capture starts mid-recipe with no title present.\n   336→ * Returns true if the first 3 non-empty lines are all ingredients or cooking instructions.\n   337→ */\n   338→function isTitleAbsentPage(lines: Array<string>): boolean {\n   339→  const nonEmptyLines = lines.map(l => l.trim()).filter(l => l.length > 0);\n   340→\n   341→  if (nonEmptyLines.length < 3) return false;\n   342→\n   343→  const first3 = nonEmptyLines.slice(0, 3);\n   344→\n   345→  return first3.every(line => looksLikeIngredient(line) || looksLikeCookingInstruction(line));\n   346→}\n   347→\n   348→function passesHardFilters(text: string): boolean {\n   349→  if (text.length < 3 || text.length > 80) return false;\n   350→  if (looksLikeIngredient(text)) return false;\n   351→  if (startsWithNumber(text)) return false;\n   352→  if (looksLikeMetadata(text)) return false;\n   353→  if (isLikelyGarbled(text)) return false;\n   354→  if (looksLikeCookingInstruction(text)) return false;\n   355→  // Pipe-separated lines are book category/chapter headers, not recipe titles\n   356→  if (text.includes(\" | \")) return false;\n   357→  // Trailing page number (e.g. \"VEGETABLE SIDES                         145\")\n   358→  if (/\\s{3,}\\d{1,4}\\s*$/.test(text)) return false;\n   359→  // Slash-separated breadcrumbs (e.g., \"/ Jesien / Zupy\") are navigation, not titles\n   360→  // Only filter when 2+ slashes are present — single-slash lines like\n   361→  // \"TITLE / SUBTITLE\" are legitimate continuation-merged titles\n   362→  if ((text.match(/\\//g) || []).length >= 2) return false;\n   363→  // Bullet-list items (ingredients or instruction steps) are never titles\n   364→  if (/^\\s*[-•*]\\s/.test(text)) return false;\n   365→  // \"For the sauce:\", \"For the filling:\" etc. are sub-section headers\n   366→  if (/^For the\\s+/i.test(text) && /:\\s*$/.test(text)) return false;\n   367→  // Lines ending with \":\" are recipe sub-section headers, not titles.\n   368→  // Exception: compound titles using \" : \" as a title separator (e.g. \"LEMON CURD : LEMON CURD WITH THYME\").\n   369→  if (/:\\s*$/.test(text.trim()) && !/ : /.test(text)) return false;\n   370→  // Page references are navigation markers, not recipe titles\n   371→  if (/^Page\\s+\\d+/i.test(text.trim())) return false;\n   372→  if (/^Strona\\s+\\d+/i.test(text.trim())) return false;\n   373→  // Corrupted spillover annotations from synthetic multi-page OCR\n   374→  if (/^\\[CORRUPTED\\s+SPILLOVER/i.test(text.trim())) return false;\n   375→  // Parenthetical OCR annotation lines describing corruption artifacts\n   376→  if (/^\\(OCR\\b/i.test(text.trim())) return false;\n   377→  if (/^\\(.*\\bcorruption\\b/i.test(text.trim())) return false;\n   378→  // Square-bracket category tags (e.g., \"[CLASSIC FALL SOUPS]\")\n   379→  if (/^\\[.*\\]$/.test(text.trim())) return false;\n   380→  // Known recipe section labels are structural headers, not titles\n   381→  if (isSectionLabel(text)) return false;\n   382→  // Single-word non-title fragments\n   383→  const words = text.trim().split(/\\s+/);\n   384→  if (words.length === 1 && NON_TITLE_WORDS.has(text.trim().toLowerCase())) return false;\n   385→  // Lines with ≥8 words are almost certainly body text, not titles.\n   386→  // Exception: multi-title compounds with \" + \", \" : \", or \" & \" separators are allowed.\n   387→  if (words.length >= 8 && !/ [+:&/] /.test(text)) return false;\n   388→  return true;\n   389→}\n   390→\n   391→/**\n   392→ * Detect initial burst of short garbled lines.\n   393→ * Returns the index of the first non-garbled or long line.\n   394→ */\n   395→function findBurstEnd(lines: Array<{ text: string }>): number {\n   396→  let i = 0;\n   397→\n   398→  // Skip overflow preambles: blocks introduced by \"PREVIOUS RECIPE OVERFLOW\",\n   399→  // \"PREVIOUS PAGE CONTENT\", \"CORRUPTED SECTION\", etc. that precede the actual recipe.\n   400→  const OVERFLOW_MARKERS = /\\b(PREVIOUS\\s+(RECIPE|PAGE)\\s+(OVERFLOW|CONTENT)|SPILLOVER|CONTINUATION|CORRUPTED\\s+SECTION)\\b/i;\n   401→  let overflowEnd = 0;\n   402→  for (let k = 0; k < lines.length && k < 30; k++) {\n   403→    if (OVERFLOW_MARKERS.test(lines[k].text)) {\n   404→      // Skip forward past the overflow block to the next visual separator or blank cluster\n   405→      let m = k + 1;\n   406→      while (m < lines.length) {\n   407→        if (/^[=\\-]{4,}$/.test(lines[m].text) || lines[m].text.length === 0) {\n   408→          overflowEnd = m + 1;\n   409→          break;"}]},"parent_tool_use_id":"toolu_01JaDnF4qj57zraQmGUntama","session_id":"45df4770-9767-477d-a65f-eaa50cfc39f0","uuid":"2c32b46e-1735-4143-85b4-ec9cabefce18"}
