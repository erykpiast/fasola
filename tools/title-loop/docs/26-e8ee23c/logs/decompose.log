{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Ficnk9SzJ2YMYDxjXeJ21o","type":"tool_result","content":"     1→/**\n     2→ * ~500 common English and Polish food/cooking words for OCR repair.\n     3→ * Words are lowercase, without diacritics (OCR-resilient matching).\n     4→ * Used by repairOcrWord() to resolve ambiguous digit→letter substitutions.\n     5→ */\n     6→export const FOOD_DICTIONARY: Set<string> = new Set([\n     7→  // ── English ingredients ──────────────────────────────────────────────────\n     8→  \"chicken\", \"beef\", \"pork\", \"lamb\", \"veal\", \"duck\", \"turkey\", \"venison\",\n     9→  \"salmon\", \"cod\", \"halibut\", \"tuna\", \"trout\", \"sardine\", \"anchovy\",\n    10→  \"shrimp\", \"prawn\", \"lobster\", \"crab\", \"scallop\", \"mussel\", \"clam\",\n    11→  \"tofu\", \"tempeh\", \"seitan\",\n    12→\n    13→  // Grains & starches\n    14→  \"rice\", \"pasta\", \"bread\", \"noodle\", \"flour\", \"oat\", \"barley\", \"wheat\",\n    15→  \"rye\", \"quinoa\", \"corn\", \"cornmeal\", \"semolina\", \"couscous\", \"polenta\",\n    16→  \"buckwheat\", \"millet\",\n    17→\n    18→  // Dairy & eggs\n    19→  \"butter\", \"cream\", \"cheese\", \"milk\", \"egg\", \"yogurt\", \"ghee\",\n    20→  \"ricotta\", \"mozzarella\", \"parmesan\", \"cheddar\", \"brie\", \"feta\",\n    21→\n    22→  // Fats & condiments\n    23→  \"oil\", \"vinegar\", \"mustard\", \"ketchup\", \"mayo\", \"mayonnaise\",\n    24→  \"soy\", \"sauce\", \"paste\", \"stock\", \"broth\", \"gravy\",\n    25→\n    26→  // Vegetables\n    27→  \"garlic\", \"onion\", \"tomato\", \"potato\", \"carrot\", \"celery\", \"pepper\",\n    28→  \"broccoli\", \"cauliflower\", \"asparagus\", \"artichoke\", \"eggplant\",\n    29→  \"zucchini\", \"squash\", \"pumpkin\", \"cucumber\", \"radish\", \"turnip\",\n    30→  \"beet\", \"mushroom\", \"avocado\", \"olive\", \"bean\", \"lentil\", \"chickpea\",\n    31→  \"arugula\", \"spinach\", \"kale\", \"lettuce\", \"cabbage\", \"leek\", \"fennel\",\n    32→  \"chard\", \"endive\", \"watercress\", \"sprout\", \"pea\", \"edamame\",\n    33→  \"scallion\", \"shallot\", \"chili\", \"jalapeno\", \"poblano\", \"serrano\",\n    34→  \"brukselka\",\n    35→\n    36→  // Fruits\n    37→  \"lemon\", \"lime\", \"orange\", \"apple\", \"berry\", \"blackberry\", \"blueberry\",\n    38→  \"raspberry\", \"strawberry\", \"cherry\", \"peach\", \"pear\", \"plum\", \"grape\",\n    39→  \"banana\", \"mango\", \"pineapple\", \"coconut\", \"fig\", \"date\", \"apricot\",\n    40→  \"pomegranate\", \"melon\", \"watermelon\", \"grapefruit\", \"papaya\", \"kiwi\",\n    41→  \"passion\", \"guava\", \"lychee\",\n    42→\n    43→  // Nuts & seeds\n    44→  \"almond\", \"walnut\", \"pecan\", \"cashew\", \"pistachio\", \"hazelnut\",\n    45→  \"peanut\", \"sesame\", \"flaxseed\", \"chia\", \"sunflower\", \"pumpkinseed\",\n    46→  \"poppy\",\n    47→\n    48→  // Spices & herbs\n    49→  \"ginger\", \"cinnamon\", \"cumin\", \"paprika\", \"turmeric\", \"oregano\",\n    50→  \"basil\", \"thyme\", \"rosemary\", \"parsley\", \"cilantro\", \"dill\", \"mint\",\n    51→  \"sage\", \"chive\", \"tarragon\", \"nutmeg\", \"clove\", \"cardamom\", \"saffron\",\n    52→  \"vanilla\", \"anise\", \"coriander\", \"bay\", \"marjoram\", \"chervil\",\n    53→  \"fenugreek\", \"sumac\", \"caraway\", \"allspice\",\n    54→\n    55→  // Sweeteners & flavourings\n    56→  \"chocolate\", \"cocoa\", \"honey\", \"maple\", \"molasses\", \"sugar\", \"salt\",\n    57→  \"yeast\", \"baking\", \"powder\", \"soda\",\n    58→\n    59→  // Common recipe adjectives / descriptors\n    60→  \"white\", \"red\", \"green\", \"black\", \"brown\", \"sweet\", \"sour\", \"hot\",\n    61→  \"cold\", \"fresh\", \"dried\", \"whole\", \"ground\", \"roasted\", \"grilled\",\n    62→  \"braised\", \"baked\", \"fried\", \"steamed\", \"smoked\", \"stuffed\", \"glazed\",\n    63→  \"caramelized\", \"pickled\", \"fermented\", \"cured\", \"raw\", \"cooked\",\n    64→  \"crispy\", \"tender\", \"spicy\", \"savory\", \"creamy\", \"crunchy\", \"tangy\",\n    65→  \"herb\", \"herbed\", \"seasoned\", \"marinated\",\n    66→\n    67→  // Cooking terms / verbs\n    68→  \"bake\", \"roast\", \"grill\", \"fry\", \"saute\", \"braise\", \"simmer\", \"boil\",\n    69→  \"steam\", \"poach\", \"broil\", \"smoke\", \"cure\", \"pickle\", \"ferment\",\n    70→  \"blanch\", \"reduce\", \"deglaze\", \"emulsify\", \"whisk\", \"knead\", \"fold\",\n    71→  \"chop\", \"dice\", \"mince\", \"slice\", \"julienne\", \"marinate\", \"season\",\n    72→  \"glaze\", \"caramelize\", \"sear\", \"flambe\", \"infuse\", \"steep\", \"toast\",\n    73→  \"blend\", \"puree\", \"strain\", \"press\", \"squeeze\", \"drizzle\", \"toss\",\n    74→  \"stir\", \"mix\", \"beat\", \"cream\", \"sift\", \"coat\", \"dredge\", \"bread\",\n    75→\n    76→  // Dish types\n    77→  \"salad\", \"soup\", \"stew\", \"casserole\", \"risotto\", \"curry\", \"pie\",\n    78→  \"tart\", \"cake\", \"cookie\", \"brownie\", \"muffin\", \"scone\", \"pancake\",\n    79→  \"waffle\", \"crepe\", \"quiche\", \"frittata\", \"omelette\", \"sandwich\",\n    80→  \"wrap\", \"burger\", \"pizza\", \"dumpling\", \"pierogi\", \"sushi\", \"taco\",\n    81→  \"burrito\", \"enchilada\", \"chowder\", \"bisque\", \"broth\", \"consomme\",\n    82→  \"terrine\", \"pate\", \"mousse\", \"souffle\", \"galette\", \"clafoutis\",\n    83→  \"cobbler\", \"crumble\", \"pudding\", \"custard\", \"parfait\", \"tiramisu\",\n    84→  \"cheesecake\", \"torte\", \"trifle\", \"fool\", \"compote\", \"sorbet\",\n    85→  \"gelato\", \"icecream\", \"meringue\", \"macaron\",\n    86→\n    87→  // Wine & drinks that appear in recipes\n    88→  \"wine\", \"beer\", \"cider\", \"brandy\", \"rum\", \"vodka\", \"gin\", \"whiskey\",\n    89→  \"vermouth\", \"sherry\", \"port\", \"mirin\", \"sake\", \"tea\", \"coffee\",\n    90→  \"juice\",\n    91→\n    92→  // ── Polish ingredients (without diacritics) ───────────────────────────────\n    93→  \"kurczak\", \"wolowina\", \"wieprzowina\", \"cielecina\", \"golonka\",\n    94→  \"losos\", \"dorsz\", \"krewetki\", \"ryz\", \"makaron\", \"chleb\", \"maslo\",\n    95→  \"smietana\", \"ser\", \"czosnek\", \"cebula\", \"pomidor\", \"ziemniak\",\n    96→  \"marchew\", \"seler\", \"pieprz\", \"sol\", \"cukier\", \"maka\", \"jajko\",\n    97→  \"mleko\", \"olej\", \"ocet\", \"cytryna\", \"pomarancza\", \"jablko\", \"jagoda\",\n    98→  \"malina\", \"truskawka\", \"wisnia\", \"brzoskwinia\", \"gruszka\", \"sliwka\",\n    99→  \"winogrono\", \"banan\", \"orzech\", \"migdal\", \"imbir\", \"cynamon\",\n   100→  \"kminek\", \"papryka\", \"kurkuma\", \"oregano\", \"bazylia\", \"tymianek\",\n   101→  \"rozmaryn\", \"pietruszka\", \"kolendra\", \"koperek\", \"mieta\", \"szalwia\",\n   102→  \"szpinak\", \"kapusta\", \"kalafior\", \"szparag\", \"baklazan\", \"cukinia\",\n   103→  \"dynia\", \"ogorek\", \"rzodkiewka\", \"burak\", \"grzyb\", \"awokado\",\n   104→  \"oliwka\", \"fasola\", \"soczewica\", \"ciecierzyca\", \"kasza\", \"owies\",\n   105→  \"jeczmien\", \"pszenica\", \"zyto\",\n   106→\n   107→  // Polish bread varieties\n   108→  \"pszenny\", \"razowy\", \"zytni\", \"wieloziarnisty\", \"tostowy\",\n   109→\n   110→  // Polish cooking terms (without diacritics)\n   111→  \"piec\", \"smazyc\", \"grillowac\", \"gotowac\", \"dusic\", \"blanszowac\",\n   112→  \"kroic\", \"siekac\", \"marynowac\", \"przyprawiac\", \"karmelizowac\",\n   113→  \"podsmaz\", \"zapiekac\", \"gotowac\", \"dusic\", \"wedzic\", \"kisic\",\n   114→\n   115→  // Polish dishes\n   116→  \"bigos\", \"zurek\", \"barszcz\", \"rosol\", \"kotlet\", \"schabowy\",\n   117→  \"golabki\", \"placki\", \"nalesniki\", \"piernik\", \"sernik\", \"makowiec\",\n   118→  \"babka\", \"chalka\", \"rogal\", \"paczek\", \"faworki\", \"kluski\",\n   119→  \"kopytka\", \"pyzy\", \"uszka\", \"gzik\", \"flaczki\", \"zrazy\", \"gulasz\",\n   120→  \"leczo\", \"kapusniak\", \"grochowka\", \"krupnik\", \"zupa\", \"sałatka\",\n   121→  \"salatka\", \"mizeria\", \"surowka\",\n   122→\n   123→  // Polish ingredient descriptors (without diacritics)\n   124→  \"swiezy\", \"suszony\", \"marynowany\", \"wegdzony\", \"pieczony\", \"gotowany\",\n   125→  \"smazony\", \"surowy\", \"mrożony\", \"mrozony\", \"konserwowy\",\n   126→  \"ziemniaczane\", \"ziemniaczany\",\n   127→\n   128→  // Polish section labels (appear in recipe texts, useful for context)\n   129→  \"skladniki\", \"przygotowanie\", \"sposob\", \"wykonanie\", \"porcje\",\n   130→  \"czas\", \"temperatura\", \"pieczenia\",\n   131→]);\n   132→"}]},"parent_tool_use_id":"toolu_01JaDnF4qj57zraQmGUntama","session_id":"45df4770-9767-477d-a65f-eaa50cfc39f0","uuid":"71428fbe-ee76-4228-887f-c0b6be985fda"}
