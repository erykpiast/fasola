{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017f4x8jRjQKsPuoC4xSXvjU","type":"tool_result","content":"   684→ * Attempt to repair a single OCR-corrupted word using dictionary lookup.\n   685→ * Returns the repaired word if a dictionary match is found, otherwise returns the original.\n   686→ */\n   687→function repairOcrWord(word: string): string {\n   688→  if (!OCR_ARTIFACT_PATTERN.test(word)) return word;\n   689→\n   690→  const lower = word.toLowerCase();\n   691→\n   692→  const positions: Array<{ index: number; replacements: Array<string> }> = [];\n   693→  for (let i = 0; i < lower.length; i++) {\n   694→    const replacements = OCR_SUBSTITUTIONS[lower[i]];\n   695→    if (replacements) {\n   696→      positions.push({ index: i, replacements });\n   697→    }\n   698→  }\n   699→\n   700→  if (positions.length === 0 || positions.length > 8) return word;\n   701→\n   702→  const candidates = generateSubstitutions(lower, positions, 0);\n   703→\n   704→  for (const candidate of candidates) {\n   705→    if (FOOD_DICTIONARY.has(candidate)) {\n   706→      if (word === word.toUpperCase()) return candidate.toUpperCase();\n   707→      if (word[0] === word[0].toUpperCase()) {\n   708→        return candidate[0].toUpperCase() + candidate.slice(1);\n   709→      }\n   710→      return candidate;\n   711→    }\n   712→  }\n   713→\n   714→  return word;\n   715→}\n   716→\n   717→/**\n   718→ * Recursively generate all substitution variants for OCR artifact positions.\n   719→ */\n   720→function generateSubstitutions(\n   721→  base: string,\n   722→  positions: Array<{ index: number; replacements: Array<string> }>,\n   723→  posIdx: number,\n   724→): Array<string> {\n   725→  if (posIdx >= positions.length) return [base];\n   726→\n   727→  const { index, replacements } = positions[posIdx];\n   728→  const results: Array<string> = [];\n   729→\n   730→  for (const replacement of replacements) {\n   731→    const variant = base.slice(0, index) + replacement + base.slice(index + 1);\n   732→    results.push(...generateSubstitutions(variant, positions, posIdx + 1));\n   733→  }\n   734→\n   735→  return results;\n   736→}\n   737→\n   738→/**\n   739→ * Apply dictionary-guided OCR repair to all words in a text string.\n   740→ */\n   741→function repairOcrText(text: string): string {\n   742→  return text\n   743→    .split(/\\s+/)\n   744→    .map((word) => {\n   745→      const match = word.match(/^([^a-zA-Z0-9À-ÿ]*)(.*?)([^a-zA-Z0-9À-ÿ]*)$/);\n   746→      if (!match) return word;\n   747→      const [, prefix, core, suffix] = match;\n   748→      if (!core) return word;"}]},"parent_tool_use_id":"toolu_01JaDnF4qj57zraQmGUntama","session_id":"45df4770-9767-477d-a65f-eaa50cfc39f0","uuid":"40b76ebb-001b-4852-a553-8a6060d4507d"}
