{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CQXvM5kR3jxGeV92R4xFA8","type":"tool_result","content":"   160→  \"koktajle\",         // cocktails/smoothies\n   161→  // English — recipe-book chapter/category labels\n   162→  \"vegetables\", \"seafood\", \"fish\", \"soups\", \"salads\", \"desserts\",\n   163→  \"appetizers\", \"breads\", \"breakfast\", \"pasta\", \"grains\",\n   164→  \"main courses\", \"side dishes\", \"preserves\", \"baked goods\",\n   165→  \"fish & seafood\", \"soups & broths\", \"desserts & baked goods\",\n   166→  \"meats\", \"poultry\", \"game\",\n   167→]);\n   168→\n   169→/**\n   170→ * Subset of SECTION_LABELS that are food-group/chapter labels (not structural process labels).\n   171→ * These may appear as the last word of a compound recipe title (e.g. \"LEMON HERB ROASTED VEGETABLES\").\n   172→ */\n   173→const CATEGORY_SECTION_LABELS = new Set([\n   174→  // English food categories\n   175→  \"vegetables\", \"seafood\", \"fish\", \"soups\", \"salads\", \"desserts\",\n   176→  \"appetizers\", \"breads\", \"breakfast\", \"pasta\", \"grains\",\n   177→  \"meats\", \"poultry\", \"game\",\n   178→  // Polish food categories\n   179→  \"warzywa\", \"mieso\", \"miesa\", \"ryby\", \"zupy\", \"salatki\", \"desery\",\n   180→  \"napoje\", \"pieczywo\", \"przekaski\", \"sniadania\", \"obiady\", \"kolacje\",\n   181→  \"makarony\", \"kasza\", \"kasze\", \"przystawki\", \"dodatki\", \"wypieki\",\n   182→  \"ciasta\", \"ciastka\", \"torty\", \"koktajle\",\n   183→]);\n   184→\n   185→function isCategorySectionLabel(text: string): boolean {\n   186→  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n   187→  return CATEGORY_SECTION_LABELS.has(normalized);\n   188→}\n   189→\n   190→function isSectionLabel(text: string): boolean {\n   191→  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n   192→  if (SECTION_LABELS.has(normalized)) return true;\n   193→  // OCR variant: leading \"l\" may be OCR-corrupted \"I\" (e.g. \"lngredients\" → \"ingredients\")\n   194→  const ocrNormalized = normalized.replace(/^l/, \"i\");\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"6746208e-9db7-45b5-89d0-a33b9f6b28a6","uuid":"f1edf75a-5ff0-4f50-b740-72472612fa1d","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/title-extractor.ts","content":"  \"koktajle\",         // cocktails/smoothies\n  // English — recipe-book chapter/category labels\n  \"vegetables\", \"seafood\", \"fish\", \"soups\", \"salads\", \"desserts\",\n  \"appetizers\", \"breads\", \"breakfast\", \"pasta\", \"grains\",\n  \"main courses\", \"side dishes\", \"preserves\", \"baked goods\",\n  \"fish & seafood\", \"soups & broths\", \"desserts & baked goods\",\n  \"meats\", \"poultry\", \"game\",\n]);\n\n/**\n * Subset of SECTION_LABELS that are food-group/chapter labels (not structural process labels).\n * These may appear as the last word of a compound recipe title (e.g. \"LEMON HERB ROASTED VEGETABLES\").\n */\nconst CATEGORY_SECTION_LABELS = new Set([\n  // English food categories\n  \"vegetables\", \"seafood\", \"fish\", \"soups\", \"salads\", \"desserts\",\n  \"appetizers\", \"breads\", \"breakfast\", \"pasta\", \"grains\",\n  \"meats\", \"poultry\", \"game\",\n  // Polish food categories\n  \"warzywa\", \"mieso\", \"miesa\", \"ryby\", \"zupy\", \"salatki\", \"desery\",\n  \"napoje\", \"pieczywo\", \"przekaski\", \"sniadania\", \"obiady\", \"kolacje\",\n  \"makarony\", \"kasza\", \"kasze\", \"przystawki\", \"dodatki\", \"wypieki\",\n  \"ciasta\", \"ciastka\", \"torty\", \"koktajle\",\n]);\n\nfunction isCategorySectionLabel(text: string): boolean {\n  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n  return CATEGORY_SECTION_LABELS.has(normalized);\n}\n\nfunction isSectionLabel(text: string): boolean {\n  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n  if (SECTION_LABELS.has(normalized)) return true;\n  // OCR variant: leading \"l\" may be OCR-corrupted \"I\" (e.g. \"lngredients\" → \"ingredients\")\n  const ocrNormalized = normalized.replace(/^l/, \"i\");","numLines":35,"startLine":160,"totalLines":1458}}}
