{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Le4MhTenurLgoYTjMPUXrL","type":"tool_result","content":"   380→  // Slash-separated breadcrumbs (e.g., \"/ Jesien / Zupy\") are navigation, not titles\n   381→  // Only filter when 2+ slashes are present — single-slash lines like\n   382→  // \"TITLE / SUBTITLE\" are legitimate continuation-merged titles\n   383→  if ((text.match(/\\//g) || []).length >= 2) return false;\n   384→  // Bullet-list items (ingredients or instruction steps) are never titles\n   385→  if (/^\\s*[-•*]\\s/.test(text)) return false;\n   386→  // \"For the sauce:\", \"For the filling:\" etc. are sub-section headers\n   387→  if (/^For the\\s+/i.test(text) && /:\\s*$/.test(text)) return false;\n   388→  // Lines ending with \":\" are recipe sub-section headers, not titles.\n   389→  // Exception: compound titles using \" : \" as a title separator (e.g. \"LEMON CURD : LEMON CURD WITH THYME\").\n   390→  if (/:\\s*$/.test(text.trim()) && !/ : /.test(text)) return false;\n   391→  // Page references are navigation markers, not recipe titles\n   392→  if (/^Page\\s+\\d+/i.test(text.trim())) return false;\n   393→  if (/^Strona\\s+\\d+/i.test(text.trim())) return false;\n   394→  // Corrupted spillover annotations from synthetic multi-page OCR\n   395→  if (/^\\[CORRUPTED\\s+SPILLOVER/i.test(text.trim())) return false;\n   396→  // Parenthetical OCR annotation lines describing corruption artifacts\n   397→  if (/^\\(OCR\\b/i.test(text.trim())) return false;\n   398→  if (/^\\(.*\\bcorruption\\b/i.test(text.trim())) return false;\n   399→  // Square-bracket category tags (e.g., \"[CLASSIC FALL SOUPS]\")\n   400→  if (/^\\[.*\\]$/.test(text.trim())) return false;\n   401→  // Known recipe section labels are structural headers, not titles\n   402→  if (isSectionLabel(text)) return false;\n   403→  // Single-word non-title fragments\n   404→  const words = text.trim().split(/\\s+/);\n   405→  if (words.length === 1 && NON_TITLE_WORDS.has(text.trim().toLowerCase())) return false;\n   406→  // Lines with ≥8 words are almost certainly body text, not titles.\n   407→  // Exception: multi-title compounds with \" + \", \" : \", or \" & \" separators are allowed.\n   408→  if (words.length >= 8 && !/ [+:&/] /.test(text)) return false;\n   409→  return true;\n   410→}\n   411→\n   412→/**\n   413→ * Detect initial burst of short garbled lines.\n   414→ * Returns the index of the first non-garbled or long line.\n   415→ */\n   416→function findBurstEnd(lines: Array<{ text: string }>): number {\n   417→  let i = 0;\n   418→\n   419→  // Skip overflow preambles: blocks introduced by \"PREVIOUS RECIPE OVERFLOW\",\n   420→  // \"PREVIOUS PAGE CONTENT\", \"CORRUPTED SECTION\", etc. that precede the actual recipe.\n   421→  const OVERFLOW_MARKERS = /\\b(PREVIOUS\\s+(RECIPE|PAGE)\\s+(OVERFLOW|CONTENT)|SPILLOVER|CONTINUATION|CORRUPTED\\s+SECTION)\\b/i;\n   422→  let overflowEnd = 0;\n   423→  for (let k = 0; k < lines.length && k < 30; k++) {\n   424→    if (OVERFLOW_MARKERS.test(lines[k].text)) {\n   425→      // Skip forward past the overflow block to the next visual separator or blank cluster\n   426→      let m = k + 1;\n   427→      let consecutiveBlanks = 0;\n   428→      while (m < lines.length) {\n   429→        const lineText = lines[m].text;\n   430→        // Stop at visual separator\n   431→        if (/^[=\\-]{4,}$/.test(lineText)) {\n   432→          overflowEnd = m + 1;\n   433→          break;\n   434→        }\n   435→        // Track consecutive blank lines\n   436→        if (lineText.trim().length === 0) {\n   437→          consecutiveBlanks++;\n   438→          if (consecutiveBlanks >= 2) {\n   439→            overflowEnd = m + 1;\n   440→            break;\n   441→          }\n   442→        } else {\n   443→          consecutiveBlanks = 0;\n   444→          // Stop at ALL_CAPS line with ≥2 words (likely next recipe heading)\n   445→          if (isAllCaps(lineText) && wordCount(lineText) >= 2) {\n   446→            overflowEnd = m; // Don't skip past the heading itself\n   447→            break;\n   448→          }\n   449→        }\n   450→        m++;\n   451→      }\n   452→      // If we walked to end without finding termination, skip everything we saw\n   453→      if (overflowEnd === 0) overflowEnd = Math.min(m, k + 1);\n   454→    }\n   455→  }\n   456→  if (overflowEnd > 0) i = overflowEnd;\n   457→\n   458→  while (i < lines.length && lines[i].text.length < 20 && isLikelyGarbled(lines[i].text) && !isAllCaps(lines[i].text)) {\n   459→    i++;\n   460→  }\n   461→  // Skip long instruction-like prologues: if 5+ consecutive lines look like cooking instructions,\n   462→  // skip them to find the actual title region.\n   463→  if (i === 0) {\n   464→    let j = 0;\n   465→    while (j < lines.length && looksLikeCookingInstruction(lines[j].text)) {\n   466→      j++;\n   467→    }\n   468→    if (j >= 5) {\n   469→      i = j;\n   470→    }\n   471→  }\n   472→  // Skip prose prologues: mid-recipe body text before the actual title.\n   473→  // If 3+ consecutive lines look like running body text (lowercase start, continuation,\n   474→  // or sentence-ending with many words), skip them.\n   475→  if (i === 0) {\n   476→    let j = 0;\n   477→    while (j < lines.length) {\n   478→      const t = lines[j].text;\n   479→      const isBodyText = (\n   480→        /^[a-ząćęłńóśźż]/.test(t) ||\n   481→        t.endsWith(\",\") ||\n   482→        (t.endsWith(\".\") && wordCount(t) > 4)\n   483→      ) && wordCount(t) >= 4;\n   484→      if (isBodyText) j++;\n   485→      else break;\n   486→    }\n   487→    if (j >= 3) i = j;\n   488→  }\n   489→  return i;\n   490→}\n   491→\n   492→function stripParentheticalGloss(text: string): string {\n   493→  // Strip trailing English-gloss parentheticals from ALL_CAPS titles.\n   494→  // e.g. \"PIEROGI RUSKIE (Boiled Dumplings with Potato and Cheese)\" → \"PIEROGI RUSKIE\"\n   495→  // Keep if parenthet