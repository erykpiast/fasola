{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013PX1K7UVZK8e2i1wx7EnFL","type":"tool_result","content":"338:function isTitleAbsentPage(lines: Array<string>): boolean {\n374:  if (/^\\[CORRUPTED\\s+SPILLOVER/i.test(text.trim())) return false;\n395:function findBurstEnd(lines: Array<{ text: string }>): number {\n398:  // Skip overflow preambles: blocks introduced by \"PREVIOUS RECIPE OVERFLOW\",\n400:  const OVERFLOW_MARKERS = /\\b(PREVIOUS\\s+(RECIPE|PAGE)\\s+(OVERFLOW|CONTENT)|SPILLOVER|CONTINUATION|CORRUPTED\\s+SECTION)\\b/i;\n403:    if (OVERFLOW_MARKERS.test(lines[k].text)) {\n493:  const burstEnd = findBurstEnd(nonEmptyLines);\n838:  const titleAbsent = isTitleAbsentPage(lines);\n931:    // raw line position, so filtered preamble lines don't penalize the first real candidate.\n960:  // First-after-preamble bonus (Pattern 3): when lines before the first candidate were all","is_error":false}]},"parent_tool_use_id":"toolu_011dVkNoYbCNwL2ozhAMzvL2","session_id":"18f2edd5-ecb4-45b8-8e46-36d66db82038","uuid":"729f57d6-c47d-4ade-8231-4d0ad265120d"}
