{\n   607→   607→        const norm = joined2.toLowerCase();\n   608→   608→        if (!seen.has(norm)) {\n   609→   609→          seen.add(norm);\n   610→   610→          candidates.push({ text: joined2, position: line.index, origin: \"2-line\" });\n   611→   611→        }\n   612→   612→      }\n   613→   613→    }\n   614→   614→\n   615→   615→    // 3-line join — skip if first line is a section label AND join would be ≤2 words\n   616→   616→    if (i + 2 < mergedLines.length) {\n   617→   617→      const joined3 = repairOcrText(`${line.text} ${mergedLines[i + 1].text} ${mergedLines[i + 2].text}`);\n   618→   618→      const shouldBlock3 = isSectionLabel(line.text) &&\n   619→   619→        (wordCount(joined3) <= 2 || isAlwaysBlockJoinLabel(line.text));\n   620→   620→      if (!shouldBlock3 && passesHardFilters(joined3)) {\n   621→   621→        const norm = joined3.toLowerCase();\n   622→   622→        if (!seen.has(norm)) {\n   623→   623→          seen.add(norm);\n   624→   624→          candidates.push({ text: joined3, position: line.index, origin: \"3-line\" });\n   625→   625→        }\n   626→   626→      }\n   627→   627→    }\n   628→   628→  }\n   629→   629→\n   630→   630→  // Pre-filter to 25 before embedding calls: prefer ALL_CAPS and short candidates.\n   631→   631→  // Position-based scoring handles final ranking.\n   632→   632→  if (candidates.length > 25) {\n   633→   633→    const prioritized = candidates.slice().sort((a, b) => {\n   634→   634→      const aAllCaps = isAllCaps(a.text) ? 0 : 1;\n   635→   635→      const bAllCaps = isAllCaps(b.text) ? 0 : 1;\n   636→   636→      if (aAllCaps !== bAllCaps) return aAllCaps - bAllCaps;\n   637→   637→      const aShort = wordCount(a.text) <= 5 ? 0 : 1;\n   638→   638→      const bShort = wordCount(b.text) <= 5 ? 0 : 1;\n   639→   639→      return aShort - bShort;\n   640→   640→    });\n   641→   641→    return prioritized.slice(0, 25);\n   642→   642→  }\n   643→   643→\n   644→   644→  return candidates;\n   645→   645→}\n   646→   646→\n   647→   647→/**\n   648→   648→ * Convert an ALL_CAPS string to Title Case, using a small-words list.\n   649→   649→ * Preserves Polish/French diacritics.\n   650→   650→ */\n   651→   651→function toTitleCase(text: string): string {\n   652→   652→  const smallWords = new Set([\n   653→   653→    \"a\", \"an\", \"the\", \"and\", \"but\", \"or\", \"for\", \"nor\",\n   654→   654→    \"in\", \"on\", \"at\", \"to\", \"of\", \"by\", \"with\", \"from\",\n   655→   655→    \"z\", \"w\", \"i\", \"ze\", \"na\", \"do\", \"od\", \"za\", \"po\",\n   656→   656→  ]);\n   657→   657→  return text.split(/(\\s+)/).map((word, idx) => {\n   658→   658→    if (/^\\s+$/.test(word)) return word;\n   659→   659→    const lower = word.toLowerCase();\n   660→   660→    if (idx === 0 || !smallWords.has(lower)) {\n   661→   661→      return lower.charAt(0).toUpperCase() + lower.slice(1);\n   662→   662→    }\n   663→   663→    return lower;\n   664→   664→  }).join(\"\");\n   665→   665→}\n   666→   666→\n   667→   667→/**\n   668→   668→ * OCR digit→letter substitution map.\n   669→   669→ * Each key is a character that OCR commonly confuses; values are possible correct letters.\n   670→   670→ */\n   671→   671→const OCR_SUBSTITUTIONS: Record<string, string[]> = {\n   672→   672→  \"0\": [\"o\"],\n   673→   673→  \"1\": [\"i\", \"l\"],\n   674→   674→  \"4\": [\"a\"],\n   675→   675→  \"5\": [\"s\"],\n   676→   676→  \"¡\": [\"i\"],\n   677→   677→  \"í\": [\"i\", \"l\"],\n   678→   678→  \"€\": [\"e\"],\n   679→   679→};\n   680→   680→\n   681→   681→const OCR_ARTIFACT_PATTERN = /[0-9¡Íí€]/;\n   682→   682→\n   683→   683→/**\n   684→   684→ * Attempt to repair a single OCR-corrupted word using dictionary lookup.\n   685→   685→ * Returns the repaired word if a dictionary match is found, otherwise returns the original.\n   686→   686→ */\n   687→   687→function repairOcrWord(word: string): string {\n   688→   688→  if (!OCR_ARTIFACT_PATTERN.test(word)) return word;\n   689→   689→\n   690→   690→  const lower = word.toLowerCase();\n   691→   691→\n   692→   692→  const positions: Array<{ index: number; replacements: Array<string> }> = [];\n   693→   693→  for (let i = 0; i < lower.length; i++) {\n   694→   694→    const replacements = OCR_SUBSTITUTIONS[lower[i]];\n   695→   695→    if (replacements) {\n   696→   696→      positions.push({ index: i, replacements });\n   697→   697→    }\n   698→   698→  }\n   699→   699→\n   700→   700→  if (positions.length === 0 || positions.length > 8) return word;\n   701→   701→\n   702→   702→  const candidates = generateSubstitutions(lower, positions, 0);\n   703→   703→\n   704→   704→  for (const candidate of candidates) {\n   705→   705→    if (FOOD_DICTIONARY.has(candidate)) {\n   706→   706→      if (word === word.toUpperCase()) return candidate.toUpperCase();\n   707→   707→      if (word[0] === word[0].toUpperCase()) {\n   708→   708→        return candidate[0].toUpperCase() + candidate.slice(1);\n   709→   709→      }\n   710→   710→      return candidate;\n   711→   711→    }\n   712→   712→  }\n   713→   713→\n   714→   714→  return word;\n   715→   715→}\n   716→   716→\n   717→   717→/**\n   718→   718→ * Recursively generate all substitution variants for OCR artifact positions.\n   719→   719→ */\n   720→   720→function generateSubstitutions(\n   721→   721→  base: string,\n   722→   722→  positions: Array<{ index: number; replacements: Array<string> }>,\n   723→   723→  posIdx: number,\n   724→   724→): Array<string> {\n   725→   725→  if (posIdx >= positions.length) return [base];\n   726→   726→\n   727→   727→  const { index, replacements } = positions[posIdx];\n   728→   728→  const results: Array<string> = [];\n   729→   729→\n   730→   730→  for (const replacement of replacements) {\n   731→   731→    const variant = base.slice(0, index) + replacement + base.slice(index + 1);\n   732→   732→    results.push(...generateSubstitutions(variant, positions, posIdx + 1));\n   733→   733→  }\n   734→   734→\n   735→   735→  return results;\n   736→   736→}\n   737→   737→\n   738→   738→/**\n   739→   739→ * Apply dictionary-guided OCR repair to all words in a text string.\n   740→   740→ */\n   741→   741→function repairOcrText(text: string): string {\n   742→   742→  return text\n   743→   743→    .split(/\\s+/)\n   744→   744→    .map((word) => {\n   745→   745→      const match = word.match(/^([^a-zA-Z0-9À-ÿ]*)(.*?)([^a-zA-Z0-9À-ÿ]*)$/);\n   746→   746→      if (!match) return word;\n   747→   747→      const [, prefix, core, suffix] = match;\n   748→   748→      if (!core) return word;\n   749→   749→      const repaired = repairOcrWord(core);\n   750→   750→      return prefix + repaired + suffix;\n   751→   751→    })\n   752→   752→    .join(\" \");\n   753→   753→}\n   754→   754→\n   755→   755→/**\n   756→   756→ * Post-processing normalization for OCR-extracted titles.\n   757→   757→ * Strips stray section markers and substitutes common OCR digit-for-letter artifacts.\n   758→   758→ * Title-case conversion is applied only when a substitution was actually made, so\n   759→   759→ * clean ALL_CAPS titles (e.g. \"CHOCOLATE CAKE\") are returned unchanged.\n   760→   760→ */\n   761→   761→function normalizeOcrTitle(raw: string): string {\n   762→   762→  let text = raw.trim();\n   763→   763→\n   764→   764→  // Step 0: Dictionary-guided OCR repair — resolve ambiguous substitutions\n   765→   765→  // using word-level context before applying blind character replacements.\n   766→   766→  text = repairOcrText(text);\n   767→   767→\n   768→   768→  // Step 1: Strip trailing section markers greedily appended to the title.\n   769→   769→  // e.g. \"MAKOWIEC ZE ŚLIWKAMI + SERVING AND STORAGE:\" → \"MAKOWIEC ZE ŚLIWKAMI\"\n   770→   770→  text = text.replace(\n   771→   771→    /\\s*\\+\\s*(?:SERV[IÍ1]NG(?:\\s+AND\\s+STORAGE)?|TOPPING|NOTES?|TIPS?)\\s*:?\\s*$/i,\n   772→   772→    \"\"\n   773→   773→  );\n   774→   774→\n   775→   775→  // Step 2: OCR character substitution.\n   776→   776→  // For ALL_CAPS text, apply digit-for-letter substitutions.\n   777→   777→  const beforeSub = text;\n   778→   778→  if (isAllCaps(text)) {\n   779→   779→    text = text\n   780→   780→      .replace(/1/g, \"I\")\n   781→   781→      .replace(/0(?=[A-ZÀ-Ż])/g, \"O\")\n   782→   782→      .replace(/(?<=[A-ZÀ-Ż])0/g, \"O\")\n   783→   783→      .replace(/4(?=[A-ZÀ-Ż])/g, \"A\")\n   784→   784→      .replace(/(?<=[A-ZÀ-Ż])4/g, \"A\")\n   785→   785→      .replace(/5(?=[A-ZÀ-Ż])/g, \"S\")\n   786→   786→      .replace(/(?<=[A-ZÀ-Ż])5/g, \"S\")\n   787→   787→      .replace(/¡/g, \"I\")\n   788→   788→      .replace(/€/g, \"E\")\n   789→   789→      .replace(/[ÍÌ]/g, \"I\");\n   790→   790→  } else {\n   791→   791→    // Mixed-case: fix per-word (digits between lowercase letters)\n   792→   792→    text = text.split(/(\\s+)/).map((token) => {\n   793→   793→      if (/^\\s+$/.test(token)) return token;\n   794→   794→      if (isAllCaps(token) && token.length > 1) {\n   795→   795→        return token\n   796→   796→          .replace(/1/g, \"I\")\n   797→   797→          .replace(/0(?=[A-Z])/g, \"O\")\n   798→   798→          .replace(/(?<=[A-Z])0/g, \"O\");\n   799→   799→      }\n   800→   800→      return token\n   801→   801→        .replace(/(?<=[a-zà-ż])1/g, \"l\")\n   802→   802→        .replace(/1(?=[a-zà-ż])/g, \"l\")\n   803→   803→        .replace(/¡/g, \"i\")\n   804→   804→        .replace(/€/g, \"e\");\n   805→   805→    }).join(\"\");\n   806→   806→  }\n   807→   807→\n   808→   808→  // Step 3: Title-case conversion — ONLY when OCR substitution changed the text.\n   809→   809→  // This preserves clean ALL_CAPS titles (e.g. \"CHOCOLATE CAKE\") as-is.\n   810→   810→  if (text !== beforeSub && isAllCaps(text)) {\n   811→   811→    text = toTitleCase(text);\n   812→   812→  }\n   813→   813→\n   814→   814→  return text.trim();\n   815→   815→}\n   816→   816→\n   817→   817→// Module-level cache for reference embeddings\n   818→   818→let cachedTitleRefEmbedding: Array<number> | null = null;\n   819→   819→let cachedHeaderRefEmbedding: Array<number> | null = null;\n   820→   820→let cachedNoiseRefEmbedding: Array<number> | null = null;\n   821→   821→\n   822→   822→export function _resetEmbeddingCacheForTests(): void {\n   823→   823→  cachedTitleRefEmbedding = null;\n   824→   824→  cachedHeaderRefEmbedding = null;\n   825→   825→  cachedNoiseRefEmbedding = null;\n   826→   826→}\n   827→   827→\n   828→   828→export async function extractTitleWithEmbeddings(\n   829→   829→  text: string,\n   830→   830→  embed: EmbedFn\n   831→   831→): Promise<string | undefined> {\n   832→   832→  if (!text || text.trim().length === 0) {\n   833→   833→    return undefined;\n   834→   834→  }\n   835→   835→\n   836→   836→  const lines = text.split(\"\\n\");\n   837→   837→  const candidates = buildCandidates(lines);\n   838→   838→  const titleAbsent = isTitleAbsentPage(lines);\n   839→   839→\n   840→   840→  if (candidates.length === 0) {\n   841→   841→    return undefined;\n   842→   842→  }\n   843→   843→\n   844→   844→  // Cache reference embeddings\n   845→   845→  if (!cachedTitleRefEmbedding) {\n   846→   846→    cachedTitleRefEmbedding = await embed(TITLE_REFERENCE);\n   847→   847→  }\n   848→   848→  if (!cachedHeaderRefEmbedding) {\n   849→   849→    cachedHeaderRefEmbedding = await embed(HEADER_REFERENCE);\n   850→   850→  }\n   851→   851→  if (!cachedNoiseRefEmbedding) {\n   852→   852→    cachedNoiseRefEmbedding = await embed(NOISE_REFERENCE);\n   853→   853→  }\n   854→   854→\n   855→   855→  // Find ALL_CAPS candidates with ≥2 words where every significant word has ≥4 alpha letters.\n   856→   856→  // Insignificant tokens (≤1 alpha letter: \"/\", \"&\", \"+\", \":\", \"D)\", etc.) are filtered before\n   857→   857→  // the check so that multi-line joins with continuation punctuation still qualify.\n   858→   858→  const isStructuralHeading = (c: { text: string }): boolean => {\n   859→   859→    if (!isAllCaps(c.text) || wordCount(c.text) < 2) return false;\n   860→   860→    const sigWords = c.text.trim().split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length > 1);\n   861→   861→    return sigWords.length >= 2 && sigWords.every((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   862→   862→  };\n   863→   863→\n   864→   864→  // Pass 1: compute rawScore for all candidates (embedding quality signal)\n   865→   865→  const rawScored: Array<{ text: string; position: number; origin: CandidateOrigin; rawScore: number; embedding: Array<number> }> = [];\n   866→   866→  for (const candidate of candidates) {\n   867→   867→    const embedding = await embed(candidate.text);\n   868→   868→    const titleSim = cosineSimilarity(embedding, cachedTitleRefEmbedding);\n   869→   869→    const headerSim = cosineSimilarity(embedding, cachedHeaderRefEmbedding);\n   870→   870→    const noiseSim = cosineSimilarity(embedding, cachedNoiseRefEmbedding);\n   871→   871→    const rawScore = titleSim - Math.max(headerSim, noiseSim);\n   872→   872→    rawScored.push({ text: candidate.text, position: candidate.position, origin: candidate.origin, rawScore, embedding });\n   873→   873→  }\n   874→   874→\n   875→   875→  // Select baseHeading by embedding quality (rawScore), not position.\n   876→   876→  // This prevents OCR-garbled fragments from claiming the structural heading slot.\n   877→   877→  const structuralCandidates = rawScored.filter((s) => isStructuralHeading(s));\n   878→   878→\n   879→   879→  // Penalize structural headings with truncated OCR words:\n   880→   880→  // if \"FRON\" appears and another heading has \"SAFFRON\", \"FRON\" is likely garbled.\n   881→   881→  for (const sc of structuralCandidates) {\n   882→   882→    const sigWords = sc.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   883→   883→    for (const other of structuralCandidates) {\n   884→   884→      if (other === sc) continue;\n   885→   885→      const otherSigWords = other.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   886→   886→      const hasTruncation = sigWords.some((w) =>\n   887→   887→        otherSigWords.some((ow) => ow !== w && ow.length > w.length && ow.endsWith(w))\n   888→   888→      );\n   889→   889→      if (hasTruncation) {\n   890→   890→        sc.rawScore = -1.0;  // Hard disqualification — truncated OCR artifact\n   891→   891→        break;\n   892→   892→      }\n   893→   893→    }\n   894→   894→  }\n   895→   895→\n   896→   896→  const bestStructural = structuralCandidates.length > 0\n   897→   897→    ? structuralCandidates.reduce((a, b) => {\n   898→   898→        const scoreDiff = a.rawScore - b.rawScore;\n   899→   899→        if (Math.abs(scoreDiff) > 0.03) return scoreDiff > 0 ? a : b;\n   900→   900→        // Tiebreak: single-line origin beats multi-line joins (avoids conflating two separate headings)\n   901→   901→        if (a.origin === \"single\" && b.origin !== \"single\") return a;\n   902→   902→        if (b.origin === \"single\" && a.origin !== \"single\") return b;\n   903→   903→        // Tiebreak: more words (more specific) → better\n   904→   904→        const wcDiff = wordCount(b.text) - wordCount(a.text);\n   905→   905→        if (wcDiff !== 0) return wcDiff > 0 ? b : a;\n   906→   906→        // Tiebreak: earlier position → better\n   907→   907→        return a.position < b.position ? a : b;\n   908→   908→      })\n   909→   909→    : null;\n   910→   910→  const baseHeading = bestStructural ?? undefined;\n   911→   911→\n   912→   912→  // When the best structural heading has a continuation on the next line introduced by a\n   913→   913→  // punctuation token (/, &, +, :, or parenthesis), prefer the longer 2-line join as the\n   914→   914→  // complete heading. E.g. \"SAFFRON WHEAT BUNS WITH QUARK\" + \"/ COTTAGE CHEESE (VARIATION D)\".\n   915→   915→  // Guard: the remainder after the prefix must start with a continuation character to avoid\n   916→   916→  // merging two separate consecutive recipe titles (FINNISH MILK FLATBREADS stays separate\n   917→   917→  // from FINNISH POTATO FLATBREADS because \"FINNISH\" does not start with a continuation token).\n   918→   918→  let firstStructuralHeading = baseHeading && (\n   919→   919→    rawScored.find((c) => {\n   920→   920→      if (!isStructuralHeading(c)) return false;\n   921→   921→      const hLower = baseHeading.text.toLowerCase();\n   922→   922→      const cLower = c.text.toLowerCase();\n   923→   923→      return cLower.startsWith(hLower + \" \") && /^[/&+:(]/.test(cLower.slice(hLower.length + 1));\n   924→   924→    }) ?? baseHeading\n   925→   925→  );\n   926→   926→\n   927→   927→  // Pass 2: apply bonuses\n   928→   928→  const scored: Array<{ text: string; position: number; origin: CandidateOrigin; score: number; rawScore: number; baseScore: number; thresholdScore: number }> = rawScored.map((rs, candidateIndex) => {\n   929→   929→    // Position factor: multiplicative tiebreaker — amplifies existing signal, doesn't replace it.\n   930→   930→    // Use candidate-relative position (rank among candidates that passed hard filters) rather than\n   931→   931→    // raw line position, so filtered preamble lines don't penalize the first real candidate.\n   932→   932→    const candidateRelativePosition = candidateIndex / rawScored.length;\n   933→   933→    const positionFactor = candidateRelativePosition < 0.5\n   934→   934→      ? 1.0 + 0.12 * (1 - candidateRelativePosition * 2)\n   935→   935→      : 1.0;\n   936→   936→\n   937→   937→    // ALL_CAPS bonus: recipe books use ALL_CAPS for titles and section headings.\n   938→   938→    // Single-word ALL_CAPS terms are overwhelmingly section/category labels, not recipe titles;\n   939→   939→    // real recipe titles in ALL_CAPS are almost always multi-word. Reduce the bonus for single words.\n   940→   940→    const allCapsBonus = isAllCaps(rs.text) && rs.text.replace(/[^a-zA-Z]/g, \"\").length >= 4\n   941→   941→      ? (wordCount(rs.text) >= 2 ? 0.08 : 0.03)\n   942→   942→      : 0;\n   943→   943→\n   944→   944→    // Structural heading bonus: best ALL_CAPS heading (or its continuation join) is almost always the recipe title\n   945→   945→    const structuralBonus = firstStructuralHeading && rs.text === firstStructuralHeading.text ? 0.10 : 0;\n   946→   946→\n   947→   947→    // thresholdScore excludes structural bonus so the bonus doesn't inflate the threshold\n   948→   948→    // and prevent equally-valid structural headings from passing on multi-recipe pages.\n   949→   949→    const thresholdScore = rs.rawScore + allCapsBonus;\n   950→   950→    // baseScore excludes position factor — used for diagnostics and ranking\n   951→   951→    const baseScore = rs.rawScore + allCapsBonus + structuralBonus;\n   952→   952→    const score = rs.rawScore * positionFactor + allCapsBonus + structuralBonus;\n   953→   953→    return { text: rs.text, position: rs.position, origin: rs.origin, score, rawScore: rs.rawScore, baseScore, thresholdScore };\n   954→   954→  });\n   955→   955→\n   956→   956→  if (scored.length === 0) {\n   957→   957→    return undefined;\n   958→   958→  }\n   959→   959→\n   960→   960→  // First-after-preamble bonus (Pattern 3): when lines before the first candidate were all\n   961→   961→  // filtered/empty, the first surviving candidate occupies the structural \"title position\".\n   962→   962→  // E.g. \"FISH & SEAFOOD\\nHalibut with Saffron Cream Sauce\\n...\" — \"FISH & SEAFOOD\" is filtered\n   963→   963→  // as a section label, so \"Halibut...\" is the first candidate and gets this boost.\n   964→   964→  const firstCandidate = scored[0];\n   965→   965→  if (firstCandidate.position > 0) {\n   966→   966→    const allPrecedingFiltered = lines\n   967→   967→      .slice(0, firstCandidate.position)\n   968→   968→      .every((line) => {\n   969→   969→        const trimmed = line.trim();\n   970→   970→        return trimmed === \"\" || !passesHardFilters(trimmed);\n   971→   971→      });\n   972→   972→    if (allPrecedingFiltered) {\n   973→   973→      firstCandidate.score += 0.08;\n   974→   974→      firstCandidate.baseScore += 0.08;\n   975→   975→      firstCandidate.thresholdScore += 0.08;\n   976→   976→    }\n   977→   977→  }\n   978→   978→\n   979→   979→  // --- Pre-threshold bilingual title detection ---\n   980→   980→  // When a mixed-case candidate at position 0 is followed by an ALL_CAPS candidate\n   981→   981→  // at position ≤ 2 that is semantically similar to it, this is a bilingual recipe\n   982→   982→  // page (e.g., Polish title + ALL_CAPS Korean romanization). Suppress confirmed\n   983→   983→  // translation candidates before computing threshold so their bonuses don't inflate\n   984→   984→  // the threshold beyond the mixed-case title's reach.\n   985→   985→  // Note: we check position ≤ 2 (local proximity), not global ALL_CAPS count, so\n   986→   986→  // section headers later in the document (SKŁADNIKI, WARZYWA, etc.) are irrelevant.\n   987→   987→  let translationCandidates: typeof scored = [];\n   988→   988→  let scoredForThreshold = scored;\n   989→   989→  const prePos0 = scored.find((s) => s.position === 0 && !isAllCaps(s.text));\n   990→   990→  if (prePos0) {\n   991→   991→    const nearbyAllCaps = scored.filter(\n   992→   992→      (s) => isAllCaps(s.text) && s.position >= 1 && s.position <= 2 && s.origin === \"single\"\n   993→   993→    );\n   994→   994→    const pos0Embedding = rawScored.find((r) => r.text === prePos0.text)?.embedding;\n   995→   995→\n   996→   996→    // Method 1: embedding similarity (works for related languages)\n   997→   997→    if (pos0Embedding && nearbyAllCaps.length > 0) {\n   998→   998→      translationCandidates = nearbyAllCaps.filter((cap) => {\n   999→   999→        const capEmbedding = rawScored.find((r) => r.text === cap.text)?.embedding;"}]},"parent_tool_use_id":null,"session_id":"d80e2ded-f7a7-46bb-8be0-f1bcb73047ba","uuid":"c60e6d95-c9bc-4861-8b44-31a25c87ba69","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/.claude/projects/-Users-eryk-napierala-Projects-fasola/d80e2ded-f7a7-46bb-8be0-f1bcb73047ba/tool-results/toolu_01PPWJXL1KBFfczYAdBvWmcC.txt","content":"   500→      nonEmptyLines[hi] = { text: joined, index: nonEmptyLines[hi].index };\n   501→      nonEmptyLines.splice(hi + 1, 1);\n   502→    }\n   503→  }\n   504→\n   505→  // Pre-merge consecutive short ALL_CAPS lines (OCR-fragmented headings).\n   506→  // When a sequence of 2+ ALL_CAPS lines each has ≤2 words and ≤25 chars, they are\n   507→  // almost certainly OCR fragments of a single heading. Merge them into one line so\n   508→  // the complete title enters the candidate pool without hitting the 3-line join ceiling.\n   509→  const capsCoalesced: Array<{ text: string; index: number }> = [];\n   510→  let ci = burstEnd;\n   511→  while (ci < nonEmptyLines.length) {\n   512→    const line = nonEmptyLines[ci];\n   513→    if (\n   514→      isAllCaps(line.text) &&\n   515→      wordCount(line.text) <= 2 &&\n   516→      line.text.length <= 25 &&\n   517→      !isSectionLabel(line.text) &&\n   518→      !looksLikeMetadata(line.text)\n   519→    ) {\n   520→      let merged = line.text;\n   521→      const startIndex = line.index;\n   522→      let j = ci + 1;\n   523→      while (j < nonEmptyLines.length) {\n   524→        const next = nonEmptyLines[j];\n   525→        if (\n   526→          isAllCaps(next.text) &&\n   527→          wordCount(next.text) <= 2 &&\n   528→          next.text.length <= 25 &&\n   529→          !isSectionLabel(next.text) &&\n   530→          !isSectionLabel(repairOcrText(next.text)) &&\n   531→          !looksLikeMetadata(next.text) &&\n   532→          (merged + \" \" + next.text).length <= 80\n   533→        ) {\n   534→          merged += \" \" + next.text;\n   535→          j++;\n   536→        } else {\n   537→          break;\n   538→        }\n   539→      }\n   540→      if (j > ci + 1) {\n   541→        capsCoalesced.push({ text: merged, index: startIndex });\n   542→        ci = j;\n   543→        continue;\n   544→      }\n   545→    }\n   546→    capsCoalesced.push(line);\n   547→    ci++;\n   548→  }\n   549→\n   550→  // Pre-merge continuation lines: a line starting with /&+:( is never a standalone title.\n   551→  // Merge it into the preceding line so the complete title enters the pool as a single candidate,\n   552→  // avoiding the fragile chain of conditions required by the downstream join survival logic.\n   553→  // Limitation: only one continuation line per preceding line is merged. Titles split across\n   554→  // three or more lines with continuation tokens (rare in practice) are not handled here —\n   555→  // the downstream 2-line and 3-line join candidates cover those cases instead.\n   556→  const mergedLines: Array<{ text: string; index: number }> = [];\n   557→  for (let i = 0; i < capsCoalesced.length; i++) {\n   558→    const line = capsCoalesced[i];\n   559→    if (i + 1 < capsCoalesced.length) {\n   560→      const nextText = capsCoalesced[i + 1].text;\n   561→      if (/^[/&+:(]/.test(nextText)) {\n   562→        mergedLines.push({ text: `${line.text} ${nextText}`, index: line.index });\n   563→        i++;\n   564→        continue;\n   565→      }\n   566→    }\n   567→    mergedLines.push(line);\n   568→  }\n   569→\n   570→  const candidates: Array<{ text: string; position: number; origin: CandidateOrigin }> = [];\n   571→  const seen = new Set<string>();\n   572→\n   573→  // Build a set of positions to skip: short ALL_CAPS lines immediately following metadata\n   574→  const metadataContinuationPositions = new Set<number>();\n   575→  for (let i = 0; i < mergedLines.length - 1; i++) {\n   576→    if (looksLikeMetadata(mergedLines[i].text)) {\n   577→      const next = mergedLines[i + 1];\n   578→      if (isAllCaps(next.text) && wordCount(next.text) <= 2 && next.text.length <= 15) {\n   579→        metadataContinuationPositions.add(next.index);\n   580→      }\n   581→    }\n   582→  }\n   583→\n   584→  for (let i = 0; i < mergedLines.length; i++) {\n   585→    const line = mergedLines[i];\n   586→\n   587→    // Skip metadata continuation fragments\n   588→    if (metadataContinuationPositions.has(line.index)) continue;\n   589→\n   590→    // Single line — strip page-number prefixes and parenthetical glosses before scoring\n   591→    const singleText = repairOcrText(stripParentheticalGloss(stripPageNumber(line.text)));\n   592→    if (passesHardFilters(singleText)) {\n   593→      const norm = singleText.toLowerCase();\n   594→      if (!seen.has(norm)) {\n   595→        seen.add(norm);\n   596→        candidates.push({ text: singleText, position: line.index, origin: \"single\" });\n   597→      }\n   598→    }\n   599→\n   600→    // 2-line join — skip if first line is a section label AND join would be ≤2 words\n   601→    // (a section label followed by modifiers is likely a recipe title, not a category header)\n   602→    if (i + 1 < mergedLines.length) {\n   603→      const joined2 = repairOcrText(`${line.text} ${mergedLines[i + 1].text}`);\n   604→      const shouldBlock2 = isSectionLabel(line.text) &&\n   605→        (wordCount(joined2) <= 2 || isAlwaysBlockJoinLabel(line.text));\n   606→      if (!shouldBlock2 && passesHardFilters(joined2)) {\n   607→        const norm = joined2.toLowerCase();\n   608→        if (!seen.has(norm)) {\n   609→          seen.add(norm);\n   610→          candidates.push({ text: joined2, position: line.index, origin: \"2-line\" });\n   611→        }\n   612→      }\n   613→    }\n   614→\n   615→    // 3-line join — skip if first line is a section label AND join would be ≤2 words\n   616→    if (i + 2 < mergedLines.length) {\n   617→      const joined3 = repairOcrText(`${line.text} ${mergedLines[i + 1].text} ${mergedLines[i + 2].text}`);\n   618→      const shouldBlock3 = isSectionLabel(line.text) &&\n   619→        (wordCount(joined3) <= 2 || isAlwaysBlockJoinLabel(line.text));\n   620→      if (!shouldBlock3 && passesHardFilters(joined3)) {\n   621→        const norm = joined3.toLowerCase();\n   622→        if (!seen.has(norm)) {\n   623→          seen.add(norm);\n   624→          candidates.push({ text: joined3, position: line.index, origin: \"3-line\" });\n   625→        }\n   626→      }\n   627→    }\n   628→  }\n   629→\n   630→  // Pre-filter to 25 before embedding calls: prefer ALL_CAPS and short candidates.\n   631→  // Position-based scoring handles final ranking.\n   632→  if (candidates.length > 25) {\n   633→    const prioritized = candidates.slice().sort((a, b) => {\n   634→      const aAllCaps = isAllCaps(a.text) ? 0 : 1;\n   635→      const bAllCaps = isAllCaps(b.text) ? 0 : 1;\n   636→      if (aAllCaps !== bAllCaps) return aAllCaps - bAllCaps;\n   637→      const aShort = wordCount(a.text) <= 5 ? 0 : 1;\n   638→      const bShort = wordCount(b.text) <= 5 ? 0 : 1;\n   639→      return aShort - bShort;\n   640→    });\n   641→    return prioritized.slice(0, 25);\n   642→  }\n   643→\n   644→  return candidates;\n   645→}\n   646→\n   647→/**\n   648→ * Convert an ALL_CAPS string to Title Case, using a small-words list.\n   649→ * Preserves Polish/French diacritics.\n   650→ */\n   651→function toTitleCase(text: string): string {\n   652→  const smallWords = new Set([\n   653→    \"a\", \"an\", \"the\", \"and\", \"but\", \"or\", \"for\", \"nor\",\n   654→    \"in\", \"on\", \"at\", \"to\", \"of\", \"by\", \"with\", \"from\",\n   655→    \"z\", \"w\", \"i\", \"ze\", \"na\", \"do\", \"od\", \"za\", \"po\",\n   656→  ]);\n   657→  return text.split(/(\\s+)/).map((word, idx) => {\n   658→    if (/^\\s+$/.test(word)) return word;\n   659→    const lower = word.toLowerCase();\n   660→    if (idx === 0 || !smallWords.has(lower)) {\n   661→      return lower.charAt(0).toUpperCase() + lower.slice(1);\n   662→    }\n   663→    return lower;\n   664→  }).join(\"\");\n   665→}\n   666→\n   667→/**\n   668→ * OCR digit→letter substitution map.\n   669→ * Each key is a character that OCR commonly confuses; values are possible correct letters.\n   670→ */\n   671→const OCR_SUBSTITUTIONS: Record<string, string[]> = {\n   672→  \"0\": [\"o\"],\n   673→  \"1\": [\"i\", \"l\"],\n   674→  \"4\": [\"a\"],\n   675→  \"5\": [\"s\"],\n   676→  \"¡\": [\"i\"],\n   677→  \"í\": [\"i\", \"l\"],\n   678→  \"€\": [\"e\"],\n   679→};\n   680→\n   681→const OCR_ARTIFACT_PATTERN = /[0-9¡Íí€]/;\n   682→\n   683→/**\n   684→ * Attempt to repair a single OCR-corrupted word using dictionary lookup.\n   685→ * Returns the repaired word if a dictionary match is found, otherwise returns the original.\n   686→ */\n   687→function repairOcrWord(word: string): string {\n   688→  if (!OCR_ARTIFACT_PATTERN.test(word)) return word;\n   689→\n   690→  const lower = word.toLowerCase();\n   691→\n   692→  const positions: Array<{ index: number; replacements: Array<string> }> = [];\n   693→  for (let i = 0; i < lower.length; i++) {\n   694→    const replacements = OCR_SUBSTITUTIONS[lower[i]];\n   695→    if (replacements) {\n   696→      positions.push({ index: i, replacements });\n   697→    }\n   698→  }\n   699→\n   700→  if (positions.length === 0 || positions.length > 8) return word;\n   701→\n   702→  const candidates = generateSubstitutions(lower, positions, 0);\n   703→\n   704→  for (const candidate of candidates) {\n   705→    if (FOOD_DICTIONARY.has(candidate)) {\n   706→      if (word === word.toUpperCase()) return candidate.toUpperCase();\n   707→      if (word[0] === word[0].toUpperCase()) {\n   708→        return candidate[0].toUpperCase() + candidate.slice(1);\n   709→      }\n   710→      return candidate;\n   711→    }\n   712→  }\n   713→\n   714→  return word;\n   715→}\n   716→\n   717→/**\n   718→ * Recursively generate all substitution variants for OCR artifact positions.\n   719→ */\n   720→function generateSubstitutions(\n   721→  base: string,\n   722→  positions: Array<{ index: number; replacements: Array<string> }>,\n   723→  posIdx: number,\n   724→): Array<string> {\n   725→  if (posIdx >= positions.length) return [base];\n   726→\n   727→  const { index, replacements } = positions[posIdx];\n   728→  const results: Array<string> = [];\n   729→\n   730→  for (const replacement of replacements) {\n   731→    const variant = base.slice(0, index) + replacement + base.slice(index + 1);\n   732→    results.push(...generateSubstitutions(variant, positions, posIdx + 1));\n   733→  }\n   734→\n   735→  return results;\n   736→}\n   737→\n   738→/**\n   739→ * Apply dictionary-guided OCR repair to all words in a text string.\n   740→ */\n   741→function repairOcrText(text: string): string {\n   742→  return text\n   743→    .split(/\\s+/)\n   744→    .map((word) => {\n   745→      const match = word.match(/^([^a-zA-Z0-9À-ÿ]*)(.*?)([^a-zA-Z0-9À-ÿ]*)$/);\n   746→      if (!match) return word;\n   747→      const [, prefix, core, suffix] = match;\n   748→      if (!core) return word;\n   749→      const repaired = repairOcrWord(core);\n   750→      return prefix + repaired + suffix;\n   751→    })\n   752→    .join(\" \");\n   753→}\n   754→\n   755→/**\n   756→ * Post-processing normalization for OCR-extracted titles.\n   757→ * Strips stray section markers and substitutes common OCR digit-for-letter artifacts.\n   758→ * Title-case conversion is applied only when a substitution was actually made, so\n   759→ * clean ALL_CAPS titles (e.g. \"CHOCOLATE CAKE\") are returned unchanged.\n   760→ */\n   761→function normalizeOcrTitle(raw: string): string {\n   762→  let text = raw.trim();\n   763→\n   764→  // Step 0: Dictionary-guided OCR repair — resolve ambiguous substitutions\n   765→  // using word-level context before applying blind character replacements.\n   766→  text = repairOcrText(text);\n   767→\n   768→  // Step 1: Strip trailing section markers greedily appended to the title.\n   769→  // e.g. \"MAKOWIEC ZE ŚLIWKAMI + SERVING AND STORAGE:\" → \"MAKOWIEC ZE ŚLIWKAMI\"\n   770→  text = text.replace(\n   771→    /\\s*\\+\\s*(?:SERV[IÍ1]NG(?:\\s+AND\\s+STORAGE)?|TOPPING|NOTES?|TIPS?)\\s*:?\\s*$/i,\n   772→    \"\"\n   773→  );\n   774→\n   775→  // Step 2: OCR character substitution.\n   776→  // For ALL_CAPS text, apply digit-for-letter substitutions.\n   777→  const beforeSub = text;\n   778→  if (isAllCaps(text)) {\n   779→    text = text\n   780→      .replace(/1/g, \"I\")\n   781→      .replace(/0(?=[A-ZÀ-Ż])/g, \"O\")\n   782→      .replace(/(?<=[A-ZÀ-Ż])0/g, \"O\")\n   783→      .replace(/4(?=[A-ZÀ-Ż])/g, \"A\")\n   784→      .replace(/(?<=[A-ZÀ-Ż])4/g, \"A\")\n   785→      .replace(/5(?=[A-ZÀ-Ż])/g, \"S\")\n   786→      .replace(/(?<=[A-ZÀ-Ż])5/g, \"S\")\n   787→      .replace(/¡/g, \"I\")\n   788→      .replace(/€/g, \"E\")\n   789→      .replace(/[ÍÌ]/g, \"I\");\n   790→  } else {\n   791→    // Mixed-case: fix per-word (digits between lowercase letters)\n   792→    text = text.split(/(\\s+)/).map((token) => {\n   793→      if (/^\\s+$/.test(token)) return token;\n   794→      if (isAllCaps(token) && token.length > 1) {\n   795→        return token\n   796→          .replace(/1/g, \"I\")\n   797→          .replace(/0(?=[A-Z])/g, \"O\")\n   798→          .replace(/(?<=[A-Z])0/g, \"O\");\n   799→      }\n   800→      return token\n   801→        .replace(/(?<=[a-zà-ż])1/g, \"l\")\n   802→        .replace(/1(?=[a-zà-ż])/g, \"l\")\n   803→        .replace(/¡/g, \"i\")\n   804→        .replace(/€/g, \"e\");\n   805→    }).join(\"\");\n   806→  }\n   807→\n   808→  // Step 3: Title-case conversion — ONLY when OCR substitution changed the text.\n   809→  // This preserves clean ALL_CAPS titles (e.g. \"CHOCOLATE CAKE\") as-is.\n   810→  if (text !== beforeSub && isAllCaps(text)) {\n   811→    text = toTitleCase(text);\n   812→  }\n   813→\n   814→  return text.trim();\n   815→}\n   816→\n   817→// Module-level cache for reference embeddings\n   818→let cachedTitleRefEmbedding: Array<number> | null = null;\n   819→let cachedHeaderRefEmbedding: Array<number> | null = null;\n   820→let cachedNoiseRefEmbedding: Array<number> | null = null;\n   821→\n   822→export function _resetEmbeddingCacheForTests(): void {\n   823→  cachedTitleRefEmbedding = null;\n   824→  cachedHeaderRefEmbedding = null;\n   825→  cachedNoiseRefEmbedding = null;\n   826→}\n   827→\n   828→export async function extractTitleWithEmbeddings(\n   829→  text: string,\n   830→  embed: EmbedFn\n   831→): Promise<string | undefined> {\n   832→  if (!text || text.trim().length === 0) {\n   833→    return undefined;\n   834→  }\n   835→\n   836→  const lines = text.split(\"\\n\");\n   837→  const candidates = buildCandidates(lines);\n   838→  const titleAbsent = isTitleAbsentPage(lines);\n   839→\n   840→  if (candidates.length === 0) {\n   841→    return undefined;\n   842→  }\n   843→\n   844→  // Cache reference embeddings\n   845→  if (!cachedTitleRefEmbedding) {\n   846→    cachedTitleRefEmbedding = await embed(TITLE_REFERENCE);\n   847→  }\n   848→  if (!cachedHeaderRefEmbedding) {\n   849→    cachedHeaderRefEmbedding = await embed(HEADER_REFERENCE);\n   850→  }\n   851→  if (!cachedNoiseRefEmbedding) {\n   852→    cachedNoiseRefEmbedding = await embed(NOISE_REFERENCE);\n   853→  }\n   854→\n   855→  // Find ALL_CAPS candidates with ≥2 words where every significant word has ≥4 alpha letters.\n   856→  // Insignificant tokens (≤1 alpha letter: \"/\", \"&\", \"+\", \":\", \"D)\", etc.) are filtered before\n   857→  // the check so that multi-line joins with continuation punctuation still qualify.\n   858→  const isStructuralHeading = (c: { text: string }): boolean => {\n   859→    if (!isAllCaps(c.text) || wordCount(c.text) < 2) return false;\n   860→    const sigWords = c.text.trim().split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length > 1);\n   861→    return sigWords.length >= 2 && sigWords.every((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   862→  };\n   863→\n   864→  // Pass 1: compute rawScore for all candidates (embedding quality signal)\n   865→  const rawScored: Array<{ text: string; position: number; origin: CandidateOrigin; rawScore: number; embedding: Array<number> }> = [];\n   866→  for (const candidate of candidates) {\n   867→    const embedding = await embed(candidate.text);\n   868→    const titleSim = cosineSimilarity(embedding, cachedTitleRefEmbedding);\n   869→    const headerSim = cosineSimilarity(embedding, cachedHeaderRefEmbedding);\n   870→    const noiseSim = cosineSimilarity(embedding, cachedNoiseRefEmbedding);\n   871→    const rawScore = titleSim - Math.max(headerSim, noiseSim);\n   872→    rawScored.push({ text: candidate.text, position: candidate.position, origin: candidate.origin, rawScore, embedding });\n   873→  }\n   874→\n   875→  // Select baseHeading by embedding quality (rawScore), not position.\n   876→  // This prevents OCR-garbled fragments from claiming the structural heading slot.\n   877→  const structuralCandidates = rawScored.filter((s) => isStructuralHeading(s));\n   878→\n   879→  // Penalize structural headings with truncated OCR words:\n   880→  // if \"FRON\" appears and another heading has \"SAFFRON\", \"FRON\" is likely garbled.\n   881→  for (const sc of structuralCandidates) {\n   882→    const sigWords = sc.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   883→    for (const other of structuralCandidates) {\n   884→      if (other === sc) continue;\n   885→      const otherSigWords = other.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   886→      const hasTruncation = sigWords.some((w) =>\n   887→        otherSigWords.some((ow) => ow !== w && ow.length > w.length && ow.endsWith(w))\n   888→      );\n   889→      if (hasTruncation) {\n   890→        sc.rawScore = -1.0;  // Hard disqualification — truncated OCR artifact\n   891→        break;\n   892→      }\n   893→    }\n   894→  }\n   895→\n   896→  const bestStructural = structuralCandidates.length > 0\n   897→    ? structuralCandidates.reduce((a, b) => {\n   898→        const scoreDiff = a.rawScore - b.rawScore;\n   899→        if (Math.abs(scoreDiff) > 0.03) return scoreDiff > 0 ? a : b;\n   900→        // Tiebreak: single-line origin beats multi-line joins (avoids conflating two separate headings)\n   901→        if (a.origin === \"single\" && b.origin !== \"single\") return a;\n   902→        if (b.origin === \"single\" && a.origin !== \"single\") return b;\n   903→        // Tiebreak: more words (more specific) → better\n   904→        const wcDiff = wordCount(b.text) - wordCount(a.text);\n   905→        if (wcDiff !== 0) return wcDiff > 0 ? b : a;\n   906→        // Tiebreak: earlier position → better\n   907→        return a.position < b.position ? a : b;\n   908→      })\n   909→    : null;\n   910→  const baseHeading = bestStructural ?? undefined;\n   911→\n   912→  // When the best structural heading has a continuation on the next line introduced by a\n   913→  // punctuation token (/, &, +, :, or parenthesis), prefer the longer 2-line join as the\n   914→  // complete heading. E.g. \"SAFFRON WHEAT BUNS WITH QUARK\" + \"/ COTTAGE CHEESE (VARIATION D)\".\n   915→  // Guard: the remainder after the prefix must start with a continuation character to avoid\n   916→  // merging two separate consecutive recipe titles (FINNISH MILK FLATBREADS stays separate\n   917→  // from FINNISH POTATO FLATBREADS because \"FINNISH\" does not start with a continuation token).\n   918→  let firstStructuralHeading = baseHeading && (\n   919→    rawScored.find((c) => {\n   920→      if (!isStructuralHeading(c)) return false;\n   921→      const hLower = baseHeading.text.toLowerCase();\n   922→      const cLower = c.text.toLowerCase();\n   923→      return cLower.startsWith(hLower + \" \") && /^[/&+:(]/.test(cLower.slice(hLower.length + 1));\n   924→    }) ?? baseHeading\n   925→  );\n   926→\n   927→  // Pass 2: apply bonuses\n   928→  const scored: Array<{ text: string; position: number; origin: CandidateOrigin; score: number; rawScore: number; baseScore: number; thresholdScore: number }> = rawScored.map((rs, candidateIndex) => {\n   929→    // Position factor: multiplicative tiebreaker — amplifies existing signal, doesn't replace it.\n   930→    // Use candidate-relative position (rank among candidates that passed hard filters) rather than\n   931→    // raw line position, so filtered preamble lines don't penalize the first real candidate.\n   932→    const candidateRelativePosition = candidateIndex / rawScored.length;\n   933→    const positionFactor = candidateRelativePosition < 0.5\n   934→      ? 1.0 + 0.12 * (1 - candidateRelativePosition * 2)\n   935→      : 1.0;\n   936→\n   937→    // ALL_CAPS bonus: recipe books use ALL_CAPS for titles and section headings.\n   938→    // Single-word ALL_CAPS terms are overwhelmingly section/category labels, not recipe titles;\n   939→    // real recipe titles in ALL_CAPS are almost always multi-word. Reduce the bonus for single words.\n   940→    const allCapsBonus = isAllCaps(rs.text) && rs.text.replace(/[^a-zA-Z]/g, \"\").length >= 4\n   941→      ? (wordCount(rs.text) >= 2 ? 0.08 : 0.03)\n   942→      : 0;\n   943→\n   944→    // Structural heading bonus: best ALL_CAPS heading (or its continuation join) is almost always the recipe title\n   945→    const structuralBonus = firstStructuralHeading && rs.text === firstStructuralHeading.text ? 0.10 : 0;\n   946→\n   947→    // thresholdScore excludes structural bonus so the bonus doesn't inflate the threshold\n   948→    // and prevent equally-valid structural headings from passing on multi-recipe pages.\n   949→    const thresholdScore = rs.rawScore + allCapsBonus;\n   950→    // baseScore excludes position factor — used for diagnostics and ranking\n   951→    const baseScore = rs.rawScore + allCapsBonus + structuralBonus;\n   952→    const score = rs.rawScore * positionFactor + allCapsBonus + structuralBonus;\n   953→    return { text: rs.text, position: rs.position, origin: rs.origin, score, rawScore: rs.rawScore, baseScore, thresholdScore };\n   954→  });\n   955→\n   956→  if (scored.length === 0) {\n   957→    return undefined;\n   958→  }\n   959→\n   960→  // First-after-preamble bonus (Pattern 3): when lines before the first candidate were all\n   961→  // filtered/empty, the first surviving candidate occupies the structural \"title position\".\n   962→  // E.g. \"FISH & SEAFOOD\\nHalibut with Saffron Cream Sauce\\n...\" — \"FISH & SEAFOOD\" is filtered\n   963→  // as a section label, so \"Halibut...\" is the first candidate and gets this boost.\n   964→  const firstCandidate = scored[0];\n   965→  if (firstCandidate.position > 0) {\n   966→    const allPrecedingFiltered = lines\n   967→      .slice(0, firstCandidate.position)\n   968→      .every((line) => {\n   969→        const trimmed = line.trim();\n   970→        return trimmed === \"\" || !passesHardFilters(trimmed);\n   971→      });\n   972→    if (allPrecedingFiltered) {\n   973→      firstCandidate.score += 0.08;\n   974→      firstCandidate.baseScore += 0.08;\n   975→      firstCandidate.thresholdScore += 0.08;\n   976→    }\n   977→  }\n   978→\n   979→  // --- Pre-threshold bilingual title detection ---\n   980→  // When a mixed-case candidate at position 0 is followed by an ALL_CAPS candidate\n   981→  // at position ≤ 2 that is semantically similar to it, this is a bilingual recipe\n   982→  // page (e.g., Polish title + ALL_CAPS Korean romanization). Suppress confirmed\n   983→  // translation candidates before computing threshold so their bonuses don't inflate\n   984→  // the threshold beyond the mixed-case title's reach.\n   985→  // Note: we check position ≤ 2 (local proximity), not global ALL_CAPS count, so\n   986→  // section headers later in the document (SKŁADNIKI, WARZYWA, etc.) are irrelevant.\n   987→  let translationCandidates: typeof scored = [];\n   988→  let scoredForThreshold = scored;\n   989→  const prePos0 = scored.find((s) => s.position === 0 && !isAllCaps(s.text));\n   990→  if (prePos0) {\n   991→    const nearbyAllCaps = scored.filter(\n   992→      (s) => isAllCaps(s.text) && s.position >= 1 && s.position <= 2 && s.origin === \"single\"\n   993→    );\n   994→    const pos0Embedding = rawScored.find((r) => r.text === prePos0.text)?.embedding;\n   995→\n   996→    // Method 1: embedding similarity (works for related languages)\n   997→    if (pos0Embedding && nearbyAllCaps.length > 0) {\n   998→      translationCandidates = nearbyAllCaps.filter((cap) => {\n   999→        const capEmbedding = rawScored.find((r) => r.text === cap.text)?.embedding;","numLines":500,"startLine":500,"totalLines":1436}}}
