 535→   535→          j++;\n   536→   536→        } else {\n   537→   537→          break;\n   538→   538→        }\n   539→   539→      }\n   540→   540→      if (j > ci + 1) {\n   541→   541→        capsCoalesced.push({ text: merged, index: startIndex });\n   542→   542→        ci = j;\n   543→   543→        continue;\n   544→   544→      }\n   545→   545→    }\n   546→   546→    capsCoalesced.push(line);\n   547→   547→    ci++;\n   548→   548→  }\n   549→   549→\n   550→   550→  // Pre-merge continuation lines: a line starting with /&+:( is never a standalone title.\n   551→   551→  // Merge it into the preceding line so the complete title enters the pool as a single candidate,\n   552→   552→  // avoiding the fragile chain of conditions required by the downstream join survival logic.\n   553→   553→  // Limitation: only one continuation line per preceding line is merged. Titles split across\n   554→   554→  // three or more lines with continuation tokens (rare in practice) are not handled here —\n   555→   555→  // the downstream 2-line and 3-line join candidates cover those cases instead.\n   556→   556→  const mergedLines: Array<{ text: string; index: number }> = [];\n   557→   557→  for (let i = 0; i < capsCoalesced.length; i++) {\n   558→   558→    const line = capsCoalesced[i];\n   559→   559→    if (i + 1 < capsCoalesced.length) {\n   560→   560→      const nextText = capsCoalesced[i + 1].text;\n   561→   561→      if (/^[/&+:(]/.test(nextText)) {\n   562→   562→        mergedLines.push({ text: `${line.text} ${nextText}`, index: line.index });\n   563→   563→        i++;\n   564→   564→        continue;\n   565→   565→      }\n   566→   566→    }\n   567→   567→    mergedLines.push(line);\n   568→   568→  }\n   569→   569→\n   570→   570→  const candidates: Array<{ text: string; position: number; origin: CandidateOrigin }> = [];\n   571→   571→  const seen = new Set<string>();\n   572→   572→\n   573→   573→  // Build a set of positions to skip: short ALL