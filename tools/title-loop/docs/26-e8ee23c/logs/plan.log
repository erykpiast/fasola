{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01N352PArAQ1FG3hnT2FmUzc","type":"tool_result","content":"     1→     1→/**\n     2→     2→ * Title Extraction\n     3→     3→ * Extracts potential recipe title from OCR text using heuristics or semantic embeddings\n     4→     4→ */\n     5→     5→\n     6→     6→import { cosineSimilarity } from \"./embeddings\";\n     7→     7→import { FOOD_DICTIONARY } from \"./food-dictionary\";\n     8→     8→\n     9→     9→export type EmbedFn = (text: string) => Promise<Array<number>>;\n    10→    10→\n    11→    11→const TITLE_REFERENCE =\n    12→    12→  \"recipe name, dish title, name of the food, nazwa przepisu, nazwa dania\";\n    13→    13→const HEADER_REFERENCE =\n    14→    14→  \"ingredients list, cooking directions, section heading, składniki, przygotowanie, sposób wykonania\";\n    15→    15→const NOISE_REFERENCE =\n    16→    16→  \"page number, table of contents, book footer, garbled text\";\n    17→    17→\n    18→    18→/**\n    19→    19→ * Measurement units commonly found in ingredient lists\n    20→    20→ */\n    21→    21→const MEASUREMENT_PATTERNS = [\n    22→    22→  // English\n    23→    23→  \"cup\",\n    24→    24→  \"cups\",\n    25→    25→  \"tbsp\",\n    26→    26→  \"tsp\",\n    27→    27→  \"tablespoon\",\n    28→    28→  \"teaspoon\",\n    29→    29→  // \"oz\" and \"lb\" are matched with word boundaries in looksLikeIngredient\n    30→    30→  // to avoid false positives (\"oz\" in \"mozzarella\", \"lb\" in \"albacore\")\n    31→    31→  \"gram\",\n    32→    32→  \"grams\",\n    33→    33→  \"kg\",\n    34→    34→  \"ml\",\n    35→    35→  \"liter\",\n    36→    36→  \"pinch\",\n    37→    37→  \"dash\",\n    38→    38→  \"handful\",\n    39→    39→  // Polish\n    40→    40→  \"łyżka\", \"łyżki\", \"łyżek\",           // tablespoon(s)\n    41→    41→  \"łyżeczka\", \"łyżeczki\", \"łyżeczek\",   // teaspoon(s)\n    42→    42→  \"szklanka\", \"szklanki\", \"szklanek\",    // cup(s)\n    43→    43→  \"szczypta\",                            // pinch\n    44→    44→  \"garść\",                               // handful\n    45→    45→  \"opakowanie\", \"opakowania\",            // package(s)\n    46→    46→  \"plasterek\", \"plasterki\",             // slice(s)\n    47→    47→];\n    48→    48→\n    49→    49→/**\n    50→    50→ * Patterns that identify recipe metadata lines (not titles)\n    51→    51→ */\n    52→    52→const METADATA_PATTERNS = [\n    53→    53→  /^(SERVES?|MAKES?|YIELDS?)\\b/i,\n    54→    54→  /^(PREP(ARATION)?|COOK(ING)?|PROOF|RISING|FERMENTATION|REST(ING)?)\\s*(AND\\s*)?(COOK(ING)?)?\\s*TIME/i,\n    55→    55→  /^SAMPLE\\s+SCHEDULE\\b/i,\n    56→    56→  /^BULK\\s+FERMENTATION\\b/i,\n    57→    57→  /^(THIS\\s+RECIPE\\s+)?MAKES\\b/i,\n    58→    58→  // Polish serving-size patterns: \"NA 3 PAPRYKI\", \"NA OKOŁO 1 KG\", \"DLA 4 OSÓB\"\n    59→    59→  /^NA\\s+(\\d|OKOŁO)\\b/i,\n    60→    60→  /^DLA\\s+\\d/i,\n    61→    61→  // OCR-resilient: \"DLA\" + any token + serving-unit word (handles DLA & OSOB, DLA § OSOB, etc.)\n    62→    62→  /^DLA\\s+\\S+\\s+OSOB/i,\n    63→    63→  // OCR-resilient: \"DLA\" + single non-alphanumeric char (common digit→symbol OCR error)\n    64→    64→  /^DLA\\s+[^a-zA-Z0-9\\s]\\s/i,\n    65→    65→  // Time-unit metadata: any line containing \"N MIN\" or \"N GODZ\" is prep/cook/rest time,\n    66→    66→  // regardless of OCR-corrupted prefix (catches PRZYGOTOWANTE, GOTOMANTE, etc.)\n    67→    67→  /\\b\\d+\\s*MIN\\b/i,\n    68→    68→  /\\b\\d+\\s*GODZ/i,\n    69→    69→  // Season/category indicators\n    70→    70→  /^SEZON\\s*:/i,\n    71→    71→  /^KATEGORIA\\s*:/i,\n    72→    72→  /^RODZAJ\\s*:/i,\n    73→    73→  /^PORCJI\\s*:/i,       // Polish serving count\n    74→    74→  /^PORTIONS?\\s*:/i,    // English serving count\n    75→    75→  /^CZ[ĘE]Ś[ĆC]\\s*\\d/i,   // CZĘŚĆ 1: ... (Polish \"Part 1:\")\n    76→    76→  /^PART\\s+\\d/i,             // PART 1: ... (English)\n    77→    77→  /^MAIN\\s+RECIPE\\s*:/i,    // \"MAIN RECIPE: ...\" structural prefix lines\n    78→    78→  /^--\\s*\\w/,               // \"--VARIATION:\", \"--WERSJA NOWOCZESNA\" sub-section headers\n    79→    79→];\n    80→    80→\n    81→    81→/**\n    82→    82→ * Single-word non-title words — standalone OCR fragments unlikely to be recipe titles\n    83→    83→ */\n    84→    84→const NON_TITLE_WORDS = new Set([\n    85→    85→  \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"are\", \"was\",\n    86→    86→  \"has\", \"his\", \"her\", \"its\", \"our\", \"who\", \"how\", \"may\", \"new\", \"now\",\n    87→    87→  \"old\", \"see\", \"way\", \"did\", \"get\", \"let\", \"say\", \"she\", \"too\", \"use\",\n    88→    88→  \"buns\", \"with\",\n    89→    89→]);\n    90→    90→\n    91→    91→function looksLikeIngredient(line: string): boolean {\n    92→    92→  const lowerLine = line.toLowerCase();\n    93→    93→  if (MEASUREMENT_PATTERNS.some((pattern) => lowerLine.includes(pattern))) return true;\n    94→    94→  // Compact metric: \"100g\", \"50ml\", \"250g\" — digit immediately followed by g/ml/kg\n    95→    95→  if (/\\b\\d+\\s*(?:g|ml|kg)\\b/i.test(line)) return true;\n    96→    96→  // \"to taste\" / \"do smaku\" — qualitative ingredient with no unit\n    97→    97→  if (/\\bto taste\\b/i.test(line) || /\\bdo smaku\\b/i.test(line)) return true;\n    98→    98→  return false;\n    99→    99→}\n   100→   100→\n   101→   101→function startsWithNumber(line: string): boolean {\n   102→   102→  // Match lines starting with a digit, or bullet-then-digit (e.g., \"- 2 jajka\")\n   103→   103→  return /^\\s*(?:[-•*]\\s*)?\\d/.test(line);\n   104→   104→}\n   105→   105→\n   106→   106→function stripDiacritics(text: string): string {\n   107→   107→  return text.normalize(\"NFKD\").replace(/[\\u0300-\\u036f]/g, \"\");\n   108→   108→}\n   109→   109→\n   110→   110→/**\n   111→   111→ * Known recipe section labels — these are structural headers, not recipe titles.\n   112→   112→ * Matched case-insensitively after trimming, stripping trailing punctuation, and stripping diacritics.\n   113→   113→ * Polish entries are stored without diacritics for OCR resilience (e.g. \"SKLADNIKI\" matches \"składniki\").\n   114→   114→ */\n   115→   115→const SECTION_LABELS = new Set([\n   116→   116→  // English\n   117→   117→  \"ingredients\", \"directions\", \"instructions\", \"method\", \"preparation\",\n   118→   118→  \"steps\", \"notes\", \"tip\", \"tips\", \"variations\", \"variation\",\n   119→   119→  \"garnish\", \"topping\", \"toppings\", \"frosting\", \"filling\",\n   120→   120→  \"serving suggestion\", \"serving suggestions\", \"serving\",\n   121→   121→  \"glaze\", \"for the sauce\", \"for the filling\", \"for the dough\",\n   122→   122→  \"for the topping\", \"for the glaze\", \"for the pasta dough\",\n   123→   123→  \"for the pasta\", \"for the crust\",\n   124→   124→  // Polish — recipe section labels (stored without diacritics for OCR resilience)\n   125→   125→  \"skladniki\", \"przygotowanie\", \"sposob przygotowania\", \"sposob wykonania\",\n   126→   126→  \"wykonanie\", \"wskazowki\", \"podpowiedz\", \"warianty\",\n   127→   127→  \"sos\", \"nadzienie\", \"polewa\", \"lukier\", \"ciasto\",  // ciasto = dough/pastry base (recipe-internal section AND chapter label)\n   128→   128→  \"instrukcje\",       // instructions\n   129→   129→  \"uwagi\",            // notes/remarks\n   130→   130→  \"notatki\",          // notes\n   131→   131→  \"podawanie\",        // serving\n   132→   132→  \"przechowywanie\",   // storage\n   133→   133→  // Polish — recipe-book chapter/category labels (food groups, meal types)\n   134→   134→  \"warzywa\",          // vegetables\n   135→   135→  \"mieso\",            // meat (mięso)\n   136→   136→  \"miesa\",            // meats (mięsa)\n   137→   137→  \"ryby\",             // fish\n   138→   138→  \"owoce morza\",      // seafood\n   139→   139→  \"zupy\",             // soups\n   140→   140→  \"salatki\",          // salads (sałatki)\n   141→   141→  \"desery\",           // desserts\n   142→   142→  \"napoje\",           // drinks\n   143→   143→  \"pieczywo\",         // bread/baked goods\n   144→   144→  \"przekaski\",        // appetizers/snacks\n   145→   145→  \"sniadania\",        // breakfasts (śniadania)\n   146→   146→  \"obiady\",           // dinners/lunches\n   147→   147→  \"kolacje\",          // suppers\n   148→   148→  \"makarony\",         // pasta dishes\n   149→   149→  \"kasza\",            // groats/grains\n   150→   150→  \"kasze\",            // groats/grains (plural)\n   151→   151→  \"dania glowne\",     // main courses (dania główne)\n   152→   152→  \"przystawki\",       // starters\n   153→   153→  \"dodatki\",          // side dishes\n   154→   154→  \"przetwory\",        // preserves\n   155→   155→  \"wypieki\",          // baked goods\n   156→   156→  \"ciasta\",           // cakes (plural)\n   157→   157→  \"ciastka\",          // cookies\n   158→   158→  \"torty\",            // layer cakes\n   159→   159→  // \"placki\" removed — it commonly starts recipe titles like \"Placki Ziemniaczane\", \"Placki Żółte z Kukurydzą\"\n   160→   160→  \"koktajle\",         // cocktails/smoothies\n   161→   161→  // English — recipe-book chapter/category labels\n   162→   162→  \"vegetables\", \"seafood\", \"fish\", \"soups\", \"salads\", \"desserts\",\n   163→   163→  \"appetizers\", \"breads\", \"breakfast\", \"pasta\", \"grains\",\n   164→   164→  \"main courses\", \"side dishes\", \"preserves\", \"baked goods\",\n   165→   165→  \"fish & seafood\", \"soups & broths\", \"desserts & baked goods\",\n   166→   166→  \"meats\", \"poultry\", \"game\",\n   167→   167→]);\n   168→   168→\n   169→   169→function isSectionLabel(text: string): boolean {\n   170→   170→  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n   171→   171→  if (SECTION_LABELS.has(normalized)) return true;\n   172→   172→  // OCR variant: leading \"l\" may be OCR-corrupted \"I\" (e.g. \"lngredients\" → \"ingredients\")\n   173→   173→  const ocrNormalized = normalized.replace(/^l/, \"i\");\n   174→   174→  if (ocrNormalized !== normalized && SECTION_LABELS.has(ocrNormalized)) return true;\n   175→   175→  return false;\n   176→   176→}\n   177→   177→\n   178→   178→/**\n   179→   179→ * Recipe-internal section labels that should ALWAYS block multi-line joins,\n   180→   180→ * even when the combined word count is ≥ 3.\n   181→   181→ * Category labels (\"zupy\", \"placki\", etc.) are NOT in this set — they can\n   182→   182→ * legitimately start a multi-word recipe title like \"Zupy Zimowe Warzywne\".\n   183→   183→ */\n   184→   184→const ALWAYS_BLOCK_JOIN_LABELS = new Set([\n   185→   185→  \"ingredients\", \"directions\", \"instructions\", \"method\", \"preparation\",\n   186→   186→  \"steps\", \"notes\", \"tip\", \"tips\", \"variations\", \"variation\",\n   187→   187→  \"garnish\", \"topping\", \"toppings\", \"frosting\", \"filling\",\n   188→   188→  \"serving suggestion\", \"serving suggestions\", \"serving\",\n   189→   189→  \"glaze\", \"instrukcje\", \"uwagi\", \"notatki\", \"podawanie\", \"przechowywanie\",\n   190→   190→  \"skladniki\", \"przygotowanie\", \"sposob przygotowania\", \"sposob wykonania\",\n   191→   191→  \"wykonanie\", \"wskazowki\", \"podpowiedz\", \"warianty\",\n   192→   192→  \"sos\", \"nadzienie\", \"polewa\", \"lukier\", \"ciasto\",\n   193→   193→]);\n   194→   194→\n   195→   195→function isAlwaysBlockJoinLabel(text: string): boolean {\n   196→   196→  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n   197→   197→  return ALWAYS_BLOCK_JOIN_LABELS.has(normalized);\n   198→   198→}\n   199→   199→\n   200→   200→function isAllCaps(line: string): boolean {\n   201→   201→  const letters = line.replace(/[^a-zA-Z]/g, \"\");\n   202→   202→  return letters.length > 0 && letters === letters.toUpperCase();\n   203→   203→}\n   204→   204→\n   205→   205→function looksLikeMetadata(text: string): boolean {\n   206→   206→  return METADATA_PATTERNS.some((pattern) => pattern.test(text.trim()));\n   207→   207→}\n   208→   208→\n   209→   209→/** Content words are ≥3 alpha characters after stripping punctuation. */\n   210→   210→function extractContentWords(text: string): string[] {\n   211→   211→  return text\n   212→   212→    .split(/\\s+/)\n   213→   213→    .filter((w) => w.replace(/[^a-zA-ZÀ-ÿ]/g, \"\").length >= 3)\n   214→   214→    .map((w) => w.toUpperCase());\n   215→   215→}\n   216→   216→\n   217→   217→/**\n   218→   218→ * Returns true if the candidate's vocabulary is sufficiently supported by the rest of\n   219→   219→ * the document. Short candidates (≤3 content words) require 100% corroboration;\n   220→   220→ * longer candidates require ≥67%. Used to detect orphaned OCR artifacts in multi-title pages.\n   221→   221→ */\n   222→   222→function passesCorroboration(\n   223→   223→  text: string,\n   224→   224→  position: number,\n   225→   225→  allLines: string[]\n   226→   226→): boolean {\n   227→   227→  const contentWords = extractContentWords(text);\n   228→   228→\n   229→   229→  if (contentWords.length === 0) {\n   230→   230→    return true; // No checkable words — pass through\n   231→   231→  }\n   232→   232→\n   233→   233→  let corroboratedCount = 0;\n   234→   234→  for (const word of contentWords) {\n   235→   235→    for (let i = 0; i < allLines.length; i++) {\n   236→   236→      if (i === position) continue;\n   237→   237→      if (allLines[i].toUpperCase().includes(word)) {\n   238→   238→        corroboratedCount++;\n   239→   239→        break;\n   240→   240→      }\n   241→   241→    }\n   242→   242→  }\n   243→   243→\n   244→   244→  const score = corroboratedCount / contentWords.length;\n   245→   245→  const threshold = contentWords.length <= 3 ? 1.0 : 0.67;\n   246→   246→  return score >= threshold;\n   247→   247→}\n   248→   248→\n   249→   249→function isLikelyGarbled(text: string): boolean {\n   250→   250→  const letters = text.replace(/[^a-zA-Z]/g, \"\");\n   251→   251→  if (letters.length < 2) return true;\n   252→   252→\n   253→   253→  // Pipe embedded in words = OCR artifact (e.g., \"Sp|aszcz\", \"pa|ką\")\n   254→   254→  if (/[a-zA-ZÀ-ÿа-яА-Я]\\|[a-zA-ZÀ-ÿа-яА-Я]/.test(text)) return true;\n   255→   255→\n   256→   256→  // Mixed Latin + Cyrillic = OCR corruption\n   257→   257→  if (/[а-яА-ЯёЁіІїЇєЄґҐ]/.test(text) && /[a-zA-Z]/.test(text)) return true;\n   258→   258→\n   259→   259→  // Check vowel ratio — English/Polish text typically has 30–50% vowels\n   260→   260→  const vowels = letters.replace(/[^aeiouAEIOUyYąęóĄĘÓ]/g, \"\").length;\n   261→   261→  const vowelRatio = vowels / letters.length;\n   262→   262→  if (vowelRatio < 0.10 || vowelRatio > 0.85) return true;\n   263→   263→\n   264→   264→  // Single orphaned word ≤3 letters that isn't a common word\n   265→   265→  const words = text.trim().split(/\\s+/);\n   266→   266→  const COMMON_SHORT = new Set([\n   267→   267→    \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"had\", \"her\",\n   268→   268→    \"was\", \"one\", \"our\", \"out\", \"are\", \"has\", \"his\", \"how\", \"its\", \"may\",\n   269→   269→    \"new\", \"now\", \"old\", \"see\", \"way\", \"who\", \"did\", \"get\", \"let\", \"say\",\n   270→   270→    \"she\", \"too\", \"use\",\n   271→   271→  ]);\n   272→   272→  // Count all Unicode letters (not just ASCII) so Polish words like \"Żur\" (3 letters) pass\n   273→   273→  const unicodeLetters = text.trim().replace(/[^a-zA-ZąćęłńóśźżĄĆĘŁŃÓŚŹŻ]/g, \"\");\n   274→   274→  if (words.length === 1 && unicodeLetters.length <= 3 && !COMMON_SHORT.has(text.trim().toLowerCase())) {\n   275→   275→    return true;\n   276→   276→  }\n   277→   277→\n   278→   278→  // Single word with internal lowercase→uppercase transition — OCR noise (e.g., \"UuIw\", \"aBC\")\n   279→   279→  // No recipe title uses this pattern as a standalone single-word candidate.\n   280→   280→  if (words.length === 1 && /[a-z][A-Z]/.test(text.trim())) {\n   281→   281→    return true;\n   282→   282→  }\n   283→   283→\n   284→   284→  // Recipe titles never start with a lowercase letter\n   285→   285→  if (/^[a-z]/.test(text.trim())) {\n   286→   286→    return true;\n   287→   287→  }\n   288→   288→\n   289→   289→  // Mid-text sentence boundary (\". \" followed by a letter) — body text fragment spliced from multiple sentences\n   290→   290→  const trimmed = text.trim();\n   291→   291→  if (/\\.\\s+[a-zA-Z]/.test(trimmed) && !trimmed.endsWith(\")\")) {\n   292→   292→    return true;\n   293→   293→  }\n   294→   294→\n   295→   295→  // Multi-word candidate containing a garbled OCR fragment: a short lowercase word that isn't a known short word\n   296→   296→  if (words.length >= 2) {\n   297→   297→    const commonShort2 = new Set([\n   298→   298→      \"a\", \"i\", \"of\", \"or\", \"to\", \"in\", \"on\", \"is\", \"it\", \"an\",\n   299→   299→      \"as\", \"at\", \"by\", \"do\", \"go\", \"if\", \"no\", \"so\", \"up\", \"we\",\n   300→   300→      \"w\", \"z\",   // Polish prepositions (basic)\n   301→   301→      \"ze\", \"bo\", \"na\", \"ni\", \"po\", \"ku\", \"od\", \"za\", \"co\",  // Polish prepositions (extended)\n   302→   302→    ]);\n   303→   303→    const hasGarbledWord = words.some(\n   304→   304→      (w) =>\n   305→   305→        /^[a-z]/.test(w) &&\n   306→   306→        w.replace(/[^a-z]/g, \"\").length <= 2 &&\n   307→   307→        !commonShort2.has(w.toLowerCase())\n   308→   308→    );\n   309→   309→    if (hasGarbledWord) {\n   310→   310→      return true;\n   311→   311→    }\n   312→   312→  }\n   313→   313→\n   314→   314→  return false;\n   315→   315→}\n   316→   316→\n   317→   317→const COOKING_INSTRUCTION_STARTS = /^(beat|fold|stir|mix|add|pour|bake|cook|cool|remove|place|combine|whisk|knead|roll|spread|brush|slice|chop|dice|mince|drain|rinse|peel|grate|melt|simmer|boil|fry|sauté|saute|roast|grill|broil|steam|let|set|transfer|serve|garnish|arrange|sprinkle|season|preheat|cover|uncover|reduce|bring|toss|cut|trim|shape|form|scatter|score|pat|rub|skim|strain|heat|discard|rest|marinate|wrap|flip|turn|layer|stuff|drizzle|squeeze|zest|soak|thaw|freeze|chill|warm|toast|crush|pound|crack|break|separate|weigh|measure|sift|dust|coat|dip|dredge|baste|debone|butterfly|truss|shred|puree|blend|process|pulse|whip|cream|proof|rise|punch|divide|portion|assemble)\\b/i;\n   318→   318→\n   319→   319→// Polish imperative cooking verbs (with OCR-resilient forms — no diacritics required).\n   320→   320→// These cover the most common recipe instruction starters. Includes common OCR-corrupted\n   321→   321→// forms (e.g., \"Smaż\" → \"Smaz\", \"Dodaj\" → \"Dodaj\").\n   322→   322→// Note: only verbs that NEVER start a recipe title. \"Piecz\" (bake) is excluded because\n   323→   323→// \"Pieczeń\" (roast) and \"Pieczarki\" (mushrooms) share the prefix.\n   324→   324→const POLISH_COOKING_INSTRUCTION_STARTS = /^(podawaj|dodaj|dodawaj|sma[zż]|gotuj|odced[zź]|wymieszaj|mieszaj|wlej|nalej|przygotuj|zagotuj|pokr[oó]j|obierz|wrzuc|wrzuć|usma[zż]|podsma[zż]|prze[lł][oó][zż]|zblenduj|ubij|roztrzepaj|rozprowad[zź]|wyrob|zamieszaj|posyp|polej|odstaw|na[lł][oó][zż]|przykryj|odkryj|wstaw|zdejmij|ods[aą]cz|rozgrzej|posiekaj|zetrzyj|wy[lł][oó][zż]|wyjmij|ukr[oó]j|przekr[oó]j|formuj|ugniataj|rozwałkuj)\\b/i;\n   325→   325→\n   326→   326→function looksLikeCookingInstruction(text: string): boolean {\n   327→   327→  const words = text.trim().split(/\\s+/);\n   328→   328→  if (words.length < 4) return false;  // Instructions are multi-word sentences\n   329→   329→  if (COOKING_INSTRUCTION_STARTS.test(text.trim())) return true;\n   330→   330→  if (POLISH_COOKING_INSTRUCTION_STARTS.test(text.trim())) return true;\n   331→   331→  return false;\n   332→   332→}\n   333→   333→\n   334→   334→/**\n   335→   335→ * Detect pages where the OCR capture starts mid-recipe with no title present.\n   336→   336→ * Returns true if the first 3 non-empty lines are all ingredients or cooking instructions.\n   337→   337→ */\n   338→   338→function isTitleAbsentPage(lines: Array<string>): boolean {\n   339→   339→  const nonEmptyLines = lines.map(l => l.trim()).filter(l => l.length > 0);\n   340→   340→\n   341→   341→  if (nonEmptyLines.length < 3) return false;\n   342→   342→\n   343→   343→  const first3 = nonEmptyLines.slice(0, 3);\n   344→   344→\n   345→   345→  return first3.every(line => looksLikeIngredient(line) || looksLikeCookingInstruction(line));\n   346→   346→}\n   347→   347→\n   348→   348→function passesHardFilters(text: string): boolean {\n   349→   349→  if (text.length < 3 || text.length > 80) return false;\n   350→   350→  if (looksLikeIngredient(text)) return false;\n   351→   351→  if (startsWithNumber(text)) return false;\n   352→   352→  if (looksLikeMetadata(text)) return false;\n   353→   353→  if (isLikelyGarbled(text)) return false;\n   354→   354→  if (looksLikeCookingInstruction(text)) return false;\n   355→   355→  // Pipe-separated lines are book category/chapter headers, not recipe titles\n   356→   356→  if (text.includes(\" | \")) return false;\n   357→   357→  // Trailing page number (e.g. \"VEGETABLE SIDES                         145\")\n   358→   358→  if (/\\s{3,}\\d{1,4}\\s*$/.test(text)) return false;\n   359→   359→  // Slash-separated breadcrumbs (e.g., \"/ Jesien / Zupy\") are navigation, not titles\n   360→   360→  // Only filter when 2+ slashes are present — single-slash lines like\n   361→   361→  // \"TITLE / SUBTITLE\" are legitimate continuation-merged titles\n   362→   362→  if ((text.match(/\\//g) || []).length >= 2) return false;\n   363→   363→  // Bullet-list items (ingredients or instruction steps) are never titles\n   364→   364→  if (/^\\s*[-•*]\\s/.test(text)) return false;\n   365→   365→  // \"For the sauce:\", \"For the filling:\" etc. are sub-section headers\n   366→   366→  if (/^For the\\s+/i.test(text) && /:\\s*$/.test(text)) return false;\n   367→   367→  // Lines ending with \":\" are recipe sub-section headers, not titles.\n   368→   368→  // Exception: compound titles using \" : \" as a title separator (e.g. \"LEMON CURD : LEMON CURD WITH THYME\").\n   369→   369→  if (/:\\s*$/.test(text.trim()) && !/ : /.test(text)) return false;\n   370→   370→  // Page references are navigation markers, not recipe titles\n   371→   371→  if (/^Page\\s+\\d+/i.test(text.trim())) return false;\n   372→   372→  if (/^Strona\\s+\\d+/i.test(text.trim())) return false;\n   373→   373→  // Corrupted spillover annotations from synthetic multi-page OCR\n   374→   374→  if (/^\\[CORRUPTED\\s+SPILLOVER/i.test(text.trim())) return false;\n   375→   375→  // Parenthetical OCR annotation lines describing corruption artifacts\n   376→   376→  if (/^\\(OCR\\b/i.test(text.trim())) return false;\n   377→   377→  if (/^\\(.*\\bcorruption\\b/i.test(text.trim())) return false;\n   378→   378→  // Square-bracket category tags (e.g., \"[CLASSIC FALL SOUPS]\")\n   379→   379→  if (/^\\[.*\\]$/.test(text.trim())) return false;\n   380→   380→  // Known recipe section labels are structural headers, not titles\n   381→   381→  if (isSectionLabel(text)) return false;\n   382→   382→  // Single-word non-title fragments\n   383→   383→  const words = text.trim().split(/\\s+/);\n   384→   384→  if (words.length === 1 && NON_TITLE_WORDS.has(text.trim().toLowerCase())) return false;\n   385→   385→  // Lines with ≥8 words are almost certainly body text, not titles.\n   386→   386→  // Exception: multi-title compounds with \" + \", \" : \", or \" & \" separators are allowed.\n   387→   387→  if (words.length >= 8 && !/ [+:&/] /.test(text)) return false;\n   388→   388→  return true;\n   389→   389→}\n   390→   390→\n   391→   391→/**\n   392→   392→ * Detect initial burst of short garbled lines.\n   393→   393→ * Returns the index of the first non-garbled or long line.\n   394→   394→ */\n   395→   395→function findBurstEnd(lines: Array<{ text: string }>): number {\n   396→   396→  let i = 0;\n   397→   397→\n   398→   398→  // Skip overflow preambles: blocks introduced by \"PREVIOUS RECIPE OVERFLOW\",\n   399→   399→  // \"PREVIOUS PAGE CONTENT\", \"CORRUPTED SECTION\", etc. that precede the actual recipe.\n   400→   400→  const OVERFLOW_MARKERS = /\\b(PREVIOUS\\s+(RECIPE|PAGE)\\s+(OVERFLOW|CONTENT)|SPILLOVER|CONTINUATION|CORRUPTED\\s+SECTION)\\b/i;\n   401→   401→  let overflowEnd = 0;\n   402→   402→  for (let k = 0; k < lines.length && k < 30; k++) {\n   403→   403→    if (OVERFLOW_MARKERS.test(lines[k].text)) {\n   404→   404→      // Skip forward past the overflow block to the next visual separator or blank cluster\n   405→   405→      let m = k + 1;\n   406→   406→      while (m < lines.length) {\n   407→   407→        if (/^[=\\-]{4,}$/.test(lines[m].text) || lines[m].text.length === 0) {\n   408→   408→          overflowEnd = m + 1;\n   409→   409→          break;\n   410→   410→        }\n   411→   411→        m++;\n   412→   412→      }\n   413→   413→      if (overflowEnd === 0) overflowEnd = k + 1;\n   414→   414→    }\n   415→   415→  }\n   416→   416→  if (overflowEnd > 0) i = overflowEnd;\n   417→   417→\n   418→   418→  while (i < lines.length && lines[i].text.length < 20 && isLikelyGarbled(lines[i].text) && !isAllCaps(lines[i].text)) {\n   419→   419→    i++;\n   420→   420→  }\n   421→   421→  // Skip long instruction-like prologues: if 5+ consecutive lines look like cooking instructions,\n   422→   422→  // skip them to find the actual title region.\n   423→   423→  if (i === 0) {\n   424→   424→    let j = 0;\n   425→   425→    while (j < lines.length && looksLikeCookingInstruction(lines[j].text)) {\n   426→   426→      j++;\n   427→   427→    }\n   428→   428→    if (j >= 5) {\n   429→   429→      i = j;\n   430→   430→    }\n   431→   431→  }\n   432→   432→  // Skip prose prologues: mid-recipe body text before the actual title.\n   433→   433→  // If 3+ consecutive lines look like running body text (lowercase start, continuation,\n   434→   434→  // or sentence-ending with many words), skip them.\n   435→   435→  if (i === 0) {\n   436→   436→    let j = 0;\n   437→   437→    while (j < lines.length) {\n   438→   438→      const t = lines[j].text;\n   439→   439→      const isBodyText = (\n   440→   440→        /^[a-ząćęłńóśźż]/.test(t) ||\n   441→   441→        t.endsWith(\",\") ||\n   442→   442→        (t.endsWith(\".\") && wordCount(t) > 4)\n   443→   443→      ) && wordCount(t) >= 4;\n   444→   444→      if (isBodyText) j++;\n   445→   445→      else break;\n   446→   446→    }\n   447→   447→    if (j >= 3) i = j;\n   448→   448→  }\n   449→   449→  return i;\n   450→   450→}\n   451→   451→\n   452→   452→function stripParentheticalGloss(text: string): string {\n   453→   453→  // Strip trailing English-gloss parentheticals from ALL_CAPS titles.\n   454→   454→  // e.g. \"PIEROGI RUSKIE (Boiled Dumplings with Potato and Cheese)\" → \"PIEROGI RUSKIE\"\n   455→   455→  // Keep if parenthetical is ALL_CAPS (variation/subtitle in same language).\n   456→   456→  // Keep if both base and paren are mixed-case (both are part of the title).\n   457→   457→  const match = text.match(/^(.+?)\\s*\\(([^)]+)\\)\\s*$/);\n   458→   458→  if (!match) return text;\n   459→   459→  const [, base, paren] = match;\n   460→   460→  if (isAllCaps(paren)) return text;\n   461→   461→  if (!isAllCaps(base) && !isAllCaps(paren)) return text;\n   462→   462→  return base.trim();\n   463→   463→}\n   464→   464→\n   465→   465→function stripPageNumber(text: string): string {\n   466→   466→  // \"34  Berry Jam\" → \"Berry Jam\" (2+ spaces distinguishes from \"2 eggs\")\n   467→   467→  const match = text.match(/^\\d{1,3}\\s{2,}(.+)$/);\n   468→   468→  return match ? match[1] : text;\n   469→   469→}\n   470→   470→\n   471→   471→function wordCount(text: string): number {\n   472→   472→  return text.split(/\\s+/).filter((w) => w.length > 0).length;\n   473→   473→}\n   474→   474→\n   475→   475→/**\n   476→   476→ * Build candidate strings from lines: single lines plus multi-line joins (2-3 consecutive).\n   477→   477→ * Skips initial burst of short garbled lines. Scans all remaining lines. Caps at 25.\n   478→   478→ */\n   479→   479→export type CandidateOrigin = \"single\" | \"2-line\" | \"3-line\";\n   480→   480→\n   481→   481→function buildCandidates(\n   482→   482→  lines: Array<string>\n   483→   483→): Array<{ text: string; position: number; origin: CandidateOrigin }> {\n   484→   484→  const nonEmptyLines: Array<{ text: string; index: number }> = [];\n   485→   485→\n   486→   486→  for (let i = 0; i < lines.length; i++) {\n   487→   487→    const trimmed = lines[i].trim();\n   488→   488→    if (trimmed.length > 0) {\n   489→   489→      nonEmptyLines.push({ text: trimmed, index: i });\n   490→   490→    }\n   491→   491→  }\n   492→   492→\n   493→   493→  const burstEnd = findBurstEnd(nonEmptyLines);\n   494→   494→\n   495→   495→  // Pre-join hyphen-broken lines: \"ROASTED CHICKEN WITH ROOT VEGET-\" + \"ABLES\" → single line.\n   496→   496→  // Only applies within the candidate region (after burst end).\n   497→   497→  for (let hi = burstEnd; hi < nonEmptyLines.length - 1; hi++) {\n   498→   498→    if (nonEmptyLines[hi].text.endsWith(\"-\")) {\n   499→   499→      const joined = nonEmptyLines[hi].text.slice(0, -1) + nonEmptyLines[hi + 1].text;\n   500→   500→      nonEmptyLines[hi] = { text: joined, index: nonEmptyLines[hi].index };"}]},"parent_tool_use_id":null,"session_id":"d80e2ded-f7a7-46bb-8be0-f1bcb73047ba","uuid":"c181a8a7-8ad0-4357-9936-3f5259ec4d6e","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/.claude/projects/-Users-eryk-napierala-Projects-fasola/d80e2ded-f7a7-46bb-8be0-f1bcb73047ba/tool-results/toolu_01PPWJXL1KBFfczYAdBvWmcC.txt","content":"     1→/**\n     2→ * Title Extraction\n     3→ * Extracts potential recipe title from OCR text using heuristics or semantic embeddings\n     4→ */\n     5→\n     6→import { cosineSimilarity } from \"./embeddings\";\n     7→import { FOOD_DICTIONARY } from \"./food-dictionary\";\n     8→\n     9→export type EmbedFn = (text: string) => Promise<Array<number>>;\n    10→\n    11→const TITLE_REFERENCE =\n    12→  \"recipe name, dish title, name of the food, nazwa przepisu, nazwa dania\";\n    13→const HEADER_REFERENCE =\n    14→  \"ingredients list, cooking directions, section heading, składniki, przygotowanie, sposób wykonania\";\n    15→const NOISE_REFERENCE =\n    16→  \"page number, table of contents, book footer, garbled text\";\n    17→\n    18→/**\n    19→ * Measurement units commonly found in ingredient lists\n    20→ */\n    21→const MEASUREMENT_PATTERNS = [\n    22→  // English\n    23→  \"cup\",\n    24→  \"cups\",\n    25→  \"tbsp\",\n    26→  \"tsp\",\n    27→  \"tablespoon\",\n    28→  \"teaspoon\",\n    29→  // \"oz\" and \"lb\" are matched with word boundaries in looksLikeIngredient\n    30→  // to avoid false positives (\"oz\" in \"mozzarella\", \"lb\" in \"albacore\")\n    31→  \"gram\",\n    32→  \"grams\",\n    33→  \"kg\",\n    34→  \"ml\",\n    35→  \"liter\",\n    36→  \"pinch\",\n    37→  \"dash\",\n    38→  \"handful\",\n    39→  // Polish\n    40→  \"łyżka\", \"łyżki\", \"łyżek\",           // tablespoon(s)\n    41→  \"łyżeczka\", \"łyżeczki\", \"łyżeczek\",   // teaspoon(s)\n    42→  \"szklanka\", \"szklanki\", \"szklanek\",    // cup(s)\n    43→  \"szczypta\",                            // pinch\n    44→  \"garść\",                               // handful\n    45→  \"opakowanie\", \"opakowania\",            // package(s)\n    46→  \"plasterek\", \"plasterki\",             // slice(s)\n    47→];\n    48→\n    49→/**\n    50→ * Patterns that identify recipe metadata lines (not titles)\n    51→ */\n    52→const METADATA_PATTERNS = [\n    53→  /^(SERVES?|MAKES?|YIELDS?)\\b/i,\n    54→  /^(PREP(ARATION)?|COOK(ING)?|PROOF|RISING|FERMENTATION|REST(ING)?)\\s*(AND\\s*)?(COOK(ING)?)?\\s*TIME/i,\n    55→  /^SAMPLE\\s+SCHEDULE\\b/i,\n    56→  /^BULK\\s+FERMENTATION\\b/i,\n    57→  /^(THIS\\s+RECIPE\\s+)?MAKES\\b/i,\n    58→  // Polish serving-size patterns: \"NA 3 PAPRYKI\", \"NA OKOŁO 1 KG\", \"DLA 4 OSÓB\"\n    59→  /^NA\\s+(\\d|OKOŁO)\\b/i,\n    60→  /^DLA\\s+\\d/i,\n    61→  // OCR-resilient: \"DLA\" + any token + serving-unit word (handles DLA & OSOB, DLA § OSOB, etc.)\n    62→  /^DLA\\s+\\S+\\s+OSOB/i,\n    63→  // OCR-resilient: \"DLA\" + single non-alphanumeric char (common digit→symbol OCR error)\n    64→  /^DLA\\s+[^a-zA-Z0-9\\s]\\s/i,\n    65→  // Time-unit metadata: any line containing \"N MIN\" or \"N GODZ\" is prep/cook/rest time,\n    66→  // regardless of OCR-corrupted prefix (catches PRZYGOTOWANTE, GOTOMANTE, etc.)\n    67→  /\\b\\d+\\s*MIN\\b/i,\n    68→  /\\b\\d+\\s*GODZ/i,\n    69→  // Season/category indicators\n    70→  /^SEZON\\s*:/i,\n    71→  /^KATEGORIA\\s*:/i,\n    72→  /^RODZAJ\\s*:/i,\n    73→  /^PORCJI\\s*:/i,       // Polish serving count\n    74→  /^PORTIONS?\\s*:/i,    // English serving count\n    75→  /^CZ[ĘE]Ś[ĆC]\\s*\\d/i,   // CZĘŚĆ 1: ... (Polish \"Part 1:\")\n    76→  /^PART\\s+\\d/i,             // PART 1: ... (English)\n    77→  /^MAIN\\s+RECIPE\\s*:/i,    // \"MAIN RECIPE: ...\" structural prefix lines\n    78→  /^--\\s*\\w/,               // \"--VARIATION:\", \"--WERSJA NOWOCZESNA\" sub-section headers\n    79→];\n    80→\n    81→/**\n    82→ * Single-word non-title words — standalone OCR fragments unlikely to be recipe titles\n    83→ */\n    84→const NON_TITLE_WORDS = new Set([\n    85→  \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"are\", \"was\",\n    86→  \"has\", \"his\", \"her\", \"its\", \"our\", \"who\", \"how\", \"may\", \"new\", \"now\",\n    87→  \"old\", \"see\", \"way\", \"did\", \"get\", \"let\", \"say\", \"she\", \"too\", \"use\",\n    88→  \"buns\", \"with\",\n    89→]);\n    90→\n    91→function looksLikeIngredient(line: string): boolean {\n    92→  const lowerLine = line.toLowerCase();\n    93→  if (MEASUREMENT_PATTERNS.some((pattern) => lowerLine.includes(pattern))) return true;\n    94→  // Compact metric: \"100g\", \"50ml\", \"250g\" — digit immediately followed by g/ml/kg\n    95→  if (/\\b\\d+\\s*(?:g|ml|kg)\\b/i.test(line)) return true;\n    96→  // \"to taste\" / \"do smaku\" — qualitative ingredient with no unit\n    97→  if (/\\bto taste\\b/i.test(line) || /\\bdo smaku\\b/i.test(line)) return true;\n    98→  return false;\n    99→}\n   100→\n   101→function startsWithNumber(line: string): boolean {\n   102→  // Match lines starting with a digit, or bullet-then-digit (e.g., \"- 2 jajka\")\n   103→  return /^\\s*(?:[-•*]\\s*)?\\d/.test(line);\n   104→}\n   105→\n   106→function stripDiacritics(text: string): string {\n   107→  return text.normalize(\"NFKD\").replace(/[\\u0300-\\u036f]/g, \"\");\n   108→}\n   109→\n   110→/**\n   111→ * Known recipe section labels — these are structural headers, not recipe titles.\n   112→ * Matched case-insensitively after trimming, stripping trailing punctuation, and stripping diacritics.\n   113→ * Polish entries are stored without diacritics for OCR resilience (e.g. \"SKLADNIKI\" matches \"składniki\").\n   114→ */\n   115→const SECTION_LABELS = new Set([\n   116→  // English\n   117→  \"ingredients\", \"directions\", \"instructions\", \"method\", \"preparation\",\n   118→  \"steps\", \"notes\", \"tip\", \"tips\", \"variations\", \"variation\",\n   119→  \"garnish\", \"topping\", \"toppings\", \"frosting\", \"filling\",\n   120→  \"serving suggestion\", \"serving suggestions\", \"serving\",\n   121→  \"glaze\", \"for the sauce\", \"for the filling\", \"for the dough\",\n   122→  \"for the topping\", \"for the glaze\", \"for the pasta dough\",\n   123→  \"for the pasta\", \"for the crust\",\n   124→  // Polish — recipe section labels (stored without diacritics for OCR resilience)\n   125→  \"skladniki\", \"przygotowanie\", \"sposob przygotowania\", \"sposob wykonania\",\n   126→  \"wykonanie\", \"wskazowki\", \"podpowiedz\", \"warianty\",\n   127→  \"sos\", \"nadzienie\", \"polewa\", \"lukier\", \"ciasto\",  // ciasto = dough/pastry base (recipe-internal section AND chapter label)\n   128→  \"instrukcje\",       // instructions\n   129→  \"uwagi\",            // notes/remarks\n   130→  \"notatki\",          // notes\n   131→  \"podawanie\",        // serving\n   132→  \"przechowywanie\",   // storage\n   133→  // Polish — recipe-book chapter/category labels (food groups, meal types)\n   134→  \"warzywa\",          // vegetables\n   135→  \"mieso\",            // meat (mięso)\n   136→  \"miesa\",            // meats (mięsa)\n   137→  \"ryby\",             // fish\n   138→  \"owoce morza\",      // seafood\n   139→  \"zupy\",             // soups\n   140→  \"salatki\",          // salads (sałatki)\n   141→  \"desery\",           // desserts\n   142→  \"napoje\",           // drinks\n   143→  \"pieczywo\",         // bread/baked goods\n   144→  \"przekaski\",        // appetizers/snacks\n   145→  \"sniadania\",        // breakfasts (śniadania)\n   146→  \"obiady\",           // dinners/lunches\n   147→  \"kolacje\",          // suppers\n   148→  \"makarony\",         // pasta dishes\n   149→  \"kasza\",            // groats/grains\n   150→  \"kasze\",            // groats/grains (plural)\n   151→  \"dania glowne\",     // main courses (dania główne)\n   152→  \"przystawki\",       // starters\n   153→  \"dodatki\",          // side dishes\n   154→  \"przetwory\",        // preserves\n   155→  \"wypieki\",          // baked goods\n   156→  \"ciasta\",           // cakes (plural)\n   157→  \"ciastka\",          // cookies\n   158→  \"torty\",            // layer cakes\n   159→  // \"placki\" removed — it commonly starts recipe titles like \"Placki Ziemniaczane\", \"Placki Żółte z Kukurydzą\"\n   160→  \"koktajle\",         // cocktails/smoothies\n   161→  // English — recipe-book chapter/category labels\n   162→  \"vegetables\", \"seafood\", \"fish\", \"soups\", \"salads\", \"desserts\",\n   163→  \"appetizers\", \"breads\", \"breakfast\", \"pasta\", \"grains\",\n   164→  \"main courses\", \"side dishes\", \"preserves\", \"baked goods\",\n   165→  \"fish & seafood\", \"soups & broths\", \"desserts & baked goods\",\n   166→  \"meats\", \"poultry\", \"game\",\n   167→]);\n   168→\n   169→function isSectionLabel(text: string): boolean {\n   170→  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n   171→  if (SECTION_LABELS.has(normalized)) return true;\n   172→  // OCR variant: leading \"l\" may be OCR-corrupted \"I\" (e.g. \"lngredients\" → \"ingredients\")\n   173→  const ocrNormalized = normalized.replace(/^l/, \"i\");\n   174→  if (ocrNormalized !== normalized && SECTION_LABELS.has(ocrNormalized)) return true;\n   175→  return false;\n   176→}\n   177→\n   178→/**\n   179→ * Recipe-internal section labels that should ALWAYS block multi-line joins,\n   180→ * even when the combined word count is ≥ 3.\n   181→ * Category labels (\"zupy\", \"placki\", etc.) are NOT in this set — they can\n   182→ * legitimately start a multi-word recipe title like \"Zupy Zimowe Warzywne\".\n   183→ */\n   184→const ALWAYS_BLOCK_JOIN_LABELS = new Set([\n   185→  \"ingredients\", \"directions\", \"instructions\", \"method\", \"preparation\",\n   186→  \"steps\", \"notes\", \"tip\", \"tips\", \"variations\", \"variation\",\n   187→  \"garnish\", \"topping\", \"toppings\", \"frosting\", \"filling\",\n   188→  \"serving suggestion\", \"serving suggestions\", \"serving\",\n   189→  \"glaze\", \"instrukcje\", \"uwagi\", \"notatki\", \"podawanie\", \"przechowywanie\",\n   190→  \"skladniki\", \"przygotowanie\", \"sposob przygotowania\", \"sposob wykonania\",\n   191→  \"wykonanie\", \"wskazowki\", \"podpowiedz\", \"warianty\",\n   192→  \"sos\", \"nadzienie\", \"polewa\", \"lukier\", \"ciasto\",\n   193→]);\n   194→\n   195→function isAlwaysBlockJoinLabel(text: string): boolean {\n   196→  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n   197→  return ALWAYS_BLOCK_JOIN_LABELS.has(normalized);\n   198→}\n   199→\n   200→function isAllCaps(line: string): boolean {\n   201→  const letters = line.replace(/[^a-zA-Z]/g, \"\");\n   202→  return letters.length > 0 && letters === letters.toUpperCase();\n   203→}\n   204→\n   205→function looksLikeMetadata(text: string): boolean {\n   206→  return METADATA_PATTERNS.some((pattern) => pattern.test(text.trim()));\n   207→}\n   208→\n   209→/** Content words are ≥3 alpha characters after stripping punctuation. */\n   210→function extractContentWords(text: string): string[] {\n   211→  return text\n   212→    .split(/\\s+/)\n   213→    .filter((w) => w.replace(/[^a-zA-ZÀ-ÿ]/g, \"\").length >= 3)\n   214→    .map((w) => w.toUpperCase());\n   215→}\n   216→\n   217→/**\n   218→ * Returns true if the candidate's vocabulary is sufficiently supported by the rest of\n   219→ * the document. Short candidates (≤3 content words) require 100% corroboration;\n   220→ * longer candidates require ≥67%. Used to detect orphaned OCR artifacts in multi-title pages.\n   221→ */\n   222→function passesCorroboration(\n   223→  text: string,\n   224→  position: number,\n   225→  allLines: string[]\n   226→): boolean {\n   227→  const contentWords = extractContentWords(text);\n   228→\n   229→  if (contentWords.length === 0) {\n   230→    return true; // No checkable words — pass through\n   231→  }\n   232→\n   233→  let corroboratedCount = 0;\n   234→  for (const word of contentWords) {\n   235→    for (let i = 0; i < allLines.length; i++) {\n   236→      if (i === position) continue;\n   237→      if (allLines[i].toUpperCase().includes(word)) {\n   238→        corroboratedCount++;\n   239→        break;\n   240→      }\n   241→    }\n   242→  }\n   243→\n   244→  const score = corroboratedCount / contentWords.length;\n   245→  const threshold = contentWords.length <= 3 ? 1.0 : 0.67;\n   246→  return score >= threshold;\n   247→}\n   248→\n   249→function isLikelyGarbled(text: string): boolean {\n   250→  const letters = text.replace(/[^a-zA-Z]/g, \"\");\n   251→  if (letters.length < 2) return true;\n   252→\n   253→  // Pipe embedded in words = OCR artifact (e.g., \"Sp|aszcz\", \"pa|ką\")\n   254→  if (/[a-zA-ZÀ-ÿа-яА-Я]\\|[a-zA-ZÀ-ÿа-яА-Я]/.test(text)) return true;\n   255→\n   256→  // Mixed Latin + Cyrillic = OCR corruption\n   257→  if (/[а-яА-ЯёЁіІїЇєЄґҐ]/.test(text) && /[a-zA-Z]/.test(text)) return true;\n   258→\n   259→  // Check vowel ratio — English/Polish text typically has 30–50% vowels\n   260→  const vowels = letters.replace(/[^aeiouAEIOUyYąęóĄĘÓ]/g, \"\").length;\n   261→  const vowelRatio = vowels / letters.length;\n   262→  if (vowelRatio < 0.10 || vowelRatio > 0.85) return true;\n   263→\n   264→  // Single orphaned word ≤3 letters that isn't a common word\n   265→  const words = text.trim().split(/\\s+/);\n   266→  const COMMON_SHORT = new Set([\n   267→    \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"had\", \"her\",\n   268→    \"was\", \"one\", \"our\", \"out\", \"are\", \"has\", \"his\", \"how\", \"its\", \"may\",\n   269→    \"new\", \"now\", \"old\", \"see\", \"way\", \"who\", \"did\", \"get\", \"let\", \"say\",\n   270→    \"she\", \"too\", \"use\",\n   271→  ]);\n   272→  // Count all Unicode letters (not just ASCII) so Polish words like \"Żur\" (3 letters) pass\n   273→  const unicodeLetters = text.trim().replace(/[^a-zA-ZąćęłńóśźżĄĆĘŁŃÓŚŹŻ]/g, \"\");\n   274→  if (words.length === 1 && unicodeLetters.length <= 3 && !COMMON_SHORT.has(text.trim().toLowerCase())) {\n   275→    return true;\n   276→  }\n   277→\n   278→  // Single word with internal lowercase→uppercase transition — OCR noise (e.g., \"UuIw\", \"aBC\")\n   279→  // No recipe title uses this pattern as a standalone single-word candidate.\n   280→  if (words.length === 1 && /[a-z][A-Z]/.test(text.trim())) {\n   281→    return true;\n   282→  }\n   283→\n   284→  // Recipe titles never start with a lowercase letter\n   285→  if (/^[a-z]/.test(text.trim())) {\n   286→    return true;\n   287→  }\n   288→\n   289→  // Mid-text sentence boundary (\". \" followed by a letter) — body text fragment spliced from multiple sentences\n   290→  const trimmed = text.trim();\n   291→  if (/\\.\\s+[a-zA-Z]/.test(trimmed) && !trimmed.endsWith(\")\")) {\n   292→    return true;\n   293→  }\n   294→\n   295→  // Multi-word candidate containing a garbled OCR fragment: a short lowercase word that isn't a known short word\n   296→  if (words.length >= 2) {\n   297→    const commonShort2 = new Set([\n   298→      \"a\", \"i\", \"of\", \"or\", \"to\", \"in\", \"on\", \"is\", \"it\", \"an\",\n   299→      \"as\", \"at\", \"by\", \"do\", \"go\", \"if\", \"no\", \"so\", \"up\", \"we\",\n   300→      \"w\", \"z\",   // Polish prepositions (basic)\n   301→      \"ze\", \"bo\", \"na\", \"ni\", \"po\", \"ku\", \"od\", \"za\", \"co\",  // Polish prepositions (extended)\n   302→    ]);\n   303→    const hasGarbledWord = words.some(\n   304→      (w) =>\n   305→        /^[a-z]/.test(w) &&\n   306→        w.replace(/[^a-z]/g, \"\").length <= 2 &&\n   307→        !commonShort2.has(w.toLowerCase())\n   308→    );\n   309→    if (hasGarbledWord) {\n   310→      return true;\n   311→    }\n   312→  }\n   313→\n   314→  return false;\n   315→}\n   316→\n   317→const COOKING_INSTRUCTION_STARTS = /^(beat|fold|stir|mix|add|pour|bake|cook|cool|remove|place|combine|whisk|knead|roll|spread|brush|slice|chop|dice|mince|drain|rinse|peel|grate|melt|simmer|boil|fry|sauté|saute|roast|grill|broil|steam|let|set|transfer|serve|garnish|arrange|sprinkle|season|preheat|cover|uncover|reduce|bring|toss|cut|trim|shape|form|scatter|score|pat|rub|skim|strain|heat|discard|rest|marinate|wrap|flip|turn|layer|stuff|drizzle|squeeze|zest|soak|thaw|freeze|chill|warm|toast|crush|pound|crack|break|separate|weigh|measure|sift|dust|coat|dip|dredge|baste|debone|butterfly|truss|shred|puree|blend|process|pulse|whip|cream|proof|rise|punch|divide|portion|assemble)\\b/i;\n   318→\n   319→// Polish imperative cooking verbs (with OCR-resilient forms — no diacritics required).\n   320→// These cover the most common recipe instruction starters. Includes common OCR-corrupted\n   321→// forms (e.g., \"Smaż\" → \"Smaz\", \"Dodaj\" → \"Dodaj\").\n   322→// Note: only verbs that NEVER start a recipe title. \"Piecz\" (bake) is excluded because\n   323→// \"Pieczeń\" (roast) and \"Pieczarki\" (mushrooms) share the prefix.\n   324→const POLISH_COOKING_INSTRUCTION_STARTS = /^(podawaj|dodaj|dodawaj|sma[zż]|gotuj|odced[zź]|wymieszaj|mieszaj|wlej|nalej|przygotuj|zagotuj|pokr[oó]j|obierz|wrzuc|wrzuć|usma[zż]|podsma[zż]|prze[lł][oó][zż]|zblenduj|ubij|roztrzepaj|rozprowad[zź]|wyrob|zamieszaj|posyp|polej|odstaw|na[lł][oó][zż]|przykryj|odkryj|wstaw|zdejmij|ods[aą]cz|rozgrzej|posiekaj|zetrzyj|wy[lł][oó][zż]|wyjmij|ukr[oó]j|przekr[oó]j|formuj|ugniataj|rozwałkuj)\\b/i;\n   325→\n   326→function looksLikeCookingInstruction(text: string): boolean {\n   327→  const words = text.trim().split(/\\s+/);\n   328→  if (words.length < 4) return false;  // Instructions are multi-word sentences\n   329→  if (COOKING_INSTRUCTION_STARTS.test(text.trim())) return true;\n   330→  if (POLISH_COOKING_INSTRUCTION_STARTS.test(text.trim())) return true;\n   331→  return false;\n   332→}\n   333→\n   334→/**\n   335→ * Detect pages where the OCR capture starts mid-recipe with no title present.\n   336→ * Returns true if the first 3 non-empty lines are all ingredients or cooking instructions.\n   337→ */\n   338→function isTitleAbsentPage(lines: Array<string>): boolean {\n   339→  const nonEmptyLines = lines.map(l => l.trim()).filter(l => l.length > 0);\n   340→\n   341→  if (nonEmptyLines.length < 3) return false;\n   342→\n   343→  const first3 = nonEmptyLines.slice(0, 3);\n   344→\n   345→  return first3.every(line => looksLikeIngredient(line) || looksLikeCookingInstruction(line));\n   346→}\n   347→\n   348→function passesHardFilters(text: string): boolean {\n   349→  if (text.length < 3 || text.length > 80) return false;\n   350→  if (looksLikeIngredient(text)) return false;\n   351→  if (startsWithNumber(text)) return false;\n   352→  if (looksLikeMetadata(text)) return false;\n   353→  if (isLikelyGarbled(text)) return false;\n   354→  if (looksLikeCookingInstruction(text)) return false;\n   355→  // Pipe-separated lines are book category/chapter headers, not recipe titles\n   356→  if (text.includes(\" | \")) return false;\n   357→  // Trailing page number (e.g. \"VEGETABLE SIDES                         145\")\n   358→  if (/\\s{3,}\\d{1,4}\\s*$/.test(text)) return false;\n   359→  // Slash-separated breadcrumbs (e.g., \"/ Jesien / Zupy\") are navigation, not titles\n   360→  // Only filter when 2+ slashes are present — single-slash lines like\n   361→  // \"TITLE / SUBTITLE\" are legitimate continuation-merged titles\n   362→  if ((text.match(/\\//g) || []).length >= 2) return false;\n   363→  // Bullet-list items (ingredients or instruction steps) are never titles\n   364→  if (/^\\s*[-•*]\\s/.test(text)) return false;\n   365→  // \"For the sauce:\", \"For the filling:\" etc. are sub-section headers\n   366→  if (/^For the\\s+/i.test(text) && /:\\s*$/.test(text)) return false;\n   367→  // Lines ending with \":\" are recipe sub-section headers, not titles.\n   368→  // Exception: compound titles using \" : \" as a title separator (e.g. \"LEMON CURD : LEMON CURD WITH THYME\").\n   369→  if (/:\\s*$/.test(text.trim()) && !/ : /.test(text)) return false;\n   370→  // Page references are navigation markers, not recipe titles\n   371→  if (/^Page\\s+\\d+/i.test(text.trim())) return false;\n   372→  if (/^Strona\\s+\\d+/i.test(text.trim())) return false;\n   373→  // Corrupted spillover annotations from synthetic multi-page OCR\n   374→  if (/^\\[CORRUPTED\\s+SPILLOVER/i.test(text.trim())) return false;\n   375→  // Parenthetical OCR annotation lines describing corruption artifacts\n   376→  if (/^\\(OCR\\b/i.test(text.trim())) return false;\n   377→  if (/^\\(.*\\bcorruption\\b/i.test(text.trim())) return false;\n   378→  // Square-bracket category tags (e.g., \"[CLASSIC FALL SOUPS]\")\n   379→  if (/^\\[.*\\]$/.test(text.trim())) return false;\n   380→  // Known recipe section labels are structural headers, not titles\n   381→  if (isSectionLabel(text)) return false;\n   382→  // Single-word non-title fragments\n   383→  const words = text.trim().split(/\\s+/);\n   384→  if (words.length === 1 && NON_TITLE_WORDS.has(text.trim().toLowerCase())) return false;\n   385→  // Lines with ≥8 words are almost certainly body text, not titles.\n   386→  // Exception: multi-title compounds with \" + \", \" : \", or \" & \" separators are allowed.\n   387→  if (words.length >= 8 && !/ [+:&/] /.test(text)) return false;\n   388→  return true;\n   389→}\n   390→\n   391→/**\n   392→ * Detect initial burst of short garbled lines.\n   393→ * Returns the index of the first non-garbled or long line.\n   394→ */\n   395→function findBurstEnd(lines: Array<{ text: string }>): number {\n   396→  let i = 0;\n   397→\n   398→  // Skip overflow preambles: blocks introduced by \"PREVIOUS RECIPE OVERFLOW\",\n   399→  // \"PREVIOUS PAGE CONTENT\", \"CORRUPTED SECTION\", etc. that precede the actual recipe.\n   400→  const OVERFLOW_MARKERS = /\\b(PREVIOUS\\s+(RECIPE|PAGE)\\s+(OVERFLOW|CONTENT)|SPILLOVER|CONTINUATION|CORRUPTED\\s+SECTION)\\b/i;\n   401→  let overflowEnd = 0;\n   402→  for (let k = 0; k < lines.length && k < 30; k++) {\n   403→    if (OVERFLOW_MARKERS.test(lines[k].text)) {\n   404→      // Skip forward past the overflow block to the next visual separator or blank cluster\n   405→      let m = k + 1;\n   406→      while (m < lines.length) {\n   407→        if (/^[=\\-]{4,}$/.test(lines[m].text) || lines[m].text.length === 0) {\n   408→          overflowEnd = m + 1;\n   409→          break;\n   410→        }\n   411→        m++;\n   412→      }\n   413→      if (overflowEnd === 0) overflowEnd = k + 1;\n   414→    }\n   415→  }\n   416→  if (overflowEnd > 0) i = overflowEnd;\n   417→\n   418→  while (i < lines.length && lines[i].text.length < 20 && isLikelyGarbled(lines[i].text) && !isAllCaps(lines[i].text)) {\n   419→    i++;\n   420→  }\n   421→  // Skip long instruction-like prologues: if 5+ consecutive lines look like cooking instructions,\n   422→  // skip them to find the actual title region.\n   423→  if (i === 0) {\n   424→    let j = 0;\n   425→    while (j < lines.length && looksLikeCookingInstruction(lines[j].text)) {\n   426→      j++;\n   427→    }\n   428→    if (j >= 5) {\n   429→      i = j;\n   430→    }\n   431→  }\n   432→  // Skip prose prologues: mid-recipe body text before the actual title.\n   433→  // If 3+ consecutive lines look like running body text (lowercase start, continuation,\n   434→  // or sentence-ending with many words), skip them.\n   435→  if (i === 0) {\n   436→    let j = 0;\n   437→    while (j < lines.length) {\n   438→      const t = lines[j].text;\n   439→      const isBodyText = (\n   440→        /^[a-ząćęłńóśźż]/.test(t) ||\n   441→        t.endsWith(\",\") ||\n   442→        (t.endsWith(\".\") && wordCount(t) > 4)\n   443→      ) && wordCount(t) >= 4;\n   444→      if (isBodyText) j++;\n   445→      else break;\n   446→    }\n   447→    if (j >= 3) i = j;\n   448→  }\n   449→  return i;\n   450→}\n   451→\n   452→function stripParentheticalGloss(text: string): string {\n   453→  // Strip trailing English-gloss parentheticals from ALL_CAPS titles.\n   454→  // e.g. \"PIEROGI RUSKIE (Boiled Dumplings with Potato and Cheese)\" → \"PIEROGI RUSKIE\"\n   455→  // Keep if parenthetical is ALL_CAPS (variation/subtitle in same language).\n   456→  // Keep if both base and paren are mixed-case (both are part of the title).\n   457→  const match = text.match(/^(.+?)\\s*\\(([^)]+)\\)\\s*$/);\n   458→  if (!match) return text;\n   459→  const [, base, paren] = match;\n   460→  if (isAllCaps(paren)) return text;\n   461→  if (!isAllCaps(base) && !isAllCaps(paren)) return text;\n   462→  return base.trim();\n   463→}\n   464→\n   465→function stripPageNumber(text: string): string {\n   466→  // \"34  Berry Jam\" → \"Berry Jam\" (2+ spaces distinguishes from \"2 eggs\")\n   467→  const match = text.match(/^\\d{1,3}\\s{2,}(.+)$/);\n   468→  return match ? match[1] : text;\n   469→}\n   470→\n   471→function wordCount(text: string): number {\n   472→  return text.split(/\\s+/).filter((w) => w.length > 0).length;\n   473→}\n   474→\n   475→/**\n   476→ * Build candidate strings from lines: single lines plus multi-line joins (2-3 consecutive).\n   477→ * Skips initial burst of short garbled lines. Scans all remaining lines. Caps at 25.\n   478→ */\n   479→export type CandidateOrigin = \"single\" | \"2-line\" | \"3-line\";\n   480→\n   481→function buildCandidates(\n   482→  lines: Array<string>\n   483→): Array<{ text: string; position: number; origin: CandidateOrigin }> {\n   484→  const nonEmptyLines: Array<{ text: string; index: number }> = [];\n   485→\n   486→  for (let i = 0; i < lines.length; i++) {\n   487→    const trimmed = lines[i].trim();\n   488→    if (trimmed.length > 0) {\n   489→      nonEmptyLines.push({ text: trimmed, index: i });\n   490→    }\n   491→  }\n   492→\n   493→  const burstEnd = findBurstEnd(nonEmptyLines);\n   494→\n   495→  // Pre-join hyphen-broken lines: \"ROASTED CHICKEN WITH ROOT VEGET-\" + \"ABLES\" → single line.\n   496→  // Only applies within the candidate region (after burst end).\n   497→  for (let hi = burstEnd; hi < nonEmptyLines.length - 1; hi++) {\n   498→    if (nonEmptyLines[hi].text.endsWith(\"-\")) {\n   499→      const joined = nonEmptyLines[hi].text.slice(0, -1) + nonEmptyLines[hi + 1].text;\n   500→      nonEmptyLines[hi] = { text: joined, index: nonEmptyLines[hi].index };","numLines":500,"startLine":1,"totalLines":1436}}}
