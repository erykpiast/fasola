      return sLower.startsWith(tLower) ||\n  1029→                 sLower.endsWith(\" \" + tLower) ||\n  1030→                 sLower.includes(\" \" + tLower);\n  1031→        });\n  1032→      });\n  1033→    }\n  1034→  }\n  1035→\n  1036→  // Fix 2: If the structural heading was identified as a bilingual translation, reassign it.\n  1037→  // This prevents the translation's ALL_CAPS bonus from inflating the threshold and ensures\n  1038→  // the fallback path in scored also uses the correct heading.\n  1039→  if (\n  1040→    translationCandidates.length > 0 &&\n  1041→    firstStructuralHeading &&\n  1042→    translationCandidates.some((t) => t.text === firstStructuralHeading!.text)\n  1043→  ) {\n  1044→    const nonTranslationStructural = structuralCandidates.filter(\n  1045→      (sc) => !translationCandidates.some((t) => t.text === sc.text)\n  1046→    );\n  1047→    const newHeading = nonTranslationStructural.length > 0\n  1048→      ? nonTranslationStructural.reduce((a, b) => a.rawScore > b.rawScore ? a : b)\n  1049→      : undefined;\n  1050→\n  1051→    // Patch scored array: remove old structural bonus, apply new one\n  1052→    for (const s of scored) {\n  1053→      if (s.text === firstStructuralHeading.text) {\n  1054→        s.score -= 0.10;\n  1055→        s.baseScore -= 0.10;\n  1056→      }\n  1057→      if (newHeading && s.text === newHeading.text) {\n  1058→        s.score += 0.10;\n  1059→        s.baseScore += 0.10;\n  1060→      }\n  1061→    }\n  1062→    // Update reference for downstream prefix-removal logic\n  1063→    firstStructuralHeading = newHeading ?? undefined;\n  1064→  }\n  1065→\n  1066→  // Subtitle suppression: when a short mixed-case title at position 0 is followed by a\n  1067→  // longer mixed-case candidate at position 1-2, the longer one is a subtitle/translation.\n  1068→  // Apply a penalty so the primary title (position 0) wins.\n  1069→  const pos0Primary = scored.find((s) => s.position === 0 && !isAllCaps(s.text) && wordCount(s.text) <= 5);\n  1070→  if (pos0Primary) {\n  1071→    const subtitleCandidates = scored.filter((s) =>\n  1072→      s.position >= 1 && s.position <= 2 &&\n  1073→      !isAllCaps(s.text) &&\n  1074→      wordCount(s.text) > wordCount(pos0Primary.text) + 2\n  1075→    );\n  1076→    for (const sub of subtitleCandidates) {\n  1077→      sub.score -= 0.15;\n  1078→    }\n  1079→  }\n  1080→\n  1081→  // Bilingual layout pattern: [FoodName (≤2 words)]\\n[Translation (2-5 words, mixed-case)]\\n...[Section label]\n  1082→  // Common in bilingual cookbooks: foreign food name at position 0, English translation at position 1-2.\n  1083→  // When detected, boost the position-0 candidate so it clears the threshold.\n  1084→  // Note: the ALL_CAPS bilingual block above (lines 940-995) handles mixed-case + ALL_CAPS pairs.\n  1085→  // This block handles mixed-case + mixed-case translation pairs — the two do not overlap because\n  1086→  // the mixed-case guard (`biSecond.text !== biSecond.text.toUpperCase()`) excludes ALL_CAPS lines.\n  1087→  if (scored.length >= 2) {\n  1088→    const biFirst = scored.find((s) => s.position === 0);\n  1089→    // Restrict to single-line candidates (same guard as the ALL_CAPS bilingual block at line 953)\n  1090→    const biSecond = scored.find((s) => s.position >= 1 && s.position <= 2 && s !== biFirst && s.origin === \"single\");\n  1091→\n  1092→    if (biFirst && biSecond) {\n  1093→      const firstWords = biFirst.text.trim().split(/\\s+/);\n  1094→      const secondWords = biSecond.text.trim().split(/\\s+/);\n  1095→\n  1096→      const isBilingualLayout =\n  1097→        firstWords.length <= 2 &&\n  1098→        secondWords.length >= 2 &&\n  1099→        secondWords.length <= 5 &&\n  1100→        // Second line is mixed-case (not ALL_CAPS, not all-lower)\n  1101→        biSecond.text !== biSecond.text.toUpperCase() &&\n  1102→        biSecond.text !== biSecond.text.toLowerCase() &&\n  1103→        // Second line is not an ingredient or instruction\n  1104→        !looksLikeIngredient(biSecond.text) &&\n  1105→        !looksLikeCookingInstruction(biSecond.text);\n  1106→\n  1107→      if (isBilingualLayout) {\n  1108→        // Check if a section label follows within a few lines after the first candidate\n  1109→        const sectionLabelNearby = lines\n  1110→          .slice(biFirst.position + 1, biFirst.position + 6)\n  1111→          .some((line) => isSectionLabel(line.trim()));\n  1112→\n  1113→        if (sectionLabelNearby) {\n  1114→          biFirst.score += 0.15;\n  1115→          biFirst.baseScore += 0.15;\n  1116→          biFirst.thresholdScore += 0.15;\n  1117→        }\n  1118→      }\n  1119→    }\n  1120→  }\n  1121→\n  1122→  // Pre-filter: when ≥2 ALL_CAPS candidates are present, identify OCR artifacts (those whose\n  1123→  // vocabulary has no support elsewhere in the document) and remove them before computing the\n  1124→  // threshold. Artifacts like \"DAT FLATBREADS\" can inflate the threshold via their early-position\n  1125→  // bonus, which causes legitimate titles later in the document to fall just below the cutoff.\n  1126→  // Safety: only pre-filter if ≥2 candidates remain after removal (avoids false-positive removal\n  1127→  // of unique-vocabulary titles on two-recipe pages).\n  1128→  const allCapsInScored = scoredForThreshold.filter((s) => isAllCaps(s.text));\n  1129→  if (allCapsInScored.length >= 2) {\n  1130→    const artifactTexts = new Set(\n  1131→      allCapsInScored\n  1132→        .filter((cap) => !passesCorroboration(cap.text, cap.position, lines))\n  1133→        .map((c) => c.text)\n  1134→    );\n  1135→    if (artifactTexts.size > 0) {\n  1136→      const remainingCaps = allCapsInScored.filter((c) => !artifactTexts.has(c.text));\n  1137→      if (remainingCaps.length >= 2) {\n  1138→        scoredForThreshold = scoredForThreshold.filter((s) => !artifactTexts.has(s.text));\n  1139→      }\n  1140→    }\n  1141→  }\n  1142→\n  1143→  // Use thresholdScore (excludes structural bonus) so the structural bonus doesn't inflate\n  1144→  // the threshold and block equally-valid headings on multi-recipe pages.\n  1145→  const bestThresholdScore = Math.max(...scoredForThreshold.map((s) => s.thresholdScore));\n  1146→  const threshold = Math.max(0.08, bestThresholdScore * 0.7);\n  1147→\n  1148→  // Filter candidates above threshold\n  1149→  let selected = scoredForThreshold.filter((s) => s.score >= threshold);\n  1150→\n  1151→  // Empty-pool fallback: when threshold filtering discards every candidate,\n  1152→  // the hard filters' structural verdict should not be overruled by weak\n  1153→  // embedding differentiation. Return the best positional candidate only\n  1154→  // if it has a meaningful positive raw score (avoids ingredient-list leakage).\n  1155→  if (selected.length === 0 && scored.length > 0) {\n  1156→    const fallback = scored\n  1157→      .slice()\n  1158→      .sort((a, b) => a.position - b.position || b.score - a.score);\n  1159→    // Position-0 candidates that passed hard filters are very likely titles even with\n  1160→    // weak embedding signal. Relax the rawScore guard for early-position candidates.\n  1161→    const rawScoreThreshold = fallback[0].position <= 2 ? -0.05 : 0.02;\n  1162→    if (fallback[0].rawScore > rawScoreThreshold) {\n  1163→      selected = [fallback[0]];\n  1164→    }\n  1165→  }\n  1166→\n  1167→  // Title-absent page guard: when the page starts mid-recipe (all of the first 3 non-empty\n  1168→  // lines are ingredients or cooking instructions), require a much higher rawScore and\n  1169→  // discard candidates deep in the file. This prevents stray body text or adjacent recipe\n  1170→  // titles from being picked up on pages with no title (Pattern 4).\n  1171→  if (titleAbsent) {\n  1172→    const titleAbsentThreshold = 0.10;\n  1173→    selected = selected.filter(s => s.rawScore >= titleAbsentThreshold);\n  1174→    selected = selected.filter(s => s.position <= 2);\n  1175→  }\n  1176→\n  1177→  // Remove word-boundary prefixes of firstStructuralHeading when the heading itself survived\n  1178→  // the threshold. Cases:\n  1179→  //   ARAYES case:  firstStructuralHeading = \"ARAYES SHRAK\" (2-word join qualifies; \"ARAYES\"\n  1180→  //     alone = 1 word, so it never qualified). Filter removes \"ARAYES\" so dedup keeps the join.\n  1181→  //   SAFFRON case: baseHeading was the partial line; continuation logic above upgraded\n  1182→  //     firstStructuralHeading to the full join. Filter removes the partial so dedup keeps join.\n  1183→  // Safety: only fires when the complete heading itself is in selected (passed the threshold).\n  1184→  if (firstStructuralHeading && selected.some((s) => s.text === firstStructuralHeading.text)) {\n  1185→    const fshLower = firstStructuralHeading.text.toLowerCase();\n  1186→    selected = selected.filter((s) => {\n  1187→      if (s.text === firstStructuralHeading.text) return true;\n  1188→      const sLower = s.text.toLowerCase();\n  1189→      // Remove s if it is a space-delimited prefix of the structural heading\n  1190→      return !fshLower.startsWith(sLower + \" \");\n  1191→    });\n  1192→  }\n  1193→\n  1194→  // Protect continuation joins: when a multi-line join (2-line or 3-line) survived the threshold\n  1195→  // and its second part starts with a continuation character, remove the single-line prefix/suffix\n  1196→  // so the dedup \"shorter wins\" rule doesn't destroy the complete join.\n  1197→  // Note: the pre-merge step above already handles the common Baked Eggs case (&/continuation\n  1198→  // on next line) by turning it into a single candidate — this block covers the rarer case where\n  1199→  // a continuation-character join was generated as a 2-line/3-line candidate and the prefix\n  1200→  // single also survived threshold independently (e.g. from a different code path or OCR layout).\n  1201→  // Safety: only fires for joins whose continuation starts with /&+:( — digit continuations\n  1202→  // like \"Pierogi Ruskie 200g mąki\" are NOT protected, so dedup correctly keeps the shorter form.\n  1203→  const survivingJoins = selected.filter((s) => s.origin === \"2-line\" || s.origin === \"3-line\");\n  1204→  if (survivingJoins.length > 0) {\n  1205→    selected = selected.filter((s) => {\n  1206→      if (s.origin !== \"single\") return true;\n  1207→      const sLower = s.text.toLowerCase();\n  1208→      // Remove PREFIX singles whose continuation join also survived\n  1209→      const isPrefixOfJoin = survivingJoins.some((j) => {\n  1210→        const jLower = j.text.toLowerCase();\n  1211→        if (!jLower.startsWith(sLower + \" \")) return false;\n  1212→        const remainder = jLower.slice(sLower.length + 1);\n  1213→        return /^[/&+:(]/.test(remainder);\n  1214→      });\n  1215→      if (isPrefixOfJoin) return false;\n  1216→      // Remove SUFFIX singles (e.g. \"& Coriander\") whose parent join also survived\n  1217→      const isSuffixOfJoin = survivingJoins.some((j) => {\n  1218→        const jLower = j.text.toLowerCase();\n  1219→        if (!jLower.endsWith(\" \" + sLower)) return false;\n  1220→        // Only remove if the suffix starts with a continuation character\n  1221→        return /^[/&+:(]/.test(sLower);\n  1222→      });\n  1223→      if (isSuffixOfJoin) return false;\n  1224→      return true;\n  1225→    });\n  1226→  }\n  1227→\n  1228→  // Pre-dedup: remove sub-section headers that are substrings of other surviving candidates.\n  1229→  // A sub-section header is an ALL_CAPS candidate followed by ingredient-like lines in the source.\n  1230→  // Example: \"CHLEBEK\" (bread section header, followed by \"500 g mąki\") is a substring of\n  1231→  // \"CHLEBEK Z WARZYWAMI I BOCZKIEM\" (the real title). Without this filter, dedup kills the title.\n  1232→  selected = selected.filter((candidate) => {\n  1233→    if (!isAllCaps(candidate.text)) return true;\n  1234→    // Check if this candidate is immediately followed by ingredient-like content\n  1235→    const nextSourceLines = lines.slice(candidate.position + 1, candidate.position + 2);\n  1236→    const followedByIngredients = nextSourceLines.some(\n  1237→      (l) => looksLikeIngredient(l.trim()) || startsWithNumber(l.trim())\n  1238→    );\n  1239→    if (!followedByIngredients) return true;\n  1240→    // Only remove if a longer candidate contains this one as a substring\n  1241→    const candidateLower = candidate.text.toLowerCase();\n  1242→    const hasLongerParent = rawScored.some(\n  1243→      (other) =>\n  1244→        other.text !== candidate.text &&\n  1245→        other.text.length > candidate.text.length &&\n  1246→        other.text.toLowerCase().includes(candidateLower)\n  1247→    );\n  1248→    return !hasLongerParent;\n  1249→  });\n  1250→\n  1251→  // Protect multi-line joins from being destroyed by their own component singles.\n  1252→  // When \"Lamb Stew\" (2-line join) survives AND both \"Lamb\" and \"Stew\" (singles) also survive,\n  1253→  // the join is the intended title — remove the singles.\n  1254→  const joinsToProtect = selected.filter((s) => s.origin === \"2-line\" || s.origin === \"3-line\");\n  1255→  if (joinsToProtect.length > 0) {\n  1256→    const singlesToRemove = new Set<string>();\n  1257→    for (const join of joinsToProtect) {\n  1258→      const joinWords = join.text.split(/\\s+/);\n  1259→      const componentSingles = selected.filter(\n  1260→        (s) => s.origin === \"single\" && joinWords.some((w) => s.text.toLowerCase() === w.toLowerCase())\n  1261→      );\n  1262→      if (componentSingles.length >= Math.min(joinWords.length, 2)) {\n  1263→        componentSingles.forEach((s) => singlesToRemove.add(s.text));\n  1264→      }\n  1265→    }\n  1266→    if (singlesToRemove.size > 0) {\n  1267→      selected = selected.filter((s) => s.origin !== \"single\" || !singlesToRemove.has(s.text));\n  1268→    }\n  1269→  }\n  1270→\n  1271→  // Protect position-0 compound titles from distant sub-section headers.\n  1272→  // When a position-0 compound title is longer and contains a shorter candidate\n  1273→  // that appears > 10 lines later, remove the distant candidate so the dedup\n  1274→  // (shorter-wins rule) doesn't destroy the compound title.\n  1275→  const pos0Compounds = selected.filter((s) => s.position === 0);\n  1276→  if (pos0Compounds.length > 0) {\n  1277→    selected = selected.filter((s) => {\n  1278→      if (s.position === 0) return true;\n  1279→      const sLower = s.text.toLowerCase();\n  1280→      return !pos0Compounds.some(\n  1281→        (p0) =>\n  1282→          p0.position + 10 < s.position &&\n  1283→          s.text.length < p0.text.length &&\n  1284→          p0.text.toLowerCase().includes(sLower)\n  1285→      );\n  1286→    });\n  1287→  }\n  1288→\n  1289→  // Deduplicate: if one title is a substring of another, keep the shorter (more focused) one.\n  1290→  // DO NOT CHANGE THIS LOGIC — it has been incorrectly \"improved\" by the title-loop 5 times.\n  1291→  // The tests require shorter wins: \"Pierogi Ruskie\" over \"Pierogi Ruskie 200g mąki 3 ziemniaki\".\n  1292→  // The pre-filter above handles the conflicting case (structural heading prefix removal) so that\n  1293→  // the incomplete prefix line is never present here when the complete join is in selected.\n  1294→  selected = selected.filter((a) => {\n  1295→    const aLower = a.text.toLowerCase();\n  1296→    // Protect compound titles — these use explicit separators and the full form is intentional\n  1297→    if (/ [+:&] /.test(a.text)) return true;\n  1298→    return !selected.some(\n  1299→      (b) =>\n  1300→        b !== a &&\n  1301→        aLower.includes(b.text.toLowerCase()) &&\n  1302→        b.text.length < a.text.length\n  1303→    );\n  1304→  });\n  1305→\n  1306→  // Multi-title guard: only join multiple candidates with \"+\" when there is\n  1307→  // structural evidence of a multi-recipe page (≥2 ALL_CAPS headings).\n  1308→  // A single ALL_CAPS title among mixed-case survivors is a single-recipe page —\n  1309→  // collapse to the highest-scoring candidate.\n  1310→  // Zero ALL_CAPS survivors → apply positional tiebreak only when candidates are\n  1311→  // spread far apart (>10 lines), which indicates body-text leakage. Closely-\n  1312→  // positioned candidates are likely genuine multi-recipe content.\n  1313→  if (selected.length > 1) {\n  1314→    const allCapsSelected = selected.filter((s) => isAllCaps(s.text));\n  1315→    if (allCapsSelected.length >= 2) {\n  1316→      // Vocabulary corroboration: filter out ALL_CAPS candidates whose content words\n  1317→      // don't appear elsewhere in the document. This catches orphaned OCR artifacts\n  1318→      // (e.g., \"DAT FLATBREADS\" from a preceding page) that look structurally identical\n  1319→      // to real titles but have no vocabulary support in the document body.\n  1320→      const corroboratedCaps = allCapsSelected.filter((cap) =>\n  1321→        passesCorroboration(cap.text, cap.position, lines)\n  1322→      );\n  1323→\n  1324→      // Use corroborated candidates if any remain; otherwise fall back to original set\n  1325→      // (don't remove all candidates — that would break legitimate multi-title pages\n  1326→      // where corroboration fails for benign reasons).\n  1327→      const capsToUse = corroboratedCaps.length >= 2 ? corroboratedCaps : allCapsSelected;\n  1328→\n  1329→      // Check whether non-first ALL_CAPS headings are section headers within one recipe\n  1330→      // (followed immediately by ingredient-like content) rather than separate recipe titles.\n  1331→      // A multi-recipe page has body text between titles; a single-recipe page has\n  1332→      // ingredient lines immediately after each section heading.\n  1333→      const sortedCaps = [...capsToUse].sort((a, b) => a.position - b.position);\n  1334→      const isSubHeader = sortedCaps.slice(1).every((cap) => {\n  1335→        const nextLines = lines.slice(cap.position + 1, cap.position + 3);\n  1336→        return nextLines.some(\n  1337→          (l) => looksLikeIngredient(l.trim()) || /^\\s*\\d/.test(l.trim())\n  1338→        );\n  1339→      });\n  1340→      if (isSubHeader) {\n  1341→        selected = [sortedCaps[0]];\n  1342→      } else {\n  1343→        selected = capsToUse;\n  1344→      }\n  1345→    } else if (allCapsSelected.length === 1) {\n  1346→      const theCapCandidate = allCapsSelected[0];\n  1347→      // Use non-empty line count so the 75% threshold is consistent regardless of blank-line density.\n  1348→      const nonEmptyCount = lines.filter((l) => l.trim().length > 0).length;\n  1349→      const capRelPos = theCapCandidate.position / Math.max(nonEmptyCount, 1);\n  1350→      // If the sole ALL_CAPS candidate is in the last 25% of the document,\n  1351→      // it's likely a category footer, not a title. Prefer the best earlier candidate.\n  1352→      if (capRelPos > 0.75) {\n  1353→        const earlierCandidates = selected.filter(\n  1354→          (s) => s.position / Math.max(nonEmptyCount, 1) <= 0.75\n  1355→        );\n  1356→        if (earlierCandidates.length > 0) {\n  1357→          selected = [earlierCandidates.reduce((a, b) => (a.score > b.score ? a : b))];\n  1358→        } else {\n  1359→          // All candidates are in the last 25% — no positional basis to prefer one over another;\n  1360→          // fall back to score, accepting that the guard cannot help here.\n  1361→          selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n  1362→        }\n  1363→      } else {\n  1364→        selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n  1365→      }\n  1366→    } else {\n  1367→      // Zero ALL_CAPS survivors → mixed-case page.\n  1368→      // If all survivors are closely positioned (within 10 lines of each other), keep them all —\n  1369→      // they're likely genuine multi-recipe content on a single page.\n  1370→      // If any survivor is far from the earliest, apply a positional tiebreak: the real title\n  1371→      // is almost always the earliest candidate; distant survivors are likely body-text leakage.\n  1372→      selected.sort((a, b) => a.position - b.position);\n  1373→      const earliest = selected[0];\n  1374→      const farthest = selected[selected.length - 1];\n  1375→      if (farthest.position - earliest.position > 10) {\n  1376→        // Large span → body-text leakage. Collapse to one: prefer the highest-scoring\n  1377→        // candidate within 3 positions of the earliest (position tolerance for OCR gaps),\n  1378→        // falling back to the earliest itself if none score higher.\n  1379→        const closeCompetitors = selected.filter(\n  1380→          (s) => s.position <= earliest.position + 3 && s.score > earliest.score\n  1381→        );\n  1382→        selected = closeCompetitors.length > 0\n  1383→          ? [closeCompetitors.reduce((a, b) => (a.score > b.score ? a : b))]\n  1384→          : [earliest];\n  1385→      }\n  1386→      // Span ≤ 10 → all survivors are closely positioned; fall through keeping all.\n  1387→    }\n  1388→  }\n  1389→\n  1390→  // Cap at 3, sort by document position\n  1391→  selected.sort((a, b) => a.position - b.position);\n  1392→  selected = selected.slice(0, 3);\n  1393→\n  1394→  if (selected.length === 0) {\n  1395→    // Last resort: embedding scoring provided no usable signal.\n  1396→    // Return the earliest candidate that passed hard filters — it already survived\n  1397→    // ingredient, metadata, garbled, section-label, and cooking-instruction checks.\n  1398→    // Position 0 in a recipe file is overwhelmingly the title.\n  1399→    // Exclude hard-disqualified candidates (rawScore -1.0 = truncated OCR artifact).\n  1400→    const lastResort = scored\n  1401→      .slice()\n  1402→      .filter((s) => s.rawScore > -0.5)\n  1403→      .sort((a, b) => a.position - b.position || b.score - a.score);\n  1404→    if (lastResort.length > 0) {\n  1405→      return normalizeOcrTitle(lastResort[0].text.normalize(\"NFC\").trim());\n  1406→    }\n  1407→    return undefined;\n  1408→  }\n  1409→\n  1410→  const result = selected.map((s) => normalizeOcrTitle(s.text.normalize(\"NFC\").trim())).join(\" + \");\n  1411→\n  1412→  return result;\n  1413→}\n  1414→\n  1415→/**\n  1416→ * Extract potential recipe title from OCR text (sync heuristic fallback)\n  1417→ */\n  1418→export function extractTitle(text: string): string | undefined {\n  1419→  if (!text || text.trim().length === 0) {\n  1420→    return undefined;\n  1421→  }\n  1422→\n  1423→  const lines = text.split(\"\\n\").map((line) => line.trim());\n  1424→\n  1425→  for (const line of lines) {\n  1426→    if (line.length === 0) continue;\n  1427→    if (line.length < 3 || line.length > 50) continue;\n  1428→    if (looksLikeIngredient(line)) continue;\n  1429→    if (isAllCaps(line)) continue;\n  1430→    if (startsWithNumber(line)) continue;\n  1431→    return line;\n  1432→  }\n  1433→\n  1434→  return undefined;\n  1435→}\n  1436→","numLines":437,"startLine":1000,"totalLines":1436}}}
