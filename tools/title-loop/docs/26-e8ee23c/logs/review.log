{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018XkSmHa3zPWCY6KzqBrgY9","type":"tool_result","content":"   600→        continue;\n   601→      }\n   602→    }\n   603→    capsCoalesced.push(line);\n   604→    ci++;\n   605→  }\n   606→\n   607→  // Pre-merge continuation lines: a line starting with /&+:( is never a standalone title.\n   608→  // Merge it into the preceding line so the complete title enters the pool as a single candidate,\n   609→  // avoiding the fragile chain of conditions required by the downstream join survival logic.\n   610→  // Limitation: only one continuation line per preceding line is merged. Titles split across\n   611→  // three or more lines with continuation tokens (rare in practice) are not handled here —\n   612→  // the downstream 2-line and 3-line join candidates cover those cases instead.\n   613→  const mergedLines: Array<{ text: string; index: number }> = [];\n   614→  for (let i = 0; i < capsCoalesced.length; i++) {\n   615→    const line = capsCoalesced[i];\n   616→    if (i + 1 < capsCoalesced.length) {\n   617→      const nextText = capsCoalesced[i + 1].text;\n   618→      if (/^[/&+:(]/.test(nextText)) {\n   619→        mergedLines.push({ text: `${line.text} ${nextText}`, index: line.index });\n   620→        i++;\n   621→        continue;\n   622→      }\n   623→    }\n   624→    mergedLines.push(line);\n   625→  }\n   626→\n   627→  const candidates: Array<{ text: string; position: number; origin: CandidateOrigin }> = [];\n   628→  const seen = new Set<string>();\n   629→\n   630→  // Build a set of positions to skip: short ALL_CAPS lines immediately following metadata\n   631→  const metadataContinuationPositions = new Set<number>();\n   632→  for (let i = 0; i < mergedLines.length - 1; i++) {\n   633→    if (looksLikeMetadata(mergedLines[i].text)) {\n   634→      const next = mergedLines[i + 1];\n   635→      if (isAllCaps(next.text) && wordCount(next.text) <= 2 && next.text.length <= 15) {\n   636→        metadataContinuationPositions.add(next.index);\n   637→      }\n   638→    }\n   639→  }\n   640→\n   641→  for (let i = 0; i < mergedLines.length; i++) {\n   642→    const line = mergedLines[i];\n   643→\n   644→    // Skip metadata continuation fragments\n   645→    if (metadataContinuationPositions.has(line.index)) continue;\n   646→\n   647→    // Single line — strip page-number prefixes and parenthetical glosses before scoring\n   648→    const singleText = repairOcrText(stripParentheticalGloss(stripPageNumber(line.text)));\n   649→    if (passesHardFilters(singleText)) {\n   650→      const norm = singleText.toLowerCase();\n   651→      if (!seen.has(norm)) {\n   652→        seen.add(norm);\n   653→        candidates.push({ text: singleText, position: line.index, origin: \"single\" });\n   654→      }\n   655→    }\n   656→\n   657→    // 2-line join — skip if first line is a section label AND join would be ≤2 words\n   658→    // (a section label followed by modifiers is likely a recipe title, not a category header)\n   659→    if (i + 1 < mergedLines.length) {\n   660→      const joined2 = repairOcrText(`${line.text} ${mergedLines[i + 1].text}`);\n   661→      const shouldBlock2 = isSectionLabel(line.text) &&\n   662→        (wordCount(joined2) <= 2 || isAlwaysBlockJoinLabel(line.text));\n   663→      if (!shouldBlock2 && passesHardFilters(joined2)) {\n   664→        const norm = joined2.toLowerCase();\n   665→        if (!seen.has(norm)) {\n   666→          seen.add(norm);\n   667→          candidates.push({ text: joined2, position: line.index, origin: \"2-line\" });\n   668→        }\n   669→      }\n   670→    }\n   671→\n   672→    // 3-line join — skip if first line is a section label AND join would be ≤2 words\n   673→    if (i + 2 < mergedLines.length) {\n   674→      const joined3 = repairOcrText(`${line.text} ${mergedLines[i + 1].text} ${mergedLines[i + 2].text}`);\n   675→      const shouldBlock3 = isSectionLabel(line.text) &&\n   676→        (wordCount(joined3) <= 2 || isAlwaysBlockJoinLabel(line.text));\n   677→      if (!shouldBlock3 && passesHardFilters(joined3)) {\n   678→        const norm = joined3.toLowerCase();\n   679→        if (!seen.has(norm)) {\n   680→          seen.add(norm);\n   681→          candidates.push({ text: joined3, position: line.index, origin: \"3-line\" });\n   682→        }\n   683→      }\n   684→    }\n   685→  }\n   686→\n   687→  // Pre-filter to 25 before embedding calls: prefer ALL_CAPS and short candidates.\n   688→  // Position-based scoring handles final ranking.\n   689→  if (candidates.length > 25) {\n   690→    const prioritized = candidates.slice().sort((a, b) => {\n   691→      const aAllCaps = isAllCaps(a.text) ? 0 : 1;\n   692→      const bAllCaps = isAllCaps(b.text) ? 0 : 1;\n   693→      if (aAllCaps !== bAllCaps) return aAllCaps - bAllCaps;\n   694→      const aShort = wordCount(a.text) <= 5 ? 0 : 1;\n   695→      const bShort = wordCount(b.text) <= 5 ? 0 : 1;\n   696→      return aShort - bShort;\n   697→    });\n   698→    return prioritized.slice(0, 25);\n   699→  }\n   700→\n   701→  return candidates;\n   702→}\n   703→\n   704→/**\n   705→ * Convert an ALL_CAPS string to Title Case, using a small-words list.\n   706→ * Preserves Polish/French diacritics.\n   707→ */\n   708→function toTitleCase(text: string): string {\n   709→  const smallWords = new Set([\n   710→    \"a\", \"an\", \"the\", \"and\", \"but\", \"or\", \"for\", \"nor\",\n   711→    \"in\", \"on\", \"at\", \"to\", \"of\", \"by\", \"with\", \"from\",\n   712→    \"z\", \"w\", \"i\", \"ze\", \"na\", \"do\", \"od\", \"za\", \"po\",\n   713→  ]);\n   714→  return text.split(/(\\s+)/).map((word, idx) => {\n   715→    if (/^\\s+$/.test(word)) return word;\n   716→    const lower = word.toLowerCase();\n   717→    if (idx === 0 || !smallWords.has(lower)) {\n   718→      return lower.charAt(0).toUpperCase() + lower.slice(1);\n   719→    }\n   720→    return lower;\n   721→  }).join(\"\");\n   722→}\n   723→\n   724→/**\n   725→ * OCR digit→letter substitution map.\n   726→ * Each key is a character that OCR commonly confuses; values are possible correct letters.\n   727→ */\n   728→const OCR_SUBSTITUTIONS: Record<string, string[]> = {\n   729→  \"0\": [\"o\"],\n   730→  \"1\": [\"i\", \"l\"],\n   731→  \"4\": [\"a\"],\n   732→  \"5\": [\"s\"],\n   733→  \"¡\": [\"i\"],\n   734→  \"í\": [\"i\", \"l\"],\n   735→  \"€\": [\"e\"],\n   736→};\n   737→\n   738→const OCR_ARTIFACT_PATTERN = /[0-9¡Íí€]/;\n   739→\n   740→/**\n   741→ * Attempt to repair a single OCR-corrupted word using dictionary lookup.\n   742→ * Returns the repaired word if a dictionary match is found, otherwise returns the original.\n   743→ */\n   744→function repairOcrWord(word: string): string {\n   745→  if (!OCR_ARTIFACT_PATTERN.test(word)) return word;\n   746→\n   747→  const lower = word.toLowerCase();\n   748→\n   749→  const positions: Array<{ index: number; replacements: Array<string> }> = [];\n   750→  for (let i = 0; i < lower.length; i++) {\n   751→    const replacements = OCR_SUBSTITUTIONS[lower[i]];\n   752→    if (replacements) {\n   753→      positions.push({ index: i, replacements });\n   754→    }\n   755→  }\n   756→\n   757→  if (positions.length === 0 || positions.length > 8) return word;\n   758→\n   759→  const candidates = generateSubstitutions(lower, positions, 0);\n   760→\n   761→  for (const candidate of candidates) {\n   762→    if (FOOD_DICTIONARY.has(candidate)) {\n   763→      if (word === word.toUpperCase()) return candidate.toUpperCase();\n   764→      if (word[0] === word[0].toUpperCase()) {\n   765→        return candidate[0].toUpperCase() + candidate.slice(1);\n   766→      }\n   767→      return candidate;\n   768→    }\n   769→  }\n   770→\n   771→  return word;\n   772→}\n   773→\n   774→/**\n   775→ * Recursively generate all substitution variants for OCR artifact positions.\n   776→ */\n   777→function generateSubstitutions(\n   778→  base: string,\n   779→  positions: Array<{ index: number; replacements: Array<string> }>,\n   780→  posIdx: number,\n   781→): Array<string> {\n   782→  if (posIdx >= positions.length) return [base];\n   783→\n   784→  const { index, replacements } = positions[posIdx];\n   785→  const results: Array<string> = [];\n   786→\n   787→  for (const replacement of replacements) {\n   788→    const variant = base.slice(0, index) + replacement + base.slice(index + 1);\n   789→    results.push(...generateSubstitutions(variant, positions, posIdx + 1));\n   790→  }\n   791→\n   792→  return results;\n   793→}\n   794→\n   795→/**\n   796→ * Apply dictionary-guided OCR repair to all words in a text string.\n   797→ */\n   798→function repairOcrText(text: string): string {\n   799→  return text"}]},"parent_tool_use_id":"toolu_014ZeYx2KMUHyi6o55JfXJ1N","session_id":"80bb29ff-3467-4b06-a8e7-a7aec63d83fa","uuid":"a6eb610d-9f75-4b4d-9c58-7dd573cac8a6"}
