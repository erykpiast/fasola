{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018qPh7JZHboQBUXQrniRQ3M","type":"tool_result","content":"  1300→      });\n  1301→      if (isSuffixOfJoin) return false;\n  1302→      return true;\n  1303→    });\n  1304→  }\n  1305→\n  1306→  // Pre-dedup: remove sub-section headers that are substrings of other surviving candidates.\n  1307→  // A sub-section header is an ALL_CAPS candidate followed by ingredient-like lines in the source.\n  1308→  // Example: \"CHLEBEK\" (bread section header, followed by \"500 g mąki\") is a substring of\n  1309→  // \"CHLEBEK Z WARZYWAMI I BOCZKIEM\" (the real title). Without this filter, dedup kills the title.\n  1310→  selected = selected.filter((candidate) => {\n  1311→    if (!isAllCaps(candidate.text)) return true;\n  1312→    // Check if this candidate is immediately followed by ingredient-like content\n  1313→    const nextSourceLines = lines.slice(candidate.position + 1, candidate.position + 2);\n  1314→    const followedByIngredients = nextSourceLines.some(\n  1315→      (l) => looksLikeIngredient(l.trim()) || startsWithNumber(l.trim())\n  1316→    );\n  1317→    if (!followedByIngredients) return true;\n  1318→    // Only remove if a longer candidate contains this one as a substring\n  1319→    const candidateLower = candidate.text.toLowerCase();\n  1320→    const hasLongerParent = rawScored.some(\n  1321→      (other) =>\n  1322→        other.text !== candidate.text &&\n  1323→        other.text.length > candidate.text.length &&\n  1324→        other.text.toLowerCase().includes(candidateLower)\n  1325→    );\n  1326→    return !hasLongerParent;\n  1327→  });\n  1328→\n  1329→  // Protect multi-line joins from being destroyed by their own component singles.\n  1330→  // When \"Lamb Stew\" (2-line join) survives AND both \"Lamb\" and \"Stew\" (singles) also survive,\n  1331→  // the join is the intended title — remove the singles.\n  1332→  const joinsToProtect = selected.filter((s) => s.origin === \"2-line\" || s.origin === \"3-line\");\n  1333→  if (joinsToProtect.length > 0) {\n  1334→    const singlesToRemove = new Set<string>();\n  1335→    for (const join of joinsToProtect) {\n  1336→      const joinWords = join.text.split(/\\s+/);\n  1337→      const componentSingles = selected.filter(\n  1338→        (s) => s.origin === \"single\" && joinWords.some((w) => s.text.toLowerCase() === w.toLowerCase())\n  1339→      );\n  1340→      if (componentSingles.length >= Math.min(joinWords.length, 2)) {\n  1341→        componentSingles.forEach((s) => singlesToRemove.add(s.text));\n  1342→      }\n  1343→    }\n  1344→    if (singlesToRemove.size > 0) {\n  1345→      selected = selected.filter((s) => s.origin !== \"single\" || !singlesToRemove.has(s.text));\n  1346→    }\n  1347→  }\n  1348→\n  1349→  // Protect position-0 compound titles from distant sub-section headers.\n  1350→  // When a position-0 compound title is longer and contains a shorter candidate\n  1351→  // that appears > 10 lines later, remove the distant candidate so the dedup\n  1352→  // (shorter-wins rule) doesn't destroy the compound title.\n  1353→  const pos0Compounds = selected.filter((s) => s.position === 0);\n  1354→  if (pos0Compounds.length > 0) {\n  1355→    selected = selected.filter((s) => {\n  1356→      if (s.position === 0) return true;\n  1357→      const sLower = s.text.toLowerCase();\n  1358→      return !pos0Compounds.some(\n  1359→        (p0) =>\n  1360→          p0.position + 10 < s.position &&\n  1361→          s.text.length < p0.text.length &&\n  1362→          p0.text.toLowerCase().includes(sLower)\n  1363→      );\n  1364→    });\n  1365→  }\n  1366→\n  1367→  // Deduplicate: if one title is a substring of another, keep the shorter (more focused) one.\n  1368→  // DO NOT CHANGE THIS LOGIC — it has been incorrectly \"improved\" by the title-loop 5 times.\n  1369→  // The tests require shorter wins: \"Pierogi Ruskie\" over \"Pierogi Ruskie 200g mąki 3 ziemniaki\".\n  1370→  // The pre-filter above handles the conflicting case (structural heading prefix removal) so that\n  1371→  // the incomplete prefix line is never present here when the complete join is in selected.\n  1372→  selected = selected.filter((a) => {\n  1373→    const aLower = a.text.toLowerCase();\n  1374→    // Protect compound titles — these use explicit separators and the full form is intentional\n  1375→    if (/ [+:&] /.test(a.text)) return true;\n  1376→    return !selected.some(\n  1377→      (b) =>\n  1378→        b !== a &&\n  1379→        aLower.includes(b.text.toLowerCase()) &&\n  1380→        b.text.length < a.text.length\n  1381→    );\n  1382→  });\n  1383→\n  1384→  // Multi-title guard: only join multiple candidates with \"+\" when there is\n  1385→  // structural evidence of a multi-recipe page (≥2 ALL_CAPS headings).\n  1386→  // A single ALL_CAPS title among mixed-case survivors is a single-recipe page —\n  1387→  // collapse to the highest-scoring candidate.\n  1388→  // Zero ALL_CAPS survivors → apply positional tiebreak only when candidates are\n  1389→  // spread far apart (>10 lines), which indicates body-text leakage. Closely-\n  1390→  // positioned candidates are likely genuine multi-recipe content.\n  1391→  if (selected.length > 1) {\n  1392→    const allCapsSelected = selected.filter((s) => isAllCaps(s.text));\n  1393→    if (allCapsSelected.length >= 2) {\n  1394→      // Vocabulary corroboration: filter out ALL_CAPS candidates whose content words\n  1395→      // don't appear elsewhere in the document. This catches orphaned OCR artifacts\n  1396→      // (e.g., \"DAT FLATBREADS\" from a preceding page) that look structurally identical\n  1397→      // to real titles but have no vocabulary support in the document body.\n  1398→      const corroboratedCaps = allCapsSelected.filter((cap) =>\n  1399→        passesCorroboration(cap.text, cap.position, lines)\n  1400→      );\n  1401→\n  1402→      // Use corroborated candidates if any remain; otherwise fall back to original set\n  1403→      // (don't remove all candidates — that would break legitimate multi-title pages\n  1404→      // where corroboration fails for benign reasons).\n  1405→      const capsToUse = corroboratedCaps.length >= 2 ? corroboratedCaps : allCapsSelected;\n  1406→\n  1407→      // Check whether non-first ALL_CAPS headings are section headers within one recipe\n  1408→      // (followed immediately by ingredient-like content) rather than separate recipe titles.\n  1409→      // A multi-recipe page has body text between titles; a single-recipe page has\n  1410→      // ingredient lines immediately after each section heading.\n  1411→      const sortedCaps = [...capsToUse].sort((a, b) => a.position - b.position);\n  1412→      const isSubHeader = sortedCaps.slice(1).every((cap) => {\n  1413→        const nextLines = lines.slice(cap.position + 1, cap.position + 3);\n  1414→        return nextLines.some(\n  1415→          (l) => looksLikeIngredient(l.trim()) || startsWithNumber(l.trim())\n  1416→        );\n  1417→      });\n  1418→      if (isSubHeader) {\n  1419→        selected = [sortedCaps[0]];\n  1420→      } else {\n  1421→        selected = capsToUse;\n  1422→      }\n  1423→    } else if (allCapsSelected.length === 1) {\n  1424→      const theCapCandidate = allCapsSelected[0];\n  1425→      // Use non-empty line count so the 75% threshold is consistent regardless of blank-line density.\n  1426→      const nonEmptyCount = lines.filter((l) => l.trim().length > 0).length;\n  1427→      const capRelPos = theCapCandidate.position / Math.max(nonEmptyCount, 1);\n  1428→      // If the sole ALL_CAPS candidate is in the last 25% of the document,\n  1429→      // it's likely a category footer, not a title. Prefer the best earlier candidate.\n  1430→      if (capRelPos > 0.75) {\n  1431→        const earlierCandidates = selected.filter(\n  1432→          (s) => s.position / Math.max(nonEmptyCount, 1) <= 0.75\n  1433→        );\n  1434→        if (earlierCandidates.length > 0) {\n  1435→          selected = [earlierCandidates.reduce((a, b) => (a.score > b.score ? a : b))];\n  1436→        } else {\n  1437→          // All candidates are in the last 25% — no positional basis to prefer one over another;\n  1438→          // fall back to score, accepting that the guard cannot help here.\n  1439→          selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n  1440→        }\n  1441→      } else {\n  1442→        selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n  1443→      }\n  1444→    } else {\n  1445→      // Zero ALL_CAPS survivors → mixed-case page.\n  1446→      // If all survivors are closely positioned (within 10 lines of each other), keep them all —\n  1447→      // they're likely genuine multi-recipe content on a single page.\n  1448→      // If any survivor is far from the earliest, apply a positional tiebreak: the real title\n  1449→      // is almost always the earliest candidate; distant survivors are likely body-text leakage.\n  1450→      selected.sort((a, b) => a.position - b.position);\n  1451→      const earliest = selected[0];\n  1452→      const farthest = selected[selected.length - 1];\n  1453→      if (farthest.position - earliest.position > 10) {\n  1454→        // Large span → body-text leakage. Collapse to one: prefer the highest-scoring\n  1455→        // candidate within 3 positions of the earliest (position tolerance for OCR gaps),\n  1456→        // falling back to the earliest itself if none score higher.\n  1457→        const closeCompetitors = selected.filter(\n  1458→          (s) => s.position <= earliest.position + 3 && s.score > earliest.score\n  1459→        );\n  1460→        selected = closeCompetitors.length > 0\n  1461→          ? [closeCompetitors.reduce((a, b) => (a.score > b.score ? a : b))]\n  1462→          : [earliest];\n  1463→      }\n  1464→      // Span ≤ 10 → all survivors are closely positioned; fall through keeping all.\n  1465→    }\n  1466→  }\n  1467→\n  1468→  // Cap at 3, sort by document position\n  1469→  selected.sort((a, b) => a.position - b.position);\n  1470→  selected = selected.slice(0, 3);\n  1471→\n  1472→  if (selected.length === 0) {\n  1473→    // Last resort: embedding scoring provided no usable signal.\n  1474→    // Return the earliest candidate that passed hard filters — it already survived\n  1475→    // ingredient, metadata, garbled, section-label, and cooking-instruction checks.\n  1476→    // Position 0 in a recipe file is overwhelmingly the title.\n  1477→    // Exclude hard-disqualified candidates (rawScore -1.0 = truncated OCR artifact).\n  1478→    const lastResort = scored\n  1479→      .slice()\n  1480→      .filter((s) => s.rawScore > -0.5)\n  1481→      .sort((a, b) => a.position - b.position || b.score - a.score);\n  1482→    if (lastResort.length > 0) {\n  1483→      return normalizeOcrTitle(lastResort[0].text.normalize(\"NFC\").trim());\n  1484→    }\n  1485→    return undefined;\n  1486→  }\n  1487→\n  1488→  const result = selected.map((s) => normalizeOcrTitle(s.text.normalize(\"NFC\").trim())).join(\" + \");\n  1489→\n  1490→  return result;\n  1491→}\n  1492→\n  1493→/**\n  1494→ * Extract potential recipe title from OCR text (sync heuristic fallback)\n  1495→ */\n  1496→export function extractTitle(text: string): string | undefined {\n  1497→  if (!text || text.trim().length === 0) {\n  1498→    return undefined;\n  1499→  }"}]},"parent_tool_use_id":"toolu_014ZeYx2KMUHyi6o55JfXJ1N","session_id":"80bb29ff-3467-4b06-a8e7-a7aec63d83fa","uuid":"e9e3d31c-c122-4e21-aa67-5dedcf7e0385"}
