                     // pinch\n    44→  \"garść\",                               // handful\n    45→  \"opakowanie\", \"opakowania\",            // package(s)\n    46→  \"plasterek\", \"plasterki\",             // slice(s)\n    47→];\n    48→\n    49→/**\n    50→ * Patterns that identify recipe metadata lines (not titles)\n    51→ */\n    52→const METADATA_PATTERNS = [\n    53→  /^(SERVES?|MAKES?|YIELDS?)\\b/i,\n...\n</persisted-output>"}]},"parent_tool_use_id":"toolu_0133P19M1rSeTMKMTSjeZaR3","session_id":"80bb29ff-3467-4b06-a8e7-a7aec63d83fa","uuid":"4f2a4fd5-5a95-4a16-ba9e-f882fa5fef7c"}
