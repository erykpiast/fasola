{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Hn1AGZXG74VxgJr9MXW9s6","type":"tool_result","content":"  1050→  if (totalPositionalBoost > maxPositionalBoost) {\n  1051→    const excess = totalPositionalBoost - maxPositionalBoost;\n  1052→    firstCandidate.score -= excess;\n  1053→    firstCandidate.baseScore -= excess;\n  1054→    firstCandidate.thresholdScore -= excess;\n  1055→  }\n  1056→\n  1057→  // --- Pre-threshold bilingual title detection ---\n  1058→  // When a mixed-case candidate at position 0 is followed by an ALL_CAPS candidate\n  1059→  // at position ≤ 2 that is semantically similar to it, this is a bilingual recipe\n  1060→  // page (e.g., Polish title + ALL_CAPS Korean romanization). Suppress confirmed\n  1061→  // translation candidates before computing threshold so their bonuses don't inflate\n  1062→  // the threshold beyond the mixed-case title's reach.\n  1063→  // Note: we check position ≤ 2 (local proximity), not global ALL_CAPS count, so\n  1064→  // section headers later in the document (SKŁADNIKI, WARZYWA, etc.) are irrelevant.\n  1065→  let translationCandidates: typeof scored = [];\n  1066→  let scoredForThreshold = scored;\n  1067→  const prePos0 = scored.find((s) => s.position === 0 && !isAllCaps(s.text));\n  1068→  if (prePos0) {\n  1069→    const nearbyAllCaps = scored.filter(\n  1070→      (s) => isAllCaps(s.text) && s.position >= 1 && s.position <= 2 && s.origin === \"single\"\n  1071→    );\n  1072→    const pos0Embedding = rawScored.find((r) => r.text === prePos0.text)?.embedding;\n  1073→\n  1074→    // Method 1: embedding similarity (works for related languages)\n  1075→    if (pos0Embedding && nearbyAllCaps.length > 0) {\n  1076→      translationCandidates = nearbyAllCaps.filter((cap) => {\n  1077→        const capEmbedding = rawScored.find((r) => r.text === cap.text)?.embedding;\n  1078→        if (!capEmbedding) return false;\n  1079→        return cosineSimilarity(pos0Embedding, capEmbedding) > 0.4;\n  1080→      });\n  1081→    }\n  1082→\n  1083→    // Method 2: layout-based detection (cross-lingual fallback).\n  1084→    // When embedding similarity is insufficient (e.g. Polish ↔ Korean romanization),\n  1085→    // detect bilingual layout by position and word overlap:\n  1086→    // mixed-case ≥2 words at pos 0 + ALL_CAPS ≥2 words at pos 1-2 with no shared words.\n  1087→    if (translationCandidates.length === 0 && wordCount(prePos0.text) >= 2) {\n  1088→      const pos0Words = new Set(\n  1089→        prePos0.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2)\n  1090→      );\n  1091→      translationCandidates = nearbyAllCaps.filter((cap) => {\n  1092→        if (wordCount(cap.text) < 2) return false;\n  1093→        const capWords = cap.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2);\n  1094→        return !capWords.some((w) => pos0Words.has(w));\n  1095→      });\n  1096→    }\n  1097→\n  1098→    if (translationCandidates.length > 0) {\n  1099→      // Suppress standalone translations and any multi-line joins that embed the translation\n  1100→      // as a suffix or substring (e.g. \"Smażona zielona fasolka GREEN BEANS BORKEUM\" ends with\n  1101→      // the translation; \"Title GREEN BEANS BORKEUM 그린빈\" includes it as a substring).\n  1102→      scoredForThreshold = scored.filter((s) => {\n  1103→        const sLower = s.text.toLowerCase();\n  1104→        return !translationCandidates.some((t) => {\n  1105→          const tLower = t.text.toLowerCase();\n  1106→          return sLower.startsWith(tLower) ||\n  1107→                 sLower.endsWith(\" \" + tLower) ||\n  1108→                 sLower.includes(\" \" + tLower);\n  1109→        });\n  1110→      });\n  1111→    }\n  1112→  }\n  1113→\n  1114→  // Fix 2: If the structural heading was identified as a bilingual translation, reassign it.\n  1115→  // This prevents the translation's ALL_CAPS bonus from inflating the threshold and ensures\n  1116→  // the fallback path in scored also uses the correct heading.\n  1117→  if (\n  1118→    translationCandidates.length > 0 &&\n  1119→    firstStructuralHeading &&\n  1120→    translationCandidates.some((t) => t.text === firstStructuralHeading!.text)\n  1121→  ) {\n  1122→    const nonTranslationStructural = structuralCandidates.filter(\n  1123→      (sc) => !translationCandidates.some((t) => t.text === sc.text)\n  1124→    );\n  1125→    const newHeading = nonTranslationStructural.length > 0\n  1126→      ? nonTranslationStructural.reduce((a, b) => a.rawScore > b.rawScore ? a : b)\n  1127→      : undefined;\n  1128→\n  1129→    // Patch scored array: remove old structural bonus, apply new one\n  1130→    for (const s of scored) {\n  1131→      if (s.text === firstStructuralHeading.text) {\n  1132→        s.score -= 0.10;\n  1133→        s.baseScore -= 0.10;\n  1134→      }\n  1135→      if (newHeading && s.text === newHeading.text) {\n  1136→        s.score += 0.10;\n  1137→        s.baseScore += 0.10;\n  1138→      }\n  1139→    }\n  1140→    // Update reference for downstream prefix-removal logic\n  1141→    firstStructuralHeading = newHeading ?? undefined;\n  1142→  }\n  1143→\n  1144→  // Subtitle suppression: when a short mixed-case title at position 0 is followed by a\n  1145→  // longer mixed-case candidate at position 1-2, the longer one is a subtitle/translation.\n  1146→  // Apply a penalty so the primary title (position 0) wins.\n  1147→  const pos0Primary = scored.find((s) => s.position === 0 && !isAllCaps(s.text) && wordCount(s.text) <= 5);\n  1148→  if (pos0Primary) {\n  1149→    const subtitleCandidates = scored.filter((s) =>\n  1150→      s.position >= 1 && s.position <= 2 &&\n  1151→      !isAllCaps(s.text) &&\n  1152→      wordCount(s.text) > wordCount(pos0Primary.text) + 2\n  1153→    );\n  1154→    for (const sub of subtitleCandidates) {\n  1155→      sub.score -= 0.15;\n  1156→    }\n  1157→  }\n  1158→\n  1159→  // Bilingual layout pattern: [FoodName (≤2 words)]\\n[Translation (2-5 words, mixed-case)]\\n...[Section label]\n  1160→  // Common in bilingual cookbooks: foreign food name at position 0, English translation at position 1-2.\n  1161→  // When detected, boost the position-0 candidate so it clears the threshold.\n  1162→  // Note: the ALL_CAPS bilingual block above (lines 940-995) handles mixed-case + ALL_CAPS pairs.\n  1163→  // This block handles mixed-case + mixed-case translation pairs — the two do not overlap because\n  1164→  // the mixed-case guard (`biSecond.text !== biSecond.text.toUpperCase()`) excludes ALL_CAPS lines.\n  1165→  if (scored.length >= 2) {\n  1166→    const biFirst = scored.find((s) => s.position === 0);\n  1167→    // Restrict to single-line candidates (same guard as the ALL_CAPS bilingual block at line 953)\n  1168→    const biSecond = scored.find((s) => s.position >= 1 && s.position <= 2 && s !== biFirst && s.origin === \"single\");\n  1169→\n  1170→    if (biFirst && biSecond) {\n  1171→      const firstWords = biFirst.text.trim().split(/\\s+/);\n  1172→      const secondWords = biSecond.text.trim().split(/\\s+/);\n  1173→\n  1174→      const isBilingualLayout =\n  1175→        firstWords.length <= 2 &&\n  1176→        secondWords.length >= 2 &&\n  1177→        secondWords.length <= 5 &&\n  1178→        // Second line is mixed-case (not ALL_CAPS, not all-lower)\n  1179→        biSecond.text !== biSecond.text.toUpperCase() &&\n  1180→        biSecond.text !== biSecond.text.toLowerCase() &&\n  1181→        // Second line is not an ingredient or instruction\n  1182→        !looksLikeIngredient(biSecond.text) &&\n  1183→        !looksLikeCookingInstruction(biSecond.text);\n  1184→\n  1185→      if (isBilingualLayout) {\n  1186→        // Check if a section label follows within a few lines after the first candidate\n  1187→        const sectionLabelNearby = lines\n  1188→          .slice(biFirst.position + 1, biFirst.position + 6)\n  1189→          .some((line) => isSectionLabel(line.trim()));\n  1190→\n  1191→        if (sectionLabelNearby) {\n  1192→          biFirst.score += 0.15;\n  1193→          biFirst.baseScore += 0.15;\n  1194→          biFirst.thresholdScore += 0.15;\n  1195→        }\n  1196→      }\n  1197→    }\n  1198→  }\n  1199→\n  1200→  // Pre-filter: when ≥2 ALL_CAPS candidates are present, identify OCR artifacts (those whose\n  1201→  // vocabulary has no support elsewhere in the document) and remove them before computing the\n  1202→  // threshold. Artifacts like \"DAT FLATBREADS\" can inflate the threshold via their early-position\n  1203→  // bonus, which causes legitimate titles later in the document to fall just below the cutoff.\n  1204→  // Safety: only pre-filter if ≥2 candidates remain after removal (avoids false-positive removal\n  1205→  // of unique-vocabulary titles on two-recipe pages).\n  1206→  const allCapsInScored = scoredForThreshold.filter((s) => isAllCaps(s.text));\n  1207→  if (allCapsInScored.length >= 2) {\n  1208→    const artifactTexts = new Set(\n  1209→      allCapsInScored\n  1210→        .filter((cap) => !passesCorroboration(cap.text, cap.position, lines))\n  1211→        .map((c) => c.text)\n  1212→    );\n  1213→    if (artifactTexts.size > 0) {\n  1214→      const remainingCaps = allCapsInScored.filter((c) => !artifactTexts.has(c.text));\n  1215→      if (remainingCaps.length >= 2) {\n  1216→        scoredForThreshold = scoredForThreshold.filter((s) => !artifactTexts.has(s.text));\n  1217→      }\n  1218→    }\n  1219→  }\n  1220→\n  1221→  // Use thresholdScore (excludes structural bonus) so the structural bonus doesn't inflate\n  1222→  // the threshold and block equally-valid headings on multi-recipe pages.\n  1223→  const bestThresholdScore = Math.max(...scoredForThreshold.map((s) => s.thresholdScore));\n  1224→  const threshold = Math.max(0.08, bestThresholdScore * 0.7);\n  1225→\n  1226→  // Filter candidates above threshold\n  1227→  let selected = scoredForThreshold.filter((s) => s.score >= threshold);\n  1228→\n  1229→  // Empty-pool fallback: when threshold filtering discards every candidate,\n  1230→  // the hard filters' structural verdict should not be overruled by weak\n  1231→  // embedding differentiation. Return the best positional candidate only\n  1232→  // if it has a meaningful positive raw score (avoids ingredient-list leakage).\n  1233→  if (selected.length === 0 && scored.length > 0) {\n  1234→    const fallback = scored\n  1235→      .slice()\n  1236→      .sort((a, b) => a.position - b.position || b.score - a.score);\n  1237→    // Position-0 candidates that passed hard filters are very likely titles even with\n  1238→    // weak embedding signal. Relax the rawScore guard for early-position candidates.\n  1239→    const rawScoreThreshold = fallback[0].position <= 2 ? -0.05 : 0.02;\n  1240→    if (fallback[0].rawScore > rawScoreThreshold) {\n  1241→      selected = [fallback[0]];\n  1242→    }\n  1243→  }\n  1244→\n  1245→  // Title-absent page guard: when the page starts mid-recipe (all of the first 3 non-empty\n  1246→  // lines are ingredients or cooking instructions), require a much higher rawScore and\n  1247→  // discard candidates deep in the file. This prevents stray body text or adjacent recipe\n  1248→  // titles from being picked up on pages with no title (Pattern 4).\n  1249→  if (titleAbsent) {\n  1250→    const titleAbsentThreshold = 0.10;\n  1251→    selected = selected.filter(s => s.rawScore >= titleAbsentThreshold);\n  1252→    selected = selected.filter(s => s.position <= 2);\n  1253→  }\n  1254→\n  1255→  // Remove word-boundary prefixes of firstStructuralHeading when the heading itself survived\n  1256→  // the threshold. Cases:\n  1257→  //   ARAYES case:  firstStructuralHeading = \"ARAYES SHRAK\" (2-word join qualifies; \"ARAYES\"\n  1258→  //     alone = 1 word, so it never qualified). Filter removes \"ARAYES\" so dedup keeps the join.\n  1259→  //   SAFFRON case: baseHeading was the partial line; continuation logic above upgraded\n  1260→  //     firstStructuralHeading to the full join. Filter removes the partial so dedup keeps join.\n  1261→  // Safety: only fires when the complete heading itself is in selected (passed the threshold).\n  1262→  if (firstStructuralHeading && selected.some((s) => s.text === firstStructuralHeading.text)) {\n  1263→    const fshLower = firstStructuralHeading.text.toLowerCase();\n  1264→    selected = selected.filter((s) => {\n  1265→      if (s.text === firstStructuralHeading.text) return true;\n  1266→      const sLower = s.text.toLowerCase();\n  1267→      // Remove s if it is a space-delimited prefix of the structural heading\n  1268→      return !fshLower.startsWith(sLower + \" \");\n  1269→    });\n  1270→  }\n  1271→\n  1272→  // Protect continuation joins: when a multi-line join (2-line or 3-line) survived the threshold\n  1273→  // and its second part starts with a continuation character, remove the single-line prefix/suffix\n  1274→  // so the dedup \"shorter wins\" rule doesn't destroy the complete join.\n  1275→  // Note: the pre-merge step above already handles the common Baked Eggs case (&/continuation\n  1276→  // on next line) by turning it into a single candidate — this block covers the rarer case where\n  1277→  // a continuation-character join was generated as a 2-line/3-line candidate and the prefix\n  1278→  // single also survived threshold independently (e.g. from a different code path or OCR layout).\n  1279→  // Safety: only fires for joins whose continuation starts with /&+:( — digit continuations\n  1280→  // like \"Pierogi Ruskie 200g mąki\" are NOT protected, so dedup correctly keeps the shorter form.\n  1281→  const survivingJoins = selected.filter((s) => s.origin === \"2-line\" || s.origin === \"3-line\");\n  1282→  if (survivingJoins.length > 0) {\n  1283→    selected = selected.filter((s) => {\n  1284→      if (s.origin !== \"single\") return true;\n  1285→      const sLower = s.text.toLowerCase();\n  1286→      // Remove PREFIX singles whose continuation join also survived\n  1287→      const isPrefixOfJoin = survivingJoins.some((j) => {\n  1288→        const jLower = j.text.toLowerCase();\n  1289→        if (!jLower.startsWith(sLower + \" \")) return false;\n  1290→        const remainder = jLower.slice(sLower.length + 1);\n  1291→        return /^[/&+:(]/.test(remainder);\n  1292→      });\n  1293→      if (isPrefixOfJoin) return false;\n  1294→      // Remove SUFFIX singles (e.g. \"& Coriander\") whose parent join also survived\n  1295→      const isSuffixOfJoin = survivingJoins.some((j) => {\n  1296→        const jLower = j.text.toLowerCase();\n  1297→        if (!jLower.endsWith(\" \" + sLower)) return false;\n  1298→        // Only remove if the suffix starts with a continuation character\n  1299→        return /^[/&+:(]/.test(sLower);"}]},"parent_tool_use_id":"toolu_014ZeYx2KMUHyi6o55JfXJ1N","session_id":"80bb29ff-3467-4b06-a8e7-a7aec63d83fa","uuid":"9173b477-2a18-4e83-a3cc-f7909b206da1"}
