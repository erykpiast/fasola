{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AeRBK7jfbPeCtsq2q7n8me","type":"tool_result","content":"  1195→        }\n  1196→      }\n  1197→    }\n  1198→  }\n  1199→\n  1200→  // Pre-filter: when ≥2 ALL_CAPS candidates are present, identify OCR artifacts (those whose\n  1201→  // vocabulary has no support elsewhere in the document) and remove them before computing the\n  1202→  // threshold. Artifacts like \"DAT FLATBREADS\" can inflate the threshold via their early-position\n  1203→  // bonus, which causes legitimate titles later in the document to fall just below the cutoff.\n  1204→  // Safety: only pre-filter if ≥2 candidates remain after removal (avoids false-positive removal\n  1205→  // of unique-vocabulary titles on two-recipe pages).\n  1206→  const allCapsInScored = scoredForThreshold.filter((s) => isAllCaps(s.text));\n  1207→  if (allCapsInScored.length >= 2) {\n  1208→    const artifactTexts = new Set(\n  1209→      allCapsInScored\n  1210→        .filter((cap) => !passesCorroboration(cap.text, cap.position, lines))\n  1211→        .map((c) => c.text)\n  1212→    );\n  1213→    if (artifactTexts.size > 0) {\n  1214→      const remainingCaps = allCapsInScored.filter((c) => !artifactTexts.has(c.text));\n  1215→      if (remainingCaps.length >= 2) {\n  1216→        scoredForThreshold = scoredForThreshold.filter((s) => !artifactTexts.has(s.text));\n  1217→      }\n  1218→    }\n  1219→  }\n  1220→\n  1221→  // Use thresholdScore (excludes structural bonus) so the structural bonus doesn't inflate\n  1222→  // the threshold and block equally-valid headings on multi-recipe pages.\n  1223→  const bestThresholdScore = Math.max(...scoredForThreshold.map((s) => s.thresholdScore));\n  1224→  const threshold = Math.max(0.08, bestThresholdScore * 0.7);"}]},"parent_tool_use_id":null,"session_id":"80bb29ff-3467-4b06-a8e7-a7aec63d83fa","uuid":"a5f03a02-0ab7-4430-be3b-51e972623775","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/title-extractor.ts","content":"        }\n      }\n    }\n  }\n\n  // Pre-filter: when ≥2 ALL_CAPS candidates are present, identify OCR artifacts (those whose\n  // vocabulary has no support elsewhere in the document) and remove them before computing the\n  // threshold. Artifacts like \"DAT FLATBREADS\" can inflate the threshold via their early-position\n  // bonus, which causes legitimate titles later in the document to fall just below the cutoff.\n  // Safety: only pre-filter if ≥2 candidates remain after removal (avoids false-positive removal\n  // of unique-vocabulary titles on two-recipe pages).\n  const allCapsInScored = scoredForThreshold.filter((s) => isAllCaps(s.text));\n  if (allCapsInScored.length >= 2) {\n    const artifactTexts = new Set(\n      allCapsInScored\n        .filter((cap) => !passesCorroboration(cap.text, cap.position, lines))\n        .map((c) => c.text)\n    );\n    if (artifactTexts.size > 0) {\n      const remainingCaps = allCapsInScored.filter((c) => !artifactTexts.has(c.text));\n      if (remainingCaps.length >= 2) {\n        scoredForThreshold = scoredForThreshold.filter((s) => !artifactTexts.has(s.text));\n      }\n    }\n  }\n\n  // Use thresholdScore (excludes structural bonus) so the structural bonus doesn't inflate\n  // the threshold and block equally-valid headings on multi-recipe pages.\n  const bestThresholdScore = Math.max(...scoredForThreshold.map((s) => s.thresholdScore));\n  const threshold = Math.max(0.08, bestThresholdScore * 0.7);","numLines":30,"startLine":1195,"totalLines":1514}}}
