{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019jR14i8UNsvUTTXXiaE3Mb","type":"tool_result","content":"   426→/**\n   427→ * Detect initial burst of short garbled lines.\n   428→ * Returns the index of the first non-garbled or long line.\n   429→ */\n   430→function findBurstEnd(lines: Array<{ text: string }>): number {\n   431→  let i = 0;\n   432→\n   433→  // Skip overflow preambles: blocks introduced by \"PREVIOUS RECIPE OVERFLOW\",\n   434→  // \"PREVIOUS PAGE CONTENT\", \"CORRUPTED SECTION\", etc. that precede the actual recipe.\n   435→  const OVERFLOW_MARKERS = /\\b(PREVIOUS\\s+(RECIPE|PAGE)\\s+(OVERFLOW|CONTENT)|SPILLOVER|CONTINUATION|CORRUPTED\\s+SECTION)\\b/i;\n   436→  let overflowEnd = 0;\n   437→  for (let k = 0; k < lines.length && k < 30; k++) {\n   438→    // Don't re-examine lines already determined to be overflow\n   439→    if (overflowEnd > 0 && k < overflowEnd) continue;\n   440→    if (OVERFLOW_MARKERS.test(lines[k].text)) {\n   441→      // Skip forward past the overflow block to the next visual separator or blank cluster\n   442→      let m = k + 1;\n   443→      let consecutiveBlanks = 0;\n   444→      while (m < lines.length) {\n   445→        const lineText = lines[m].text;\n   446→        // Stop at visual separator\n   447→        if (/^[=\\-]{4,}$/.test(lineText)) {\n   448→          overflowEnd = m + 1;\n   449→          break;\n   450→        }\n   451→        // Track consecutive blank lines\n   452→        if (lineText.trim().length === 0) {\n   453→          consecutiveBlanks++;\n   454→          if (consecutiveBlanks >= 2) {\n   455→            overflowEnd = m + 1;\n   456→            break;\n   457→          }\n   458→        } else {\n   459→          consecutiveBlanks = 0;\n   460→          // Stop at ALL_CAPS line with ≥2 words (likely next recipe heading)\n   461→          if (isAllCaps(lineText) && wordCount(lineText) >= 2) {\n   462→            overflowEnd = m; // Don't skip past the heading itself\n   463→            break;\n   464→          }\n   465→        }\n   466→        m++;\n   467→      }\n   468→      // If we walked to end without finding termination, skip everything we saw\n   469→      if (overflowEnd === 0) overflowEnd = m;\n   470→    }\n   471→  }\n   472→  if (overflowEnd > 0) i = overflowEnd;\n   473→\n   474→  while (i < lines.length && lines[i].text.length < 20 && isLikelyGarbled(lines[i].text) && !isAllCaps(lines[i].text)) {\n   475→    i++;\n   476→  }\n   477→  // Skip long instruction-like prologues: if 5+ consecutive lines look like cooking instructions,\n   478→  // skip them to find the actual title region.\n   479→  if (i === 0) {\n   480→    let j = 0;\n   481→    while (j < lines.length && looksLikeCookingInstruction(lines[j].text)) {\n   482→      j++;\n   483→    }\n   484→    if (j >= 5) {\n   485→      i = j;\n   486→    }\n   487→  }\n   488→  // Skip prose prologues: mid-recipe body text before the actual title.\n   489→  // If 3+ consecutive lines look like running body text (lowercase start, continuation,\n   490→  // or sentence-ending with many words), skip them.\n   491→  if (i === 0) {\n   492→    let j = 0;\n   493→    while (j < lines.length) {\n   494→      const t = lines[j].text;\n   495→      const isBodyText = (\n   496→        /^[a-ząćęłńóśźż]/.test(t) ||\n   497→        t.endsWith(\",\") ||\n   498→        (t.endsWith(\".\") && wordCount(t) > 4)\n   499→      ) && wordCount(t) >= 4;\n   500→      if (isBodyText) j++;\n   501→      else break;\n   502→    }\n   503→    if (j >= 3) i = j;\n   504→  }\n   505→  return i;\n   506→}\n   507→\n   508→function stripParentheticalGloss(text: string): string {\n   509→  // Strip trailing English-gloss parentheticals from ALL_CAPS titles.\n   510→  // e.g. \"PIEROGI RUSKIE (Boiled Dumplings with Potato and Cheese)\" → \"PIEROGI RUSKIE\"\n   511→  // Keep if parenthetical is ALL_CAPS (variation/subtitle in same language).\n   512→  // Keep if both base and paren are mixed-case (both are part of the title).\n   513→  const match = text.match(/^(.+?)\\s*\\(([^)]+)\\)\\s*$/);\n   514→  if (!match) return text;\n   515→  const [, base, paren] = match;\n   516→  if (isAllCaps(paren)) return text;\n   517→  if (!isAllCaps(base) && !isAllCaps(paren)) return text;\n   518→  return base.trim();\n   519→}\n   520→\n   521→function stripPageNumber(text: string): string {\n   522→  // \"34  Berry Jam\" → \"Berry Jam\" (2+ spaces distinguishes from \"2 eggs\")\n   523→  const match = text.match(/^\\d{1,3}\\s{2,}(.+)$/);\n   524→  return match ? match[1] : text;\n   525→}\n   526→\n   527→function wordCount(text: string): number {\n   528→  return text.split(/\\s+/).filter((w) => w.length > 0).length;\n   529→}\n   530→\n   531→/**\n   532→ * Build candidate strings from lines: single lines plus multi-line joins (2-3 consecutive).\n   533→ * Skips initial burst of short garbled lines. Scans all remaining lines. Caps at 25.\n   534→ */\n   535→export type CandidateOrigin = \"single\" | \"2-line\" | \"3-line\";\n   536→\n   537→function buildCandidates(\n   538→  lines: Array<string>\n   539→): Array<{ text: string; position: number; origin: CandidateOrigin }> {\n   540→  const nonEmptyLines: Array<{ text: string; index: number }> = [];\n   541→\n   542→  for (let i = 0; i < lines.length; i++) {\n   543→    const trimmed = lines[i].trim();\n   544→    if (trimmed.length > 0) {\n   545→      nonEmptyLines.push({ text: trimmed, index: i });"}]},"parent_tool_use_id":"toolu_0133P19M1rSeTMKMTSjeZaR3","session_id":"80bb29ff-3467-4b06-a8e7-a7aec63d83fa","uuid":"6b52d0e7-0a4d-44ed-b175-9e26d452d230"}
