{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0174dfz8jJGfEyCTY5MXuKPd","type":"tool_result","content":"     1→/**\n     2→ * Common English and Polish food/cooking words and structural recipe title\n     3→ * words (prepositions, adjectives) for OCR repair.\n     4→ * Words are lowercase, without diacritics (OCR-resilient matching).\n     5→ * Used by repairOcrWord() to resolve ambiguous digit→letter substitutions.\n     6→ */\n     7→export const FOOD_DICTIONARY: Set<string> = new Set([\n     8→  // ── English ingredients ──────────────────────────────────────────────────\n     9→  \"chicken\", \"beef\", \"pork\", \"lamb\", \"veal\", \"duck\", \"turkey\", \"venison\",\n    10→  \"salmon\", \"cod\", \"halibut\", \"tuna\", \"trout\", \"sardine\", \"anchovy\",\n    11→  \"shrimp\", \"prawn\", \"lobster\", \"crab\", \"scallop\", \"mussel\", \"clam\",\n    12→  \"tofu\", \"tempeh\", \"seitan\",\n    13→\n    14→  // Grains & starches\n    15→  \"rice\", \"pasta\", \"bread\", \"noodle\", \"flour\", \"oat\", \"barley\", \"wheat\",\n    16→  \"rye\", \"quinoa\", \"corn\", \"cornmeal\", \"semolina\", \"couscous\", \"polenta\",\n    17→  \"buckwheat\", \"millet\",\n    18→\n    19→  // Dairy & eggs\n    20→  \"butter\", \"cream\", \"cheese\", \"milk\", \"egg\", \"yogurt\", \"ghee\",\n    21→  \"ricotta\", \"mozzarella\", \"parmesan\", \"cheddar\", \"brie\", \"feta\",\n    22→\n    23→  // Fats & condiments\n    24→  \"oil\", \"vinegar\", \"mustard\", \"ketchup\", \"mayo\", \"mayonnaise\",\n    25→  \"soy\", \"sauce\", \"paste\", \"stock\", \"broth\", \"gravy\",\n    26→\n    27→  // Vegetables\n    28→  \"garlic\", \"onion\", \"tomato\", \"potato\", \"carrot\", \"celery\", \"pepper\",\n    29→  \"broccoli\", \"cauliflower\", \"asparagus\", \"artichoke\", \"eggplant\",\n    30→  \"zucchini\", \"squash\", \"pumpkin\", \"cucumber\", \"radish\", \"turnip\",\n    31→  \"beet\", \"mushroom\", \"avocado\", \"olive\", \"bean\", \"lentil\", \"chickpea\",\n    32→  \"arugula\", \"spinach\", \"kale\", \"lettuce\", \"cabbage\", \"leek\", \"fennel\",\n    33→  \"chard\", \"endive\", \"watercress\", \"sprout\", \"pea\", \"edamame\",\n    34→  \"scallion\", \"shallot\", \"chili\", \"jalapeno\", \"poblano\", \"serrano\",\n    35→  \"brukselka\",\n    36→\n    37→  // Fruits\n    38→  \"lemon\", \"lime\", \"orange\", \"apple\", \"berry\", \"blackberry\", \"blueberry\",\n    39→  \"raspberry\", \"strawberry\", \"cherry\", \"peach\", \"pear\", \"plum\", \"grape\",\n    40→  \"banana\", \"mango\", \"pineapple\", \"coconut\", \"fig\", \"date\", \"apricot\",\n    41→  \"pomegranate\", \"melon\", \"watermelon\", \"grapefruit\", \"papaya\", \"kiwi\",\n    42→  \"passion\", \"guava\", \"lychee\",\n    43→\n    44→  // Nuts & seeds\n    45→  \"almond\", \"walnut\", \"pecan\", \"cashew\", \"pistachio\", \"hazelnut\",\n    46→  \"peanut\", \"sesame\", \"flaxseed\", \"chia\", \"sunflower\", \"pumpkinseed\",\n    47→  \"poppy\",\n    48→\n    49→  // Spices & herbs\n    50→  \"ginger\", \"cinnamon\", \"cumin\", \"paprika\", \"turmeric\", \"oregano\",\n    51→  \"basil\", \"thyme\", \"rosemary\", \"parsley\", \"cilantro\", \"dill\", \"mint\",\n    52→  \"sage\", \"chive\", \"tarragon\", \"nutmeg\", \"clove\", \"cardamom\", \"saffron\",\n    53→  \"vanilla\", \"anise\", \"coriander\", \"bay\", \"marjoram\", \"chervil\",\n    54→  \"fenugreek\", \"sumac\", \"caraway\", \"allspice\",\n    55→\n    56→  // Sweeteners & flavourings\n    57→  \"chocolate\", \"cocoa\", \"honey\", \"maple\", \"molasses\", \"sugar\", \"salt\",\n    58→  \"yeast\", \"baking\", \"powder\", \"soda\",\n    59→\n    60→  // Common recipe adjectives / descriptors\n    61→  \"white\", \"red\", \"green\", \"black\", \"brown\", \"sweet\", \"sour\", \"hot\",\n    62→  \"cold\", \"fresh\", \"dried\", \"whole\", \"ground\", \"roasted\", \"grilled\",\n    63→  \"braised\", \"baked\", \"fried\", \"steamed\", \"smoked\", \"stuffed\", \"glazed\",\n    64→  \"caramelized\", \"pick