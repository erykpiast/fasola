{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SEJCjjsNKNVpk4TJHjvW1n","type":"tool_result","content":"   430→function findBurstEnd(lines: Array<{ text: string }>): number {\n   431→  let i = 0;\n   432→\n   433→  // Skip overflow preambles: blocks introduced by \"PREVIOUS RECIPE OVERFLOW\",\n   434→  // \"PREVIOUS PAGE CONTENT\", \"CORRUPTED SECTION\", etc. that precede the actual recipe.\n   435→  const OVERFLOW_MARKERS = /\\b(PREVIOUS\\s+(RECIPE|PAGE)\\s+(OVERFLOW|CONTENT)|SPILLOVER|CONTINUATION|CORRUPTED\\s+SECTION)\\b/i;\n   436→  let overflowEnd = 0;\n   437→  for (let k = 0; k < lines.length && k < 30; k++) {\n   438→    // Don't re-examine lines already determined to be overflow\n   439→    if (overflowEnd > 0 && k < overflowEnd) continue;\n   440→    if (OVERFLOW_MARKERS.test(lines[k].text)) {\n   441→      // Skip forward past the overflow block to the next visual separator or blank cluster\n   442→      let m = k + 1;\n   443→      let consecutiveBlanks = 0;\n   444→      while (m < lines.length) {\n   445→        const lineText = lines[m].text;\n   446→        // Stop at visual separator\n   447→        if (/^[=\\-]{4,}$/.test(lineText)) {\n   448→          overflowEnd = m + 1;\n   449→          break;\n   450→        }\n   451→        // Track consecutive blank lines\n   452→        if (lineText.trim().length === 0) {\n   453→          consecutiveBlanks++;\n   454→          if (consecutiveBlanks >= 2) {\n   455→            overflowEnd = m + 1;\n   456→            break;\n   457→          }\n   458→        } else {\n   459→          consecutiveBlanks = 0;\n   460→          // Stop at ALL_CAPS line with ≥2 words (likely next recipe heading)\n   461→          if (isAllCaps(lineText) && wordCount(lineText) >= 2) {\n   462→            overflowEnd = m; // Don't skip past the heading itself\n   463→            break;\n   464→          }\n   465→        }\n   466→        m++;\n   467→      }\n   468→      // If we walked to end without finding termination, skip everything we saw\n   469→      if (overflowEnd === 0) overflowEnd = m;\n   470→    }\n   471→  }\n   472→  if (overflowEnd > 0) i = overflowEnd;\n   473→\n   474→  while (i < lines.length && lines[i].text.length < 20 && isLikelyGarbled(lines[i].text) && !isAllCaps(lines[i].text)) {\n   475→    i++;\n   476→  }\n   477→  // Skip long instruction-like prologues: if 5+ consecutive lines look like cooking instructions,\n   478→  // skip them to find the actual title region.\n   479→  if (i === 0) {\n   480→    let j = 0;\n   481→    while (j < lines.length && looksLikeCookingInstruction(lines[j].text)) {\n   482→      j++;\n   483→    }\n   484→    if (j >= 5) {\n   485→      i = j;\n   486→    }\n   487→  }\n   488→  // Skip prose prologues: mid-recipe body text before the actual title.\n   489→  // If 3+ consecutive lines look like running body text (lowercase start, continuation,\n   490→  // or sentence-ending with many words), skip them.\n   491→  if (i === 0) {\n   492→    let j = 0;\n   493→    while (j < lines.length) {\n   494→      const t = lines[j].text;\n   495→      const isBodyText = (\n   496→        /^[a-ząćęłńóśźż]/.test(t) ||\n   497→        t.endsWith(\",\") ||\n   498→        (t.endsWith(\".\") && wordCount(t) > 4)\n   499→      ) && wordCount(t) >= 4;\n   500→      if (isBodyText) j++;\n   501→      else break;\n   502→    }\n   503→    if (j >= 3) i = j;\n   504→  }\n   505→  return i;\n   506→}\n   507→\n   508→function stripParentheticalGloss(text: string): string {\n   509→  // Strip trailing English-gloss parentheticals from ALL_CAPS titles."}]},"parent_tool_use_id":null,"session_id":"b58b8c45-4f2d-433d-859c-e1c4435e3073","uuid":"3e64063f-12a6-453b-a71b-11468a4dccf8","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/title-extractor.ts","content":"function findBurstEnd(lines: Array<{ text: string }>): number {\n  let i = 0;\n\n  // Skip overflow preambles: blocks introduced by \"PREVIOUS RECIPE OVERFLOW\",\n  // \"PREVIOUS PAGE CONTENT\", \"CORRUPTED SECTION\", etc. that precede the actual recipe.\n  const OVERFLOW_MARKERS = /\\b(PREVIOUS\\s+(RECIPE|PAGE)\\s+(OVERFLOW|CONTENT)|SPILLOVER|CONTINUATION|CORRUPTED\\s+SECTION)\\b/i;\n  let overflowEnd = 0;\n  for (let k = 0; k < lines.length && k < 30; k++) {\n    // Don't re-examine lines already determined to be overflow\n    if (overflowEnd > 0 && k < overflowEnd) continue;\n    if (OVERFLOW_MARKERS.test(lines[k].text)) {\n      // Skip forward past the overflow block to the next visual separator or blank cluster\n      let m = k + 1;\n      let consecutiveBlanks = 0;\n      while (m < lines.length) {\n        const lineText = lines[m].text;\n        // Stop at visual separator\n        if (/^[=\\-]{4,}$/.test(lineText)) {\n          overflowEnd = m + 1;\n          break;\n        }\n        // Track consecutive blank lines\n        if (lineText.trim().length === 0) {\n          consecutiveBlanks++;\n          if (consecutiveBlanks >= 2) {\n            overflowEnd = m + 1;\n            break;\n          }\n        } else {\n          consecutiveBlanks = 0;\n          // Stop at ALL_CAPS line with ≥2 words (likely next recipe heading)\n          if (isAllCaps(lineText) && wordCount(lineText) >= 2) {\n            overflowEnd = m; // Don't skip past the heading itself\n            break;\n          }\n        }\n        m++;\n      }\n      // If we walked to end without finding termination, skip everything we saw\n      if (overflowEnd === 0) overflowEnd = m;\n    }\n  }\n  if (overflowEnd > 0) i = overflowEnd;\n\n  while (i < lines.length && lines[i].text.length < 20 && isLikelyGarbled(lines[i].text) && !isAllCaps(lines[i].text)) {\n    i++;\n  }\n  // Skip long instruction-like prologues: if 5+ consecutive lines look like cooking instructions,\n  // skip them to find the actual title region.\n  if (i === 0) {\n    let j = 0;\n    while (j < lines.length && looksLikeCookingInstruction(lines[j].text)) {\n      j++;\n    }\n    if (j >= 5) {\n      i = j;\n    }\n  }\n  // Skip prose prologues: mid-recipe body text before the actual title.\n  // If 3+ consecutive lines look like running body text (lowercase start, continuation,\n  // or sentence-ending with many words), skip them.\n  if (i === 0) {\n    let j = 0;\n    while (j < lines.length) {\n      const t = lines[j].text;\n      const isBodyText = (\n        /^[a-ząćęłńóśźż]/.test(t) ||\n        t.endsWith(\",\") ||\n        (t.endsWith(\".\") && wordCount(t) > 4)\n      ) && wordCount(t) >= 4;\n      if (isBodyText) j++;\n      else break;\n    }\n    if (j >= 3) i = j;\n  }\n  return i;\n}\n\nfunction stripParentheticalGloss(text: string): string {\n  // Strip trailing English-gloss parentheticals from ALL_CAPS titles.","numLines":80,"startLine":430,"totalLines":1518}}}
