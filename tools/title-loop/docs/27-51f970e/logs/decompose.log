dients (without diacritics) ───────────────────────────────\n    94→  \"kurczak\", \"wolowina\", \"wieprzowina\", \"cielecina\", \"golonka\",\n    95→  \"losos\", \"dorsz\", \"krewetki\", \"ryz\", \"makaron\", \"chleb\", \"maslo\",\n    96→  \"smietana\", \"ser\", \"czosnek\", \"cebula\", \"pomidor\", \"ziemniak\",\n    97→  \"marchew\", \"seler\", \"pieprz\", \"sol\", \"cukier\", \"maka\", \"jajko\",\n    98→  \"mleko\", \"olej\", \"ocet\", \"cytryna\", \"pomarancza\", \"jablko\", \"jagoda\",\n    99→  \"malina\", \"truskawka\", \"wisnia\", \"brzoskwinia\", \"gruszka\", \"sliwka\",\n   100→  \"winogrono\", \"banan\", \"orzech\", \"migdal\", \"imbir\", \"cynamon\",\n   101→  \"kminek\", \"papryka\", \"kurkuma\", \"oregano\", \"bazylia\", \"tymianek\",\n   102→  \"rozmaryn\", \"pietruszka\", \"kolendra\", \"koperek\", \"mieta\", \"szalwia\",\n   103→  \"szpinak\", \"kapusta\", \"kalafior\", \"szparag\", \"baklazan\", \"cukinia\",\n   104→  \"dynia\", \"ogorek\", \"rzodkiewka\", \"burak\", \"grzyb\", \"awokado\",\n   105→  \"oliwka\", \"fasola\", \"soczewica\", \"ciecierzyca\", \"kasza\", \"owies\",\n   106→  \"jeczmien\", \"pszenica\", \"zyto\",\n   107→\n   108→  // Polish bread varieties\n   109→  \"pszenny\", \"razowy\", \"zytni\", \"wieloziarnisty\", \"tostowy\",\n   110→\n   111→  // Polish cooking terms (without diacritics)\n   112→  \"piec\", \"smazyc\", \"grillowac\", \"gotowac\", \"dusic\", \"blanszowac\",\n   113→  \"kroic\", \"siekac\", \"marynowac\", \"przyprawiac\", \"karmelizowac\",\n   114→  \"podsmaz\", \"zapiekac\", \"gotowac\", \"dusic\", \"wedzic\", \"kisic\",\n   115→\n   116→  // Polish dishes\n   117→  \"bigos\", \"zurek\", \"barszcz\", \"rosol\", \"kotlet\", \"schabowy\",\n   118→  \"golabki\", \"placki\", \"nalesniki\", \"piernik\", \"sernik\", \"makowiec\",\n   119→  \"babka\", \"chalka\", \"rogal\", \"paczek\", \"faworki\", \"kluski\",\n   120→  \"kopytka\", \"pyzy\", \"uszka\", \"gzik\", \"flaczki\", \"zrazy\", \"gulasz\",\n   121→  \"leczo\", \"kapusniak\", \"grochowka\", \"krupnik\", \"zupa\", \"sałatka\",\n   122→  \"salatka\", \"mizeria\", \"surowka\",\n   123→\n   124→  // Polish ingredient descriptors (without diacritics)\n   125→  \"swiezy\", \"suszony\", \"marynowany\", \"wegdzony\", \"pieczony\", \"gotowany\",\n   126→  \"smazony\", \"surowy\", \"mrożony\", \"mrozony\", \"konserwowy\",\n   127→  \"ziemniaczane\", \"ziemniaczany\",\n   128→\n   129→  // Polish section labels (appear in recipe texts, useful for context)\n   130→  \"skladniki\", \"przygotowanie\", \"sposob\", \"wykonanie\", \"porcje\",\n   131→  \"czas\", \"temperatura\", \"pieczenia\",\n   132→\n   133→  // ── Common title words (for OCR repair) ─────────────────────────────────\n   134→  // Prepositions & conjunctions\n   135→  \"with\", \"from\", \"over\", \"under\", \"the\", \"and\", \"for\",\n   136→  // Adjectives commonly in recipe titles\n   137→  \"classic\", \"simple\", \"quick\", \"easy\", \"light\",\n   138→  \"thick\", \"thin\", \"old\", \"new\",\n   139→  // Short food terms missing from main dictionary\n   140→  \"dip\", \"bun\", \"buns\", \"roll\", \"rolls\",\n   141→  \"jam\", \"jelly\", \"loaf\", \"hash\", \"bowl\",\n   142→  // Polish common title words (without diacritics)\n   143→  \"pieczone\", \"smazone\",\n   144→  \"gotowane\", \"duszone\", \"duszony\",\n   145→  \"domowy\", \"domowe\", \"tradycyjny\", \"tradycyjne\",\n   146→]);\n   147→"}]},"parent_tool_use_id":"toolu_01G8C2dkPvbhHaYpuQ3jx316","session_id":"b58b8c45-4f2d-433d-859c-e1c4435e3073","uuid":"8a230677-071b-4737-8a5b-23a6faa6e8f0"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NTFw24AGaz1JzhhPG99Zmm","type":"tool_result","content":"<persisted-output>\nOutput too large (75.4KB). Full output saved to: /Users/eryk.napierala/.claude/projects/-Users-eryk-napierala-Projects-fasola/b58b8c45-4f2d-433d-859c-e1c4435e3073/tool-results/toolu_01NTFw24AGaz1JzhhPG99Zmm.txt\n\nPreview (first 2KB):\n     1→/**\n     2→ * Title Extraction\n     3→ * Extracts potential recipe title from OCR text using heuristics or semantic embeddings\n     4→ */\n     5→\n     6→import { cosineSimilarity } from \"./embeddings\";\n     7→import { FOOD_DICTIONARY } from \"./food-dictionary\";\n     8→\n     9→export type EmbedFn = (text: string) => Promise<Array<number>>;\n    10→\n    11→const TITLE_REFERENCE =\n    12→  \"recipe name, dish title, name of the food, nazwa przepisu, nazwa dania\";\n    13→const HEADER_REFERENCE =\n    14→  \"ingredients list, cooking directions, section heading, składniki, przygotowanie, sposób wykonania\";\n    15→const NOISE_REFERENCE =\n    16→  \"page number, table of contents, book footer, garbled text\";\n    17→\n    18→/**\n    19→ * Measurement units commonly found in ingredient lists\n    20→ */\n    21→const MEASUREMENT_PATTERNS = [\n    22→  // English\n    23→  \"cup\",\n    24→  \"cups\",\n    25→  \"tbsp\",\n    26→  \"tsp\",\n    27→  \"tablespoon\",\n    28→  \"teaspoon\",\n    29→  // \"oz\" and \"lb\" are matched with word boundaries in looksLikeIngredient\n    30→  // to avoid false positives (\"oz\" in \"mozzarella\", \"lb\" in \"albacore\")\n    31→  \"gram\",\n    32→  \"grams\",\n    33→  \"kg\",\n    34→  \"ml\",\n    35→  \"liter\",\n    36→  \"pinch\",\n    37→  \"dash\",\n    38→  \"handful\",\n    39→  // Polish\n    40→  \"łyżka\", \"łyżki\", \"łyżek\",           // tablespoon(s)\n    41→  \"łyżeczka\", \"łyżeczki\", \"łyżeczek\",   // teaspoon(s)\n    42→  \"szklanka\", \"szklanki\", \"szklanek\",    // cup(s)\n    43→  \"szczypta\",     