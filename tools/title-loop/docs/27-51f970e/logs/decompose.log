{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GKaLAqr4eLgmjbPP1oiqn4","type":"tool_result","content":"   537→function buildCandidates(\n   538→  lines: Array<string>\n   539→): Array<{ text: string; position: number; origin: CandidateOrigin }> {\n   540→  const nonEmptyLines: Array<{ text: string; index: number }> = [];\n   541→\n   542→  for (let i = 0; i < lines.length; i++) {\n   543→    const trimmed = lines[i].trim();\n   544→    if (trimmed.length > 0) {\n   545→      nonEmptyLines.push({ text: trimmed, index: i });\n   546→    }\n   547→  }\n   548→\n   549→  const burstEnd = findBurstEnd(nonEmptyLines);\n   550→\n   551→  // Pre-join hyphen-broken lines: \"ROASTED CHICKEN WITH ROOT VEGET-\" + \"ABLES\" → single line.\n   552→  // Only applies within the candidate region (after burst end).\n   553→  for (let hi = burstEnd; hi < nonEmptyLines.length - 1; hi++) {\n   554→    if (nonEmptyLines[hi].text.endsWith(\"-\")) {\n   555→      const joined = nonEmptyLines[hi].text.slice(0, -1) + nonEmptyLines[hi + 1].text;\n   556→      nonEmptyLines[hi] = { text: joined, index: nonEmptyLines[hi].index };\n   557→      nonEmptyLines.splice(hi + 1, 1);\n   558→    }\n   559→  }\n   560→\n   561→  // Pre-merge consecutive short ALL_CAPS lines (OCR-fragmented headings).\n   562→  // When a sequence of 2+ ALL_CAPS lines each has ≤2 words and ≤25 chars, they are\n   563→  // almost certainly OCR fragments of a single heading. Merge them into one line so\n   564→  // the complete title enters the candidate pool without hitting the 3-line join ceiling.\n   565→  const capsCoalesced: Array<{ text: string; index: number }> = [];\n   566→  let ci = burstEnd;\n   567→  while (ci < nonEmptyLines.length) {\n   568→    const line = nonEmptyLines[ci];\n   569→    if (\n   570→      isAllCaps(line.text) &&\n   571→      wordCount(line.text) <= 2 &&\n   572→      line.text.length <= 25 &&\n   573→      !isSectionLabel(line.text) &&\n   574→      !looksLikeMetadata(line.text)\n   575→    ) {\n   576→      let merged = line.text;\n   577→      const startIndex = line.index;\n   578→      let j = ci + 1;\n   579→      while (j < nonEmptyLines.length) {\n   580→        const next = nonEmptyLines[j];\n   581→        if (\n   582→          isAllCaps(next.text) &&\n   583→          wordCount(next.text) <= 2 &&\n   584→          next.text.length <= 25 &&\n   585→          ((!isSectionLabel(next.text) && !isSectionLabel(repairOcrText(next.text))) ||\n   586→           (wordCount(next.text) === 1 && wordCount(merged) >= 2 && wordCount(merged) <= 4 &&\n   587→            isCategorySectionLabel(next.text))) &&\n   588→          !looksLikeMetadata(next.text) &&\n   589→          (merged + \" \" + next.text).length <= 80\n   590→        ) {\n   591→          merged += \" \" + next.text;\n   592→          j++;\n   593→        } else {\n   594→          break;\n   595→        }\n   596→      }\n   597→      if (j > ci + 1) {\n   598→        capsCoalesced.push({ text: merged, index: startIndex });\n   599→        ci = j;\n   600→        continue;\n   601→      }\n   602→    }\n   603→    capsCoalesced.push(line);\n   604→    ci++;\n   605→  }\n   606→\n   607→  // Pre-merge continuation lines: a line starting with /&+:( is never a standalone title.\n   608→  // Merge it into the preceding line so the complete title enters the pool as a single candidate,\n   609→  // avoiding the fragile chain of conditions required by the downstream join survival logic.\n   610→  // Limitation: only one continuation line per preceding line is merged. Titles split across\n   611→  // three or more lines with continuation tokens (rare in practice) are not handled here —\n   612→  // the downstream 2-line and 3-line join candidates cover those cases instead.\n   613→  const mergedLines: Array<{ text: string; index: number }> = [];\n   614→  for (let i = 0; i < capsCoalesced.length; i++) {\n   615→    const line = capsCoalesced[i];\n   616→    if (i + 1 < capsCoalesced.length) {\n   617→      const nextText = capsCoalesced[i + 1].text;\n   618→      if (/^[/&+:(]/.test(nextText)) {\n   619→        mergedLines.push({ text: `${line.text} ${nextText}`, index: line.index });\n   620→        i++;\n   621→        continue;\n   622→      }\n   623→    }\n   624→    mergedLines.push(line);\n   625→  }\n   626→\n   627→  const candidates: Array<{ text: string; position: number; origin: CandidateOrigin }> = [];\n   628→  const seen = new Set<string>();\n   629→\n   630→  // Build a set of positions to skip: short ALL_CAPS lines immediately following metadata\n   631→  const metadataContinuationPositions = new Set<number>();\n   632→  for (let i = 0; i < mergedLines.length - 1; i++) {\n   633→    if (looksLikeMetadata(mergedLines[i].text)) {\n   634→      const next = mergedLines[i + 1];\n   635→      if (isAllCaps(next.text) && wordCount(next.text) <= 2 && next.text.length <= 15) {\n   636→        metadataContinuationPositions.add(next.index);\n   637→      }\n   638→    }\n   639→  }\n   640→\n   641→  for (let i = 0; i < mergedLines.length; i++) {\n   642→    const line = mergedLines[i];\n   643→\n   644→    // Skip metadata continuation fragments\n   645→    if (metadataContinuationPositions.has(line.index)) continue;\n   646→\n   647→    // Single line — strip page-number prefixes and parenthetical glosses before scoring\n   648→    const singleText = repairOcrText(stripParentheticalGloss(stripPageNumber(line.text)));\n   649→    if (passesHardFilters(singleText)) {\n   650→      const norm = singleText.toLowerCase();\n   651→      if (!seen.has(norm)) {\n   652→        seen.add(norm);\n   653→        candidates.push({ text: singleText, position: line.index, origin: \"single\" });\n   654→      }\n   655→    }\n   656→\n   657→    // 2-line join — skip if first line is a section label AND join would be ≤2 words\n   658→    // (a section label followed by modifiers is likely a recipe title, not a category header)\n   659→    if (i + 1 < mergedLines.length) {\n   660→      const joined2 = repairOcrText(`${line.text} ${mergedLines[i + 1].text}`);\n   661→      const shouldBlock2 = isSectionLabel(line.text) &&\n   662→        (wordCount(joined2) <= 2 || isAlwaysBlockJoinLabel(line.text));\n   663→      if (!shouldBlock2 && passesHardFilters(joined2)) {\n   664→        const norm = joined2.toLowerCase();\n   665→        if (!seen.has(norm)) {\n   666→          seen.add(norm);\n   667→          candidates.push({ text: joined2, position: line.index, origin: \"2-line\" });\n   668→        }\n   669→      }\n   670→    }\n   671→\n   672→    // 3-line join — skip if first line is a section label AND join would be ≤2 words\n   673→    if (i + 2 < mergedLines.length) {\n   674→      const joined3 = repairOcrText(`${line.text} ${mergedLines[i + 1].text} ${mergedLines[i + 2].text}`);\n   675→      const shouldBlock3 = isSectionLabel(line.text) &&\n   676→        (wordCount(joined3) <= 2 || isAlwaysBlockJoinLabel(line.text));\n   677→      if (!shouldBlock3 && passesHardFilters(joined3)) {\n   678→        const norm = joined3.toLowerCase();\n   679→        if (!seen.has(norm)) {\n   680→          seen.add(norm);\n   681→          candidates.push({ text: joined3, position: line.index, origin: \"3-line\" });\n   682→        }\n   683→      }\n   684→    }\n   685→  }\n   686→"}]},"parent_tool_use_id":null,"session_id":"b58b8c45-4f2d-433d-859c-e1c4435e3073","uuid":"7843089c-1548-42d2-82fe-47c784cdd22b","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/title-extractor.ts","content":"function buildCandidates(\n  lines: Array<string>\n): Array<{ text: string; position: number; origin: CandidateOrigin }> {\n  const nonEmptyLines: Array<{ text: string; index: number }> = [];\n\n  for (let i = 0; i < lines.length; i++) {\n    const trimmed = lines[i].trim();\n    if (trimmed.length > 0) {\n      nonEmptyLines.push({ text: trimmed, index: i });\n    }\n  }\n\n  const burstEnd = findBurstEnd(nonEmptyLines);\n\n  // Pre-join hyphen-broken lines: \"ROASTED CHICKEN WITH ROOT VEGET-\" + \"ABLES\" → single line.\n  // Only applies within the candidate region (after burst end).\n  for (let hi = burstEnd; hi < nonEmptyLines.length - 1; hi++) {\n    if (nonEmptyLines[hi].text.endsWith(\"-\")) {\n      const joined = nonEmptyLines[hi].text.slice(0, -1) + nonEmptyLines[hi + 1].text;\n      nonEmptyLines[hi] = { text: joined, index: nonEmptyLines[hi].index };\n      nonEmptyLines.splice(hi + 1, 1);\n    }\n  }\n\n  // Pre-merge consecutive short ALL_CAPS lines (OCR-fragmented headings).\n  // When a sequence of 2+ ALL_CAPS lines each has ≤2 words and ≤25 chars, they are\n  // almost certainly OCR fragments of a single heading. Merge them into one line so\n  // the complete title enters the candidate pool without hitting the 3-line join ceiling.\n  const capsCoalesced: Array<{ text: string; index: number }> = [];\n  let ci = burstEnd;\n  while (ci < nonEmptyLines.length) {\n    const line = nonEmptyLines[ci];\n    if (\n      isAllCaps(line.text) &&\n      wordCount(line.text) <= 2 &&\n      line.text.length <= 25 &&\n      !isSectionLabel(line.text) &&\n      !looksLikeMetadata(line.text)\n    ) {\n      let merged = line.text;\n      const startIndex = line.index;\n      let j = ci + 1;\n      while (j < nonEmptyLines.length) {\n        const next = nonEmptyLines[j];\n        if (\n          isAllCaps(next.text) &&\n          wordCount(next.text) <= 2 &&\n          next.text.length <= 25 &&\n          ((!isSectionLabel(next.text) && !isSectionLabel(repairOcrText(next.text))) ||\n           (wordCount(next.text) === 1 && wordCount(merged) >= 2 && wordCount(merged) <= 4 &&\n            isCategorySectionLabel(next.text))) &&\n          !looksLikeMetadata(next.text) &&\n          (merged + \" \" + next.text).length <= 80\n        ) {\n          merged += \" \" + next.text;\n          j++;\n        } else {\n          break;\n        }\n      }\n      if (j > ci + 1) {\n        capsCoalesced.push({ text: merged, index: startIndex });\n        ci = j;\n        continue;\n      }\n    }\n    capsCoalesced.push(line);\n    ci++;\n  }\n\n  // Pre-merge continuation lines: a line starting with /&+:( is never a standalone title.\n  // Merge it into the preceding line so the complete title enters the pool as a single candidate,\n  // avoiding the fragile chain of conditions required by the downstream join survival logic.\n  // Limitation: only one continuation line per preceding line is merged. Titles split across\n  // three or more lines with continuation tokens (rare in practice) are not handled here —\n  // the downstream 2-line and 3-line join candidates cover those cases instead.\n  const mergedLines: Array<{ text: string; index: number }> = [];\n  for (let i = 0; i < capsCoalesced.length; i++) {\n    const line = capsCoalesced[i];\n    if (i + 1 < capsCoalesced.length) {\n      const nextText = capsCoalesced[i + 1].text;\n      if (/^[/&+:(]/.test(nextText)) {\n        mergedLines.push({ text: `${line.text} ${nextText}`, index: line.index });\n        i++;\n        continue;\n      }\n    }\n    mergedLines.push(line);\n  }\n\n  const candidates: Array<{ text: string; position: number; origin: CandidateOrigin }> = [];\n  const seen = new Set<string>();\n\n  // Build a set of positions to skip: short ALL_CAPS lines immediately following metadata\n  const metadataContinuationPositions = new Set<number>();\n  for (let i = 0; i < mergedLines.length - 1; i++) {\n    if (looksLikeMetadata(mergedLines[i].text)) {\n      const next = mergedLines[i + 1];\n      if (isAllCaps(next.text) && wordCount(next.text) <= 2 && next.text.length <= 15) {\n        metadataContinuationPositions.add(next.index);\n      }\n    }\n  }\n\n  for (let i = 0; i < mergedLines.length; i++) {\n    const line = mergedLines[i];\n\n    // Skip metadata continuation fragments\n    if (metadataContinuationPositions.has(line.index)) continue;\n\n    // Single line — strip page-number prefixes and parenthetical glosses before scoring\n    const singleText = repairOcrText(stripParentheticalGloss(stripPageNumber(line.text)));\n    if (passesHardFilters(singleText)) {\n      const norm = singleText.toLowerCase();\n      if (!seen.has(norm)) {\n        seen.add(norm);\n        candidates.push({ text: singleText, position: line.index, origin: \"single\" });\n      }\n    }\n\n    // 2-line join — skip if first line is a section label AND join would be ≤2 words\n    // (a section label followed by modifiers is likely a recipe title, not a category header)\n    if (i + 1 < mergedLines.length) {\n      const joined2 = repairOcrText(`${line.text} ${mergedLines[i + 1].text}`);\n      const shouldBlock2 = isSectionLabel(line.text) &&\n        (wordCount(joined2) <= 2 || isAlwaysBlockJoinLabel(line.text));\n      if (!shouldBlock2 && passesHardFilters(joined2)) {\n        const norm = joined2.toLowerCase();\n        if (!seen.has(norm)) {\n          seen.add(norm);\n          candidates.push({ text: joined2, position: line.index, origin: \"2-line\" });\n        }\n      }\n    }\n\n    // 3-line join — skip if first line is a section label AND join would be ≤2 words\n    if (i + 2 < mergedLines.length) {\n      const joined3 = repairOcrText(`${line.text} ${mergedLines[i + 1].text} ${mergedLines[i + 2].text}`);\n      const shouldBlock3 = isSectionLabel(line.text) &&\n        (wordCount(joined3) <= 2 || isAlwaysBlockJoinLabel(line.text));\n      if (!shouldBlock3 && passesHardFilters(joined3)) {\n        const norm = joined3.toLowerCase();\n        if (!seen.has(norm)) {\n          seen.add(norm);\n          candidates.push({ text: joined3, position: line.index, origin: \"3-line\" });\n        }\n      }\n    }\n  }\n","numLines":150,"startLine":537,"totalLines":1518}}}
