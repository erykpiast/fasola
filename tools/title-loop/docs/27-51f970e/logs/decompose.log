{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Cux1fyx2jbmYWZE27Lx4Sk","type":"tool_result","content":"   190→function isSectionLabel(text: string): boolean {\n   191→  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n   192→  if (SECTION_LABELS.has(normalized)) return true;\n   193→  // OCR variant: leading \"l\" may be OCR-corrupted \"I\" (e.g. \"lngredients\" → \"ingredients\")\n   194→  const ocrNormalized = normalized.replace(/^l/, \"i\");\n   195→  if (ocrNormalized !== normalized && SECTION_LABELS.has(ocrNormalized)) return true;\n   196→  return false;\n   197→}\n   198→\n   199→/**\n   200→ * Recipe-internal section labels that should ALWAYS block multi-line joins,\n   201→ * even when the combined word count is ≥ 3.\n   202→ * Category labels (\"zupy\", \"placki\", etc.) are NOT in this set — they can\n   203→ * legitimately start a multi-word recipe title like \"Zupy Zimowe Warzywne\".\n   204→ */\n   205→const ALWAYS_BLOCK_JOIN_LABELS = new Set([\n   206→  \"ingredients\", \"directions\", \"instructions\", \"method\", \"preparation\",\n   207→  \"steps\", \"notes\", \"tip\", \"tips\", \"variations\", \"variation\",\n   208→  \"garnish\", \"topping\", \"toppings\", \"frosting\", \"filling\",\n   209→  \"serving suggestion\", \"serving suggestions\", \"serving\",\n   210→  \"glaze\", \"instrukcje\", \"uwagi\", \"notatki\", \"podawanie\", \"przechowywanie\",\n   211→  \"skladniki\", \"przygotowanie\", \"sposob przygotowania\", \"sposob wykonania\",\n   212→  \"wykonanie\", \"wskazowki\", \"podpowiedz\", \"warianty\",\n   213→  \"sos\", \"nadzienie\", \"polewa\", \"lukier\", \"ciasto\",\n   214→]);\n   215→\n   216→function isAlwaysBlockJoinLabel(text: string): boolean {\n   217→  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n   218→  return ALWAYS_BLOCK_JOIN_LABELS.has(normalized);\n   219→}\n   220→\n   221→function isAllCaps(line: string): boolean {\n   222→  const letters = line.replace(/[^a-zA-Z]/g, \"\");\n   223→  return letters.length > 0 && letters === letters.toUpperCase();\n   224→}\n   225→\n   226→function looksLikeMetadata(text: string): boolean {\n   227→  return METADATA_PATTERNS.some((pattern) => pattern.test(text.trim()));\n   228→}\n   229→\n   230→/** Content words are ≥3 alpha characters after stripping punctuation. */\n   231→function extractContentWords(text: string): string[] {\n   232→  return text\n   233→    .split(/\\s+/)\n   234→    .filter((w) => w.replace(/[^a-zA-ZÀ-ÿ]/g, \"\").length >= 3)\n   235→    .map((w) => w.toUpperCase());\n   236→}\n   237→\n   238→/**\n   239→ * Returns true if the candidate's vocabulary is sufficiently supported by the rest of\n   240→ * the document. Short candidates (≤3 content words) require 100% corroboration;\n   241→ * longer candidates require ≥67%. Used to detect orphaned OCR artifacts in multi-title pages.\n   242→ */\n   243→function passesCorroboration(\n   244→  text: string,\n   245→  position: number,\n   246→  allLines: string[]\n   247→): boolean {\n   248→  const contentWords = extractContentWords(text);\n   249→\n   250→  if (contentWords.length === 0) {\n   251→    return true; // No checkable words — pass through\n   252→  }\n   253→\n   254→  let corroboratedCount = 0;\n   255→  for (const word of contentWords) {\n   256→    for (let i = 0; i < allLines.length; i++) {\n   257→      if (i === position) continue;\n   258→      if (allLines[i].toUpperCase().includes(word)) {\n   259→        corroboratedCount++;\n   260→        break;\n   261→      }\n   262→    }\n   263→  }\n   264→\n   265→  const score = corroboratedCount / contentWords.length;\n   266→  const threshold = contentWords.length <= 3 ? 1.0 : 0.67;\n   267→  return score >= threshold;\n   268→}\n   269→\n   270→function isLikelyGarbled(text: string): boolean {\n   271→  const letters = text.replace(/[^a-zA-Z]/g, \"\");\n   272→  if (letters.length < 2) return true;\n   273→\n   274→  // Pipe embedded in words = OCR artifact (e.g., \"Sp|aszcz\", \"pa|ką\")\n   275→  if (/[a-zA-ZÀ-ÿа-яА-Я]\\|[a-zA-ZÀ-ÿа-яА-Я]/.test(text)) return true;\n   276→\n   277→  // Mixed Latin + Cyrillic = OCR corruption\n   278→  if (/[а-яА-ЯёЁіІїЇєЄґҐ]/.test(text) && /[a-zA-Z]/.test(text)) return true;\n   279→\n   280→  // Check vowel ratio — English/Polish text typically has 30–50% vowels\n   281→  const vowels = letters.replace(/[^aeiouAEIOUyYąęóĄĘÓ]/g, \"\").length;\n   282→  const vowelRatio = vowels / letters.length;\n   283→  if (vowelRatio < 0.10 || vowelRatio > 0.85) return true;\n   284→\n   285→  // Single orphaned word ≤3 letters that isn't a common word\n   286→  const words = text.trim().split(/\\s+/);\n   287→  const COMMON_SHORT = new Set([\n   288→    \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"had\", \"her\",\n   289→    \"was\", \"one\", \"our\", \"out\", \"are\", \"has\", \"his\", \"how\", \"its\", \"may\","}]},"parent_tool_use_id":"toolu_01G8C2dkPvbhHaYpuQ3jx316","session_id":"b58b8c45-4f2d-433d-859c-e1c4435e3073","uuid":"2ee336b2-1a5d-4278-a6f8-9b955009463a"}
