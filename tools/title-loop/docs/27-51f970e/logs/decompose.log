{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QDhunhcivuBHfFVsCh26bq","type":"tool_result","content":"   430→function findBurstEnd(lines: Array<{ text: string }>): number {\n   431→  let i = 0;\n   432→\n   433→  // Skip overflow preambles: blocks introduced by \"PREVIOUS RECIPE OVERFLOW\",\n   434→  // \"PREVIOUS PAGE CONTENT\", \"CORRUPTED SECTION\", etc. that precede the actual recipe.\n   435→  const OVERFLOW_MARKERS = /\\b(PREVIOUS\\s+(RECIPE|PAGE)\\s+(OVERFLOW|CONTENT)|SPILLOVER|CONTINUATION|CORRUPTED\\s+SECTION)\\b/i;\n   436→  let overflowEnd = 0;\n   437→  for (let k = 0; k < lines.length && k < 30; k++) {\n   438→    // Don't re-examine lines already determined to be overflow\n   439→    if (overflowEnd > 0 && k < overflowEnd) continue;\n   440→    if (OVERFLOW_MARKERS.test(lines[k].text)) {\n   441→      // Skip forward past the overflow block to the next visual separator or blank cluster\n   442→      let m = k + 1;\n   443→      let consecutiveBlanks = 0;\n   444→      while (m < lines.length) {\n   445→        const lineText = lines[m].text;\n   446→        // Stop at visual separator\n   447→        if (/^[=\\-]{4,}$/.test(lineText)) {\n   448→          overflowEnd = m + 1;\n   449→          break;\n   450→        }\n   451→        // Track consecutive blank lines\n   452→        if (lineText.trim().length === 0) {\n   453→          consecutiveBlanks++;\n   454→          if (consecutiveBlanks >= 2) {\n   455→            overflowEnd = m + 1;\n   456→            break;\n   457→          }\n   458→        } else {\n   459→          consecutiveBlanks = 0;\n   460→          // Stop at ALL_CAPS line with ≥2 words (likely next recipe heading)\n   461→          if (isAllCaps(lineText) && wordCount(lineText) >= 2) {\n   462→            overflowEnd = m; // Don't skip past the heading itself\n   463→            break;\n   464→          }\n   465→        }\n   466→        m++;\n   467→      }\n   468→      // If we walked to end without finding termination, skip everything we saw\n   469→      if (overflowEnd === 0) overflowEnd = m;\n   470→    }\n   471→  }\n   472→  if (overflowEnd > 0) i = overflowEnd;\n   473→\n   474→  while (i < lines.length && lines[i].text.length < 20 && isLikelyGarbled(lines[i].text) && !isAllCaps(lines[i].text)) {\n   475→    i++;\n   476→  }\n   477→  // Skip long instruction-like prologues: if 5+ consecutive lines look like cooking instructions,\n   478→  // skip them to find the actual title region.\n   479→  if (i === 0) {\n   480→    let j = 0;\n   481→    while (j < lines.length && looksLikeCookingInstruction(lines[j].text)) {\n   482→      j++;\n   483→    }\n   484→    if (j >= 5) {\n   485→      i = j;\n   486→    }\n   487→  }\n   488→  // Skip prose prologues: mid-recipe body text before the actual title.\n   489→  // If 3+ consecutive lines look like running body text (lowercase start, continuation,\n   490→  // or sentence-ending with many words), skip them.\n   491→  if (i === 0) {\n   492→    let j = 0;\n   493→    while (j < lines.length) {\n   494→      const t = lines[j].text;\n   495→      const isBodyText = (\n   496→        /^[a-ząćęłńóśźż]/.test(t) ||\n   497→        t.endsWith(\",\") ||\n   498→        (t.endsWith(\".\") && wordCount(t) > 4)\n   499→      ) && wordCount(t) >= 4;\n   500→      if (isBodyText) j++;\n   501→      else break;\n   502→    }\n   503→    if (j >= 3) i = j;\n   504→  }\n   505→  return i;\n   506→}\n   507→\n   508→function stripParentheticalGloss(text: string): string {\n   509→  // Strip trailing English-gloss parentheticals from ALL_CAPS titles."}]},"parent_tool_use_id":"toolu_01G8C2dkPvbhHaYpuQ3jx316","session_id":"b58b8c45-4f2d-433d-859c-e1c4435e3073","uuid":"62756d57-f410-47b6-9e04-16f0f53a4a2c"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TFTJyEwmKr5HE3Dgnc8R5e","type":"tool_result","content":"   537→function buildCandidates(\n   538→  lines: Array<string>\n   539→): Array<{ text: string; position: number; origin: CandidateOrigin }> {\n   540→  const nonEmptyLines: Array<{ text: string; index: number }> = [];\n   541→\n   542→  for (let i = 0; i < lines.length; i++) {\n   543→    const trimmed = lines[i].trim();\n   544→    if (trimmed.length > 0) {\n   545→      nonEmptyLines.push({ text: trimmed, index: i });\n   546→    }\n   547→  }\n   548→\n   549→  const burstEnd = findBurstEnd(nonEmptyLines);\n   550→\n   551→  // Pre-join hyphen-broken lines: \"ROASTED CHICKEN WITH ROOT VEGET-\" + \"ABLES\" → single line.\n   552→  // Only applies within the candidate region (after burst end).\n   553→  for (let hi = burstEnd; hi < nonEmptyLines.length - 1; hi++) {\n   554→    if (nonEmptyLines[hi].text.endsWith(\"-\")) {\n   555→      const joined = nonEmptyLines[hi].text.slice(0, -1) + nonEmptyLines[hi + 1].text;\n   556→      nonEmptyLines[hi] = { text: joined, index: nonEmptyLines[hi].index };\n   557→      nonEmptyLines.splice(hi + 1, 1);\n   558→    }\n   559→  }\n   560→\n   561→  // Pre-merge consecutive short ALL_CAPS lines (OCR-fragmented headings).\n   562→  // When a sequence of 2+ ALL_CAPS lines each has ≤2 words and ≤25 chars, they are\n   563→  // almost certainly OCR fragments of a single heading. Merge them into one line so\n   564→  // the complete title enters the candidate pool without hitting the 3-line join ceiling.\n   565→  const capsCoalesced: Array<{ text: string; index: number }> = [];\n   566→  let ci = burstEnd;\n   567→  while (ci < nonEmptyLines.length) {\n   568→    const line = nonEmptyLines[ci];\n   569→    if (\n   570→      isAllCaps(line.text) &&\n   571→      wordCount(line.text) <= 2 &&\n   572→      line.text.length <= 25 &&\n   573→      !isSectionLabel(line.text) &&\n   574→      !looksLikeMetadata(line.text)\n   575→    ) {\n   576→      let merged = line.text;\n   577→      const startIndex = line.index;\n   578→      let j = ci + 1;\n   579→      while (j < nonEmptyLines.length) {\n   580→        const next = nonEmptyLines[j];\n   581→        if (\n   582→          isAllCaps(next.text) &&\n   583→          wordCount(next.text) <= 2 &&\n   584→          next.text.length <= 25 &&\n   585→          ((!isSectionLabel(next.text) && !isSectionLabel(repairOcrText(next.text))) ||\n   586→           (wordCount(next.text) === 1 && wordCount(merged) >= 2 && wordCount(merged) <= 4 &&\n   587→            isCategorySectionLabel(next.text))) &&\n   588→          !looksLikeMetadata(next.text) &&\n   589→          (merged + \" \" + next.text).length <= 80\n   590→        ) {\n   591→          merged += \" \" + next.text;\n   592→          j++;\n   593→        } else {\n   594→          break;\n   595→        }\n   596→      }\n   597→      if (j > ci + 1) {\n   598→        capsCoalesced.push({ text: merged, index: startIndex });\n   599→        ci = j;\n   600→        continue;\n   601→      }\n   602→    }\n   603→    capsCoalesced.push(line);\n   604→    ci++;\n   605→  }\n   606→\n   607→  // Pre-merge continuation lines: a line starting with /&+:( is never a standalone title.\n   608→  // Merge it into the preceding line so the complete title enters the pool as a single candidate,\n   609→  // avoiding the fragile chain of conditions required by the downstream join survival logic.\n   610→  // Limitation: only one continuation line per preceding line is merged. Titles split across\n   611→  // three or more lines with continuation tokens (rare in practice) are not handled here —\n   612→  // the downstream 2-line and 3-line join candidates cover those cases instead.\n   613→  const mergedLines: Array<{ text: string; index: number }> = [];\n   614→  for (let i = 0; i < capsCoalesced.length; i++) {\n   615→    const line = capsCoalesced[i];\n   616→    if (i + 1 < capsCoalesced.length) {\n   617→      const nextText = capsCoalesced[i + 1].text;\n   618→      if (/^[/&+:(]/.test(nextText)) {\n   619→        mergedLines.push({ text: `${line.text} ${nextText}`, index: line.index });\n   620→        i++;\n   621→        continue;\n   622→      }\n   623→    }\n   624→    mergedLines.push(line);\n   625→  }\n   626→\n   627→  const candidates: Array<{ text: string; position: number; origin: CandidateOrigin }> = [];\n   628→  const seen = new Set<string>();\n   629→\n   630→  // Build a set of positions to skip: short ALL_CAPS lines immediately following metadata\n   631→  const metadataContinuationPositions = new Set<number>();\n   632→  for (let i = 0; i < mergedLines.length - 1; i++) {\n   633→    if (looksLikeMetadata(mergedLines[i].text)) {\n   634→      const next = mergedLines[i + 1];\n   635→      if (isAllCaps(next.text) && wordCount(next.text) <= 2 && next.text.length <= 15) {\n   636→        metadataContinuationPositions.add(next.index);\n   637→      }\n   638→    }\n   639→  }\n   640→\n   641→  for (let i = 0; i < mergedLines.length; i++) {\n   642→    const line = mergedLines[i];\n   643→\n   644→    // Skip metadata continuation fragments\n   645→    if (metadataContinuationPositions.has(line.index)) continue;\n   646→\n   647→    // Single line — strip page-number prefixes and parenthetical glosses before scoring\n   648→    const singleText = repairOcrText(stripParentheticalGloss(stripPageNumber(line.text)));\n   649→    if (passesHardFilters(singleText)) {\n   650→      const norm = singleText.toLowerCase();\n   651→      if (!seen.has(norm)) {\n   652→        seen.add(norm);\n   653→        candidates.push({ text: singleText, position: line.index, origin: \"single\" });\n   654→      }\n   655→    }\n   656→\n   657→    // 2-line join — skip if first line is a section label AND join would be ≤2 words\n   658→    // (a section label followed by modifiers is likely a recipe title, not a category header)\n   659→    if (i + 1 < mergedLines.length) {\n   660→      const joined2 = repairOcrText(`${line.text} ${mergedLines[i + 1].text}`);\n   661→      const shouldBlock2 = isSectionLabel(line.text) &&\n   662→        (wordCount(joined2) <= 2 || isAlwaysBlockJoinLabel(line.text));\n   663→      if (!shouldBlock2 && passesHardFilters(joined2)) {\n   664→        const norm = joined2.toLowerCase();\n   665→        if (!seen.has(norm)) {\n   666→          seen.add(norm);\n   667→          candidates.push({ text: joined2, position: line.index, origin: \"2-line\" });\n   668→        }\n   669→      }\n   670→    }\n   671→\n   672→    // 3-line join — skip if first line is a section label AND join would be ≤2 words\n   673→    if (i + 2 < mergedLines.length) {\n   674→      const joined3 = repairOcrText(`${line.text} ${mergedLines[i + 1].text} ${mergedLines[i + 2].text}`);\n   675→      const shouldBlock3 = isSectionLabel(line.text) &&\n   676→        (wordCount(joined3) <= 2 || isAlwaysBlockJoinLabel(line.text));\n   677→      if (!shouldBlock3 && passesHardFilters(joined3)) {\n   678→        const norm = joined3.toLowerCase();\n   679→        if (!seen.has(norm)) {\n   680→          seen.add(norm);\n   681→          candidates.push({ text: joined3, position: line.index, origin: \"3-line\" });\n   682→        }\n   683→      }\n   684→    }\n   685→  }\n   686→"}]},"parent_tool_use_id":"toolu_01G8C2dkPvbhHaYpuQ3jx316","session_id":"b58b8c45-4f2d-433d-859c-e1c4435e3073","uuid":"613dc12d-11eb-4694-bb7c-e2fc100545b8"}
