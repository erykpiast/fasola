{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AtfeQKEsiYKStZL6cRwGZP","type":"tool_result","content":"  1015→  }\n  1016→\n  1017→  // First-after-preamble bonus (Pattern 3): when lines before the first candidate were all\n  1018→  // filtered/empty, the first surviving candidate occupies the structural \"title position\".\n  1019→  // E.g. \"FISH & SEAFOOD\\nHalibut with Saffron Cream Sauce\\n...\" — \"FISH & SEAFOOD\" is filtered\n  1020→  // as a section label, so \"Halibut...\" is the first candidate and gets this boost.\n  1021→  const firstCandidate = scored[0];\n  1022→  // Capture base score before positional bonuses to cap combined boost later\n  1023→  const baseScoreBeforePositionalBonuses = firstCandidate.baseScore;\n  1024→  if (firstCandidate.position > 0) {\n  1025→    const allPrecedingFiltered = lines\n  1026→      .slice(0, firstCandidate.position)\n  1027→      .every((line) => {\n  1028→        const trimmed = line.trim();\n  1029→        return trimmed === \"\" || !passesHardFilters(trimmed) || isSectionLabel(trimmed);\n  1030→      });\n  1031→    if (allPrecedingFiltered) {\n  1032→      // Stronger bonus when preamble contained structural markers (section labels, metadata)\n  1033→      // vs. only empty lines — structural markers are stronger positional evidence.\n  1034→      const hasStructuralPreamble = lines\n  1035→        .slice(0, firstCandidate.position)\n  1036→        .some((line) => {\n  1037→          const trimmed = line.trim();\n  1038→          return trimmed !== \"\" && (isSectionLabel(trimmed) || looksLikeMetadata(trimmed) || trimmed.includes(\" | \"));\n  1039→        });\n  1040→      const preambleBonus = hasStructuralPreamble ? 0.12 : 0.08;\n  1041→      firstCandidate.score += preambleBonus;\n  1042→      firstCandidate.baseScore += preambleBonus;\n  1043→      firstCandidate.thresholdScore += preambleBonus;\n  1044→    }\n  1045→  }\n  1046→  // Cap combined positional boost (candidate-relative position factor + first-after-preamble bonus)\n  1047→  // to avoid over-boosting when both fire together (~+0.24 uncapped → capped at +0.15).\n  1048→  const maxPositionalBoost = 0.15;\n  1049→  const totalPositionalBoost = firstCandidate.score - baseScoreBeforePositionalBonuses;\n  1050→  if (totalPositionalBoost > maxPositionalBoost) {\n  1051→    const excess = totalPositionalBoost - maxPositionalBoost;\n  1052→    firstCandidate.score -= excess;\n  1053→    firstCandidate.baseScore -= excess;\n  1054→    firstCandidate.thresholdScore -= excess;\n  1055→  }\n  1056→\n  1057→  // --- Pre-threshold bilingual title detection ---\n  1058→  // When a mixed-case candidate at position 0 is followed by an ALL_CAPS candidate\n  1059→  // at position ≤ 2 that is semantically similar to it, this is a bilingual recipe\n  1060→  // page (e.g., Polish title + ALL_CAPS Korean romanization). Suppress confirmed\n  1061→  // translation candidates before computing threshold so their bonuses don't inflate\n  1062→  // the threshold beyond the mixed-case title's reach.\n  1063→  // Note: we check position ≤ 2 (local proximity), not global ALL_CAPS count, so\n  1064→  // section headers later in the document (SKŁADNIKI, WARZYWA, etc.) are irrelevant."}]},"parent_tool_use_id":null,"session_id":"b58b8c45-4f2d-433d-859c-e1c4435e3073","uuid":"1869fc42-cc10-4c71-a342-ff379472527d","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/title-extractor.ts","content":"  }\n\n  // First-after-preamble bonus (Pattern 3): when lines before the first candidate were all\n  // filtered/empty, the first surviving candidate occupies the structural \"title position\".\n  // E.g. \"FISH & SEAFOOD\\nHalibut with Saffron Cream Sauce\\n...\" — \"FISH & SEAFOOD\" is filtered\n  // as a section label, so \"Halibut...\" is the first candidate and gets this boost.\n  const firstCandidate = scored[0];\n  // Capture base score before positional bonuses to cap combined boost later\n  const baseScoreBeforePositionalBonuses = firstCandidate.baseScore;\n  if (firstCandidate.position > 0) {\n    const allPrecedingFiltered = lines\n      .slice(0, firstCandidate.position)\n      .every((line) => {\n        const trimmed = line.trim();\n        return trimmed === \"\" || !passesHardFilters(trimmed) || isSectionLabel(trimmed);\n      });\n    if (allPrecedingFiltered) {\n      // Stronger bonus when preamble contained structural markers (section labels, metadata)\n      // vs. only empty lines — structural markers are stronger positional evidence.\n      const hasStructuralPreamble = lines\n        .slice(0, firstCandidate.position)\n        .some((line) => {\n          const trimmed = line.trim();\n          return trimmed !== \"\" && (isSectionLabel(trimmed) || looksLikeMetadata(trimmed) || trimmed.includes(\" | \"));\n        });\n      const preambleBonus = hasStructuralPreamble ? 0.12 : 0.08;\n      firstCandidate.score += preambleBonus;\n      firstCandidate.baseScore += preambleBonus;\n      firstCandidate.thresholdScore += preambleBonus;\n    }\n  }\n  // Cap combined positional boost (candidate-relative position factor + first-after-preamble bonus)\n  // to avoid over-boosting when both fire together (~+0.24 uncapped → capped at +0.15).\n  const maxPositionalBoost = 0.15;\n  const totalPositionalBoost = firstCandidate.score - baseScoreBeforePositionalBonuses;\n  if (totalPositionalBoost > maxPositionalBoost) {\n    const excess = totalPositionalBoost - maxPositionalBoost;\n    firstCandidate.score -= excess;\n    firstCandidate.baseScore -= excess;\n    firstCandidate.thresholdScore -= excess;\n  }\n\n  // --- Pre-threshold bilingual title detection ---\n  // When a mixed-case candidate at position 0 is followed by an ALL_CAPS candidate\n  // at position ≤ 2 that is semantically similar to it, this is a bilingual recipe\n  // page (e.g., Polish title + ALL_CAPS Korean romanization). Suppress confirmed\n  // translation candidates before computing threshold so their bonuses don't inflate\n  // the threshold beyond the mixed-case title's reach.\n  // Note: we check position ≤ 2 (local proximity), not global ALL_CAPS count, so\n  // section headers later in the document (SKŁADNIKI, WARZYWA, etc.) are irrelevant.","numLines":50,"startLine":1015,"totalLines":1518}}}
