{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019ZZ99hat7ZfKLMTJB2fK16","type":"tool_result","content":"   728→const OCR_SUBSTITUTIONS: Record<string, string[]> = {\n   729→  \"0\": [\"o\"],\n   730→  \"1\": [\"i\", \"l\"],\n   731→  \"4\": [\"a\"],\n   732→  \"5\": [\"s\"],\n   733→  \"¡\": [\"i\"],\n   734→  \"í\": [\"i\", \"l\"],\n   735→  \"€\": [\"e\"],\n   736→};\n   737→\n   738→const OCR_ARTIFACT_PATTERN = /[0-9¡Íí€]/;\n   739→\n   740→/**\n   741→ * Attempt to repair a single OCR-corrupted word using dictionary lookup.\n   742→ * Returns the repaired word if a dictionary match is found, otherwise returns the original.\n   743→ */\n   744→function repairOcrWord(word: string): string {\n   745→  if (!OCR_ARTIFACT_PATTERN.test(word)) return word;\n   746→\n   747→  const lower = word.toLowerCase();\n   748→\n   749→  const positions: Array<{ index: number; replacements: Array<string> }> = [];\n   750→  for (let i = 0; i < lower.length; i++) {\n   751→    const replacements = OCR_SUBSTITUTIONS[lower[i]];\n   752→    if (replacements) {\n   753→      positions.push({ index: i, replacements });\n   754→    }\n   755→  }\n   756→\n   757→  if (positions.length === 0 || positions.length > 8) return word;\n   758→\n   759→  const candidates = generateSubstitutions(lower, positions, 0);\n   760→\n   761→  for (const candidate of candidates) {\n   762→    if (FOOD_DICTIONARY.has(candidate)) {\n   763→      if (word === word.toUpperCase()) return candidate.toUpperCase();\n   764→      if (word[0] === word[0].toUpperCase()) {\n   765→        return candidate[0].toUpperCase() + candidate.slice(1);\n   766→      }\n   767→      return candidate;\n   768→    }\n   769→  }\n   770→\n   771→  return word;\n   772→}\n   773→\n   774→/**\n   775→ * Recursively generate all substitution variants for OCR artifact positions.\n   776→ */\n   777→function generateSubstitutions(\n   778→  base: string,\n   779→  positions: Array<{ index: number; replacements: Array<string> }>,\n   780→  posIdx: number,\n   781→): Array<string> {\n   782→  if (posIdx >= positions.length) return [base];\n   783→\n   784→  const { index, replacements } = positions[posIdx];\n   785→  const results: Array<string> = [];\n   786→\n   787→  for (const replacement of replacements) {\n   788→    const variant = base.slice(0, index) + replacement + base.slice(index + 1);\n   789→    results.push(...generateSubstitutions(variant, positions, posIdx + 1));\n   790→  }\n   791→\n   792→  return results;\n   793→}\n   794→\n   795→/**\n   796→ * Apply dictionary-guided OCR repair to all words in a text string.\n   797→ */\n   798→function repairOcrText(text: string): string {\n   799→  return text\n   800→    .split(/\\s+/)\n   801→    .map((word) => {\n   802→      const match = word.match(/^([^a-zA-Z0-9À-ÿ]*)(.*?)([^a-zA-Z0-9À-ÿ]*)$/);\n   803→      if (!match) return word;\n   804→      const [, prefix, core, suffix] = match;\n   805→      if (!core) return word;\n   806→      const repaired = repairOcrWord(core);\n   807→      return prefix + repaired + suffix;\n   808→    })\n   809→    .join(\" \");\n   810→}\n   811→\n   812→/**\n   813→ * Post-processing normalization for OCR-extracted titles.\n   814→ * Strips stray section markers and substitutes common OCR digit-for-letter artifacts.\n   815→ * Title-case conversion is applied only when a substitution was actually made, so\n   816→ * clean ALL_CAPS titles (e.g. \"CHOCOLATE CAKE\") are returned unchanged.\n   817→ */"}]},"parent_tool_use_id":null,"session_id":"b58b8c45-4f2d-433d-859c-e1c4435e3073","uuid":"1cc330b9-cb37-4304-96f9-bf081e273368","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/title-extractor.ts","content":"const OCR_SUBSTITUTIONS: Record<string, string[]> = {\n  \"0\": [\"o\"],\n  \"1\": [\"i\", \"l\"],\n  \"4\": [\"a\"],\n  \"5\": [\"s\"],\n  \"¡\": [\"i\"],\n  \"í\": [\"i\", \"l\"],\n  \"€\": [\"e\"],\n};\n\nconst OCR_ARTIFACT_PATTERN = /[0-9¡Íí€]/;\n\n/**\n * Attempt to repair a single OCR-corrupted word using dictionary lookup.\n * Returns the repaired word if a dictionary match is found, otherwise returns the original.\n */\nfunction repairOcrWord(word: string): string {\n  if (!OCR_ARTIFACT_PATTERN.test(word)) return word;\n\n  const lower = word.toLowerCase();\n\n  const positions: Array<{ index: number; replacements: Array<string> }> = [];\n  for (let i = 0; i < lower.length; i++) {\n    const replacements = OCR_SUBSTITUTIONS[lower[i]];\n    if (replacements) {\n      positions.push({ index: i, replacements });\n    }\n  }\n\n  if (positions.length === 0 || positions.length > 8) return word;\n\n  const candidates = generateSubstitutions(lower, positions, 0);\n\n  for (const candidate of candidates) {\n    if (FOOD_DICTIONARY.has(candidate)) {\n      if (word === word.toUpperCase()) return candidate.toUpperCase();\n      if (word[0] === word[0].toUpperCase()) {\n        return candidate[0].toUpperCase() + candidate.slice(1);\n      }\n      return candidate;\n    }\n  }\n\n  return word;\n}\n\n/**\n * Recursively generate all substitution variants for OCR artifact positions.\n */\nfunction generateSubstitutions(\n  base: string,\n  positions: Array<{ index: number; replacements: Array<string> }>,\n  posIdx: number,\n): Array<string> {\n  if (posIdx >= positions.length) return [base];\n\n  const { index, replacements } = positions[posIdx];\n  const results: Array<string> = [];\n\n  for (const replacement of replacements) {\n    const variant = base.slice(0, index) + replacement + base.slice(index + 1);\n    results.push(...generateSubstitutions(variant, positions, posIdx + 1));\n  }\n\n  return results;\n}\n\n/**\n * Apply dictionary-guided OCR repair to all words in a text string.\n */\nfunction repairOcrText(text: string): string {\n  return text\n    .split(/\\s+/)\n    .map((word) => {\n      const match = word.match(/^([^a-zA-Z0-9À-ÿ]*)(.*?)([^a-zA-Z0-9À-ÿ]*)$/);\n      if (!match) return word;\n      const [, prefix, core, suffix] = match;\n      if (!core) return word;\n      const repaired = repairOcrWord(core);\n      return prefix + repaired + suffix;\n    })\n    .join(\" \");\n}\n\n/**\n * Post-processing normalization for OCR-extracted titles.\n * Strips stray section markers and substitutes common OCR digit-for-letter artifacts.\n * Title-case conversion is applied only when a substitution was actually made, so\n * clean ALL_CAPS titles (e.g. \"CHOCOLATE CAKE\") are returned unchanged.\n */","numLines":90,"startLine":728,"totalLines":1518}}}
