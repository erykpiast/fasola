{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VhzXpoaAbVKUkw9RE3dmh7","type":"tool_result","content":"   243→function passesCorroboration(\n   244→  text: string,\n   245→  position: number,\n   246→  allLines: string[]\n   247→): boolean {\n   248→  const contentWords = extractContentWords(text);\n   249→\n   250→  if (contentWords.length === 0) {\n   251→    return true; // No checkable words — pass through\n   252→  }\n   253→\n   254→  let corroboratedCount = 0;\n   255→  for (const word of contentWords) {\n   256→    for (let i = 0; i < allLines.length; i++) {\n   257→      if (i === position) continue;\n   258→      if (allLines[i].toUpperCase().includes(word)) {\n   259→        corroboratedCount++;\n   260→        break;\n   261→      }\n   262→    }\n   263→  }\n   264→\n   265→  const score = corroboratedCount / contentWords.length;\n   266→  const threshold = contentWords.length <= 3 ? 1.0 : 0.67;\n   267→  return score >= threshold;\n   268→}\n   269→\n   270→function isLikelyGarbled(text: string): boolean {\n   271→  const letters = text.replace(/[^a-zA-Z]/g, \"\");\n   272→  if (letters.length < 2) return true;\n   273→\n   274→  // Pipe embedded in words = OCR artifact (e.g., \"Sp|aszcz\", \"pa|ką\")\n   275→  if (/[a-zA-ZÀ-ÿа-яА-Я]\\|[a-zA-ZÀ-ÿа-яА-Я]/.test(text)) return true;\n   276→\n   277→  // Mixed Latin + Cyrillic = OCR corruption\n   278→  if (/[а-яА-ЯёЁіІїЇєЄґҐ]/.test(text) && /[a-zA-Z]/.test(text)) return true;\n   279→\n   280→  // Check vowel ratio — English/Polish text typically has 30–50% vowels\n   281→  const vowels = letters.replace(/[^aeiouAEIOUyYąęóĄĘÓ]/g, \"\").length;\n   282→  const vowelRatio = vowels / letters.length;\n   283→  if (vowelRatio < 0.10 || vowelRatio > 0.85) return true;\n   284→\n   285→  // Single orphaned word ≤3 letters that isn't a common word\n   286→  const words = text.trim().split(/\\s+/);\n   287→  const COMMON_SHORT = new Set([\n   288→    \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"had\", \"her\",\n   289→    \"was\", \"one\", \"our\", \"out\", \"are\", \"has\", \"his\", \"how\", \"its\", \"may\",\n   290→    \"new\", \"now\", \"old\", \"see\", \"way\", \"who\", \"did\", \"get\", \"let\", \"say\",\n   291→    \"she\", \"too\", \"use\",\n   292→  ]);\n   293→  // Count all Unicode letters (not just ASCII) so Polish words like \"Żur\" (3 letters) pass\n   294→  const unicodeLetters = text.trim().replace(/[^a-zA-ZąćęłńóśźżĄĆĘŁŃÓŚŹŻ]/g, \"\");\n   295→  if (words.length === 1 && unicodeLetters.length <= 3 && !COMMON_SHORT.has(text.trim().toLowerCase())) {\n   296→    return true;\n   297→  }\n   298→\n   299→  // Single word with internal lowercase→uppercase transition — OCR noise (e.g., \"UuIw\", \"aBC\")\n   300→  // No recipe title uses this pattern as a standalone single-word candidate.\n   301→  if (words.length === 1 && /[a-z][A-Z]/.test(text.trim())) {\n   302→    return true;\n   303→  }\n   304→\n   305→  // Recipe titles never start with a lowercase letter\n   306→  if (/^[a-z]/.test(text.trim())) {\n   307→    return true;\n   308→  }\n   309→\n   310→  // Mid-text sentence boundary (\". \" followed by a letter) — body text fragment spliced from multiple sentences\n   311→  const trimmed = text.trim();\n   312→  if (/\\.\\s+[a-zA-Z]/.test(trimmed) && !trimmed.endsWith(\")\")) {\n   313→    return true;\n   314→  }\n   315→\n   316→  // Multi-word candidate containing a garbled OCR fragment: a short lowercase word that isn't a known short word\n   317→  if (words.length >= 2) {\n   318→    const commonShort2 = new Set([\n   319→      \"a\", \"i\", \"of\", \"or\", \"to\", \"in\", \"on\", \"is\", \"it\", \"an\",\n   320→      \"as\", \"at\", \"by\", \"do\", \"go\", \"if\", \"no\", \"so\", \"up\", \"we\",\n   321→      \"w\", \"z\",   // Polish prepositions (basic)\n   322→      \"ze\", \"bo\", \"na\", \"ni\", \"po\", \"ku\", \"od\", \"za\", \"co\",  // Polish prepositions (extended)\n   323→    ]);\n   324→    const hasGarbledWord = words.some(\n   325→      (w) =>\n   326→        /^[a-z]/.test(w) &&\n   327→        w.replace(/[^a-z]/g, \"\").length <= 2 &&\n   328→        !commonShort2.has(w.toLowerCase())\n   329→    );\n   330→    if (hasGarbledWord) {\n   331→      return true;\n   332→    }\n   333→  }\n   334→\n   335→  return false;\n   336→}\n   337→\n   338→const COOKING_INSTRUCTION_STARTS = /^(beat|fold|stir|mix|add|pour|bake|cook|cool|remove|place|combine|whisk|knead|roll|spread|brush|slice|chop|dice|mince|drain|rinse|peel|grate|melt|simmer|boil|fry|sauté|saute|roast|grill|broil|steam|let|set|transfer|serve|garnish|arrange|sprinkle|season|preheat|cover|uncover|reduce|bring|toss|cut|trim|shape|form|scatter|score|pat|rub|skim|strain|heat|discard|rest|marinate|wrap|flip|turn|layer|stuff|drizzle|squeeze|zest|soak|thaw|freeze|chill|warm|toast|crush|pound|crack|break|separate|weigh|measure|sift|dust|coat|dip|dredge|baste|debone|butterfly|truss|shred|puree|blend|process|pulse|whip|cream|proof|rise|punch|divide|portion|assemble)\\b/i;\n   339→\n   340→// Polish imperative cooking verbs (with OCR-resilient forms — no diacritics required).\n   341→// These cover the most common recipe instruction starters. Includes common OCR-corrupted\n   342→// forms (e.g., \"Smaż\" → \"Smaz\", \"Dodaj\" → \"Dodaj\").\n   343→// Note: only verbs that NEVER start a recipe title. \"Piecz\" (bake) is excluded because\n   344→// \"Pieczeń\" (roast) and \"Pieczarki\" (mushrooms) share the prefix.\n   345→const POLISH_COOKING_INSTRUCTION_STARTS = /^(podawaj|dodaj|dodawaj|sma[zż]|gotuj|odced[zź]|wymieszaj|mieszaj|wlej|nalej|przygotuj|zagotuj|pokr[oó]j|obierz|wrzuc|wrzuć|usma[zż]|podsma[zż]|prze[lł][oó][zż]|zblenduj|ubij|roztrzepaj|rozprowad[zź]|wyrob|zamieszaj|posyp|polej|odstaw|na[lł][oó][zż]|przykryj|odkryj|wstaw|zdejmij|ods[aą]cz|rozgrzej|posiekaj|zetrzyj|wy[lł][oó][zż]|wyjmij|ukr[oó]j|przekr[oó]j|formuj|ugniataj|rozwałkuj)\\b/i;\n   346→\n   347→function looksLikeCookingInstruction(text: string): boolean {\n   348→  const words = text.trim().split(/\\s+/);\n   349→  if (words.length < 4) return false;  // Instructions are multi-word sentences\n   350→  if (COOKING_INSTRUCTION_STARTS.test(text.trim())) return true;\n   351→  if (POLISH_COOKING_INSTRUCTION_STARTS.test(text.trim())) return true;\n   352→  return false;\n   353→}\n   354→\n   355→/**\n   356→ * A line starting with a lowercase letter and having 4+ words is prose continuation.\n   357→ * Recipe titles are capitalized (Title Case or ALL CAPS), so a lowercase-start line\n   358→ * is a strong signal for mid-recipe body text.\n   359→ */\n   360→function isBodyProse(line: string): boolean {\n   361→  return /^[a-ząćęłńóśźż]/.test(line) && wordCount(line) >= 4;\n   362→}\n   363→\n   364→/**\n   365→ * Detect pages where the OCR capture starts mid-recipe with no title present.\n   366→ * Returns true if the first 3 non-empty lines are all ingredients, cooking instructions,\n   367→ * or body prose continuation text.\n   368→ */\n   369→function isTitleAbsentPage(lines: Array<string>): boolean {\n   370→  const nonEmptyLines = lines.map(l => l.trim()).filter(l => l.length > 0);\n   371→\n   372→  if (nonEmptyLines.length < 3) return false;\n   373→\n   374→  const first3 = nonEmptyLines.slice(0, 3);\n   375→\n   376→  return first3.every(line =>\n   377→    looksLikeIngredient(line) ||\n   378→    looksLikeCookingInstruction(line) ||\n   379→    isBodyProse(line)\n   380→  );\n   381→}\n   382→\n   383→function passesHardFilters(text: string): boolean {\n   384→  if (text.length < 3 || text.length > 80) return false;\n   385→  if (looksLikeIngredient(text)) return false;\n   386→  if (startsWithNumber(text)) return false;\n   387→  if (looksLikeMetadata(text)) return false;\n   388→  if (isLikelyGarbled(text)) return false;\n   389→  if (looksLikeCookingInstruction(text)) return false;\n   390→  // Pipe-separated lines are book category/chapter headers, not recipe titles\n   391→  if (text.includes(\" | \")) return false;\n   392→  // Trailing page number (e.g. \"VEGETABLE SIDES                         145\")"}]},"parent_tool_use_id":"toolu_01G8C2dkPvbhHaYpuQ3jx316","session_id":"b58b8c45-4f2d-433d-859c-e1c4435e3073","uuid":"602e3354-aa96-421f-8bd5-1c2088133415"}
