ta(trimmed) || trimmed.includes(\" | \"));\n  1061→        });\n  1062→      const preambleBonus = hasStructuralPreamble ? 0.12 : 0.08;\n  1063→      firstCandidate.score += preambleBonus;\n  1064→      firstCandidate.baseScore += preambleBonus;\n  1065→      firstCandidate.thresholdScore += preambleBonus;\n  1066→    }\n  1067→  }\n  1068→  // Cap combined positional boost (candidate-relative position factor + first-after-preamble bonus)\n  1069→  // to avoid over-boosting when both fire together (~+0.24 uncapped → capped at +0.15).\n  1070→  const maxPositionalBoost = 0.15;\n  1071→  const totalPositionalBoost = firstCandidate.score - baseScoreBeforePositionalBonuses;\n  1072→  if (totalPositionalBoost > maxPositionalBoost) {\n  1073→    const excess = totalPositionalBoost - maxPositionalBoost;\n  1074→    firstCandidate.score -= excess;\n  1075→    firstCandidate.baseScore -= excess;\n  1076→    firstCandidate.thresholdScore -= excess;\n  1077→  }\n  1078→\n  1079→  // Direct-successor bonus: when the line immediately before this candidate is a\n  1080→  // section label, metadata, or pipe-separated line, the candidate is very likely\n  1081→  // the title that follows that header. This complements the first-after-preamble\n  1082→  // bonus which requires ALL preceding lines to be filtered — this one fires even\n  1083→  // when earlier non-filtered lines exist.\n  1084→  for (let ci = 0; ci < scored.length && ci <= 2; ci++) {\n  1085→    const candidate = scored[ci];\n  1086→    if (candidate.position > 0) {\n  1087→      const prevLine = lines[candidate.position - 1]?.trim() ?? \"\";\n  1088→      const prevIsHeader =\n  1089→        isSectionLabel(prevLine) ||\n  1090→        looksLikeMetadata(prevLine) ||\n  1091→        prevLine.includes(\" | \");\n  1092→      if (prevIsHeader) {\n  1093→        candidate.score += 0.10;\n  1094→        candidate.baseScore += 0.10;\n  1095→        candidate.thresholdScore += 0.10;\n  1096→      }\n  1097→    }\n  1098→  }\n  1099→\n  1100→  // --- Pre-threshold bilingual title detection ---\n  1101→  // When a mixed-case candidate at position 0 is followed by an ALL_CAPS candidate\n  1102→  // at position ≤ 2 that is semantically similar to it, this is a bilingual recipe\n  1103→  // page (e.g., Polish title + ALL_CAPS Korean romanization). Suppress confirmed\n  1104→  // translation candidates before computing threshold so their bonuses don't inflate\n  1105→  // the threshold beyond the mixed-case title's reach.\n  1106→  // Note: we check position ≤ 2 (local proximity), not global ALL_CAPS count, so\n  1107→  // section headers later in the document (SKŁADNIKI, WARZYWA, etc.) are irrelevant.\n  1108→  let translationCandidates: typeof scored = [];\n  1109→  let scoredForThreshold = scored;\n  1110→  const prePos0 = scored.find((s) => s.position === 0 && !isAllCaps(s.text));\n  1111→  if (prePos0) {\n  1112→    const nearbyAllCaps = scored.filter(\n  1113→      (s) => isAllCaps(s.text) && s.position >= 1 && s.position <= 2 && s.origin === \"single\"\n  1114→    );\n  1115→    const pos0Embedding = rawScored.find((r) => r.text === prePos0.text)?.embedding;\n  1116→\n  1117→    // Method 1: embedding similarity (works for related languages)\n  1118→    if (pos0Embedding && nearbyAllCaps.length > 0) {\n  1119→      translationCandidates = nearbyAllCaps.filter((cap) => {\n  1120→        const capEmbedding = rawScored.find((r) => r.text === cap.text)?.embedding;\n  1121→        if (!capEmbedding) return false;\n  1122→        return cosineSimilarity(pos0Embedding, capEmbedding) > 0.4;\n  1123→      });\n  1124→    }\n  1125→\n  1126→    // Method 2: layout-based detection (cross-lingual fallback).\n  1127→    // When embedding similarity is insufficient (e.g. Polish ↔ Korean romanization),\n  1128→    // detect bilingual layout by position and word overlap:\n  1129→    // mixed-case ≥2 words at pos 0 + ALL_CAPS ≥2 words at pos 1-2 with no shared words.\n  1130→    if (translationCandidates.length === 0 && wordCount(prePos0.text) >= 2) {\n  1131→      const pos0Words = new Set(\n  1132→        prePos0.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2)\n  1133→      );\n  1134→      translationCandidates = nearbyAllCaps.filter((cap) => {\n  1135→        if (wordCount(cap.text) < 2) return false;\n  1136→        const capWords = cap.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2);\n  1137→        return !capWords.some((w) => pos0Words.has(w));\n  1138→      });\n  1139→    }\n  1140→\n  1141→    if (translationCandidates.length > 0) {\n  1142→      // Suppress standalone translations and any multi-line joins that embed the translation\n  1143→      // as a suffix or substring (e.g. \"Smażona zielona fasolka GREEN BEANS BORKEUM\" ends with\n  1144→      // the translation; \"Title GREEN BEANS BORKEUM 그린빈\" includes it as a substring).\n  1145→      scoredForThreshold = scored.filter((s) => {\n  1146→        const sLower = s.text.toLowerCase();\n  1147→        return !translationCandidates.some((t) => {\n  1148→          const tLower = t.text.toLowerCase();\n  1149→          return sLower.startsWith(tLower) ||\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_011JX6GZGA2Gz7hDwHepb6nk","session_id":"46d852de-57ac-48de-8e5b-66deacf5a9a2","uuid":"a2d4b0ca-1c46-49b3-b8a2-2b88f8c47284"}
