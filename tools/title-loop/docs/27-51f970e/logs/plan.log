  1511→    if (isAllCaps(line)) continue;\n  1512→    if (startsWithNumber(line)) continue;\n  1513→    return line;\n  1514→  }\n  1515→\n  1516→  return undefined;\n  1517→}\n  1518→","numLines":219,"startLine":1300,"totalLines":1518}}}
