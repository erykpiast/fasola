55→      sub.score -= 0.15;\n  1156→  1156→    }\n  1157→  1157→  }\n  1158→  1158→\n  1159→  1159→  // Bilingual layout pattern: [FoodName (≤2 words)]\\n[Translation (2-5 words, mixed-case)]\\n...[Section label]\n  1160→  1160→  // Common in bilingual cookbooks: foreign food name at position 0, English translation at position 1-2.\n  1161→  1161→  // When detected, boost the position-0 candidate so it clears the threshold.\n  1162→  1162→  // Note: the ALL_CAPS bilingual block above (lines 940-995) handles mixed-case + ALL_CAPS pairs.\n  1163→  1163→  // This block handles mixed-case + mixed-case translation pairs — the two do not overlap because\n  1164→  1164→  // the mixed-case guard (`biSecond.text !== biSecond.text.toUpperCase()`) excludes ALL_CAPS lines.\n  1165→  1165→  if (scored.length >= 2) {\n  1166→  1166→    const biFirst = scored.find((s) => s.position === 0);\n  1167→  1167→    // Restrict to single-line candidates (same guard as the ALL_CAPS bilingual block at line 953)\n  1168→  1168→    const biSecond = scored.find((s) => s.position >= 1 && s.position <= 2 && s !== biFirst && s.origin === \"single\");\n  1169→  1169→\n  1170→  1170→    if (biFirst && biSecond) {\n  1171→  1171→      const firstWords = biFirst.text.trim().split(/\\s+/);\n  1172→  1172→      const secondWords = biSecond.text.trim().split(/\\s+/);\n  1173→  1173→\n  1174→  1174→      const isBilingualLayout =\n  1175→  1175→        firstWords.length <= 2 &&\n  1176→  1176→        secondWords.length >= 2 &&\n  1177→  1177→        secondWords.length <= 5 &&\n  1178→  1178→        // Second line is mixed-case (not ALL_CAPS, not all-lower)\n  1179→  1179→        biSecond.text !== biSecond.text.toUpperCase() &&\n  1180→  1180→        biSecond.text !== biSecond.text.toLowerCase() &&\n  1181→  1181→        // Second line is not an ingredient or instruction\n  1182→  1182→        !looksLikeIngredient(biSecond.text) &&\n  1183→  1183→        !looksLikeCookingInstruction(biSecond.text);\n  1184→  1184→\n  1185→  1185→      if (isBilingualLayout) {\n  1186→  1186→        // Check if a section label follows within a few lines after the first candidate\n  1187→  1187→        const sectionLabelNearby = lines\n  1188→  1188→          .slice(biFirst.position + 1, biFirst.position + 6)\n  1189→  1189→          .some((line) => isSectionLabel(line.trim()));\n  1190→  1190→\n  1191→  1191→        if (sectionLabelNearby) {\n  1192→  1192→          biFirst.score += 0.15;\n  1193→  1193→          biFirst.baseScore += 0.15;\n  1194→  1194→          biFirst.thresholdScore += 0.15;\n  1195→  1195→        }\n  1196→  1196→      }\n  1197→  1197→    }\n  1198→  1198→  }\n  1199→  1199→\n  1200→  1200→  // Pre-filter: when ≥2 ALL_CAPS candidates are present, identify OCR artifacts (those whose\n  1201→  1201→  // vocabulary has no support elsewhere in the document) and remove them before computing the\n  1202→  1202→  // threshold. Artifacts like \"DAT FLATBREADS\" can inflate the threshold via their early-position\n  1203→  1203→  // bonus, which causes legitimate titles later in the document to fall just below the cutoff.\n  1204→  1204→  // Safety: only pre-filter if ≥2 candidates remain after removal (avoids false-positive removal\n  1205→  1205→  // of unique-vocabulary titles on two-recipe pages).\n  1206→  1206→  // NOTE: The ≥2 guard is conservative — when there are exactly 2 ALL_CAPS candidates and one is\n  1207→  1207→  // an artifact, the artifact is NOT removed. Relaxing to ≥1 causes regressions because 3-line\n  1208→  1208→  // join candidates (which span a section label) can pass corroboration via shared vocabulary,\n  1209→  1209→  // while the legitimate short title fails. See \"WORD ONE / INGREDIENTS / WORD TWO\" test case.\n  1210→  1210→  const allCapsInScored = scoredForThreshold.filter((s) => isAllCaps(s.text));\n  1211→  1211→  if (allCapsInScored.length >= 2) {\n  1212→  1212→    const artifactTexts = new Set(\n  1213→  1213→      allCapsInScored\n  1214→  1214→        .filter((cap) => !passesCorroboration(cap.text, cap.position, lines))\n  1215→  1215→        .map((c) => c.text)\n  1216→  1216→    );\n  1217→  1217→    if (artifactTexts.size > 0) {\n  1218→  1218→      const remainingCaps = allCapsInScored.filter((c) => !artifactTexts.has(c.text));\n  1219→  1219→      if (remainingCaps.length >= 2) {\n  1220→  1220→        scoredForThreshold = scoredForThreshold.filter((s) => !artifactTexts.has(s.text));\n  1221→  1221→      }\n  1222→  1222→    }\n  1223→  1223→  }\n  1224→  1224→\n  1225→  1225→  // Use thresholdScore (excludes structural bonus) so the structural bonus doesn't inflate\n  1226→  1226→  // the threshold and block equally-valid headings on multi-recipe pages.\n  1227→  1227→  const bestThresholdScore = Math.max(...scoredForThreshold.map((s) => s.thresholdScore));\n  1228→  1228→  const threshold = Math.max(0.08, bestThresholdScore * 0.7);\n  1229→  1229→\n  1230→  1230→  // Filter candidates above threshold\n  1231→  1231→  let selected = scoredForThreshold.filter((s) => s.score >= threshold);\n  1232→  1232→\n  1233→  1233→  // Empty-pool fallback: when threshold filtering discards every candidate,\n  1234→  1234→  // the hard filters' structural verdict should not be overruled by weak\n  1235→  1235→  // embedding differentiation. Return the best positional candidate only\n  1236→  1236→  // if it has a meaningful positive raw score (avoids ingredient-list leakage).\n  1237→  1237→  if (selected.length === 0 && scored.length > 0) {\n  1238→  1238→    const fallback = scored\n  1239→  1239→      .slice()\n  1240→  1240→      .sort((a, b) => a.position - b.position || b.score - a.score);\n  1241→  1241→    // Position-0 candidates that passed hard filters are very likely titles even with\n  1242→  1242→    // weak embedding signal. Relax the rawScore guard for early-position candidates.\n  1243→  1243→    const rawScoreThreshold = fallback[0].position <= 2 ? -0.05 : 0.02;\n  1244→  1244→    if (fallback[0].rawScore > rawScoreThreshold) {\n  1245→  1245→      selected = [fallback[0]];\n  1246→  1246→    }\n  1247→  1247→  }\n  1248→  1248→\n  1249→  1249→  // Title-absent page guard: when the page starts mid-recipe (all of the first 3 non-empty\n  1250→  1250→  // lines are ingredients or cooking instructions), require a much higher rawScore and\n  1251→  1251→  // discard candidates deep in the file. This prevents stray body text or adjacent recipe\n  1252→  1252→  // titles from being picked up on pages with no title (Pattern 4).\n  1253→  1253→  if (titleAbsent) {\n  1254→  1254→    const titleAbsentThreshold = 0.10;\n  1255→  1255→    selected = selected.filter(s => s.rawScore >= titleAbsentThreshold);\n  1256→  1256→    selected = selected.filter(s => s.position <= 2);\n  1257→  1257→  }\n  1258→  1258→\n  1259→  1259→  // Remove word-boundary prefixes of firstStructuralHeading when the heading itself survived\n  1260→  1260→  // the threshold. Cases:\n  1261→  1261→  //   ARAYES case:  firstStructuralHeading = \"ARAYES SHRAK\" (2-word join qualifies; \"ARAYES\"\n  1262→  1262→  //     alone = 1 word, so it never qualified). Filter removes \"ARAYES\" so dedup keeps the join.\n  1263→  1263→  //   SAFFRON case: baseHeading was the partial line; continuation logic above upgraded\n  1264→  1264→  //     firstStructuralHeading to the full join. Filter removes the partial so dedup keeps join.\n  1265→  1265→  // Safety: only fires when the complete heading itself is in selected (passed the threshold).\n  1266→  1266→  if (firstStructuralHeading && selected.some((s) => s.text === firstStructuralHeading.text)) {\n  1267→  1267→    const fshLower = firstStructuralHeading.text.toLowerCase();\n  1268→  1268→    selected = selected.filter((s) => {\n  1269→  1269→      if (s.text === firstStructuralHeading.text) return true;\n  1270→  1270→      const sLower = s.text.toLowerCase();\n  1271→  1271→      // Remove s if it is a space-delimited prefix of the structural heading\n  1272→  1272→      return !fshLower.startsWith(sLower + \" \");\n  1273→  1273→    });\n  1274→  1274→  }\n  1275→  1275→\n  1276→  1276→  // Protect continuation joins: when a multi-line join (2-line or 3-line) survived the threshold\n  1277→  1277→  // and its second part starts with a continuation character, remove the single-line prefix/suffix\n  1278→  1278→  // so the dedup \"shorter wins\" rule doesn't destroy the complete join.\n  1279→  1279→  // Note: the pre-merge step above already handles the common Baked Eggs case (&/continuation\n  1280→  1280→  // on next line) by turning it into a single candidate — this block covers the rarer case where\n  1281→  1281→  // a continuation-character join was generated as a 2-line/3-line candidate and the prefix\n  1282→  1282→  // single also survived threshold independently (e.g. from a different code path or OCR layout).\n  1283→  1283→  // Safety: only fires for joins whose continuation starts with /&+:( — digit continuations\n  1284→  1284→  // like \"Pierogi Ruskie 200g mąki\" are NOT protected, so dedup correctly keeps the shorter form.\n  1285→  1285→  const survivingJoins = selected.filter((s) => s.origin === \"2-line\" || s.origin === \"3-line\");\n  1286→  1286→  if (survivingJoins.length > 0) {\n  1287→  1287→    selected = selected.filter((s) => {\n  1288→  1288→      if (s.origin !== \"single\") return true;\n  1289→  1289→      const sLower = s.text.toLowerCase();\n  1290→  1290→      // Remove PREFIX singles whose continuation join also survived\n  1291→  1291→      const isPrefixOfJoin = survivingJoins.some((j) => {\n  1292→  1292→        const jLower = j.text.toLowerCase();\n  1293→  1293→        if (!jLower.startsWith(sLower + \" \")) return false;\n  1294→  1294→        const remainder = jLower.slice(sLower.length + 1);\n  1295→  1295→        return /^[/&+:(]/.test(remainder);\n  1296→  1296→      });\n  1297→  1297→      if (isPrefixOfJoin) return false;\n  1298→  1298→      // Rem