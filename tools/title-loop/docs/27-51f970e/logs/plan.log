/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length > 1);\n   918→   918→    return sigWords.length >= 2 && sigWords.every((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   919→   919→  };\n   920→   920→\n   921→   921→  // Pass 1: compute rawScore for all candidates (embedding quality signal)\n   922→   922→  const rawScored: Array<{ text: string; position: number; origin: CandidateOrigin; rawScore: number; embedding: Array<number> }> = [];\n   923→   923→  for (const candidate of candidates) {\n   924→   924→    const embedding = await embed(candidate.text);\n   925→   925→    const titleSim = cosineSimilarity(embedding, cachedTitleRefEmbedding);\n   926→   926→    const headerSim = cosineSimilarity(embedding, cachedHeaderRefEmbedding);\n   927→   927→    const noiseSim = cosineSimilarity(embedding, cachedNoiseRefEmbedding);\n   928→   928→    const rawScore = titleSim - Math.max(headerSim, noiseSim);\n   929→   929→    rawScored.push({ text: candidate.text, position: candidate.position, origin: candidate.origin, rawScore, embedding });\n   930→   930→  }\n   931→   931→\n   932→   932→  // Select baseHeading by embedding quality (rawScore), not position.\n   933→   933→  // This prevents OCR-garbled fragments from claiming the structural heading slot.\n   934→   934→  const structuralCandidates = rawScored.filter((s) => isStructuralHeading(s));\n   935→   935→\n   936→   936→  // Penalize structural headings with truncated OCR words:\n   937→   937→  // if \"FRON\" appears and another heading has \"SAFFRON\", \"FRON\" is likely garbled.\n   938→   938→  for (const sc of structuralCandidates) {\n   939→   939→    const sigWords = sc.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   940→   940→    for (const other of structuralCandidates) {\n   941→   941→      if (other === sc) continue;\n   942→   942→      const otherSigWords = other.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   943→   943→      const hasTruncation = sigWords.some((w) =>\n   944→   944→        otherSigWords.some((ow) => ow !== w && ow.length > w.length && ow.endsWith(w))\n   945→   945→      );\n   946→   946→      if (hasTruncation) {\n   947→   947→        sc.rawScore = -1.0;  // Hard disqualification — truncated OCR artifact\n   948→   948→        break;\n   949→   949→      }\n   950→   950→    }\n   951→   951→  }\n   952→   952→\n   953→   953→  const bestStructural = structuralCandidates.length > 0\n   954→   954→    ? structuralCandidates.reduce((a, b) => {\n   955→   955→        const scoreDiff = a.rawScore - b.rawScore;\n   956→   956→        if (Math.abs(scoreDiff) > 0.03) return scoreDiff > 0 ? a : b;\n   957→   957→        // Tiebreak: single-line origin beats multi-line joins (avoids conflating two separate headings)\n   958→   958→        if (a.origin === \"single\" && b.origin !== \"single\") return a;\n   959→   959→        if (b.origin === \"single\" && a.origin !== \"single\") return b;\n   960→   960→        // Tiebreak: more words (more specific) → better\n   961→   961→        const wcDiff = wordCount(b.text) - wordCount(a.text);\n   962→   962→        if (wcDiff !== 0) return wcDiff > 0 ? b : a;\n   963→   963→        // Tiebreak: earlier position → better\n   964→   964→        return a.position < b.position ? a : b;\n   965→   965→      })\n   966→   966→    : null;\n   967→   967→  const baseHeading = bestStructural ?? undefined;\n   968→   968→\n   969→   969→  // When the best structural heading has a continuation on the next line introduced by a\n   970→   970→  // punctuation token (/, &, +, :, or parenthesis), prefer the longer 2-line join as the\n   971→   971→  // complete heading. E.g. \"SAFFRON WHEAT BUNS WITH QUARK\" + \"/ COTTAGE CHEESE (VARIATION D)\".\n   972→   972→  // Guard: the remainder after the prefix must start with a continuation character to avoid\n   973→   973→  // merging two separate consecutive recipe titles (FINNISH MILK FLATBREADS stay