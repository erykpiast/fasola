ion.\n   833→  // For ALL_CAPS text, apply digit-for-letter substitutions.\n   834→  const beforeSub = text;\n   835→  if (isAllCaps(text)) {\n   836→    text = text\n   837→      .replace(/1/g, \"I\")\n   838→      .replace(/0(?=[A-ZÀ-Ż])/g, \"O\")\n   839→      .replace(/(?<=[A-ZÀ-Ż])0/g, \"O\")\n   840→      .replace(/4(?=[A-ZÀ-Ż])/g, \"A\")\n   841→      .replace(/(?<=[A-ZÀ-Ż])4/g, \"A\")\n   842→      .replace(/5(?=[A-ZÀ-Ż])/g, \"S\")\n   843→      .replace(/(?<=[A-ZÀ-Ż])5/g, \"S\")\n   844→      .replace(/¡/g, \"I\")\n   845→      .replace(/€/g, \"E\")\n   846→      .replace(/[ÍÌ]/g, \"I\");\n   847→  } else {\n   848→    // Mixed-case: fix per-word (digits between lowercase letters)\n   849→    text = text.split(/(\\s+)/).map((token) => {\n   850→      if (/^\\s+$/.test(token)) return token;\n   851→      if (isAllCaps(token) && token.length > 1) {\n   852→        return token\n   853→          .replace(/1/g, \"I\")\n   854→          .replace(/0(?=[A-Z])/g, \"O\")\n   855→          .replace(/(?<=[A-Z])0/g, \"O\");\n   856→      }\n   857→      return token\n   858→        .replace(/(?<=[a-zà-ż])1/g, \"l\")\n   859→        .replace(/1(?=[a-zà-ż])/g, \"l\")\n   860→        .replace(/¡/g, \"i\")\n   861→        .replace(/€/g, \"e\");\n   862→    }).join(\"\");\n   863→  }\n   864→\n   865→  // Step 3: Title-case conversion — ONLY when OCR substitution changed the text.\n   866→  // This preserves clean ALL_CAPS titles (e.g. \"CHOCOLATE CAKE\") as-is.\n   867→  if (text !== beforeSub && isAllCaps(text)) {\n   868→    text = toTitleCase(text);\n   869→  }\n   870→\n   871→  return text.trim();\n   872→}\n   873→\n   874→// Module-level cache for reference embeddings\n   875→let cachedTitleRefEmbedding: Array<number> | null = null;\n   876→let cachedHeaderRefEmbedding: Array<number> | null = null;\n   877→let cachedNoiseRefEmbedding: Array<number> | null = null;\n   878→\n   879→export function _resetEmbeddingCacheForTests(): void {\n   880→  cachedTitleRefEmbedding = null;\n   881→  cachedHeaderRefEmbedding = null;\n   882→  cachedNoiseRefEmbedding = null;\n   883→}\n   884→\n   885→export async function extractTitleWithEmbeddings(\n   886→  text: string,\n   887→  embed: EmbedFn\n   888→): Promise<string | undefined> {\n   889→  if (!text || text.trim().length === 0) {\n   890→    return undefined;\n   891→  }\n   892→\n   893→  const lines = text.split(\"\\n\");\n   894→  const candidates = buildCandidates(lines);\n   895→  const titleAbsent = isTitleAbsentPage(lines);\n   896→\n   897→  if (candidates.length === 0) {\n   898→    return undefined;\n   899→  }\n   900→\n   901→  // Cache reference embeddings\n   902→  if (!cachedTitleRefEmbedding) {\n   903→    cachedTitleRefEmbedding = await embed(TITLE_REFERENCE);\n   904→  }\n   905→  if (!cachedHeaderRefEmbedding) {\n   906→    cachedHeaderRefEmbedding = await embed(HEADER_REFERENCE);\n   907→  }\n   908→  if (!cachedNoiseRefEmbedding) {\n   909→    cachedNoiseRefEmbedding = await embed(NOISE_REFERENCE);\n   910→  }\n   911→\n   912→  // Find ALL_CAPS candidates with ≥2 words where every significant word has ≥4 alpha letters.\n   913→  // Insignificant tokens (≤1 alpha letter: \"/\", \"&\", \"+\", \":\", \"D)\", etc.) are filtered before\n   914→  // the check so that multi-line joins with continuation punctuation still qualify.\n   915→  const isStructuralHeading = (c: { text: string }): boolean => {\n   916→    if (!isAllCaps(c.text) || wordCount(c.text) < 2) return false;\n   917→    const sigWords = c.text.trim().split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length > 1);\n   918→    return sigWords.length >= 2 && sigWords.every((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   919→  };\n   920→\n   921→  // Pass 1: compute rawScore for all candidates (embedding quality signal)\n   922→  const rawScored: Array<{ text: string; position: number; origin: CandidateOrigin; rawScore: number; embedding: Array<number> }> = [];\n   923→  for (const candidate of candidates) {\n   924→    const embedding = await embed(candidate.text);\n   925→    const titleSim = cosineSimilarity(embedding, cachedTitleRefEmbedding);\n   926→    const headerSim = cosineSimilarity(embedding, cachedHeaderRefEmbedding);\n   927→    const noiseSim = cosineSimilarity(embedding, cachedNoiseRefEmbedding);\n   928→    const rawScore = titleSim - Math.max(headerSim, noiseSim);\n   929→    rawScored.push({ text: candidate.text, position: candidate.position, origin: candidate.origin, rawScore, embedding });\n   930→  }\n   931→\n   932→  // Select baseHeading by embedding quality (rawScore), not position.\n   933→  // This prevents OCR-garbled fragments from claiming the structural heading slot.\n   934→  const structuralCandidates = rawScored.filter((s) => isStructuralHeading(s));\n   935→\n   936→  // Penalize structural headings with truncated OCR words:\n   937→  // if \"FRON\" appears and another heading has \"SAFFRON\", \"FRON\" is likely garbled.\n   938→  for (const sc of structuralCandidates) {\n   939→    const sigWords = sc.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   940→    for (const other of structuralCandidates) {\n   941→      if (other === sc) continue;\n   942→      const otherSigWords = other.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   943→      const hasTruncation = sigWords.some((w) =>\n   944→        otherSigWords.some((ow) => ow !== w && ow.length > w.length && ow.endsWith(w))\n   945→      );\n   946→      if (hasTruncation) {\n   947→        sc.rawScore = -1.0;  // Hard disqualification — truncated OCR artifact\n   948→        break;\n   949→      }\n   950→    }\n   951→  }\n   952→\n   953→  const bestStructural = structuralCandidates.length > 0\n   954→    ? structuralCandidates.reduce((a, b) => {\n   955→        const scoreDiff = a.rawScore - b.rawScore;\n   956→        if (Math.abs(scoreDiff) > 0.03) return scoreDiff > 0 ? a : b;\n   957→        // Tiebreak: single-line origin beats multi-line joins (avoids conflating two separate headings)\n   958→        if (a.origin === \"single\" && b.origin !== \"single\") return a;\n   959→        if (b.origin === \"single\" && a.origin !== \"single\") return b;\n   960→        // Tiebreak: more words (more specific) → better\n   961→        const wcDiff = wordCount(b.text) - wordCount(a.text);\n   962→        if (wcDiff !== 0) return wcDiff > 0 ? b : a;\n   963→        // Tiebreak: earlier position → better\n   964→        return a.position < b.position ? a : b;\n   965→      })\n   966→    : null;\n   967→  const baseHeading = bestStructural ?? undefined;\n   968→\n   969→  // When the best structural heading has a continuation on the next line introduced by a\n   970→  // punctuation token (/, &, +, :, or parenthesis), prefer the longer 2-line join as the\n   971→  // complete heading. E.g. \"SAFFRON WHEAT BUNS WITH QUARK\" + \"/ COTTAGE CHEESE (VARIATION D)\".\n   972→  // Guard: the remainder after the prefix must start with a continuation character to avoid\n   973→  // merging two separate consecutive recipe titles (FINNISH MILK FLATBREADS stays separate\n   974→  // from FINNISH POTATO FLATBREADS because \"FINNISH\" does not start with a continuation token).\n   975→  let firstStructuralHeading = baseHeading && (\n   976→    rawScored.find((c) => {\n   977→      if (!isStructuralHeading(c)) return false;\n   978→      const hLower = baseHeading.text.toLowerCase();\n   979→      const cLower = c.text.toLowerCase();\n   980→      return cLower.startsWith(hLower + \" \") && /^[/&+:(]/.test(cLower.slice(hLower.length + 1));\n   981→    }) ?? baseHeading\n   982→  );\n   983→\n   984→  // Pass 2: apply bonuses\n   985→  const scored: Array<{ text: string; position: number; origin: CandidateOrigin; score: number; rawScore: number; baseScore: number; thresholdScore: number }> = rawScored.map((rs, candidateIndex) => {\n   986→    // Position factor: multiplicative tiebreaker — amplifies existing signal, doesn't replace it.\n   987→    // Use candidate-relative position (rank among candidates that passed hard filters) rather than\n   988→    // raw line position, so filtered preamble lines don't penalize the first real candidate.\n   989→    const candidateRelativePosition = candidateIndex / rawScored.length;\n   990→    const positionFactor = candidateRelativePosition < 0.5\n   991→      ? 1.0 + 0.12 * (1 - candidateRelativePosition * 2)\n   992→      : 1.0;\n   993→\n   994→    // ALL_CAPS bonus: recipe books use ALL_CAPS for titles and section headings.\n   995→    // Single-word ALL_CAPS terms are overwhelmingly section/category labels, not recipe titles;\n   996→    // real recipe titles in ALL_CAPS are almost always multi-word. Reduce the bonus for single words.\n   997→    const allCapsBonus = isAllCaps(rs.text) && rs.text.replace(/[^a-zA-Z]/g, \"\").length >= 4\n   998→      ? (wordCount(rs.text) >= 2 ? 0.08 : 0.03)\n   999→      : 0;\n  1000→\n  1001→    // Structural heading bonus: best ALL_CAPS heading (or its continuation join) is almost always the recipe title\n  1002→    const structuralBonus = firstStructuralHeading && rs.text === firstStructuralHeading.text ? 0.10 : 0;\n  1003→\n  1004→    // thresholdScore excludes structural bonus so the bonus doesn't inflate the threshold\n  1005→    // and prevent equally-valid structural headings from passing on multi-recipe pages.\n  1006→    const thresholdScore = rs.rawScore + allCapsBonus;\n  1007→    // baseScore excludes position factor — used for diagnostics and ranking\n  1008→    const baseScore = rs.rawScore + allCapsBonus + structuralBonus;\n  1009→    const score = rs.rawScore * positionFactor + allCapsBonus + structuralBonus;\n  1010→    return { text: rs.text, position: rs.position, origin: rs.origin, score, rawScore: rs.rawScore, baseScore, thresholdScore };\n  1011→  });\n  1012→\n  1013→  if (scored.length === 0) {\n  1014→    return undefined;\n  1015→  }\n  1016→\n  1017→  // First-after-preamble bonus (Pattern 3): when lines before the first candidate were all\n  1018→  // filtered/empty, the first surviving candidate occupies the structural \"title position\".\n  1019→  // E.g. \"FISH & SEAFOOD\\nHalibut with Saffron Cream Sauce\\n...\" — \"FISH & SEAFOOD\" is filtered\n  1020→  // as a section label, so \"Halibut...\" is the first candidate and gets this boost.\n  1021→  const firstCandidate = scored[0];\n  1022→  // Capture base score before positional bonuses to cap combined boost later\n  1023→  const baseScoreBeforePositionalBonuses = firstCandidate.baseScore;\n  1024→  if (firstCandidate.position > 0) {\n  1025→    const allPrecedingFiltered = lines\n  1026→      .slice(0, firstCandidate.position)\n  1027→      .every((line) => {\n  1028→        const trimmed = line.trim();\n  1029→        return trimmed === \"\" || !passesHardFilters(trimmed) || isSectionLabel(trimmed);\n  1030→      });\n  1031→    if (allPrecedingFiltered) {\n  1032→      // Stronger bonus when preamble contained structural markers (section labels, metadata)\n  1033→      // vs. only empty lines — structural markers are stronger positional evidence.\n  1034→      const hasStructuralPreamble = lines\n  1035→        .slice(0, firstCandidate.position)\n  1036→        .some((line) => {\n  1037→          const trimmed = line.trim();\n  1038→          return trimmed !== \"\" && (isSectionLabel(trimmed) || looksLikeMetadata(trimmed) || trimmed.includes(\" | \"));\n  1039→        });\n  1040→      const preambleBonus = hasStructuralPreamble ? 0.12 : 0.08;\n  1041→      firstCandidate.score += preambleBonus;\n  1042→      firstCandidate.baseScore += preambleBonus;\n  1043→      firstCandidate.thresholdScore += preambleBonus;\n  1044→    }\n  1045→  }\n  1046→  // Cap combined positional boost (candidate-relative position factor + first-after-preamble bonus)\n  1047→  // to avoid over-boosting when both fire together (~+0.24 uncapped → capped at +0.15).\n  1048→  const maxPositionalBoost = 0.15;\n  1049→  const totalPositionalBoost = firstCandidate.score - baseScoreBeforePositionalBonuses;\n  1050→  if (totalPositionalBoost > maxPositionalBoost) {\n  1051→    const excess = totalPositionalBoost - maxPositionalBoost;\n  1052→    firstCandidate.score -= excess;\n  1053→    firstCandidate.baseScore -= excess;\n  1054→    firstCandidate.thresholdScore -= excess;\n  1055→  }\n  1056→\n  1057→  // --- Pre-threshold bilingual title detection ---\n  1058→  // When a mixed-case candidate at position 0 is followed by an ALL_CAPS candidate\n  1059→  // at position ≤ 2 that is semantically similar to it, this is a bilingual recipe\n  1060→  // page (e.g., Polish title + ALL_CAPS Korean romanization). Suppress confirmed\n  1061→  // translation candidates before computing threshold so their bonuses don't inflate\n  1062→  // the threshold beyond the mixed-case title's reach.\n  1063→  // Note: we check position ≤ 2 (local proximity), not global ALL_CAPS count, so\n  1064→  // section headers later in the document (SKŁADNIKI, WARZYWA, etc.) are irrelevant.\n  1065→  let translationCandidates: typeof scored = [];\n  1066→  let scoredForThreshold = scored;\n  1067→  const prePos0 = scored.find((s) => s.position === 0 && !isAllCaps(s.text));\n  1068→  if (prePos0) {\n  1069→    const nearbyAllCaps = scored.filter(\n  1070→      (s) => isAllCaps(s.text) && s.position >= 1 && s.position <= 2 && s.origin === \"single\"\n  1071→    );\n  1072→    const pos0Embedding = rawScored.find((r) => r.text === prePos0.text)?.embedding;\n  1073→\n  1074→    // Method 1: embedding similarity (works for related languages)\n  1075→    if (pos0Embedding && nearbyAllCaps.length > 0) {\n  1076→      translationCandidates = nearbyAllCaps.filter((cap) => {\n  1077→        const capEmbedding = rawScored.find((r) => r.text === cap.text)?.embedding;\n  1078→        if (!capEmbedding) return false;\n  1079→        return cosineSimilarity(pos0Embedding, capEmbedding) > 0.4;\n  1080→      });\n  1081→    }\n  1082→\n  1083→    // Method 2: layout-based detection (cross-lingual fallback).\n  1084→    // When embedding similarity is insufficient (e.g. Polish ↔ Korean romanization),\n  1085→    // detect bilingual layout by position and word overlap:\n  1086→    // mixed-case ≥2 words at pos 0 + ALL_CAPS ≥2 words at pos 1-2 with no shared words.\n  1087→    if (translationCandidates.length === 0 && wordCount(prePos0.text) >= 2) {\n  1088→      const pos0Words = new Set(\n  1089→        prePos0.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2)\n  1090→      );\n  1091→      translationCandidates = nearbyAllCaps.filter((cap) => {\n  1092→        if (wordCount(cap.text) < 2) return false;\n  1093→        const capWords = cap.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2);\n  1094→        return !capWords.some((w) => pos0Words.has(w));\n  1095→      });\n  1096→    }\n  1097→\n  1098→    if (translationCandidates.length > 0) {\n  1099→      // Suppress standalone translations and any multi-line joins that embed the translation\n  1100→      // as a suffix or substring (e.g. \"Smażona zielona fasolka GREEN BEANS BORKEUM\" ends with\n  1101→      // the translation; \"Title GREEN BEANS BORKEUM 그린빈\" includes it as a substring).\n  1102→      scoredForThreshold = scored.filter((s) => {\n  1103→        const sLower = s.text.toLowerCase();\n  1104→        return !translationCandidates.some((t) => {\n  1105→          const tLower = t.text.toLowerCase();\n  1106→          return sLower.startsWith(tLower) ||\n  1107→                 sLower.endsWith(\" \" + tLower) ||\n  1108→                 sLower.includes(\" \" + tLower);\n  1109→        });\n  1110→      });\n  1111→    }\n  1112→  }\n  1113→\n  1114→  // Fix 2: If the structural heading was identified as a bilingual translation, reassign it.\n  1115→  // This prevents the translation's ALL_CAPS bonus from inflating the threshold and ensures\n  1116→  // the fallback path in scored also uses the correct heading.\n  1117→  if (\n  1118→    translationCandidates.length > 0 &&\n  1119→    firstStructuralHeading &&\n  1120→    translationCandidates.some((t) => t.text === firstStructuralHeading!.text)\n  1121→  ) {\n  1122→    const nonTranslationStructural = structuralCandidates.filter(\n  1123→      (sc) => !translationCandidates.some((t) => t.text === sc.text)\n  1124→    );\n  1125→    const newHeading = nonTranslationStructural.length > 0\n  1126→      ? nonTranslationStructural.reduce((a, b) => a.rawScore > b.rawScore ? a : b)\n  1127→      : undefined;\n  1128→\n  1129→    // Patch scored array: remove old structural bonus, apply new one\n  1130→    for (const s of scored) {\n  1131→      if (s.text === firstStructuralHeading.text) {\n  1132→        s.score -= 0.10;\n  1133→        s.baseScore -= 0.10;\n  1134→      }\n  1135→      if (newHeading && s.text === newHeading.text) {\n  1136→        s.score += 0.10;\n  1137→        s.baseScore += 0.10;\n  1138→      }\n  1139→    }\n  1140→    // Update reference for downstream prefix-removal logic\n  1141→    firstStructuralHeading = newHeading ?? undefined;\n  1142→  }\n  1143→\n  1144→  // Subtitle suppression: when a short mixed-case title at position 0 is followed by a\n  1145→  // longer mixed-case candidate at position 1-2, the longer one is a subtitle/translation.\n  1146→  // Apply a penalty so the primary title (position 0) wins.\n  1147→  const pos0Primary = scored.find((s) => s.position === 0 && !isAllCaps(s.text) && wordCount(s.text) <= 5);\n  1148→  if (pos0Primary) {\n  1149→    const subtitleCandidates = scored.filter((s) =>\n  1150→      s.position >= 1 && s.position <= 2 &&\n  1151→      !isAllCaps(s.text) &&\n  1152→      wordCount(s.text) > wordCount(pos0Primary.text) + 2\n  1153→    );\n  1154→    for (const sub of subtitleCandidates) {\n  1155→      sub.score -= 0.15;\n  1156→    }\n  1157→  }\n  1158→\n  1159→  // Bilingual layout pattern: [FoodName (≤2 words)]\\n[Translation (2-5 words, mixed-case)]\\n...[Section label]\n  1160→  // Common in bilingual cookbooks: foreign food name at position 0, English translation at position 1-2.\n  1161→  // When detected, boost the position-0 candidate so it clears the threshold.\n  1162→  // Note: the ALL_CAPS bilingual block above (lines 940-995) handles mixed-case + ALL_CAPS pairs.\n  1163→  // This block handles mixed-case + mixed-case translation pairs — the two do not overlap because\n  1164→  // the mixed-case guard (`biSecond.text !== biSecond.text.toUpperCase()`) excludes ALL_CAPS lines.\n  1165→  if (scored.length >= 2) {\n  1166→    const biFirst = scored.find((s) => s.position === 0);\n  1167→    // Restrict to single-line candidates (same guard as the ALL_CAPS bilingual block at line 953)\n  1168→    const biSecond = scored.find((s) => s.position >= 1 && s.position <= 2 && s !== biFirst && s.origin === \"single\");\n  1169→\n  1170→    if (biFirst && biSecond) {\n  1171→      const firstWords = biFirst.text.trim().split(/\\s+/);\n  1172→      const secondWords = biSecond.text.trim().split(/\\s+/);\n  1173→\n  1174→      const isBilingualLayout =\n  1175→        firstWords.length <= 2 &&\n  1176→        secondWords.length >= 2 &&\n  1177→        secondWords.length <= 5 &&\n  1178→        // Second line is mixed-case (not ALL_CAPS, not all-lower)\n  1179→        biSecond.text !== biSecond.text.toUpperCase() &&\n  1180→        biSecond.text !== biSecond.text.toLowerCase() &&\n  1181→        // Second line is not an ingredient or instruction\n  1182→        !looksLikeIngredient(biSecond.text) &&\n  1183→        !looksLikeCookingInstruction(biSecond.text);\n  1184→\n  1185→      if (isBilingualLayout) {\n  1186→        // Check if a section label follows within a few lines after the first candidate\n  1187→        const sectionLabelNearby = lines\n  1188→          .slice(biFirst.position + 1, biFirst.position + 6)\n  1189→          .some((line) => isSectionLabel(line.trim()));\n  1190→\n  1191→        if (sectionLabelNearby) {\n  1192→          biFirst.score += 0.15;\n  1193→          biFirst.baseScore += 0.15;\n  1194→          biFirst.thresholdScore += 0.15;\n  1195→        }\n  1196→      }\n  1197→    }\n  1198→  }\n  1199→\n  1200→  // Pre-filter: when ≥2 ALL_CAPS candidates are present, identify OCR artifacts (those whose\n  1201→  // vocabulary has no support elsewhere in the document) and remove them before computing the\n  1202→  // threshold. Artifacts like \"DAT FLATBREADS\" can inflate the threshold via their early-position\n  1203→  // bonus, which causes legitimate titles later in the document to fall just below the cutoff.\n  1204→  // Safety: only pre-filter if ≥2 candidates remain after removal (avoids false-positive removal\n  1205→  // of unique-vocabulary titles on two-recipe pages).\n  1206→  // NOTE: The ≥2 guard is conservative — when there are exactly 2 ALL_CAPS candidates and one is\n  1207→  // an artifact, the artifact is NOT removed. Relaxing to ≥1 causes regressions because 3-line\n  1208→  // join candidates (which span a section label) can pass corroboration via shared vocabulary,\n  1209→  // while the legitimate short title fails. See \"WORD ONE / INGREDIENTS / WORD TWO\" test case.\n  1210→  const allCapsInScored = scoredForThreshold.filter((s) => isAllCaps(s.text));\n  1211→  if (allCapsInScored.length >= 2) {\n  1212→    const artifactTexts = new Set(\n  1213→      allCapsInScored\n  1214→        .filter((cap) => !passesCorroboration(cap.text, cap.position, lines))\n  1215→        .map((c) => c.text)\n  1216→    );\n  1217→    if (artifactTexts.size > 0) {\n  1218→      const remainingCaps = allCapsInScored.filter((c) => !artifactTexts.has(c.text));\n  1219→      if (remainingCaps.length >= 2) {\n  1220→        scoredForThreshold = scoredForThreshold.filter((s) => !artifactTexts.has(s.text));\n  1221→      }\n  1222→    }\n  1223→  }\n  1224→\n  1225→  // Use thresholdScore (excludes structural bonus) so the structural bonus doesn't inflate\n  1226→  // the threshold and block equally-valid headings on multi-recipe pages.\n  1227→  const bestThresholdScore = Math.max(...scoredForThreshold.map((s) => s.thresholdScore));\n  1228→  const threshold = Math.max(0.08, bestThresholdScore * 0.7);\n  1229→\n  1230→  // Filter candidates above threshold\n  1231→  let selected = scoredForThreshold.filter((s) => s.score >= threshold);\n  1232→\n  1233→  // Empty-pool fallback: when threshold filtering discards every candidate,\n  1234→  // the hard filters' structural verdict should not be overruled by weak\n  1235→  // embedding differentiation. Return the best positional candidate only\n  1236→  // if it has a meaningful positive raw score (avoids ingredient-list leakage).\n  1237→  if (selected.length === 0 && scored.length > 0) {\n  1238→    const fallback = scored\n  1239→      .slice()\n  1240→      .sort((a, b) => a.position - b.position || b.score - a.score);\n  1241→    // Position-0 candidates that passed hard filters are very likely titles even with\n  1242→    // weak embedding signal. Relax the rawScore guard for early-position candidates.\n  1243→    const rawScoreThreshold = fallback[0].position <= 2 ? -0.05 : 0.02;\n  1244→    if (fallback[0].rawScore > rawScoreThreshold) {\n  1245→      selected = [fallback[0]];\n  1246→    }\n  1247→  }\n  1248→\n  1249→  // Title-absent page guard: when the page starts mid-recipe (all of the first 3 non-empty\n  1250→  // lines are ingredients or cooking instructions), require a much higher rawScore and\n  1251→  // discard candidates deep in the file. This prevents stray body text or adjacent recipe\n  1252→  // titles from being picked up on pages with no title (Pattern 4).\n  1253→  if (titleAbsent) {\n  1254→    const titleAbsentThreshold = 0.10;\n  1255→    selected = selected.filter(s => s.rawScore >= titleAbsentThreshold);\n  1256→    selected = selected.filter(s => s.position <= 2);\n  1257→  }\n  1258→\n  1259→  // Remove word-boundary prefixes of firstStructuralHeading when the heading itself survived\n  1260→  // the threshold. Cases:\n  1261→  //   ARAYES case:  firstStructuralHeading = \"ARAYES SHRAK\" (2-word join qualifies; \"ARAYES\"\n  1262→  //     alone = 1 word, so it never qualified). Filter removes \"ARAYES\" so dedup keeps the join.\n  1263→  //   SAFFRON case: baseHeading was the partial line; continuation logic above upgraded\n  1264→  //     firstStructuralHeading to the full join. Filter removes the partial so dedup keeps join.\n  1265→  // Safety: only fires when the complete heading itself is in selected (passed the threshold).\n  1266→  if (firstStructuralHeading && selected.some((s) => s.text === firstStructuralHeading.text)) {\n  1267→    const fshLower = firstStructuralHeading.text.toLowerCase();\n  1268→    selected = selected.filter((s) => {\n  1269→      if (s.text === firstStructuralHeading.text) return true;\n  1270→      const sLower = s.text.toLowerCase();\n  1271→      // Remove s if it is a space-delimited prefix of the structural heading\n  1272→      return !fshLower.startsWith(sLower + \" \");\n  1273→    });\n  1274→  }\n  1275→\n  1276→  // Protect continuation joins: when a multi-line join (2-line or 3-line) survived the threshold\n  1277→  // and its second part starts with a continuation character, remove the single-line prefix/suffix\n  1278→  // so the dedup \"shorter wins\" rule doesn't destroy the complete join.\n  1279→  // Note: the pre-merge step above already handles the common Baked Eggs case (&/continuation\n  1280→  // on next line) by turning it into a single candidate — this block covers the rarer case where\n  1281→  // a continuation-character join was generated as a 2-line/3-line candidate and the prefix\n  1282→  // single also survived threshold independently (e.g. from a different code path or OCR layout).\n  1283→  // Safety: only fires for joins whose continuation starts with /&+:( — digit continuations\n  1284→  // like \"Pierogi Ruskie 200g mąki\" are NOT protected, so dedup correctly keeps the shorter form.\n  1285→  const survivingJoins = selected.filter((s) => s.origin === \"2-line\" || s.origin === \"3-line\");\n  1286→  if (survivingJoins.length > 0) {\n  1287→    selected = selected.filter((s) => {\n  1288→      if (s.origin !== \"single\") return true;\n  1289→      const sLower = s.text.toLowerCase();\n  1290→      // Remove PREFIX singles whose continuation join also survived\n  1291→      const isPrefixOfJoin = survivingJoins.some((j) => {\n  1292→        const jLower = j.text.toLowerCase();\n  1293→        if (!jLower.startsWith(sLower + \" \")) return false;\n  1294→        const remainder = jLower.slice(sLower.length + 1);\n  1295→        return /^[/&+:(]/.test(remainder);\n  1296→      });\n  1297→      if (isPrefixOfJoin) return false;\n  1298→      // Remove SUFFIX singles (e.g. \"& Coriander\") whose parent join also survived\n  1299→      const isSuffixOfJoin = survivingJoins.some((j) => {","numLines":500,"startLine":800,"totalLines":1518}}}
