{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LJKCMrH1H9h34xb1CBtWEv","type":"tool_result","content":"   400→   400→  // \"For the sauce:\", \"For the filling:\" etc. are sub-section headers\n   401→   401→  if (/^For the\\s+/i.test(text) && /:\\s*$/.test(text)) return false;\n   402→   402→  // Lines ending with \":\" are recipe sub-section headers, not titles.\n   403→   403→  // Exception: compound titles using \" : \" as a title separator (e.g. \"LEMON CURD : LEMON CURD WITH THYME\").\n   404→   404→  if (/:\\s*$/.test(text.trim()) && !/ : /.test(text)) return false;\n   405→   405→  // Page references are navigation markers, not recipe titles\n   406→   406→  if (/^Page\\s+\\d+/i.test(text.trim())) return false;\n   407→   407→  if (/^Strona\\s+\\d+/i.test(text.trim())) return false;\n   408→   408→  // Corrupted spillover annotations from synthetic multi-page OCR\n   409→   409→  if (/^\\[CORRUPTED\\s+SPILLOVER/i.test(text.trim())) return false;\n   410→   410→  // Parenthetical OCR annotation lines describing corruption artifacts\n   411→   411→  if (/^\\(OCR\\b/i.test(text.trim())) return false;\n   412→   412→  if (/^\\(.*\\bcorruption\\b/i.test(text.trim())) return false;\n   413→   413→  // Square-bracket category tags (e.g., \"[CLASSIC FALL SOUPS]\")\n   414→   414→  if (/^\\[.*\\]$/.test(text.trim())) return false;\n   415→   415→  // Known recipe section labels are structural headers, not titles\n   416→   416→  if (isSectionLabel(text)) return false;\n   417→   417→  // Single-word non-title fragments\n   418→   418→  const words = text.trim().split(/\\s+/);\n   419→   419→  if (words.length === 1 && NON_TITLE_WORDS.has(text.trim().toLowerCase())) return false;\n   420→   420→  // Lines with ≥8 words are almost certainly body text, not titles.\n   421→   421→  // Exception: multi-title compounds with \" + \", \" : \", or \" & \" separators are allowed.\n   422→   422→  if (words.length >= 8 && !/ [+:&/] /.test(text)) return false;\n   423→   423→  return true;\n   424→   424→}\n   425→   425→\n   426→   426→/**\n   427→   427→ * Detect initial burst of short garbled lines.\n   428→   428→ * Returns the index of the first non-garbled or long line.\n   429→   429→ */\n   430→   430→function findBurstEnd(lines: Array<{ text: string }>): number {\n   431→   431→  let i = 0;\n   432→   432→\n   433→   433→  // Skip overflow preambles: blocks introduced by \"PREVIOUS RECIPE OVERFLOW\",\n   434→   434→  // \"PREVIOUS PAGE CONTENT\", \"CORRUPTED SECTION\", etc. that precede the actual recipe.\n   435→   435→  const OVERFLOW_MARKERS = /\\b(PREVIOUS\\s+(RECIPE|PAGE)\\s+(OVERFLOW|CONTENT)|SPILLOVER|CONTINUATION|CORRUPTED\\s+SECTION)\\b/i;\n   436→   436→  let overflowEnd = 0;\n   437→   437→  for (let k = 0; k < lines.length && k < 30; k++) {\n   438→   438→    // Don't re-examine lines already determined to be overflow\n   439→   439→    if (overflowEnd > 0 && k < overflowEnd) continue;\n   440→   440→    if (OVERFLOW_MARKERS.test(lines[k].text)) {\n   441→   441→      // Skip forward past the overflow block to the next visual separator or blank cluster\n   442→   442→      let m = k + 1;\n   443→   443→      let consecutiveBlanks = 0;\n   444→   444→      while (m < lines.length) {\n   445→   445→        const lineText = lines[m].text;\n   446→   446→        // Stop at visual separator\n   447→   447→        if (/^[=\\-]{4,}$/.test(lineText)) {\n   448→   448→          overflowEnd = m + 1;\n   449→   449→          break;\n   450→   450→        }\n   451→   451→        // Track consecutive blank lines\n   452→   452→        if (lineText.trim().length === 0) {\n   453→   453→          consecutiveBlanks++;\n   454→   454→          if (consecutiveBlanks >= 2) {\n   455→   455→            overflowEnd = m + 1;\n   456→   456→            break;\n   457→   457→          }\n   458→   458→        } else {\n   459→   459→          consecutiveBlanks = 0;\n   460→   460→          // Stop at ALL_CAPS line with ≥2 words (likely next recipe heading)\n   461→   461→          if (isAllCaps(lineText) && wordCount(lineText) >= 2) {\n   462→   462→            overflowEnd = m; // Don't skip past the heading itself\n   463→   463→            break;\n   464→   464→          }\n   465→   465→        }\n   466→   466→        m++;\n   467→   467→      }\n   468→   468→      // If we walked to end without finding termination, skip everything we saw\n   469→   469→      if (overflowEnd === 0) overflowEnd = m;\n   470→   470→    }\n   471→   471→  }\n   472→   472→  if (overflowEnd > 0) i = overflowEnd;\n   473→   473→\n   474→   474→  while (i < lines.length && lines[i].text.length < 20 && isLikelyGarbled(lines[i].text) && !isAllCaps(lines[i].text)) {\n   475→   475→    i++;\n   476→   476→  }\n   477→   477→  // Skip long instruction-like prologues: if 5+ consecutive lines look like cooking instructions,\n   478→   478→  // skip them to find the actual title region.\n   479→   479→  if (i === 0) {\n   480→   480→    let j = 0;\n   481→   481→    while (j < lines.length && looksLikeCookingInstruction(lines[j].text)) {\n   482→   482→      j++;\n   483→   483→    }\n   484→   484→    if (j >= 5) {\n   485→   485→      i = j;\n   486→   486→    }\n   487→   487→  }\n   488→   488→  // Skip prose prologues: mid-recipe body text before the actual title.\n   489→   489→  // If 3+ consecutive lines look like running body text (lowercase start, continuation,\n   490→   490→  // or sentence-ending with many words), skip them.\n   491→   491→  if (i === 0) {\n   492→   492→    let j = 0;\n   493→   493→    while (j < lines.length) {\n   494→   494→      const t = lines[j].text;\n   495→   495→      const isBodyText = (\n   496→   496→        /^[a-ząćęłńóśźż]/.test(t) ||\n   497→   497→        t.endsWith(\",\") ||\n   498→   498→        (t.endsWith(\".\") && wordCount(t) > 4)\n   499→   499→      ) && wordCount(t) >= 4;\n   500→   500→      if (isBodyText) j++;\n   501→   501→      else break;\n   502→   502→    }\n   503→   503→    if (j >= 3) i = j;\n   504→   504→  }\n   505→   505→  return i;\n   506→   506→}\n   507→   507→\n   508→   508→function stripParentheticalGloss(text: string): string {\n   509→   509→  // Strip trailing English-gloss parentheticals from ALL_CAPS titles.\n   510→   510→  // e.g. \"PIEROGI RUSKIE (Boiled Dumplings with Potato and Cheese)\" → \"PIEROGI RUSKIE\"\n   511→   511→  // Keep if parenthetical is ALL_CAPS (variation/subtitle in same language).\n   512→   512→  // Keep if both base and paren are mixed-case (both are part of the title).\n   513→   513→  const match = text.match(/^(.+?)\\s*\\(([^)]+)\\)\\s*$/);\n   514→   514→  if (!match) return text;\n   515→   515→  const [, base, paren] = match;\n   516→   516→  if (isAllCaps(paren)) return text;\n   517→   517→  if (!isAllCaps(base) && !isAllCaps(paren)) return text;\n   518→   518→  return base.trim();\n   519→   519→}\n   520→   520→\n   521→   521→function stripPageNumber(text: string): string {\n   522→   522→  // \"34  Berry Jam\" → \"Berry Jam\" (2+ spaces distinguishes from \"2 eggs\")\n   523→   523→  const match = text.match(/^\\d{1,3}\\s{2,}(.+)$/);\n   524→   524→  return match ? match[1] : text;\n   525→   525→}\n   526→   526→\n   527→   527→function wordCount(text: string): number {\n   528→   528→  return text.split(/\\s+/).filter((w) => w.length > 0).length;\n   529→   529→}\n   530→   530→\n   531→   531→/**\n   532→   532→ * Build candidate strings from lines: single lines plus multi-line joins (2-3 consecutive).\n   533→   533→ * Skips initial burst of short garbled lines. Scans all remaining lines. Caps at 25.\n   534→   534→ */\n   535→   535→export type CandidateOrigin = \"single\" | \"2-line\" | \"3-line\";\n   536→   536→\n   537→   537→function buildCandidates(\n   538→   538→  lines: Array<string>\n   539→   539→): Array<{ text: string; position: number; origin: CandidateOrigin }> {\n   540→   540→  const nonEmptyLines: Array<{ text: string; index: number }> = [];\n   541→   541→\n   542→   542→  for (let i = 0; i < lines.length; i++) {\n   543→   543→    const trimmed = lines[i].trim();\n   544→   544→    if (trimmed.length > 0) {\n   545→   545→      nonEmptyLines.push({ text: trimmed, index: i });\n   546→   546→    }\n   547→   547→  }\n   548→   548→\n   549→   549→  const burstEnd = findBurstEnd(nonEmptyLines);\n   550→   550→\n   551→   551→  // Pre-join hyphen-broken lines: \"ROASTED CHICKEN WITH ROOT VEGET-\" + \"ABLES\" → single line.\n   552→   552→  // Only applies within the candidate region (after burst end).\n   553→   553→  for (let hi = burstEnd; hi < nonEmptyLines.length - 1; hi++) {\n   554→   554→    if (nonEmptyLines[hi].text.endsWith(\"-\")) {\n   555→   555→      const joined = nonEmptyLines[hi].text.slice(0, -1) + nonEmptyLines[hi + 1].text;\n   556→   556→      nonEmptyLines[hi] = { text: joined, index: nonEmptyLines[hi].index };\n   557→   557→      nonEmptyLines.splice(hi + 1, 1);\n   558→   558→    }\n   559→   559→  }\n   560→   560→\n   561→   561→  // Pre-merge consecutive short ALL_CAPS lines (OCR-fragmented headings).\n   562→   562→  // When a sequence of 2+ ALL_CAPS lines each has ≤2 words and ≤25 chars, they are\n   563→   563→  // almost certainly OCR fragments of a single heading. Merge them into one line so\n   564→   564→  // the complete title enters the candidate pool without hitting the 3-line join ceiling.\n   565→   565→  const capsCoalesced: Array<{ text: string; index: number }> = [];\n   566→   566→  let ci = burstEnd;\n   567→   567→  while (ci < nonEmptyLines.length) {\n   568→   568→    const line = nonEmptyLines[ci];\n   569→   569→    if (\n   570→   570→      isAllCaps(line.text) &&\n   571→   571→      wordCount(line.text) <= 2 &&\n   572→   572→      line.text.length <= 25 &&\n   573→   573→      !isSectionLabel(line.text) &&\n   574→   574→      !looksLikeMetadata(line.text)\n   575→   575→    ) {\n   576→   576→      let merged = line.text;\n   577→   577→      const startIndex = line.index;\n   578→   578→      let j = ci + 1;\n   579→   579→      while (j < nonEmptyLines.length) {\n   580→   580→        const next = nonEmptyLines[j];\n   581→   581→        if (\n   582→   582→          isAllCaps(next.text) &&\n   583→   583→          wordCount(next.text) <= 2 &&\n   584→   584→          next.text.length <= 25 &&\n   585→   585→          ((!isSectionLabel(next.text) && !isSectionLabel(repairOcrText(next.text))) ||\n   586→   586→           (wordCount(next.text) === 1 && wordCount(merged) >= 2 && wordCount(merged) <= 4 &&\n   587→   587→            isCategorySectionLabel(next.text))) &&\n   588→   588→          !looksLikeMetadata(next.text) &&\n   589→   589→          (merged + \" \" + next.text).length <= 80\n   590→   590→        ) {\n   591→   591→          merged += \" \" + next.text;\n   592→   592→          j++;\n   593→   593→        } else {\n   594→   594→          break;\n   595→   595→        }\n   596→   596→      }\n   597→   597→      if (j > ci + 1) {\n   598→   598→        capsCoalesced.push({ text: merged, index: startIndex });\n   599→   599→        ci = j;\n   600→   600→        continue;\n   601→   601→      }\n   602→   602→    }\n   603→   603→    capsCoalesced.push(line);\n   604→   604→    ci++;\n   605→   605→  }\n   606→   606→\n   607→   607→  // Pre-merge continuation lines: a line starting with /&+:( is never a standalone title.\n   608→   608→  // Merge it into the preceding line so the complete title enters the pool as a single candidate,\n   609→   609→  // avoiding the fragile chain of conditions required by the downstream join survival logic.\n   610→   610→  // Limitation: only one continuation line per preceding line is merged. Titles split across\n   611→   611→  // three or more lines with continuation tokens (rare in practice) are not handled here —\n   612→   612→  // the downstream 2-line and 3-line join candidates cover those cases instead.\n   613→   613→  const mergedLines: Array<{ text: string; index: number }> = [];\n   614→   614→  for (let i = 0; i < capsCoalesced.length; i++) {\n   615→   615→    const line = capsCoalesced[i];\n   616→   616→    if (i + 1 < capsCoalesced.length) {\n   617→   617→      const nextText = capsCoalesced[i + 1].text;\n   618→   618→      if (/^[/&+:(]/.test(nextText)) {\n   619→   619→        mergedLines.push({ text: `${line.text} ${nextText}`, index: line.index });\n   620→   620→        i++;\n   621→   621→        continue;\n   622→   622→      }\n   623→   623→    }\n   624→   624→    mergedLines.push(line);\n   625→   625→  }\n   626→   626→\n   627→   627→  const candidates: Array<{ text: string; position: number; origin: CandidateOrigin }> = [];\n   628→   628→  const seen = new Set<string>();\n   629→   629→\n   630→   630→  // Build a set of positions to skip: short ALL_CAPS lines immediately following metadata\n   631→   631→  const metadataContinuationPositions = new Set<number>();\n   632→   632→  for (let i = 0; i < mergedLines.length - 1; i++) {\n   633→   633→    if (looksLikeMetadata(mergedLines[i].text)) {\n   634→   634→      const next = mergedLines[i + 1];\n   635→   635→      if (isAllCaps(next.text) && wordCount(next.text) <= 2 && next.text.length <= 15) {\n   636→   636→        metadataContinuationPositions.add(next.index);\n   637→   637→      }\n   638→   638→    }\n   639→   639→  }\n   640→   640→\n   641→   641→  for (let i = 0; i < mergedLines.length; i++) {\n   642→   642→    const line = mergedLines[i];\n   643→   643→\n   644→   644→    // Skip metadata continuation fragments\n   645→   645→    if (metadataContinuationPositions.has(line.index)) continue;\n   646→   646→\n   647→   647→    // Single line — strip page-number prefixes and parenthetical glosses before scoring\n   648→   648→    const singleText = repairOcrText(stripParentheticalGloss(stripPageNumber(line.text)));\n   649→   649→    if (passesHardFilters(singleText)) {\n   650→   650→      const norm = singleText.toLowerCase();\n   651→   651→      if (!seen.has(norm)) {\n   652→   652→        seen.add(norm);\n   653→   653→        candidates.push({ text: singleText, position: line.index, origin: \"single\" });\n   654→   654→      }\n   655→   655→    }\n   656→   656→\n   657→   657→    // 2-line join — skip if first line is a section label AND join would be ≤2 words\n   658→   658→    // (a section label followed by modifiers is likely a recipe title, not a category header)\n   659→   659→    if (i + 1 < mergedLines.length) {\n   660→   660→      const joined2 = repairOcrText(`${line.text} ${mergedLines[i + 1].text}`);\n   661→   661→      const shouldBlock2 = isSectionLabel(line.text) &&\n   662→   662→        (wordCount(joined2) <= 2 || isAlwaysBlockJoinLabel(line.text));\n   663→   663→      if (!shouldBlock2 && passesHardFilters(joined2)) {\n   664→   664→        const norm = joined2.toLowerCase();\n   665→   665→        if (!seen.has(norm)) {\n   666→   666→          seen.add(norm);\n   667→   667→          candidates.push({ text: joined2, position: line.index, origin: \"2-line\" });\n   668→   668→        }\n   669→   669→      }\n   670→   670→    }\n   671→   671→\n   672→   672→    // 3-line join — skip if first line is a section label AND join would be ≤2 words\n   673→   673→    if (i + 2 < mergedLines.length) {\n   674→   674→      const joined3 = repairOcrText(`${line.text} ${mergedLines[i + 1].text} ${mergedLines[i + 2].text}`);\n   675→   675→      const shouldBlock3 = isSectionLabel(line.text) &&\n   676→   676→        (wordCount(joined3) <= 2 || isAlwaysBlockJoinLabel(line.text));\n   677→   677→      if (!shouldBlock3 && passesHardFilters(joined3)) {\n   678→   678→        const norm = joined3.toLowerCase();\n   679→   679→        if (!seen.has(norm)) {\n   680→   680→          seen.add(norm);\n   681→   681→          candidates.push({ text: joined3, position: line.index, origin: \"3-line\" });\n   682→   682→        }\n   683→   683→      }\n   684→   684→    }\n   685→   685→  }\n   686→   686→\n   687→   687→  // Pre-filter to 25 before embedding calls: prefer ALL_CAPS and short candidates.\n   688→   688→  // Position-based scoring handles final ranking.\n   689→   689→  if (candidates.length > 25) {\n   690→   690→    const prioritized = candidates.slice().sort((a, b) => {\n   691→   691→      const aAllCaps = isAllCaps(a.text) ? 0 : 1;\n   692→   692→      const bAllCaps = isAllCaps(b.text) ? 0 : 1;\n   693→   693→      if (aAllCaps !== bAllCaps) return aAllCaps - bAllCaps;\n   694→   694→      const aShort = wordCount(a.text) <= 5 ? 0 : 1;\n   695→   695→      const bShort = wordCount(b.text) <= 5 ? 0 : 1;\n   696→   696→      return aShort - bShort;\n   697→   697→    });\n   698→   698→    return prioritized.slice(0, 25);\n   699→   699→  }\n   700→   700→\n   701→   701→  return candidates;\n   702→   702→}\n   703→   703→\n   704→   704→/**\n   705→   705→ * Convert an ALL_CAPS string to Title Case, using a small-words list.\n   706→   706→ * Preserves Polish/French diacritics.\n   707→   707→ */\n   708→   708→function toTitleCase(text: string): string {\n   709→   709→  const smallWords = new Set([\n   710→   710→    \"a\", \"an\", \"the\", \"and\", \"but\", \"or\", \"for\", \"nor\",\n   711→   711→    \"in\", \"on\", \"at\", \"to\", \"of\", \"by\", \"with\", \"from\",\n   712→   712→    \"z\", \"w\", \"i\", \"ze\", \"na\", \"do\", \"od\", \"za\", \"po\",\n   713→   713→  ]);\n   714→   714→  return text.split(/(\\s+)/).map((word, idx) => {\n   715→   715→    if (/^\\s+$/.test(word)) return word;\n   716→   716→    const lower = word.toLowerCase();\n   717→   717→    if (idx === 0 || !smallWords.has(lower)) {\n   718→   718→      return lower.charAt(0).toUpperCase() + lower.slice(1);\n   719→   719→    }\n   720→   720→    return lower;\n   721→   721→  }).join(\"\");\n   722→   722→}\n   723→   723→\n   724→   724→/**\n   725→   725→ * OCR digit→letter substitution map.\n   726→   726→ * Each key is a character that OCR commonly confuses; values are possible correct letters.\n   727→   727→ */\n   728→   728→const OCR_SUBSTITUTIONS: Record<string, string[]> = {\n   729→   729→  \"0\": [\"o\"],\n   730→   730→  \"1\": [\"i\", \"l\"],\n   731→   731→  \"4\": [\"a\"],\n   732→   732→  \"5\": [\"s\"],\n   733→   733→  \"¡\": [\"i\"],\n   734→   734→  \"í\": [\"i\", \"l\"],\n   735→   735→  \"€\": [\"e\"],\n   736→   736→};\n   737→   737→\n   738→   738→const OCR_ARTIFACT_PATTERN = /[0-9¡Íí€]/;\n   739→   739→\n   740→   740→/**\n   741→   741→ * Attempt to repair a single OCR-corrupted word using dictionary lookup.\n   742→   742→ * Returns the repaired word if a dictionary match is found, otherwise returns the original.\n   743→   743→ */\n   744→   744→function repairOcrWord(word: string): string {\n   745→   745→  if (!OCR_ARTIFACT_PATTERN.test(word)) return word;\n   746→   746→\n   747→   747→  const lower = word.toLowerCase();\n   748→   748→\n   749→   749→  const positions: Array<{ index: number; replacements: Array<string> }> = [];\n   750→   750→  for (let i = 0; i < lower.length; i++) {\n   751→   751→    const replacements = OCR_SUBSTITUTIONS[lower[i]];\n   752→   752→    if (replacements) {\n   753→   753→      positions.push({ index: i, replacements });\n   754→   754→    }\n   755→   755→  }\n   756→   756→\n   757→   757→  if (positions.length === 0 || positions.length > 8) return word;\n   758→   758→\n   759→   759→  const candidates = generateSubstitutions(lower, positions, 0);\n   760→   760→\n   761→   761→  for (const candidate of candidates) {\n   762→   762→    if (FOOD_DICTIONARY.has(candidate)) {\n   763→   763→      if (word === word.toUpperCase()) return candidate.toUpperCase();\n   764→   764→      if (word[0] === word[0].toUpperCase()) {\n   765→   765→        return candidate[0].toUpperCase() + candidate.slice(1);\n   766→   766→      }\n   767→   767→      return candidate;\n   768→   768→    }\n   769→   769→  }\n   770→   770→\n   771→   771→  return word;\n   772→   772→}\n   773→   773→\n   774→   774→/**\n   775→   775→ * Recursively generate all substitution variants for OCR artifact positions.\n   776→   776→ */\n   777→   777→function generateSubstitutions(\n   778→   778→  base: string,\n   779→   779→  positions: Array<{ index: number; replacements: Array<string> }>,\n   780→   780→  posIdx: number,\n   781→   781→): Array<string> {\n   782→   782→  if (posIdx >= positions.length) return [base];\n   783→   783→\n   784→   784→  const { index, replacements } = positions[posIdx];\n   785→   785→  const results: Array<string> = [];\n   786→   786→\n   787→   787→  for (const replacement of replacements) {\n   788→   788→    const variant = base.slice(0, index) + replacement + base.slice(index + 1);\n   789→   789→    results.push(...generateSubstitutions(variant, positions, posIdx + 1));\n   790→   790→  }\n   791→   791→\n   792→   792→  return results;\n   793→   793→}\n   794→   794→\n   795→   795→/**\n   796→   796→ * Apply dictionary-guided OCR repair to all words in a text string.\n   797→   797→ */\n   798→   798→function repairOcrText(text: string): string {\n   799→   799→  return text"}]},"parent_tool_use_id":null,"session_id":"67c804db-4061-40f8-823f-56265230248d","uuid":"7d6a87ae-bc6f-4adf-bba7-3e6f4d13b707","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/.claude/projects/-Users-eryk-napierala-Projects-fasola/67c804db-4061-40f8-823f-56265230248d/tool-results/toolu_01DvKFciZsJPvPdys84EBJ9N.txt","content":"   400→  // \"For the sauce:\", \"For the filling:\" etc. are sub-section headers\n   401→  if (/^For the\\s+/i.test(text) && /:\\s*$/.test(text)) return false;\n   402→  // Lines ending with \":\" are recipe sub-section headers, not titles.\n   403→  // Exception: compound titles using \" : \" as a title separator (e.g. \"LEMON CURD : LEMON CURD WITH THYME\").\n   404→  if (/:\\s*$/.test(text.trim()) && !/ : /.test(text)) return false;\n   405→  // Page references are navigation markers, not recipe titles\n   406→  if (/^Page\\s+\\d+/i.test(text.trim())) return false;\n   407→  if (/^Strona\\s+\\d+/i.test(text.trim())) return false;\n   408→  // Corrupted spillover annotations from synthetic multi-page OCR\n   409→  if (/^\\[CORRUPTED\\s+SPILLOVER/i.test(text.trim())) return false;\n   410→  // Parenthetical OCR annotation lines describing corruption artifacts\n   411→  if (/^\\(OCR\\b/i.test(text.trim())) return false;\n   412→  if (/^\\(.*\\bcorruption\\b/i.test(text.trim())) return false;\n   413→  // Square-bracket category tags (e.g., \"[CLASSIC FALL SOUPS]\")\n   414→  if (/^\\[.*\\]$/.test(text.trim())) return false;\n   415→  // Known recipe section labels are structural headers, not titles\n   416→  if (isSectionLabel(text)) return false;\n   417→  // Single-word non-title fragments\n   418→  const words = text.trim().split(/\\s+/);\n   419→  if (words.length === 1 && NON_TITLE_WORDS.has(text.trim().toLowerCase())) return false;\n   420→  // Lines with ≥8 words are almost certainly body text, not titles.\n   421→  // Exception: multi-title compounds with \" + \", \" : \", or \" & \" separators are allowed.\n   422→  if (words.length >= 8 && !/ [+:&/] /.test(text)) return false;\n   423→  return true;\n   424→}\n   425→\n   426→/**\n   427→ * Detect initial burst of short garbled lines.\n   428→ * Returns the index of the first non-garbled or long line.\n   429→ */\n   430→function findBurstEnd(lines: Array<{ text: string }>): number {\n   431→  let i = 0;\n   432→\n   433→  // Skip overflow preambles: blocks introduced by \"PREVIOUS RECIPE OVERFLOW\",\n   434→  // \"PREVIOUS PAGE CONTENT\", \"CORRUPTED SECTION\", etc. that precede the actual recipe.\n   435→  const OVERFLOW_MARKERS = /\\b(PREVIOUS\\s+(RECIPE|PAGE)\\s+(OVERFLOW|CONTENT)|SPILLOVER|CONTINUATION|CORRUPTED\\s+SECTION)\\b/i;\n   436→  let overflowEnd = 0;\n   437→  for (let k = 0; k < lines.length && k < 30; k++) {\n   438→    // Don't re-examine lines already determined to be overflow\n   439→    if (overflowEnd > 0 && k < overflowEnd) continue;\n   440→    if (OVERFLOW_MARKERS.test(lines[k].text)) {\n   441→      // Skip forward past the overflow block to the next visual separator or blank cluster\n   442→      let m = k + 1;\n   443→      let consecutiveBlanks = 0;\n   444→      while (m < lines.length) {\n   445→        const lineText = lines[m].text;\n   446→        // Stop at visual separator\n   447→        if (/^[=\\-]{4,}$/.test(lineText)) {\n   448→          overflowEnd = m + 1;\n   449→          break;\n   450→        }\n   451→        // Track consecutive blank lines\n   452→        if (lineText.trim().length === 0) {\n   453→          consecutiveBlanks++;\n   454→          if (consecutiveBlanks >= 2) {\n   455→            overflowEnd = m + 1;\n   456→            break;\n   457→          }\n   458→        } else {\n   459→          consecutiveBlanks = 0;\n   460→          // Stop at ALL_CAPS line with ≥2 words (likely next recipe heading)\n   461→          if (isAllCaps(lineText) && wordCount(lineText) >= 2) {\n   462→            overflowEnd = m; // Don't skip past the heading itself\n   463→            break;\n   464→          }\n   465→        }\n   466→        m++;\n   467→      }\n   468→      // If we walked to end without finding termination, skip everything we saw\n   469→      if (overflowEnd === 0) overflowEnd = m;\n   470→    }\n   471→  }\n   472→  if (overflowEnd > 0) i = overflowEnd;\n   473→\n   474→  while (i < lines.length && lines[i].text.length < 20 && isLikelyGarbled(lines[i].text) && !isAllCaps(lines[i].text)) {\n   475→    i++;\n   476→  }\n   477→  // Skip long instruction-like prologues: if 5+ consecutive lines look like cooking instructions,\n   478→  // skip them to find the actual title region.\n   479→  if (i === 0) {\n   480→    let j = 0;\n   481→    while (j < lines.length && looksLikeCookingInstruction(lines[j].text)) {\n   482→      j++;\n   483→    }\n   484→    if (j >= 5) {\n   485→      i = j;\n   486→    }\n   487→  }\n   488→  // Skip prose prologues: mid-recipe body text before the actual title.\n   489→  // If 3+ consecutive lines look like running body text (lowercase start, continuation,\n   490→  // or sentence-ending with many words), skip them.\n   491→  if (i === 0) {\n   492→    let j = 0;\n   493→    while (j < lines.length) {\n   494→      const t = lines[j].text;\n   495→      const isBodyText = (\n   496→        /^[a-ząćęłńóśźż]/.test(t) ||\n   497→        t.endsWith(\",\") ||\n   498→        (t.endsWith(\".\") && wordCount(t) > 4)\n   499→      ) && wordCount(t) >= 4;\n   500→      if (isBodyText) j++;\n   501→      else break;\n   502→    }\n   503→    if (j >= 3) i = j;\n   504→  }\n   505→  return i;\n   506→}\n   507→\n   508→function stripParentheticalGloss(text: string): string {\n   509→  // Strip trailing English-gloss parentheticals from ALL_CAPS titles.\n   510→  // e.g. \"PIEROGI RUSKIE (Boiled Dumplings with Potato and Cheese)\" → \"PIEROGI RUSKIE\"\n   511→  // Keep if parenthetical is ALL_CAPS (variation/subtitle in same language).\n   512→  // Keep if both base and paren are mixed-case (both are part of the title).\n   513→  const match = text.match(/^(.+?)\\s*\\(([^)]+)\\)\\s*$/);\n   514→  if (!match) return text;\n   515→  const [, base, paren] = match;\n   516→  if (isAllCaps(paren)) return text;\n   517→  if (!isAllCaps(base) && !isAllCaps(paren)) return text;\n   518→  return base.trim();\n   519→}\n   520→\n   521→function stripPageNumber(text: string): string {\n   522→  // \"34  Berry Jam\" → \"Berry Jam\" (2+ spaces distinguishes from \"2 eggs\")\n   523→  const match = text.match(/^\\d{1,3}\\s{2,}(.+)$/);\n   524→  return match ? match[1] : text;\n   525→}\n   526→\n   527→function wordCount(text: string): number {\n   528→  return text.split(/\\s+/).filter((w) => w.length > 0).length;\n   529→}\n   530→\n   531→/**\n   532→ * Build candidate strings from lines: single lines plus multi-line joins (2-3 consecutive).\n   533→ * Skips initial burst of short garbled lines. Scans all remaining lines. Caps at 25.\n   534→ */\n   535→export type CandidateOrigin = \"single\" | \"2-line\" | \"3-line\";\n   536→\n   537→function buildCandidates(\n   538→  lines: Array<string>\n   539→): Array<{ text: string; position: number; origin: CandidateOrigin }> {\n   540→  const nonEmptyLines: Array<{ text: string; index: number }> = [];\n   541→\n   542→  for (let i = 0; i < lines.length; i++) {\n   543→    const trimmed = lines[i].trim();\n   544→    if (trimmed.length > 0) {\n   545→      nonEmptyLines.push({ text: trimmed, index: i });\n   546→    }\n   547→  }\n   548→\n   549→  const burstEnd = findBurstEnd(nonEmptyLines);\n   550→\n   551→  // Pre-join hyphen-broken lines: \"ROASTED CHICKEN WITH ROOT VEGET-\" + \"ABLES\" → single line.\n   552→  // Only applies within the candidate region (after burst end).\n   553→  for (let hi = burstEnd; hi < nonEmptyLines.length - 1; hi++) {\n   554→    if (nonEmptyLines[hi].text.endsWith(\"-\")) {\n   555→      const joined = nonEmptyLines[hi].text.slice(0, -1) + nonEmptyLines[hi + 1].text;\n   556→      nonEmptyLines[hi] = { text: joined, index: nonEmptyLines[hi].index };\n   557→      nonEmptyLines.splice(hi + 1, 1);\n   558→    }\n   559→  }\n   560→\n   561→  // Pre-merge consecutive short ALL_CAPS lines (OCR-fragmented headings).\n   562→  // When a sequence of 2+ ALL_CAPS lines each has ≤2 words and ≤25 chars, they are\n   563→  // almost certainly OCR fragments of a single heading. Merge them into one line so\n   564→  // the complete title enters the candidate pool without hitting the 3-line join ceiling.\n   565→  const capsCoalesced: Array<{ text: string; index: number }> = [];\n   566→  let ci = burstEnd;\n   567→  while (ci < nonEmptyLines.length) {\n   568→    const line = nonEmptyLines[ci];\n   569→    if (\n   570→      isAllCaps(line.text) &&\n   571→      wordCount(line.text) <= 2 &&\n   572→      line.text.length <= 25 &&\n   573→      !isSectionLabel(line.text) &&\n   574→      !looksLikeMetadata(line.text)\n   575→    ) {\n   576→      let merged = line.text;\n   577→      const startIndex = line.index;\n   578→      let j = ci + 1;\n   579→      while (j < nonEmptyLines.length) {\n   580→        const next = nonEmptyLines[j];\n   581→        if (\n   582→          isAllCaps(next.text) &&\n   583→          wordCount(next.text) <= 2 &&\n   584→          next.text.length <= 25 &&\n   585→          ((!isSectionLabel(next.text) && !isSectionLabel(repairOcrText(next.text))) ||\n   586→           (wordCount(next.text) === 1 && wordCount(merged) >= 2 && wordCount(merged) <= 4 &&\n   587→            isCategorySectionLabel(next.text))) &&\n   588→          !looksLikeMetadata(next.text) &&\n   589→          (merged + \" \" + next.text).length <= 80\n   590→        ) {\n   591→          merged += \" \" + next.text;\n   592→          j++;\n   593→        } else {\n   594→          break;\n   595→        }\n   596→      }\n   597→      if (j > ci + 1) {\n   598→        capsCoalesced.push({ text: merged, index: startIndex });\n   599→        ci = j;\n   600→        continue;\n   601→      }\n   602→    }\n   603→    capsCoalesced.push(line);\n   604→    ci++;\n   605→  }\n   606→\n   607→  // Pre-merge continuation lines: a line starting with /&+:( is never a standalone title.\n   608→  // Merge it into the preceding line so the complete title enters the pool as a single candidate,\n   609→  // avoiding the fragile chain of conditions required by the downstream join survival logic.\n   610→  // Limitation: only one continuation line per preceding line is merged. Titles split across\n   611→  // three or more lines with continuation tokens (rare in practice) are not handled here —\n   612→  // the downstream 2-line and 3-line join candidates cover those cases instead.\n   613→  const mergedLines: Array<{ text: string; index: number }> = [];\n   614→  for (let i = 0; i < capsCoalesced.length; i++) {\n   615→    const line = capsCoalesced[i];\n   616→    if (i + 1 < capsCoalesced.length) {\n   617→      const nextText = capsCoalesced[i + 1].text;\n   618→      if (/^[/&+:(]/.test(nextText)) {\n   619→        mergedLines.push({ text: `${line.text} ${nextText}`, index: line.index });\n   620→        i++;\n   621→        continue;\n   622→      }\n   623→    }\n   624→    mergedLines.push(line);\n   625→  }\n   626→\n   627→  const candidates: Array<{ text: string; position: number; origin: CandidateOrigin }> = [];\n   628→  const seen = new Set<string>();\n   629→\n   630→  // Build a set of positions to skip: short ALL_CAPS lines immediately following metadata\n   631→  const metadataContinuationPositions = new Set<number>();\n   632→  for (let i = 0; i < mergedLines.length - 1; i++) {\n   633→    if (looksLikeMetadata(mergedLines[i].text)) {\n   634→      const next = mergedLines[i + 1];\n   635→      if (isAllCaps(next.text) && wordCount(next.text) <= 2 && next.text.length <= 15) {\n   636→        metadataContinuationPositions.add(next.index);\n   637→      }\n   638→    }\n   639→  }\n   640→\n   641→  for (let i = 0; i < mergedLines.length; i++) {\n   642→    const line = mergedLines[i];\n   643→\n   644→    // Skip metadata continuation fragments\n   645→    if (metadataContinuationPositions.has(line.index)) continue;\n   646→\n   647→    // Single line — strip page-number prefixes and parenthetical glosses before scoring\n   648→    const singleText = repairOcrText(stripParentheticalGloss(stripPageNumber(line.text)));\n   649→    if (passesHardFilters(singleText)) {\n   650→      const norm = singleText.toLowerCase();\n   651→      if (!seen.has(norm)) {\n   652→        seen.add(norm);\n   653→        candidates.push({ text: singleText, position: line.index, origin: \"single\" });\n   654→      }\n   655→    }\n   656→\n   657→    // 2-line join — skip if first line is a section label AND join would be