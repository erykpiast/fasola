{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VuztuUjvWfbFxj6jKb6dgw","type":"tool_result","content":"     1→import {\n     2→  extractTitle,\n     3→  extractTitleWithEmbeddings,\n     4→  _resetEmbeddingCacheForTests,\n     5→} from \"../title-extractor\";\n     6→\n     7→/**\n     8→ * Creates a mock embed function that returns predictable vectors.\n     9→ * Words matching titleWords get a vector pointing \"toward titles\",\n    10→ * words matching headerWords get a vector pointing \"toward headers\",\n    11→ * and everything else gets a neutral vector.\n    12→ */\n    13→function createMockEmbed(\n    14→  titleWords: Array<string>,\n    15→  headerWords: Array<string>\n    16→): (text: string) => Promise<Array<number>> {\n    17→  // Reference phrases from the module\n    18→  const TITLE_REF =\n    19→    \"recipe name, dish title, name of the food, nazwa przepisu, nazwa dania\";\n    20→  const HEADER_REF =\n    21→    \"ingredients list, cooking directions, section heading, składniki, przygotowanie, sposób wykonania\";\n    22→  const NOISE_REF =\n    23→    \"page number, table of contents, book footer, garbled text\";\n    24→\n    25→  return async (text: string): Promise<Array<number>> => {\n    26→    const lower = text.toLowerCase();\n    27→\n    28→    // Title reference → unit vector in dimension 0\n    29→    if (lower === TITLE_REF.toLowerCase()) {\n    30→      return [1, 0, 0];\n    31→    }\n    32→    // Header reference → unit vector in dimension 1\n    33→    if (lower === HEADER_REF.toLowerCase()) {\n    34→      return [0, 1, 0];\n    35→    }\n    36→    // Noise reference → unit vector in dimension 2 (orthogonal)\n    37→    if (lower === NOISE_REF.toLowerCase()) {\n    38→      return [0, 0, 1];\n    39→    }\n    40→\n    41→    // Check if text contains title-like words → high cosine with title ref\n    42→    const isTitle = titleWords.some((w) => lower.includes(w.toLowerCase()));\n    43→    // Check if text contains header-like words → high cosine with header ref\n    44→    const isHeader = headerWords.some((w) => lower.includes(w.toLowerCase()));\n    45→\n    46→    if (isTitle && !isHeader) {\n    47→      return [0.9, 0.1, 0]; // High title similarity, low header similarity\n    48→    }\n    49→    if (isHeader && !isTitle) {\n    50→      return [0.1, 0.9, 0]; // Low title similarity, high header similarity\n    51→    }\n    52→    if (isTitle && isHeader) {\n    53→      return [0.5, 0.5, 0]; // Ambiguous\n    54→    }\n    55→    // Neutral\n    56→    return [0.3, 0.3, 0.7];\n    57→  };\n    58→}\n    59→\n    60→describe(\"extractTitle (heuristic)\", () => {\n    61→  it(\"returns undefined for empty text\", () => {\n    62→    expect(extractTitle(\"\")).toBeUndefined();\n    63→    expect(extractTitle(\"  \")).toBeUndefined();\n    64→  });\n    65→\n    66→  it(\"returns the first valid line\", () => {\n    67→    expect(extractTitle(\"Chicken Soup\\nIngredients\\n1 cup water\")).toBe(\n    68→      \"Chicken Soup\"\n    69→    );\n    70→  });\n    71→\n    72→  it(\"skips lines that are too short or too long\", () => {\n    73→    const longLine = \"A\".repeat(51);\n    74→    expect(extractTitle(`ab\\n${longLine}\\nGood Title`)).toBe(\"Good Title\");\n    75→  });\n    76→\n    77→  it(\"skips ingredient lines\", () => {\n    78→    expect(extractTitle(\"2 cups flour\\nApple Pie\")).toBe(\"Apple Pie\");\n    79→  });\n    80→\n    81→  it(\"skips all-caps lines\", () => {\n    82→    expect(extractTitle(\"INGREDIENTS\\nChocolate Cake\")).toBe(\"Chocolate Cake\");\n    83→  });\n    84→\n    85→  it(\"skips lines starting with numbers\", () => {\n    86→    expect(extractTitle(\"12\\nApple Pie\")).toBe(\"Apple Pie\");\n    87→  });\n    88→});\n    89→\n    90→describe(\"extractTitleWithEmbeddings\", () => {\n    91→  beforeEach(() => {\n    92→    _resetEmbeddingCacheForTests();\n    93→  });\n    94→\n    95→  it(\"returns undefined for empty text\", async () => {\n    96→    const embed = createMockEmbed([], []);\n    97→    expect(await extractTitleWithEmbeddings(\"\", embed)).toBeUndefined();\n    98→    expect(await extractTitleWithEmbeddings(\"  \", embed)).toBeUndefined();\n    99→  });\n   100→\n   101→  it(\"picks title over section header (Polish)\", async () => {\n   102→    const embed = createMockEmbed([\"pierogi ruskie\"], [\"składniki\"]);\n   103→    const text = \"Składniki\\nPierogi Ruskie\\n200g mąki\\n3 ziemniaki\";\n   104→    const result = await extractTitleWithEmbeddings(text, embed);\n   105→    expect(result).toBe(\"Pierogi Ruskie\");\n   106→  });\n   107→\n   108→  it(\"picks title over section header (English)\", async () => {\n   109→    const embed = createMockEmbed([\"chicken soup\"], [\"ingredients\"]);\n   110→    const text = \"Ingredients\\nChicken Soup\\n1 cup water\\nSalt\";\n   111→    const result = await extractTitleWithEmbeddings(text, embed);\n   112→    expect(result).toBe(\"Chicken Soup\");\n   113→  });\n   114→\n   115→  it(\"preserves all-caps titles\", async () => {\n   116→    const embed = createMockEmbed([\"chocolate cake\"], [\"ingredients\"]);\n   117→    const text = \"CHOCOLATE CAKE\\nIngredients\\n200g flour\";\n   118→    const result = await extractTitleWithEmbeddings(text, embed);\n   119→    expect(result).toBe(\"CHOCOLATE CAKE\");\n   120→  });\n   121→\n   122→  it(\"skips numbered lines\", async () => {\n   123→    const embed = createMockEmbed([\"apple pie\"], []);\n   124→    const text = \"12\\nApple Pie\\nSome instructions\";\n   125→    const result = await extractTitleWithEmbeddings(text, embed);\n   126→    expect(result).toBe(\"Apple Pie\");\n   127→  });\n   128→\n   129→  it(\"joins multi-line title (2 lines)\", async () => {\n   130→    const embed = createMockEmbed(\n   131→      [\"kurczak w sosie śmietanowym z pieczarkami\"],\n   132→      [\"składniki\"]\n   133→    );\n   134→    const text =\n   135→      \"Kurczak w sosie\\nśmietanowym z pieczarkami\\nSkładniki\\n200g kurczaka\";\n   136→    const result = await extractTitleWithEmbeddings(text, embed);\n   137→    expect(result).toBe(\"Kurczak w sosie śmietanowym z pieczarkami\");\n   138→  });\n   139→\n   140→  it(\"joins multi-line title (3 lines)\", async () => {\n   141→    const embed = createMockEmbed(\n   142→      [\"makaron z sosem pomidorowym i bazylią\"],\n   143→      [\"składniki\"]\n   144→    );\n   145→    const text =\n   146→      \"Makaron z sosem\\npomidorowym\\ni bazylią\\nSkładniki\\n300g makaronu\";\n   147→    const result = await extractTitleWithEmbeddings(text, embed);\n   148→    expect(result).toBe(\"Makaron z sosem pomidorowym i bazylią\");\n   149→  });\n   150→\n   151→  it(\"does not over-greedily join title with header\", async () => {\n   152→    const embed = createMockEmbed([\"apple pie\"], [\"ingredients\"]);\n   153→    const text = \"Apple Pie\\nIngredients\\n200g flour\";\n   154→    const result = await extractTitleWithEmbeddings(text, embed);\n   155→    // Should prefer \"Apple Pie\" alone, not \"Apple Pie Ingredients\"\n   156→    expect(result).toBe(\"Apple Pie\");\n   157→  });\n   158→\n   159→  it(\"returns multiple titles joined with + when both score well\", async () => {\n   160→    const embed = createMockEmbed(\n   161→      [\"first recipe\", \"second recipe\"],\n   162→      []\n   163→    );\n   164→    const text = \"First Recipe\\nSecond Recipe\\nSome other text\";\n   165→    const result = await extractTitleWithEmbeddings(text, embed);\n   166→    expect(result).toBe(\"First Recipe + Second Recipe\");\n   167→  });\n   168→\n   169→  it(\"skips burst of short lines at start and finds title after\", async () => {\n   170→    const embed = createMockEmbed([\"beef stew\"], [\"ingredients\"]);\n   171→    // 3+ short garbled lines at start, then real content with a long line\n   172→    const text =\n   173→      \"pg 42\\nA.\\nfoo\\nThis is a longer line that triggers burst end detection\\nBeef Stew\\nIngredients\\n500g beef\";\n   174→    const result = await extractTitleWithEmbeddings(text, embed);\n   175→    expect(result).toBe(\"Beef Stew\");\n   176→  });\n   177→\n   178→  it(\"two titles deep in text returns both joined\", async () => {\n   179→    const embed = createMockEmbed(\n   180→      [\"pasta carbonara\", \"tiramisu classico\"],\n   181→      [\"ingredients\", \"składniki\"]\n   182→    );\n   183→    const text =\n   184→      \"Ingredients\\nPasta Carbonara\\n200g pasta\\n100g guanciale\\nIngredients\\nTiramisu Classico\\n250g mascarpone\";\n   185→    const result = await extractTitleWithEmbeddings(text, embed);\n   186→    expect(result).toBe(\"Pasta Carbonara + Tiramisu Classico\");\n   187→  });\n   188→\n   189→  it(\"single-recipe page still returns one title\", async () => {\n   190→    const embed = createMockEmbed([\"tomato soup\"], [\"ingredients\"]);\n   191→    const text = \"Tomato Soup\\nIngredients\\n4 tomatoes\\n1 cup cream\\nSalt\";\n   192→    const result = await extractTitleWithEmbeddings(text, embed);\n   193→    expect(result).toBe(\"Tomato Soup\");\n   194→  });\n   195→\n   196→  it(\"keeps 2-word ALL_CAPS join over its single-word prefix (ARAYES-type)\", async () => {\n   197→    // \"ARAYES\" alone is 1 word → never qualifies as firstStructuralHeading.\n   198→    // \"ARAYES SHRAK\" qualifies → pre-filter removes \"ARAYES\" so dedup keeps the join.\n   199→    const embed = createMockEmbed([\"arayes\"], [\"ingredients\"]);\n   200→    const text = \"ARAYES\\nSHRAK\\nIngredients\\n2 cups flour\";\n   201→    const result = await extractTitleWithEmbeddings(text, embed);\n   202→    expect(result).toBe(\"ARAYES SHRAK\");\n   203→  });\n   204→\n   205→  it(\"keeps 2-line ALL_CAPS join when suffix is a food-category label (VEGETABLES-type)\", async () => {\n   206→    // \"LEMON HERB ROASTED\" qualifies as a structural heading on its own (3 words ALL_CAPS).\n   207→    // \"LEMON HERB ROASTED VEGETABLES\" is its 2-line join. The dedup shorter-wins rule would\n   208→    // normally drop the join in favour of the shorter prefix — but \"VEGETABLES\" is in\n   209→    // CATEGORY_SECTION_LABELS, so the protection keeps the full joined form.\n   210→    const embed = createMockEmbed([\"lemon herb roasted vegetables\"], [\"ingredients\"]);\n   211→    const text = \"LEMON HERB ROASTED\\nVEGETABLES\\nIngredients\\n2 cups broth\";\n   212→    const result = await extractTitleWithEmbeddings(text, embed);\n   213→    expect(result).toBe(\"LEMON HERB ROASTED VEGETABLES\");\n   214→  });\n   215→\n   216→  it(\"extends ALL_CAPS structural heading when next line starts with continuation token (SAFFRON-type)\", async () => {\n   217→    // \"TITLE FIRST PART\" qualifies as structural heading; continuation upgrades it to the join.\n   218→    // Pre-filter then removes the partial so dedup keeps the complete join.\n   219→    const embed = createMockEmbed([\"title first part\"], [\"ingredients\"]);\n   220→    const text = \"TITLE FIRST PART\\n/ SECOND PART\\nIngredients\\n1 cup flour\";\n   221→    const result = await extractTitleWithEmbeddings(text, embed);\n   222→    expect(result).toBe(\"TITLE FIRST PART / SECOND PART\");\n   223→  });\n   224→\n   225→  it(\"pre-merges continuation line starting with & into preceding line (Baked Eggs type)\", async () => {\n   226→    // \"& Coriander\" starts with & so it's merged into the preceding line before candidate\n   227→    // generation — the complete title enters the pool as a single candidate.\n   228→    const embed = createMockEmbed(\n   229→      [\"baked eggs with feta\"],\n   230→      [\"ingredients\"]\n   231→    );\n   232→    const text =\n   233→      \"Baked Eggs with Feta, Harissa Tomato Sauce\\n& Coriander\\nIngredients\\n2 eggs\";\n   234→    const result = await extractTitleWithEmbeddings(text, embed);\n   235→    expect(result).toBe(\"Baked Eggs with Feta, Harissa Tomato Sauce & Coriander\");\n   236→  });\n   237→\n   238→  it(\"does not pre-merge second line that lacks a continuation character (ARAYES-type safety)\", async () => {\n   239→    // \"SHRAK\" does not start with /&+:( so it is NOT pre-merged.\n   240→    // The existing structural heading join logic handles it instead.\n   241→    const embed = createMockEmbed([\"arayes\"], [\"ingredients\"]);\n   242→    const text = \"ARAYES\\nSHRAK\\nIngredients\\n2 cups flour\";\n   243→    const result = await extractTitleWithEmbeddings(text, embed);\n   244→    expect(result).toBe(\"ARAYES SHRAK\");\n   245→  });\n   246→\n   247→  it(\"returns only the first ALL_CAPS heading when subsequent ALL_CAPS headings are section headers followed by ingredients (CHLEBEK type)\", async () => {\n   248→    // WARZYWA I BOCZEK is immediately followed by ingredient lines (numbers) →\n   249→    // it's a section header, not a second recipe title. Keep only CHLEBEK Z WARZYWAMI I BOCZKIEM.\n   250→    const embed = createMockEmbed(\n   251→      [\"chlebek z warzywami i boczkiem\", \"warzywa i boczek\"],\n   252→      []\n   253→    );\n   254→    const text = [\n   255→      \"CHLEBEK Z WARZYWAMI I BOCZKIEM\",\n   256→      \"WARZYWA I BOCZEK\",\n   257→      \"500 g strączków zielonego groszku\",\n   258→      \"1 żółta papryka\",\n   259→      \"CHLEBEK\",\n   260→      \"500 g mąki\",\n   261→    ].join(\"\\n\");\n   262→    const result = await extractTitleWithEmbeddings(text, embed);\n   263→    expect(result).toBe(\"CHLEBEK Z WARZYWAMI I BOCZKIEM\");\n   264→  });\n   265→\n   266→  it(\"returns both ALL_CAPS titles when headings are NOT followed by ingredient lines (FINNISH-type)\", async () => {\n   267→    // POTATO FLATBREADS is followed by body text, not ingredients →\n   268→    // these are two separate recipe titles on a multi-recipe page.\n   269→    const embed = createMockEmbed(\n   270→      [\"milk flatbreads\", \"potato flatbreads\"],\n   271→      []\n   272→    );\n   273→    const text = [\n   274→      \"MILK FLATBREADS\",\n   275→      \"Mix flour with milk and knead\",\n   276→      \"Cook on a dry skillet\",\n   277→      \"POTATO FLATBREADS\",\n   278→      \"Boil potatoes until tender\",\n   279→      \"Mash well before mixing\",\n   280→    ].join(\"\\n\");\n   281→    const result = await extractTitleWithEmbeddings(text, embed);\n   282→    expect(result).toBe(\"MILK FLATBREADS + POTATO FLATBREADS\");\n   283→  });\n   284→\n   285→  it(\"filters bullet-list lines so real title wins\", async () => {\n   286→    const embed = createMockEmbed([\"mozzarella sticks\"], []);\n   287→    const text = \"MOZZARELLA STICKS\\n- 2 tbsp sugar\\n- Salt to taste\";\n   288→    const result = await extractTitleWithEmbeddings(text, embed);\n   289→    expect(result).toBe(\"MOZZARELLA STICKS\");\n   290→  });\n   291→\n   292→  it(\"filters INGREDIENTS section label so real ALL_CAPS title wins\", async () => {\n   293→    const embed = createMockEmbed([\"mozzarella sticks\"], []);\n   294→    const text = \"INGREDIENTS\\nMOZZARELLA STICKS\\n- 2 tbsp sugar\";\n   295→    const result = await extractTitleWithEmbeddings(text, embed);\n   296→    expect(result).toBe(\"MOZZARELLA STICKS\");\n   297→  });\n   298→\n   299→  it(\"filters compact metric ingredient lines so real title wins\", async () => {\n   300→    const embed = createMockEmbed([\"barszcz czerwony\"], []);\n   301→    const text = \"BARSZCZ CZERWONY\\n100g buraków\\n50ml bulionu\";\n   302→    const result = await extractTitleWithEmbeddings(text, embed);\n   303→    expect(result).toBe(\"BARSZCZ CZERWONY\");\n   304→  });\n   305→\n   306→  it(\"prefers mixed-case title at position 0 over ALL_CAPS subtitle at position 1 (bilingual page)\", async () => {\n   307→    // \"Faszerowana papryka\" is the Polish title at position 0 (mixed-case).\n   308→    // \"PAPRIKA GYERAN-JJIM\" is an ALL_CAPS romanization at position 1 — treated as subtitle.\n   309→    const embed = createMockEmbed(\n   310→      [\"faszerowana papryka\", \"paprika gyeran\"],\n   311→      []\n   312→    );\n   313→    const text =\n   314→      \"Faszerowana papryka\\nPAPRIKA GYERAN-JJIM\\nIngredients\\n200g peppers\";\n   315→    const result = await extractTitleWithEmbeddings(text, embed);\n   316→    expect(result).toBe(\"Faszerowana papryka\");\n   317→  });\n   318→\n   319→  it(\"merges 4 consecutive short ALL_CAPS lines into one title (LABANEH-type)\", async () => {\n   320→    // Each OCR line is ≤2 words and ≤25 chars — the short-caps merge pass coalesces them.\n   321→    const embed = createMockEmbed([\"labaneh\"], []);\n   322→    const text = [\n   323→      \"LABANEH\",\n   324→      \"BALLS\",\n   325→      \"WITH NIGELLA\",\n   326→      \"SEEDS\",\n   327→      \"Essential to blending the flavours together\",\n   328→    ].join(\"\\n\");\n   329→    const result = await extractTitleWithEmbeddings(text, embed);\n   330→    expect(result).toBe(\"LABANEH BALLS WITH NIGELLA SEEDS\");\n   331→  });\n   332→\n   333→  it(\"short-caps merge breaks at a section label, preventing spurious joins\", async () => {\n   334→    // WORD ONE and WORD TWO are short ALL_CAPS, but INGREDIENTS (section label) sits between\n   335→    // them and breaks the run — they should NOT be merged into \"WORD ONE WORD TWO\".\n   336→    const embed = createMockEmbed([\"word one\"], []);\n   337→    const text = [\n   338→      \"WORD ONE\",\n   339→      \"INGREDIENTS\",\n   340→      \"WORD TWO\",\n   341→      \"Some body text here to fill the page\",\n   342→    ].join(\"\\n\");\n   343→    const result = await extractTitleWithEmbeddings(text, embed);\n   344→    // WORD ONE wins (title word); WORD TWO is a separate candidate but scores lower.\n   345→    // The key assertion: no \"WORD ONE INGREDIENTS WORD TWO\" merged result.\n   346→    expect(result).toBe(\"WORD ONE\");\n   347→  });\n   348→\n   349→  it(\"short-caps merge does not fire when a line exceeds 2 words\", async () => {\n   350→    // \"THREE WORD LINE\" has 3 words — above the ≤2 limit — so it is never the start of a merge run.\n   351→    const embed = createMockEmbed([\"three word line\"], []);\n   352→    const text = [\n   353→      \"THREE WORD LINE\",\n   354→      \"ANOTHER LINE\",\n   355→      \"Body text follows here\",\n   356→    ].join(\"\\n\");\n   357→    const result = await extractTitleWithEmbeddings(text, embed);\n   358→    // Candidates are generated individually; no spurious merge of the two lines by the caps pass.\n   359→    // \"THREE WORD LINE ANOTHER LINE\" may appear as a downstream 2-line join candidate but\n   360→    // \"THREE WORD LINE\" wins as the structural heading (more words, higher rawScore from title word).\n   361→    expect(result).toBe(\"THREE WORD LINE\");\n   362→  });\n   363→\n   364→  it(\"filters OCR-corrupted serving size 'DLA & OSOB' so mixed-case title wins\", async () => {\n   365→    // \"DLA & OSOB\" is OCR-corrupted Polish \"DLA 4 OSÓB\" (for 4 people) — metadata, not a title.\n   366→    // The expanded DLA pattern matches even when the digit is corrupted to a symbol.\n   367→    const embed = createMockEmbed([\"smażona zielona fasolka\"], []);\n   368→    const text = [\n   369→      \"Smażona zielona fasolka\",\n   370→      \"DLA & OSOB\",\n   371→      \"200g fasolki\",\n   372→      \"1 cebula\",\n   373→    ].join(\"\\n\");\n   374→    const result = await extractTitleWithEmbeddings(text, embed);\n   375→    expect(result).toBe(\"Smażona zielona fasolka\");\n   376→  });\n   377→\n   378→  it(\"layout-based bilingual detection suppresses ALL_CAPS romanization with no word overlap\", async () => {\n   379→    // Mixed-case title at position 0 (≥2 words) + ALL_CAPS candidate at position 1 with no\n   380→    // words in common → layout guard fires and suppresses the ALL_CAPS candidate.\n   381→    const embed = createMockEmbed([\"mixed case title\", \"all caps different\"], []);\n   382→    const text = [\n   383→      \"Mixed Case Title\",\n   384→      \"ALL CAPS DIFFERENT\",\n   385→      \"Body text that fills the rest of the page\",\n   386→    ].join(\"\\n\");\n   387→    const result = await extractTitleWithEmbeddings(text, embed);\n   388→    expect(result).toBe(\"Mixed Case Title\");\n   389→  });\n   390→\n   391→  describe(\"corroboration (multi-title filtering)\", () => {\n   392→    it(\"rejects orphaned OCR artifact in multi-title assembly\", async () => {\n   393→      // \"DAT FLATBREADS\" is an OCR artifact from a preceding page — \"DAT\" doesn't appear\n   394→      // anywhere else in the document, so it fails the 100% corroboration threshold.\n   395→      // \"FINNISH MILK FLATBREADS\" and \"FINNISH POTATO FLATBREADS\" are both corroborated\n   396→      // by their words appearing in the body text.\n   397→      const embed = createMockEmbed(\n   398→        [\"dat flatbreads\", \"finnish milk flatbreads\", \"finnish potato flatbreads\"],\n   399→        []\n   400→      );\n   401→      const input = [\n   402→        \"2 cup plus 1 tablespoon mixer fried with for 5 minutes\",\n   403→        \"nto a loured work counter shape into ball\",\n   404→        \"DAT FLATBREADS\",\n   405→        \"le Finnish region of Savo bread more like a\",\n   406→        \"\",\n   407→        \"FINNISH MILK FLATBREADS\",\n   408→        \"\",\n   409→        \"These traditional flatbreads are soft and delicious\",\n   410→        \"served warm with butter and milk\",\n   411→        \"500g flour\",\n   412→        \"300ml milk\",\n   413→        \"1 tsp salt\",\n   414→        \"\",\n   415→        \"Mix the flour and milk together until smooth\",\n   416→        \"Let the dough rest for 30 minutes\",\n   417→        \"\",\n   418→        \"FINNISH POTATO FLATBREADS\",\n   419→        \"\",\n   420→        \"Finnish potato flatbreads are hearty and filling\",\n   421→        \"3 large potatoes\",\n   422→        \"200g flour\",\n   423→        \"butter for frying\",\n   424→        \"\",\n   425→        \"Boil the potatoes until tender then mash\",\n   426→        \"Mix mashed potato with flour and salt\",\n   427→      ].join(\"\\n\");\n   428→\n   429→      const result = await extractTitleWithEmbeddings(input, embed);\n   430→      expect(result).toBe(\"FINNISH MILK FLATBREADS + FINNISH POTATO FLATBREADS\");\n   431→    });\n   432→\n   433→    it(\"keeps legitimate multi-recipe titles that are corroborated\", async () => {\n   434→      // Both CHICKEN SOUP and BEEF STEW have their words in the document body,\n   435→      // so both pass corroboration and are returned.\n   436→      const embed = createMockEmbed([\"chicken soup\", \"beef stew\"], []);\n   437→      const input = [\n   438→        \"CHICKEN SOUP\",\n   439→        \"\",\n   440→        \"A classic chicken soup recipe\",\n   441→        \"1 whole chicken\",\n   442→        \"2 carrots\",\n   443→        \"salt and pepper\",\n   444→        \"\",\n   445→        \"Place the chicken in a large pot\",\n   446→        \"\",\n   447→        \"BEEF STEW\",\n   448→        \"\",\n   449→        \"A hearty beef stew for cold days\",\n   450→        \"500g beef chuck\",\n   451→        \"3 potatoes\",\n   452→        \"2 onions\",\n   453→        \"\",\n   454→        \"Cut the beef into cubes\",\n   455→      ].join(\"\\n\");\n   456→\n   457→      const result = await extractTitleWithEmbeddings(input, embed);\n   458→      expect(result).toBe(\"CHICKEN SOUP + BEEF STEW\");\n   459→    });\n   460→\n   461→    it(\"does not apply corroboration to single-title pages\", async () => {\n   462→      // Corroboration only runs when ≥2 ALL_CAPS candidates are selected.\n   463→      // A single ALL_CAPS title is returned as-is regardless of vocabulary overlap.\n   464→      const embed = createMockEmbed([\"golonka pieczona\"], []);\n   465→      const input = [\n   466→        \"GOLONKA PIECZONA\",\n   467→        \"\",\n   468→        \"Składniki na 4 porcje\",\n   469→        \"1 kg mięsa\",\n   470→        \"2 cebule\",\n   471→        \"3 ząbki czosnku\",\n   472→        \"\",\n   473→        \"Mięso umyć i osuszyć\",\n   474→        \"Cebulę pokroić w plastry\",\n   475→      ].join(\"\\n\");\n   476→\n   477→      const result = await extractTitleWithEmbeddings(input, embed);\n   478→      expect(result).toBe(\"GOLONKA PIECZONA\");\n   479→    });\n   480→  });\n   481→});\n   482→"}]},"parent_tool_use_id":null,"session_id":"4cf8a7d1-939d-4c00-8b9d-2a05046808fb","uuid":"a131a5bb-1cd2-4ff8-99c5-b77c48dd8f58","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/__tests__/title-extractor.test.ts","content":"import {\n  extractTitle,\n  extractTitleWithEmbeddings,\n  _resetEmbeddingCacheForTests,\n} from \"../title-extractor\";\n\n/**\n * Creates a mock embed function that returns predictable vectors.\n * Words matching titleWords get a vector pointing \"toward titles\",\n * words matching headerWords get a vector pointing \"toward headers\",\n * and everything else gets a neutral vector.\n */\nfunction createMockEmbed(\n  titleWords: Array<string>,\n  headerWords: Array<string>\n): (text: string) => Promise<Array<number>> {\n  // Reference phrases from the module\n  const TITLE_REF =\n    \"recipe name, dish title, name of the food, nazwa przepisu, nazwa dania\";\n  const HEADER_REF =\n    \"ingredients list, cooking directions, section heading, składniki, przygotowanie, sposób wykonania\";\n  const NOISE_REF =\n    \"page number, table of contents, book footer, garbled text\";\n\n  return async (text: string): Promise<Array<number>> => {\n    const lower = text.toLowerCase();\n\n    // Title reference → unit vector in dimension 0\n    if (lower === TITLE_REF.toLowerCase()) {\n      return [1, 0, 0];\n    }\n    // Header reference → unit vector in dimension 1\n    if (lower === HEADER_REF.toLowerCase()) {\n      return [0, 1, 0];\n    }\n    // Noise reference → unit vector in dimension 2 (orthogonal)\n    if (lower === NOISE_REF.toLowerCase()) {\n      return [0, 0, 1];\n    }\n\n    // Check if text contains title-like words → high cosine with title ref\n    const isTitle = titleWords.some((w) => lower.includes(w.toLowerCase()));\n    // Check if text contains header-like words → high cosine with header ref\n    const isHeader = headerWords.some((w) => lower.includes(w.toLowerCase()));\n\n    if (isTitle && !isHeader) {\n      return [0.9, 0.1, 0]; // High title similarity, low header similarity\n    }\n    if (isHeader && !isTitle) {\n      return [0.1, 0.9, 0]; // Low title similarity, high header similarity\n    }\n    if (isTitle && isHeader) {\n      return [0.5, 0.5, 0]; // Ambiguous\n    }\n    // Neutral\n    return [0.3, 0.3, 0.7];\n  };\n}\n\ndescribe(\"extractTitle (heuristic)\", () => {\n  it(\"returns undefined for empty text\", () => {\n    expect(extractTitle(\"\")).toBeUndefined();\n    expect(extractTitle(\"  \")).toBeUndefined();\n  });\n\n  it(\"returns the first valid line\", () => {\n    expect(extractTitle(\"Chicken Soup\\nIngredients\\n1 cup water\")).toBe(\n      \"Chicken Soup\"\n    );\n  });\n\n  it(\"skips lines that are too short or too long\", () => {\n    const longLine = \"A\".repeat(51);\n    expect(extractTitle(`ab\\n${longLine}\\nGood Title`)).toBe(\"Good Title\");\n  });\n\n  it(\"skips ingredient lines\", () => {\n    expect(extractTitle(\"2 cups flour\\nApple Pie\")).toBe(\"Apple Pie\");\n  });\n\n  it(\"skips all-caps lines\", () => {\n    expect(extractTitle(\"INGREDIENTS\\nChocolate Cake\")).toBe(\"Chocolate Cake\");\n  });\n\n  it(\"skips lines starting with numbers\", () => {\n    expect(extractTitle(\"12\\nApple Pie\")).toBe(\"Apple Pie\");\n  });\n});\n\ndescribe(\"extractTitleWithEmbeddings\", () => {\n  beforeEach(() => {\n    _resetEmbeddingCacheForTests();\n  });\n\n  it(\"returns undefined for empty text\", async () => {\n    const embed = createMockEmbed([], []);\n    expect(await extractTitleWithEmbeddings(\"\", embed)).toBeUndefined();\n    expect(await extractTitleWithEmbeddings(\"  \", embed)).toBeUndefined();\n  });\n\n  it(\"picks title over section header (Polish)\", async () => {\n    const embed = createMockEmbed([\"pierogi ruskie\"], [\"składniki\"]);\n    const text = \"Składniki\\nPierogi Ruskie\\n200g mąki\\n3 ziemniaki\";\n    const result = await extractTitleWithEmbeddings(text, embed);\n    expect(result).toBe(\"Pierogi Ruskie\");\n  });\n\n  it(\"picks title over section header (English)\", async () => {\n    const embed = createMockEmbed([\"chicken soup\"], [\"ingredients\"]);\n    const text = \"Ingredients\\nChicken Soup\\n1 cup water\\nSalt\";\n    const result = await extractTitleWithEmbeddings(text, embed);\n    expect(result).toBe(\"Chicken Soup\");\n  });\n\n  it(\"preserves all-caps titles\", async () => {\n    const embed = createMockEmbed([\"chocolate cake\"], [\"ingredients\"]);\n    const text = \"CHOCOLATE CAKE\\nIngredients\\n200g flour\";\n    const result = await extractTitleWithEmbeddings(text, embed);\n    expect(result).toBe(\"CHOCOLATE CAKE\");\n  });\n\n  it(\"skips numbered lines\", async () => {\n    const embed = createMockEmbed([\"apple pie\"], []);\n    const text = \"12\\nApple Pie\\nSome instructions\";\n    const result = await extractTitleWithEmbeddings(text, embed);\n    expect(result).toBe(\"Apple Pie\");\n  });\n\n  it(\"joins multi-line title (2 lines)\", async () => {\n    const embed = createMockEmbed(\n      [\"kurczak w sosie śmietanowym z pieczarkami\"],\n      [\"składniki\"]\n    );\n    const text =\n      \"Kurczak w sosie\\nśmietanowym z pieczarkami\\nSkładniki\\n200g kurczaka\";\n    const result = await extractTitleWithEmbeddings(text, embed);\n    expect(result).toBe(\"Kurczak w sosie śmietanowym z pieczarkami\");\n  });\n\n  it(\"joins multi-line title (3 lines)\", async () => {\n    const embed = createMockEmbed(\n      [\"makaron z sosem pomidorowym i bazylią\"],\n      [\"składniki\"]\n    );\n    const text =\n      \"Makaron z sosem\\npomidorowym\\ni bazylią\\nSkładniki\\n300g makaronu\";\n    const result = await extractTitleWithEmbeddings(text, embed);\n    expect(result).toBe(\"Makaron z sosem pomidorowym i bazylią\");\n  });\n\n  it(\"does not over-greedily join title with header\", async () => {\n    const embed = createMockEmbed([\"apple pie\"], [\"ingredients\"]);\n    const text = \"Apple Pie\\nIngredients\\n200g flour\";\n    const result = await extractTitleWithEmbeddings(text, embed);\n    // Should prefer \"Apple Pie\" alone, not \"Apple Pie Ingredients\"\n    expect(result).toBe(\"Apple Pie\");\n  });\n\n  it(\"returns multiple titles joined with + when both score well\", async () => {\n    const embed = createMockEmbed(\n      [\"first recipe\", \"second recipe\"],\n      []\n    );\n    const text = \"First Recipe\\nSecond Recipe\\nSome other text\";\n    const result = await extractTitleWithEmbeddings(text, embed);\n    expect(result).toBe(\"First Recipe + Second Recipe\");\n  });\n\n  it(\"skips burst of short lines at start and finds title after\", async () => {\n    const embed = createMockEmbed([\"beef stew\"], [\"ingredients\"]);\n    // 3+ short garbled lines at start, then real content with a long line\n    const text =\n      \"pg 42\\nA.\\nfoo\\nThis is a longer line that triggers burst end detection\\nBeef Stew\\nIngredients\\n500g beef\";\n    const result = await extractTitleWithEmbeddings(text, embed);\n    expect(result).toBe(\"Beef Stew\");\n  });\n\n  it(\"two titles deep in text returns both joined\", async () => {\n    const embed = createMockEmbed(\n      [\"pasta carbonara\", \"tiramisu classico\"],\n      [\"ingredients\", \"składniki\"]\n    );\n    const text =\n      \"Ingredients\\nPasta Carbonara\\n200g pasta\\n100g guanciale\\nIngredients\\nTiramisu Classico\\n250g mascarpone\";\n    const result = await extractTitleWithEmbeddings(text, embed);\n    expect(result).toBe(\"Pasta Carbonara + Tiramisu Classico\");\n  });\n\n  it(\"single-recipe page still returns one title\", async () => {\n    const embed = createMockEmbed([\"tomato soup\"], [\"ingredients\"]);\n    const text = \"Tomato Soup\\nIngredients\\n4 tomatoes\\n1 cup cream\\nSalt\";\n    const result = await extractTitleWithEmbeddings(text, embed);\n    expect(result).toBe(\"Tomato Soup\");\n  });\n\n  it(\"keeps 2-word ALL_CAPS join over its single-word prefix (ARAYES-type)\", async () => {\n    // \"ARAYES\" alone is 1 word → never qualifies as firstStructuralHeading.\n    // \"ARAYES SHRAK\" qualifies → pre-filter removes \"ARAYES\" so dedup keeps the join.\n    const embed = createMockEmbed([\"arayes\"], [\"ingredients\"]);\n    const text = \"ARAYES\\nSHRAK\\nIngredients\\n2 cups flour\";\n    const result = await extractTitleWithEmbeddings(text, embed);\n    expect(result).toBe(\"ARAYES SHRAK\");\n  });\n\n  it(\"keeps 2-line ALL_CAPS join when suffix is a food-category label (VEGETABLES-type)\", async () => {\n    // \"LEMON HERB ROASTED\" qualifies as a structural heading on its own (3 words ALL_CAPS).\n    // \"LEMON HERB ROASTED VEGETABLES\" is its 2-line join. The dedup shorter-wins rule would\n    // normally drop the join in favour of the shorter prefix — but \"VEGETABLES\" is in\n    // CATEGORY_SECTION_LABELS, so the protection keeps the full joined form.\n    const embed = createMockEmbed([\"lemon herb roasted vegetables\"], [\"ingredients\"]);\n    const text = \"LEMON HERB ROASTED\\nVEGETABLES\\nIngredients\\n2 cups broth\";\n    const result = await extractTitleWithEmbeddings(text, embed);\n    expect(result).toBe(\"LEMON HERB ROASTED VEGETABLES\");\n  });\n\n  it(\"extends ALL_CAPS structural heading when next line starts with continuation token (SAFFRON-type)\", async () => {\n    // \"TITLE FIRST PART\" qualifies as structural heading; continuation upgrades it to the join.\n    // Pre-filter then removes the partial so dedup keeps the complete join.\n    const embed = createMockEmbed([\"title first part\"], [\"ingredients\"]);\n    const text = \"TITLE FIRST PART\\n/ SECOND PART\\nIngredients\\n1 cup flour\";\n    const result = await extractTitleWithEmbeddings(text, embed);\n    expect(result).toBe(\"TITLE FIRST PART / SECOND PART\");\n  });\n\n  it(\"pre-merges continuation line starting with & into preceding line (Baked Eggs type)\", async () => {\n    // \"& Coriander\" starts with & so it's merged into the preceding line before candidate\n    // generation — the complete title enters the pool as a single candidate.\n    const embed = createMockEmbed(\n      [\"baked eggs with feta\"],\n      [\"ingredients\"]\n    );\n    const text =\n      \"Baked Eggs with Feta, Harissa Tomato Sauce\\n& Coriander\\nIngredients\\n2 eggs\";\n    const result = await extractTitleWithEmbeddings(text, embed);\n    expect(result).toBe(\"Baked Eggs with Feta, Harissa Tomato Sauce & Coriander\");\n  });\n\n  it(\"does not pre-merge second line that lacks a continuation character (ARAYES-type safety)\", async () => {\n    // \"SHRAK\" does not start with /&+:( so it is NOT pre-merged.\n    // The existing structural heading join logic handles it instead.\n    const embed = createMockEmbed([\"arayes\"], [\"ingredients\"]);\n    const text = \"ARAYES\\nSHRAK\\nIngredients\\n2 cups flour\";\n    const result = await extractTitleWithEmbeddings(text, embed);\n    expect(result).toBe(\"ARAYES SHRAK\");\n  });\n\n  it(\"returns only the first ALL_CAPS heading when subsequent ALL_CAPS headings are section headers followed by ingredients (CHLEBEK type)\", async () => {\n    // WARZYWA I BOCZEK is immediately followed by ingredient lines (numbers) →\n    // it's a section header, not a second recipe title. Keep only CHLEBEK Z WARZYWAMI I BOCZKIEM.\n    const embed = createMockEmbed(\n      [\"chlebek z warzywami i boczkiem\", \"warzywa i boczek\"],\n      []\n    );\n    const text = [\n      \"CHLEBEK Z WARZYWAMI I BOCZKIEM\",\n      \"WARZYWA I BOCZEK\",\n      \"500 g strączków zielonego groszku\",\n      \"1 żółta papryka\",\n      \"CHLEBEK\",\n      \"500 g mąki\",\n    ].join(\"\\n\");\n    const result = await extractTitleWithEmbeddings(text, embed);\n    expect(result).toBe(\"CHLEBEK Z WARZYWAMI I BOCZKIEM\");\n  });\n\n  it(\"returns both ALL_CAPS titles when headings are NOT followed by ingredient lines (FINNISH-type)\", async () => {\n    // POTATO FLATBREADS is followed by body text, not ingredients →\n    // these are two separate recipe titles on a multi-recipe page.\n    const embed = createMockEmbed(\n      [\"milk flatbreads\", \"potato flatbreads\"],\n      []\n    );\n    const text = [\n      \"MILK FLATBREADS\",\n      \"Mix flour with milk and knead\",\n      \"Cook on a dry skillet\",\n      \"POTATO FLATBREADS\",\n      \"Boil potatoes until tender\",\n      \"Mash well before mixing\",\n    ].join(\"\\n\");\n    const result = await extractTitleWithEmbeddings(text, embed);\n    expect(result).toBe(\"MILK FLATBREADS + POTATO FLATBREADS\");\n  });\n\n  it(\"filters bullet-list lines so real title wins\", async () => {\n    const embed = createMockEmbed([\"mozzarella sticks\"], []);\n    const text = \"MOZZARELLA STICKS\\n- 2 tbsp sugar\\n- Salt to taste\";\n    const result = await extractTitleWithEmbeddings(text, embed);\n    expect(result).toBe(\"MOZZARELLA STICKS\");\n  });\n\n  it(\"filters INGREDIENTS section label so real ALL_CAPS title wins\", async () => {\n    const embed = createMockEmbed([\"mozzarella sticks\"], []);\n    const text = \"INGREDIENTS\\nMOZZARELLA STICKS\\n- 2 tbsp sugar\";\n    const result = await extractTitleWithEmbeddings(text, embed);\n    expect(result).toBe(\"MOZZARELLA STICKS\");\n  });\n\n  it(\"filters compact metric ingredient lines so real title wins\", async () => {\n    const embed = createMockEmbed([\"barszcz czerwony\"], []);\n    const text = \"BARSZCZ CZERWONY\\n100g buraków\\n50ml bulionu\";\n    const result = await extractTitleWithEmbeddings(text, embed);\n    expect(result).toBe(\"BARSZCZ CZERWONY\");\n  });\n\n  it(\"prefers mixed-case title at position 0 over ALL_CAPS subtitle at position 1 (bilingual page)\", async () => {\n    // \"Faszerowana papryka\" is the Polish title at position 0 (mixed-case).\n    // \"PAPRIKA GYERAN-JJIM\" is an ALL_CAPS romanization at position 1 — treated as subtitle.\n    const embed = createMockEmbed(\n      [\"faszerowana papryka\", \"paprika gyeran\"],\n      []\n    );\n    const text =\n      \"Faszerowana papryka\\nPAPRIKA GYERAN-JJIM\\nIngredients\\n200g peppers\";\n    const result = await extractTitleWithEmbeddings(text, embed);\n    expect(result).toBe(\"Faszerowana papryka\");\n  });\n\n  it(\"merges 4 consecutive short ALL_CAPS lines into one title (LABANEH-type)\", async () => {\n    // Each OCR line is ≤2 words and ≤25 chars — the short-caps merge pass coalesces them.\n    const embed = createMockEmbed([\"labaneh\"], []);\n    const text = [\n      \"LABANEH\",\n      \"BALLS\",\n      \"WITH NIGELLA\",\n      \"SEEDS\",\n      \"Essential to blending the flavours together\",\n    ].join(\"\\n\");\n    const result = await extractTitleWithEmbeddings(text, embed);\n    expect(result).toBe(\"LABANEH BALLS WITH NIGELLA SEEDS\");\n  });\n\n  it(\"short-caps merge breaks at a section label, preventing spurious joins\", async () => {\n    // WORD ONE and WORD TWO are short ALL_CAPS, but INGREDIENTS (section label) sits between\n    // them and breaks the run — they should NOT be merged into \"WORD ONE WORD TWO\".\n    const embed = createMockEmbed([\"word one\"], []);\n    const text = [\n      \"WORD ONE\",\n      \"INGREDIENTS\",\n      \"WORD TWO\",\n      \"Some body text here to fill the page\",\n    ].join(\"\\n\");\n    const result = await extractTitleWithEmbeddings(text, embed);\n    // WORD ONE wins (title word); WORD TWO is a separate candidate but scores lower.\n    // The key assertion: no \"WORD ONE INGREDIENTS WORD TWO\" merged result.\n    expect(result).toBe(\"WORD ONE\");\n  });\n\n  it(\"short-caps merge does not fire when a line exceeds 2 words\", async () => {\n    // \"THREE WORD LINE\" has 3 words — above the ≤2 limit — so it is never the start of a merge run.\n    const embed = createMockEmbed([\"three word line\"], []);\n    const text = [\n      \"THREE WORD LINE\",\n      \"ANOTHER LINE\",\n      \"Body text follows here\",\n    ].join(\"\\n\");\n    const result = await extractTitleWithEmbeddings(text, embed);\n    // Candidates are generated individually; no spurious merge of the two lines by the caps pass.\n    // \"THREE WORD LINE ANOTHER LINE\" may appear as a downstream 2-line join candidate but\n    // \"THREE WORD LINE\" wins as the structural heading (more words, higher rawScore from title word).\n    expect(result).toBe(\"THREE WORD LINE\");\n  });\n\n  it(\"filters OCR-corrupted serving size 'DLA & OSOB' so mixed-case title wins\", async () => {\n    // \"DLA & OSOB\" is OCR-corrupted Polish \"DLA 4 OSÓB\" (for 4 people) — metadata, not a title.\n    // The expanded DLA pattern matches even when the digit is corrupted to a symbol.\n    const embed = createMockEmbed([\"smażona zielona fasolka\"], []);\n    const text = [\n      \"Smażona zielona fasolka\",\n      \"DLA & OSOB\",\n      \"200g fasolki\",\n      \"1 cebula\",\n    ].join(\"\\n\");\n    const result = await extractTitleWithEmbeddings(text, embed);\n    expect(result).toBe(\"Smażona zielona fasolka\");\n  });\n\n  it(\"layout-based bilingual detection suppresses ALL_CAPS romanization with no word overlap\", async () => {\n    // Mixed-case title at position 0 (≥2 words) + ALL_CAPS candidate at position 1 with no\n    // words in common → layout guard fires and suppresses the ALL_CAPS candidate.\n    const embed = createMockEmbed([\"mixed case title\", \"all caps different\"], []);\n    const text = [\n      \"Mixed Case Title\",\n      \"ALL CAPS DIFFERENT\",\n      \"Body text that fills the rest of the page\",\n    ].join(\"\\n\");\n    const result = await extractTitleWithEmbeddings(text, embed);\n    expect(result).toBe(\"Mixed Case Title\");\n  });\n\n  describe(\"corroboration (multi-title filtering)\", () => {\n    it(\"rejects orphaned OCR artifact in multi-title assembly\", async () => {\n      // \"DAT FLATBREADS\" is an OCR artifact from a preceding page — \"DAT\" doesn't appear\n      // anywhere else in the document, so it fails the 100% corroboration threshold.\n      // \"FINNISH MILK FLATBREADS\" and \"FINNISH POTATO FLATBREADS\" are both corroborated\n      // by their words appearing in the body text.\n      const embed = createMockEmbed(\n        [\"dat flatbreads\", \"finnish milk flatbreads\", \"finnish potato flatbreads\"],\n        []\n      );\n      const input = [\n        \"2 cup plus 1 tablespoon mixer fried with for 5 minutes\",\n        \"nto a loured work counter shape into ball\",\n        \"DAT FLATBREADS\",\n        \"le Finnish region of Savo bread more like a\",\n        \"\",\n        \"FINNISH MILK FLATBREADS\",\n        \"\",\n        \"These traditional flatbreads are soft and delicious\",\n        \"served warm with butter and milk\",\n        \"500g flour\",\n        \"300ml milk\",\n        \"1 tsp salt\",\n        \"\",\n        \"Mix the flour and milk together until smooth\",\n        \"Let the dough rest for 30 minutes\",\n        \"\",\n        \"FINNISH POTATO FLATBREADS\",\n        \"\",\n        \"Finnish potato flatbreads are hearty and filling\",\n        \"3 large potatoes\",\n        \"200g flour\",\n        \"butter for frying\",\n        \"\",\n        \"Boil the potatoes until tender then mash\",\n        \"Mix mashed potato with flour and salt\",\n      ].join(\"\\n\");\n\n      const result = await extractTitleWithEmbeddings(input, embed);\n      expect(result).toBe(\"FINNISH MILK FLATBREADS + FINNISH POTATO FLATBREADS\");\n    });\n\n    it(\"keeps legitimate multi-recipe titles that are corroborated\", async () => {\n      // Both CHICKEN SOUP and BEEF STEW have their words in the document body,\n      // so both pass corroboration and are returned.\n      const embed = createMockEmbed([\"chicken soup\", \"beef stew\"], []);\n      const input = [\n        \"CHICKEN SOUP\",\n        \"\",\n        \"A classic chicken soup recipe\",\n        \"1 whole chicken\",\n        \"2 carrots\",\n        \"salt and pepper\",\n        \"\",\n        \"Place the chicken in a large pot\",\n        \"\",\n        \"BEEF STEW\",\n        \"\",\n        \"A hearty beef stew for cold days\",\n        \"500g beef chuck\",\n        \"3 potatoes\",\n        \"2 onions\",\n        \"\",\n        \"Cut the beef into cubes\",\n      ].join(\"\\n\");\n\n      const result = await extractTitleWithEmbeddings(input, embed);\n      expect(result).toBe(\"CHICKEN SOUP + BEEF STEW\");\n    });\n\n    it(\"does not apply corroboration to single-title pages\", async () => {\n      // Corroboration only runs when ≥2 ALL_CAPS candidates are selected.\n      // A single ALL_CAPS title is returned as-is regardless of vocabulary overlap.\n      const embed = createMockEmbed([\"golonka pieczona\"], []);\n      const input = [\n        \"GOLONKA PIECZONA\",\n        \"\",\n        \"Składniki na 4 porcje\",\n        \"1 kg mięsa\",\n        \"2 cebule\",\n        \"3 ząbki czosnku\",\n        \"\",\n        \"Mięso umyć i osuszyć\",\n        \"Cebulę pokroić w plastry\",\n      ].join(\"\\n\");\n\n      const result = await extractTitleWithEmbeddings(input, embed);\n      expect(result).toBe(\"GOLONKA PIECZONA\");\n    });\n  });\n});\n","numLines":482,"startLine":1,"totalLines":482}}}
