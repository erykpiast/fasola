{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YKnkzBrjnzsSo6Y8GpAPSp","type":"tool_result","content":"  1069→  // Direct-successor bonus: when the line immediately before this candidate is a\n  1070→  // section label, metadata, or pipe-separated line, the candidate is very likely\n  1071→  // the title that follows that header. This complements the first-after-preamble\n  1072→  // bonus which requires ALL preceding lines to be filtered — this one fires even\n  1073→  // when earlier non-filtered lines exist. Checked for the top 3 candidates only\n  1074→  // (ci <= 2) to prevent the bonus from firing on random mid-document lines.\n  1075→  for (let ci = 0; ci < scored.length && ci <= 2; ci++) {\n  1076→    const candidate = scored[ci];\n  1077→    if (candidate.position > 0) {\n  1078→      const prevLine = lines[candidate.position - 1]?.trim() ?? \"\";\n  1079→      const prevIsHeader =\n  1080→        isSectionLabel(prevLine) ||\n  1081→        looksLikeMetadata(prevLine) ||\n  1082→        prevLine.includes(\" | \");\n  1083→      if (prevIsHeader) {\n  1084→        candidate.score += 0.10;\n  1085→        candidate.baseScore += 0.10;\n  1086→        candidate.thresholdScore += 0.10;\n  1087→      }\n  1088→    }\n  1089→  }\n  1090→\n  1091→  // Cap combined positional boost (position factor + first-after-preamble + direct-successor)\n  1092→  // to avoid over-boosting when multiple bonuses fire together. Applied after all positional\n  1093→  // bonuses so the cap covers all of them (per improvement plan: shared +0.15 max).\n  1094→  const maxPositionalBoost = 0.15;\n  1095→  const totalPositionalBoost = firstCandidate.score - baseScoreBeforePositionalBonuses;\n  1096→  if (totalPositionalBoost > maxPositionalBoost) {\n  1097→    const excess = totalPositionalBoost - maxPositionalBoost;\n  1098→    firstCandidate.score -= excess;"}]},"parent_tool_use_id":"toolu_01CBchhnYE5Ks69HxHXqB1Py","session_id":"e11d10e0-5bff-40d6-8c5d-c73d1c