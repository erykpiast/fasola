{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01StWQ7b552Qwo52Xg2Z71Gs","type":"tool_result","content":"   431→function findBurstEnd(lines: Array<{ text: string }>): number {\n   432→  let i = 0;\n   433→\n   434→  // Skip overflow preambles: blocks introduced by \"PREVIOUS RECIPE OVERFLOW\",\n   435→  // \"PREVIOUS PAGE CONTENT\", \"CORRUPTED SECTION\", etc. that precede the actual recipe.\n   436→  const OVERFLOW_MARKERS = /\\b(PREVIOUS\\s+(RECIPE|PAGE)\\s+(OVERFLOW|CONTENT)|SPILLOVER|CONTINUATION|CORRUPTED\\s+SECTION)\\b/i;\n   437→  let overflowEnd = 0;\n   438→  for (let k = 0; k < lines.length && k < 30; k++) {\n   439→    // Don't re-examine lines already determined to be overflow\n   440→    if (overflowEnd > 0 && k < overflowEnd) continue;\n   441→    if (OVERFLOW_MARKERS.test(lines[k].text)) {\n   442→      // Skip forward past the overflow block to the next visual separator or blank cluster\n   443→      let m = k + 1;\n   444→      let consecutiveBlanks = 0;\n   445→      while (m < lines.length) {\n   446→        const lineText = lines[m].text;\n   447→        // Stop at visual separator\n   448→        if (/^[=\\-]{4,}$/.test(lineText)) {\n   449→          overflowEnd = m + 1;\n   450→          break;\n   451→        }\n   452→        // Track consecutive blank lines\n   453→        if (lineText.trim().length === 0) {\n   454→          consecutiveBlanks++;\n   455→          if (consecutiveBlanks >= 2) {\n   456→            overflowEnd = m + 1;\n   457→            break;\n   458→          }\n   459→        } else {\n   460→          consecutiveBlanks = 0;\n   461→          // Stop at ALL_CAPS line with ≥2 words (likely next recipe heading)\n   462→          if (isAllCaps(lineText) && wordCount(lineText) >= 2) {\n   463→            overflowEnd = m; // Don't skip past the heading itself\n   464→            break;\n   465→          }\n   466→        }\n   467→        m++;\n   468→      }\n   469→      // If we walked to end without finding termination, skip everything we saw\n   470→      if (overflowEnd === 0) overflowEnd = m;\n   471→    }\n   472→  }\n   473→  if (overflowEnd > 0) i = overflowEnd;\n   474→\n   475→  while (i < lines.length && lines[i].text.length < 20 && isLikelyGarbled(lines[i].text) && !isAllCaps(lines[i].text)) {\n   476→    i++;\n   477→  }\n   478→  // Skip long instruction-like prologues: if 3+ consecutive lines look like cooking instructions,\n   479→  // skip them to find the actual title region.\n   480→  if (i === 0) {\n   481→    let j = 0;\n   482→    while (j < lines.length && looksLikeCookingInstruction(lines[j].text)) {\n   483→      j++;\n   484→    }\n   485→    if (j >= 3) {\n   486→      i = j;\n   487→    }\n   488→  }\n   489→  // Skip prose prologues: mid-recipe body text before the actual title.\n   490→  // If 3+ consecutive lines look like running body text (lowercase start, continuation,\n   491→  // or sentence-ending with many words), skip them.\n   492→  if (i === 0) {\n   493→    let j = 0;\n   494→    while (j < lines.length) {\n   495→      const t = lines[j].text;\n   496→      const isBodyText = (\n   497→        /^[a-ząćęłńóśźż]/.test(t) ||\n   498→        t.endsWith(\",\") ||\n   499→        (t.endsWith(\".\") && wordCount(t) > 4)\n   500→      ) && wordCount(t) >= 4;\n   501→      if (isBodyText) j++;\n   502→      else break;\n   503→    }\n   504→    if (j >= 3) i = j;\n   505→  }\n   506→  return i;\n   507→}\n   508→\n   509→function stripParentheticalGloss(text: string): string {\n   510→  // Strip trailing English-gloss parentheticals from ALL_CAPS titles.\n   511→  // e.g. \"PIEROGI RUSKIE (Boiled Dumplings with Potato and Cheese)\" → \"PIEROGI RUSKIE\"\n   512→  // Keep if parenthetical is ALL_CAPS (variation/subtitle in same language).\n   513→  // Keep if both base and paren are mixed-case (both are part of the title).\n   514→  const match = text.match(/^(.+?)\\s*\\(([^)]+)\\)\\s*$/);\n   515→  if (!match) return text;\n   516→  const [, base, paren] = match;\n   517→  if (isAllCaps(paren)) return text;\n   518→  if (!isAllCaps(base) && !isAllCaps(paren)) return text;\n   519→  return base.trim();\n   520→}\n   521→\n   522→function stripPageNumber(text: string): string {\n   523→  // \"34  Berry Jam\" → \"Berry Jam\" (2+ spaces distinguishes from \"2 eggs\")\n   524→  const match = text.match(/^\\d{1,3}\\s{2,}(.+)$/);\n   525→  return match ? match[1] : text;\n   526→}\n   527→\n   528→function wordCount(text: string): number {\n   529→  return text.split(/\\s+/).filter((w) => w.length > 0).length;\n   530→}\n   531→\n   532→/**\n   533→ * Build candidate strings from lines: single lines plus multi-line joins (2-3 consecutive).\n   534→ * Skips initial burst of short garbled lines. Scans all remaining lines. Caps at 25.\n   535→ */\n   536→export type CandidateOrigin = \"single\" | \"2-line\" | \"3-line\";\n   537→\n   538→function buildCandidates(\n   539→  lines: Array<string>\n   540→): { candidates: Array<{ text: string; position: number; origin: CandidateOrigin }>; burstEnd: number } {\n   541→  const nonEmptyLines: Array<{ text: string; index: number }> = [];\n   542→\n   543→  for (let i = 0; i < lines.length; i++) {\n   544→    const trimmed = lines[i].trim();\n   545→    if (trimmed.length > 0) {\n   546→      nonEmptyLines.push({ text: trimmed, index: i });\n   547→    }\n   548→  }\n   549→\n   550→  const burstEnd = findBurstEnd(nonEmptyLines);"}]},"parent_tool_use_id":"toolu_01CBchhnYE5Ks69HxHXqB1Py","session_id":"e11d10e0-5bff-40d6-8c5d-c73d1cbcdcc2","uuid":"111ec189-7280-4e16-8ccf-84eda6c2db9f"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MuRsDzAGyzwzCdGs9p8b3X","type":"tool_result","content":"   370→function isTitleAbsentPage(lines: Array<string>): boolean {\n   371→  const nonEmptyLines = lines.map(l => l.trim()).filter(l => l.length > 0);\n   372→\n   373→  if (nonEmptyLines.length < 3) return false;\n   374→\n   375→  const first3 = nonEmptyLines.slice(0, 3);\n   376→\n   377→  return first3.every(line =>\n   378→    looksLikeIngredient(line) ||\n   379→    looksLikeCookingInstruction(line) ||\n   380→    isBodyProse(line)\n   381→  );\n   382→}\n   383→\n   384→function passesHardFilters(text: string): boolean {\n   385→  if (text.length < 3 || text.length > 80) return false;\n   386→  if (looksLikeIngredient(text)) return false;\n   387→  if (startsWithNumber(text)) return false;\n   388→  if (looksLikeMetadata(text)) return false;\n   389→  if (isLikelyGarbled(text)) return false;"}]},"parent_tool_use_id":"toolu_01CBchhnYE5Ks69HxHXqB1Py","session_id":"e11d10e0-5bff-40d6-8c5d-c73d1cbcdcc2","uuid":"cbb535e4-e8fb-46c3-980f-fa5591ee2ddc"}
