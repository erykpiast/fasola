                       // pinch\n    44→  \"garść\",                               // handful\n    45→  \"opakowanie\", \"opakowania\",            // package(s)\n    46→  \"plasterek\", \"plasterki\",             // slice(s)\n    47→];\n    48→\n    49→/**\n    50→ * Patterns that identify recipe metadata lines (not titles)\n    51→ */\n    52→const METADATA_PATTERNS = [\n    53→  /^(SERVES?|MAKES?|YIELDS?)\\b/i,\n...\n</persisted-output>"}]},"parent_tool_use_id":"toolu_01CBchhnYE5Ks69HxHXqB1Py","session_id":"e11d10e0-5bff-40d6-8c5d-c73d1cbcdcc2","uuid":"65d00de2-7d49-4b35-b9e9-ae12736b7daf"}
