{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VpAr1D9kieFokgkLcnBTcf","type":"tool_result","content":"   190→function isSectionLabel(text: string): boolean {\n   191→  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n   192→  if (SECTION_LABELS.has(normalized)) return true;\n   193→  // OCR variant: leading \"l\" may be OCR-corrupted \"I\" (e.g. \"lngredients\" → \"ingredients\")\n   194→  const ocrNormalized = normalized.replace(/^l/, \"i\");\n   195→  if (ocrNormalized !== normalized && SECTION_LABELS.has(ocrNormalized)) return true;\n   196→  return false;\n   197→}\n   198→\n   199→/**\n   200→ * Recipe-internal section labels that should ALWAYS block multi-line joins,\n   201→ * even when the combined word count is ≥ 3.\n   202→ * Category labels (\"zupy\", \"placki\", etc.) are NOT in this set — they can\n   203→ * legitimately start a multi-word recipe title like \"Zupy Zimowe Warzywne\".\n   204→ */\n   205→const ALWAYS_BLOCK_JOIN_LABELS = new Set([\n   206→  \"ingredients\", \"directions\", \"instructions\", \"method\", \"preparation\",\n   207→  \"steps\", \"notes\", \"tip\", \"tips\", \"variations\", \"variation\",\n   208→  \"garnish\", \"topping\", \"toppings\", \"frosting\", \"filling\",\n   209→  \"serving suggestion\", \"serving suggestions\", \"serving\",\n   210→  \"glaze\", \"instrukcje\", \"uwagi\", \"notatki\", \"podawanie\", \"przechowywanie\",\n   211→  \"skladniki\", \"przygotowanie\", \"sposob przygotowania\", \"sposob wykonania\",\n   212→  \"wykonanie\", \"wskazowki\", \"podpowiedz\", \"warianty\",\n   213→  \"sos\", \"nadzienie\", \"polewa\", \"lukier\", \"ciasto\",\n   214→]);\n   215→\n   216→function isAlwaysBlockJoinLabel(text: string): boolean {\n   217→  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n   218→  return ALWAYS_BLOCK_JOIN_LABELS.has(normalized);\n   219→}\n   220→\n   221→function isAllCaps(line: string): boolean {\n   222→  const letters = line.replace(/[^a-zA-Z]/g, \"\");\n   223→  return letters.length > 0 && letters === letters.toUpperCase();\n   224→}\n   225→\n   226→function looksLikeMetadata(text: string): boolean {\n   227→  return METADATA_PATTERNS.some((pattern) => pattern.test(text.trim()));\n   228→}\n   229→"}]},"parent_tool_use_id":"toolu_01CBchhnYE5Ks69HxHXqB1Py","session_id":"e11d10e0-5bff-40d6-8c5d-c73d1cbcdcc2","uuid":"0b2bcb8e-f182-4828-9cd2-1d3ba04472df"}
