{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BbyiYNTav5KtvT81Q2kqTN","type":"tool_result","content":"   620→        mergedLines.push({ text: `${line.text} ${nextText}`, index: line.index });\n   621→        i++;\n   622→        continue;\n   623→      }\n   624→    }\n   625→    mergedLines.push(line);\n   626→  }\n   627→\n   628→  const candidates: Array<{ text: string; position: number; origin: CandidateOrigin }> = [];\n   629→  const seen = new Set<string>();\n   630→\n   631→  // Build a set of positions to skip: short ALL_CAPS lines immediately following metadata\n   632→  const metadataContinuationPositions = new Set<number>();\n   633→  for (let i = 0; i < mergedLines.length - 1; i++) {\n   634→    if (looksLikeMetadata(mergedLines[i].text)) {\n   635→      const next = mergedLines[i + 1];\n   636→      if (isAllCaps(next.text) && wordCount(next.text) <= 2 && next.text.length <= 15) {\n   637→        metadataContinuationPositions.add(next.index);\n   638→      }\n   639→    }\n   640→  }\n   641→\n   642→  for (let i = 0; i < mergedLines.length; i++) {\n   643→    const line = mergedLines[i];\n   644→\n   645→    // Skip metadata continuation fragments\n   646→    if (metadataContinuationPositions.has(line.index)) continue;\n   647→\n   648→    // Single line — strip page-number prefixes and parenthetical glosses before scoring\n   649→    const singleText = repairOcrText(stripParentheticalGloss(stripPageNumber(line.text)));\n   650→    if (passesHardFilters(singleText)) {\n   651→      const norm = singleText.toLowerCase();\n   652→      if (!seen.has(norm)) {\n   653→        seen.add(norm);\n   654→        candidates.push({ text: singleText, position: line.index, origin: \"single\" });\n   655→      }\n   656→    }\n   657→\n   658→    // Blind OCR repair for early-position candidates: when the original text\n   659→    // has OCR artifacts and is in the first few lines (strong positional evidence),\n   660→    // generate an additional candidate with blind digit→letter repair.\n   661→    // This gives the embedding scorer a clean version even when dictionary repair misses.\n   662→    if (line.index <= 5 && OCR_ARTIFACT_PATTERN.test(line.text)) {\n   663→      const blindRepaired = applyBlindOcrRepair(singleText);\n   664→      if (blindRepaired !== singleText && passesHardFilters(blindRepaired)) {\n   665→        const norm = blindRepaired.toLowerCase();\n   666→        if (!seen.has(norm)) {\n   667→          seen.add(norm);\n   668→          candidates.push({ text: blindRepaired, position: line.index, origin: \"single\" });\n   669→        }\n   670→      }\n   671→    }\n   672→\n   673→    // 2-line join — skip if first line is a section label AND join would be ≤2 words\n   674→    // (a section label followed by modifiers is likely a recipe title, not a category header)\n   675→    if (i + 1 < mergedLines.length) {\n   676→      const joined2 = repairOcrText(`${line.text} ${mergedLines[i + 1].text}`);\n   677→      const shouldBlock2 = isSectionLabel(line.text) &&\n   678→        (wordCount(joined2) <= 2 || isAlwaysBlockJoinLabel(line.text));\n   679→      if (!shouldBlock2 && passesHardFilters(joined2)) {\n   680→        const norm = joined2.toLowerCase();\n   681→        if (!seen.has(norm)) {\n   682→          seen.add(norm);\n   683→          candidates.push({ text: joined2, position: line.index, origin: \"2-line\" });\n   684→        }\n   685→      }\n   686→    }\n   687→\n   688→    // 3-line join — skip if first line is a section label AND join would be ≤2 words\n   689→    if (i + 2 < mergedLines.length) {\n   690→      const joined3 = repairOcrText(`${line.text} ${mergedLines[i + 1].text} ${mergedLines[i + 2].text}`);\n   691→      const shouldBlock3 = isSectionLabel(line.text) &&\n   692→        (wordCount(joined3) <= 2 || isAlwaysBlockJoinLabel(line.text));\n   693→      if (!shouldBlock3 && passesHardFilters(joined3)) {\n   694→        const norm = joined3.toLowerCase();\n   695→        if (!seen.has(norm)) {\n   696→          seen.add(norm);\n   697→          candidates.push({ text: joined3, position: line.index, origin: \"3-line\" });\n   698→        }\n   699→      }\n   700→    }\n   701→  }\n   702→\n   703→  // Pre-filter to 25 before embedding calls: prefer ALL_CAPS and short candidates.\n   704→  // Position-based scoring handles final ranking.\n   705→  if (candidates.length > 25) {\n   706→    const prioritized = candidates.slice().sort((a, b) => {\n   707→      const aAllCaps = isAllCaps(a.text) ? 0 : 1;\n   708→      const bAllCaps = isAllCaps(b.text) ? 0 : 1;\n   709→      if (aAllCaps !== bAllCaps) return aAllCaps - bAllCaps;\n   710→      const aShort = wordCount(a.text) <= 5 ? 0 : 1;\n   711→      const bShort = wordCount(b.text) <= 5 ? 0 : 1;\n   712→      return aShort - bShort;\n   713→    });\n   714→    return { candidates: prioritized.slice(0, 25), burstEnd: nonEmptyLines[burstEnd]?.index ?? 0 };\n   715→  }\n   716→\n   717→  return { candidates, burstEnd: nonEmptyLines[burstEnd]?.index ?? 0 };\n   718→}\n   719→"}]},"parent_tool_use_id":"toolu_01CBchhnYE5Ks69HxHXqB1Py","session_id":"e11d10e0-5bff-40d6-8c5d-c73d1cbcdcc2","uuid":"d3970537-3530-4520-913f-636a2b081aeb"}
