{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013NZ5gzcHBZnqqKBSLBonFA","type":"tool_result","content":"   365→/**\n   366→ * Detect pages where the OCR capture starts mid-recipe with no title present.\n   367→ * Returns true if the first 3 non-empty lines are all ingredients, cooking instructions,\n   368→ * or body prose continuation text.\n   369→ */\n   370→function isTitleAbsentPage(lines: Array<string>): boolean {\n   371→  const nonEmptyLines = lines.map(l => l.trim()).filter(l => l.length > 0);\n   372→\n   373→  if (nonEmptyLines.length < 3) return false;\n   374→\n   375→  const first3 = nonEmptyLines.slice(0, 3);\n   376→\n   377→  return first3.every(line =>\n   378→    looksLikeIngredient(line) ||\n   379→    looksLikeCookingInstruction(line) ||\n   380→    isBodyProse(line)\n   381→  );\n   382→}\n   383→\n   384→function passesHardFilters(text: string): boolean {\n   385→  if (text.length < 3 || text.length > 80) return false;\n   386→  if (looksLikeIngredient(text)) return false;\n   387→  if (startsWithNumber(text)) return false;\n   388→  if (looksLikeMetadata(text)) return false;\n   389→  if (isLikelyGarbled(text)) return false;\n   390→  if (looksLikeCookingInstruction(text)) return false;\n   391→  // Pipe-separated lines are book category/chapter headers, not recipe titles\n   392→  if (text.includes(\" | \")) return false;\n   393→  // Trailing page number (e.g. \"VEGETABLE SIDES                         145\")\n   394→  if (/\\s{3,}\\d{1,4}\\s*$/.test(text)) return false;\n   395→  // Slash-separated breadcrumbs (e.g., \"/ Jesien / Zupy\") are navigation, not titles\n   396→  // Only filter when 2+ slashes are present — single-slash lines like\n   397→  // \"TITLE / SUBTITLE\" are legitimate continuation-merged titles\n   398→  if ((text.match(/\\//g) || []).length >= 2) return false;\n   399→  // Bullet-list items (ingredients or instruction steps) are never titles\n   400→  if (/^\\s*[-•*]\\s/.test(text)) return false;\n   401→  // \"For the sauce:\", \"For the filling:\" etc. are sub-section headers\n   402→  if (/^For the\\s+/i.test(text) && /:\\s*$/.test(text)) return false;\n   403→  // Lines ending with \":\" are recipe sub-section headers, not titles.\n   404→  // Exception: compound titles using \" : \" as a title separator (e.g. \"LEMON CURD : LEMON CURD WITH THYME\").\n   405→  if (/:\\s*$/.test(text.trim()) && !/ : /.test(text)) return false;\n   406→  // Page references are navigation markers, not recipe titles\n   407→  if (/^Page\\s+\\d+/i.test(text.trim())) return false;\n   408→  if (/^Strona\\s+\\d+/i.test(text.trim())) return false;\n   409→  // Corrupted spillover annotations from synthetic multi-page OCR\n   410→  if (/^\\[CORRUPTED\\s+SPILLOVER/i.test(text.trim())) return false;\n   411→  // Parenthetical OCR annotation lines describing corruption artifacts\n   412→  if (/^\\(OCR\\b/i.test(text.trim())) return false;\n   413→  if (/^\\(.*\\bcorruption\\b/i.test(text.trim())) return false;\n   414→  // Square-bracket category tags (e.g., \"[CLASSIC FALL SOUPS]\")\n   415→  if (/^\\[.*\\]$/.test(text.trim())) return false;\n   416→  // Known recipe section labels are structural headers, not titles\n   417→  if (isSectionLabel(text)) return false;\n   418→  // Single-word non-title fragments\n   419→  const words = text.trim().split(/\\s+/);\n   420→  if (words.length === 1 && NON_TITLE_WORDS.has(text.trim().toLowerCase())) return false;\n   421→  // Lines with ≥8 words are almost certainly body text, not titles.\n   422→  // Exception: multi-title compounds with \" + \", \" : \", or \" & \" separators are allowed.\n   423→  if (words.length >= 8 && !/ [+:&/] /.test(text)) return false;\n   424→  return true;\n   425→}\n   426→\n   427→/**\n   428→ * Detect initial burst of short garbled lines.\n   429→ * Returns the index of the first non-garbled or long line."}]},"parent_tool_use_id":null,"session_id":"e11d10e0-5bff-40d6-8c5d-c73d1cbcdcc2","uuid":"b7dc9c41-ac20-44bb-b803-be16ed940cc9","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/title-extractor.ts","content":"/**\n * Detect pages where the OCR capture starts mid-recipe with no title present.\n * Returns true if the first 3 non-empty lines are all ingredients, cooking instructions,\n * or body prose continuation text.\n */\nfunction isTitleAbsentPage(lines: Array<string>): boolean {\n  const nonEmptyLines = lines.map(l => l.trim()).filter(l => l.length > 0);\n\n  if (nonEmptyLines.length < 3) return false;\n\n  const first3 = nonEmptyLines.slice(0, 3);\n\n  return first3.every(line =>\n    looksLikeIngredient(line) ||\n    looksLikeCookingInstruction(line) ||\n    isBodyProse(line)\n  );\n}\n\nfunction passesHardFilters(text: string): boolean {\n  if (text.length < 3 || text.length > 80) return false;\n  if (looksLikeIngredient(text)) return false;\n  if (startsWithNumber(text)) return false;\n  if (looksLikeMetadata(text)) return false;\n  if (isLikelyGarbled(text)) return false;\n  if (looksLikeCookingInstruction(text)) return false;\n  // Pipe-separated lines are book category/chapter headers, not recipe titles\n  if (text.includes(\" | \")) return false;\n  // Trailing page number (e.g. \"VEGETABLE SIDES                         145\")\n  if (/\\s{3,}\\d{1,4}\\s*$/.test(text)) return false;\n  // Slash-separated breadcrumbs (e.g., \"/ Jesien / Zupy\") are navigation, not titles\n  // Only filter when 2+ slashes are present — single-slash lines like\n  // \"TITLE / SUBTITLE\" are legitimate continuation-merged titles\n  if ((text.match(/\\//g) || []).length >= 2) return false;\n  // Bullet-list items (ingredients or instruction steps) are never titles\n  if (/^\\s*[-•*]\\s/.test(text)) return false;\n  // \"For the sauce:\", \"For the filling:\" etc. are sub-section headers\n  if (/^For the\\s+/i.test(text) && /:\\s*$/.test(text)) return false;\n  // Lines ending with \":\" are recipe sub-section headers, not titles.\n  // Exception: compound titles using \" : \" as a title separator (e.g. \"LEMON CURD : LEMON CURD WITH THYME\").\n  if (/:\\s*$/.test(text.trim()) && !/ : /.test(text)) return false;\n  // Page references are navigation markers, not recipe titles\n  if (/^Page\\s+\\d+/i.test(text.trim())) return false;\n  if (/^Strona\\s+\\d+/i.test(text.trim())) return false;\n  // Corrupted spillover annotations from synthetic multi-page OCR\n  if (/^\\[CORRUPTED\\s+SPILLOVER/i.test(text.trim())) return false;\n  // Parenthetical OCR annotation lines describing corruption artifacts\n  if (/^\\(OCR\\b/i.test(text.trim())) return false;\n  if (/^\\(.*\\bcorruption\\b/i.test(text.trim())) return false;\n  // Square-bracket category tags (e.g., \"[CLASSIC FALL SOUPS]\")\n  if (/^\\[.*\\]$/.test(text.trim())) return false;\n  // Known recipe section labels are structural headers, not titles\n  if (isSectionLabel(text)) return false;\n  // Single-word non-title fragments\n  const words = text.trim().split(/\\s+/);\n  if (words.length === 1 && NON_TITLE_WORDS.has(text.trim().toLowerCase())) return false;\n  // Lines with ≥8 words are almost certainly body text, not titles.\n  // Exception: multi-title compounds with \" + \", \" : \", or \" & \" separators are allowed.\n  if (words.length >= 8 && !/ [+:&/] /.test(text)) return false;\n  return true;\n}\n\n/**\n * Detect initial burst of short garbled lines.\n * Returns the index of the first non-garbled or long line.","numLines":65,"startLine":365,"totalLines":1578}}}
