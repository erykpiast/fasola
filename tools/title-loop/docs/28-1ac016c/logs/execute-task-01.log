{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JdqW3Ma5dYoFjG6U99tTFC","type":"tool_result","content":"   855→      .replace(/5(?=[A-ZÀ-Ż])/g, \"S\")\n   856→      .replace(/(?<=[A-ZÀ-Ż])5/g, \"S\")\n   857→      .replace(/¡/g, \"I\")\n   858→      .replace(/€/g, \"E\")\n   859→      .replace(/[ÍÌ]/g, \"I\");\n   860→  }\n   861→  // Mixed-case: fix per-word (digits between lowercase letters)\n   862→  return text.split(/(\\s+)/).map((token) => {\n   863→    if (/^\\s+$/.test(token)) return token;\n   864→    if (isAllCaps(token) && token.length > 1) {\n   865→      return token\n   866→        .replace(/1/g, \"I\")\n   867→        .replace(/0(?=[A-Z])/g, \"O\")\n   868→        .replace(/(?<=[A-Z])0/g, \"O\");\n   869→    }\n   870→    return token\n   871→      .replace(/(?<=[a-zà-ż])1/g, \"l\")\n   872→      .replace(/1(?=[a-zà-ż])/g, \"l\")\n   873→      .replace(/¡/g, \"i\")\n   874→      .replace(/€/g, \"e\");\n   875→  }).join(\"\");\n   876→}\n   877→\n   878→function hasErraticCasing(text: string): boolean {\n   879→  return text.split(/\\s+/).some(word => {\n   880→    if (word.length < 3) return false;\n   881→    if (isAllCaps(word)) return false;\n   882→    const inner = word.slice(1);\n   883→    const upperInner = (inner.match(/[A-ZÀ-Ż]/g) || []).length;\n   884→    const lowerInner = (inner.match(/[a-zà-ż]/g) || []).length;\n   885→    return upperInner >= 2 && upperInner >= lowerInner * 0.3;\n   886→  });\n   887→}\n   888→\n   889→function normalizeErraticCasing(text: string): string {\n   890→  return text.split(/(\\s+)/).map(token => {\n   891→    if (/^\\s+$/.test(token)) return token;\n   892→    if (isAllCaps(token)) return token;\n   893→    if (hasErraticCasing(token)) {\n   894→      return token.charAt(0).toUpperCase() + token.slice(1).toLowerCase();\n   895→    }\n   896→    return token;\n   897→  }).join(\"\");\n   898→}\n   899→\n   900→/**\n   901→ * Generate multiple blind OCR repair variants for embedding