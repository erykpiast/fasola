{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01P8xtF6R5dZZmo9RfQE3od5","type":"tool_result","content":"   185→function isCategorySectionLabel(text: string): boolean {\n   186→  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n   187→  return CATEGORY_SECTION_LABELS.has(normalized);\n   188→}\n   189→\n   190→function isSectionLabel(text: string): boolean {\n   191→  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n   192→  if (SECTION_LABELS.has(normalized)) return true;\n   193→  // OCR variant: leading \"l\" may be OCR-corrupted \"I\" (e.g. \"lngredients\" → \"ingredients\")\n   194→  const ocrNormalized = normalized.replace(/^l/, \"i\");\n   195→  if (ocrNormalized !== normalized && SECTION_LABELS.has(ocrNormalized)) return true;\n   196→  return false;\n   197→}\n   198→\n   199→/**\n   200→ * Recipe-internal section labels that should ALWAYS block multi-line joins,\n   201→ * even when the combined word count is ≥ 3.\n   202→ * Category labels (\"zupy\", \"placki\", etc.) are NOT in this set — they can\n   203→ * legitimately start a multi-word recipe title like \"Zupy Zimowe Warzywne\".\n   204→ */"}]},"parent_tool_use_id":null,"session_id":"7a8a1052-f060-407b-8164-bf7c5f97f8a0","uuid":"6f07fbec-0352-4fbe-b48e-c424a005cc90","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/title-extractor.ts","content":"function isCategorySectionLabel(text: string): boolean {\n  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n  return CATEGORY_SECTION_LABELS.has(normalized);\n}\n\nfunction isSectionLabel(text: string): boolean {\n  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n  if (SECTION_LABELS.has(normalized)) return true;\n  // OCR variant: leading \"l\" may be OCR-corrupted \"I\" (e.g. \"lngredients\" → \"ingredients\")\n  const ocrNormalized = normalized.replace(/^l/, \"i\");\n  if (ocrNormalized !== normalized && SECTION_LABELS.has(ocrNormalized)) return true;\n  return false;\n}\n\n/**\n * Recipe-internal section labels that should ALWAYS block multi-line joins,\n * even when the combined word count is ≥ 3.\n * Category labels (\"zupy\", \"placki\", etc.) are NOT in this set — they can\n * legitimately start a multi-word recipe title like \"Zupy Zimowe Warzywne\".\n */","numLines":20,"startLine":185,"totalLines":1578}}}
