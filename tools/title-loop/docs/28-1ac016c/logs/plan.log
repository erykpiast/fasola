{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WvknepqPxmUX2AwgTFwzpT","type":"tool_result","content":"   400→  if (/^\\s*[-•*]\\s/.test(text)) return false;\n   401→  // \"For the sauce:\", \"For the filling:\" etc. are sub-section headers\n   402→  if (/^For the\\s+/i.test(text) && /:\\s*$/.test(text)) return false;\n   403→  // Lines ending with \":\" are recipe sub-section headers, not titles.\n   404→  // Exception: compound titles using \" : \" as a title separator (e.g. \"LEMON CURD : LEMON CURD WITH THYME\").\n   405→  if (/:\\s*$/.test(text.trim()) && !/ : /.test(text)) return false;\n   406→  // Page references are navigation markers, not recipe titles\n   407→  if (/^Page\\s+\\d+/i.test(text.trim())) return false;\n   408→  if (/^Strona\\s+\\d+/i.test(text.trim())) return false;\n   409→  // Corrupted spillover annotations from synthetic multi-page OCR\n   410→  if (/^\\[CORRUPTED\\s+SPILLOVER/i.test(text.trim())) return false;\n   411→  // Parenthetical OCR annotation lines describing corruption artifacts\n   412→  if (/^\\(OCR\\b/i.test(text.trim())) return false;\n   413→  if (/^\\(.*\\bcorruption\\b/i.test(text.trim())) return false;\n   414→  // Square-bracket category tags (e.g., \"[CLASSIC FALL SOUPS]\")\n   415→  if (/^\\[.*\\]$/.test(text.trim())) return false;\n   416→  // Known recipe section labels are structural headers, not titles\n   417→  if (isSectionLabel(text)) return false;\n   418→  // Single-word non-title fragments\n   419→  const words = text.trim().split(/\\s+/);\n   420→  if (words.length === 1 && NON_TITLE_WORDS.has(text.trim().toLowerCase())) return false;\n   421→  // Lines with ≥8 words are almost certainly body text, not titles.\n   422→  // Exception: multi-title compounds with \" + \", \" : \", or \" & \" separators are allowed.\n   423→  if (words.length >= 8 && !/ [+:&/] /.test(text)) return false;\n   424→  return true;\n   425→}\n   426→\n   427→/**\n   428→ * Detect initial burst of short garbled lines.\n   429→ * Returns the index of the first non-garbled or long line.\n   430→ */\n   431→function findBurstEnd(lines: Array<{ text: string }>): number {\n   432→  let i = 0;\n   433→\n   434→  // Skip overflow preambles: blocks introduced by \"PREVIOUS RECIPE OVERFLOW\",\n   435→  // \"PREVIOUS PAGE CONTENT\", \"CORRUPTED SECTION\", etc. that precede the actual recipe.\n   436→  const OVERFLOW_MARKERS = /\\b(PREVIOUS\\s+(RECIPE|PAGE)\\s+(OVERFLOW|CONTENT)|SPILLOVER|CONTINUATION|CORRUPTED\\s+SECTION)\\b/i;\n   437→  let overflowEnd = 0;\n   438→  for (let k = 0; k < lines.length && k < 30; k++) {\n   439→    // Don't re-examine lines already determined to be overflow\n   440→    if (overflowEnd > 0 && k < overflowEnd) continue;\n   441→    if (OVERFLOW_MARKERS.test(lines[k].text)) {\n   442→      // Skip forward past the overflow block to the next visual separator or blank cluster\n   443→      let m = k + 1;\n   444→      let consecutiveBlanks = 0;\n   445→      while (m < lines.length) {\n   446→        const lineText = lines[m].text;\n   447→        // Stop at visual separator\n   448→        if (/^[=\\-]{4,}$/.test(lineText)) {\n   449→          overflowEnd = m + 1;\n   450→          break;\n   451→        }\n   452→        // Track consecutive blank lines\n   453→        if (lineText.trim().length === 0) {\n   454→          consecutiveBlanks++;\n   455→          if (consecutiveBlanks >= 2) {\n   456→            overflowEnd = m + 1;\n   457→            break;\n   458→          }\n   459→        } else {\n   460→          consecutiveBlanks = 0;\n   461→          // Stop at ALL_CAPS line with ≥2 words (likely next recipe heading)\n   462→          if (isAllCaps(lineText) && wordCount(lineText) >= 2) {\n   463→            overflowEnd = m; // Don't skip past the heading itself\n   464→            break;\n   465→          }\n   466→        }\n   467→        m++;\n   468→      }\n   469→      // If we walked to end without finding termination, skip everything we saw\n   470→      if (overflowEnd === 0) overflowEnd = m;\n   471→    }\n   472→  }\n   473→  if (overflowEnd > 0) i = overflowEnd;\n   474→\n   475→  while (i < lines.length && lines[i].text.length < 20 && isLikelyGarbled(lines[i].text) && !isAllCaps(lines[i].text)) {\n   476→    i++;\n   477→  }\n   478→  // Skip long instruction-like prologues: if 3+ consecutive lines look like cooking instructions,\n   479→  // skip them to find the actual title region.\n   480→  if (i === 0) {\n   481→    let j = 0;\n   482→    while (j < lines.length && looksLikeCookingInstruction(lines[j].text)) {\n   483→      j++;\n   484→    }\n   485→    if (j >= 3) {\n   486→      i = j;\n   487→    }\n   488→  }\n   489→  // Skip prose prologues: mid-recipe body text before the actual title.\n   490→  // If 3+ consecutive lines look like running body text (lowercase start, continuation,\n   491→  // or sentence-ending with many words), skip them.\n   492→  if (i === 0) {\n   493→    let j = 0;\n   494→    while (j < lines.length) {\n   495→      const t = lines[j].text;\n   496→      const isBodyText = (\n   497→        /^[a-ząćęłńóśźż]/.test(t) ||\n   498→        t.endsWith(\",\") ||\n   499→        (t.endsWith(\".\") && wordCount(t) > 4)\n   500→      ) && wordCount(t) >= 4;\n   501→      if (isBodyText) j++;\n   502→      else break;\n   503→    }\n   504→    if (j >= 3) i = j;\n   505→  }\n   506→  return i;\n   507→}\n   508→\n   509→function stripParentheticalGloss(text: string): string {\n   510→  // Strip trailing English-gloss parentheticals from ALL_CAPS titles.\n   511→  // e.g. \"PIEROGI RUSKIE (Boiled Dumplings with Potato and Cheese)\" → \"PIEROGI RUSKIE\"\n   512→  // Keep if parenthetical is ALL_CAPS (variation/subtitle in same language).\n   513→  // Keep if both base and paren are mixed-case (both are part of the title).\n   514→  const match = text.match(/^(.+?)\\s*\\(([^)]+)\\)\\s*$/);\n   515→  if (!match) return text;\n   516→  const [, base, paren] = match;\n   517→  if (isAllCaps(paren)) return text;\n   518→  if (!isAllCaps(base) && !isAllCaps(paren)) return text;\n   519→  return base.trim();\n   520→}\n   521→\n   522→function stripPageNumber(text: string): string {\n   523→  // \"34  Berry Jam\" → \"Berry Jam\" (2+ spaces distinguishes from \"2 eggs\")\n   524→  const match = text.match(/^\\d{1,3}\\s{2,}(.+)$/);\n   525→  return match ? match[1] : text;\n   526→}\n   527→\n   528→function wordCount(text: string): number {\n   529→  return text.split(/\\s+/).filter((w) => w.length > 0).length;\n   530→}\n   531→\n   532→/**\n   533→ * Build candidate strings from lines: single lines plus multi-line joins (2-3 consecutive).\n   534→ * Skips initial burst of short garbled lines. Scans all remaining lines. Caps at 25.\n   535→ */\n   536→export type CandidateOrigin = \"single\" | \"2-line\" | \"3-line\";\n   537→\n   538→function buildCandidates(\n   539→  lines: Array<string>\n   540→): { candidates: Array<{ text: string; position: number; origin: CandidateOrigin }>; burstEnd: number } {\n   541→  const nonEmptyLines: Array<{ text: string; index: number }> = [];\n   542→\n   543→  for (let i = 0; i < lines.length; i++) {\n   544→    const trimmed = lines[i].trim();\n   545→    if (trimmed.length > 0) {\n   546→      nonEmptyLines.push({ text: trimmed, index: i });\n   547→    }\n   548→  }\n   549→\n   550→  const burstEnd = findBurstEnd(nonEmptyLines);\n   551→\n   552→  // Pre-join hyphen-broken lines: \"ROASTED CHICKEN WITH ROOT VEGET-\" + \"ABLES\" → single line.\n   553→  // Only applies within the candidate region (after burst end).\n   554→  for (let hi = burstEnd; hi < nonEmptyLines.length - 1; hi++) {\n   555→    if (nonEmptyLines[hi].text.endsWith(\"-\")) {\n   556→      const joined = nonEmptyLines[hi].text.slice(0, -1) + nonEmptyLines[hi + 1].text;\n   557→      nonEmptyLines[hi] = { text: joined, index: nonEmptyLines[hi].index };\n   558→      nonEmptyLines.splice(hi + 1, 1);\n   559→    }\n   560→  }\n   561→\n   562→  // Pre-merge consecutive short ALL_CAPS lines (OCR-fragmented headings).\n   563→  // When a sequence of 2+ ALL_CAPS lines each has ≤2 words and ≤25 chars, they are\n   564→  // almost certainly OCR fragments of a single heading. Merge them into one line so\n   565→  // the complete title enters the candidate pool without hitting the 3-line join ceiling.\n   566→  const capsCoalesced: Array<{ text: string; index: number }> = [];\n   567→  let ci = burstEnd;\n   568→  while (ci < nonEmptyLines.length) {\n   569→    const line = nonEmptyLines[ci];\n   570→    if (\n   571→      isAllCaps(line.text) &&\n   572→      wordCount(line.text) <= 2 &&\n   573→      line.text.length <= 25 &&\n   574→      !isSectionLabel(line.text) &&\n   575→      !looksLikeMetadata(line.text)\n   576→    ) {\n   577→      let merged = line.text;\n   578→      const startIndex = line.index;\n   579→      let j = ci + 1;\n   580→      while (j < nonEmptyLines.length) {\n   581→        const next = nonEmptyLines[j];\n   582→        if (\n   583→          isAllCaps(next.text) &&\n   584→          wordCount(next.text) <= 2 &&\n   585→          next.text.length <= 25 &&\n   586→          ((!isSectionLabel(next.text) && !isSectionLabel(repairOcrText(next.text))) ||\n   587→           (wordCount(next.text) === 1 && wordCount(merged) >= 2 && wordCount(merged) <= 4 &&\n   588→            isCategorySectionLabel(next.text))) &&\n   589→          !looksLikeMetadata(next.text) &&\n   590→          (merged + \" \" + next.text).length <= 80\n   591→        ) {\n   592→          merged += \" \" + next.text;\n   593→          j++;\n   594→        } else {\n   595→          break;\n   596→        }\n   597→      }\n   598→      if (j > ci + 1) {\n   599→        capsCoalesced.push({ text: merged, index: startIndex });"}]},"parent_tool_use_id":"toolu_01SkGVRfuYHRcmb4gr5mY2s8","session_id":"b1b8cabe-82af-4d43-a6df-d4a8ec65d151","uuid":"2b0fbbb7-444d-4b01-a04a-63f23af09e6d"}
