{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011yyLBRy6myiDHcRyDpDDLT","type":"tool_result","content":"     1→#!/usr/bin/env node\n     2→\n     3→/**\n     4→ * Standalone title extraction CLI.\n     5→ * Reads a text file, runs extractTitleWithEmbeddings, prints the title to stdout.\n     6→ * Exit 0 on success, 1 on error.\n     7→ *\n     8→ * Usage: npx tsx tools/title-loop/extract-title.ts <text-file-path>\n     9→ */\n    10→\n    11→import { readFileSync } from \"fs\";\n    12→import {\n    13→  embedText,\n    14→  loadEmbedder,\n    15→  type FeatureEmbedder,\n    16→} from \"@/lib/text-classifier/embedder\";\n    17→import { extractTitleWithEmbeddings } from \"@/lib/text-classifier/title-extractor\";\n    18→\n    19→let cachedEmbedder: FeatureEmbedder | null = null;\n    20→\n    21→async function getEmbedder(): Promise<FeatureEmbedder> {\n    22→  if (!cachedEmbedder) {\n    23→    cachedEmbedder = await loadEmbedder();\n    24→  }\n    25→  return cachedEmbedder;\n    26→}\n    27→\n    28→async function embed(text: string): Promise<Array<number>> {\n    29→  return embedText(await getEmbedder(), text);\n    30→}\n    31→\n    32→async function main(): Promise<void> {\n    33→  const filePath = process.argv[2];\n    34→  if (!filePath) {\n    35→    console.error(\"Usage: npx tsx tools/title-loop/extract-title.ts <text-file>\");\n    36→    process.exit(1);\n    37→  }\n    38→\n    39→  const text = readFileSync(filePath, \"utf-8\");\n    40→  const title = await extractTitleWithEmbeddings(text, embed);\n    41→  process.stdout.write(title ?? \"\");\n    42→}\n    43→\n    44→main().catch((err) => {\n    45→  console.error(err);\n    46→  process.exit(1);\n    47→});\n    48→"}]},"parent_tool_use_id":"toolu_01SkGVRfuYHRcmb4gr5mY2s8","session_id":"b1b8cabe-82af-4d43-a6df-d4a8ec65d151","uuid":"5db9450c-ff1c-4449-9f4d-5b045e10615d"}
