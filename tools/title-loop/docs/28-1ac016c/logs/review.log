{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YLyy4aeDtwGYB2vAHBegCF","type":"tool_result","content":"   200→ * Recipe-internal section labels that should ALWAYS block multi-line joins,\n   201→ * even when the combined word count is ≥ 3.\n   202→ * Category labels (\"zupy\", \"placki\", etc.) are NOT in this set — they can\n   203→ * legitimately start a multi-word recipe title like \"Zupy Zimowe Warzywne\".\n   204→ */\n   205→const ALWAYS_BLOCK_JOIN_LABELS = new Set([\n   206→  \"ingredients\", \"directions\", \"instructions\", \"method\", \"preparation\",\n   207→  \"steps\", \"notes\", \"tip\", \"tips\", \"variations\", \"variation\",\n   208→  \"garnish\", \"topping\", \"toppings\", \"frosting\", \"filling\",\n   209→  \"serving suggestion\", \"serving suggestions\", \"serving\",\n   210→  \"glaze\", \"instrukcje\", \"uwagi\", \"notatki\", \"podawanie\", \"przechowywanie\",\n   211→  \"skladniki\", \"przygotowanie\", \"sposob przygotowania\", \"sposob wykonania\",\n   212→  \"wykonanie\", \"wskazowki\", \"podpowiedz\", \"warianty\",\n   213→  \"sos\", \"nadzienie\", \"polewa\", \"lukier\", \"ciasto\",\n   214→]);\n   215→\n   216→function isAlwaysBlockJoinLabel(text: string): boolean {\n   217→  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n   218→  return ALWAYS_BLOCK_JOIN_LABELS.has(normalized);\n   219→}\n   220→\n   221→function isAllCaps(line: string): boolean {\n   222→  const letters = line.replace(/[^a-zA-Z]/g, \"\");\n   223→  return letters.length > 0 && letters === letters.toUpperCase();\n   224→}\n   225→\n   226→function looksLikeMetadata(text: string): boolean {\n   227→  return METADATA_PATTERNS.some((pattern) => pattern.test(text.trim()));\n   228→}\n   229→\n   230→/** Content words are ≥3 alpha characters after stripping punctuation. */\n   231→function extractContentWords(text: string): string[] {\n   232→  return text\n   233→    .split(/\\s+/)\n   234→    .filter((w) => w.replace(/[^a-zA-ZÀ-ÿ]/g, \"\").length >= 3)\n   235→    .map((w) => w.toUpperCase());\n   236→}\n   237→\n   238→/**\n   239→ * Returns true if the candidate's vocabulary is sufficiently supported by the rest of\n   240→ * the document. Short candidates (≤3 content words) require 100% corroboration;\n   241→ * longer candidates require ≥67%. Used to detect orphaned OCR artifacts in multi-title pages.\n   242→ */\n   243→function passesCorroboration(\n   244→  text: string,\n   245→  position: number,\n   246→  allLines: string[],\n   247→  startLine: number = 0 // Only check corroboration against lines from this index onward\n   248→): boolean {\n   249→  const contentWords = extractContentWords(text);\n   250→\n   251→  if (contentWords.length === 0) {\n   252→    return true; // No checkable words — pass through\n   253→  }\n   254→\n   255→  let corroboratedCount = 0;\n   256→  for (const word of contentWords) {\n   257→    for (let i = startLine; i < allLines.length; i++) {\n   258→      if (i === position) continue;\n   259→      if (allLines[i].toUpperCase().includes(word)) {\n   260→        corroboratedCount++;\n   261→        break;\n   262→      }\n   263→    }\n   264→  }\n   265→\n   266→  const score = corroboratedCount / contentWords.length;\n   267→  const threshold = contentWords.length <= 3 ? 1.0 : 0.67;\n   268→  return score >= threshold;\n   269→}\n   270→\n   271→function isLikelyGarbled(text: string): boolean {\n   272→  const letters = text.replace(/[^a-zA-Z]/g, \"\");\n   273→  if (letters.length < 2) return true;\n   274→\n   275→  // Pipe embedded in words = OCR artifact (e.g., \"Sp|aszcz\", \"pa|ką\")\n   276→  if (/[a-zA-ZÀ-ÿа-яА-Я]\\|[a-zA-ZÀ-ÿа-яА-Я]/.test(text)) return true;\n   277→\n   278→  // Mixed Latin + Cyrillic = OCR corruption\n   279→  if (/[а-яА-ЯёЁіІїЇєЄґҐ]/.test(text) && /[a-zA-Z]/.test(text)) return true;\n   280→\n   281→  // Check vowel ratio — English/Polish text typically has 30–50% vowels\n   282→  const vowels = letters.replace(/[^aeiouAEIOUyYąęóĄĘÓ]/g, \"\").length;\n   283→  const vowelRatio = vowels / letters.length;\n   284→  if (vowelRatio < 0.10 || vowelRatio > 0.85) return true;\n   285→\n   286→  // Single orphaned word ≤3 letters that isn't a common word\n   287→  const words = text.trim().split(/\\s+/);\n   288→  const COMMON_SHORT = new Set([\n   289→    \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"had\", \"her\",\n   290→    \"was\", \"one\", \"our\", \"out\", \"are\", \"has\", \"his\", \"how\", \"its\", \"may\",\n   291→    \"new\", \"now\", \"old\", \"see\", \"way\", \"who\", \"did\", \"get\", \"let\", \"say\",\n   292→    \"she\", \"too\", \"use\",\n   293→  ]);\n   294→  // Count all Unicode letters (not just ASCII) so Polish words like \"Żur\" (3 letters) pass\n   295→  const unicodeLetters = text.trim().replace(/[^a-zA-ZąćęłńóśźżĄĆĘŁŃÓŚŹŻ]/g, \"\");\n   296→  if (words.length === 1 && unicodeLetters.length <= 3 && !COMMON_SHORT.has(text.trim().toLowerCase())) {\n   297→    return true;\n   298→  }\n   299→\n   300→  // Single word with internal lowercase→uppercase transition — OCR noise (e.g., \"UuIw\", \"aBC\")\n   301→  // No recipe title uses this pattern as a standalone single-word candidate.\n   302→  if (words.length === 1 && /[a-z][A-Z]/.test(text.trim())) {\n   303→    return true;\n   304→  }\n   305→\n   306→  // Recipe titles never start with a lowercase letter\n   307→  if (/^[a-z]/.test(text.trim())) {\n   308→    return true;\n   309→  }\n   310→\n   311→  // Mid-text sentence boundary (\". \" followed by a letter) — body text fragment spliced from multiple sentences\n   312→  const trimmed = text.trim();\n   313→  if (/\\.\\s+[a-zA-Z]/.test(trimmed) && !trimmed.endsWith(\")\")) {\n   314→    return true;\n   315→  }\n   316→\n   317→  // Multi-word candidate containing a garbled OCR fragment: a short lowercase word that isn't a known short word\n   318→  if (words.length >= 2) {\n   319→    const commonShort2 = new Set([\n   320→      \"a\", \"i\", \"of\", \"or\", \"to\", \"in\", \"on\", \"is\", \"it\", \"an\",\n   321→      \"as\", \"at\", \"by\", \"do\", \"go\", \"if\", \"no\", \"so\", \"up\", \"we\",\n   322→      \"w\", \"z\",   // Polish prepositions (basic)\n   323→      \"ze\", \"bo\", \"na\", \"ni\", \"po\", \"ku\", \"od\", \"za\", \"co\",  // Polish prepositions (extended)\n   324→    ]);\n   325→    const hasGarbledWord = words.some(\n   326→      (w) =>\n   327→        /^[a-z]/.test(w) &&\n   328→        w.replace(/[^a-z]/g, \"\").length <= 2 &&\n   329→        !commonShort2.has(w.toLowerCase())\n   330→    );\n   331→    if (hasGarbledWord) {\n   332→      return true;\n   333→    }\n   334→  }\n   335→\n   336→  return false;\n   337→}\n   338→\n   339→const COOKING_INSTRUCTION_STARTS = /^(beat|fold|stir|mix|add|pour|bake|cook|cool|remove|place|combine|whisk|knead|roll|spread|brush|slice|chop|dice|mince|drain|rinse|peel|grate|melt|simmer|boil|fry|sauté|saute|roast|grill|broil|steam|let|set|transfer|serve|garnish|arrange|sprinkle|season|preheat|cover|uncover|reduce|bring|toss|cut|trim|shape|form|scatter|score|pat|rub|skim|strain|heat|discard|rest|marinate|wrap|flip|turn|layer|stuff|drizzle|squeeze|zest|soak|thaw|freeze|chill|warm|toast|crush|pound|crack|break|separate|weigh|measure|sift|dust|coat|dip|dredge|baste|debone|butterfly|truss|shred|puree|blend|process|pulse|whip|cream|proof|rise|punch|divide|portion|assemble)\\b/i;\n   340→\n   341→// Polish imperative cooking verbs (with OCR-resilient forms — no diacritics required).\n   342→// These cover the most common recipe instruction starters. Includes common OCR-corrupted\n   343→// forms (e.g., \"Smaż\" → \"Smaz\", \"Dodaj\" → \"Dodaj\").\n   344→// Note: only verbs that NEVER start a recipe title. \"Piecz\" (bake) is excluded because\n   345→// \"Pieczeń\" (roast) and \"Pieczarki\" (mushrooms) share the prefix.\n   346→const POLISH_COOKING_INSTRUCTION_STARTS = /^(podawaj|dodaj|dodawaj|sma[zż]|gotuj|odced[zź]|wymieszaj|mieszaj|wlej|nalej|przygotuj|zagotuj|pokr[oó]j|obierz|wrzuc|wrzuć|usma[zż]|podsma[zż]|prze[lł][oó][zż]|zblenduj|ubij|roztrzepaj|rozprowad[zź]|wyrob|zamieszaj|posyp|polej|odstaw|na[lł][oó][zż]|przykryj|odkryj|wstaw|zdejmij|ods[aą]cz|rozgrzej|posiekaj|zetrzyj|wy[lł][oó][zż]|wyjmij|ukr[oó]j|przekr[oó]j|formuj|ugniataj|rozwałkuj)\\b/i;\n   347→\n   348→function looksLikeCookingInstruction(text: string): boolean {\n   349→  const words = text.trim().split(/\\s+/);\n   350→  if (words.length < 4) return false;  // Instructions are multi-word sentences\n   351→  if (COOKING_INSTRUCTION_STARTS.test(text.trim())) return true;\n   352→  if (POLISH_COOKING_INSTRUCTION_STARTS.test(text.trim())) return true;\n   353→  return false;\n   354→}\n   355→\n   356→/**\n   357→ * A line starting with a lowercase letter and having 4+ words is prose continuation.\n   358→ * Recipe titles are capitalized (Title Case or ALL CAPS), so a lowercase-start line\n   359→ * is a strong signal for mid-recipe body text.\n   360→ */\n   361→function isBodyProse(line: string): boolean {\n   362→  return /^[a-ząćęłńóśźż]/.test(line) && wordCount(line) >= 4;\n   363→}\n   364→\n   365→/**\n   366→ * Detect pages where the OCR capture starts mid-recipe with no title present.\n   367→ * Returns true if the first 3 non-empty lines (after `startFrom`) are all ingredients,\n   368→ * cooking instructions, or body prose continuation text.\n   369→ */\n   370→function isTitleAbsentPage(lines: Array<string>, startFrom: number = 0): boolean {\n   371→  const relevantLines = startFrom > 0 ? lines.slice(startFrom) : lines;\n   372→  const nonEmptyLines = relevantLines.map(l => l.trim()).filter(l => l.length > 0);\n   373→\n   374→  if (nonEmptyLines.length < 3) return false;\n   375→\n   376→  const first3 = nonEmptyLines.slice(0, 3);\n   377→\n   378→  return first3.every(line =>\n   379→    looksLikeIngredient(line) ||\n   380→    looksLikeCookingInstruction(line) ||\n   381→    isBodyProse(line)\n   382→  );\n   383→}\n   384→\n   385→function passesHardFilters(text: string): boolean {\n   386→  if (text.length < 3 || text.length > 80) return false;\n   387→  if (looksLikeIngredient(text)) return false;\n   388→  if (startsWithNumber(text)) return false;\n   389→  if (looksLikeMetadata(text)) return false;\n   390→  if (isLikelyGarbled(text)) return false;\n   391→  if (looksLikeCookingInstruction(text)) return false;\n   392→  // Pipe-separated lines are book category/chapter headers, not recipe titles\n   393→  if (text.includes(\" | \")) return false;\n   394→  // Trailing page number (e.g. \"VEGETABLE SIDES                         145\")\n   395→  if (/\\s{3,}\\d{1,4}\\s*$/.test(text)) return false;\n   396→  // Slash-separated breadcrumbs (e.g., \"/ Jesien / Zupy\") are navigation, not titles\n   397→  // Only filter when 2+ slashes are present — single-slash lines like\n   398→  // \"TITLE / SUBTITLE\" are legitimate continuation-merged titles\n   399→  if ((text.match(/\\//g) || []).length >= 2) return false;\n   400→  // Bullet-list items (ingredients or instruction steps) are never titles\n   401→  if (/^\\s*[-•*]\\s/.test(text)) return false;\n   402→  // \"For the sauce:\", \"For the filling:\" etc. are sub-section headers\n   403→  if (/^For the\\s+/i.test(text) && /:\\s*$/.test(text)) return false;\n   404→  // Lines ending with \":\" are recipe sub-section headers, not titles.\n   405→  // Exception: compound titles using \" : \" as a title separator (e.g. \"LEMON CURD : LEMON CURD WITH THYME\").\n   406→  if (/:\\s*$/.test(text.trim()) && !/ : /.test(text)) return false;\n   407→  // Page references are navigation markers, not recipe titles\n   408→  if (/^Page\\s+\\d+/i.test(text.trim())) return false;\n   409→  if (/^Strona\\s+\\d+/i.test(text.trim())) return false;\n   410→  // Corrupted spillover annotations from synthetic multi-page OCR\n   411→  if (/^\\[CORRUPTED\\s+SPILLOVER/i.test(text.trim())) return false;\n   412→  // Parenthetical OCR annotation lines describing corruption artifacts\n   413→  if (/^\\(OCR\\b/i.test(text.trim())) return false;\n   414→  if (/^\\(.*\\bcorruption\\b/i.test(text.trim())) return false;\n   415→  // Square-bracket category tags (e.g., \"[CLASSIC FALL SOUPS]\")\n   416→  if (/^\\[.*\\]$/.test(text.trim())) return false;\n   417→  // Known recipe section labels are structural headers, not titles\n   418→  if (isSectionLabel(text)) return false;\n   419→  // Single-word non-title fragments\n   420→  const words = text.trim().split(/\\s+/);\n   421→  if (words.length === 1 && NON_TITLE_WORDS.has(text.trim().toLowerCase())) return false;\n   422→  // Lines with ≥8 words are almost certainly body text, not titles.\n   423→  // Exception: multi-title compounds with \" + \", \" : \", or \" & \" separators are allowed.\n   424→  if (words.length >= 8 && !/ [+:&/] /.test(text)) return false;\n   425→  return true;\n   426→}\n   427→\n   428→/**\n   429→ * Detect initial burst of short garbled lines.\n   430→ * Returns the index of the first non-garbled or long line.\n   431→ */\n   432→function findBurstEnd(lines: Array<{ text: string }>): number {\n   433→  let i = 0;\n   434→\n   435→  // Skip overflow preambles: blocks introduced by \"PREVIOUS RECIPE OVERFLOW\",\n   436→  // \"PREVIOUS PAGE CONTENT\", \"CORRUPTED SECTION\", etc. that precede the actual recipe.\n   437→  const OVERFLOW_MARKERS = /\\b(PREVIOUS\\s+(RECIPE|PAGE)\\b|SPILLOVER|CONTINUATION|CORRUPTED\\s+(SECTION|TEXT)\\b|PARTIAL\\s+RECIPE)\\b/i;\n   438→  let overflowEnd = 0;\n   439→  for (let k = 0; k < lines.length && k < 30; k++) {\n   440→    // Don't re-examine lines already determined to be overflow\n   441→    if (overflowEnd > 0 && k < overflowEnd) continue;\n   442→    if (OVERFLOW_MARKERS.test(lines[k].text) || /^\\[.*\\b(PREVIOUS|CORRUPTED|SPILLOVER|CONTINUATION|PARTIAL)\\b.*\\]$/i.test(lines[k].text)) {\n   443→      // Skip forward past the overflow block to the next visual separator or blank cluster\n   444→      let m = k + 1;\n   445→      let consecutiveBlanks = 0;\n   446→      while (m < lines.length) {\n   447→        const lineText = lines[m].text;\n   448→        // Stop at visual separator\n   449→        if (/^[=\\-]{4,}$/.test(lineText)) {"}]},"parent_tool_use_id":"toolu_01Es9TDQPf3NedsZAii36MzQ","session_id":"66d6120a-7fee-4673-bb0a-75db3320d34d","uuid":"fd8d2492-9719-48d9-9415-21aef0756f1f"}
{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01CJnqrGbnDHpjZdtRBTv6hk","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_0113zBR45qeQELc4gZrLP6BF","name":"Read","input":{"file_path":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/title-extractor.ts","offset":448,"limit":300},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":5188,"cache_read_input_tokens":23102,"cache_creation":{"ephemeral_5m_input_tokens":5188,"ephemeral_1h_input_tokens":0},"output_tokens":18,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01Es9TDQPf3NedsZAii36MzQ","session_id":"66d6120a-7fee-4673-bb0a-75db3320d34d","uuid":"cfe85d54-8442-4aae-8236-20f682cab0b9"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0113zBR45qeQELc4gZrLP6BF","type":"tool_result","content":"   448→        // Stop at visual separator\n   449→        if (/^[=\\-]{4,}$/.test(lineText)) {\n   450→          overflowEnd = m + 1;\n   451→          break;\n   452→        }\n   453→        // Track consecutive blank lines\n   454→        if (lineText.trim().length === 0) {\n   455→          consecutiveBlanks++;\n   456→          if (consecutiveBlanks >= 2) {\n   457→            overflowEnd = m + 1;\n   458→            break;\n   459→          }\n   460→        } else {\n   461→          consecutiveBlanks = 0;\n   462→          // Stop at ALL_CAPS line with ≥2 words (likely next recipe heading)\n   463→          if (isAllCaps(lineText) && wordCount(lineText) >= 2) {\n   464→            overflowEnd = m; // Don't skip past the heading itself\n   465→            break;\n   466→          }\n   467→        }\n   468→        m++;\n   469→      }\n   470→      // If we walked to end without finding termination, skip everything we saw\n   471→      if (overflowEnd === 0) overflowEnd = m;\n   472→    }\n   473→  }\n   474→  if (overflowEnd > 0) i = overflowEnd;\n   475→\n   476→  while (i < lines.length && lines[i].text.length < 20 && isLikelyGarbled(lines[i].text) && !isAllCaps(lines[i].text)) {\n   477→    i++;\n   478→  }\n   479→  // Skip body-content prologues: when 3+ consecutive lines at the start are cooking\n   480→  // instructions, prose continuations, or a mix of both, skip them to find the actual\n   481→  // title region. This unifies the previous separate instruction and prose checks to\n   482→  // handle interleaved patterns (e.g., instruction → prose continuation → instruction).\n   483→  if (i === 0) {\n   484→    let j = 0;\n   485→    while (j < lines.length) {\n   486→      const t = lines[j].text;\n   487→      const isInstruction = looksLikeCookingInstruction(t);\n   488→      const isProse = (\n   489→        /^[a-ząćęłńóśźż]/.test(t) ||\n   490→        t.endsWith(\",\") ||\n   491→        (t.endsWith(\".\") && wordCount(t) > 4)\n   492→      ) && wordCount(t) >= 4;\n   493→      const isContinuation = /^[a-ząćęłńóśźż]/.test(t) && wordCount(t) >= 2;\n   494→\n   495→      if (isInstruction || isProse || isContinuation) {\n   496→        j++;\n   497→      } else {\n   498→        break;\n   499→      }\n   500→    }\n   501→    if (j >= 3) {\n   502→      i = j;\n   503→    }\n   504→  }\n   505→  return i;\n   506→}\n   507→\n   508→function stripParentheticalGloss(text: string): string {\n   509→  // Strip trailing English-gloss parentheticals from ALL_CAPS titles.\n   510→  // e.g. \"PIEROGI RUSKIE (Boiled Dumplings with Potato and Cheese)\" → \"PIEROGI RUSKIE\"\n   511→  // Keep if parenthetical is ALL_CAPS (variation/subtitle in same language).\n   512→  // Keep if both base and paren are mixed-case (both are part of the title).\n   513→  const match = text.match(/^(.+?)\\s*\\(([^)]+)\\)\\s*$/);\n   514→  if (!match) return text;\n   515→  const [, base, paren] = match;\n   516→  if (isAllCaps(paren)) return text;\n   517→  if (!isAllCaps(base) && !isAllCaps(paren)) return text;\n   518→  return base.trim();\n   519→}\n   520→\n   521→function stripPageNumber(text: string): string {\n   522→  // \"34  Berry Jam\" → \"Berry Jam\" (2+ spaces distinguishes from \"2 eggs\")\n   523→  const match = text.match(/^\\d{1,3}\\s{2,}(.+)$/);\n   524→  return match ? match[1] : text;\n   525→}\n   526→\n   527→function wordCount(text: string): number {\n   528→  return text.split(/\\s+/).filter((w) => w.length > 0).length;\n   529→}\n   530→\n   531→/**\n   532→ * Build candidate strings from lines: single lines plus multi-line joins (2-3 consecutive).\n   533→ * Skips initial burst of short garbled lines. Scans all remaining lines. Caps at 25.\n   534→ */\n   535→export type CandidateOrigin = \"single\" | \"2-line\" | \"3-line\";\n   536→\n   537→function buildCandidates(\n   538→  lines: Array<string>\n   539→): { candidates: Array<{ text: string; position: number; origin: CandidateOrigin }>; burstEnd: number } {\n   540→  const nonEmptyLines: Array<{ text: string; index: number }> = [];\n   541→\n   542→  for (let i = 0; i < lines.length; i++) {\n   543→    const trimmed = lines[i].trim();\n   544→    if (trimmed.length > 0) {\n   545→      nonEmptyLines.push({ text: trimmed, index: i });\n   546→    }\n   547→  }\n   548→\n   549→  const burstEnd = findBurstEnd(nonEmptyLines);\n   550→\n   551→  // Pre-join hyphen-broken lines: \"ROASTED CHICKEN WITH ROOT VEGET-\" + \"ABLES\" → single line.\n   552→  // Only applies within the candidate region (after burst end).\n   553→  for (let hi = burstEnd; hi < nonEmptyLines.length - 1; hi++) {\n   554→    if (nonEmptyLines[hi].text.endsWith(\"-\")) {\n   555→      const joined = nonEmptyLines[hi].text.slice(0, -1) + nonEmptyLines[hi + 1].text;\n   556→      nonEmptyLines[hi] = { text: joined, index: nonEmptyLines[hi].index };\n   557→      nonEmptyLines.splice(hi + 1, 1);\n   558→    }\n   559→  }\n   560→\n   561→  // Pre-merge consecutive short ALL_CAPS lines (OCR-fragmented headings).\n   562→  // When a sequence of 2+ ALL_CAPS lines each has ≤2 words and ≤25 chars, they are\n   563→  // almost certainly OCR fragments of a single heading. Merge them into one line so\n   564→  // the complete title enters the candidate pool without hitting the 3-line join ceiling.\n   565→  const capsCoalesced: Array<{ text: string; index: number }> = [];\n   566→  let ci = burstEnd;\n   567→  while (ci < nonEmptyLines.length) {\n   568→    const line = nonEmptyLines[ci];\n   569→    if (\n   570→      isAllCaps(line.text) &&\n   571→      wordCount(line.text) <= 2 &&\n   572→      line.text.length <= 25 &&\n   573→      !isSectionLabel(line.text) &&\n   574→      !looksLikeMetadata(line.text)\n   575→    ) {\n   576→      let merged = line.text;\n   577→      const startIndex = line.index;\n   578→      let j = ci + 1;\n   579→      while (j < nonEmptyLines.length) {\n   580→        const next = nonEmptyLines[j];\n   581→        if (\n   582→          isAllCaps(next.text) &&\n   583→          wordCount(next.text) <= 2 &&\n   584→          next.text.length <= 25 &&\n   585→          ((!isSectionLabel(next.text) && !isSectionLabel(repairOcrText(next.text))) ||\n   586→           (wordCount(next.text) === 1 && wordCount(merged) >= 2 && wordCount(merged) <= 4 &&\n   587→            isCategorySectionLabel(next.text))) &&\n   588→          !looksLikeMetadata(next.text) &&\n   589→          (merged + \" \" + next.text).length <= 80\n   590→        ) {\n   591→          merged += \" \" + next.text;\n   592→          j++;\n   593→        } else {\n   594→          break;\n   595→        }\n   596→      }\n   597→      if (j > ci + 1) {\n   598→        capsCoalesced.push({ text: merged, index: startIndex });\n   599→        ci = j;\n   600→        continue;\n   601→      }\n   602→    }\n   603→    capsCoalesced.push(line);\n   604→    ci++;\n   605→  }\n   606→\n   607→  // Pre-merge continuation lines: a line starting with /&+:( is never a standalone title.\n   608→  // Merge it into the preceding line so the complete title enters the pool as a single candidate,\n   609→  // avoiding the fragile chain of conditions required by the downstream join survival logic.\n   610→  // Limitation: only one continuation line per preceding line is merged. Titles split across\n   611→  // three or more lines with continuation tokens (rare in practice) are not handled here —\n   612→  // the downstream 2-line and 3-line join candidates cover those cases instead.\n   613→  const mergedLines: Array<{ text: string; index: number }> = [];\n   614→  for (let i = 0; i < capsCoalesced.length; i++) {\n   615→    const line = capsCoalesced[i];\n   616→    if (i + 1 < capsCoalesced.length) {\n   617→      const nextText = capsCoalesced[i + 1].text;\n   618→      if (/^[/&+:(]/.test(nextText)) {\n   619→        mergedLines.push({ text: `${line.text} ${nextText}`, index: line.index });\n   620→        i++;\n   621→        continue;\n   622→      }\n   623→    }\n   624→    mergedLines.push(line);\n   625→  }\n   626→\n   627→  const candidates: Array<{ text: string; position: number; origin: CandidateOrigin }> = [];\n   628→  const seen = new Set<string>();\n   629→\n   630→  // Build a set of positions to skip: short ALL_CAPS lines immediately following metadata\n   631→  const metadataContinuationPositions = new Set<number>();\n   632→  for (let i = 0; i < mergedLines.length - 1; i++) {\n   633→    if (looksLikeMetadata(mergedLines[i].text)) {\n   634→      const next = mergedLines[i + 1];\n   635→      if (isAllCaps(next.text) && wordCount(next.text) <= 2 && next.text.length <= 15) {\n   636→        metadataContinuationPositions.add(next.index);\n   637→      }\n   638→    }\n   639→  }\n   640→\n   641→  for (let i = 0; i < mergedLines.length; i++) {\n   642→    const line = mergedLines[i];\n   643→\n   644→    // Skip metadata continuation fragments\n   645→    if (metadataContinuationPositions.has(line.index)) continue;\n   646→\n   647→    // Single line — strip page-number prefixes and parenthetical glosses before scoring\n   648→    const singleText = repairOcrText(stripParentheticalGloss(stripPageNumber(line.text)));\n   649→    if (passesHardFilters(singleText)) {\n   650→      const norm = singleText.toLowerCase();\n   651→      if (!seen.has(norm)) {\n   652→        seen.add(norm);\n   653→        candidates.push({ text: singleText, position: line.index, origin: \"single\" });\n   654→      }\n   655→    }\n   656→\n   657→    // Blind OCR repair for early-position candidates: when the original text\n   658→    // has OCR artifacts or erratic casing and is in the first few lines,\n   659→    // generate additional candidates with blind digit→letter repair and/or\n   660→    // casing normalization. This gives the embedding scorer clean versions\n   661→    // even when dictionary repair misses.\n   662→    if (line.index <= 5 && (OCR_ARTIFACT_PATTERN.test(line.text) || hasErraticCasing(line.text))) {\n   663→      let repairable = singleText;\n   664→      if (hasErraticCasing(repairable)) {\n   665→        repairable = normalizeErraticCasing(repairable);\n   666→        if (repairable !== singleText && passesHardFilters(repairable)) {\n   667→          const norm = repairable.toLowerCase();\n   668→          if (!seen.has(norm)) {\n   669→            seen.add(norm);\n   670→            candidates.push({ text: repairable, position: line.index, origin: \"single\" });\n   671→          }\n   672→        }\n   673→      }\n   674→      const variants = generateBlindOcrVariants(repairable);\n   675→      for (const variant of variants) {\n   676→        if (passesHardFilters(variant)) {\n   677→          const norm = variant.toLowerCase();\n   678→          if (!seen.has(norm)) {\n   679→            seen.add(norm);\n   680→            candidates.push({ text: variant, position: line.index, origin: \"single\" });\n   681→          }\n   682→        }\n   683→      }\n   684→    }\n   685→\n   686→    // 2-line join — skip if first line is a section label AND join would be ≤2 words\n   687→    // (a section label followed by modifiers is likely a recipe title, not a category header)\n   688→    if (i + 1 < mergedLines.length) {\n   689→      const joined2 = repairOcrText(`${line.text} ${mergedLines[i + 1].text}`);\n   690→      const shouldBlock2 = isSectionLabel(line.text) &&\n   691→        (wordCount(joined2) <= 2 || isAlwaysBlockJoinLabel(line.text));\n   692→      if (!shouldBlock2 && passesHardFilters(joined2)) {\n   693→        const norm = joined2.toLowerCase();\n   694→        if (!seen.has(norm)) {\n   695→          seen.add(norm);\n   696→          candidates.push({ text: joined2, position: line.index, origin: \"2-line\" });\n   697→        }\n   698→      }\n   699→    }\n   700→\n   701→    // 3-line join — skip if first line is a section label AND join would be ≤2 words\n   702→    if (i + 2 < mergedLines.length) {\n   703→      const joined3 = repairOcrText(`${line.text} ${mergedLines[i + 1].text} ${mergedLines[i + 2].text}`);\n   704→      const shouldBlock3 = isSectionLabel(line.text) &&\n   705→        (wordCount(joined3) <= 2 || isAlwaysBlockJoinLabel(line.text));\n   706→      if (!shouldBlock3 && passesHardFilters(joined3)) {\n   707→        const norm = joined3.toLowerCase();\n   708→        if (!seen.has(norm)) {\n   709→          seen.add(norm);\n   710→          candidates.push({ text: joined3, position: line.index, origin: \"3-line\" });\n   711→        }\n   712→      }\n   713→    }\n   714→  }\n   715→\n   716→  // Pre-filter to 25 before embedding calls: prefer ALL_CAPS and short candidates.\n   717→  // Position-based scoring handles final ranking.\n   718→  if (candidates.length > 25) {\n   719→    const prioritized = candidates.slice().sort((a, b) => {\n   720→      const aAllCaps = isAllCaps(a.text) ? 0 : 1;\n   721→      const bAllCaps = isAllCaps(b.text) ? 0 : 1;\n   722→      if (aAllCaps !== bAllCaps) return aAllCaps - bAllCaps;\n   723→      const aShort = wordCount(a.text) <= 5 ? 0 : 1;\n   724→      const bShort = wordCount(b.text) <= 5 ? 0 : 1;\n   725→      return aShort - bShort;\n   726→    });\n   727→    return { candidates: prioritized.slice(0, 25), burstEnd: nonEmptyLines[burstEnd]?.index ?? 0 };\n   728→  }\n   729→\n   730→  return { candidates, burstEnd: nonEmptyLines[burstEnd]?.index ?? 0 };\n   731→}\n   732→\n   733→/**\n   734→ * Convert an ALL_CAPS string to Title Case, using a small-words list.\n   735→ * Preserves Polish/French diacritics.\n   736→ */\n   737→function toTitleCase(text: string): string {\n   738→  const smallWords = new Set([\n   739→    \"a\", \"an\", \"the\", \"and\", \"but\", \"or\", \"for\", \"nor\",\n   740→    \"in\", \"on\", \"at\", \"to\", \"of\", \"by\", \"with\", \"from\",\n   741→    \"z\", \"w\", \"i\", \"ze\", \"na\", \"do\", \"od\", \"za\", \"po\",\n   742→  ]);\n   743→  return text.split(/(\\s+)/).map((word, idx) => {\n   744→    if (/^\\s+$/.test(word)) return word;\n   745→    const lower = word.toLowerCase();\n   746→    if (idx === 0 || !smallWords.has(lower)) {\n   747→      return lower.charAt(0).toUpperCase() + lower.slice(1);"}]},"parent_tool_use_id":"toolu_01Es9TDQPf3NedsZAii36MzQ","session_id":"66d6120a-7fee-4673-bb0a-75db3320d34d","uuid":"606e189a-3ff6-4b05-989a-b7bc5815aa83"}
