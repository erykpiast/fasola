                       // pinch\n    44→  \"garść\",                               // handful\n    45→  \"opakowanie\", \"opakowania\",            // package(s)\n    46→  \"plasterek\", \"plasterki\",             // slice(s)\n    47→];\n    48→\n    49→/**\n    50→ * Patterns that identify recipe metadata lines (not titles)\n    51→ */\n    52→const METADATA_PATTERNS = [\n    53→  /^(SERVES?|MAKES?|YIELDS?)\\b/i,\n...\n</persisted-output>"}]},"parent_tool_use_id":"toolu_01BGAEdezNUxJg1jisKfTg9G","session_id":"66d6120a-7fee-4673-bb0a-75db3320d34d","uuid":"3e08446b-0834-484b-b816-38a3fa239ca5"}
