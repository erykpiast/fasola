{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PLEbtsMDCnsUcJC1CFhe2T","type":"tool_result","content":"   747→      return lower.charAt(0).toUpperCase() + lower.slice(1);\n   748→    }\n   749→    return lower;\n   750→  }).join(\"\");\n   751→}\n   752→\n   753→/**\n   754→ * OCR digit→letter substitution map.\n   755→ * Each key is a character that OCR commonly confuses; values are possible correct letters.\n   756→ */\n   757→const OCR_SUBSTITUTIONS: Record<string, string[]> = {\n   758→  \"0\": [\"o\"],\n   759→  \"1\": [\"i\", \"l\"],\n   760→  \"4\": [\"a\"],\n   761→  \"5\": [\"s\"],\n   762→  \"¡\": [\"i\"],\n   763→  \"í\": [\"i\", \"l\"],\n   764→  \"€\": [\"e\"],\n   765→};\n   766→\n   767→const OCR_ARTIFACT_PATTERN = /[0-9¡Íí€]/;\n   768→\n   769→/**\n   770→ * Attempt to repair a single OCR-corrupted word using dictionary lookup.\n   771→ * Returns the repaired word if a dictionary match is found, otherwise returns the original.\n   772→ */\n   773→function repairOcrWord(word: string): string {\n   774→  if (!OCR_ARTIFACT_PATTERN.test(word)) return word;\n   775→\n   776→  const lower = word.toLowerCase();\n   777→\n   778→  const positions: Array<{ index: number; replacements: Array<string> }> = [];\n   779→  for (let i = 0; i < lower.length; i++) {\n   780→    const replacements = OCR_SUBSTITUTIONS[lower[i]];\n   781→    if (replacements) {\n   782→      positions.push({ index: i, replacements });\n   783→    }\n   784→  }\n   785→\n   786→  if (positions.length === 0 || positions.length > 8) return word;\n   787→\n   788→  const candidates = generateSubstitutions(lower, positions, 0);\n   789→\n   790→  for (const candidate of candidates) {\n   791→    if (FOOD_DICTIONARY.has(candidate)) {\n   792→      if (word === word.toUpperCase()) return candidate.toUpperCase();\n   793→      if (word[0] === word[0].toUpperCase()) {\n   794→        return candidate[0].toUpperCase() + candidate.slice(1);\n   795→      }\n   796→      return candidate;\n   797→    }\n   798→  }\n   799→\n   800→  return word;\n   801→}\n   802→\n   803→/**\n   804→ * Recursively generate all substitution variants for OCR artifact positions.\n   805→ */\n   806→function generateSubstitutions(\n   807→  base: string,\n   808→  positions: Array<{ index: number; replacements: Array<string> }>,\n   809→  posIdx: number,\n   810→): Array<string> {\n   811→  if (posIdx >= positions.length) return [base];\n   812→\n   813→  const { index, replacements } = positions[posIdx];\n   814→  const results: Array<string> = [];\n   815→\n   816→  for (const replacement of replacements) {\n   817→    const variant = base.slice(0, index) + replacement + base.slice(index + 1);\n   818→    results.push(...generateSubstitutions(variant, positions, posIdx + 1));\n   819→  }\n   820→\n   821→  return results;\n   822→}\n   823→\n   824→/**\n   825→ * Apply dictionary-guided OCR repair to all words in a text string.\n   826→ */\n   827→function repairOcrText(text: string): string {\n   828→  return text\n   829→    .split(/\\s+/)\n   830→    .map((word) => {\n   831→      const match = word.match(/^([^a-zA-Z0-9À-ÿ]*)(.*?)([^a-zA-Z0-9À-ÿ]*)$/);\n   832→      if (!match) return word;\n   833→      const [, prefix, core, suffix] = match;\n   834→      if (!core) return word;\n   835→      const repaired = repairOcrWord(core);\n   836→      return prefix + repaired + suffix;\n   837→    })\n   838→    .join(\" \");\n   839→}\n   840→\n   841→/**\n   842→ * Apply blind OCR repair to a single mixed-case token.\n   843→ * @param oneLetter - the letter to substitute for `1` in lowercase context (\"i\" or \"l\")\n   844→ */\n   845→function applyBlindOcrRepairToken(token: string, oneLetter: \"i\" | \"l\"): string {\n   846→  if (isAllCaps(token) && token.length > 1) {\n   847→    return token\n   848→      .replace(/1/g, \"I\")\n   849→      .replace(/0(?=[A-Z])/g, \"O\")\n   850→      .replace(/(?<=[A-Z])0/g, \"O\");\n   851→  }\n   852→  return token\n   853→    .replace(/(?<=[a-zà-ż])1/g, oneLetter)\n   854→    .replace(/1(?=[a-zà-ż])/g, oneLetter)\n   855→    .replace(/¡/g, \"i\")\n   856→    .replace(/€/g, \"e\");\n   857→}\n   858→\n   859→/**\n   860→ * Apply blind OCR digit-for-letter repair without dictionary lookup.\n   861→ * Used to generate additional candidates for early-position lines where\n   862→ * positional evidence is strong enough to justify speculative repair.\n   863→ */\n   864→function applyBlindOcrRepair(text: string): string {\n   865→  if (isAllCaps(text)) {\n   866→    return text\n   867→      .replace(/1/g, \"I\")\n   868→      .replace(/0(?=[A-ZÀ-Ż])/g, \"O\")\n   869→      .replace(/(?<=[A-ZÀ-Ż])0/g, \"O\")\n   870→      .replace(/4(?=[A-ZÀ-Ż])/g, \"A\")\n   871→      .replace(/(?<=[A-ZÀ-Ż])4/g, \"A\")\n   872→      .replace(/5(?=[A-ZÀ-Ż])/g, \"S\")\n   873→      .replace(/(?<=[A-ZÀ-Ż])5/g, \"S\")\n   874→      .replace(/¡/g, \"I\")\n   875→      .replace(/€/g, \"E\")\n   876→      .replace(/[ÍÌ]/g, \"I\");\n   877→  }\n   878→  // Mixed-case: fix per-word (digits between lowercase letters)\n   879→  return text.split(/(\\s+)/).map((token) => {\n   880→    if (/^\\s+$/.test(token)) return token;\n   881→    return applyBlindOcrRepairToken(token, \"l\");\n   882→  }).join(\"\");\n   883→}\n   884→\n   885→function hasErraticCasing(text: string): boolean {\n   886→  return text.split(/\\s+/).some(word => {\n   887→    if (word.length < 3) return false;\n   888→    if (isAllCaps(word)) return false;\n   889→    const inner = word.slice(1);\n   890→    const upperInner = (inner.match(/[A-ZÀ-Ż]/g) || []).length;\n   891→    const lowerInner = (inner.match(/[a-zà-ż]/g) || []).length;\n   892→    return upperInner >= 2 && upperInner >= lowerInner * 0.3;\n   893→  });\n   894→}\n   895→\n   896→function normalizeErraticCasing(text: string): string {\n   897→  return text.split(/(\\s+)/).map(token => {\n   898→    if (/^\\s+$/.test(token)) return token;\n   899→    if (isAllCaps(token)) return token;\n   900→    if (hasErraticCasing(token)) {\n   901→      return token.charAt(0).toUpperCase() + token.slice(1).toLowerCase();\n   902→    }\n   903→    return token;\n   904→  }).join(\"\");\n   905→}\n   906→\n   907→/**\n   908→ * Generate multiple blind OCR repair variants for embedding comparison.\n   909→ * For ALL_CAPS text, returns a single variant (1→I is unambiguous).\n   910→ * For mixed-case text, returns two variants: one with 1→i and one with 1→l,\n   911→ * letting the embedding scorer pick the better one.\n   912→ */\n   913→function generateBlindOcrVariants(text: string): Array<string> {\n   914→  if (isAllCaps(text)) {\n   915→    const repaired = applyBlindOcrRepair(text);\n   916→    return repaired !== text ? [repaired] : [];\n   917→  }\n   918→\n   919→  const variants: Array<string> = [];\n   920→\n   921→  // i-variant: 1→i between lowercase letters\n   922→  const iVariant = text.split(/(\\s+)/).map((token) => {\n   923→    if (/^\\s+$/.test(token)) return token;\n   924→    return applyBlindOcrRepairToken(token, \"i\");\n   925→  }).join(\"\");\n   926→\n   927→  // l-variant: 1→l between lowercase letters (current behavior)\n   928→  const lVariant = applyBlindOcrRepair(text);\n   929→\n   930→  if (iVariant !== text) variants.push(iVariant);\n   931→  if (lVariant !== text && lVariant !== iVariant) variants.push(lVariant);\n   932→\n   933→  return variants;\n   934→}\n   935→\n   936→/**\n   937→ * Post-processing normalization for OCR-extracted titles.\n   938→ * Strips stray section markers and substitutes common OCR digit-for-letter artifacts.\n   939→ * Title-case conversion is applied only when a substitution was actually made, so\n   940→ * clean ALL_CAPS titles (e.g. \"CHOCOLATE CAKE\") are returned unchanged.\n   941→ */\n   942→function normalizeOcrTitle(raw: string): string {\n   943→  let text = raw.trim();\n   944→\n   945→  // Step 0: Dictionary-guided OCR repair — resolve ambiguous substitutions\n   946→  // using word-level context before applying blind character replacements.\n   947→  text = repairOcrText(text);\n   948→\n   949→  // Step 1: Strip trailing section markers greedily appended to the title.\n   950→  // e.g. \"MAKOWIEC ZE ŚLIWKAMI + SERVING AND STORAGE:\" → \"MAKOWIEC ZE ŚLIWKAMI\"\n   951→  text = text.replace(\n   952→    /\\s*\\+\\s*(?:SERV[IÍ1]NG(?:\\s+AND\\s+STORAGE)?|TOPPING|NOTES?|TIPS?)\\s*:?\\s*$/i,\n   953→    \"\"\n   954→  );\n   955→\n   956→  // Step 2: OCR character substitution.\n   957→  const beforeSub = text;\n   958→  text = applyBlindOcrRepair(text);\n   959→\n   960→  // Step 3: Title-case conversion — ONLY when OCR substitution changed the text.\n   961→  // This preserves clean ALL_CAPS titles (e.g. \"CHOCOLATE CAKE\") as-is.\n   962→  if (text !== beforeSub && isAllCaps(text)) {\n   963→    text = toTitleCase(text);\n   964→  }\n   965→\n   966→  // Step 4: Normalize erratic casing (e.g. \"KoPyTka\" → \"Kopytka\").\n   967→  if (hasErraticCasing(text)) {\n   968→    text = normalizeErraticCasing(text);\n   969→  }\n   970→\n   971→  return text.trim();\n   972→}\n   973→\n   974→// Module-level cache for reference embeddings\n   975→let cachedTitleRefEmbedding: Array<number> | null = null;\n   976→let cachedHeaderRefEmbedding: Array<number> | null = null;\n   977→let cachedNoiseRefEmbedding: Array<number> | null = null;\n   978→\n   979→export function _resetEmbeddingCacheForTests(): void {\n   980→  cachedTitleRefEmbedding = null;\n   981→  cachedHeaderRefEmbedding = null;\n   982→  cachedNoiseRefEmbedding = null;\n   983→}\n   984→\n   985→export async function extractTitleWithEmbeddings(\n   986→  text: string,\n   987→  embed: EmbedFn\n   988→): Promise<string | undefined> {\n   989→  if (!text || text.trim().length === 0) {\n   990→    return undefined;\n   991→  }\n   992→\n   993→  const lines = text.split(\"\\n\");\n   994→  const { candidates, burstEnd } = buildCandidates(lines);\n   995→  const titleAbsent = isTitleAbsentPage(lines, burstEnd);\n   996→\n   997→  if (candidates.length === 0) {\n   998→    return undefined;\n   999→  }\n  1000→\n  1001→  // Cache reference embeddings\n  1002→  if (!cachedTitleRefEmbedding) {\n  1003→    cachedTitleRefEmbedding = await embed(TITLE_REFERENCE);\n  1004→  }\n  1005→  if (!cachedHeaderRefEmbedding) {\n  1006→    cachedHeaderRefEmbedding = await embed(HEADER_REFERENCE);\n  1007→  }\n  1008→  if (!cachedNoiseRefEmbedding) {\n  1009→    cachedNoiseRefEmbedding = await embed(NOISE_REFERENCE);\n  1010→  }\n  1011→\n  1012→  // Find ALL_CAPS candidates with ≥2 words where every significant word has ≥4 alpha letters.\n  1013→  // Insignificant tokens (≤1 alpha letter: \"/\", \"&\", \"+\", \":\", \"D)\", etc.) are filtered before\n  1014→  // the check so that multi-line joins with continuation punctuation still qualify.\n  1015→  const isStructuralHeading = (c: { text: string }): boolean => {\n  1016→    if (!isAllCaps(c.text) || wordCount(c.text) < 2) return false;\n  1017→    const sigWords = c.text.trim().split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length > 1);\n  1018→    return sigWords.length >= 2 && sigWords.every((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n  1019→  };\n  1020→\n  1021→  // Pass 1: compute rawScore for all candidates (embedding quality signal)\n  1022→  const rawScored: Array<{ text: string; position: number; origin: CandidateOrigin; rawScore: number; embedding: Array<number> }> = [];\n  1023→  for (const candidate of candidates) {\n  1024→    const embedding = await embed(candidate.text);\n  1025→    const titleSim = cosineSimilarity(embedding, cachedTitleRefEmbedding);\n  1026→    const headerSim = cosineSimilarity(embedding, cachedHeaderRefEmbedding);\n  1027→    const noiseSim = cosineSimilarity(embedding, cachedNoiseRefEmbedding);\n  1028→    const rawScore = titleSim - Math.max(headerSim, noiseSim);\n  1029→    rawScored.push({ text: candidate.text, position: candidate.position, origin: candidate.origin, rawScore, embedding });\n  1030→  }\n  1031→\n  1032→  // Select baseHeading by embedding quality (rawScore), not position.\n  1033→  // This prevents OCR-garbled fragments from claiming the structural heading slot.\n  1034→  const structuralCandidates = rawScored.filter((s) => isStructuralHeading(s));\n  1035→\n  1036→  // Penalize structural headings with truncated OCR words:\n  1037→  // if \"FRON\" appears and another heading has \"SAFFRON\", \"FRON\" is likely garbled.\n  1038→  for (const sc of structuralCandidates) {\n  1039→    const sigWords = sc.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n  1040→    for (const other of structuralCandidates) {\n  1041→      if (other === sc) continue;\n  1042→      const otherSigWords = other.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n  1043→      const hasTruncation = sigWords.some((w) =>\n  1044→        otherSigWords.some((ow) => ow !== w && ow.length > w.length && ow.endsWith(w))\n  1045→      );\n  1046→      if (hasTruncation) {"}]},"parent_tool_use_id":"toolu_01Es9TDQPf3NedsZAii36MzQ","session_id":"66d6120a-7fee-4673-bb0a-75db3320d34d","uuid":"d8d4ea13-18cd-4b1b-8ccf-22d2622cb54a"}
