{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DxjtjXsDPXQAWcgah3pN4R","type":"tool_result","content":"  1350→        scoredForThreshold = scoredForThreshold.filter((s) => !artifactTexts.has(s.text));\n  1351→      }\n  1352→    }\n  1353→  }\n  1354→\n  1355→  // Use thresholdScore (excludes structural bonus) so the structural bonus doesn't inflate\n  1356→  // the threshold and block equally-valid headings on multi-recipe pages.\n  1357→  const bestThresholdScore = Math.max(...scoredForThreshold.map((s) => s.thresholdScore));\n  1358→  const threshold = Math.max(0.08, bestThresholdScore * 0.7);\n  1359→\n  1360→  // Filter candidates above threshold\n  1361→  let selected = scoredForThreshold.filter((s) => s.score >= threshold);\n  1362→\n  1363→  // Empty-pool fallback: when threshold filtering discards every candidate,\n  1364→  // the hard filters' structural verdict should not be overruled by weak\n  1365→  // embedding differentiation. Return the best positional candidate only\n  1366→  // if it has a meaningful positive raw score (avoids ingredient-list leakage).\n  1367→  if (selected.length === 0 && scored.length > 0) {\n  1368→    const fallback = scored\n  1369→      .slice()\n  1370→      .sort((a, b) => a.position - b.position || b.score - a.score);\n  1371→    // Position-0 candidates that passed hard filters are very likely titles even with\n  1372→    // weak embedding signal. Relax the rawScore guard for early-position candidates.\n  1373→    const rawScoreThreshold = fallback[0].position <= 2 ? -0.05 : 0.02;\n  1374→    if (fallback[0].rawScore > rawScoreThreshold) {\n  1375→      selected = [fallback[0]];\n  1376→    }\n  1377→  }\n  1378→\n  1379→  // Title-absent page guard: when the page starts mid-recipe (all of the first 3 non-empty\n  1380→  // lines are ingredients or cooking instructions), require a much higher rawScore and\n  1381→  // discard candidates deep in the file. This prevents stray body text or adjacent recipe\n  1382→  // titles from being picked up on pages with no title (Pattern 4).\n  1383→  if (titleAbsent) {\n  1384→    const titleAbsentThreshold = 0.10;\n  1385→    selected = selected.filter(s => s.rawScore >= titleAbsentThreshold);\n  1386→    selected = selected.filter(s => s.position <= 2);\n  1387→  }\n  1388→\n  1389→  // Remove word-boundary prefixes of firstStructuralHeading when the heading itself survived\n  1390→  // the threshold. Cases:\n  1391→  //   ARAYES case:  firstStructuralHeading = \"ARAYES SHRAK\" (2-word join qualifies; \"ARAYES\"\n  1392→  //     alone = 1 word, so it never qualified). Filter removes \"ARAYES\" so dedup keeps the join.\n  1393→  //   SAFFRON case: baseHeading was the partial line; continuation logic above upgraded\n  1394→  //     firstStructuralHeading to the full join. Filter removes the partial so dedup keeps join.\n  1395→  // Safety: only fires when the complete heading itself is in selected (passed the threshold).\n  1396→  if (firstStructuralHeading && selected.some((s) => s.text === firstStructuralHeading.text)) {\n  1397→    const fshLower = firstStructuralHeading.text.toLowerCase();\n  1398→    selected = selected.filter((s) => {\n  1399→      if (s.text === firstStructuralHeading.text) return true;\n  1400→      const sLower = s.text.toLowerCase();\n  1401→      // Remove s if it is a space-delimited prefix of the structural heading\n  1402→      return !fshLower.startsWith(sLower + \" \");\n  1403→    });\n  1404→  }\n  1405→\n  1406→  // Protect continuation joins: when a multi-line join (2-line or 3-line) survived the threshold\n  1407→  // and its second part starts with a continuation character, remove the single-line prefix/suffix\n  1408→  // so the dedup \"shorter wins\" rule doesn't destroy the complete join.\n  1409→  // Note: the pre-merge step above already handles the common Baked Eggs case (&/continuation\n  1410→  // on next line) by turning it into a single candidate — this block covers the rarer case where\n  1411→  // a continuation-character join was generated as a 2-line/3-line candidate and the prefix\n  1412→  // single also survived threshold independently (e.g. from a different code path or OCR layout).\n  1413→  // Safety: only fires for joins whose continuation starts with /&+:( — digit continuations\n  1414→  // like \"Pierogi Ruskie 200g mąki\" are NOT protected, so dedup correctly keeps the shorter form.\n  1415→  const survivingJoins = selected.filter((s) => s.origin === \"2-line\" || s.origin === \"3-line\");\n  1416→  if (survivingJoins.length > 0) {\n  1417→    selected = selected.filter((s) => {\n  1418→      if (s.origin !== \"single\") return true;\n  1419→      const sLower = s.text.toLowerCase();\n  1420→      // Remove PREFIX singles whose continuation join also survived\n  1421→      const isPrefixOfJoin = survivingJoins.some((j) => {\n  1422→        const jLower = j.text.toLowerCase();\n  1423→        if (!jLower.startsWith(sLower + \" \")) return false;\n  1424→        const remainder = jLower.slice(sLower.length + 1);\n  1425→        return /^[/&+:(]/.test(remainder);\n  1426→      });\n  1427→      if (isPrefixOfJoin) return false;\n  1428→      // Remove SUFFIX singles (e.g. \"& Coriander\") whose parent join also survived\n  1429→      const isSuffixOfJoin = survivingJoins.some((j) => {\n  1430→        const jLower = j.text.toLowerCase();\n  1431→        if (!jLower.endsWith(\" \" + sLower)) return false;\n  1432→        // Only remove if the suffix starts with a continuation character\n  1433→        return /^[/&+:(]/.test(sLower);\n  1434→      });\n  1435→      if (isSuffixOfJoin) return false;\n  1436→      return true;\n  1437→    });\n  1438→  }\n  1439→\n  1440→  // Pre-dedup: remove sub-section headers that are substrings of other surviving candidates.\n  1441→  // A sub-section header is an ALL_CAPS candidate followed by ingredient-like lines in the source.\n  1442→  // Example: \"CHLEBEK\" (bread section header, followed by \"500 g mąki\") is a substring of\n  1443→  // \"CHLEBEK Z WARZYWAMI I BOCZKIEM\" (the real title). Without this filter, dedup kills the title.\n  1444→  selected = selected.filter((candidate) => {\n  1445→    if (!isAllCaps(candidate.text)) return true;\n  1446→    // Check if this candidate is immediately followed by ingredient-like content\n  1447→    const nextSourceLines = lines.slice(candidate.position + 1, candidate.position + 2);\n  1448→    const followedByIngredients = nextSourceLines.some(\n  1449→      (l) => looksLikeIngredient(l.trim()) || startsWithNumber(l.trim())\n  1450→    );\n  1451→    if (!followedByIngredients) return true;\n  1452→    // Only remove if a longer candidate contains this one as a substring\n  1453→    const candidateLower = candidate.text.toLowerCase();\n  1454→    const hasLongerParent = rawScored.some(\n  1455→      (other) =>\n  1456→        other.text !== candidate.text &&\n  1457→        other.text.length > candidate.text.length &&\n  1458→        other.text.toLowerCase().includes(candidateLower)\n  1459→    );\n  1460→    return !hasLongerParent;\n  1461→  });\n  1462→\n  1463→  // Protect multi-line joins from being destroyed by their own component singles.\n  1464→  // When \"Lamb Stew\" (2-line join) survives AND both \"Lamb\" and \"Stew\" (singles) also survive,\n  1465→  // the join is the intended title — remove the singles.\n  1466→  const joinsToProtect = selected.filter((s) => s.origin === \"2-line\" || s.origin === \"3-line\");\n  1467→  if (joinsToProtect.length > 0) {\n  1468→    const singlesToRemove = new Set<string>();\n  1469→    for (const join of joinsToProtect) {\n  1470→      const joinWords = join.text.split(/\\s+/);\n  1471→      const componentSingles = selected.filter(\n  1472→        (s) => s.origin === \"single\" && joinWords.some((w) => s.text.toLowerCase() === w.toLowerCase())\n  1473→      );\n  1474→      if (componentSingles.length >= Math.min(joinWords.length, 2)) {\n  1475→        componentSingles.forEach((s) => singlesToRemove.add(s.text));\n  1476→      }\n  1477→    }\n  1478→    if (singlesToRemove.size > 0) {\n  1479→      selected = selected.filter((s) => s.origin !== \"single\" || !singlesToRemove.has(s.text));\n  1480→    }\n  1481→  }\n  1482→\n  1483→  // Protect position-0 compound titles from distant sub-section headers.\n  1484→  // When a position-0 compound title is longer and contains a shorter candidate\n  1485→  // that appears > 10 lines later, remove the distant candidate so the dedup\n  1486→  // (shorter-wins rule) doesn't destroy the compound title.\n  1487→  const pos0Compounds = selected.filter((s) => s.position === 0);\n  1488→  if (pos0Compounds.length > 0) {\n  1489→    selected = selected.filter((s) => {\n  1490→      if (s.position === 0) return true;\n  1491→      const sLower = s.text.toLowerCase();\n  1492→      return !pos0Compounds.some(\n  1493→        (p0) =>\n  1494→          p0.position + 10 < s.position &&\n  1495→          s.text.length < p0.text.length &&\n  1496→          p0.text.toLowerCase().includes(sLower)\n  1497→      );\n  1498→    });\n  1499→  }\n  1500→\n  1501→  // Deduplicate: if one title is a substring of another, keep the shorter (more focused) one.\n  1502→  // DO NOT CHANGE THIS LOGIC — it has been incorrectly \"improved\" by the title-loop 5 times.\n  1503→  // The tests require shorter wins: \"Pierogi Ruskie\" over \"Pierogi Ruskie 200g mąki 3 ziemniaki\".\n  1504→  // The pre-filter above handles the conflicting case (structural heading prefix removal) so that\n  1505→  // the incomplete prefix line is never present here when the complete join is in selected.\n  1506→  selected = selected.filter((a) => {\n  1507→    const aLower = a.text.toLowerCase();\n  1508→    // Protect compound titles — these use explicit separators and the full form is intentional\n  1509→    if (/ [+:&] /.test(a.text)) return true;\n  1510→    return !selected.some((b) => {\n  1511→      if (b === a)