{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011fsF6b1nPqwwjba81srBsh","type":"tool_result","content":"   655→    }\n   656→\n   657→    // Blind OCR repair for early-position candidates: when the original text\n   658→    // has OCR artifacts or erratic casing and is in the first few lines,\n   659→    // generate additional candidates with blind digit→letter repair and/or\n   660→    // casing normalization. This gives the embedding scorer clean versions\n   661→    // even when dictionary repair misses.\n   662→    if (line.index <= 5 && (OCR_ARTIFACT_PATTERN.test(line.text) || hasErraticCasing(line.text))) {\n   663→      let repairable = singleText;\n   664→      if (hasErraticCasing(repairable)) {\n   665→        repairable = normalizeErraticCasing(repairable);\n   666→        if (repairable !== singleText && passesHardFilters(repairable)) {\n   667→          const norm = repairable.toLowerCase();\n   668→          if (!seen.has(norm)) {\n   669→            seen.add(norm);\n   670→            candidates.push({ text: repairable, position: line.index, origin: \"single\" });\n   671→          }\n   672→        }\n   673→      }\n   674→      const variants = generateBlindOcrVariants(repairable);\n   675→      for (const variant of variants) {\n   676→        if (passesHardFilters(variant)) {\n   677→          const norm = variant.toLowerCase();\n   678→          if (!seen.has(norm)) {\n   679→            seen.add(norm);\n   680→            candidates.push({ text: variant, position: line.index, origin: \"single\" });\n   681→          }\n   682→        }\n   683→      }\n   684→    }\n   685→\n   686→    // 2-line join — skip if first line is a section label AND join would be ≤2 words\n   687→    // (a section label followed by modifiers is likely a recipe title, not a category header)\n   688→    if (i + 1 < mergedLines.length) {\n   689→      const joined2 = repairOcrText(`${line.text} ${mergedLines[i + 1].text}`);"}]},"parent_tool_use_id":null,"session_id":"66d6120a-7fee-4673-bb0a-75db3320d34d","uuid":"7b465049-e35f-4f5d-954f-a20f13df8e81","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/title-extractor.ts","content":"    }\n\n    // Blind OCR repair for early-position candidates: when the original text\n    // has OCR artifacts or erratic casing and is in the first few lines,\n    // generate additional candidates with blind digit→letter repair and/or\n    // casing normalization. This gives the embedding scorer clean versions\n    // even when dictionary repair misses.\n    if (line.index <= 5 && (OCR_ARTIFACT_PATTERN.test(line.text) || hasErraticCasing(line.text))) {\n      let repairable = singleText;\n      if (hasErraticCasing(repairable)) {\n        repairable = normalizeErraticCasing(repairable);\n        if (repairable !== singleText && passesHardFilters(repairable)) {\n          const norm = repairable.toLowerCase();\n          if (!seen.has(norm)) {\n            seen.add(norm);\n            candidates.push({ text: repairable, position: line.index, origin: \"single\" });\n          }\n        }\n      }\n      const variants = generateBlindOcrVariants(repairable);\n      for (const variant of variants) {\n        if (passesHardFilters(variant)) {\n          const norm = variant.toLowerCase();\n          if (!seen.has(norm)) {\n            seen.add(norm);\n            candidates.push({ text: variant, position: line.index, origin: \"single\" });\n          }\n        }\n      }\n    }\n\n    // 2-line join — skip if first line is a section label AND join would be ≤2 words\n    // (a section label followed by modifiers is likely a recipe title, not a category header)\n    if (i + 1 < mergedLines.length) {\n      const joined2 = repairOcrText(`${line.text} ${mergedLines[i + 1].text}`);","numLines":35,"startLine":655,"totalLines":1662}}}
