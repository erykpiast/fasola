{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FgwQ7qzUSfThJCfAFsi6mp","type":"tool_result","content":"  1000→\n  1001→  // Cache reference embeddings\n  1002→  if (!cachedTitleRefEmbedding) {\n  1003→    cachedTitleRefEmbedding = await embed(TITLE_REFERENCE);\n  1004→  }\n  1005→  if (!cachedHeaderRefEmbedding) {\n  1006→    cachedHeaderRefEmbedding = await embed(HEADER_REFERENCE);\n  1007→  }\n  1008→  if (!cachedNoiseRefEmbedding) {\n  1009→    cachedNoiseRefEmbedding = await embed(NOISE_REFERENCE);\n  1010→  }\n  1011→\n  1012→  // Find ALL_CAPS candidates with ≥2 words where every significant word has ≥4 alpha letters.\n  1013→  // Insignificant tokens (≤1 alpha letter: \"/\", \"&\", \"+\", \":\", \"D)\", etc.) are filtered before\n  1014→  // the check so that multi-line joins with continuation punctuation still qualify.\n  1015→  const isStructuralHeading = (c: { text: string }): boolean => {\n  1016→    if (!isAllCaps(c.text) || wordCount(c.text) < 2) return false;\n  1017→    const sigWords = c.text.trim().split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length > 1);\n  1018→    return sigWords.length >= 2 && sigWords.every((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n  1019→  };\n  1020→\n  1021→  // Pass 1: compute rawScore for all candidates (embedding quality signal)\n  1022→  const rawScored: Array<{ text: string; position: number; origin: CandidateOrigin; rawScore: number; embedding: Array<number> }> = [];\n  1023→  for (const candidate of candidates) {\n  1024→    const embedding = await embed(candidate.text);\n  1025→    const titleSim = cosineSimilarity(embedding, cachedTitleRefEmbedding);\n  1026→    const headerSim = cosineSimilarity(embedding, cachedHeaderRefEmbedding);\n  1027→    const noiseSim = cosineSimilarity(embedding, cachedNoiseRefEmbedding);\n  1028→    const rawScore = titleSim - Math.max(headerSim, noiseSim);\n  1029→    rawScored.push({ text: candidate.text, position: candidate.position, origin: candidate.origin, rawScore, embedding });\n  1030→  }\n  1031→\n  1032→  // Select baseHeading by embedding quality (rawScore), not position.\n  1033→  // This prevents OCR-garbled fragments from claiming the structural heading slot.\n  1034→  const structuralCandidates = rawScored.filter((s) => isStructuralHeading(s));\n  1035→\n  1036→  // Penalize structural headings with truncated OCR words:\n  1037→  // if \"FRON\" appears and another heading has \"SAFFRON\", \"FRON\" is likely garbled.\n  1038→  for (const sc of structuralCandidates) {\n  1039→    const sigWords = sc.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n  1040→    for (const other of structuralCandidates) {\n  1041→      if (other === sc) continue;\n  1042→      const otherSigWords = other.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n  1043→      const hasTruncation = sigWords.some((w) =>\n  1044→        otherSigWords.some((ow) => ow !== w && ow.length > w.length && ow.endsWith(w))\n  1045→      );\n  1046→      if (hasTruncation) {\n  1047→        sc.rawScore = -1.0;  // Hard disqualification — truncated OCR artifact\n  1048→        break;\n  1049→      }\n  1050→    }\n  1051→  }\n  1052→\n  1053→  const bestStructural = structuralCandidates.length > 0\n  1054→    ? structuralCandidates.reduce((a, b) => {\n  1055→        const scoreDiff = a.rawScore - b.rawScore;\n  1056→        if (Math.abs(scoreDiff) > 0.03) return scoreDiff > 0 ? a : b;\n  1057→        // Tiebreak: single-line origin beats multi-line joins (avoids conflating two separate headings)\n  1058→        if (a.origin === \"single\" && b.origin !== \"single\") return a;\n  1059→        if (b.origin === \"single\" && a.origin !== \"single\") return b;\n  1060→        // Tiebreak: more words (more specific) → better\n  1061→        const wcDiff = wordCount(b.text) - wordCount(a.text);\n  1062→        if (wcDiff !== 0) return wcDiff > 0 ? b : a;\n  1063→        // Tiebreak: earlier position → better\n  1064→        return a.position < b.position ? a : b;\n  1065→      })\n  1066→    : null;\n  1067→  const baseHeading = bestStructural ?? undefined;\n  1068→\n  1069→  // When the best structural heading has a continuation on the next line introduced by a\n  1070→  // punctuation token (/, &, +, :, or parenthesis), prefer the longer 2-line join as the\n  1071→  // complete heading. E.g. \"SAFFRON WHEAT BUNS WITH QUARK\" + \"/ COTTAGE CHEESE (VARIATION D)\".\n  1072→  // Guard: the remainder after the prefix must start with a continuation character to avoid\n  1073→  // merging two separate consecutive recipe titles (FINNISH MILK FLATBREADS stays separate\n  1074→  // from FINNISH POTATO FLATBREADS because \"FINNISH\" does not start with a continuation token).\n  1075→  let firstStructuralHeading = baseHeading && (\n  1076→    rawScored.find((c) => {\n  1077→      if (!isStructuralHeading(c)) return false;\n  1078→      const hLower = baseHeading.text.toLowerCase();\n  1079→      const cLower = c.text.toLowerCase();\n  1080→      return cLower.startsWith(hLower + \" \") && /^[/&+:(]/.test(cLower.slice(hLower.length + 1));\n  1081→    }) ?? baseHeading\n  1082→  );\n  1083→\n  1084→  // Pass 2: apply bonuses\n  1085→  const scored: Array<{ text: string; position: number; origin: CandidateOrigin; score: number; rawScore: number; baseScore: number; thresholdScore: number }> = rawScored.map((rs, candidateIndex) => {\n  1086→    // Position factor: multiplicative tiebreaker — amplifies existing signal, doesn't replace it.\n  1087→    // Use candidate-relative position (rank among candidates that passed hard filters) rather than\n  1088→    // raw line position, so filtered preamble lines don't penalize the first real candidate.\n  1089→    const candidateRelativePosition = candidateIndex / rawScored.length;\n  1090→    const positionFactor = candidateRelativePosition < 0.5\n  1091→      ? 1.0 + 0.12 * (1 - candidateRelativePosition * 2)\n  1092→      : 1.0;\n  1093→\n  1094→    // ALL_CAPS bonus: recipe books use ALL_CAPS for titles and section headings.\n  1095→    // Single-word ALL_CAPS terms are overwhelmingly section/category labels, not recipe titles;\n  1096→    // real recipe titles in ALL_CAPS are almost always multi-word. Reduce the bonus for single words.\n  1097→    const allCapsBonus = isAllCaps(rs.text) && rs.text.replace(/[^a-zA-Z]/g, \"\").length >= 4\n  1098→      ? (wordCount(rs.text) >= 2 ? 0.08 : 0.03)\n  1099→      : 0;\n  1100→\n  1101→    // Structural heading bonus: best ALL_CAPS heading (or its continuation join) is almost always the recipe title\n  1102→    const structuralBonus = firstStructuralHeading && rs.text === firstStructuralHeading.text ? 0.10 : 0;\n  1103→\n  1104→    // thresholdScore excludes structural bonus so the bonus doesn't inflate the threshold\n  1105→    // and prevent equally-valid structural headings from passing on multi-recipe pages.\n  1106→    const thresholdScore = rs.rawScore + allCapsBonus;\n  1107→    // baseScore excludes position factor — used for diagnostics and ranking\n  1108→    const baseScore = rs.rawScore + allCapsBonus + structuralBonus;\n  1109→    const score = rs.rawScore * positionFactor + allCapsBonus + structuralBonus;\n  1110→    return { text: rs.text, position: rs.position, origin: rs.origin, score, rawScore: rs.rawScore, baseScore, thresholdScore };\n  1111→  });\n  1112→\n  1113→  if (scored.length === 0) {\n  1114→    return undefined;\n  1115→  }\n  1116→\n  1117→  // First-after-preamble bonus (Pattern 3): when lines before the first candidate were all\n  1118→  // filtered/empty, the first surviving candidate occupies the structural \"title position\".\n  1119→  // E.g. \"FISH & SEAFOOD\\nHalibut with Saffron Cream Sauce\\n...\" — \"FISH & SEAFOOD\" is filtered\n  1120→  // as a section label, so \"Halibut...\" is the first candidate and gets this boost.\n  1121→  const firstCandidate = scored[0];\n  1122→  // Capture base score before positional bonuses to cap combined boost later\n  1123→  const baseScoreBeforePositionalBonuses = firstCandidate.baseScore;\n  1124→  if (firstCandidate.position > 0) {\n  1125→    const allPrecedingFiltered = lines\n  1126→      .slice(0, firstCandidate.position)\n  1127→      .every((line) => {\n  1128→        const trimmed = line.trim();\n  1129→        return trimmed === \"\" || !passesHardFilters(trimmed) || isSectionLabel(trimmed);\n  1130→      });\n  1131→    if (allPrecedingFiltered) {\n  1132→      // Stronger bonus when preamble contained structural markers (section labels, metadata)\n  1133→      // vs. only empty lines — structural markers are stronger positional evidence.\n  1134→      const hasStructuralPreamble = lines\n  1135→        .slice(0, firstCandidate.position)\n  1136→        .some((line) => {\n  1137→          const trimmed = line.trim();\n  1138→          return trimmed !== \"\" && (isSectionLabel(trimmed) || looksLikeMetadata(trimmed) || trimmed.includes(\" | \"));\n  1139→        });\n  1140→      const preambleBonus = hasStructuralPreamble ? 0.12 : 0.08;\n  1141→      firstCandidate.score += preambleBonus;\n  1142→      firstCandidate.baseScore += preambleBonus;\n  1143→      firstCandidate.thresholdScore += preambleBonus;\n  1144→    }\n  1145→  }\n  1146→  // Direct-successor bonus: when the line immediately before this candidate is a\n  1147→  // section label, metadata, or pipe-separated line, the candidate is very likely\n  1148→  // the title that follows that header. This complements the first-after-preamble\n  1149→  // bonus which requires ALL preceding lines to be filtered — this one fires even\n  1150→  // when earlier non-filtered lines exist. Checked for the top 3 candidates only\n  1151→  // (ci <= 2) to prevent the bonus from firing on random mid-document lines.\n  1152→  for (let ci = 0; ci < scored.length && ci <= 2; ci++) {\n  1153→    const candidate = scored[ci];\n  1154→    if (candidate.position > 0) {\n  1155→      // Scan backward past blank lines to find nearest non-empty preceding line\n  1156→      let prevPos = candidate.position - 1;\n  1157→      while (prevPos >= 0 && lines[prevPos].trim() === \"\") {\n  1158→        prevPos--;\n  1159→      }\n  1160→      if (prevPos >= 0) {\n  1161→        const prevLine = lines[prevPos].trim();\n  1162→        const prevIsHeader =\n  1163→          isSectionLabel(prevLine) ||\n  1164→          looksLikeMetadata(prevLine) ||\n  1165→          prevLine.includes(\" | \");\n  1166→        if (prevIsHeader) {\n  1167→          candidate.score += 0.10;\n  1168→          candidate.baseScore += 0.10;\n  1169→          candidate.thresholdScore += 0.10;\n  1170→        }\n  1171→      }\n  1172→    }\n  1173→  }\n  1174→\n  1175→  // Cap combined positional boost (position factor + first-after-preamble + direct-successor)\n  1176→  // to avoid over-boosting when multiple bonuses fire together. Applied after all positional\n  1177→  // bonuses so the cap covers all of them (per improvement plan: shared +0.15 max).\n  1178→  const maxPositionalBoost = 0.15;\n  1179→  const totalPositionalBoost = firstCandidate.score - baseScoreBeforePositionalBonuses;\n  1180→  if (totalPositionalBoost > maxPositionalBoost) {\n  1181→    const excess = totalPositionalBoost - maxPositionalBoost;\n  1182→    firstCandidate.score -= excess;\n  1183→    firstCandidate.baseScore -= excess;\n  1184→    firstCandidate.thresholdScore -= excess;\n  1185→  }\n  1186→\n  1187→  // --- Pre-threshold bilingual title detection ---\n  1188→  // When a mixed-case candidate at position 0 is followed by an ALL_CAPS candidate\n  1189→  // at position ≤ 2 that is semantically similar to it, this is a bilingual recipe\n  1190→  // page (e.g., Polish title + ALL_CAPS Korean romanization). Suppress confirmed\n  1191→  // translation candidates before computing threshold so their bonuses don't inflate\n  1192→  // the threshold beyond the mixed-case title's reach.\n  1193→  // Note: we check position ≤ 2 (local proximity), not global ALL_CAPS count, so\n  1194→  // section headers later in the document (SKŁADNIKI, WARZYWA, etc.) are irrelevant.\n  1195→  let translationCandidates: typeof scored = [];\n  1196→  let scoredForThreshold = scored;\n  1197→  const prePos0 = scored.find((s) => s.position === 0 && !isAllCaps(s.text));\n  1198→  if (prePos0) {\n  1199→    const nearbyAllCaps = scored.filter("}]},"parent_tool_use_id":"toolu_01DWZvkYLSgR3KWoyc1JyPBq","session_id":"66d6120a-7fee-4673-bb0a-75db3320d34d","uuid":"289569cb-15f8-4792-b38b-903123817e6e"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XXBc5KiWx3pApTodB6ki7u","type":"tool_result","content":"     1→import {\n     2→  extractTitle,\n     3→  extractTitleWithEmbeddings,\n     4→  _resetEmbeddingCacheForTests,\n     5→} from \"../title-extractor\";\n     6→\n     7→/**\n     8→ * Creates a mock embed function that returns predictable vectors.\n     9→ * Words matching titleWords get a vector pointing \"toward titles\",\n    10→ * words matching headerWords get a vector pointing \"toward headers\",\n    11→ * and everything else gets a neutral vector.\n    12→ */\n    13→function createMockEmbed(\n    14→  titleWords: Array<string>,\n    15→  headerWords: Array<string>\n    16→): (text: string) => Promise<Array<number>> {\n    17→  // Reference phrases from the module\n    18→  const TITLE_REF =\n    19→    \"recipe name, dish title, name of the food, nazwa przepisu, nazwa dania\";\n    20→  const HEADER_REF =\n    21→    \"ingredients list, cooking directions, section heading, składniki, przygotowanie, sposób wykonania\";\n    22→  const NOISE_REF =\n    23→    \"page number, table of contents, book footer, garbled text\";\n    24→\n    25→  return async (text: string): Promise<Array<number>> => {\n    26→    const lower = text.toLowerCase();\n    27→\n    28→    // Title reference → unit vector in dimension 0\n    29→    if (lower === TITLE_REF.toLowerCase()) {\n    30→      return [1, 0, 0];\n    31→    }\n    32→    // Header reference → unit vector in dimension 1\n    33→    if (lower === HEADER_REF.toLowerCase()) {\n    34→      return [0, 1, 0];\n    35→    }\n    36→    // Noise reference → unit vector in dimension 2 (orthogonal)\n    37→    if (lower === NOISE_REF.toLowerCase()) {\n    38→      return [0, 0, 1];\n    39→    }\n    40→\n    41→    // Check if text contains title-like words → high cosine with title ref\n    42→    const isTitle = titleWords.some((w) => lower.includes(w.toLowerCase()));\n    43→    // Check if text contains header-like words → high cosine with header ref\n    44→    const isHeader = headerWords.some((w) => lower.includes(w.toLowerCase()));\n    45→\n    46→    if (isTitle && !isHeader) {\n    47→      return [0.9, 0.1, 0]; // High title similarity, low header similarity\n    48→    }\n    49→    if (isHeader && !isTitle) {\n    50→      return [0.1, 0.9, 0]; // Low title similarity, high header similarity\n    51→    }\n    52→    if (isTitle && isHeader) {\n    53→      return [0.5, 0.5, 0]; // Ambiguous\n    54→    }\n    55→    // Neutral\n    56→    return [0.3, 0.3, 0.7];\n    57→  };\n    58→}\n    59→\n    60→describe(\"extractTitle (heuristic)\", () => {\n    61→  it(\"returns undefined for empty text\", () => {\n    62→    expect(extractTitle(\"\")).toBeUndefined();\n    63→    expect(extractTitle(\"  \")).toBeUndefined();\n    64→  });\n    65→\n    66→  it(\"returns the first valid line\", () => {\n    67→    expect(extractTitle(\"Chicken Soup\\nIngredients\\n1 cup water\")).toBe(\n    68→      \"Chicken Soup\"\n    69→    );\n    70→  });\n    71→\n    72→  it(\"skips lines that are too short or too long\", () => {\n    73→    const longLine = \"A\".repeat(51);\n    74→    expect(extractTitle(`ab\\n${longLine}\\nGood Title`)).toBe(\"Good Title\");\n    75→  });\n    76→\n    77→  it(\"skips ingredient lines\", () => {\n    78→    expect(extractTitle(\"2 cups flour\\nApple Pie\")).toBe(\"Apple Pie\");\n    79→  });\n    80→\n    81→  it(\"skips all-caps lines\", () => {\n    82→    expect(extractTitle(\"INGREDIENTS\\nChocolate Cake\")).toBe(\"Chocolate Cake\");\n    83→  });\n    84→\n    85→  it(\"skips lines starting with numbers\", () => {\n    86→    expect(extractTitle(\"12\\nApple Pie\")).toBe(\"Apple Pie\");\n    87→  });\n    88→});\n    89→\n    90→describe(\"extractTitleWithEmbeddings\", () => {\n    91→  beforeEach(() => {\n    92→    _resetEmbeddingCacheForTests();\n    93→  });\n    94→\n    95→  it(\"returns undefined for empty text\", async () => {\n    96→    const embed = createMockEmbed([], []);\n    97→    expect(await extractTitleWithEmbeddings(\"\", embed)).toBeUndefined();\n    98→    expect(await extractTitleWithEmbeddings(\"  \", embed)).toBeUndefined();\n    99→  });\n   100→\n   101→  it(\"picks title over section header (Polish)\", async () => {\n   102→    const embed = createMockEmbed([\"pierogi ruskie\"], [\"składniki\"]);\n   103→    const text = \"Składniki\\nPierogi Ruskie\\n200g mąki\\n3 ziemniaki\";\n   104→    const result = await extractTitleWithEmbeddings(text, embed);\n   105→    expect(result).toBe(\"Pierogi Ruskie\");\n   106→  });\n   107→\n   108→  it(\"picks title over section header (English)\", async () => {\n   109→    const embed = createMockEmbed([\"chicken soup\"], [\"ingredients\"]);\n   110→    const text = \"Ingredients\\nChicken Soup\\n1 cup water\\nSalt\";\n   111→    const result = await extractTitleWithEmbeddings(text, embed);\n   112→    expect(result).toBe(\"Chicken Soup\");\n   113→  });\n   114→\n   115→  it(\"preserves all-caps titles\", async () => {\n   116→    const embed = createMockEmbed([\"chocolate cake\"], [\"ingredients\"]);\n   117→    const text = \"CHOCOLATE CAKE\\nIngredients\\n200g flour\";\n   118→    const result = await extractTitleWithEmbeddings(text, embed);\n   119→    expect(result).toBe(\"CHOCOLATE CAKE\");\n   120→  });\n   121→\n   122→  it(\"skips numbered lines\", async () => {\n   123→    const embed = createMockEmbed([\"apple pie\"], []);\n   124→    const text = \"12\\nApple Pie\\nSome instructions\";\n   125→    const result = await extractTitleWithEmbeddings(text, embed);\n   126→    expect(result).toBe(\"Apple Pie\");\n   127→  });\n   128→\n   129→  it(\"joins multi-line title (2 lines)\", async () => {\n   130→    const embed = createMockEmbed(\n   131→      [\"kurczak w sosie śmietanowym z pieczarkami\"],\n   132→      [\"składniki\"]\n   133→    );\n   134→    const text =\n   135→      \"Kurczak w sosie\\nśmietanowym z pieczarkami\\nSkładniki\\n200g kurczaka\";\n   136→    const result = await extractTitleWithEmbeddings(text, embed);\n   137→    expect(result).toBe(\"Kurczak w sosie śmietanowym z pieczarkami\");\n   138→  });\n   139→\n   140→  it(\"joins multi-line title (3 lines)\", async () => {\n   141→    const embed = createMockEmbed(\n   142→      [\"makaron z sosem pomidorowym i bazylią\"],\n   143→      [\"składniki\"]\n   144→    );\n   145→    const text =\n   146→      \"Makaron z sosem\\npomidorowym\\ni bazylią\\nSkładniki\\n300g makaronu\";\n   147→    const result = await extractTitleWithEmbeddings(text, embed);\n   148→    expect(result).toBe(\"Makaron z sosem pomidorowym i bazylią\");\n   149→  });\n   150→\n   151→  it(\"does not over-greedily join title with header\", async () => {\n   152→    const embed = createMockEmbed([\"apple pie\"], [\"ingredients\"]);\n   153→    const text = \"Apple Pie\\nIngredients\\n200g flour\";\n   154→    const result = await extractTitleWithEmbeddings(text, embed);\n   155→    // Should prefer \"Apple Pie\" alone, not \"Apple Pie Ingredients\"\n   156→    expect(result).toBe(\"Apple Pie\");\n   157→  });\n   158→\n   159→  it(\"returns multiple titles joined with + when both score well\", async () => {\n   160→    const embed = createMockEmbed(\n   161→      [\"first recipe\", \"second recipe\"],\n   162→      []\n   163→    );\n   164→    const text = \"First Recipe\\nSecond Recipe\\nSome other text\";\n   165→    const result = await extractTitleWithEmbeddings(text, embed);\n   166→    expect(result).toBe(\"First Recipe + Second Recipe\");\n   167→  });\n   168→\n   169→  it(\"skips burst of short lines at start and finds title after\", async () => {\n   170→    const embed = createMockEmbed([\"beef stew\"], [\"ingredients\"]);\n   171→    // 3+ short garbled lines at start, then real content with a long line\n   172→    const text =\n   173→      \"pg 42\\nA.\\nfoo\\nThis is a longer line that triggers burst end detection\\nBeef Stew\\nIngredients\\n500g beef\";\n   174→    const result = await extractTitleWithEmbeddings(text, embed);\n   175→    expect(result).toBe(\"Beef Stew\");\n   176→  });\n   177→\n   178→  it(\"two titles deep in text returns both joined\", async () => {\n   179→    const embed = createMockEmbed(\n   180→      [\"pasta carbonara\", \"tiramisu classico\"],\n   181→      [\"ingredients\", \"składniki\"]\n   182→    );\n   183→    const text =\n   184→      \"Ingredients\\nPasta Carbonara\\n200g pasta\\n100g guanciale\\nIngredients\\nTiramisu Classico\\n250g mascarpone\";\n   185→    const result = await extractTitleWithEmbeddings(text, embed);\n   186→    expect(result).toBe(\"Pasta Carbonara + Tiramisu Classico\");\n   187→  });\n   188→\n   189→  it(\"single-recipe page still returns one title\", async () => {\n   190→    const embed = createMockEmbed([\"tomato soup\"], [\"ingredients\"]);\n   191→    const text = \"Tomato Soup\\nIngredients\\n4 tomatoes\\n1 cup cream\\nSalt\";\n   192→    const result = await extractTitleWithEmbeddings(text, embed);\n   193→    expect(result).toBe(\"Tomato Soup\");\n   194→  });\n   195→\n   196→  it(\"keeps 2-word ALL_CAPS join over its single-word prefix (ARAYES-type)\", async () => {\n   197→    // \"ARAYES\" alone is 1 word → never qualifies as firstStructuralHeading.\n   198→    // \"ARAYES SHRAK\" qualifies → pre-filter removes \"ARAYES\" so dedup keeps the join.\n   199→    const embed = createMockEmbed([\"arayes\"], [\"ingredients\"]);\n   200→    const text = \"ARAYES\\nSHRAK\\nIngredients\\n2 cups flour\";\n   201→    const result = await extractTitleWithEmbeddings(text, embed);\n   202→    expect(result).toBe(\"ARAYES SHRAK\");\n   203→  });\n   204→\n   205→  it(\"keeps 2-line ALL_CAPS join when suffix is a food-category label (VEGETABLES-type)\", async () => {\n   206→    // \"LEMON HERB ROASTED\" qualifies as a structural heading on its own (3 words ALL_CAPS).\n   207→    // \"LEMON HERB ROASTED VEGETABLES\" is its 2-line join. The dedup shorter-wins rule would\n   208→    // normally drop the join in favour of the shorter prefix — but \"VEGETABLES\" is in\n   209→    // CATEGORY_SECTION_LABELS, so the protection keeps the full joined form.\n   210→    const embed = createMockEmbed([\"lemon herb roasted vegetables\"], [\"ingredients\"]);\n   211→    const text = \"LEMON HERB ROASTED\\nVEGETABLES\\nIngredients\\n2 cups broth\";\n   212→    const result = await extractTitleWithEmbeddings(text, embed);\n   213→    expect(result).toBe(\"LEMON HERB ROASTED VEGETABLES\");\n   214→  });\n   215→\n   216→  it(\"extends ALL_CAPS structural heading when next line starts with continuation token (SAFFRON-type)\", async () => {\n   217→    // \"TITLE FIRST PART\" qualifies as structural heading; continuation upgrades it to the join.\n   218→    // Pre-filter then removes the partial so dedup keeps the complete join.\n   219→    const embed = createMockEmbed([\"title first part\"], [\"ingredients\"]);\n   220→    const text = \"TITLE FIRST PART\\n/ SECOND PART\\nIngredients\\n1 cup flour\";\n   221→    const result = await extractTitleWithEmbeddings(text, embed);\n   222→    expect(result).toBe(\"TITLE FIRST PART / SECOND PART\");\n   223→  });\n   224→\n   225→  it(\"pre-merges continuation line starting with & into preceding line (Baked Eggs type)\", async () => {\n   226→    // \"& Coriander\" starts with & so it's merged into the preceding line before candidate\n   227→    // generation — the complete title enters the pool as a single candidate.\n   228→    const embed = createMockEmbed(\n   229→      [\"baked eggs with feta\"],\n   230→      [\"ingredients\"]\n   231→    );\n   232→    const text =\n   233→      \"Baked Eggs with Feta, Harissa Tomato Sauce\\n& Coriander\\nIngredients\\n2 eggs\";\n   234→    const result = await extractTitleWithEmbeddings(text, embed);\n   235→    expect(result).toBe(\"Baked Eggs with Feta, Harissa Tomato Sauce & Coriander\");\n   236→  });\n   237→\n   238→  it(\"does not pre-merge second line that lacks a continuation character (ARAYES-type safety)\", async () => {\n   239→    // \"SHRAK\" does not start with /&+:( so it is NOT pre-merged.\n   240→    // The existing structural heading join logic handles it instead.\n   241→    const embed = createMockEmbed([\"arayes\"], [\"ingredients\"]);\n   242→    const text = \"ARAYES\\nSHRAK\\nIngredients\\n2 cups flour\";\n   243→    const result = await extractTitleWithEmbeddings(text, embed);\n   244→    expect(result).toBe(\"ARAYES SHRAK\");\n   245→  });\n   246→\n   247→  it(\"returns only the first ALL_CAPS heading when subsequent ALL_CAPS headings are section headers followed by ingredients (CHLEBEK type)\", async () => {\n   248→    // WARZYWA I BOCZEK is immediately followed by ingredient lines (numbers) →\n   249→    // it's a section header, not a second recipe title. Keep only CHLEBEK Z WARZYWAMI I BOCZKIEM.\n   250→    const embed = createMockEmbed(\n   251→      [\"chlebek z warzywami i boczkiem\", \"warzywa i boczek\"],\n   252→      []\n   253→    );\n   254→    const text = [\n   255→      \"CHLEBEK Z WARZYWAMI I BOCZKIEM\",\n   256→      \"WARZYWA I BOCZEK\",\n   257→      \"500 g strączków zielonego groszku\",\n   258→      \"1 żółta papryka\",\n   259→      \"CHLEBEK\",\n   260→      \"500 g mąki\",\n   261→    ].join(\"\\n\");\n   262→    const result = await extractTitleWithEmbeddings(text, embed);\n   263→    expect(result).toBe(\"CHLEBEK Z WARZYWAMI I BOCZKIEM\");\n   264→  });\n   265→\n   266→  it(\"returns both ALL_CAPS titles when headings are NOT followed by ingredient lines (FINNISH-type)\", async () => {\n   267→    // POTATO FLATBREADS is followed by body text, not ingredients →\n   268→    // these are two separate recipe titles on a multi-recipe page.\n   269→    const embed = createMockEmbed(\n   270→      [\"milk flatbreads\", \"potato flatbreads\"],\n   271→      []\n   272→    );\n   273→    const text = [\n   274→      \"MILK FLATBREADS\",\n   275→      \"Mix flour with milk and knead\",\n   276→      \"Cook on a dry skillet\",\n   277→      \"POTATO FLATBREADS\",\n   278→      \"Boil potatoes until tender\",\n   279→      \"Mash well before mixing\",\n   280→    ].join(\"\\n\");\n   281→    const result = await extractTitleWithEmbeddings(text, embed);\n   282→    expect(result).toBe(\"MILK FLATBREADS + POTATO FLATBREADS\");\n   283→  });\n   284→\n   285→  it(\"filters bullet-list lines so real title wins\", async () => {\n   286→    const embed = createMockEmbed([\"mozzarella sticks\"], []);\n   287→    const text = \"MOZZARELLA STICKS\\n- 2 tbsp sugar\\n- Salt to taste\";\n   288→    const result = await extractTitleWithEmbeddings(text, embed);\n   289→    expect(result).toBe(\"MOZZARELLA STICKS\");\n   290→  });\n   291→\n   292→  it(\"filters INGREDIENTS section label so real ALL_CAPS title wins\", async () => {\n   293→    const embed = createMockEmbed([\"mozzarella sticks\"], []);\n   294→    const text = \"INGREDIENTS\\nMOZZARELLA STICKS\\n- 2 tbsp sugar\";\n   295→    const result = await extractTitleWithEmbeddings(text, embed);\n   296→    expect(result).toBe(\"MOZZARELLA STICKS\");\n   297→  });\n   298→\n   299→  it(\"filters compact metric ingredient lines so real title wins\", async () => {\n   300→    const embed = createMockEmbed([\"barszcz czerwony\"], []);\n   301→    const text = \"BARSZCZ CZERWONY\\n100g buraków\\n50ml bulionu\";\n   302→    const result = await extractTitleWithEmbeddings(text, embed);\n   303→    expect(result).toBe(\"BARSZCZ CZERWONY\");\n   304→  });\n   305→\n   306→  it(\"prefers mixed-case title at position 0 over ALL_CAPS subtitle at position 1 (bilingual page)\", async () => {\n   307→    // \"Faszerowana papryka\" is the Polish title at position 0 (mixed-case).\n   308→    // \"PAPRIKA GYERAN-JJIM\" is an ALL_CAPS romanization at position 1 — treated as subtitle.\n   309→    const embed = createMockEmbed(\n   310→      [\"faszerowana papryka\", \"paprika gyeran\"],\n   311→      []\n   312→    );\n   313→    const text =\n   314→      \"Faszerowana papryka\\nPAPRIKA GYERAN-JJIM\\nIngredients\\n200g peppers\";\n   315→    const result = await extractTitleWithEmbeddings(text, embed);\n   316→    expect(result).toBe(\"Faszerowana papryka\");\n   317→  });\n   318→\n   319→  it(\"merges 4 consecutive short ALL_CAPS lines into one title (LABANEH-type)\", async () => {\n   320→    // Each OCR line is ≤2 words and ≤25 chars — the short-caps merge pass coalesces them.\n   321→    const embed = createMockEmbed([\"labaneh\"], []);\n   322→    const text = [\n   323→      \"LABANEH\",\n   324→      \"BALLS\",\n   325→      \"WITH NIGELLA\",\n   326→      \"SEEDS\",\n   327→      \"Essential to blending the flavours together\",\n   328→    ].join(\"\\n\");\n   329→    const result = await extractTitleWithEmbeddings(text, embed);\n   330→    expect(result).toBe(\"LABANEH BALLS WITH NIGELLA SEEDS\");\n   331→  });\n   332→\n   333→  it(\"short-caps merge breaks at a section label, preventing spurious joins\", async () => {\n   334→    // WORD ONE and WORD TWO are short ALL_CAPS, but INGREDIENTS (section label) sits between\n   335→    // them and breaks the run — they should NOT be merged into \"WORD ONE WORD TWO\".\n   336→    const embed = createMockEmbed([\"word one\"], []);\n   337→    const text = [\n   338→      \"WORD ONE\",\n   339→      \"INGREDIENTS\",\n   340→      \"WORD TWO\",\n   341→      \"Some body text here to fill the page\",\n   342→    ].join(\"\\n\");\n   343→    const result = await extractTitleWithEmbeddings(text, embed);\n   344→    // WORD ONE wins (title word); WORD TWO is a separate candidate but scores lower.\n   345→    // The key assertion: no \"WORD ONE INGREDIENTS WORD TWO\" merged result.\n   346→    expect(result).toBe(\"WORD ONE\");\n   347→  });\n   348→\n   349→  it(\"short-caps merge does not fire when a line exceeds 2 words\", async () => {\n   350→    // \"THREE WORD LINE\" has 3 words — above the ≤2 limit — so it is never the start of a merge run.\n   351→    const embed = createMockEmbed([\"three word line\"], []);\n   352→    const text = [\n   353→      \"THREE WORD LINE\",\n   354→      \"ANOTHER LINE\",\n   355→      \"Body text follows here\",\n   356→    ].join(\"\\n\");\n   357→    const result = await extractTitleWithEmbeddings(text, embed);\n   358→    // Candidates are generated individually; no spurious merge of the two lines by the caps pass.\n   359→    // \"THREE WORD LINE ANOTHER LINE\" may appear as a downstream 2-line join candidate but\n   360→    // \"THREE WORD LINE\" wins as the structural heading (more words, higher rawScore from title word).\n   361→    expect(result).toBe(\"THREE WORD LINE\");\n   362→  });\n   363→\n   364→  it(\"filters OCR-corrupted serving size 'DLA & OSOB' so mixed-case title wins\", async () => {\n   365→    // \"DLA & OSOB\" is OCR-corrupted Polish \"DLA 4 OSÓB\" (for 4 people) — metadata, not a title.\n   366→    // The expanded DLA pattern matches even when the digit is corrupted to a symbol.\n   367→    const embed = createMockEmbed([\"smażona zielona fasolka\"], []);\n   368→    const text = [\n   369→      \"Smażona zielona fasolka\",\n   370→      \"DLA & OSOB\",\n   371→      \"200g fasolki\",\n   372→      \"1 cebula\",\n   373→    ].join(\"\\n\");\n   374→    const result = await extractTitleWithEmbeddings(text, embed);\n   375→    expect(result).toBe(\"Smażona zielona fasolka\");\n   376→  });\n   377→\n   378→  it(\"layout-based bilingual detection suppresses ALL_CAPS romanization with no word overlap\", async () => {\n   379→    // Mixed-case title at position 0 (≥2 words) + ALL_CAPS candidate at position 1 with no\n   380→    // words in common → layout guard fires and suppresses the ALL_CAPS candidate.\n   381→    const embed = createMockEmbed([\"mixed case title\", \"all caps different\"], []);\n   382→    const text = [\n   383→      \"Mixed Case Title\",\n   384→      \"ALL CAPS DIFFERENT\",\n   385→      \"Body text that fills the rest of the page\",\n   386→    ].join(\"\\n\");\n   387→    const result = await extractTitleWithEmbeddings(text, embed);\n   388→    expect(result).toBe(\"Mixed Case Title\");\n   389→  });\n   390→\n   391→  describe(\"corroboration (multi-title filtering)\", () => {\n   392→    it(\"rejects orphaned OCR artifact in multi-title assembly\", async () => {\n   393→      // \"DAT FLATBREADS\" is an OCR artifact from a preceding page — \"DAT\" doesn't appear\n   394→      // anywhere else in the document, so it fails the 100% corroboration threshold.\n   395→      // \"FINNISH MILK FLATBREADS\" and \"FINNISH POTATO FLATBREADS\" are both corroborated\n   396→      // by their words appearing in the body text.\n   397→      const embed = createMockEmbed(\n   398→        [\"dat flatbreads\", \"finnish milk flatbreads\", \"finnish potato flatbreads\"],\n   399→        []\n   400→      );\n   401→      const input = [\n   402→        \"2 cup plus 1 tablespoon mixer fried with for 5 minutes\",\n   403→        \"nto a loured work counter shape into ball\",\n   404→        \"DAT FLATBREADS\",\n   405→        \"le Finnish region of Savo bread more like a\",\n   406→        \"\",\n   407→        \"FINNISH MILK FLATBREADS\",\n   408→        \"\",\n   409→        \"These traditional flatbreads are soft and delicious\",\n   410→        \"served warm with butter and milk\",\n   411→        \"500g flour\",\n   412→        \"300ml milk\",\n   413→        \"1 tsp salt\",\n   414→        \"\",\n   415→        \"Mix the flour and milk together until smooth\",\n   416→        \"Let the dough rest for 30 minutes\",\n   417→        \"\",\n   418→        \"FINNISH POTATO FLATBREADS\",\n   419→        \"\",\n   420→        \"Finnish potato flatbreads are hearty and filling\",\n   421→        \"3 large potatoes\",\n   422→        \"200g flour\",\n   423→        \"butter for frying\",\n   424→        \"\",\n   425→        \"Boil the potatoes until tender then mash\",\n   426→        \"Mix mashed potato with flour and salt\",\n   427→      ].join(\"\\n\");\n   428→\n   429→      const result = await extractTitleWithEmbeddings(input, embed);\n   430→      expect(result).toBe(\"FINNISH MILK FLATBREADS + FINNISH POTATO FLATBREADS\");\n   431→    });\n   432→\n   433→    it(\"keeps legitimate multi-recipe titles that are corroborated\", async () => {\n   434→      // Both CHICKEN SOUP and BEEF STEW have their words in the document body,\n   435→      // so both pass corroboration and are returned.\n   436→      const embed = createMockEmbed([\"chicken soup\", \"beef stew\"], []);\n   437→      const input = [\n   438→        \"CHICKEN SOUP\",\n   439→        \"\",\n   440→        \"A classic chicken soup recipe\",\n   441→        \"1 whole chicken\",\n   442→        \"2 carrots\",\n   443→        \"salt and pepper\",\n   444→        \"\",\n   445→        \"Place the chicken in a large pot\",\n   446→        \"\",\n   447→        \"BEEF STEW\",\n   448→        \"\",\n   449→        \"A hearty beef stew for cold days\",\n   450→        \"500g beef chuck\",\n   451→        \"3 potatoes\",\n   452→        \"2 onions\",\n   453→        \"\",\n   454→        \"Cut the beef into cubes\",\n   455→      ].join(\"\\n\");\n   456→\n   457→      const result = await extractTitleWithEmbeddings(input, embed);\n   458→      expect(result).toBe(\"CHICKEN SOUP + BEEF STEW\");\n   459→    });\n   460→\n   461→    it(\"does not apply corroboration to single-title pages\", async () => {\n   462→      // Corroboration only runs when ≥2 ALL_CAPS candidates are selected.\n   463→      // A single ALL_CAPS title is returned as-is regardless of vocabulary overlap.\n   464→      const embed = createMockEmbed([\"golonka pieczona\"], []);\n   465→      const input = [\n   466→        \"GOLONKA PIECZONA\",\n   467→        \"\",\n   468→        \"Składniki na 4 porcje\",\n   469→        \"1 kg mięsa\",\n   470→        \"2 cebule\",\n   471→        \"3 ząbki czosnku\",\n   472→        \"\",\n   473→        \"Mięso umyć i osuszyć\",\n   474→        \"Cebulę pokroić w plastry\",\n   475→      ].join(\"\\n\");\n   476→\n   477→      const result = await extractTitleWithEmbeddings(input, embed);\n   478→      expect(result).toBe(\"GOLONKA PIECZONA\");\n   479→    });\n   480→  });\n   481→});\n   482→"}]},"parent_tool_use_id":"toolu_01HPYA7eLe1orHqY39Ex7h1D","session_id":"66d6120a-7fee-4673-bb0a-75db3320d34d","uuid":"6e793475-67e2-40a3-8cfe-35a9e935e228"}
