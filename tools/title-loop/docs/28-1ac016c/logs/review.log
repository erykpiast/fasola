{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_011cj8iARCrGy35wf5WCwKbD","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01A2CtzmMEFsvU4kGCwc3G27","name":"Read","input":{"file_path":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/title-extractor.ts","offset":1344,"limit":250},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":6025,"cache_read_input_tokens":37981,"cache_creation":{"ephemeral_5m_input_tokens":6025,"ephemeral_1h_input_tokens":0},"output_tokens":18,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01Es9TDQPf3NedsZAii36MzQ","session_id":"66d6120a-7fee-4673-bb0a-75db3320d34d","uuid":"9a98b34b-83cb-4841-a6bc-c3df6d2cbc27"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KzFTyfQ5ec8raiJDMc4eHc","type":"tool_result","content":"  1200→      (s) => isAllCaps(s.text) && s.position >= 1 && s.position <= 2 && s.origin === \"single\"\n  1201→    );\n  1202→    const pos0Embedding = rawScored.find((r) => r.text === prePos0.text)?.embedding;\n  1203→\n  1204→    // Method 1: embedding similarity (works for related languages)\n  1205→    if (pos0Embedding && nearbyAllCaps.length > 0) {\n  1206→      translationCandidates = nearbyAllCaps.filter((cap) => {\n  1207→        const capEmbedding = rawScored.find((r) => r.text === cap.text)?.embedding;\n  1208→        if (!capEmbedding) return false;\n  1209→        return cosineSimilarity(pos0Embedding, capEmbedding) > 0.4;\n  1210→      });\n  1211→    }\n  1212→\n  1213→    // Method 2: layout-based detection (cross-lingual fallback).\n  1214→    // When embedding similarity is insufficient (e.g. Polish ↔ Korean romanization),\n  1215→    // detect bilingual layout by position and word overlap:\n  1216→    // mixed-case ≥2 words at pos 0 + ALL_CAPS ≥2 words at pos 1-2 with no shared words.\n  1217→    if (translationCandidates.length === 0 && wordCount(prePos0.text) >= 2) {\n  1218→      const pos0Words = new Set(\n  1219→        prePos0.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2)\n  1220→      );\n  1221→      translationCandidates = nearbyAllCaps.filter((cap) => {\n  1222→        if (wordCount(cap.text) < 2) return false;\n  1223→        const capWords = cap.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2);\n  1224→        return !capWords.some((w) => pos0Words.has(w));\n  1225→      });\n  1226→    }\n  1227→\n  1228→    if (translationCandidates.length > 0) {\n  1229→      // Suppress standalone translations and any multi-line joins that embed the translation\n  1230→      // as a suffix or substring (e.g. \"Smażona zielona fasolka GREEN BEANS BORKEUM\" ends with\n  1231→      // the translation; \"Title GREEN BEANS BORKEUM 그린빈\" includes it as a substring).\n  1232→      scoredForThreshold = scored.filter((s) => {\n  1233→        const sLower = s.text.toLowerCase();\n  1234→        return !translationCandidates.some((t) => {\n  1235→          const tLower = t.text.toLowerCase();\n  1236→          return sLower.startsWith(tLower) ||\n  1237→                 sLower.endsWith(\" \" + tLower) ||\n  1238→                 sLower.includes(\" \" + tLower);\n  1239→        });\n  1240→      });\n  1241→    }\n  1242→  }\n  1243→\n  1244→  // Fix 2: If the structural heading was identified as a bilingual translation, reassign it.\n  1245→  // This prevents the translation's ALL_CAPS bonus from inflating the threshold and ensures\n  1246→  // the fallback path in scored also uses the correct heading.\n  1247→  if (\n  1248→    translationCandidates.length > 0 &&\n  1249→    firstStructuralHeading &&\n  1250→    translationCandidates.some((t) => t.text === firstStructuralHeading!.text)\n  1251→  ) {\n  1252→    const nonTranslationStructural = structuralCandidates.filter(\n  1253→      (sc) => !translationCandidates.some((t) => t.text === sc.text)\n  1254→    );\n  1255→    const newHeading = nonTranslationStructural.length > 0\n  1256→      ? nonTranslationStructural.reduce((a, b) => a.rawScore > b.rawScore ? a : b)\n  1257→      : undefined;\n  1258→\n  1259→    // Patch scored array: remove old structural bonus, apply new one\n  1260→    for (const s of scored) {\n  1261→      if (s.text === firstStructuralHeading.text) {\n  1262→        s.score -= 0.10;\n  1263→        s.baseScore -= 0.10;\n  1264→      }\n  1265→      if (newHeading && s.text === newHeading.text) {\n  1266→        s.score += 0.10;\n  1267→        s.baseScore += 0.10;\n  1268→      }\n  1269→    }\n  1270→    // Update reference for downstream prefix-removal logic\n  1271→    firstStructuralHeading = newHeading ?? undefined;\n  1272→  }\n  1273→\n  1274→  // Subtitle suppression: when a short mixed-case title at position 0 is followed by a\n  1275→  // longer mixed-case candidate at position 1-2, the longer one is a subtitle/translation.\n  1276→  // Apply a penalty so the primary title (position 0) wins.\n  1277→  const pos0Primary = scored.find((s) => s.position === 0 && !isAllCaps(s.text) && wordCount(s.text) <= 5);\n  1278→  if (pos0Primary) {\n  1279→    const subtitleCandidates = scored.filter((s) =>\n  1280→      s.position >= 1 && s.position <= 2 &&\n  1281→      !isAllCaps(s.text) &&\n  1282→      wordCount(s.text) > wordCount(pos0Primary.text) + 2\n  1283→    );\n  1284→    for (const sub of subtitleCandidates) {\n  1285→      sub.score -= 0.15;\n  1286→    }\n  1287→  }\n  1288→\n  1289→  // Bilingual layout pattern: [FoodName (≤2 words)]\\n[Translation (2-5 words, mixed-case)]\\n...[Section label]\n  1290→  // Common in bilingual cookbooks: foreign food name at position 0, English translation at position 1-2.\n  1291→  // When detected, boost the position-0 candidate so it clears the threshold.\n  1292→  // Note: the ALL_CAPS bilingual block above (lines 940-995) handles mixed-case + ALL_CAPS pairs.\n  1293→  // This block handles mixed-case + mixed-case translation pairs — the two do not overlap because\n  1294→  // the mixed-case guard (`biSecond.text !== biSecond.text.toUpperCase()`) excludes ALL_CAPS lines.\n  1295→  if (scored.length >= 2) {\n  1296→    const biFirst = scored.find((s) => s.position === 0);\n  1297→    // Restrict to single-line candidates (same guard as the ALL_CAPS bilingual block at line 953)\n  1298→    const biSecond = scored.find((s) => s.position >= 1 && s.position <= 2 && s !== biFirst && s.origin === \"single\");\n  1299→\n  1300→    if (biFirst && biSecond) {\n  1301→      const firstWords = biFirst.text.trim().split(/\\s+/);\n  1302→      const secondWords = biSecond.text.trim().split(/\\s+/);\n  1303→\n  1304→      const isBilingualLayout =\n  1305→        firstWords.length <= 2 &&\n  1306→        secondWords.length >= 2 &&\n  1307→        secondWords.length <= 5 &&\n  1308→        // Second line is mixed-case (not ALL_CAPS, not all-lower)\n  1309→        biSecond.text !== biSecond.text.toUpperCase() &&\n  1310→        biSecond.text !== biSecond.text.toLowerCase() &&\n  1311→        // Second line is not an ingredient or instruction\n  1312→        !looksLikeIngredient(biSecond.text) &&\n  1313→        !looksLikeCookingInstruction(biSecond.text);\n  1314→\n  1315→      if (isBilingualLayout) {\n  1316→        // Check if a section label follows within a few lines after the first candidate\n  1317→        const sectionLabelNearby = lines\n  1318→          .slice(biFirst.position + 1, biFirst.position + 6)\n  1319→          .some((line) => isSectionLabel(line.trim()));\n  1320→\n  1321→        if (sectionLabelNearby) {\n  1322→          biFirst.score += 0.15;\n  1323→          biFirst.baseScore += 0.15;\n  1324→          biFirst.thresholdScore += 0.15;\n  1325→        }\n  1326→      }\n  1327→    }\n  1328→  }\n  1329→\n  1330→  // Pre-filter: when ≥2 ALL_CAPS candidates are present, identify OCR artifacts (those whose\n  1331→  // vocabulary has no support elsewhere in the document) and remove them before computing the\n  1332→  // threshold. Artifacts like \"DAT FLATBREADS\" can inflate the threshold via their early-position\n  1333→  // bonus, which causes legitimate titles later in the document to fall just below the cutoff.\n  1334→  // Safety: only pre-filter if ≥2 candidates remain after removal (avoids false-positive removal\n  1335→  // of unique-vocabulary titles on two-recipe pages).\n  1336→  // NOTE: The ≥2 guard is conservative — when there are exactly 2 ALL_CAPS candidates and one is\n  1337→  // an artifact, the artifact is NOT removed. Relaxing to ≥1 causes regressions because 3-line\n  1338→  // join candidates (which span a section label) can pass corroboration via shared vocabulary,\n  1339→  // while the legitimate short title fails. See \"WORD ONE / INGREDIENTS / WORD TWO\" test case.\n  1340→  const allCapsInScored = scoredForThreshold.filter((s) => isAllCaps(s.text));\n  1341→  if (allCapsInScored.length >= 2) {\n  1342→    const artifactTexts = new Set(\n  1343→      allCapsInScored\n  1344→        .filter((cap) => !passesCorroboration(cap.text, cap.position, lines, burstEnd))\n  1345→        .map((c) => c.text)\n  1346→    );\n  1347→    if (artifactTexts.size > 0) {\n  1348→      const remainingCaps = allCapsInScored.filter((c) => !artifactTexts.has(c.text));\n  1349→      if (remainingCaps.length >= 2) {\n  1350→        scoredForThreshold = scoredForThreshold.filter((s) => !artifactTexts.has(s.text));\n  1351→      }\n  1352→    }\n  1353→  }\n  1354→\n  1355→  // Use thresholdScore (excludes structural bonus) so the structural bonus doesn't inflate\n  1356→  // the threshold and block equally-valid headings on multi-recipe pages.\n  1357→  const bestThresholdScore = Math.max(...scoredForThreshold.map((s) => s.thresholdScore));\n  1358→  const threshold = Math.max(0.08, bestThresholdScore * 0.7);\n  1359→\n  1360→  // Filter candidates above threshold\n  1361→  let selected = scoredForThreshold.filter((s) => s.score >= threshold);\n  1362→\n  1363→  // Empty-pool fallback: when threshold filtering discards every candidate,\n  1364→  // the hard filters' structural verdict should not be overruled by weak\n  1365→  // embedding differentiation. Return the best positional candidate only\n  1366→  // if it has a meaningful positive raw score (avoids ingredient-list leakage).\n  1367→  if (selected.length === 0 && scored.length > 0) {\n  1368→    const fallback = scored\n  1369→      .slice()\n  1370→      .sort((a, b) => a.position - b.position || b.score - a.score);\n  1371→    // Position-0 candidates that passed hard filters are very likely titles even with\n  1372→    // weak embedding signal. Relax the rawScore guard for early-position candidates.\n  1373→    const rawScoreThreshold = fallback[0].position <= 2 ? -0.05 : 0.02;\n  1374→    if (fallback[0].rawScore > rawScoreThreshold) {\n  1375→      selected = [fallback[0]];\n  1376→    }\n  1377→  }\n  1378→\n  1379→  // Title-absent page guard: when the page starts mid-recipe (all of the first 3 non-empty\n  1380→  // lines are ingredients or cooking instructions), require a much higher rawScore and\n  1381→  // discard candidates deep in the file. This prevents stray body text or adjacent recipe\n  1382→  // titles from being picked up on pages with no title (Pattern 4).\n  1383→  if (titleAbsent) {\n  1384→    const titleAbsentThreshold = 0.10;\n  1385→    selected = selected.filter(s => s.rawScore >= titleAbsentThreshold);\n  1386→    selected = selected.filter(s => s.position <= 2);\n  1387→  }\n  1388→\n  1389→  // Remove word-boundary prefixes of firstStructuralHeading when the heading itself survived\n  1390→  // the threshold. Cases:\n  1391→  //   ARAYES case:  firstStructuralHeading = \"ARAYES SHRAK\" (2-word join qualifies; \"ARAYES\"\n  1392→  //     alone = 1 word, so it never qualified). Filter removes \"ARAYES\" so dedup keeps the join.\n  1393→  //   SAFFRON case: baseHeading was the partial line; continuation logic above upgraded\n  1394→  //     firstStructuralHeading to the full join. Filter removes the partial so dedup keeps join.\n  1395→  // Safety: only fires when the complete heading itself is in selected (passed the threshold).\n  1396→  if (firstStructuralHeading && selected.some((s) => s.text === firstStructuralHeading.text)) {\n  1397→    const fshLower = firstStructuralHeading.text.toLowerCase();\n  1398→    selected = selected.filter((s) => {\n  1399→      if (s.text === firstStructuralHeading.text) return true;"}]},"parent_tool_use_id":"toolu_01DWZvkYLSgR3KWoyc1JyPBq","session_id":"66d6120a-7fee-4673-bb0a-75db3320d34d","uuid":"e471aeb9-ddef-45b8-840e-5e4e05d9345a"}
