                       // pinch\n    44→  \"garść\",                               // handful\n    45→  \"opakowanie\", \"opakowania\",            // package(s)\n    46→  \"plasterek\", \"plasterki\",             // slice(s)\n    47→];\n    48→\n    49→/**\n    50→ * Patterns that identify recipe metadata lines (not titles)\n    51→ */\n    52→const METADATA_PATTERNS = [\n    53→  /^(SERVES?|MAKES?|YIELDS?)\\b/i,\n...\n</persisted-output>"}]},"parent_tool_use_id":"toolu_01DWZvkYLSgR3KWoyc1JyPBq","session_id":"66d6120a-7fee-4673-bb0a-75db3320d34d","uuid":"8ad139f6-d113-4aa7-b82c-ec341a40f56d"}
