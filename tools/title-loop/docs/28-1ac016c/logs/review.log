{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011DjnwefCtpuwfM7JHBgEVe","type":"tool_result","content":"  1050→    }\n  1051→  }\n  1052→\n  1053→  const bestStructural = structuralCandidates.length > 0\n  1054→    ? structuralCandidates.reduce((a, b) => {\n  1055→        const scoreDiff = a.rawScore - b.rawScore;\n  1056→        if (Math.abs(scoreDiff) > 0.03) return scoreDiff > 0 ? a : b;\n  1057→        // Tiebreak: single-line origin beats multi-line joins (avoids conflating two separate headings)\n  1058→        if (a.origin === \"single\" && b.origin !== \"single\") return a;\n  1059→        if (b.origin === \"single\" && a.origin !== \"single\") return b;\n  1060→        // Tiebreak: more words (more specific) → better\n  1061→        const wcDiff = wordCount(b.text) - wordCount(a.text);\n  1062→        if (wcDiff !== 0) return wcDiff > 0 ? b : a;\n  1063→        // Tiebreak: earlier position → better\n  1064→        return a.position < b.position ? a : b;\n  1065→      })\n  1066→    : null;\n  1067→  const baseHeading = bestStructural ?? undefined;\n  1068→\n  1069→  // When the best structural heading has a continuation on the next line introduced by a\n  1070→  // punctuation token (/, &, +, :, or parenthesis), prefer the longer 2-line join as the\n  1071→  // complete heading. E.g. \"SAFFRON WHEAT BUNS WITH QUARK\" + \"/ COTTAGE CHEESE (VARIATION D)\".\n  1072→  // Guard: the remainder after the prefix must start with a continuation character to avoid\n  1073→  // merging two separate consecutive recipe titles (FINNISH MILK FLATBREADS stays separate\n  1074→  // from FINNISH POTATO FLATBREADS because \"FINNISH\" does not start with a continuation token).\n  1075→  let firstStructuralHeading = baseHeading && (\n  1076→    rawScored.find((c) => {\n  1077→      if (!isStructuralHeading(c)) return false;\n  1078→      const hLower = baseHeading.text.toLowerCase();\n  1079→      const cLower = c.text.toLowerCase();\n  1080→      return cLower.startsWith(hLower + \" \") && /^[/&+:(]/.test(cLower.slice(hLower.length + 1));\n  1081→    }) ?? baseHeading\n  1082→  );\n  1083→\n  1084→  // Pass 2: apply bonuses\n  1085→  const scored: Array<{ text: string; position: number; origin: CandidateOrigin; score: number; rawScore: number; baseScore: number; thresholdScore: number }> = rawScored.map((rs, candidateIndex) => {\n  1086→    // Position factor: multiplicative tiebreaker — amplifies existing signal, doesn't replace it.\n  1087→    // Use candidate-relative position (rank among candidates that passed hard filters) rather than\n  1088→    // raw line position, so filtered preamble lines don't penalize the first real candidate.\n  1089→    const candidateRelativePosition = candidateIndex / rawScored.length;\n  1090→    const positionFactor = candidateRelativePosition < 0.5\n  1091→      ? 1.0 + 0.12 * (1 - candidateRelativePosition * 2)\n  1092→      : 1.0;\n  1093→\n  1094→    // ALL_CAPS bonus: recipe books use ALL_CAPS for titles and section headings.\n  1095→    // Single-word ALL_CAPS terms are overwhelmingly section/category labels, not recipe titles;\n  1096→    // real recipe titles in ALL_CAPS are almost always multi-word. Reduce the bonus for single words.\n  1097→    const allCapsBonus = isAllCaps(rs.text) && rs.text.replace(/[^a-zA-Z]/g, \"\").length >= 4\n  1098→      ? (wordCount(rs.text) >= 2 ? 0.08 : 0.03)\n  1099→      : 0;\n  1100→\n  1101→    // Structural heading bonus: best ALL_CAPS heading (or its continuation join) is almost always the recipe title\n  1102→    const structuralBonus = firstStructuralHeading && rs.text === firstStructuralHeading.text ? 0.10 : 0;\n  1103→\n  1104→    // thresholdScore excludes structural bonus so the bonus doesn't inflate the threshold\n  1105→    // and prevent equally-valid structural headings from passing on multi-recipe pages.\n  1106→    const thresholdScore = rs.rawScore + allCapsBonus;\n  1107→    // baseScore excludes position factor — used for diagnostics and ranking\n  1108→    const baseScore = rs.rawScore + allCapsBonus + structuralBonus;\n  1109→    const score = rs.rawScore * positionFactor + allCapsBonus + structuralBonus;\n  1110→    return { text: rs.text, position: rs.position, origin: rs.origin, score, rawScore: rs.rawScore, baseScore, thresholdScore };\n  1111→  });\n  1112→\n  1113→  if (scored.length === 0) {\n  1114→    return undefined;\n  1115→  }\n  1116→\n  1117→  // First-after-preamble bonus (Pattern 3): when lines before the first candidate were all\n  1118→  // filtered/empty, the first surviving candidate occupies the structural \"title position\".\n  1119→  // E.g. \"FISH & SEAFOOD\\nHalibut with Saffron Cream Sauce\\n...\" — \"FISH & SEAFOOD\" is filtered\n  1120→  // as a section label, so \"Halibut...\" is the first candidate and gets this boost.\n  1121→  const firstCandidate = scored[0];\n  1122→  // Capture base score before positional bonuses to cap combined boost later\n  1123→  const baseScoreBeforePositionalBonuses = firstCandidate.baseScore;\n  1124→  if (firstCandidate.position > 0) {\n  1125→    const allPrecedingFiltered = lines\n  1126→      .slice(0, firstCandidate.position)\n  1127→      .every((line) => {\n  1128→        const trimmed = line.trim();\n  1129→        return trimmed === \"\" || !passesHardFilters(trimmed) || isSectionLabel(trimmed);\n  1130→      });\n  1131→    if (allPrecedingFiltered) {\n  1132→      // Stronger bonus when preamble contained structural markers (section labels, metadata)\n  1133→      // vs. only empty lines — structural markers are stronger positional evidence.\n  1134→      const hasStructuralPreamble = lines\n  1135→        .slice(0, firstCandidate.position)\n  1136→        .some((line) => {\n  1137→          const trimmed = line.trim();\n  1138→          return trimmed !== \"\" && (isSectionLabel(trimmed) || looksLikeMetadata(trimmed) || trimmed.includes(\" | \"));\n  1139→        });\n  1140→      const preambleBonus = hasStructuralPreamble ? 0.12 : 0.08;\n  1141→      firstCandidate.score += preambleBonus;\n  1142→      firstCandidate.baseScore += preambleBonus;\n  1143→      firstCandidate.thresholdScore += preambleBonus;\n  1144→    }\n  1145→  }\n  1146→  // Direct-successor bonus: when the line immediately before this candidate is a\n  1147→  // section label, metadata, or pipe-separated line, the candidate is very likely\n  1148→  // the title that follows that header. This complements the first-after-preamble\n  1149→  // bonus which requires ALL preceding lines to be filtered — this one fires even\n  1150→  // when earlier non-filtered lines exist. Checked for the top 3 candidates only\n  1151→  // (ci <= 2) to prevent the bonus from firing on random mid-document lines.\n  1152→  for (let ci = 0; ci < scored.length && ci <= 2; ci++) {\n  1153→    const candidate = scored[ci];\n  1154→    if (candidate.position > 0) {\n  1155→      // Scan backward past blank lines to find nearest non-empty preceding line\n  1156→      let prevPos = candidate.position - 1;\n  1157→      while (prevPos >= 0 && lines[prevPos].trim() === \"\") {\n  1158→        prevPos--;\n  1159→      }\n  1160→      if (prevPos >= 0) {\n  1161→        const prevLine = lines[prevPos].trim();\n  1162→        const prevIsHeader =\n  1163→          isSectionLabel(prevLine) ||\n  1164→          looksLikeMetadata(prevLine) ||\n  1165→          prevLine.includes(\" | \");\n  1166→        if (prevIsHeader) {\n  1167→          candidate.score += 0.10;\n  1168→          candidate.baseScore += 0.10;\n  1169→          candidate.thresholdScore += 0.10;\n  1170→        }\n  1171→      }\n  1172→    }\n  1173→  }\n  1174→\n  1175→  // Cap combined positional boost (position factor + first-after-preamble + direct-successor)\n  1176→  // to avoid over-boosting when multiple bonuses fire together. Applied after all positional\n  1177→  // bonuses so the cap covers all of them (per improvement plan: shared +0.15 max).\n  1178→  const maxPositionalBoost = 0.15;\n  1179→  const totalPositionalBoost = firstCandidate.score - baseScoreBeforePositionalBonuses;\n  1180→  if (totalPositionalBoost > maxPositionalBoost) {\n  1181→    const excess = totalPositionalBoost - maxPositionalBoost;\n  1182→    firstCandidate.score -= excess;\n  1183→    firstCandidate.baseScore -= excess;\n  1184→    firstCandidate.thresholdScore -= excess;\n  1185→  }\n  1186→\n  1187→  // --- Pre-threshold bilingual title detection ---\n  1188→  // When a mixed-case candidate at position 0 is followed by an ALL_CAPS candidate\n  1189→  // at position ≤ 2 that is semantically similar to it, this is a bilingual recipe\n  1190→  // page (e.g., Polish title + ALL_CAPS Korean romanization). Suppress confirmed\n  1191→  // translation candidates before computing threshold so their bonuses don't inflate\n  1192→  // the threshold beyond the mixed-case title's reach.\n  1193→  // Note: we check position ≤ 2 (local proximity), not global ALL_CAPS count, so\n  1194→  // section headers later in the document (SKŁADNIKI, WARZYWA, etc.) are irrelevant.\n  1195→  let translationCandidates: typeof scored = [];\n  1196→  let scoredForThreshold = scored;\n  1197→  const prePos0 = scored.find((s) => s.position === 0 && !isAllCaps(s.text));\n  1198→  if (prePos0) {\n  1199→    const nearbyAllCaps = scored.filter(\n  1200→      (s) => isAllCaps(s.text) && s.position >= 1 && s.position <= 2 && s.origin === \"single\"\n  1201→    );\n  1202→    const pos0Embedding = rawScored.find((r) => r.text === prePos0.text)?.embedding;\n  1203→\n  1204→    // Method 1: embedding similarity (works for related languages)\n  1205→    if (pos0Embedding && nearbyAllCaps.length > 0) {\n  1206→      translationCandidates = nearbyAllCaps.filter((cap) => {\n  1207→        const capEmbedding = rawScored.find((r) => r.text === cap.text)?.embedding;\n  1208→        if (!capEmbedding) return false;\n  1209→        return cosineSimilarity(pos0Embedding, capEmbedding) > 0.4;\n  1210→      });\n  1211→    }\n  1212→\n  1213→    // Method 2: layout-based detection (cross-lingual fallback).\n  1214→    // When embedding similarity is insufficient (e.g. Polish ↔ Korean romanization),\n  1215→    // detect bilingual layout by position and word overlap:\n  1216→    // mixed-case ≥2 words at pos 0 + ALL_CAPS ≥2 words at pos 1-2 with no shared words.\n  1217→    if (translationCandidates.length === 0 && wordCount(prePos0.text) >= 2) {\n  1218→      const pos0Words = new Set(\n  1219→        prePos0.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2)\n  1220→      );\n  1221→      translationCandidates = nearbyAllCaps.filter((cap) => {\n  1222→        if (wordCount(cap.text) < 2) return false;\n  1223→        const capWords = cap.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2);\n  1224→        return !capWords.some((w) => pos0Words.has(w));\n  1225→      });\n  1226→    }\n  1227→\n  1228→    if (translationCandidates.length > 0) {\n  1229→      // Suppress standalone translations and any multi-line joins that embed the translation\n  1230→      // as a suffix or substring (e.g. \"Smażona zielona fasolka GREEN BEANS BORKEUM\" ends with\n  1231→      // the translation; \"Title GREEN BEANS BORKEUM 그린빈\" includes it as a substring).\n  1232→      scoredForThreshold = scored.filter((s) => {\n  1233→        const sLower = s.text.toLowerCase();\n  1234→        return !translationCandidates.some((t) => {\n  1235→          const tLower = t.text.toLowerCase();\n  1236→          return sLower.startsWith(tLower) ||\n  1237→                 sLower.endsWith(\" \" + tLower) ||\n  1238→                 sLower.includes(\" \" + tLower);\n  1239→        });\n  1240→      });\n  1241→    }\n  1242→  }\n  1243→\n  1244→  // Fix 2: If the structural heading was identified as a bilingual translation, reassign it.\n  1245→  // This prevents the translation's ALL_CAPS bonus from inflating the threshold and ensures\n  1246→  // the fallback path in scored also uses the correct heading.\n  1247→  if (\n  1248→    translationCandidates.length > 0 &&\n  1249→    firstStructuralHeading &&\n  1250→    translationCandidates.some((t) => t.text === firstStructuralHeading!.text)\n  1251→  ) {\n  1252→    const nonTranslationStructural = structuralCandidates.filter(\n  1253→      (sc) => !translationCandidates.some((t) => t.text === sc.text)\n  1254→    );\n  1255→    const newHeading = nonTranslationStructural.length > 0\n  1256→      ? nonTranslationStructural.reduce((a, b) => a.rawScore > b.rawScore ? a : b)\n  1257→      : undefined;\n  1258→\n  1259→    // Patch scored array: remove old structural bonus, apply new one\n  1260→    for (const s of scored) {\n  1261→      if (s.text === firstStructuralHeading.text) {\n  1262→        s.score -= 0.10;\n  1263→        s.baseScore -= 0.10;\n  1264→      }\n  1265→      if (newHeading && s.text === newHeading.text) {\n  1266→        s.score += 0.10;\n  1267→        s.baseScore += 0.10;\n  1268→      }\n  1269→    }\n  1270→    // Update reference for downstream prefix-removal logic\n  1271→    firstStructuralHeading = newHeading ?? undefined;\n  1272→  }\n  1273→\n  1274→  // Subtitle suppression: when a short mixed-case title at position 0 is followed by a\n  1275→  // longer mixed-case candidate at position 1-2, the longer one is a subtitle/translation.\n  1276→  // Apply a penalty so the primary title (position 0) wins.\n  1277→  const pos0Primary = scored.find((s) => s.position === 0 && !isAllCaps(s.text) && wordCount(s.text) <= 5);\n  1278→  if (pos0Primary) {\n  1279→    const subtitleCandidates = scored.filter((s) =>\n  1280→      s.position >= 1 && s.position <= 2 &&\n  1281→      !isAllCaps(s.text) &&\n  1282→      wordCount(s.text) > wordCount(pos0Primary.text) + 2\n  1283→    );\n  1284→    for (const sub of subtitleCandidates) {\n  1285→      sub.score -= 0.15;\n  1286→    }\n  1287→  }\n  1288→\n  1289→  // Bilingual layout pattern: [FoodName (≤2 words)]\\n[Translation (2-5 words, mixed-case)]\\n...[Section label]\n  1290→  // Common in bilingual cookbooks: foreign food name at position 0, English translation at position 1-2.\n  1291→  // When detected, boost the position-0 candidate so it clears the threshold.\n  1292→  // Note: the ALL_CAPS bilingual block above (lines 940-995) handles mixed-case + ALL_CAPS pairs.\n  1293→  // This block handles mixed-case + mixed-case translation pairs — the two do not overlap because\n  1294→  // the mixed-case guard (`biSecond.text !== biSecond.text.toUpperCase()`) excludes ALL_CAPS lines.\n  1295→  if (scored.length >= 2) {\n  1296→    const biFirst = scored.find((s) => s.position === 0);\n  1297→    // Restrict to single-line candidates (same guard as the ALL_CAPS bilingual block at line 953)\n  1298→    const biSecond = scored.find((s) => s.position >= 1 && s.position <= 2 && s !== biFirst && s.origin === \"single\");\n  1299→\n  1300→    if (biFirst && biSecond) {\n  1301→      const firstWords = biFirst.text.trim().split(/\\s+/);\n  1302→      const secondWords = biSecond.text.trim().split(/\\s+/);\n  1303→\n  1304→      const isBilingualLayout =\n  1305→        firstWords.length <= 2 &&\n  1306→        secondWords.length >= 2 &&\n  1307→        secondWords.length <= 5 &&\n  1308→        // Second line is mixed-case (not ALL_CAPS, not all-lower)\n  1309→        biSecond.text !== biSecond.text.toUpperCase() &&\n  1310→        biSecond.text !== biSecond.text.toLowerCase() &&\n  1311→        // Second line is not an ingredient or instruction\n  1312→        !looksLikeIngredient(biSecond.text) &&\n  1313→        !looksLikeCookingInstruction(biSecond.text);\n  1314→\n  1315→      if (isBilingualLayout) {\n  1316→        // Check if a section label follows within a few lines after the first candidate\n  1317→        const sectionLabelNearby = lines\n  1318→          .slice(biFirst.position + 1, biFirst.position + 6)\n  1319→          .some((line) => isSectionLabel(line.trim