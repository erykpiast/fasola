{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Qu4YdqRRT7hStkVHZSfutR","type":"tool_result","content":"   350→  if (words.length < 4) return false;  // Instructions are multi-word sentences\n   351→  if (COOKING_INSTRUCTION_STARTS.test(text.trim())) return true;\n   352→  if (POLISH_COOKING_INSTRUCTION_STARTS.test(text.trim())) return true;\n   353→  return false;\n   354→}\n   355→\n   356→/**\n   357→ * A line starting with a lowercase letter and having 4+ words is prose continuation.\n   358→ * Recipe titles are capitalized (Title Case or ALL CAPS), so a lowercase-start line\n   359→ * is a strong signal for mid-recipe body text.\n   360→ */\n   361→function isBodyProse(line: string): boolean {\n   362→  return /^[a-ząćęłńóśźż]/.test(line) && wordCount(line) >= 4;\n   363→}\n   364→\n   365→/**\n   366→ * Detect pages where the OCR capture starts mid-recipe with no title present.\n   367→ * Returns true if the first 3 non-empty lines (after `startFrom`) are all ingredients,\n   368→ * cooking instructions, or body prose continuation text.\n   369→ */\n   370→function isTitleAbsentPage(lines: Array<string>, startFrom: number = 0): boolean {\n   371→  const relevantLines = startFrom > 0 ? lines.slice(startFrom) : lines;\n   372→  const nonEmptyLines = relevantLines.map(l => l.trim()).filter(l => l.length > 0);\n   373→\n   374→  if (nonEmptyLines.length < 3) return false;\n   375→\n   376→  const first3 = nonEmptyLines.slice(0, 3);\n   377→\n   378→  return first3.every(line =>\n   379→    looksLikeIngredient(line) ||\n   380→    looksLikeCookingInstruction(line) ||\n   381→    isBodyProse(line)\n   382→  );\n   383→}\n   384→\n   385→function passesHardFilters(text: string): boolean {\n   386→  if (text.length < 3 || text.length > 80) return false;\n   387→  if (looksLikeIngredient(text)) return false;\n   388→  if (startsWithNumber(text)) return false;\n   389→  if (looksLikeMetadata(text)) return false;\n   390→  if (isLikelyGarbled(text)) return false;\n   391→  if (looksLikeCookingInstruction(text)) return false;\n   392→  // Pipe-separated lines are book category/chapter headers, not recipe titles\n   393→  if (text.includes(\" | \")) return false;\n   394→  // Trailing page number (e.g. \"VEGETABLE SIDES                         145\")\n   395→  if (/\\s{3,}\\d{1,4}\\s*$/.test(text)) return false;\n   396→  // Slash-separated breadcrumbs (e.g., \"/ Jesien / Zupy\") are navigation, not titles\n   397→  // Only filter when 2+ slashes are present — single-slash lines like\n   398→  // \"TITLE / SUBTITLE\" are legitimate continuation-merged titles\n   399→  if ((text.match(/\\//g) || []).length >= 2) return false;\n   400→  // Bullet-list items (ingredients or instruction steps) are never titles\n   401→  if (/^\\s*[-•*]\\s/.test(text)) return false;\n   402→  // \"For the sauce:\", \"For the filling:\" etc. are sub-section headers\n   403→  if (/^For the\\s+/i.test(text) && /:\\s*$/.test(text)) return false;\n   404→  // Lines ending with \":\" are recipe sub-section headers, not titles.\n   405→  // Exception: compound titles using \" : \" as a title separator (e.g. \"LEMON CURD : LEMON CURD WITH THYME\").\n   406→  if (/:\\s*$/.test(text.trim()) && !/ : /.test(text)) return false;\n   407→  // Page references are navigation markers, not recipe titles\n   408→  if (/^Page\\s+\\d+/i.test(text.trim())) return false;\n   409→  if (/^Strona\\s+\\d+/i.test(text.trim())) return false;\n   410→  // Corrupted spillover annotations from synthetic multi-page OCR\n   411→  if (/^\\[CORRUPTED\\s+SPILLOVER/i.test(text.trim())) return false;\n   412→  // Parenthetical OCR annotation lines describing corruption artifacts\n   413→  if (/^\\(OCR\\b/i.test(text.trim())) return false;\n   414→  if (/^\\(.*\\bcorruption\\b/i.test(text.trim())) return false;\n   415→  // Square-bracket category tags (e.g., \"[CLASSIC FALL SOUPS]\")\n   416→  if (/^\\[.*\\]$/.test(text.trim())) return false;\n   417→  // Known recipe section labels are structural headers, not titles\n   418→  if (isSectionLabel(text)) return false;\n   419→  // Single-word non-title fragments\n   420→  const words = text.trim().split(/\\s+/);\n   421→  if (words.length === 1 && NON_TITLE_WORDS.has(text.trim().toLowerCase())) return false;\n   422→  // Lines with ≥8 words are almost certainly body text, not titles.\n   423→  // Exception: multi-title compounds with \" + \", \" : \", or \" & \" separators are allowed.\n   424→  if (words.length >= 8 && !/ [+:&/] /.test(text)) return false;\n   425→  return true;\n   426→}\n   427→\n   428→/**\n   429→ * Detect initial burst of short garbled lines.\n   430→ * Returns the index of the first non-garbled or long line.\n   431→ */\n   432→function findBurstEnd(lines: Array<{ text: string }>): number {\n   433→  let i = 0;\n   434→\n   435→  // Skip overflow preambles: blocks introduced by \"PREVIOUS RECIPE OVERFLOW\",\n   436→  // \"PREVIOUS PAGE CONTENT\", \"CORRUPTED SECTION\", etc. that precede the actual recipe.\n   437→  const OVERFLOW_MARKERS = /\\b(PREVIOUS\\s+(RECIPE|PAGE)\\b|SPILLOVER|CONTINUATION|CORRUPTED\\s+(SECTION|TEXT)\\b|PARTIAL\\s+RECIPE)\\b/i;\n   438→  let overflowEnd = 0;\n   439→  for (let k = 0; k < lines.length && k < 30; k++) {\n   440→    // Don't re-examine lines already determined to be overflow\n   441→    if (overflowEnd > 0 && k < overflowEnd) continue;\n   442→    if (OVERFLOW_MARKERS.test(lines[k].text) || /^\\[.*\\b(PREVIOUS|CORRUPTED|SPILLOVER|CONTINUATION|PARTIAL)\\b.*\\]$/i.test(lines[k].text)) {\n   443→      // Skip forward past the overflow block to the next visual separator or blank cluster\n   444→      let m = k + 1;\n   445→      let consecutiveBlanks = 0;\n   446→      while (m < lines.length) {\n   447→        const lineText = lines[m].text;\n   448→        // Stop at visual separator\n   449→        if (/^[=\\-]{4,}$/.test(lineText)) {\n   450→          overflowEnd = m + 1;\n   451→          break;\n   452→        }\n   453→        // Track consecutive blank lines\n   454→        if (lineText.trim().length === 0) {\n   455→          consecutiveBlanks++;\n   456→          if (consecutiveBlanks >= 2) {\n   457→            overflowEnd = m + 1;\n   458→            break;\n   459→          }\n   460→        } else {\n   461→          consecutiveBlanks = 0;\n   462→          // Stop at ALL_CAPS line with ≥2 words (likely next recipe heading)\n   463→          if (isAllCaps(lineText) && wordCount(lineText) >= 2) {\n   464→            overflowEnd = m; // Don't skip past the heading itself\n   465→            break;\n   466→          }\n   467→        }\n   468→        m++;\n   469→      }\n   470→      // If we walked to end without finding termination, skip everything we saw\n   471→      if (overflowEnd === 0) overflowEnd = m;\n   472→    }\n   473→  }\n   474→  if (overflowEnd > 0) i = overflowEnd;\n   475→\n   476→  while (i < lines.length && lines[i].text.length < 20 && isLikelyGarbled(lines[i].text) && !isAllCaps(lines[i].text)) {\n   477→    i++;\n   478→  }\n   479→  // Skip body-content prologues: when 3+ consecutive lines at the start are cooking\n   480→  // instructions, prose continuations, or a mix of both, skip them to find the actual\n   481→  // title region. This unifies the previous separate instruction and prose checks to\n   482→  // handle interleaved patterns (e.g., instruction → prose continuation → instruction).\n   483→  if (i === 0) {\n   484→    let j = 0;\n   485→    while (j < lines.length) {\n   486→      const t = lines[j].text;\n   487→      const isInstruction = looksLikeCookingInstruction(t);\n   488→      const isProse = (\n   489→        /^[a-ząćęłńóśźż]/.test(t) ||\n   490→        t.endsWith(\",\") ||\n   491→        (t.endsWith(\".\") && wordCount(t) > 4)\n   492→      ) && wordCount(t) >= 4;\n   493→      const isContinuation = /^[a-ząćęłńóśźż]/.test(t) && wordCount(t) >= 2;\n   494→\n   495→      if (isInstruction || isProse || isContinuation) {\n   496→        j++;\n   497→      } else {\n   498→        break;\n   499→      }\n   500→    }\n   501→    if (j >= 3) {\n   502→      i = j;\n   503→    }\n   504→  }\n   505→  return i;\n   506→}\n   507→\n   508→function stripParentheticalGloss(text: string): string {\n   509→  // Strip trailing English-gloss parentheticals from ALL_CAPS titles.\n   510→  // e.g. \"PIEROGI RUSKIE (Boiled Dumplings with Potato and Cheese)\" → \"PIEROGI RUSKIE\"\n   511→  // Keep if parenthetical is ALL_CAPS (variation/subtitle in same language).\n   512→  // Keep if both base and paren are mixed-case (both are part of the title).\n   513→  const match = text.match(/^(.+?)\\s*\\(([^)]+)\\)\\s*$/);\n   514→  if (!match) return text;\n   515→  const [, base, paren] = match;\n   516→  if (isAllCaps(paren)) return text;\n   517→  if (!isAllCaps(base) && !isAllCaps(paren)) return text;\n   518→  return base.trim();\n   519→}\n   520→\n   521→function stripPageNumber(text: string): string {\n   522→  // \"34  Berry Jam\" → \"Berry Jam\" (2+ spaces distinguishes from \"2 eggs\")\n   523→  const match = text.match(/^\\d{1,3}\\s{2,}(.+)$/);\n   524→  return match ? match[1] : text;\n   525→}\n   526→\n   527→function wordCount(text: string): number {\n   528→  return text.split(/\\s+/).filter((w) => w.length > 0).length;\n   529→}\n   530→\n   531→/**\n   532→ * Build candidate strings from lines: single lines plus multi-line joins (2-3 consecutive).\n   533→ * Skips initial burst of short garbled lines. Scans all remaining lines. Caps at 25.\n   534→ */\n   535→export type CandidateOrigin = \"single\" | \"2-line\" | \"3-line\";\n   536→\n   537→function buildCandidates(\n   538→  lines: Array<string>\n   539→): { candidates: Array<{ text: string; position: number; origin: CandidateOrigin }>; burstEnd: number } {\n   540→  const nonEmptyLines: Array<{ text: string; index: number }> = [];\n   541→\n   542→  for (let i = 0; i < lines.length; i++) {\n   543→    const trimmed = lines[i].trim();\n   544→    if (trimmed.length > 0) {\n   545→      nonEmptyLines.push({ text: trimmed, index: i });\n   546→    }\n   547→  }\n   548→\n   549→  const burstEnd = findBurstEnd(nonEmptyLines);"}]},"parent_tool_use_id":"toolu_01BGAEdezNUxJg1jisKfTg9G","session_id":"66d6120a-7fee-4673-bb0a-75db3320d34d","uuid":"59459e5b-5fd1-4452-97ff-4481b2b7e662"}
