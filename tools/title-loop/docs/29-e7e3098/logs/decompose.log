{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GZyvi6tFobX2ZPgDZ2bKLr","type":"tool_result","content":"   340→\n   341→// Polish imperative cooking verbs (with OCR-resilient forms — no diacritics required).\n   342→// These cover the most common recipe instruction starters. Includes common OCR-corrupted\n   343→// forms (e.g., \"Smaż\" → \"Smaz\", \"Dodaj\" → \"Dodaj\").\n   344→// Note: only verbs that NEVER start a recipe title. \"Piecz\" (bake) is excluded because\n   345→// \"Pieczeń\" (roast) and \"Pieczarki\" (mushrooms) share the prefix.\n   346→const POLISH_COOKING_INSTRUCTION_STARTS = /^(podawaj|dodaj|dodawaj|sma[zż]|gotuj|odced[zź]|wymieszaj|mieszaj|wlej|nalej|przygotuj|zagotuj|pokr[oó]j|obierz|wrzuc|wrzuć|usma[zż]|podsma[zż]|prze[lł][oó][zż]|zblenduj|ubij|roztrzepaj|rozprowad[zź]|wyrob|zamieszaj|posyp|polej|odstaw|na[lł][oó][zż]|przykryj|odkryj|wstaw|zdejmij|ods[aą]cz|rozgrzej|posiekaj|zetrzyj|wy[lł][oó][zż]|wyjmij|ukr[oó]j|przekr[oó]j|formuj|ugniataj|rozwałkuj)\\b/i;\n   347→\n   348→function looksLikeCookingInstruction(text: string): boolean {\n   349→  const words = text.trim().split(/\\s+/);\n   350→  if (words.length < 4) return false;  // Instructions are multi-word sentences\n   351→  if (COOKING_INSTRUCTION_STARTS.test(text.trim())) return true;\n   352→  if (POLISH_COOKING_INSTRUCTION_STARTS.test(text.trim())) return true;\n   353→  return false;\n   354→}\n   355→\n   356→/**\n   357→ * A line starting with a lowercase letter and having 4+ words is prose continuation.\n   358→ * Recipe titles are capitalized (Title Case or ALL CAPS), so a lowercase-start line\n   359→ * is a strong signal for mid-recipe body text.\n   360→ */\n   361→function isBodyProse(line: string): boolean {\n   362→  return /^[a-ząćęłńóśźż]/.test(line) && wordCount(line) >= 4;\n   363→}\n   364→\n   365→/**\n   366→ * Detect pages where the OCR capture starts mid-recipe with no title present.\n   367→ * Returns true if the first 3 non-empty lines (after `startFrom`) are all ingredients,\n   368→ * cooking instructions, or body prose continuation text.\n   369→ */\n   370→function isTitleAbsentPage(lines: Array<string>, startFrom: number = 0): boolean {\n   371→  const relevantLines = startFrom > 0 ? lines.slice(startFrom) : lines;\n   372→  const nonEmptyLines = relevantLines.map(l => l.trim()).filter(l => l.length > 0);\n   373→\n   374→  if (nonEmptyLines.length < 3) return false;\n   375→\n   376→  const first3 = nonEmptyLines.slice(0, 3);\n   377→\n   378→  return first3.every(line =>\n   379→    looksLikeIngredient(line) ||\n   380→    looksLikeCookingInstruction(line) ||\n   381→    isBodyProse(line)\n   382→  );\n   383→}\n   384→\n   385→function passesHardFilters(text: string): boolean {\n   386→  if (text.length < 3 || text.length > 80) return false;\n   387→  if (looksLikeIngredient(text)) return false;\n   388→  if (startsWithNumber(text)) return false;\n   389→  if (looksLikeMetadata(text)) return false;\n   390→  if (isLikelyGarbled(text)) return false;\n   391→  if (looksLikeCookingInstruction(text)) return false;\n   392→  // Pipe-separated lines are book category/chapter headers, not recipe titles\n   393→  if (text.includes(\" | \")) return false;\n   394→  // Trailing page number (e.g. \"VEGETABLE SIDES                         145\")\n   395→  if (/\\s{3,}\\d{1,4}\\s*$/.test(text)) return false;\n   396→  // Slash-separated breadcrumbs (e.g., \"/ Jesien / Zupy\") are navigation, not titles\n   397→  // Only filter when 2+ slashes are present — single-slash lines like\n   398→  // \"TITLE / SUBTITLE\" are legitimate continuation-merged titles\n   399→  if ((text.match(/\\//g) || []).length >= 2) return false;\n   400→  // Bullet-list items (ingredients or instruction steps) are never titles\n   401→  if (/^\\s*[-•*]\\s/.test(text)) return false;\n   402→  // \"For the sauce:\", \"For the filling:\" etc. are sub-section headers\n   403→  if (/^For the\\s+/i.test(text) && /:\\s*$/.test(text)) return false;\n   404→  // Lines ending with \":\" are recipe sub-section headers, not titles.\n   405→  // Exception: compound titles using \" : \" as a title separator (e.g. \"LEMON CURD : LEMON CURD WITH THYME\").\n   406→  if (/:\\s*$/.test(text.trim()) && !/ : /.test(text)) return false;\n   407→  // Page references are navigation markers, not recipe titles\n   408→  if (/^Page\\s+\\d+/i.test(text.trim())) return false;\n   409→  if (/^Strona\\s+\\d+/i.test(text.trim())) return false;\n   410→  // Corrupted spillover annotations from synthetic multi-page OCR\n   411→  if (/^\\[CORRUPTED\\s+SPILLOVER/i.test(text.trim())) return false;\n   412→  // Parenthetical OCR annotation lines describing corruption artifacts\n   413→  if (/^\\(OCR\\b/i.test(text.trim())) return false;\n   414→  if (/^\\(.*\\bcorruption\\b/i.test(text.trim())) return false;\n   415→  // Square-bracket category tags (e.g., \"[CLASSIC FALL SOUPS]\")\n   416→  if (/^\\[.*\\]$/.test(text.trim())) return false;\n   417→  // Known recipe section labels are structural headers, not titles\n   418→  if (isSectionLabel(text)) return false;\n   419→  // Single-word non-title fragments"}]},"parent_tool_use_id":"toolu_012DVJ8w8ixpk2mjE3s8nwsx","session_id":"670863c9-98c7-48f9-9c8e-7e02b066ba62","uuid":"8dd431a5-f230-4c18-947d-4640ddddfd7c"}
