ds.length === 1 && /[a-z][A-Z]/.test(text.trim())) {\n   303→    return true;\n   304→  }\n   305→\n   306→  // Recipe titles never start with a lowercase letter\n   307→  if (/^[a-z]/.test(text.trim())) {\n   308→    return true;\n   309→  }\n   310→\n   311→  // Mid-text sentence boundary (\". \" followed by a letter) — body text fragment spliced from multiple sentences\n   312→  const trimmed = text.trim();\n   313→  if (/\\.\\s+[a-zA-Z]/.test(trimmed) && !trimmed.endsWith(\")\")) {\n   314→    return true;\n   315→  }\n   316→\n   317→  // Multi-word candidate containing a garbled OCR fragment: a short lowercase word that isn't a known short word\n   318→  if (words.length >= 2) {\n   319→    const commonShort2 = new Set([\n   320→      \"a\", \"i\", \"of\", \"or\", \"to\", \"in\", \"on\", \"is\", \"it\", \"an\",\n   321→      \"as\", \"at\", \"by\", \"do\", \"go\", \"if\", \"no\", \"so\", \"up\", \"we\",\n   322→      \"w\", \"z\",   // Polish prepositions (basic)\n   323→      \"ze\", \"bo\", \"na\", \"ni\", \"po\", \"ku\", \"od\", \"za\", \"co\",  // Polish prepositions (extended)\n   324→    ]);\n   325→    const hasGarbledWord = words.some(\n   326→      (w) =>\n   327→        /^[a-z]/.test(w) &&\n   328→        w.replace(/[^a-z]/g, \"\").length <= 2 &&\n   329→        !commonShort2.has(w.toLowerCase())\n   330→    );\n   331→    if (hasGarbledWord) {\n   332→      return true;\n   333→    }\n   334→\n   335→    // Multi-word candidate with a garbled token: a word with internal\n   336→    // lowercase→uppercase transition that isn't a known camelCase pattern\n   337→    // (e.g., \"McDonald\", \"McCormick\"). Catches \"XxYyZz\", \"UuIw\" etc.\n   338→    const hasGarbledCamelCase = words.some(\n   339→      (w) =>\n   340→        w.length >= 3 &&\n   341→        /[a-z][A-Z]/.test(w) &&\n   342→        !/^(Mc|Mac)[A-Z]/.test(w) // Exempt Scottish/Irish names\n   343→    );\n   344→    if (hasGarbledCamelCase) {\n   345→      return true;\n   346→    }\n   3