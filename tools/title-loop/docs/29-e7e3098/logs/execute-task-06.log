 1219→  // bonuses so the cap covers all of them (per improvement plan: shared +0.15 max).\n  1220→  // Raise cap slightly for pipe-separated metadata followed by ALL_CAPS candidate.\n  1221→  // This is a near-certain title pattern in Polish cookbooks where MiniLM\n  1222→  // (English-centric) gives weak embedding scores for Polish ALL_CAPS text.\n  1223→  const hasPipePreamble = lines\n  1224→    .slice(0, firstCandidate.position)\n  1225→    .some((line) => line.trim().includes(\" | \"));\n  1226→  const maxPositionalBoost =\n  1227→    hasPipePreamble && isAllCaps(firstCandidate.text) ? 0.18 : 0.15;\n  1228→  const totalPositionalBoost = firstCandidate.score - baseScoreBeforePositionalBonuses;\n  1229→  if (totalPositionalBoost > maxPositionalBoost) {\n  1230→    const excess = totalPositionalBoost - maxPositionalBoost;\n  1231→    firstCandidate.score -= excess;\n  1232→    firstCandidate.baseScore -= excess;\n  1233→    firstCandidate.thresholdScore -= excess;\n  1234→  }\n  1235→\n  1236→  // --- Pre-threshold bilingual title detection ---\n  1237→  // When a mixed-case candidate at position 0 is followed by an ALL_CAPS candidate\n  1238→  // at position ≤ 2 that is semantically similar to it, this is a bilingual recipe\n  1239→  // page (e.g., Polish title + ALL_CAPS Korean romanization). Suppress confirmed\n  1240→  // translation candidates before computing threshold so their bonuses don't inflate\n  1241→  // the threshold beyond the mixed-case title's reach.\n  1242→  // Note: we check position ≤ 2 (local proximity), not global ALL_CAPS count, so\n  1243→  // section headers later in the document (SKŁADNIKI, WARZYWA, etc.) are irrelevant.\n  1244→  let translationCandidates: typeof scored = [];\n  1245→  let scoredForThreshold = scored;\n  1246→  const prePos0 = scored.find((s) => s.position === 0 && !isAllCaps(s.text));\n  1247→  if (prePos0) {\n  1248→    const nearbyAllCaps = scored.filter(\n  1249→      (s) => isAllCaps(s.text) && s.position >= 1 &&