  // pinch\n    44→  \"garść\",                               // handful\n    45→  \"opakowanie\", \"opakowania\",            // package(s)\n    46→  \"plasterek\", \"plasterki\",             // slice(s)\n    47→];\n    48→\n    49→/**\n    50→ * Patterns that identify recipe metadata lines (not titles)\n    51→ */\n    52→const METADATA_PATTERNS = [\n    53→  /^(SERVES?|MAKES?|YIELDS?)\\b/i,\n...\n</persisted-output>","is_error":false}]},"parent_tool_use_id":"toolu_014b1jaBC4e9WcCkenNgu7VB","session_id":"c37a3300-1904-44e6-bf34-65ba8b38fada","uuid":"a4a19b8d-0b86-4bdc-b63a-63bf433b2423"}
