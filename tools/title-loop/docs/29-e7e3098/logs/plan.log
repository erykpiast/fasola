{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Cx874HT8XBnf2xpwXX1SMu","type":"tool_result","content":"     1→#!/usr/bin/env python3\n     2→\"\"\"Standalone evaluation script - runs without launching Claude.\"\"\"\n     3→import glob, subprocess, re, unicodedata\n     4→from pathlib import Path\n     5→\n     6→INPUT_DIR = Path('tools/title-loop/input')\n     7→EXTRACT_SCRIPT = Path('tools/title-loop/extract-title.ts')\n     8→\n     9→def normalize(s):\n    10→    return re.sub(r'\\s+', ' ', s.strip()).upper()\n    11→\n    12→def normalize_separators(s):\n    13→    return s.replace('-', ' ').replace('_', ' ')\n    14→\n    15→def _strip_diacritics(s):\n    16→    return ''.join(c for c in unicodedata.normalize('NFD', s) if unicodedata.category(c) != 'Mn')\n    17→\n    18→def _ocr_normalize(s):\n    19→    return s.replace('0', 'O').replace('1', 'I').replace('5', 'S')\n    20→\n    21→def titles_match(extracted, expected):\n    22→    if not extracted:\n    23→        return False\n    24→    extracted_norm = _ocr_normalize(_strip_diacritics(normalize_separators(normalize(extracted))))\n    25→    expected_parts = [\n    26→        _ocr_normalize(_strip_diacritics(normalize_separators(normalize(p))))\n    27→        for p in expected.split('+')\n    28→    ]\n    29→    return all(part in extracted_norm for part in expected_parts)\n    30→\n    31→def extract_expected_title(filename):\n    32→    name = Path(filename).name\n    33→    cleaned = re.sub(r'\\.(real|generated)\\.txt$', '', name)\n    34→    return cleaned\n    35→\n    36→def run_extraction(file_path):\n    37→    result = subprocess.run(\n    38→        ['npx', 'tsx', str(EXTRACT_SCRIPT), file_path],\n    39→        capture_output=True, text=True, timeout=30, cwd='.'\n    40→    )\n    41→    if result.returncode != 0:\n    42→        return ''\n    43→    return result.stdout.strip()\n    44→\n    45→real_files = sorted(glob.glob(str(INPUT_DIR / '*.real.txt')))\n    46→gen_files = sorted(glob.glob(str(INPUT_DIR / '*.generated.txt')))\n    47→\n    48→print(f'Real files: {len(real_files)}, Generated files: {len(gen_files)}')\n    49→\n    50→print('\\n--- REAL FILES ---')\n    51→real_results = []\n    52→for fp in real_files:\n    53→    expected = extract_expected_title(fp)\n    54→    extracted = run_extraction(fp)\n    55→    match = titles_match(extracted, expected)\n    56→    real_results.append({'expected': expected, 'extracted': extracted, 'match': match})\n    57→    status = 'YES' if match else 'NO'\n    58→    print(f'  {status}: expected={expected!r} got={extracted!r}')\n    59→\n    60→print('\\n--- GENERATED FILES ---')\n    61→gen_results = []\n    62→for fp in gen_files:\n    63→    expected = extract_expected_title(fp)\n    64→    extracted = run_extraction(fp)\n    65→    match = titles_match(extracted, expected)\n    66→    gen_results.append({'expected': expected, 'extracted': extracted, 'match': match})\n    67→    status = 'YES' if match else 'NO'\n    68→    print(f'  {status}: expected={expected!r} got={extracted!r}')\n    69→\n    70→real_pass = sum(1 for r in real_results if r['match'])\n    71→gen_pass = sum(1 for r in gen_results if r['match'])\n    72→all_pass = real_pass + gen_pass\n    73→total = len(real_results) + len(gen_results)\n    74→\n    75→real_acc = real_pass / len(real_results) if real_results else 0\n    76→gen_acc = gen_pass / len(gen_results) if gen_results else 0\n    77→combined_acc = all_pass / total if total else 0\n    78→\n    79→print()\n    80→print(f'Real: {real_pass}/{len(real_results)} = {real_acc:.1%}')\n    81→print(f'Generated: {gen_pass}/{len(gen_results)} = {gen_acc:.1%}')\n    82→print(f'Combined: {all_pass}/{total} = {combined_acc:.1%}')\n    83→\n    84→# Show failures\n    85→failures = [r for r in real_results + gen_results if not r['match']]\n    86→if failures:\n    87→    print(f'\\nFAILURES ({len(failures)}):')\n    88→    for r in failures:\n    89→        print(f'  expected={r[\"expected\"]!r} got={r[\"extracted\"]!r}')\n    90→else:\n    91→    print('\\nAll tests passed!')\n    92→"}]},"parent_tool_use_id":"toolu_014b1jaBC4e9WcCkenNgu7VB","session_id":"c37a3300-1904-44e6-bf34-65ba8b38fada","uuid":"cb481b33-f714-4114-b4d5-17d19a812053"}
