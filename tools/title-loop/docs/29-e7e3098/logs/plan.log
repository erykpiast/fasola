{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CbVuLZquJ2rYQ6N7cBUjVW","type":"tool_result","content":"  1340→  // NOTE: The ≥2 guard is conservative — when there are exactly 2 ALL_CAPS candidates and one is\n  1341→  // an artifact, the artifact is NOT removed. Relaxing to ≥1 causes regressions because 3-line\n  1342→  // join candidates (which span a section label) can pass corroboration via shared vocabulary,\n  1343→  // while the legitimate short title fails. See \"WORD ONE / INGREDIENTS / WORD TWO\" test case.\n  1344→  const allCapsInScored = scoredForThreshold.filter((s) => isAllCaps(s.text));\n  1345→  if (allCapsInScored.length >= 2) {\n  1346→    const artifactTexts = new Set(\n  1347→      allCapsInScored\n  1348→        .filter((cap) => !passesCorroboration(cap.text, cap.position, lines, burstEnd))\n  1349→        .map((c) => c.text)\n  1350→    );\n  1351→    if (artifactTexts.size > 0) {\n  1352→      const remainingCaps = allCapsInScored.filter((c) => !artifactTexts.has(c.text));\n  1353→      if (remainingCaps.length >= 2) {\n  1354→        scoredForThreshold = scoredForThreshold.filter((s) => !artifactTexts.has(s.text));\n  1355→      }\n  1356→    }\n  1357→  }\n  1358→\n  1359→  // Use thresholdScore (excludes structural bonus) so the structural bonus doesn't inflate\n  1360→  // the threshold and block equally-valid headings on multi-recipe pages.\n  1361→  const bestThresholdScore = Math.max(...scoredForThreshold.map((s) => s.thresholdScore));\n  1362→  const threshold = Math.max(0.08, bestThresholdScore * 0.7);\n  1363→\n  1364→  // Filter candidates above threshold\n  1365→  let selected = scoredForThreshold.filter((s) => s.score >= threshold);\n  1366→\n  1367→  // Empty-pool fallback: when threshold filtering discards every candidate,\n  1368→  // the hard filters' structural verdict should not be overruled by weak\n  1369→  // embedding differentiation. Return the best positional candidate only\n  1370→  // if it has a meaningful positive raw score (avoids ingredient-list leakage).\n  1371→  if (selected.length === 0 && scored.length > 0) {\n  1372→    const fallback = scored\n  1373→      .slice()\n  1374→      .sort((a, b) => a.position - b.position || b.score - a.score);\n  1375→    // Position-0 candidates that passed hard filters are very likely titles even with\n  1376→    // weak embedding signal. Relax the rawScore guard for early-position candidates.\n  1377→    const rawScoreThreshold = fallback[0].position <= 2 ? -0.05 : 0.02;\n  1378→    if (fallback[0].rawScore > rawScoreThreshold) {\n  1379→      selected = [fallback[0]];\n  1380→    }\n  1381→  }\n  1382→\n  1383→  // Title-absent page guard: when the page starts mid-recipe (all of the first 3 non-empty\n  1384→  // lines are ingredients or cooking instructions), require a much higher rawScore and\n  1385→  // discard candidates deep in the file. This prevents stray body text or adjacent recipe\n  1386→  // titles from being picked up on pages with no title (Pattern 4).\n  1387→  if (titleAbsent) {\n  1388→    const titleAbsentThreshold = 0.10;\n  1389→    selected = selected.filter(s => s.rawScore >= titleAbsentThreshold);\n  1390→    selected = selected.filter(s => s.position <= 2);\n  1391→  }\n  1392→\n  1393→  // Remove word-boundary prefixes of firstStructuralHeading when the heading itself survived\n  1394→  // the threshold. Cases:\n  1395→  //   ARAYES case:  firstStructuralHeading = \"ARAYES SHRAK\" (2-word join qualifies; \"ARAYES\"\n  1396→  //     alone = 1 word, so it never qualified). Filter removes \"ARAYES\" so dedup keeps the join.\n  1397→  //   SAFFRON case: baseHeading was the partial line; continuation logic above upgraded\n  1398→  //     firstStructuralHeading to the full join. Filter removes the partial so dedup keeps join.\n  1399→  // Safety: only fires when the complete heading itself is in selected (passed the threshold)."}]},"parent_tool_use_id":null,"session_id":"c37a3300-1904-44e6-bf34-65ba8b38fada","uuid":"5d73c3ba-c4c0-40df-9d34-db1439ee6716","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/title-extractor.ts","content":"  // NOTE: The ≥2 guard is conservative — when there are exactly 2 ALL_CAPS candidates and one is\n  // an artifact, the artifact is NOT removed. Relaxing to ≥1 causes regressions because 3-line\n  // join candidates (which span a section label) can pass corroboration via shared vocabulary,\n  // while the legitimate short title fails. See \"WORD ONE / INGREDIENTS / WORD TWO\" test case.\n  const allCapsInScored = scoredForThreshold.filter((s) => isAllCaps(s.text));\n  if (allCapsInScored.length >= 2) {\n    const artifactTexts = new Set(\n      allCapsInScored\n        .filter((cap) => !passesCorroboration(cap.text, cap.position, lines, burstEnd))\n        .map((c) => c.text)\n    );\n    if (artifactTexts.size > 0) {\n      const remainingCaps = allCapsInScored.filter((c) => !artifactTexts.has(c.text));\n      if (remainingCaps.length >= 2) {\n        scoredForThreshold = scoredForThreshold.filter((s) => !artifactTexts.has(s.text));\n      }\n    }\n  }\n\n  // Use thresholdScore (excludes structural bonus) so the structural bonus doesn't inflate\n  // the threshold and block equally-valid headings on multi-recipe pages.\n  const bestThresholdScore = Math.max(...scoredForThreshold.map((s) => s.thresholdScore));\n  const threshold = Math.max(0.08, bestThresholdScore * 0.7);\n\n  // Filter candidates above threshold\n  let selected = scoredForThreshold.filter((s) => s.score >= threshold);\n\n  // Empty-pool fallback: when threshold filtering discards every candidate,\n  // the hard filters' structural verdict should not be overruled by weak\n  // embedding differentiation. Return the best positional candidate only\n  // if it has a meaningful positive raw score (avoids ingredient-list leakage).\n  if (selected.length === 0 && scored.length > 0) {\n    const fallback = scored\n      .slice()\n      .sort((a, b) => a.position - b.position || b.score - a.score);\n    // Position-0 candidates that passed hard filters are very likely titles even with\n    // weak embedding signal. Relax the rawScore guard for early-position candidates.\n    const rawScoreThreshold = fallback[0].position <= 2 ? -0.05 : 0.02;\n    if (fallback[0].rawScore > rawScoreThreshold) {\n      selected = [fallback[0]];\n    }\n  }\n\n  // Title-absent page guard: when the page starts mid-recipe (all of the first 3 non-empty\n  // lines are ingredients or cooking instructions), require a much higher rawScore and\n  // discard candidates deep in the file. This prevents stray body text or adjacent recipe\n  // titles from being picked up on pages with no title (Pattern 4).\n  if (titleAbsent) {\n    const titleAbsentThreshold = 0.10;\n    selected = selected.filter(s => s.rawScore >= titleAbsentThreshold);\n    selected = selected.filter(s => s.position <= 2);\n  }\n\n  // Remove word-boundary prefixes of firstStructuralHeading when the heading itself survived\n  // the threshold. Cases:\n  //   ARAYES case:  firstStructuralHeading = \"ARAYES SHRAK\" (2-word join qualifies; \"ARAYES\"\n  //     alone = 1 word, so it never qualified). Filter removes \"ARAYES\" so dedup keeps the join.\n  //   SAFFRON case: baseHeading was the partial line; continuation logic above upgraded\n  //     firstStructuralHeading to the full join. Filter removes the partial so dedup keeps join.\n  // Safety: only fires when the complete heading itself is in selected (passed the threshold).","numLines":60,"startLine":1340,"totalLines":1666}}}
