// Strip trailing English-gloss parentheticals from ALL_CAPS titles.\n   510→  // e.g. \"PIEROGI RUSKIE (Boiled Dumplings with Potato and Cheese)\" → \"PIEROGI RUSKIE\"\n   511→  // Keep if parenthetical is ALL_CAPS (variation/subtitle in same language).\n   512→  // Keep if both base and paren are mixed-case (both are part of the title).\n   513→  const match = text.match(/^(.+?)\\s*\\(([^)]+)\\)\\s*$/);\n   514→  if (!match) return text;\n   515→  const [, base, paren] = match;\n   516→  if (isAllCaps(paren)) return text;\n   517→  if (!isAllCaps(base) && !isAllCaps(paren)) return text;\n   518→  return base.trim();\n   519→}\n   520→\n   521→function stripPageNumber(text: string): string {\n   522→  // \"34  Berry Jam\" → \"Berry Jam\" (2+ spaces distinguishes from \"2 eggs\")\n   523→  const match = text.match(/^\\d{1,3}\\s{2,}(.+)$/);\n   524→  return match ? match[1] : text;\n   525→}\n   526→\n   527→function wordCount(text: string): number {\n   528→  return text.split(/\\s+/).filter((w) => w.length > 0).length;\n   529→}\n   530→\n   531→/**\n   532→ * Build candidate strings from lines: single lines plus multi-line joins (2-3 consecutive).\n   533→ * Skips initial burst of short garbled lines. Scans all remaining lines. Caps at 25.\n   534→ */\n   535→export type CandidateOrigin = \"single\" | \"2-line\" | \"3-line\";\n   536→\n   537→function buildCandidates(\n   538→  lines: Array<string>\n   539→): { candidates: Array<{ text: string; position: number; origin: CandidateOrigin }>; burstEnd: number } {\n   540→  const nonEmptyLines: Array<{ text: string; index: number }> = [];\n   541→\n   542→  for (let i = 0; i < lines.length; i++) {\n   543→    const trimmed = lines[i].trim();\n   544→    if (trimmed.length > 0) {\n   545→      nonEmptyLines.push({ text: trimmed, index: i });\n   546→    }\n   547→  }\n   548→\n   549→  const burstEnd = findBurstEnd(nonEmptyLines);\n   550→\n   551→  // Pre-join hyphen-broken lines: \"ROASTED CHICKEN WITH ROOT VEGET-\" + \"ABLES\" → single line.\n   552→  // Only applies within the candidate region (after burst end).\n   553→  for (let hi = burstEnd; hi < nonEmptyLines.length - 1; hi++) {\n   554→    if (nonEmptyLines[hi].text.endsWith(\"-\")) {\n   555→      const joined = nonEmptyLines[hi].text.slice(0, -1) + nonEmptyLines[hi + 1].text;\n   556→      nonEmptyLines[hi] = { text: joined, index: nonEmptyLines[hi].index };\n   557→      nonEmptyLines.splice(hi + 1, 1);\n   558→    }\n   559→  }\n   560→\n   561→  // Pre-merge consecutive short ALL_CAPS lines (OCR-fragmented headings).\n   562→  // When a sequence of 2+ ALL_CAPS lines each has ≤2 words and ≤25 chars, they are\n   563→  // almost certainly OCR fragments of a single heading. Merge them into one line so\n   564→  // the complete title enters the candidate pool without hitting the 3-line join ceiling.\n   565→  const capsCoalesced: Array<{ text: string; index: number }> = [];\n   566→  let ci = burstEnd;\n   567→  while (ci < nonEmptyLines.length) {\n   568→    const line = nonEmptyLines[ci];\n   569→    if (\n   570→      isAllCaps(line.text) &&\n   571→      wordCount(line.text) <= 2 &&\n   572→      line.text.length <= 25 &&\n   573→      !isSectionLabel(line.text) &&\n   574→      !looksLikeMetadata(line.text)\n   575→    ) {\n   576→      let merged = line.text;\n   577→      const startIndex = line.index;\n   578→      let j = ci + 1;\n   579→      while (j < nonEmptyLines.length) {\n   580→        const next = nonEmptyLines[j];\n   581→        if (\n   582→          isAllCaps(next.text) &&\n   583→          wordCount(next.text) <= 2 &&\n   584→          next.text.length <= 25 &&\n   585→          ((!isSectionLabel(next.text) && !isSectionLabel(repairOcrText(next.text))) ||\n   586→           (wordCount(next.text) === 1 && wordCount(merged) >= 2 && wordCount(merged) <= 4 &&\n   587→            isCategorySectionLabel(next.text))) &&\n   588→          !looksLikeMetadata(next.text) &&\n   589→          (merged + \" \"