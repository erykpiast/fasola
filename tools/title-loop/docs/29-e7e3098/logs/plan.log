{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DG9YfWBC1N3SsbvnLafYho","type":"tool_result","content":"     1→/**\n     2→ * Shared MiniLM embedder infrastructure.\n     3→ * Used by both the main CLI and the title-loop extraction script.\n     4→ */\n     5→\n     6→import { pipeline } from \"@huggingface/transformers\";\n     7→\n     8→const MODEL_NAME = \"Xenova/all-MiniLM-L6-v2\";\n     9→\n    10→export interface EmbeddingOutput {\n    11→  data: Float32Array | Array<number>;\n    12→}\n    13→\n    14→export interface FeatureEmbedder {\n    15→  (\n    16→    text: string,\n    17→    options: { pooling: \"mean\"; normalize: true }\n    18→  ): Promise<EmbeddingOutput>;\n    19→}\n    20→\n    21→export async function loadEmbedder(\n    22→  onProgress?: (progress: {\n    23→    status?: string;\n    24→    loaded?: number;\n    25→    total?: number;\n    26→  }) => void\n    27→): Promise<FeatureEmbedder> {\n    28→  return (await pipeline(\"feature-extraction\", MODEL_NAME, {\n    29→    ...(onProgress ? { progress_callback: onProgress } : {}),\n    30→  })) as unknown as FeatureEmbedder;\n    31→}\n    32→\n    33→export async function embedText(\n    34→  embedder: FeatureEmbedder,\n    35→  text: string\n    36→): Promise<Array<number>> {\n    37→  const output = await embedder(text, { pooling: \"mean\", normalize: true });\n    38→  return Array.from(output.data);\n    39→}\n    40→"}]},"parent_tool_use_id":"toolu_014b1jaBC4e9WcCkenNgu7VB","session_id":"c37a3300-1904-44e6-bf34-65ba8b38fada","uuid":"05f4498e-2239-4d99-b553-9fba64dcaa85"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UCYDakK9pUeizq7rViaQsx","type":"tool_result","content":"     1→/**\n     2→ * Common English and Polish food/cooking words and structural recipe title\n     3→ * words (prepositions, adjectives) for OCR repair.\n     4→ * Words are lowercase, without diacritics (OCR-resilient matching).\n     5→ * Used by repairOcrWord() to resolve ambiguous digit→letter substitutions.\n     6→ */\n     7→export const FOOD_DICTIONARY: Set<string> = new Set([\n     8→  // ── English ingredients ──────────────────────────────────────────────────\n     9→  \"chicken\", \"beef\", \"pork\", \"lamb\", \"veal\", \"duck\", \"turkey\", \"venison\",\n    10→  \"salmon\", \"cod\", \"halibut\", \"tuna\", \"trout\", \"sardine\", \"anchovy\",\n    11→  \"shrimp\", \"prawn\", \"lobster\", \"crab\", \"scallop\", \"mussel\", \"clam\",\n    12→  \"tofu\", \"tempeh\", \"seitan\",\n    13→\n    14→  // Grains & starches\n    15→  \"rice\", \"pasta\", \"bread\", \"noodle\", \"flour\", \"oat\", \"barley\", \"wheat\",\n    16→  \"rye\", \"quinoa\", \"corn\", \"cornmeal\", \"semolina\", \"couscous\", \"polenta\",\n    17→  \"buckwheat\", \"millet\",\n    18→\n    19→  // Dairy & eggs\n    20→  \"butter\", \"cream\", \"cheese\", \"milk\", \"egg\", \"yogurt\", \"ghee\",\n    21→  \"ricotta\", \"mozzarella\", \"parmesan\", \"cheddar\", \"brie\", \"feta\",\n    22→\n    23→  // Fats & condiments\n    24→  \"oil\", \"vinegar\", \"mustard\", \"ketchup\", \"mayo\", \"mayonnaise\",\n    25→  \"soy\", \"sauce\", \"paste\", \"stock\", \"broth\", \"gravy\",\n    26→\n    27→  // Vegetables\n    28→  \"garlic\", \"onion\", \"tomato\", \"potato\", \"carrot\", \"celery\", \"pepper\",\n    29→  \"broccoli\", \"cauliflower\", \"asparagus\", \"artichoke\", \"eggplant\",\n    30→  \"zucchini\", \"squash\", \"pumpkin\", \"cucumber\", \"radish\", \"turnip\",\n    31→  \"beet\", \"mushroom\", \"avocado\", \"olive\", \"bean\", \"lentil\", \"chickpea\",\n