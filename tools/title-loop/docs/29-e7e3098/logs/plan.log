n  1434→        const jLower = j.text.toLowerCase();\n  1435→        if (!jLower.endsWith(\" \" + sLower)) return false;\n  1436→        // Only remove if the suffix starts with a continuation character\n  1437→        return /^[/&+:(]/.test(sLower);\n  1438→      });\n  1439→      if (isSuffixOfJoin) return false;\n  1440→      return true;\n  1441→    });\n  1442→  }\n  1443→\n  1444→  // Pre-dedup: remove sub-section headers that are substrings of other surviving candidates.\n  1445→  // A sub-section header is an ALL_CAPS candidate followed by ingredient-like lines in the source.\n  1446→  // Example: \"CHLEBEK\" (bread section header, followed by \"500 g mąki\") is a substring of\n  1447→  // \"CHLEBEK Z WARZYWAMI I BOCZKIEM\" (the real title). Without this filter, dedup kills the title.\n  1448→  selected = selected.filter((candidate) => {\n  1449→    if (!isAllCaps(candidate.text)) return true;\n  1450→    // Check if this candidate is immediately followed by ingredient-like content\n  1451→    const nextSourceLines = lines.slice(candidate.position + 1, candidate.position + 2);\n  1452→    const followedByIngredients = nextSourceLines.some(\n  1453→      (l) => looksLikeIngredient(l.trim()) || startsWithNumber(l.trim())\n  1454→    );\n  1455→    if (!followedByIngredients) return true;\n  1456→    // Only remove if a longer candidate contains this one as a substring\n  1457→    const candidateLower = candidate.text.toLowerCase();\n  1458→    const hasLongerParent = rawScored.some(\n  1459→      (other) =>\n  1460→        other.text !== candidate.text &&\n  1461→        other.text.length > candidate.text.length &&\n  1462→        other.text.toLowerCase().includes(candidateLower)\n  1463→    );\n  1464→    return !hasLongerParent;\n  1465→  });\n  1466→\n  1467→  // Protect multi-line joins from being destroyed by their own component singles.\n  1468→  // When \"Lamb Stew\" (2-line join) survives AND both \"Lamb\" and \"Stew\" (singles) also survive,\n  1469→  // the join is the intended title — remove the singles.\n  1470→  const joinsToProtect = selected.filter((s) => s.origin === \"2-line\" || s.origin === \"3-line\");\n  1471→  if (joinsToProtect.length > 0) {\n  1472→    const singlesToRemove = new Set<string>();\n  1473→    for (const join of joinsToProtect) {\n  1474→      const joinWords = join.text.split(/\\s+/);\n  1475→      const componentSingles = selected.filter(\n  1476→        (s) => s.origin === \"single\" && joinWords.some((w) => s.text.toLowerCase() === w.toLowerCase())\n  1477→      );\n  1478→      if (componentSingles.length >= Math.min(joinWords.length, 2)) {\n  1479→        componentSingles.forEach((s) => singlesToRemove.add(s.text));\n  1480→      }\n  1481→    }\n  1482→    if (singlesToRemove.size > 0) {\n  1483→      selected = selected.filter((s) => s.origin !== \"single\" || !singlesToRemove.has(s.text));\n  1484→    }\n  1485→  }\n  1486→\n  1487→  // Protect position-0 compound titles from distant sub-section headers.\n  1488→  // When a position-0 compound title is longer and contains a shorter candidate\n  1489→  // that appears > 10 lines later, remove the distant candidate so the dedup\n  1490→  // (shorter-wins rule) doesn't destroy the compound title.\n  1491→  const pos0Compounds = selected.filter((s) => s.position === 0);\n  1492→  if (pos0Compounds.length > 0) {\n  1493→    selected = selected.filter((s) => {\n  1494→      if (s.position === 0) return true;\n  1495→      const sLower = s.text.toLowerCase();\n  1496→      return !pos0Compounds.some(\n  1497→        (p0) =>\n  1498→          p0.position + 10 < s.position &&\n  1499→          s.text.length < p0.text.length &&\n  1500→          p0.text.toLowerCase().includes(sLower)\n  1501→      );\n  1502→    });\n  1503→  }\n  1504→\n  1505→  // Deduplicate: if one title is a substring of another, keep the shorter (more focused) one.\n  1506→  // DO NOT CHANGE THIS LOGIC — it has been incorrectly \"improved\" by the title-loop 5 times.\n  1507→  // The tests require shorter wins: \"Pierogi Ruskie\" over \"Pierogi Ruskie 200g mąki 3 ziemniaki\".\n  1508→  // The pre-filter above handles the conflicting case (structural heading prefix removal) so that\n  1509→  // the incomplete prefix line is never present here when the complete join is in selected.\n  1510→  selected = selected.filter((a) => {\n  1511→    const aLower = a.text.toLowerCase();\n  1512→    // Protect compound titles — these use explicit separators and the full form is intentional\n  1513→    if (/ [+:&] /.test(a.text)) return true;\n  1514→    return !selected.some((b) => {\n  1515→      if (b === a) return false;\n  1516→      if (b.text.length >= a.text.length) return false;\n  1517→      if (!aLower.includes(b.text.toLowerCase())) return false;\n  1518→\n  1519→      // Protect multi-line joins whose suffix over the shorter candidate is a food-category label.\n  1520→      // E.g., \"LEMON HERB ROASTED VEGETABLES\" (2-line) vs \"LEMON HERB ROASTED\" (single):\n  1521→      // \"VEGETABLES\" is in CATEGORY_SECTION_LABELS — keep the full joined form.\n  1522→      // Use startsWith (not includes) to ensure b is a true prefix, not a mid-string match.\n  1523→      if ((a.origin === \"2-line\" || a.origin === \"3-line\") &&\n  1524→          aLower.startsWith(b.text.toLowerCase() + \" \")) {\n  1525→        const suffix = a.text.slice(b.text.length).trim();\n  1526→        const suffixNorm = stripDiacritics(suffix.toLowerCase());\n  1527→        if (CATEGORY_SECTION_LABELS.has(suffixNorm)) {\n  1528→          return false; // Don't remove `a` — its suffix is a food-category label\n  1529→        }\n  1530→      }\n  1531→\n  1532→      return true;\n  1533→    });\n  1534→  });\n  1535→\n  1536→  // Multi-title guard: only join multiple candidates with \"+\" when there is\n  1537→  // structural evidence of a multi-recipe page (≥2 ALL_CAPS headings).\n  1538→  // A single ALL_CAPS title among mixed-case survivors is a single-recipe page —\n  1539→  // collapse to the highest-scoring candidate.\n  1540→  // Zero ALL_CAPS survivors → apply positional tiebreak only when candidates are\n  1541→  // spread far apart (>10 lines), which indicates body-text leakage. Closely-\n  1542→  // positioned candidates are likely genuine multi-recipe content.\n  1543→  if (selected.length > 1) {\n  1544→    const allCapsSelected = selected.filter((s) => isAllCaps(s.text));\n  1545→    if (allCapsSelected.length >= 2) {\n  1546→      // Vocabulary corroboration: filter out ALL_CAPS candidates whose content words\n  1547→      // don't appear elsewhere in the document. This catches orphaned OCR artifacts\n  1548→      // (e.g., \"DAT FLATBREADS\" from a preceding page) that look structurally identical\n  1549→      // to real titles but have no vocabulary support in the document body.\n  1550→      const corroboratedCaps = allCapsSelected.filter((cap) =>\n  1551→        passesCorroboration(cap.text, cap.position, lines, burstEnd)\n  1552→      );\n  1553→\n  1554→      // Use corroborated candidates if any remain; otherwise fall back to original set\n  1555→      // (don't remove all candidates — that would break legitimate multi-title pages\n  1556→      // where corroboration fails for benign reasons).\n  1557→      const capsToUse = corroboratedCaps.length >= 2 ? corroboratedCaps : allCapsSelected;\n  1558→\n  1559→      // Check whether non-first ALL_CAPS headings are section headers within one recipe\n  1560→      // (followed immediately by ingredient-like content) rather than separate recipe titles.\n  1561→      // A multi-recipe page has body text between titles; a single-recipe page has\n  1562→      // ingredient lines immediately after each section heading.\n  1563→      const sortedCaps = [...capsToUse].sort((a, b) => a.position - b.position);\n  1564→      const isSubHeader = sortedCaps.slice(1).every((cap) => {\n  1565→        const nextLines = lines.slice(cap.position + 1, cap.position + 3);\n  1566→        return nextLines.some(\n  1567→          (l) => looksLikeIngredient(l.trim()) || startsWithNumber(l.trim())\n  1568→        );\n  1569→      });\n  1570→      if (isSubHeader) {\n  1571→        selected = [sortedCaps[0]];\n  1572→      } else {\n  1573→        selected = capsToUse;\n  1574→      }\n  1575→    } else if (allCapsSelected.length === 1) {\n  1576→      const theCapCandidate = allCapsSelected[0];\n  1577→      // Use non-empty line count so the 75% threshold is consistent regardless of blank-line density.\n  1578→      const nonEmptyCount = lines.filter((l) => l.trim().length > 0).length;\n  1579→      const capRelPos = theCapCandidate.position / Math.max(nonEmptyCount, 1);\n  1580→      // If the sole ALL_CAPS candidate is in the last 25% of the document,\n  1581→      // it's likely a category footer, not a title. Prefer the best earlier candidate.\n  1582→      if (capRelPos > 0.75) {\n  1583→        const earlierCandidates = selected.filter(\n  1584→          (s) => s.position / Math.max(nonEmptyCount, 1) <= 0.75\n  1585→        );\n  1586→        if (earlierCandidates.length > 0) {\n  1587→          selected = [earlierCandidates.reduce((a, b) => (a.score > b.score ? a : b))];\n  1588→        } else {\n  1589→          // All candidates are in the last 25% — no positional basis to prefer one over another;\n  1590→          // fall back to score, accepting that the guard cannot help here.\n  1591→          selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n  1592→        }\n  1593→      } else {\n  1594→        selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n  1595→      }\n  1596→    } else {\n  1597→      // Zero ALL_CAPS survivors → mixed-case page.\n  1598→      // If all survivors are closely positioned (within 10 lines of each other), keep them all —\n  1599→      // they're likely genuine multi-recipe content on a single page.\n  1600→      // If any survivor is far from the earliest, apply a positional tiebreak: the real title\n  1601→      // is almost always the earliest candidate; distant survivors are likely body-text leakage.\n  1602→      selected.sort((a, b) => a.position - b.position);\n  1603→      const earliest = selected[0];\n  1604→      const farthest = selected[selected.length - 1];\n  1605→      if (farthest.position - earliest.position > 10) {\n  1606→        // Large span → body-text leakage. Collapse to one: prefer the highest-scoring\n  1607→        // candidate within 3 positions of the earliest (position tolerance for OCR gaps),\n  1608→        // falling back to the earliest itself if none score higher.\n  1609→        const closeCompetitors = selected.filter(\n  1610→          (s) => s.position <= earliest.position + 3 && s.score > earliest.score\n  1611→        );\n  1612→        selected = closeCompetitors.length > 0\n  1613→          ? [closeCompetitors.reduce((a, b) => (a.score > b.score ? a : b))]\n  1614→          : [earliest];\n  1615→      }\n  1616→      // Span ≤ 10 → all survivors are closely positioned; fall through keeping all.\n  1617→    }\n  1618→  }\n  1619→\n  1620→  // Cap at 3, sort by document position\n  1621→  selected.sort((a, b) => a.position - b.position);\n  1622→  selected = selected.slice(0, 3);\n  1623→\n  1624→  if (selected.length === 0) {\n  1625→    // Last resort: embedding scoring provided no usable signal.\n  1626→    // Return the earliest candidate that passed hard filters — it already survived\n  1627→    // ingredient, metadata, garbled, section-label, and cooking-instruction checks.\n  1628→    // Position 0 in a recipe file is overwhelmingly the title.\n  1629→    // Exclude hard-disqualified candidates (rawScore -1.0 = truncated OCR artifact).\n  1630→    const lastResort = scored\n  1631→      .slice()\n  1632→      .filter((s) => s.rawScore > -0.5)\n  1633→      .sort((a, b) => a.position - b.position || b.score - a.score);\n  1634→    if (lastResort.length > 0) {\n  1635→      return normalizeOcrTitle(lastResort[0].text.normalize(\"NFC\").trim());\n  1636→    }\n  1637→    return undefined;\n  1638→  }\n  1639→\n  1640→  const result = selected.map((s) => normalizeOcrTitle(s.text.normalize(\"NFC\").trim())).join(\" + \");\n  1641→\n  1642→  return result;\n  1643→}\n  1644→\n  1645→/**\n  1646→ * Extract potential recipe title from OCR text (sync heuristic fallback)\n  1647→ */\n  1648→export function extractTitle(text: string): string | undefined {\n  1649→  if (!text || text.trim().length === 0) {\n  1650→    return undefined;\n  1651→  }\n  1652→\n  1653→  const lines = text.split(\"\\n\").map((line) => line.trim());\n  1654→\n  1655→  for (const line of lines) {\n  1656→    if (line.length === 0) continue;\n  1657→    if (line.length < 3 || line.length > 50) continue;\n  1658→    if (looksLikeIngredient(line)) continue;\n  1659→    if (isAllCaps(line)) continue;\n  1660→    if (startsWithNumber(line)) continue;\n  1661→    return line;\n  1662→  }\n  1663→\n  1664→  return undefined;\n  1665→}","is_error":false}]},"parent_tool_use_id":"toolu_014b1jaBC4e9WcCkenNgu7VB","session_id":"c37a3300-1904-44e6-bf34-65ba8b38fada","uuid":"8962be45-65f6-4833-b431-4494a5f84220"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EgMDYCdf6RzbgAuSfCqxer","type":"tool_result","content":"     1→/**\n     2→ * TF-IDF (Term Frequency-Inverse Document Frequency) Text Classification\n     3→ * Weights distinctive keywords higher than common ones for better classification\n     4→ */\n     5→\n     6→import type { ClassificationCategory } from \"./index.d\";\n     7→import {\n     8→  ALL_CATEGORY_KEYS,\n     9→  ALL_CUISINE_KEYS,\n    10→  ALL_SEASON_KEYS,\n    11→  CATEGORY_LABELS,\n    12→  CUISINE_LABELS,\n    13→  SEASON_LABELS,\n    14→} from \"./labels\";\n    15→\n    16→interface LabelInfo {\n    17→  key: string;\n    18→  category: ClassificationCategory;\n    19→  keywords: Array<string>;\n    20→}\n    21→\n    22→/**\n    23→ * Precomputed IDF scores for all keywords across all labels\n    24→ */\n    25→let idfScores: Map<string, number> | null = null;\n    26→let allLabels: Array<LabelInfo> | null = null;\n    27→\n    28→/**\n    29→ * Initialize IDF scores by computing how rare each keyword is across all labels\n    30→ */\n    31→function initializeIdfScores(): void {\n    32→  if (idfScores && allLabels) {\n    33→    return; // Already initialized\n    34→  }\n    35→\n    36→  // Collect all labels with their keywords\n    37→  const labels: Array<LabelInfo> = [];\n    38→\n    39→  for (const key of ALL_SEASON_KEYS) {\n    40→    const description = SEASON_LABELS[key];\n    41→    const keywords = description\n    42→      .toLowerCase()\n    43→      .split(/[,\\s]+/)\n    44→      .filter((k) => k.length > 3);\n    45→    labels.push({ key, category: \"season\", keywords });\n    46→  }\n    47→\n    48→  for (const key of ALL_CUISINE_KEYS) {\n    49→    const description = CUISINE_LABELS[key];\n    50→    const keywords = description\n    51→      .toLowerCase()\n    52→      .split(/[,\\s]+/)\n    53→      .filter((k) => k.length > 3);\n    54→    labels.push({ key, category: \"cuisine\", keywords });\n    55→  }\n    56→\n    57→  for (const key of ALL_CATEGORY_KEYS) {\n    58→    const description = CATEGORY_LABELS[key];\n    59→    const keywords = description\n    60→      .toLowerCase()\n    61→      .split(/[,\\s]+/)\n    62→      .filter((k) => k.length > 3);\n    63→    labels.push({ key, category: \"food-category\", keywords });\n    64→  }\n    65→\n    66→  allLabels = labels;\n    67→\n    68→  // Count how many labels each keyword appears in\n    69→  const keywordLabelCounts = new Map<string, number>();\n    70→\n    71→  for (const label of labels) {\n    72→    const uniqueKeywords = new Set(label.keywords);\n    73→    for (const keyword of uniqueKeywords) {\n    74→      keywordLabelCounts.set(\n    75→        keyword,\n    76→        (keywordLabelCounts.get(keyword) || 0) + 1\n    77→      );\n    78→    }\n    79→  }\n    80→\n    81→  // Compute IDF scores: IDF(keyword) = log(totalLabels / labelsContainingKeyword)\n    82→  const totalLabels = labels.length;\n    83→  idfScores = new Map<string, number>();\n    84→\n    85→  for (const [keyword, count] of keywordLabelCounts) {\n    86→    const idf = Math.log(totalLabels / count);\n    87→    idfScores.set(keyword, idf);\n    88→  }\n    89→\n    90→  console.log(\n    91→    `[TF-IDF] Initialized IDF scores for ${idfScores.size} unique keywords across ${totalLabels} labels`\n    92→  );\n    93→}\n    94→\n    95→/**\n    96→ * Compute TF (term frequency) for keywords in text\n    97→ */\n    98→function computeTermFrequency(text: string): Map<string, number> {\n    99→  const lowerText = text.toLowerCase();\n   100→  const words = lowerText.split(/[,\\s]+/).filter((w) => w.length > 3);\n   101→\n   102→  const termFreq = new Map<string, number>();\n   103→  for (const word of words) {\n   104→    termFreq.set(word, (termFreq.get(word) || 0) + 1);\n   105→  }\n   106→\n   107→  return termFreq;\n   108→}\n   109→\n   110→/**\n   111→ * Compute TF-IDF score for a label against the input text\n   112→ */\n   113→function computeLabelScore(\n   114→  textTermFreq: Map<string, number>,\n   115→  label: LabelInfo,\n   116→  idf: Map<string, number>\n   117→): number {\n   118→  let score = 0;\n   119→  let normalization = 0;\n   120→\n   121→  for (const keyword of label.keywords) {\n   122→    const idfScore = idf.get(keyword) || 0;\n   123→    const tf = textTermFreq.get(keyword) || 0;\n   124→\n   125→    if (tf > 0) {\n   126→      score += tf * idfScore;\n   127→    }\n   128→\n   129→    // Normalization: sum of IDF scores for all keywords in the label\n   130→    normalization += idfScore;\n   131→  }\n   132→\n   133→  // Normalize by the sum of IDF scores to handle labels with different keyword counts\n   134→  return normalization > 0 ? score / normalization : 0;\n   135→}\n   136→\n   137→export interface TfIdfSuggestion {\n   138→  tag: `#${string}`;\n   139→  confidence: number;\n   140→  category: ClassificationCategory;\n   141→}\n   142→\n   143→/**\n   144→ * Classify text using TF-IDF scoring\n   145→ */\n   146→export function classifyWithTfIdf(text: string): Array<TfIdfSuggestion> {\n   147→  // Initialize on first use\n   148→  initializeIdfScores();\n   149→\n   150→  if (!idfScores || !allLabels) {\n   151→    console.error(\"[TF-IDF] Failed to initialize IDF scores\");\n   152→    return [];\n   153→  }\n   154→\n   155→  // Compute term frequency for input text\n   156→  const textTermFreq = computeTermFrequency(text);\n   157→\n   158→  // Compute scores for all labels\n   159→  const suggestions: Array<TfIdfSuggestion> = [];\n   160→\n   161→  for (const label of allLabels) {\n   162→    const score = computeLabelScore(textTermFreq, label, idfScores);\n   163→\n   164→    // Only include if we have reasonable confidence\n   165→    // TF-IDF scores are typically lower than simple keyword matching\n   166→    // because they're normalized and weighted\n   167→    if (score > 0.2) {\n   168→      suggestions.push({\n   169→        tag: `#${label.key}` as `#${string}`,\n   170→        confidence: score,\n   171→        category: label.category,\n   172→      });\n   173→    }\n   174→  }\n   175→\n   176→  // Sort by confidence\n   177→  suggestions.sort((a, b) => b.confidence - a.confidence);\n   178→\n   179→  return suggestions;\n   180→}\n   181→"}]},"parent_tool_use_id":"toolu_014b1jaBC4e9WcCkenNgu7VB","session_id":"c37a3300-1904-44e6-bf34-65ba8b38fada","uuid":"b32e81d8-3f70-4c2d-8246-34c9fdc11b92"}
