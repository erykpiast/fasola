{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_01TNR2e7BV89Hs82xVfNvmHb","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01WQFJyTg5Mpjgs6ARPWfgR5","name":"Bash","input":{"command":"head -400 /Users/eryk.napierala/.claude/projects/-Users-eryk-napierala-Projects-fasola/c37a3300-1904-44e6-bf34-65ba8b38fada/tool-results/bxcxzslz1.txt"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":4,"cache_creation_input_tokens":257,"cache_read_input_tokens":86269,"cache_creation":{"ephemeral_5m_input_tokens":257,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_014b1jaBC4e9WcCkenNgu7VB","session_id":"c37a3300-1904-44e6-bf34-65ba8b38fada","uuid":"21623114-29c7-4c71-969e-44b35e980b72"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WQFJyTg5Mpjgs6ARPWfgR5","type":"tool_result","content":"     1→/**\n     2→ * Title Extraction\n     3→ * Extracts potential recipe title from OCR text using heuristics or semantic embeddings\n     4→ */\n     5→\n     6→import { cosineSimilarity } from \"./embeddings\";\n     7→import { FOOD_DICTIONARY } from \"./food-dictionary\";\n     8→\n     9→export type EmbedFn = (text: string) => Promise<Array<number>>;\n    10→\n    11→const TITLE_REFERENCE =\n    12→  \"recipe name, dish title, name of the food, nazwa przepisu, nazwa dania\";\n    13→const HEADER_REFERENCE =\n    14→  \"ingredients list, cooking directions, section heading, składniki, przygotowanie, sposób wykonania\";\n    15→const NOISE_REFERENCE =\n    16→  \"page number, table of contents, book footer, garbled text\";\n    17→\n    18→/**\n    19→ * Measurement units commonly found in ingredient lists\n    20→ */\n    21→const MEASUREMENT_PATTERNS = [\n    22→  // English\n    23→  \"cup\",\n    24→  \"cups\",\n    25→  \"tbsp\",\n    26→  \"tsp\",\n    27→  \"tablespoon\",\n    28→  \"teaspoon\",\n    29→  // \"oz\" and \"lb\" are matched with word boundaries in looksLikeIngredient\n    30→  // to avoid false positives (\"oz\" in \"mozzarella\", \"lb\" in \"albacore\")\n    31→  \"gram\",\n    32→  \"grams\",\n    33→  \"kg\",\n    34→  \"ml\",\n    35→  \"liter\",\n    36→  \"pinch\",\n    37→  \"dash\",\n    38→  \"handful\",\n    39→  // Polish\n    40→  \"łyżka\", \"łyżki\", \"łyżek\",           // tablespoon(s)\n    41→  \"łyżeczka\", \"łyżeczki\", \"łyżeczek\",   // teaspoon(s)\n    42→  \"szklanka\", \"szklanki\", \"szklanek\",    // cup(s)\n    43→  \"szczypta\",                            // pinch\n    44→  \"garść\",                               // handful\n    45→  \"opakowanie\", \"opakowania\",            // package(s)\n    46→  \"plasterek\", \"plasterki\",             // slice(s)\n    47→];\n    48→\n    49→/**\n    50→ * Patterns that identify recipe metadata lines (not titles)\n    51→ */\n    52→const METADATA_PATTERNS = [\n    53→  /^(SERVES?|MAKES?|YIELDS?)\\b/i,\n    54→  /^(PREP(ARATION)?|COOK(ING)?|PROOF|RISING|FERMENTATION|REST(ING)?)\\s*(AND\\s*)?(COOK(ING)?)?\\s*TIME/i,\n    55→  /^SAMPLE\\s+SCHEDULE\\b/i,\n    56→  /^BULK\\s+FERMENTATION\\b/i,\n    57→  /^(THIS\\s+RECIPE\\s+)?MAKES\\b/i,\n    58→  // Polish serving-size patterns: \"NA 3 PAPRYKI\", \"NA OKOŁO 1 KG\", \"DLA 4 OSÓB\"\n    59→  /^NA\\s+(\\d|OKOŁO)\\b/i,\n    60→  /^DLA\\s+\\d/i,\n    61→  // OCR-resilient: \"DLA\" + any token + serving-unit word (handles DLA & OSOB, DLA § OSOB, etc.)\n    62→  /^DLA\\s+\\S+\\s+OSOB/i,\n    63→  // OCR-resilient: \"DLA\" + single non-alphanumeric char (common digit→symbol OCR error)\n    64→  /^DLA\\s+[^a-zA-Z0-9\\s]\\s/i,\n    65→  // Time-unit metadata: any line containing \"N MIN\" or \"N GODZ\" is prep/cook/rest time,\n    66→  // regardless of OCR-corrupted prefix (catches PRZYGOTOWANTE, GOTOMANTE, etc.)\n    67→  /\\b\\d+\\s*MIN\\b/i,\n    68→  /\\b\\d+\\s*GODZ/i,\n    69→  // Season/category indicators\n    70→  /^SEZON\\s*:/i,\n    71→  /^KATEGORIA\\s*:/i,\n    72→  /^RODZAJ\\s*:/i,\n    73→  /^PORCJI\\s*:/i,       // Polish serving count\n    74→  /^PORTIONS?\\s*:/i,    // English serving count\n    75→  /^CZ[ĘE]Ś[ĆC]\\s*\\d/i,   // CZĘŚĆ 1: ... (Polish \"Part 1:\")\n    76→  /^PART\\s+\\d/i,             // PART 1: ... (English)\n    77→  /^MAIN\\s+RECIPE\\s*:/i,    // \"MAIN RECIPE: ...\" structural prefix lines\n    78→  /^--\\s*\\w/,               // \"--VARIATION:\", \"--WERSJA NOWOCZESNA\" sub-section headers\n    79→];\n    80→\n    81→/**\n    82→ * Single-word non-title words — standalone OCR fragments unlikely to be recipe titles\n    83→ */\n    84→const NON_TITLE_WORDS = new Set([\n    85→  \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"are\", \"was\",\n    86→  \"has\", \"his\", \"her\", \"its\", \"our\", \"who\", \"how\", \"may\", \"new\", \"now\",\n    87→  \"old\", \"see\", \"way\", \"did\", \"get\", \"let\", \"say\", \"she\", \"too\", \"use\",\n    88→  \"buns\", \"with\",\n    89→]);\n    90→\n    91→function looksLikeIngredient(line: string): boolean {\n    92→  const lowerLine = line.toLowerCase();\n    93→  if (MEASUREMENT_PATTERNS.some((pattern) => lowerLine.includes(pattern))) return true;\n    94→  // Compact metric: \"100g\", \"50ml\", \"250g\" — digit immediately followed by g/ml/kg\n    95→  if (/\\b\\d+\\s*(?:g|ml|kg)\\b/i.test(line)) return true;\n    96→  // \"to taste\" / \"do smaku\" — qualitative ingredient with no unit\n    97→  if (/\\bto taste\\b/i.test(line) || /\\bdo smaku\\b/i.test(line)) return true;\n    98→  return false;\n    99→}\n   100→\n   101→function startsWithNumber(line: string): boolean {\n   102→  // Match lines starting with a digit or Unicode fraction, optionally preceded by bullet\n   103→  return /^\\s*(?:[-•*]\\s*)?[\\d½⅓⅔¼¾⅕⅖⅗⅘⅙⅚⅛⅜⅝⅞]/.test(line);\n   104→}\n   105→\n   106→function stripDiacritics(text: string): string {\n   107→  return text.normalize(\"NFKD\").replace(/[\\u0300-\\u036f]/g, \"\");\n   108→}\n   109→\n   110→/**\n   111→ * Known recipe section labels — these are structural headers, not recipe titles.\n   112→ * Matched case-insensitively after trimming, stripping trailing punctuation, and stripping diacritics.\n   113→ * Polish entries are stored without diacritics for OCR resilience (e.g. \"SKLADNIKI\" matches \"składniki\").\n   114→ */\n   115→const SECTION_LABELS = new Set([\n   116→  // English\n   117→  \"ingredients\", \"directions\", \"instructions\", \"method\", \"preparation\",\n   118→  \"steps\", \"notes\", \"tip\", \"tips\", \"variations\", \"variation\",\n   119→  \"garnish\", \"topping\", \"toppings\", \"frosting\", \"filling\",\n   120→  \"serving suggestion\", \"serving suggestions\", \"serving\",\n   121→  \"glaze\", \"for the sauce\", \"for the filling\", \"for the dough\",\n   122→  \"for the topping\", \"for the glaze\", \"for the pasta dough\",\n   123→  \"for the pasta\", \"for the crust\",\n   124→  // Polish — recipe section labels (stored without diacritics for OCR resilience)\n   125→  \"skladniki\", \"przygotowanie\", \"sposob przygotowania\", \"sposob wykonania\",\n   126→  \"wykonanie\", \"wskazowki\", \"podpowiedz\", \"warianty\",\n   127→  \"sos\", \"nadzienie\", \"polewa\", \"lukier\", \"ciasto\",  // ciasto = dough/pastry base (recipe-internal section AND chapter label)\n   128→  \"instrukcje\",       // instructions\n   129→  \"uwagi\",            // notes/remarks\n   130→  \"notatki\",          // notes\n   131→  \"podawanie\",        // serving\n   132→  \"przechowywanie\",   // storage\n   133→  // Polish — recipe-book chapter/category labels (food groups, meal types)\n   134→  \"warzywa\",          // vegetables\n   135→  \"mieso\",            // meat (mięso)\n   136→  \"miesa\",            // meats (mięsa)\n   137→  \"ryby\",             // fish\n   138→  \"owoce morza\",      // seafood\n   139→  \"zupy\",             // soups\n   140→  \"salatki\",          // salads (sałatki)\n   141→  \"desery\",           // desserts\n   142→  \"napoje\",           // drinks\n   143→  \"pieczywo\",         // bread/baked goods\n   144→  \"przekaski\",        // appetizers/snacks\n   145→  \"sniadania\",        // breakfasts (śniadania)\n   146→  \"obiady\",           // dinners/lunches\n   147→  \"kolacje\",          // suppers\n   148→  \"makarony\",         // pasta dishes\n   149→  \"kasza\",            // groats/grains\n   150→  \"kasze\",            // groats/grains (plural)\n   151→  \"dania glowne\",     // main courses (dania główne)\n   152→  \"przystawki\",       // starters\n   153→  \"dodatki\",          // side dishes\n   154→  \"przetwory\",        // preserves\n   155→  \"wypieki\",          // baked goods\n   156→  \"ciasta\",           // cakes (plural)\n   157→  \"ciastka\",          // cookies\n   158→  \"torty\",            // layer cakes\n   159→  // \"placki\" removed — it commonly starts recipe titles like \"Placki Ziemniaczane\", \"Placki Żółte z Kukurydzą\"\n   160→  \"koktajle\",         // cocktails/smoothies\n   161→  // English — recipe-book chapter/category labels\n   162→  \"vegetables\", \"seafood\", \"fish\", \"soups\", \"salads\", \"desserts\",\n   163→  \"appetizers\", \"breads\", \"breakfast\", \"pasta\", \"grains\",\n   164→  \"main courses\", \"side dishes\", \"preserves\", \"baked goods\",\n   165→  \"fish & seafood\", \"soups & broths\", \"desserts & baked goods\",\n   166→  \"meats\", \"poultry\", \"game\",\n   167→]);\n   168→\n   169→/**\n   170→ * Subset of SECTION_LABELS that are food-group/chapter labels (not structural process labels).\n   171→ * These may appear as the last word of a compound recipe title (e.g. \"LEMON HERB ROASTED VEGETABLES\").\n   172→ */\n   173→const CATEGORY_SECTION_LABELS = new Set([\n   174→  // English food categories\n   175→  \"vegetables\", \"seafood\", \"fish\", \"soups\", \"salads\", \"desserts\",\n   176→  \"appetizers\", \"breads\", \"breakfast\", \"pasta\", \"grains\",\n   177→  \"meats\", \"poultry\", \"game\",\n   178→  // Polish food categories\n   179→  \"warzywa\", \"mieso\", \"miesa\", \"ryby\", \"zupy\", \"salatki\", \"desery\",\n   180→  \"napoje\", \"pieczywo\", \"przekaski\", \"sniadania\", \"obiady\", \"kolacje\",\n   181→  \"makarony\", \"kasza\", \"kasze\", \"przystawki\", \"dodatki\", \"wypieki\",\n   182→  \"ciasta\", \"ciastka\", \"torty\", \"koktajle\",\n   183→]);\n   184→\n   185→function isCategorySectionLabel(text: string): boolean {\n   186→  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n   187→  return CATEGORY_SECTION_LABELS.has(normalized);\n   188→}\n   189→\n   190→function isSectionLabel(text: string): boolean {\n   191→  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n   192→  if (SECTION_LABELS.has(normalized)) return true;\n   193→  // OCR variant: leading \"l\" may be OCR-corrupted \"I\" (e.g. \"lngredients\" → \"ingredients\")\n   194→  const ocrNormalized = normalized.replace(/^l/, \"i\");\n   195→  if (ocrNormalized !== normalized && SECTION_LABELS.has(ocrNormalized)) return true;\n   196→  return false;\n   197→}\n   198→\n   199→/**\n   200→ * Recipe-internal section labels that should ALWAYS block multi-line joins,\n   201→ * even when the combined word count is ≥ 3.\n   202→ * Category labels (\"zupy\", \"placki\", etc.) are NOT in this set — they can\n   203→ * legitimately start a multi-word recipe title like \"Zupy Zimowe Warzywne\".\n   204→ */\n   205→const ALWAYS_BLOCK_JOIN_LABELS = new Set([\n   206→  \"ingredients\", \"directions\", \"instructions\", \"method\", \"preparation\",\n   207→  \"steps\", \"notes\", \"tip\", \"tips\", \"variations\", \"variation\",\n   208→  \"garnish\", \"topping\", \"toppings\", \"frosting\", \"filling\",\n   209→  \"serving suggestion\", \"serving suggestions\", \"serving\",\n   210→  \"glaze\", \"instrukcje\", \"uwagi\", \"notatki\", \"podawanie\", \"przechowywanie\",\n   211→  \"skladniki\", \"przygotowanie\", \"sposob przygotowania\", \"sposob wykonania\",\n   212→  \"wykonanie\", \"wskazowki\", \"podpowiedz\", \"warianty\",\n   213→  \"sos\", \"nadzienie\", \"polewa\", \"lukier\", \"ciasto\",\n   214→]);\n   215→\n   216→function isAlwaysBlockJoinLabel(text: string): boolean {\n   217→  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n   218→  return ALWAYS_BLOCK_JOIN_LABELS.has(normalized);\n   219→}\n   220→\n   221→function isAllCaps(line: string): boolean {\n   222→  const letters = line.replace(/[^a-zA-Z]/g, \"\");\n   223→  return letters.length > 0 && letters === letters.toUpperCase();\n   224→}\n   225→\n   226→function looksLikeMetadata(text: string): boolean {\n   227→  return METADATA_PATTERNS.some((pattern) => pattern.test(text.trim()));\n   228→}\n   229→\n   230→/** Content words are ≥3 alpha characters after stripping punctuation. */\n   231→function extractContentWords(text: string): string[] {\n   232→  return text\n   233→    .split(/\\s+/)\n   234→    .filter((w) => w.replace(/[^a-zA-ZÀ-ÿ]/g, \"\").length >= 3)\n   235→    .map((w) => w.toUpperCase());\n   236→}\n   237→\n   238→/**\n   239→ * Returns true if the candidate's vocabulary is sufficiently supported by the rest of\n   240→ * the document. Short candidates (≤3 content words) require 100% corroboration;\n   241→ * longer candidates require ≥67%. Used to detect orphaned OCR artifacts in multi-title pages.\n   242→ */\n   243→function passesCorroboration(\n   244→  text: string,\n   245→  position: number,\n   246→  allLines: string[],\n   247→  startLine: number = 0 // Only check corroboration against lines from this index onward\n   248→): boolean {\n   249→  const contentWords = extractContentWords(text);\n   250→\n   251→  if (contentWords.length === 0) {\n   252→    return true; // No checkable words — pass through\n   253→  }\n   254→\n   255→  let corroboratedCount = 0;\n   256→  for (const word of contentWords) {\n   257→    for (let i = startLine; i < allLines.length; i++) {\n   258→      if (i === position) continue;\n   259→      if (allLines[i].toUpperCase().includes(word)) {\n   260→        corroboratedCount++;\n   261→        break;\n   262→      }\n   263→    }\n   264→  }\n   265→\n   266→  const score = corroboratedCount / contentWords.length;\n   267→  const threshold = contentWords.length <= 3 ? 1.0 : 0.67;\n   268→  return score >= threshold;\n   269→}\n   270→\n   271→function isLikelyGarbled(text: string): boolean {\n   272→  const letters = text.replace(/[^a-zA-Z]/g, \"\");\n   273→  if (letters.length < 2) return true;\n   274→\n   275→  // Pipe embedded in words = OCR artifact (e.g., \"Sp|aszcz\", \"pa|ką\")\n   276→  if (/[a-zA-ZÀ-ÿа-яА-Я]\\|[a-zA-ZÀ-ÿа-яА-Я]/.test(text)) return true;\n   277→\n   278→  // Mixed Latin + Cyrillic = OCR corruption\n   279→  if (/[а-яА-ЯёЁіІїЇєЄґҐ]/.test(text) && /[a-zA-Z]/.test(text)) return true;\n   280→\n   281→  // Check vowel ratio — English/Polish text typically has 30–50% vowels\n   282→  const vowels = letters.replace(/[^aeiouAEIOUyYąęóĄĘÓ]/g, \"\").length;\n   283→  const vowelRatio = vowels / letters.length;\n   284→  if (vowelRatio < 0.10 || vowelRatio > 0.85) return true;\n   285→\n   286→  // Single orphaned word ≤3 letters that isn't a common word\n   287→  const words = text.trim().split(/\\s+/);\n   288→  const COMMON_SHORT = new Set([\n   289→    \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"had\", \"her\",\n   290→    \"was\", \"one\", \"our\", \"out\", \"are\", \"has\", \"his\", \"how\", \"its\", \"may\",\n   291→    \"new\", \"now\", \"old\", \"see\", \"way\", \"who\", \"did\", \"get\", \"let\", \"say\",\n   292→    \"she\", \"too\", \"use\",\n   293→  ]);\n   294→  // Count all Unicode letters (not just ASCII) so Polish words like \"Żur\" (3 letters) pass\n   295→  const unicodeLetters = text.trim().replace(/[^a-zA-ZąćęłńóśźżĄĆĘŁŃÓŚŹŻ]/g, \"\");\n   296→  if (words.length === 1 && unicodeLetters.length <= 3 && !COMMON_SHORT.has(text.trim().toLowerCase())) {\n   297→    return true;\n   298→  }\n   299→\n   300→  // Single word with internal lowercase→uppercase transition — OCR noise (e.g., \"UuIw\", \"aBC\")\n   301→  // No recipe title uses this pattern as a standalone single-word candidate.\n   302→  if (words.length === 1 && /[a-z][A-Z]/.test(text.trim())) {\n   303→    return true;\n   304→  }\n   305→\n   306→  // Recipe titles never start with a lowercase letter\n   307→  if (/^[a-z]/.test(text.trim())) {\n   308→    return true;\n   309→  }\n   310→\n   311→  // Mid-text sentence boundary (\". \" followed by a letter) — body text fragment spliced from multiple sentences\n   312→  const trimmed = text.trim();\n   313→  if (/\\.\\s+[a-zA-Z]/.test(trimmed) && !trimmed.endsWith(\")\")) {\n   314→    return true;\n   315→  }\n   316→\n   317→  // Multi-word candidate containing a garbled OCR fragment: a short lowercase word that isn't a known short word\n   318→  if (words.length >= 2) {\n   319→    const commonShort2 = new Set([\n   320→      \"a\", \"i\", \"of\", \"or\", \"to\", \"in\", \"on\", \"is\", \"it\", \"an\",\n   321→      \"as\", \"at\", \"by\", \"do\", \"go\", \"if\", \"no\", \"so\", \"up\", \"we\",\n   322→      \"w\", \"z\",   // Polish prepositions (basic)\n   323→      \"ze\", \"bo\", \"na\", \"ni\", \"po\", \"ku\", \"od\", \"za\", \"co\",  // Polish prepositions (extended)\n   324→    ]);\n   325→    const hasGarbledWord = words.some(\n   326→      (w) =>\n   327→        /^[a-z]/.test(w) &&\n   328→        w.replace(/[^a-z]/g, \"\").length <= 2 &&\n   329→        !commonShort2.has(w.toLowerCase())\n   330→    );\n   331→    if (hasGarbledWord) {\n   332→      return true;\n   333→    }\n   334→  }\n   335→\n   336→  return false;\n   337→}\n   338→\n   339→const COOKING_INSTRUCTION_STARTS = /^(beat|fold|stir|mix|add|pour|bake|cook|cool|remove|place|combine|whisk|knead|roll|spread|brush|slice|chop|dice|mince|drain|rinse|peel|grate|melt|simmer|boil|fry|sauté|saute|roast|grill|broil|steam|let|set|transfer|serve|garnish|arrange|sprinkle|season|preheat|cover|uncover|reduce|bring|toss|cut|trim|shape|form|scatter|score|pat|rub|skim|strain|heat|discard|rest|marinate|wrap|flip|turn|layer|stuff|drizzle|squeeze|zest|soak|thaw|freeze|chill|warm|toast|crush|pound|crack|break|separate|weigh|measure|sift|dust|coat|dip|dredge|baste|debone|butterfly|truss|shred|puree|blend|process|pulse|whip|cream|proof|rise|punch|divide|portion|assemble)\\b/i;\n   340→\n   341→// Polish imperative cooking verbs (with OCR-resilient forms — no diacritics required).\n   342→// These cover the most common recipe instruction starters. Includes common OCR-corrupted\n   343→// forms (e.g., \"Smaż\" → \"Smaz\", \"Dodaj\" → \"Dodaj\").\n   344→// Note: only verbs that NEVER start a recipe title. \"Piecz\" (bake) is excluded because\n   345→// \"Pieczeń\" (roast) and \"Pieczarki\" (mushrooms) share the prefix.\n   346→const POLISH_COOKING_INSTRUCTION_STARTS = /^(podawaj|dodaj|dodawaj|sma[zż]|gotuj|odced[zź]|wymieszaj|mieszaj|wlej|nalej|przygotuj|zagotuj|pokr[oó]j|obierz|wrzuc|wrzuć|usma[zż]|podsma[zż]|prze[lł][oó][zż]|zblenduj|ubij|roztrzepaj|rozprowad[zź]|wyrob|zamieszaj|posyp|polej|odstaw|na[lł][oó][zż]|przykryj|odkryj|wstaw|zdejmij|ods[aą]cz|rozgrzej|posiekaj|zetrzyj|wy[lł][oó][zż]|wyjmij|ukr[oó]j|przekr[oó]j|formuj|ugniataj|rozwałkuj)\\b/i;\n   347→\n   348→function looksLikeCookingInstruction(text: string): boolean {\n   349→  const words = text.trim().split(/\\s+/);\n   350→  if (words.length < 4) return false;  // Instructions are multi-word sentences\n   351→  if (COOKING_INSTRUCTION_STARTS.test(text.trim())) return true;\n   352→  if (POLISH_COOKING_INSTRUCTION_STARTS.test(text.trim())) return true;\n   353→  return false;\n   354→}\n   355→\n   356→/**\n   357→ * A line starting with a lowercase letter and having 4+ words is prose continuation.\n   358→ * Recipe titles are capitalized (Title Case or ALL CAPS), so a lowercase-start line\n   359→ * is a strong signal for mid-recipe body text.\n   360→ */\n   361→function isBodyProse(line: string): boolean {\n   362→  return /^[a-ząćęłńóśźż]/.test(line) && wordCount(line) >= 4;\n   363→}\n   364→\n   365→/**\n   366→ * Detect pages where the OCR capture starts mid-recipe with no title present.\n   367→ * Returns true if the first 3 non-empty lines (after `startFrom`) are all ingredients,\n   368→ * cooking instructions, or body prose continuation text.\n   369→ */\n   370→function isTitleAbsentPage(lines: Array<string>, startFrom: number = 0): boolean {\n   371→  const relevantLines = startFrom > 0 ? lines.slice(startFrom) : lines;\n   372→  const nonEmptyLines = relevantLines.map(l => l.trim()).filter(l => l.length > 0);\n   373→\n   374→  if (nonEmptyLines.length < 3) return false;\n   375→\n   376→  const first3 = nonEmptyLines.slice(0, 3);\n   377→\n   378→  return first3.every(line =>\n   379→    looksLikeIngredient(line) ||\n   380→    looksLikeCookingInstruction(line) ||\n   381→    isBodyProse(line)\n   382→  );\n   383→}\n   384→\n   385→function passesHardFilters(text: string): boolean {\n   386→  if (text.length < 3 || text.length > 80) return false;\n   387→  if (looksLikeIngredient(text)) return false;\n   388→  if (startsWithNumber(text)) return false;\n   389→  if (looksLikeMetadata(text)) return false;\n   390→  if (isLikelyGarbled(text)) return false;\n   391→  if (looksLikeCookingInstruction(text)) return false;\n   392→  // Pipe-separated lines are book category/chapter headers, not recipe titles\n   393→  if (text.includes(\" | \")) return false;\n   394→  // Trailing page number (e.g. \"VEGETABLE SIDES                         145\")\n   395→  if (/\\s{3,}\\d{1,4}\\s*$/.test(text)) return false;\n   396→  // Slash-separated breadcrumbs (e.g., \"/ Jesien / Zupy\") are navigation, not titles\n   397→  // Only filter when 2+ slashes are present — single-slash lines like\n   398→  // \"TITLE / SUBTITLE\" are legitimate continuation-merged titles\n   399→  if ((text.match(/\\//g) || []).length >= 2) return false;\n   400→  // Bullet-list items (ingredients or instruction steps) are never titles","is_error":false}]},"parent_tool_use_id":"toolu_014b1jaBC4e9WcCkenNgu7VB","session_id":"c37a3300-1904-44e6-bf34-65ba8b38fada","uuid":"002bef24-be11-434c-b259-464156911b6c"}
