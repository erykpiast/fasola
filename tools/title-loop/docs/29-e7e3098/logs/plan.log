{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014CdYh3daw5BAKQSuvc6YYM","type":"tool_result","content":"   430→ * Returns the index of the first non-garbled or long line.\n   431→ */\n   432→function findBurstEnd(lines: Array<{ text: string }>): number {\n   433→  let i = 0;\n   434→\n   435→  // Skip overflow preambles: blocks introduced by \"PREVIOUS RECIPE OVERFLOW\",\n   436→  // \"PREVIOUS PAGE CONTENT\", \"CORRUPTED SECTION\", etc. that precede the actual recipe.\n   437→  const OVERFLOW_MARKERS = /\\b(PREVIOUS\\s+(RECIPE|PAGE)\\b|SPILLOVER|CONTINUATION|CORRUPTED\\s+(SECTION|TEXT)\\b|PARTIAL\\s+RECIPE)\\b/i;\n   438→  let overflowEnd = 0;\n   439→  for (let k = 0; k < lines.length && k < 30; k++) {\n   440→    // Don't re-examine lines already determined to be overflow\n   441→    if (overflowEnd > 0 && k < overflowEnd) continue;\n   442→    if (OVERFLOW_MARKERS.test(lines[k].text) || /^\\[.*\\b(PREVIOUS|CORRUPTED|SPILLOVER|CONTINUATION|PARTIAL)\\b.*\\]$/i.test(lines[k].text)) {\n   443→      // Skip forward past the overflow block to the next visual separator or blank cluster\n   444→      let m = k + 1;\n   445→      let consecutiveBlanks = 0;\n   446→      while (m < lines.length) {\n   447→        const lineText = lines[m].text;\n   448→        // Stop at visual separator\n   449→        if (/^[=\\-]{4,}$/.test(lineText)) {\n   450→          overflowEnd = m + 1;\n   451→          break;\n   452→        }\n   453→        // Track consecutive blank lines\n   454→        if (lineText.trim().length === 0) {\n   455→          consecutiveBlanks++;\n   456→          if (consecutiveBlanks >= 2) {\n   457→            overflowEnd = m + 1;\n   458→            break;\n   459→          }\n   460→        } else {\n   461→          consecutiveBlanks = 0;\n   462→          // Stop at ALL_CAPS line with ≥2 words (likely next recipe heading)\n   463→          if (isAllCaps(lineText) && wordCount(lineText) >= 2) {\n   464→            overflowEnd = m; // Don't skip past the heading itself\n   465→            break;\n   466→          }\n   467→        }\n   468→        m++;\n   469→      }\n   470→      // If we walked to end without finding termination, skip everything we saw\n   471→      if (overflowEnd === 0) overflowEnd = m;\n   472→    }\n   473→  }\n   474→  if (overflowEnd > 0) i = overflowEnd;\n   475→\n   476→  while (i < lines.length && lines[i].text.length < 20 && isLikelyGarbled(lines[i].text) && !isAllCaps(lines[i].text)) {\n   477→    i++;\n   478→  }\n   479→  // Skip body-content prologues: when 3+ consecutive lines at the start are cooking\n   480→  // instructions, prose continuations, or a mix of both, skip them to find the actual\n   481→  // title region. This unifies the previous separate instruction and prose checks to\n   482→  // handle interleaved patterns (e.g., instruction → prose continuation → instruction).\n   483→  if (i === 0) {\n   484→    let j = 0;\n   485→    while (j < lines.length) {\n   486→      const t = lines[j].text;\n   487→      const isInstruction = looksLikeCookingInstruction(t);\n   488→      // Short body-text continuation: lowercase-start with 2+ words catches fragments\n   489→      // like \"creamy but still al dente...\" that follow cooking instructions.\n   490→      // Lower threshold than isBodyProse (2 vs 4 words) to handle interleaved patterns.\n   491→      const isContinuation = /^[a-ząćęłńóśźż]/.test(t) && wordCount(t) >= 2;\n   492→      // Non-lowercase body text: comma-ending or long sentence-ending lines\n   493→      const isBodyEnding = (t.endsWith(\",\") || (t.endsWith(\".\") && wordCount(t) > 4)) && wordCount(t) >= 4;\n   494→\n   495→      if (isInstruction || isContinuation || isBodyEnding) {\n   496→        j++;\n   497→      } else {\n   498→        break;\n   499→      }\n   500→    }\n   501→    if (j >= 3) {\n   502→      i = j;\n   503→    }\n   504→  }\n   505→  return i;\n   506→}\n   507→\n   508→function stripParentheticalGloss(text: string): string {\n   509→  // Strip trailing English-gloss parentheticals from ALL_CAPS titles.\n   510→  // e.g. \"PIEROGI RUSKIE (Boiled Dumplings with Potato and Cheese)\" → \"PIEROGI RUSKIE\"\n   511→  // Keep if parenthetical is ALL_CAPS (variation/subtitle in same language).\n   512→  // Keep if both base and paren are mixed-case (both are part of the title).\n   513→  const match = text.match(/^(.+?)\\s*\\(([^)]+)\\)\\s*$/);\n   514→  if (!match) return text;\n   515→  const [, base, paren] = match;\n   516→  if (isAllCaps(paren)) return text;\n   517→  if (!isAllCaps(base) && !isAllCaps(paren)) return text;\n   518→  return base.trim();\n   519→}\n   520→\n   521→function stripPageNumber(text: string): string {\n   522→  // \"34  Berry Jam\" → \"Berry Jam\" (2+ spaces distinguishes from \"2 eggs\")\n   523→  const match = text.match(/^\\d{1,3}\\s{2,}(.+)$/);\n   524→  return match ? match[1] : text;\n   525→}\n   526→\n   527→function wordCount(text: string): number {\n   528→  return text.split(/\\s+/).filter((w) => w.length > 0).length;\n   529→}"}]},"parent_tool_use_id":null,"session_id":"c37a3300-1904-44e6-bf34-65ba8b38fada","uuid":"fd052fa7-30f6-4b70-81dd-2bc0828d7e6c","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/title-extractor.ts","content":" * Returns the index of the first non-garbled or long line.\n */\nfunction findBurstEnd(lines: Array<{ text: string }>): number {\n  let i = 0;\n\n  // Skip overflow preambles: blocks introduced by \"PREVIOUS RECIPE OVERFLOW\",\n  // \"PREVIOUS PAGE CONTENT\", \"CORRUPTED SECTION\", etc. that precede the actual recipe.\n  const OVERFLOW_MARKERS = /\\b(PREVIOUS\\s+(RECIPE|PAGE)\\b|SPILLOVER|CONTINUATION|CORRUPTED\\s+(SECTION|TEXT)\\b|PARTIAL\\s+RECIPE)\\b/i;\n  let overflowEnd = 0;\n  for (let k = 0; k < lines.length && k < 30; k++) {\n    // Don't re-examine lines already determined to be overflow\n    if (overflowEnd > 0 && k < overflowEnd) continue;\n    if (OVERFLOW_MARKERS.test(lines[k].text) || /^\\[.*\\b(PREVIOUS|CORRUPTED|SPILLOVER|CONTINUATION|PARTIAL)\\b.*\\]$/i.test(lines[k].text)) {\n      // Skip forward past the overflow block to the next visual separator or blank cluster\n      let m = k + 1;\n      let consecutiveBlanks = 0;\n      while (m < lines.length) {\n        const lineText = lines[m].text;\n        // Stop at visual separator\n        if (/^[=\\-]{4,}$/.test(lineText)) {\n          overflowEnd = m + 1;\n          break;\n        }\n        // Track consecutive blank lines\n        if (lineText.trim().length === 0) {\n          consecutiveBlanks++;\n          if (consecutiveBlanks >= 2) {\n            overflowEnd = m + 1;\n            break;\n          }\n        } else {\n          consecutiveBlanks = 0;\n          // Stop at ALL_CAPS line with ≥2 words (likely next recipe heading)\n          if (isAllCaps(lineText) && wordCount(lineText) >= 2) {\n            overflowEnd = m; // Don't skip past the heading itself\n            break;\n          }\n        }\n        m++;\n      }\n      // If we walked to end without finding termination, skip everything we saw\n      if (overflowEnd === 0) overflowEnd = m;\n    }\n  }\n  if (overflowEnd > 0) i = overflowEnd;\n\n  while (i < lines.length && lines[i].text.length < 20 && isLikelyGarbled(lines[i].text) && !isAllCaps(lines[i].text)) {\n    i++;\n  }\n  // Skip body-content prologues: when 3+ consecutive lines at the start are cooking\n  // instructions, prose continuations, or a mix of both, skip them to find the actual\n  // title region. This unifies the previous separate instruction and prose checks to\n  // handle interleaved patterns (e.g., instruction → prose continuation → instruction).\n  if (i === 0) {\n    let j = 0;\n    while (j < lines.length) {\n      const t = lines[j].text;\n      const isInstruction = looksLikeCookingInstruction(t);\n      // Short body-text continuation: lowercase-start with 2+ words catches fragments\n      // like \"creamy but still al dente...\" that follow cooking instructions.\n      // Lower threshold than isBodyProse (2 vs 4 words) to handle interleaved patterns.\n      const isContinuation = /^[a-ząćęłńóśźż]/.test(t) && wordCount(t) >= 2;\n      // Non-lowercase body text: comma-ending or long sentence-ending lines\n      const isBodyEnding = (t.endsWith(\",\") || (t.endsWith(\".\") && wordCount(t) > 4)) && wordCount(t) >= 4;\n\n      if (isInstruction || isContinuation || isBodyEnding) {\n        j++;\n      } else {\n        break;\n      }\n    }\n    if (j >= 3) {\n      i = j;\n    }\n  }\n  return i;\n}\n\nfunction stripParentheticalGloss(text: string): string {\n  // Strip trailing English-gloss parentheticals from ALL_CAPS titles.\n  // e.g. \"PIEROGI RUSKIE (Boiled Dumplings with Potato and Cheese)\" → \"PIEROGI RUSKIE\"\n  // Keep if parenthetical is ALL_CAPS (variation/subtitle in same language).\n  // Keep if both base and paren are mixed-case (both are part of the title).\n  const match = text.match(/^(.+?)\\s*\\(([^)]+)\\)\\s*$/);\n  if (!match) return text;\n  const [, base, paren] = match;\n  if (isAllCaps(paren)) return text;\n  if (!isAllCaps(base) && !isAllCaps(paren)) return text;\n  return base.trim();\n}\n\nfunction stripPageNumber(text: string): string {\n  // \"34  Berry Jam\" → \"Berry Jam\" (2+ spaces distinguishes from \"2 eggs\")\n  const match = text.match(/^\\d{1,3}\\s{2,}(.+)$/);\n  return match ? match[1] : text;\n}\n\nfunction wordCount(text: string): number {\n  return text.split(/\\s+/).filter((w) => w.length > 0).length;\n}","numLines":100,"startLine":430,"totalLines":1666}}}
