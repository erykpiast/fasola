{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PJNiNXBJUD8vZmvZ7hTwnj","type":"tool_result","content":"   400→  // Bullet-list items (ingredients or instruction steps) are never titles\n   401→  if (/^\\s*[-•*]\\s/.test(text)) return false;\n   402→  // \"For the sauce:\", \"For the filling:\" etc. are sub-section headers\n   403→  if (/^For the\\s+/i.test(text) && /:\\s*$/.test(text)) return false;\n   404→  // Lines ending with \":\" are recipe sub-section headers, not titles.\n   405→  // Exception: compound titles using \" : \" as a title separator (e.g. \"LEMON CURD : LEMON CURD WITH THYME\").\n   406→  if (/:\\s*$/.test(text.trim()) && !/ : /.test(text)) return false;\n   407→  // Page references are navigation markers, not recipe titles\n   408→  if (/^Page\\s+\\d+/i.test(text.trim())) return false;\n   409→  if (/^Strona\\s+\\d+/i.test(text.trim())) return false;\n   410→  // Corrupted spillover annotations from synthetic multi-page OCR\n   411→  if (/^\\[CORRUPTED\\s+SPILLOVER/i.test(text.trim())) return false;\n   412→  // Parenthetical OCR annotation lines describing corruption artifacts\n   413→  if (/^\\(OCR\\b/i.test(text.trim())) return false;\n   414→  if (/^\\(.*\\bcorruption\\b/i.test(text.trim())) return false;\n   415→  // Square-bracket category tags (e.g., \"[CLASSIC FALL SOUPS]\")\n   416→  if (/^\\[.*\\]$/.test(text.trim())) return false;\n   417→  // Known recipe section labels are structural headers, not titles\n   418→  if (isSectionLabel(text)) return false;\n   419→  // Single-word non-title fragments\n   420→  const words = text.trim().split(/\\s+/);\n   421→  if (words.length === 1 && NON_TITLE_WORDS.has(text.trim().toLowerCase())) return false;\n   422→  // Lines with ≥8 words are almost certainly body text, not titles.\n   423→  // Exception: multi-title compounds with \" + \", \" : \", or \" & \" separators are allowed.\n   424→  if (words.length >= 8 && !/ [+:&/] /.test(text)) return false;\n   425→  return true;\n   426→}\n   427→\n   428→/**\n   429→ * Detect initial burst of short garbled lines.\n   430→ * Returns the index of the first non-garbled or long line.\n   431→ */\n   432→function findBurstEnd(lines: Array<{ text: string }>): number {\n   433→  let i = 0;\n   434→\n   435→  // Skip overflow preambles: blocks introduced by \"PREVIOUS RECIPE OVERFLOW\",\n   436→  // \"PREVIOUS PAGE CONTENT\", \"CORRUPTED SECTION\", etc. that precede the actual recipe.\n   437→  const OVERFLOW_MARKERS = /\\b(PREVIOUS\\s+(RECIPE|PAGE)\\b|SPILLOVER|CONTINUATION|CORRUPTED\\s+(SECTION|TEXT)\\b|PARTIAL\\s+RECIPE)\\b/i;\n   438→  let overflowEnd = 0;\n   439→  for (let k = 0; k < lines.length && k < 30; k++) {\n   440→    // Don't re-examine lines already determined to be overflow\n   441→    if (overflowEnd > 0 && k < overflowEnd) continue;\n   442→    if (OVERFLOW_MARKERS.test(lines[k].text) || /^\\[.*\\b(PREVIOUS|CORRUPTED|SPILLOVER|CONTINUATION|PARTIAL)\\b.*\\]$/i.test(lines[k].text)) {\n   443→      // Skip forward past the overflow block to the next visual separator or blank cluster\n   444→      let m = k + 1;\n   445→      let consecutiveBlanks = 0;\n   446→      while (m < lines.length) {\n   447→        const lineText = lines[m].text;\n   448→        // Stop at visual separator\n   449→        if (/^[=\\-]{4,}$/.test(lineText)) {\n   450→          overflowEnd = m + 1;\n   451→          break;\n   452→        }\n   453→        // Track consecutive blank lines\n   454→        if (lineText.trim().length === 0) {\n   455→          consecutiveBlanks++;\n   456→          if (consecutiveBlanks >= 2) {\n   457→            overflowEnd = m + 1;\n   458→            break;\n   459→          }\n   460→        } else {\n   461→          consecutiveBlanks = 0;\n   462→          // Stop at ALL_CAPS line with ≥2 words (likely next recipe heading)\n   463→          if (isAllCaps(lineText) && wordCount(lineText) >= 2) {\n   464→            overflowEnd = m; // Don't skip past the heading