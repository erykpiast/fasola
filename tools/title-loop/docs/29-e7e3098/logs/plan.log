 joined3, position: line.index, origin: \"3-line\" });\n   711→        }\n   712→      }\n   713→    }\n   714→  }\n   715→\n   716→  // Pre-filter to 25 before embedding calls: prefer ALL_CAPS and short candidates.\n   717→  // Position-based scoring handles final ranking.\n   718→  if (candidates.length > 25) {\n   719→    const prioritized = candidates.slice().sort((a, b) => {\n   720→      const aAllCaps = isAllCaps(a.text) ? 0 : 1;\n   721→      const bAllCaps = isAllCaps(b.text) ? 0 : 1;\n   722→      if (aAllCaps !== bAllCaps) return aAllCaps - bAllCaps;\n   723→      const aShort = wordCount(a.text) <= 5 ? 0 : 1;\n   724→      const bShort = wordCount(b.text) <= 5 ? 0 : 1;\n   725→      return aShort - bShort;\n   726→    });\n   727→    return { candidates: prioritized.slice(0, 25), burstEnd: nonEmptyLines[burstEnd]?.index ?? lines.length };\n   728→  }\n   729→\n   730→  return { candidates, burstEnd: nonEmptyLines[burstEnd]?.index ?? lines.length };\n   731→}\n   732→\n   733→/**\n   734→ * Convert an ALL_CAPS string to Title Case, using a small-words list.\n   735→ * Preserves Polish/French diacritics.\n   736→ */\n   737→function toTitleCase(text: string): string {\n   738→  const smallWords = new Set([\n   739→    \"a\", \"an\", \"the\", \"and\", \"but\", \"or\", \"for\", \"nor\",\n   740→    \"in\", \"on\", \"at\", \"to\", \"of\", \"by\", \"with\", \"from\",\n   741→    \"z\", \"w\", \"i\", \"ze\", \"na\", \"do\", \"od\", \"za\", \"po\",\n   742→  ]);\n   743→  return text.split(/(\\s+)/).map((word, idx) => {\n   744→    if (/^\\s+$/.test(word)) return word;\n   745→    const lower = word.toLowerCase();\n   746→    if (idx === 0 || !smallWords.has(lower)) {\n   747→      return lower.charAt(0).toUpperCase() + lower.slice(1);\n   748→    }\n   749→    return lower;\n   750→  }).join(\"\");\n   751→}\n   752→\n   753→/**\n   754→ * OCR digit→letter substitution map.\n   755→ * Each key is a character that OCR commonly confuses; values are possible corre