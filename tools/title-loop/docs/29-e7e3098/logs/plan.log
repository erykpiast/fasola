{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PxCwAV6MDSvUHbde5i3GE1","type":"tool_result","content":"   860→ * Apply blind OCR digit-for-letter repair without dictionary lookup.\n   861→ * Used to generate additional candidates for early-position lines where\n   862→ * positional evidence is strong enough to justify speculative repair.\n   863→ */\n   864→/**\n   865→ * Apply blind OCR repair to mixed-case text, mapping `1` to the given letter\n   866→ * between lowercase characters. Handles per-token ALL_CAPS detection internally.\n   867→ */\n   868→function applyBlindOcrRepairMixedCase(text: string, oneLetter: \"i\" | \"l\"): string {\n   869→  return text.split(/(\\s+)/).map((token) => {\n   870→    if (/^\\s+$/.test(token)) return token;\n   871→    return applyBlindOcrRepairToken(token, oneLetter);\n   872→  }).join(\"\");\n   873→}\n   874→\n   875→function applyBlindOcrRepair(text: string): string {\n   876→  if (isAllCaps(text)) {\n   877→    return text\n   878→      .replace(/1/g, \"I\")\n   879→      .replace(/0(?=[A-ZÀ-Ż])/g, \"O\")\n   880→      .replace(/(?<=[A-ZÀ-Ż])0/g, \"O\")\n   881→      .replace(/4(?=[A-ZÀ-Ż])/g, \"A\")\n   882→      .replace(/(?<=[A-ZÀ-Ż])4/g, \"A\")\n   883→      .replace(/5(?=[A-ZÀ-Ż])/g, \"S\")\n   884→      .replace(/(?<=[A-ZÀ-Ż])5/g, \"S\")\n   885→      .replace(/¡/g, \"I\")\n   886→      .replace(/€/g, \"E\")\n   887→      .replace(/[ÍÌ]/g, \"I\");\n   888→  }\n   889→  return applyBlindOcrRepairMixedCase(text, \"i\");\n   890→}\n   891→\n   892→function hasErraticCasing(text: string): boolean {\n   893→  return text.split(/\\s+/).some(word => {\n   894→    if (word.length < 3) return false;\n   895→    if (isAllCaps(word)) return false;\n   896→    const inner = word.slice(1);\n   897→    const upperInner = (inner.match(/[A-ZÀ-Ż]/g) || []).length;\n   898→    const lowerInner = (inner.match(/[a-zà-ż]/g) || []).length;\n   899→    return upperInner >= 2 && upperInner >= lowerInner * 0.3;\n   900→  });\n   901→}\n   902→\n   903→function normalizeErraticCasing(text: string): string {\n   904→  return text.split(/(\\s+)/).map(token => {\n   905→    if (/^\\s+$/.test(token)) return token;\n   906→    if (isAllCaps(token)) return token;\n   907→    if (hasErraticCasing(token)) {\n   908→      return token.charAt(0).toUpperCase() + token.slice(1).toLowerCase();\n   909→    }\n   910→    return token;\n   911→  }).join(\"\");\n   912→}\n   913→\n   914→/**\n   915→ * Generate multiple blind OCR repair variants for embedding comparison.\n   916→ * For ALL_CAPS text, returns a single variant (1→I is unambiguous).\n   917→ * For mixed-case text, returns two variants: one with 1→i and one with 1→l,\n   918→ * letting the embedding scorer pick the better one.\n   919→ */\n   920→function generateBlindOcrVariants(text: string): Array<string> {\n   921→  if (isAllCaps(text)) {\n   922→    const repaired = applyBlindOcrRepair(text);\n   923→    return repaired !== text ? [repaired] : [];\n   924→  }\n   925→\n   926→  const variants: Array<string> = [];\n   927→\n   928→  // i-variant: 1→i between lowercase letters (default, correct for most recipe text)\n   929→  const iVariant = applyBlindOcrRepair(text);\n   930→\n   931→  // l-variant: 1→l between lowercase letters (fallback for words like \"llama\", \"fillets\")\n   932→  const lVariant = applyBlindOcrRepairMixedCase(text, \"l\");\n   933→\n   934→  if (iVariant !== text) variants.push(iVariant);\n   935→  if (lVariant !== text && lVariant !== iVariant) variants.push(lVariant);\n   936→\n   937→  return variants;\n   938→}\n   939→\n   940→/**\n   941→ * Post-processing normalization for OCR-extracted titles.\n   942→ * Strips stray section markers and substitutes common OCR digit-for-letter artifacts.\n   943→ * Title-case conversion is applied only when a substitution was actually made, so\n   944→ * clean ALL_CAPS titles (e.g. \"CHOCOLATE CAKE\") are returned unchanged.\n   945→ */\n   946→function normalizeOcrTitle(raw: string): string {\n   947→  let text = raw.trim();\n   948→\n   949→  // Step 0: Dictionary-guided OCR repair — resolve ambiguous substitutions\n   950→  // using word-level context before applying blind character replacements.\n   951→  text = repairOcrText(text);\n   952→\n   953→  // Step 1: Strip trailing section markers greedily appended to the title.\n   954→  // e.g. \"MAKOWIEC ZE ŚLIWKAMI + SERVING AND STORAGE:\" → \"MAKOWIEC ZE ŚLIWKAMI\"\n   955→  text = text.replace(\n   956→    /\\s*\\+\\s*(?:SERV[IÍ1]NG(?:\\s+AND\\s+STORAGE)?|TOPPING|NOTES?|TIPS?)\\s*:?\\s*$/i,\n   957→    \"\"\n   958→  );\n   959→\n   960→  // Step 2: OCR character substitution.\n   961→  const beforeSub = text;\n   962→  text = applyBlindOcrRepair(text);\n   963→\n   964→  // Step 3: Title-case conversion — ONLY when OCR substitution changed the text.\n   965→  // This preserves clean ALL_CAPS titles (e.g. \"CHOCOLATE CAKE\") as-is.\n   966→  if (text !== beforeSub && isAllCaps(text)) {\n   967→    text = toTitleCase(text);\n   968→  }\n   969→\n   970→  // Step 4: Normalize erratic casing (e.g. \"KoPyTka\" → \"Kopytka\").\n   971→  if (hasErraticCasing(text)) {\n   972→    text = normalizeErraticCasing(text);\n   973→  }\n   974→\n   975→  return text.trim();\n   976→}\n   977→\n   978→// Module-level cache for reference embeddings\n   979→let cachedTitleRefEmbedding: Array<number> | null = null;\n   980→let cachedHeaderRefEmbedding: Array<number> | null = null;\n   981→let cachedNoiseRefEmbedding: Array<number> | null = null;\n   982→\n   983→export function _resetEmbeddingCacheForTests(): void {\n   984→  cachedTitleRefEmbedding = null;\n   985→  cachedHeaderRefEmbedding = null;\n   986→  cachedNoiseRefEmbedding = null;\n   987→}\n   988→\n   989→export async function extractTitleWithEmbeddings("}]},"parent_tool_use_id":null,"session_id":"c37a3300-1904-44e6-bf34-65ba8b38fada","uuid":"88157aab-97fe-4ce7-8f54-b9dc0190a9cf","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/title-extractor.ts","content":" * Apply blind OCR digit-for-letter repair without dictionary lookup.\n * Used to generate additional candidates for early-position lines where\n * positional evidence is strong enough to justify speculative repair.\n */\n/**\n * Apply blind OCR repair to mixed-case text, mapping `1` to the given letter\n * between lowercase characters. Handles per-token ALL_CAPS detection internally.\n */\nfunction applyBlindOcrRepairMixedCase(text: string, oneLetter: \"i\" | \"l\"): string {\n  return text.split(/(\\s+)/).map((token) => {\n    if (/^\\s+$/.test(token)) return token;\n    return applyBlindOcrRepairToken(token, oneLetter);\n  }).join(\"\");\n}\n\nfunction applyBlindOcrRepair(text: string): string {\n  if (isAllCaps(text)) {\n    return text\n      .replace(/1/g, \"I\")\n      .replace(/0(?=[A-ZÀ-Ż])/g, \"O\")\n      .replace(/(?<=[A-ZÀ-Ż])0/g, \"O\")\n      .replace(/4(?=[A-ZÀ-Ż])/g, \"A\")\n      .replace(/(?<=[A-ZÀ-Ż])4/g, \"A\")\n      .replace(/5(?=[A-ZÀ-Ż])/g, \"S\")\n      .replace(/(?<=[A-ZÀ-Ż])5/g, \"S\")\n      .replace(/¡/g, \"I\")\n      .replace(/€/g, \"E\")\n      .replace(/[ÍÌ]/g, \"I\");\n  }\n  return applyBlindOcrRepairMixedCase(text, \"i\");\n}\n\nfunction hasErraticCasing(text: string): boolean {\n  return text.split(/\\s+/).some(word => {\n    if (word.length < 3) return false;\n    if (isAllCaps(word)) return false;\n    const inner = word.slice(1);\n    const upperInner = (inner.match(/[A-ZÀ-Ż]/g) || []).length;\n    const lowerInner = (inner.match(/[a-zà-ż]/g) || []).length;\n    return upperInner >= 2 && upperInner >= lowerInner * 0.3;\n  });\n}\n\nfunction normalizeErraticCasing(text: string): string {\n  return text.split(/(\\s+)/).map(token => {\n    if (/^\\s+$/.test(token)) return token;\n    if (isAllCaps(token)) return token;\n    if (hasErraticCasing(token)) {\n      return token.charAt(0).toUpperCase() + token.slice(1).toLowerCase();\n    }\n    return token;\n  }).join(\"\");\n}\n\n/**\n * Generate multiple blind OCR repair variants for embedding comparison.\n * For ALL_CAPS text, returns a single variant (1→I is unambiguous).\n * For mixed-case text, returns two variants: one with 1→i and one with 1→l,\n * letting the embedding scorer pick the better one.\n */\nfunction generateBlindOcrVariants(text: string): Array<string> {\n  if (isAllCaps(text)) {\n    const repaired = applyBlindOcrRepair(text);\n    return repaired !== text ? [repaired] : [];\n  }\n\n  const variants: Array<string> = [];\n\n  // i-variant: 1→i between lowercase letters (default, correct for most recipe text)\n  const iVariant = applyBlindOcrRepair(text);\n\n  // l-variant: 1→l between lowercase letters (fallback for words like \"llama\", \"fillets\")\n  const lVariant = applyBlindOcrRepairMixedCase(text, \"l\");\n\n  if (iVariant !== text) variants.push(iVariant);\n  if (lVariant !== text && lVariant !== iVariant) variants.push(lVariant);\n\n  return variants;\n}\n\n/**\n * Post-processing normalization for OCR-extracted titles.\n * Strips stray section markers and substitutes common OCR digit-for-letter artifacts.\n * Title-case conversion is applied only when a substitution was actually made, so\n * clean ALL_CAPS titles (e.g. \"CHOCOLATE CAKE\") are returned unchanged.\n */\nfunction normalizeOcrTitle(raw: string): string {\n  let text = raw.trim();\n\n  // Step 0: Dictionary-guided OCR repair — resolve ambiguous substitutions\n  // using word-level context before applying blind character replacements.\n  text = repairOcrText(text);\n\n  // Step 1: Strip trailing section markers greedily appended to the title.\n  // e.g. \"MAKOWIEC ZE ŚLIWKAMI + SERVING AND STORAGE:\" → \"MAKOWIEC ZE ŚLIWKAMI\"\n  text = text.replace(\n    /\\s*\\+\\s*(?:SERV[IÍ1]NG(?:\\s+AND\\s+STORAGE)?|TOPPING|NOTES?|TIPS?)\\s*:?\\s*$/i,\n    \"\"\n  );\n\n  // Step 2: OCR character substitution.\n  const beforeSub = text;\n  text = applyBlindOcrRepair(text);\n\n  // Step 3: Title-case conversion — ONLY when OCR substitution changed the text.\n  // This preserves clean ALL_CAPS titles (e.g. \"CHOCOLATE CAKE\") as-is.\n  if (text !== beforeSub && isAllCaps(text)) {\n    text = toTitleCase(text);\n  }\n\n  // Step 4: Normalize erratic casing (e.g. \"KoPyTka\" → \"Kopytka\").\n  if (hasErraticCasing(text)) {\n    text = normalizeErraticCasing(text);\n  }\n\n  return text.trim();\n}\n\n// Module-level cache for reference embeddings\nlet cachedTitleRefEmbedding: Array<number> | null = null;\nlet cachedHeaderRefEmbedding: Array<number> | null = null;\nlet cachedNoiseRefEmbedding: Array<number> | null = null;\n\nexport function _resetEmbeddingCacheForTests(): void {\n  cachedTitleRefEmbedding = null;\n  cachedHeaderRefEmbedding = null;\n  cachedNoiseRefEmbedding = null;\n}\n\nexport async function extractTitleWithEmbeddings(","numLines":130,"startLine":860,"totalLines":1666}}}
