{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013TU88MLAmBPdxZ4MNiAVPk","type":"tool_result","content":"   271→function isLikelyGarbled(text: string): boolean {\n   272→  const letters = text.replace(/[^a-zA-Z]/g, \"\");\n   273→  if (letters.length < 2) return true;\n   274→\n   275→  // Pipe embedded in words = OCR artifact (e.g., \"Sp|aszcz\", \"pa|ką\")\n   276→  if (/[a-zA-ZÀ-ÿа-яА-Я]\\|[a-zA-ZÀ-ÿа-яА-Я]/.test(text)) return true;\n   277→\n   278→  // Mixed Latin + Cyrillic = OCR corruption\n   279→  if (/[а-яА-ЯёЁіІїЇєЄґҐ]/.test(text) && /[a-zA-Z]/.test(text)) return true;\n   280→\n   281→  // Check vowel ratio — English/Polish text typically has 30–50% vowels\n   282→  const vowels = letters.replace(/[^aeiouAEIOUyYąęóĄĘÓ]/g, \"\").length;\n   283→  const vowelRatio = vowels / letters.length;\n   284→  if (vowelRatio < 0.10 || vowelRatio > 0.85) return true;\n   285→\n   286→  // Single orphaned word ≤3 letters that isn't a common word\n   287→  const words = text.trim().split(/\\s+/);\n   288→  const COMMON_SHORT = new Set([\n   289→    \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"had\", \"her\",\n   290→    \"was\", \"one\", \"our\", \"out\", \"are\", \"has\", \"his\", \"how\", \"its\", \"may\",\n   291→    \"new\", \"now\", \"old\", \"see\", \"way\", \"who\", \"did\", \"get\", \"let\", \"say\",\n   292→    \"she\", \"too\", \"use\",\n   293→  ]);\n   294→  // Count all Unicode letters (not just ASCII) so Polish words like \"Żur\" (3 letters) pass\n   295→  const unicodeLetters = text.trim().replace(/[^a-zA-ZąćęłńóśźżĄĆĘŁŃÓŚŹŻ]/g, \"\");\n   296→  if (words.length === 1 && unicodeLetters.length <= 3 && !COMMON_SHORT.has(text.trim().toLowerCase())) {\n   297→    return true;\n   298→  }\n   299→\n   300→  // Single word with internal lowercase→uppercase transition — OCR noise (e.g., \"UuIw\", \"aBC\")\n   301→  // No recipe title uses this pattern as a standalone single-word candidate.\n   302→  if (words.length === 1 && /[a-z][A-Z]/.test(text.trim())) {\n   303→    return true;\n   304→  }\n   305→\n   306→  // Recipe titles never start with a lowercase letter\n   307→  if (/^[a-z]/.test(text.trim())) {\n   308→    return true;\n   309→  }\n   310→\n   311→  // Mid-text sentence boundary (\". \" followed by a letter) — body text fragment spliced from multiple sentences\n   312→  const trimmed = text.trim();\n   313→  if (/\\.\\s+[a-zA-Z]/.test(trimmed) && !trimmed.endsWith(\")\")) {\n   314→    return true;\n   315→  }\n   316→\n   317→  // Multi-word candidate containing a garbled OCR fragment: a short lowercase word that isn't a known short word\n   318→  if (words.length >= 2) {\n   319→    const commonShort2 = new Set([\n   320→      \"a\", \"i\", \"of\", \"or\", \"to\", \"in\", \"on\", \"is\", \"it\", \"an\",\n   321→      \"as\", \"at\", \"by\", \"do\", \"go\", \"if\", \"no\", \"so\", \"up\", \"we\",\n   322→      \"w\", \"z\",   // Polish prepositions (basic)\n   323→      \"ze\", \"bo\", \"na\", \"ni\", \"po\", \"ku\", \"od\", \"za\", \"co\",  // Polish prepositions (extended)\n   324→    ]);\n   325→    const hasGarbledWord = words.some(\n   326→      (w) =>\n   327→        /^[a-z]/.test(w) &&\n   328→        w.replace(/[^a-z]/g, \"\").length <= 2 &&\n   329→        !commonShort2.has(w.toLowerCase())\n   330→    );\n   331→    if (hasGarbledWord) {\n   332→      return true;\n   333→    }\n   334→  }\n   335→\n   336→  return false;\n   337→}\n   338→\n   339→const COOKING_INSTRUCTION_STARTS = /^(beat|fold|stir|mix|add|pour|bake|cook|cool|remove|place|combine|whisk|knead|roll|spread|brush|slice|chop|dice|mince|drain|rinse|peel|grate|melt|simmer|boil|fry|sauté|saute|roast|grill|broil|steam|let|set|transfer|serve|garnish|arrange|sprinkle|season|preheat|cover|uncover|reduce|bring|toss|cut|trim|shape|form|scatter|score|pat|rub|skim|strain|heat|discard|rest|marinate|wrap|flip|turn|layer|stuff|drizzle|squeeze|zest|soak|thaw|freeze|chill|warm|toast|crush|pound|crack|break|separate|weigh|measure|sift|dust|coat|dip|dredge|baste|debone|butterfly|truss|shred|puree|blend|process|pulse|whip|cream|proof|rise|punch|divide|portion|assemble)\\b/i;\n   340→\n   341→// Polish imperative cooking verbs (with OCR-resilient forms — no diacritics required).\n   342→// These cover the most common recipe instruction starters. Includes common OCR-corrupted\n   343→// forms (e.g., \"Smaż\" → \"Smaz\", \"Dodaj\" → \"Dodaj\").\n   344→// Note: only verbs that NEVER start a recipe title. \"Piecz\" (bake) is excluded because\n   345→// \"Pieczeń\" (roast) and \"Pieczarki\" (mushrooms) share the prefix.\n   346→const POLISH_COOKING_INSTRUCTION_STARTS = /^(podawaj|dodaj|dodawaj|sma[zż]|gotuj|odced[zź]|wymieszaj|mieszaj|wlej|nalej|przygotuj|zagotuj|pokr[oó]j|obierz|wrzuc|wrzuć|usma[zż]|podsma[zż]|prze[lł][oó][zż]|zblenduj|ubij|roztrzepaj|rozprowad[zź]|wyrob|zamieszaj|posyp|polej|odstaw|na[lł][oó][zż]|przykryj|odkryj|wstaw|zdejmij|ods[aą]cz|rozgrzej|posiekaj|zetrzyj|wy[lł][oó][zż]|wyjmij|ukr[oó]j|przekr[oó]j|formuj|ugniataj|rozwałkuj)\\b/i;\n   347→\n   348→function looksLikeCookingInstruction(text: string): boolean {\n   349→  const words = text.trim().split(/\\s+/);\n   350→  if (words.length < 4) return false;  // Instructions are multi-word sentences"}]},"parent_tool_use_id":null,"session_id":"c37a3300-1904-44e6-bf34-65ba8b38fada","uuid":"b7442c86-cc3a-4d38-abfc-552e7248cba9","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/title-extractor.ts","content":"function isLikelyGarbled(text: string): boolean {\n  const letters = text.replace(/[^a-zA-Z]/g, \"\");\n  if (letters.length < 2) return true;\n\n  // Pipe embedded in words = OCR artifact (e.g., \"Sp|aszcz\", \"pa|ką\")\n  if (/[a-zA-ZÀ-ÿа-яА-Я]\\|[a-zA-ZÀ-ÿа-яА-Я]/.test(text)) return true;\n\n  // Mixed Latin + Cyrillic = OCR corruption\n  if (/[а-яА-ЯёЁіІїЇєЄґҐ]/.test(text) && /[a-zA-Z]/.test(text)) return true;\n\n  // Check vowel ratio — English/Polish text typically has 30–50% vowels\n  const vowels = letters.replace(/[^aeiouAEIOUyYąęóĄĘÓ]/g, \"\").length;\n  const vowelRatio = vowels / letters.length;\n  if (vowelRatio < 0.10 || vowelRatio > 0.85) return true;\n\n  // Single orphaned word ≤3 letters that isn't a common word\n  const words = text.trim().split(/\\s+/);\n  const COMMON_SHORT = new Set([\n    \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"had\", \"her\",\n    \"was\", \"one\", \"our\", \"out\", \"are\", \"has\", \"his\", \"how\", \"its\", \"may\",\n    \"new\", \"now\", \"old\", \"see\", \"way\", \"who\", \"did\", \"get\", \"let\", \"say\",\n    \"she\", \"too\", \"use\",\n  ]);\n  // Count all Unicode letters (not just ASCII) so Polish words like \"Żur\" (3 letters) pass\n  const unicodeLetters = text.trim().replace(/[^a-zA-ZąćęłńóśźżĄĆĘŁŃÓŚŹŻ]/g, \"\");\n  if (words.length === 1 && unicodeLetters.length <= 3 && !COMMON_SHORT.has(text.trim().toLowerCase())) {\n    return true;\n  }\n\n  // Single word with internal lowercase→uppercase transition — OCR noise (e.g., \"UuIw\", \"aBC\")\n  // No recipe title uses this pattern as a standalone single-word candidate.\n  if (words.length === 1 && /[a-z][A-Z]/.test(text.trim())) {\n    return true;\n  }\n\n  // Recipe titles never start with a lowercase letter\n  if (/^[a-z]/.test(text.trim())) {\n    return true;\n  }\n\n  // Mid-text sentence boundary (\". \" followed by a letter) — body text fragment spliced from multiple sentences\n  const trimmed = text.trim();\n  if (/\\.\\s+[a-zA-Z]/.test(trimmed) && !trimmed.endsWith(\")\")) {\n    return true;\n  }\n\n  // Multi-word candidate containing a garbled OCR fragment: a short lowercase word that isn't a known short word\n  if (words.length >= 2) {\n    const commonShort2 = new Set([\n      \"a\", \"i\", \"of\", \"or\", \"to\", \"in\", \"on\", \"is\", \"it\", \"an\",\n      \"as\", \"at\", \"by\", \"do\", \"go\", \"if\", \"no\", \"so\", \"up\", \"we\",\n      \"w\", \"z\",   // Polish prepositions (basic)\n      \"ze\", \"bo\", \"na\", \"ni\", \"po\", \"ku\", \"od\", \"za\", \"co\",  // Polish prepositions (extended)\n    ]);\n    const hasGarbledWord = words.some(\n      (w) =>\n        /^[a-z]/.test(w) &&\n        w.replace(/[^a-z]/g, \"\").length <= 2 &&\n        !commonShort2.has(w.toLowerCase())\n    );\n    if (hasGarbledWord) {\n      return true;\n    }\n  }\n\n  return false;\n}\n\nconst COOKING_INSTRUCTION_STARTS = /^(beat|fold|stir|mix|add|pour|bake|cook|cool|remove|place|combine|whisk|knead|roll|spread|brush|slice|chop|dice|mince|drain|rinse|peel|grate|melt|simmer|boil|fry|sauté|saute|roast|grill|broil|steam|let|set|transfer|serve|garnish|arrange|sprinkle|season|preheat|cover|uncover|reduce|bring|toss|cut|trim|shape|form|scatter|score|pat|rub|skim|strain|heat|discard|rest|marinate|wrap|flip|turn|layer|stuff|drizzle|squeeze|zest|soak|thaw|freeze|chill|warm|toast|crush|pound|crack|break|separate|weigh|measure|sift|dust|coat|dip|dredge|baste|debone|butterfly|truss|shred|puree|blend|process|pulse|whip|cream|proof|rise|punch|divide|portion|assemble)\\b/i;\n\n// Polish imperative cooking verbs (with OCR-resilient forms — no diacritics required).\n// These cover the most common recipe instruction starters. Includes common OCR-corrupted\n// forms (e.g., \"Smaż\" → \"Smaz\", \"Dodaj\" → \"Dodaj\").\n// Note: only verbs that NEVER start a recipe title. \"Piecz\" (bake) is excluded because\n// \"Pieczeń\" (roast) and \"Pieczarki\" (mushrooms) share the prefix.\nconst POLISH_COOKING_INSTRUCTION_STARTS = /^(podawaj|dodaj|dodawaj|sma[zż]|gotuj|odced[zź]|wymieszaj|mieszaj|wlej|nalej|przygotuj|zagotuj|pokr[oó]j|obierz|wrzuc|wrzuć|usma[zż]|podsma[zż]|prze[lł][oó][zż]|zblenduj|ubij|roztrzepaj|rozprowad[zź]|wyrob|zamieszaj|posyp|polej|odstaw|na[lł][oó][zż]|przykryj|odkryj|wstaw|zdejmij|ods[aą]cz|rozgrzej|posiekaj|zetrzyj|wy[lł][oó][zż]|wyjmij|ukr[oó]j|przekr[oó]j|formuj|ugniataj|rozwałkuj)\\b/i;\n\nfunction looksLikeCookingInstruction(text: string): boolean {\n  const words = text.trim().split(/\\s+/);\n  if (words.length < 4) return false;  // Instructions are multi-word sentences","numLines":80,"startLine":271,"totalLines":1666}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Wgd3jVrxd9YyD2hKYPbBYj","type":"tool_result","content":"     1→/**\n     2→ * Common English and Polish food/cooking words and structural recipe title\n     3→ * words (prepositions, adjectives) for OCR repair.\n     4→ * Words are lowercase, without diacritics (OCR-resilient matching).\n     5→ * Used by repairOcrWord() to resolve ambiguous digit→letter substitutions.\n     6→ */\n     7→export const FOOD_DICTIONARY: Set<string> = new Set([\n     8→  // ── English ingredients ──────────────────────────────────────────────────\n     9→  \"chicken\", \"beef\", \"pork\", \"lamb\", \"veal\", \"duck\", \"turkey\", \"venison\",\n    10→  \"salmon\", \"cod\", \"halibut\", \"tuna\", \"trout\", \"sardine\", \"anchovy\",\n    11→  \"shrimp\", \"prawn\", \"lobster\", \"crab\", \"scallop\", \"mussel\", \"clam\",\n    12→  \"tofu\", \"tempeh\", \"seitan\",\n    13→\n    14→  // Grains & starches\n    15→  \"rice\", \"pasta\", \"bread\", \"noodle\", \"flour\", \"oat\", \"barley\", \"wheat\",\n    16→  \"rye\", \"quinoa\", \"corn\", \"cornmeal\", \"semolina\", \"couscous\", \"polenta\",\n    17→  \"buckwheat\", \"millet\",\n    18→\n    19→  // Dairy & eggs\n    20→  \"butter\", \"cream\", \"cheese\", \"milk\", \"egg\", \"yogurt\", \"ghee\",\n    21→  \"ricotta\", \"mozzarella\", \"parmesan\", \"cheddar\", \"brie\", \"feta\",\n    22→\n    23→  // Fats & condiments\n    24→  \"oil\", \"vinegar\", \"mustard\", \"ketchup\", \"mayo\", \"mayonnaise\",\n    25→  \"soy\", \"sauce\", \"paste\", \"stock\", \"broth\", \"gravy\",\n    26→\n    27→  // Vegetables\n    28→  \"garlic\", \"onion\", \"tomato\", \"potato\", \"carrot\", \"celery\", \"pepper\",\n    29→  \"broccoli\", \"cauliflower\", \"asparagus\", \"artichoke\", \"eggplant\",\n    30→  \"zucchini\", \"squash\", \"pumpkin\", \"cucumber\", \"radish\", \"turnip\",\n    31→  \"beet\", \"mushroom\", \"avocado\", \"olive\", \"bean\", \"lentil\", \"chickpea\",\n    32→  \"arugula\", \"spinach\", \"kale\", \"lettuce\", \"cabbage\", \"leek\", \"fennel\",\n    33→  \"chard\", \"endive\", \"watercress\", \"sprout\", \"pea\", \"edamame\",\n    34→  \"scallion\", \"shallot\", \"chili\", \"jalapeno\", \"poblano\", \"serrano\",\n    35→  \"brukselka\",\n    36→\n    37→  // Fruits\n    38→  \"lemon\", \"lime\", \"orange\", \"apple\", \"berry\", \"blackberry\", \"blueberry\",\n    39→  \"raspberry\", \"strawberry\", \"cherry\", \"peach\", \"pear\", \"plum\", \"grape\",\n    40→  \"banana\", \"mango\", \"pineapple\", \"coconut\", \"fig\", \"date\", \"apricot\",\n    41→  \"pomegranate\", \"melon\", \"watermelon\", \"grapefruit\", \"papaya\", \"kiwi\",\n    42→  \"passion\", \"guava\", \"lychee\",\n    43→\n    44→  // Nuts & seeds\n    45→  \"almond\", \"walnut\", \"pecan\", \"cashew\", \"pistachio\", \"hazelnut\",\n    46→  \"peanut\", \"sesame\", \"flaxseed\", \"chia\", \"sunflower\", \"pumpkinseed\",\n    47→  \"poppy\",\n    48→\n    49→  // Spices & herbs\n    50→  \"ginger\", \"cinnamon\", \"cumin\", \"paprika\", \"turmeric\", \"oregano\",\n    51→  \"basil\", \"thyme\", \"rosemary\", \"parsley\", \"cilantro\", \"dill\", \"mint\",\n    52→  \"sage\", \"chive\", \"tarragon\", \"nutmeg\", \"clove\", \"cardamom\", \"saffron\",\n    53→  \"vanilla\", \"anise\", \"coriander\", \"bay\", \"marjoram\", \"chervil\",\n    54→  \"fenugreek\", \"sumac\", \"caraway\", \"allspice\",\n    55→\n    56→  // Sweeteners & flavourings\n    57→  \"chocolate\", \"cocoa\", \"honey\", \"maple\", \"molasses\", \"sugar\", \"salt\",\n    58→  \"yeast\", \"baking\", \"powder\", \"soda\",\n    59→\n    60→  // Common recipe adjectives / descriptors\n    61→  \"white\", \"red\", \"green\", \"black\", \"brown\", \"sweet\", \"sour\", \"hot\",\n    62→  \"cold\", \"fresh\", \"dried\", \"whole\", \"ground\", \"roasted\", \"grilled\",\n    63→  \"braised\", \"baked\", \"fried\", \"steamed\", \"smoked\", \"stuffed\", \"glazed\",\n    64→  \"caramelized\", \"pick