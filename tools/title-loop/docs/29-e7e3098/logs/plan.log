33→    if (looksLikeMetadata(mergedLines[i].text)) {\n   634→      const next = mergedLines[i + 1];\n   635→      if (isAllCaps(next.text) && wordCount(next.text) <= 2 && next.text.length <= 15) {\n   636→        metadataContinuationPositions.add(next.index);\n   637→      }\n   638→    }\n   639→  }\n   640→\n   641→  for (let i = 0; i < mergedLines.length; i++) {\n   642→    const line = mergedLines[i];\n   643→\n   644→    // Skip metadata continuation fragments\n   645→    if (metadataContinuationPositions.has(line.index)) continue;\n   646→\n   647→    // Single line — strip page-number prefixes and parenthetical glosses before scoring\n   648→    const singleText = repairOcrText(stripParentheticalGloss(stripPageNumber(line.text)));\n   649→    if (passesHardFilters(singleText)) {\n   650→      const norm = singleText.toLowerCase();\n   651→      if (!seen.has(norm)) {\n   652→        seen.add(norm);\n   653→        candidates.push({ text: singleText, position: line.index, origin: \"single\" });\n   654→      }\n   655→    }\n   656→\n   657→    // Blind OCR repair for early-position candidates: when the original text\n   658→    // has OCR artifacts or erratic casing and is in the first few lines,\n   659→    // generate additional candidates with blind digit→letter repair and/or\n   660→    // casing normalization. This gives the embedding scorer clean versions\n   661→    // even when dictionary repair misses.\n   662→    if (line.index <= 5 && (OCR_ARTIFACT_PATTERN.test(line.text) || hasErraticCasing(line.text))) {\n   663→      let repairable = singleText;\n   664→      if (hasErraticCasing(repairable)) {\n   665→        repairable = normalizeErraticCasing(repairable);\n   666→        if (repairable !== singleText && passesHardFilters(repairable)) {\n   667→          const norm = repairable.toLowerCase();\n   668→          if (!seen.has(norm)) {\n   669→            seen.add(norm);\n   670→            candidates.push({ text: repairable, position: line.index