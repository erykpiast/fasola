{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UmxubW4tuhNGdU4uBsevpi","type":"tool_result","content":"  1190→\n  1191→  // --- Pre-threshold bilingual title detection ---\n  1192→  // When a mixed-case candidate at position 0 is followed by an ALL_CAPS candidate\n  1193→  // at position ≤ 2 that is semantically similar to it, this is a bilingual recipe\n  1194→  // page (e.g., Polish title + ALL_CAPS Korean romanization). Suppress confirmed\n  1195→  // translation candidates before computing threshold so their bonuses don't inflate\n  1196→  // the threshold beyond the mixed-case title's reach.\n  1197→  // Note: we check position ≤ 2 (local proximity), not global ALL_CAPS count, so\n  1198→  // section headers later in the document (SKŁADNIKI, WARZYWA, etc.) are irrelevant.\n  1199→  let translationCandidates: typeof scored = [];\n  1200→  let scoredForThreshold = scored;\n  1201→  const prePos0 = scored.find((s) => s.position === 0 && !isAllCaps(s.text));\n  1202→  if (prePos0) {\n  1203→    const nearbyAllCaps = scored.filter(\n  1204→      (s) => isAllCaps(s.text) && s.position >= 1 && s.position <= 2 && s.origin === \"single\"\n  1205→    );\n  1206→    const pos0Embedding = rawScored.find((r) => r.text === prePos0.text)?.embedding;\n  1207→\n  1208→    // Method 1: embedding similarity (works for related languages)\n  1209→    if (pos0Embedding && nearbyAllCaps.length > 0) {\n  1210→      translationCandidates = nearbyAllCaps.filter((cap) => {\n  1211→        const capEmbedding = rawScored.find((r) => r.text === cap.text)?.embedding;\n  1212→        if (!capEmbedding) return false;\n  1213→        return cosineSimilarity(pos0Embedding, capEmbedding) > 0.4;\n  1214→      });\n  1215→    }\n  1216→\n  1217→    // Method 2: layout-based detection (cross-lingual fallback).\n  1218→    // When embedding similarity is insufficient (e.g. Polish ↔ Korean romanization),\n  1219→    // detect bilingual layout by position and word overlap:\n  1220→    // mixed-case ≥2 words at pos 0 + ALL_CAPS ≥2 words at pos 1-2 with no shared words.\n  1221→    if (translationCandidates.length === 0 && wordCount(prePos0.text) >= 2) {\n  1222→      const pos0Words = new Set(\n  1223→        prePos0.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2)\n  1224→      );\n  1225→      translationCandidates = nearbyAllCaps.filter((cap) => {\n  1226→        if (wordCount(cap.text) < 2) return false;\n  1227→        const capWords = cap.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2);\n  1228→        return !capWords.some((w) => pos0Words.has(w));\n  1229→      });\n  1230→    }\n  1231→\n  1232→    if (translationCandidates.length > 0) {\n  1233→      // Suppress standalone translations and any multi-line joins that embed the translation\n  1234→      // as a suffix or substring (e.g. \"Smażona zielona fasolka GREEN BEANS BORKEUM\" ends with\n  1235→      // the translation; \"Title GREEN BEANS BORKEUM 그린빈\" includes it as a substring).\n  1236→      scoredForThreshold = scored.filter((s) => {\n  1237→        const sLower = s.text.toLowerCase();\n  1238→        return !translationCandidates.some((t) => {\n  1239→          const tLower = t.text.toLowerCase();\n  1240→          return sLower.startsWith(tLower) ||\n  1241→                 sLower.endsWith(\" \" + tLower) ||\n  1242→                 sLower.includes(\" \" + tLower);\n  1243→        });\n  1244→      });\n  1245→    }\n  1246→  }\n  1247→\n  1248→  // Fix 2: If the structural heading was identified as a bilingual translation, reassign it.\n  1249→  // This prevents the translation's ALL_CAPS bonus from inflating the threshold and ensures\n  1250→  // the fallback path in scored also uses the correct heading.\n  1251→  if (\n  1252→    translationCandidates.length > 0 &&\n  1253→    firstStructuralHeading &&\n  1254→    translationCandidates.some((t) => t.text === firstStructuralHeading!.text)\n  1255→  ) {\n  1256→    const nonTranslationStructural = structuralCandidates.filter(\n  1257→      (sc) => !translationCandidates.some((t) => t.text === sc.text)\n  1258→    );\n  1259→    const newHeading = nonTranslationStructural.length > 0\n  1260→      ? nonTranslationStructural.reduce((a, b) => a.rawScore > b.rawScore ? a : b)\n  1261→      : undefined;\n  1262→\n  1263→    // Patch scored array: remove old structural bonus, apply new one\n  1264→    for (const s of scored) {\n  1265→      if (s.text === firstStructuralHeading.text) {\n  1266→        s.score -= 0.10;\n  1267→        s.baseScore -= 0.10;\n  1268→      }\n  1269→      if (newHeading && s.text === newHeading.text) {\n  1270→        s.score += 0.10;\n  1271→        s.baseScore += 0.10;\n  1272→      }\n  1273→    }\n  1274→    // Update reference for downstream prefix-removal logic\n  1275→    firstStructuralHeading = newHeading ?? undefined;\n  1276→  }\n  1277→\n  1278→  // Subtitle suppression: when a short mixed-case title at position 0 is followed by a\n  1279→  // longer mixed-case candidate at position 1-2, the longer one is a subtitle/translation.\n  1280→  // Apply a penalty so the primary title (position 0) wins.\n  1281→  const pos0Primary = scored.find((s) => s.position === 0 && !isAllCaps(s.text) && wordCount(s.text) <= 5);\n  1282→  if (pos0Primary) {\n  1283→    const subtitleCandidates = scored.filter((s) =>\n  1284→      s.position >= 1 && s.position <= 2 &&\n  1285→      !isAllCaps(s.text) &&\n  1286→      wordCount(s.text) > wordCount(pos0Primary.text) + 2\n  1287→    );\n  1288→    for (const sub of subtitleCandidates) {\n  1289→      sub.score -= 0.15;"}]},"parent_tool_use_id":"toolu_01Pn2J9YHaerVj5dEWKNBP49","session_id":"c37a3300-1904-44e6-bf34-65ba8b38fada","uuid":"52394581-0ec1-4254-b981-feeb663186cd"}
