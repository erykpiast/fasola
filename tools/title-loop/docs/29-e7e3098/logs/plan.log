one translations and any multi-line joins that embed the translation\n  1234→      // as a suffix or substring (e.g. \"Smażona zielona fasolka GREEN BEANS BORKEUM\" ends with\n  1235→      // the translation; \"Title GREEN BEANS BORKEUM 그린빈\" includes it as a substring).\n  1236→      scoredForThreshold = scored.filter((s) => {\n  1237→        const sLower = s.text.toLowerCase();\n  1238→        return !translationCandidates.some((t) => {\n  1239→          const tLower = t.text.toLowerCase();\n  1240→          return sLower.startsWith(tLower) ||\n  1241→                 sLower.endsWith(\" \" + tLower) ||\n  1242→                 sLower.includes(\" \" + tLower);\n  1243→        });\n  1244→      });\n  1245→    }\n  1246→  }\n  1247→\n  1248→  // Fix 2: If the structural heading was identified as a bilingual translation, reassign it.\n  1249→  // This prevents the translation's ALL_CAPS bonus from inflating the threshold and ensures\n  1250→  // the fallback path in scored also uses the correct heading.\n  1251→  if (\n  1252→    translationCandidates.length > 0 &&\n  1253→    firstStructuralHeading &&\n  1254→    translationCandidates.some((t) => t.text === firstStructuralHeading!.text)\n  1255→  ) {\n  1256→    const nonTranslationStructural = structuralCandidates.filter(\n  1257→      (sc) => !translationCandidates.some((t) => t.text === sc.text)\n  1258→    );\n  1259→    const newHeading = nonTranslationStructural.length > 0\n  1260→      ? nonTranslationStructural.reduce((a, b) => a.rawScore > b.rawScore ? a : b)\n  1261→      : undefined;\n  1262→\n  1263→    // Patch scored array: remove old structural bonus, apply new one\n  1264→    for (const s of scored) {\n  1265→      if (s.text === firstStructuralHeading.text) {\n  1266→        s.score -= 0.10;\n  1267→        s.baseScore -= 0.10;\n  1268→      }\n  1269→      if (newHeading && s.text === newHeading.text) {\n  1270→        s.score += 0.10;\n  1271→        s.baseScore += 0.10;\n  1272→      }\n  1273→    }\n  1274→    // Update reference for downstream prefix-removal logic\n  1275→    firstStructuralHeading = newHeading ?? undefined;\n  1276→  }\n  1277→\n  1278→  // Subtitle suppression: when a short mixed-case title at position 0 is followed by a\n  1279→  // longer mixed-case candidate at position 1-2, the longer one is a subtitle/translation.\n  1280→  // Apply a penalty so the primary title (position 0) wins.\n  1281→  const pos0Primary = scored.find((s) => s.position === 0 && !isAllCaps(s.text) && wordCount(s.text) <= 5);\n  1282→  if (pos0Primary) {\n  1283→    const subtitleCandidates = scored.filter((s) =>\n  1284→      s.position >= 1 && s.position <= 2 &&\n  1285→      !isAllCaps(s.text) &&\n  1286→      wordCount(s.text) > wordCount(pos0Primary.text) + 2\n  1287→    );\n  1288→    for (const sub of subtitleCandidates) {\n  1289→      sub.score -= 0.15;\n  1290→    }\n  1291→  }\n  1292→\n  1293→  // Bilingual layout pattern: [FoodName (≤2 words)]\\n[Translation (2-5 words, mixed-case)]\\n...[Section label]\n  1294→  // Common in bilingual cookbooks: foreign food name at position 0, English translation at position 1-2.\n  1295→  // When detected, boost the position-0 candidate so it clears the threshold.\n  1296→  // Note: the ALL_CAPS bilingual block above (lines 940-995) handles mixed-case + ALL_CAPS pairs.\n  1297→  // This block handles mixed-case + mixed-case translation pairs — the two do not overlap because\n  1298→  // the mixed-case guard (`biSecond.text !== biSecond.text.toUpperCase()`) excludes ALL_CAPS lines.\n  1299→  if (scored.length >= 2) {\n  1300→    const biFirst = scored.find((s) => s.position === 0);\n  1301→    // Restrict to single-line candidates (same guard as the ALL_CAPS bilingual block at line 953)\n  1302→    const biSecond = scored.find((s) => s.position >= 1 && s.position <= 2 && s !== biFirst && s.origin === \"single\");\n  1303→\n  1304→    if (biFirst && biSecond) {\n  1305→      const firstWords = biFirst.text.trim().split(/\\s+/);\n  1306→      const secondWords = biSecond.text.trim().split(/\\s+/);\n  1307→\n  1308→      const isBilingualLayout =\n  1309→        firstWords.length <= 2 &&\n  1310→        secondWords.length >= 2 &&\n  1311→        secondWords.length <= 5 &&\n  1312→        // Second line is mixed-case (not ALL_CAPS, not all-lower)\n  1313→        biSecond.text !== biSecond.text.toUpperCase() &&\n  1314→        biSecond.text !== biSecond.text.toLowerCase() &&\n  1315→        // Second line is not an ingredient or instruction\n  1316→        !looksLikeIngredient(biSecond.text) &&\n  1317→        !looksLikeCookingInstruction(biSecond.text);\n  1318→\n  1319→      if (isBilingualLayout) {\n  1320→        // Check if a section label follows within a few lines after the first candidate\n  1321→        const sectionLabelNearby = lines\n  1322→          .slice(biFirst.position + 1, biFirst.position + 6)\n  1323→          .some((line) => isSectionLabel(line.trim()));\n  1324→\n  1325→        if (sectionLabelNearby) {\n  1326→          biFirst.score += 0.15;\n  1327→          biFirst.baseScore += 0.15;\n  1328→          biFirst.thresholdScore += 0.15;\n  1329→        }\n  1330→      }\n  1331→    }\n  1332→  }\n  1333→\n  1334→  // Pre-filter: when ≥2 ALL_CAPS candidates are present, identify OCR artifacts (those whose\n  1335→  // vocabulary has no support elsewhere in the document) and remove them before computing the\n  1336→  // threshold. Artifacts like \"DAT FLATBREADS\" can inflate the threshold via their early-position\n  1337→  // bonus, which causes legitimate titles later in the document to fall just below the cutoff.\n  1338→  // Safety: only pre-filter if ≥2 candidates remain after removal (avoids false-positive removal\n  1339→  // of unique-vocabulary titles on two-recipe pages).\n  1340→  // NOTE: The ≥2 guard is conservative — when there are exactly 2 ALL_CAPS candidates and one is\n  1341→  // an artifact, the artifact is NOT removed. Relaxing to ≥1 causes regressions because 3-line\n  1342→  // join candidates (which span a section label) can pass corroboration via shared vocabulary,\n  1343→  // while the legitimate short title fails. See \"WORD ONE / INGREDIENTS / WORD TWO\" test case.\n  1344→  const allCapsInScored = scoredForThreshold.filter((s) => isAllCaps(s.text));\n  1345→  if (allCapsInScored.length >= 2) {\n  1346→    const artifactTexts = new Set(\n  1347→      allCapsInScored\n  1348→        .filter((cap) => !passesCorroboration(cap.text, cap.position, lines, burstEnd))\n  1349→        .map((c) => c.text)\n  1350→    );\n  1351→    if (artifactTexts.size > 0) {\n  1352→      const remainingCaps = allCapsInScored.filter((c) => !artifactTexts.has(c.text));\n  1353→      if (remainingCaps.length >= 2) {\n  1354→        scoredForThreshold = scoredForThreshold.filter((s) => !artifactTexts.has(s.text));\n  1355→      }\n  1356→    }\n  1357→  }\n  1358→\n  1359→  // Use thresholdScore (excludes structural bonus) so the structural bonus doesn't inflate\n  1360→  // the threshold and block equally-valid headings on multi-recipe pages.\n  1361→  const bestThresholdScore = Math.max(...scoredForThreshold.map((s) => s.thresholdScore));\n  1362→  const threshold = Math.max(0.08, bestThresholdScore * 0.7);\n  1363→\n  1364→  // Filter candidates above threshold\n  1365→  let selected = scoredForThreshold.filter((s) => s.score >= threshold);\n  1366→\n  1367→  // Empty-pool fallback: when threshold filtering discards every candidate,\n  1368→  // the hard filters' structural verdict should not be overruled by weak\n  1369→  // embedding differentiation. Return the best positional candidate only\n  1370→  // if it has a meaningful positive raw score (avoids ingredient-list leakage).\n  1371→  if (selected.length === 0 && scored.length > 0) {\n  1372→    const fallback = scored\n  1373→      .slice()\n  1374→      .sort((a, b) => a.position - b.position || b.score - a.score);\n  1375→    // Position-0 candidates that passed hard filters are very likely titles even with\n  1376→    // weak embedding signal. Relax the rawScore guard for early-position candidates.\n  1377→    const rawScoreThreshold = fallback[0].position <= 2 ? -0.05 : 0.02;\n  1378→    if (fallback[0].rawScore > rawScoreThreshold) {\n  1379→      selected = [fallback[0]];\n  1380→    }\n  1381→  }\n  1382→\n  1383→  // Title-absent page guard: when the page starts mid-recipe (all of the first 3 non-empty\n  1384→  // lines are ingredients or cooking instructions), require a much higher rawScore and\n  1385→  // discard candidates deep in the file. This prevents stray body text or adjacent recipe\n  1386→  // titles from being picked up on pages with no title (Pattern 4).\n  1387→  if (titleAbsent) {\n  1388→    const titleAbsentThreshold = 0.10;\n  1389→    selected = selected.filter(s => s.rawScore >= titleAbsentThreshold);\n  1390→    selected = selected.filter(s => s.position <= 2);\n  1391→  }\n  1392→\n  1393→  // Remove word-boundary prefixes of firstStructuralHeading when the heading itself survived\n  1394→  // the threshold. Cases:\n  1395→  //   ARAYES case:  firstStructuralHeading = \"ARAYES SHRAK\" (2-word join qualifies; \"ARAYES\"\n  1396→  //     alone = 1 word, so it never qualified). Filter removes \"ARAYES\" so dedup keeps the join.\n  1397→  //   SAFFRON case: baseHeading was the partial line; continuation logic above upgraded\n  1398→  //     firstStructuralHeading to the full join. Filter removes the partial so dedup keeps join.\n  1399→  // Safety: only fires when the complete heading itself is in selected (passed the threshold).\n  1400→  if (firstStructuralHeading && selected.some((s) => s.text === firstStructuralHeading.text)) {\n  1401→    const fshLower = firstStructuralHeading.text.toLowerCase();\n  1402→    selected = selected.filter((s) => {\n  1403→      if (s.text === firstStructuralHeading.text) return true;\n  1404→      const sLower = s.text.toLowerCase();\n  1405→      // Remove