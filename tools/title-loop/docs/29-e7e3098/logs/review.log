{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GqUMjpHykWCf9yZnANyUZB","type":"tool_result","content":"   800→const OCR_ARTIFACT_PATTERN = /[0-9¡Íí€]/;\n   801→\n   802→/**\n   803→ * Attempt to repair a single OCR-corrupted word using dictionary lookup.\n   804→ * Returns the repaired word if a dictionary match is found, otherwise returns the original.\n   805→ */\n   806→function repairOcrWord(word: string): string {\n   807→  if (!OCR_ARTIFACT_PATTERN.test(word)) return word;\n   808→\n   809→  const lower = word.toLowerCase();\n   810→\n   811→  const positions: Array<{ index: number; replacements: Array<string> }> = [];\n   812→  for (let i = 0; i < lower.length; i++) {\n   813→    const replacements = OCR_SUBSTITUTIONS[lower[i]];\n   814→    if (replacements) {\n   815→      positions.push({ index: i, replacements });\n   816→    }\n   817→  }\n   818→\n   819→  if (positions.length === 0 || positions.length > 8) return word;\n   820→\n   821→  const candidates = generateSubstitutions(lower, positions, 0);\n   822→\n   823→  for (const candidate of candidates) {\n   824→    if (FOOD_DICTIONARY.has(candidate)) {\n   825→      if (word === word.toUpperCase()) return candidate.toUpperCase();\n   826→      if (word[0] === word[0].toUpperCase()) {\n   827→        return candidate[0].toUpperCase() + candidate.slice(1);\n   828→      }\n   829→      return candidate;\n   830→    }\n   831→  }\n   832→\n   833→  return word;\n   834→}\n   835→\n   836→/**\n   837→ * Recursively generate all substitution variants for OCR artifact positions.\n   838→ */\n   839→function generateSubstitutions(\n   840→  base: string,\n   841→  positions: Array<{ index: number; replacements: Array<string> }>,\n   842→  posIdx: number,\n   843→): Array<string> {\n   844→  if (posIdx >= positions.length) return [base];\n   845→\n   846→  const { index, replacements } = positions[posIdx];\n   847→  const results: Array<string> = [];\n   848→\n   849→  for (const replacement of replacements) {\n   850→    const variant = base.slice(0, index) + replacement + base.slice(index + 1);\n   851→    results.push(...generateSubstitutions(variant, positions, posIdx + 1));\n   852→  }\n   853→\n   854→  return results;\n   855→}\n   856→\n   857→/**\n   858→ * Apply dictionary-guided OCR repair to all words in a text string.\n   859→ */\n   860→function repairOcrText(text: string): string {\n   861→  return text\n   862→    .split(/\\s+/)\n   863→    .map((word) => {\n   864→      const match = word.match(/^([^a-zA-Z0-9À-ÿ]*)(.*?)([^a-zA-Z0-9À-ÿ]*)$/);\n   865→      if (!match) return word;\n   866→      const [, prefix, core, suffix] = match;\n   867→      if (!core) return word;\n   868→      const repaired = repairOcrWord(core);\n   869→      return prefix + repaired + suffix;\n   870→    })\n   871→    .join(\" \");\n   872→}\n   873→\n   874→/**\n   875→ * Apply blind OCR repair to a single mixed-case token.\n   876→ * @param oneLetter - the letter to substitute for `1` in lowercase context (\"i\" or \"l\")\n   877→ */\n   878→function applyBlindOcrRepairToken(token: string, oneLetter: \"i\" | \"l\"): string {\n   879→  if (isAllCaps(token) && token.length > 1) {\n   880→    return token\n   881→      .replace(/1/g, \"I\")\n   882→      .replace(/0(?=[A-ZÀ-Ż])/g, \"O\")\n   883→      .replace(/(?<=[A-ZÀ-Ż])0/g, \"O\")\n   884→      .replace(/4(?=[A-ZÀ-Ż])/g, \"A\")\n   885→      .replace(/(?<=[A-ZÀ-Ż])4/g, \"A\")\n   886→      .replace(/5(?=[A-ZÀ-Ż])/g, \"S\")\n   887→      .replace(/(?<=[A-ZÀ-Ż])5/g, \"S\");\n   888→  }\n   889→  return token\n   890→    .replace(/(?<=[a-zà-ż])1/g, oneLetter)\n   891→    .replace(/1(?=[a-zà-ż])/g, oneLetter)\n   892→    .replace(/¡/g, \"i\")\n   893→    .replace(/€/g, \"e\")\n   894→    .replace(/(?<=[a-zà-ż])0/g, \"o\")\n   895→    .replace(/0(?=[a-zà-ż])/g, \"o\")\n   896→    .replace(/(?<=[a-zà-ż])4/g, \"a\")\n   897→    .replace(/4(?=[a-zà-ż])/g, \"a\")\n   898→    .replace(/(?<=[a-zà-ż])5/g, \"s\")\n   899→    .replace(/5(?=[a-zà-ż])/g, \"s\");\n   900→}\n   901→\n   902→/**\n   903→ * Apply blind OCR repair to mixed-case text, mapping `1` to the given letter\n   904→ * between lowercase characters. Handles per-token ALL_CAPS detection internally.\n   905→ */\n   906→function applyBlindOcrRepairMixedCase(text: string, oneLetter: \"i\" | \"l\"): string {\n   907→  return text.split(/(\\s+)/).map((token) => {\n   908→    if (/^\\s+$/.test(token)) return token;\n   909→    return applyBlindOcrRepairToken(token, oneLetter);\n   910→  }).join(\"\");\n   911→}\n   912→\n   913→function applyBlindOcrRepair(text: string): string {\n   914→  if (isAllCaps(text)) {\n   915→    return text\n   916→      .replace(/1/g, \"I\")\n   917→      .replace(/0(?=[A-ZÀ-Ż])/g, \"O\")\n   918→      .replace(/(?<=[A-ZÀ-Ż])0/g, \"O\")\n   919→      .replace(/4(?=[A-ZÀ-Ż])/g, \"A\")\n   920→      .replace(/(?<=[A-ZÀ-Ż])4/g, \"A\")\n   921→      .replace(/5(?=[A-ZÀ-Ż])/g, \"S\")\n   922→      .replace(/(?<=[A-ZÀ-Ż])5/g, \"S\")\n   923→      .replace(/¡/g, \"I\")\n   924→      .replace(/€/g, \"E\")\n   925→      .replace(/[ÍÌ]/g, \"I\");\n   926→  }\n   927→  return applyBlindOcrRepairMixedCase(text, \"i\");\n   928→}\n   929→\n   930→function hasErraticCasing(text: string): boolean {\n   931→  return text.split(/\\s+/).some(word => {\n   932→    if (word.length < 3) return false;\n   933→    if (isAllCaps(word)) return false;\n   934→    const inner = word.slice(1);\n   935→    const upperInner = (inner.match(/[A-ZÀ-Ż]/g) || []).length;\n   936→    const lowerInner = (inner.match(/[a-zà-ż]/g) || []).length;\n   937→    return upperInner >= 2 && upperInner >= lowerInner * 0.3;\n   938→  });\n   939→}\n   940→\n   941→function normalizeErraticCasing(text: string): string {\n   942→  return text.split(/(\\s+)/).map(token => {\n   943→    if (/^\\s+$/.test(token)) return token;\n   944→    if (isAllCaps(token)) return token;\n   945→    if (hasErraticCasing(token)) {\n   946→      return token.charAt(0).toUpperCase() + token.slice(1).toLowerCase();\n   947→    }\n   948→    return token;\n   949→  }).join(\"\");\n   950→}\n   951→\n   952→/**\n   953→ * Generate multiple blind OCR repair variants for embedding comparison.\n   954→ * For ALL_CAPS text, returns a single variant (1→I is unambiguous).\n   955→ * For mixed-case text, returns two variants: one with 1→i and one with 1→l,\n   956→ * letting the embedding scorer pick the better one.\n   957→ */\n   958→function generateBlindOcrVariants(text: string): Array<string> {\n   959→  if (isAllCaps(text)) {\n   960→    const repaired = applyBlindOcrRepair(text);\n   961→    return repaired !== text ? [repaired] : [];\n   962→  }\n   963→\n   964→  const variants: Array<string> = [];\n   965→\n   966→  // i-variant: 1→i between lowercase letters (default, correct for most recipe text)\n   967→  const iVariant = applyBlindOcrRepair(text);\n   968→\n   969→  // l-variant: 1→l between lowercase letters (fallback for words like \"llama\", \"fillets\")\n   970→  const lVariant = applyBlindOcrRepairMixedCase(text, \"l\");\n   971→\n   972→  if (iVariant !== text) variants.push(iVariant);\n   973→  if (lVariant !== text && lVariant !== iVariant) variants.push(lVariant);\n   974→\n   975→  return variants;\n   976→}\n   977→\n   978→/**\n   979→ * Post-processing normalization for OCR-extracted titles.\n   980→ * Strips stray section markers and substitutes common OCR digit-for-letter artifacts.\n   981→ * Title-case conversion is applied only when a substitution was actually made, so\n   982→ * clean ALL_CAPS titles (e.g. \"CHOCOLATE CAKE\") are returned unchanged.\n   983→ */\n   984→function normalizeOcrTitle(raw: string): string {\n   985→  let text = raw.trim();\n   986→\n   987→  // Step 0: Dictionary-guided OCR repair — resolve ambiguous substitutions\n   988→  // using word-level context before applying blind character replacements.\n   989→  text = repairOcrText(text);\n   990→\n   991→  // Step 1: Strip trailing section markers greedily appended to the title.\n   992→  // e.g. \"MAKOWIEC ZE ŚLIWKAMI + SERVING AND STORAGE:\" → \"MAKOWIEC ZE ŚLIWKAMI\"\n   993→  text = text.replace(\n   994→    /\\s*\\+\\s*(?:SERV[IÍ1]NG(?:\\s+AND\\s+STORAGE)?|TOPPING|NOTES?|TIPS?)\\s*:?\\s*$/i,\n   995→    \"\"\n   996→  );\n   997→\n   998→  // Step 2: OCR character substitution.\n   999→  const beforeSub = text;\n  1000→  text = applyBlindOcrRepair(text);\n  1001→\n  1002→  // Step 3: Title-case conversion — ONLY when OCR substitution changed the text.\n  1003→  // This preserves clean ALL_CAPS titles (e.g. \"CHOCOLATE CAKE\") as-is.\n  1004→  if (text !== beforeSub && isAllCaps(text)) {\n  1005→    text = toTitleCase(text);\n  1006→  }\n  1007→\n  1008→  // Step 4: Normalize erratic casing (e.g. \"KoPyTka\" → \"Kopytka\").\n  1009→  if (hasErraticCasing(text)) {\n  1010→    text = normalizeErraticCasing(text);\n  1011→  }\n  1012→\n  1013→  return text.trim();\n  1014→}\n  1015→\n  1016→// Module-level cache for reference embeddings\n  1017→let cachedTitleRefEmbedding: Array<number> | null = null;\n  1018→let cachedHeaderRefEmbedding: Array<number> | null = null;\n  1019→let cachedNoiseRefEmbedding: Array<number> | null = null;\n  1020→\n  1021→export function _resetEmbeddingCacheForTests(): void {\n  1022→  cachedTitleRefEmbedding = null;\n  1023→  cachedHeaderRefEmbedding = null;\n  1024→  cachedNoiseRefEmbedding = null;\n  1025→}\n  1026→\n  1027→export async function extractTitleWithEmbeddings(\n  1028→  text: string,\n  1029→  embed: EmbedFn\n  1030→): Promise<string | undefined> {\n  1031→  if (!text || text.trim().length === 0) {\n  1032→    return undefined;\n  1033→  }\n  1034→\n  1035→  const lines = text.split(\"\\n\");\n  1036→  const { candidates, burstEnd } = buildCandidates(lines);\n  1037→  const titleAbsent = isTitleAbsentPage(lines, burstEnd);\n  1038→\n  1039→  if (candidates.length === 0) {\n  1040→    return undefined;\n  1041→  }\n  1042→\n  1043→  // Cache reference embeddings\n  1044→  if (!cachedTitleRefEmbedding) {\n  1045→    cachedTitleRefEmbedding = await embed(TITLE_REFERENCE);\n  1046→  }\n  1047→  if (!cachedHeaderRefEmbedding) {\n  1048→    cachedHeaderRefEmbedding = await embed(HEADER_REFERENCE);\n  1049→  }\n  1050→  if (!cachedNoiseRefEmbedding) {\n  1051→    cachedNoiseRefEmbedding = await embed(NOISE_REFERENCE);\n  1052→  }\n  1053→\n  1054→  // Find ALL_CAPS candidates with ≥2 words where every significant word has ≥4 alpha letters.\n  1055→  // Insignificant tokens (≤1 alpha letter: \"/\", \"&\", \"+\", \":\", \"D)\", etc.) are filtered before\n  1056→  // the check so that multi-line joins with continuation punctuation still qualify.\n  1057→  const isStructuralHeading = (c: { text: string }): boolean => {\n  1058→    if (!isAllCaps(c.text) || wordCount(c.text) < 2) return false;\n  1059→    const sigWords = c.text.trim().split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length > 1);\n  1060→    return sigWords.length >= 2 && sigWords.every((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n  1061→  };\n  1062→\n  1063→  // Pass 1: compute rawScore for all candidates (embedding quality signal)\n  1064→  const rawScored: Array<{ text: string; position: number; origin: CandidateOrigin; rawScore: number; embedding: Array<number> }> = [];\n  1065→  for (const candidate of candidates) {\n  1066→    const embedding = await embed(candidate.text);\n  1067→    const titleSim = cosineSimilarity(embedding, cachedTitleRefEmbedding);\n  1068→    const headerSim = cosineSimilarity(embedding, cachedHeaderRefEmbedding);\n  1069→    const noiseSim = cosineSimilarity(embedding, cachedNoiseRefEmbedding);\n  1070→    const rawScore = titleSim - Math.max(headerSim, noiseSim);\n  1071→    rawScored.push({ text: candidate.text, position: candidate.position, origin: candidate.origin, rawScore, embedding });\n  1072→  }\n  1073→\n  1074→  // Select baseHeading by embedding quality (rawScore), not position.\n  1075→  // This prevents OCR-garbled fragments from claiming the structural heading slot.\n  1076→  const structuralCandidates = rawScored.filter((s) => isStructuralHeading(s));\n  1077→\n  1078→  // Penalize structural headings with truncated OCR words:\n  1079→  // if \"FRON\" appears and another heading has \"SAFFRON\", \"FRON\" is likely garbled.\n  1080→  for (const sc of structuralCandidates) {\n  1081→    const sigWords = sc.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n  1082→    for (const other of structuralCandidates) {\n  1083→      if (other === sc) continue;\n  1084→      const otherSigWords = other.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n  1085→      const hasTruncation = sigWords.some((w) =>\n  1086→        otherSigWords.some((ow) => ow !== w && ow.length > w.length && ow.endsWith(w))\n  1087→      );\n  1088→      if (hasTruncation) {\n  1089→        sc.rawScore = -1.0;  // Hard disqualification — truncated OCR artifact\n  1090→        break;\n  1091→      }\n  1092→    }\n  1093→  }\n  1094→\n  1095→  const bestStructural = structuralCandidates.length > 0\n  1096→    ? structuralCandidates.reduce((a, b) => {\n  1097→        const scoreDiff = a.rawScore - b.rawScore;\n  1098→        if (Math.abs(scoreDiff) > 0.03) return scoreDiff > 0 ? a : b;\n  1099→        // Tiebreak: single-line origin beats multi-line joins (avoids conflating two separate headings)"}]},"parent_tool_use_id":"toolu_01Udys7JLPFW2FJmTL4fNkXx","session_id":"f3952b68-8982-4bda-aefc-f210110437d7","uuid":"8f04893c-4a3f-4071-8afc-5bf0310c10af"}
