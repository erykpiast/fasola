{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016ujkYK2kKs7UM7BGf3Bpid","type":"tool_result","content":"   200→ * Recipe-internal section labels that should ALWAYS block multi-line joins,\n   201→ * even when the combined word count is ≥ 3.\n   202→ * Category labels (\"zupy\", \"placki\", etc.) are NOT in this set — they can\n   203→ * legitimately start a multi-word recipe title like \"Zupy Zimowe Warzywne\".\n   204→ */\n   205→const ALWAYS_BLOCK_JOIN_LABELS = new Set([\n   206→  \"ingredients\", \"directions\", \"instructions\", \"method\", \"preparation\",\n   207→  \"steps\", \"notes\", \"tip\", \"tips\", \"variations\", \"variation\",\n   208→  \"garnish\", \"topping\", \"toppings\", \"frosting\", \"filling\",\n   209→  \"serving suggestion\", \"serving suggestions\", \"serving\",\n   210→  \"glaze\", \"instrukcje\", \"uwagi\", \"notatki\", \"podawanie\", \"przechowywanie\",\n   211→  \"skladniki\", \"przygotowanie\", \"sposob przygotowania\", \"sposob wykonania\",\n   212→  \"wykonanie\", \"wskazowki\", \"podpowiedz\", \"warianty\",\n   213→  \"sos\", \"nadzienie\", \"polewa\", \"lukier\", \"ciasto\",\n   214→]);\n   215→\n   216→function isAlwaysBlockJoinLabel(text: string): boolean {\n   217→  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n   218→  return ALWAYS_BLOCK_JOIN_LABELS.has(normalized);\n   219→}\n   220→\n   221→function isAllCaps(line: string): boolean {\n   222→  const letters = line.replace(/[^a-zA-Z]/g, \"\");\n   223→  return letters.length > 0 && letters === letters.toUpperCase();\n   224→}\n   225→\n   226→function looksLikeMetadata(text: string): boolean {\n   227→  return METADATA_PATTERNS.some((pattern) => pattern.test(text.trim()));\n   228→}\n   229→\n   230→/** Content words are ≥3 alpha characters after stripping punctuation. */\n   231→function extractContentWords(text: string): string[] {\n   232→  return text\n   233→    .split(/\\s+/)\n   234→    .filter((w) => w.replace(/[^a-zA-ZÀ-ÿ]/g, \"\").length >= 3)\n   235→    .map((w) => w.toUpperCase());\n   236→}\n   237→\n   238→/**\n   239→ * Returns true if the candidate's vocabulary is sufficiently supported by the rest of\n   240→ * the document. Short candidates (≤3 content words) require 100% corroboration;\n   241→ * longer candidates require ≥67%. Used to detect orphaned OCR artifacts in multi-title pages.\n   242→ */\n   243→function passesCorroboration(\n   244→  text: string,\n   245→  position: number,\n   246→  allLines: string[],\n   247→  startLine: number = 0 // Only check corroboration against lines from this index onward\n   248→): boolean {\n   249→  const contentWords = extractContentWords(text);\n   250→\n   251→  if (contentWords.length === 0) {\n   252→    return true; // No checkable words — pass through\n   253→  }\n   254→\n   255→  let corroboratedCount = 0;\n   256→  for (const word of contentWords) {\n   257→    for (let i = startLine; i < allLines.length; i++) {\n   258→      if (i === position) continue;\n   259→      if (allLines[i].toUpperCase().includes(word)) {\n   260→        corroboratedCount++;\n   261→        break;\n   262→      }\n   263→    }\n   264→  }\n   265→\n   266→  const score = corroboratedCount / contentWords.length;\n   267→  const threshold = contentWords.length <= 3 ? 1.0 : 0.67;\n   268→  return score >= threshold;\n   269→}\n   270→\n   271→function isLikelyGarbled(text: string): boolean {\n   272→  const letters = text.replace(/[^a-zA-Z]/g, \"\");\n   273→  if (letters.length < 2) return true;\n   274→\n   275→  // Pipe embedded in words = OCR artifact (e.g., \"Sp|aszcz\", \"pa|ką\")\n   276→  if (/[a-zA-ZÀ-ÿа-яА-Я]\\|[a-zA-ZÀ-ÿа-яА-Я]/.test(text)) return true;\n   277→\n   278→  // Mixed Latin + Cyrillic = OCR corruption\n   279→  if (/[а-яА-ЯёЁіІїЇєЄґҐ]/.test(text) && /[a-zA-Z]/.test(text)) return true;\n   280→\n   281→  // Check vowel ratio — English/Polish text typically has 30–50% vowels\n   282→  const vowels = letters.replace(/[^aeiouAEIOUyYąęóĄĘÓ]/g, \"\").length;\n   283→  const vowelRatio = vowels / letters.length;\n   284→  if (vowelRatio < 0.10 || vowelRatio > 0.85) return true;\n   285→\n   286→  // Single orphaned word ≤3 letters that isn't a common word\n   287→  const words = text.trim().split(/\\s+/);\n   288→  const COMMON_SHORT = new Set([\n   289→    \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"had\", \"her\",\n   290→    \"was\", \"one\", \"our\", \"out\", \"are\", \"has\", \"his\", \"how\", \"its\", \"may\",\n   291→    \"new\", \"now\", \"old\", \"see\", \"way\", \"who\", \"did\", \"get\", \"let\", \"say\",\n   292→    \"she\", \"too\", \"use\",\n   293→  ]);\n   294→  // Count all Unicode letters (not just ASCII) so Polish words like \"Żur\" (3 letters) pass\n   295→  const unicodeLetters = text.trim().replace(/[^a-zA-ZąćęłńóśźżĄĆĘŁŃÓŚŹŻ]/g, \"\");\n   296→  if (words.length === 1 && unicodeLetters.length <= 3 && !COMMON_SHORT.has(text.trim().toLowerCase())) {\n   297→    return true;\n   298→  }\n   299→\n   300→  // Single word with internal lowercase→uppercase transition — OCR noise (e.g., \"UuIw\", \"aBC\")\n   301→  // No recipe title uses this pattern as a standalone single-word candidate.\n   302→  if (words.length === 1 && /[a-z][A-Z]/.test(text.trim()) && !/^(Mc|Mac)[A-Z]/.test(text.trim())) {\n   303→    return true;\n   304→  }\n   305→\n   306→  // Recipe titles never start with a lowercase letter\n   307→  if (/^[a-z]/.test(text.trim())) {\n   308→    return true;\n   309→  }\n   310→\n   311→  // Mid-text sentence boundary (\". \" followed by a letter) — body text fragment spliced from multiple sentences\n   312→  const trimmed = text.trim();\n   313→  if (/\\.\\s+[a-zA-Z]/.test(trimmed) && !trimmed.endsWith(\")\")) {\n   314→    return true;\n   315→  }\n   316→\n   317→  // Multi-word candidate containing a garbled OCR fragment: a short lowercase word that isn't a known short word\n   318→  if (words.length >= 2) {\n   319→    const commonShort2 = new Set([\n   320→      \"a\", \"i\", \"of\", \"or\", \"to\", \"in\", \"on\", \"is\", \"it\", \"an\",\n   321→      \"as\", \"at\", \"by\", \"do\", \"go\", \"if\", \"no\", \"so\", \"up\", \"we\",\n   322→      \"w\", \"z\",   // Polish prepositions (basic)\n   323→      \"ze\", \"bo\", \"na\", \"ni\", \"po\", \"ku\", \"od\", \"za\", \"co\",  // Polish prepositions (extended)\n   324→    ]);\n   325→    const hasGarbledWord = words.some(\n   326→      (w) =>\n   327→        /^[a-z]/.test(w) &&\n   328→        w.replace(/[^a-z]/g, \"\").length <= 2 &&\n   329→        !commonShort2.has(w.toLowerCase())\n   330→    );\n   331→    if (hasGarbledWord) {\n   332→      return true;\n   333→    }\n   334→\n   335→    // Multi-word candidate with a garbled token: a short word with internal\n   336→    // lowercase→uppercase transition. Length capped at 7 to avoid false positives\n   337→    // from OCR-dropped-space artifacts (\"withGarlic\" = 10 chars). True garbled\n   338→    // tokens like \"XxYyZz\" or \"UuIw\" are ≤7 chars.\n   339→    // Narrow exemption: Mc/Mac name prefixes only (e.g., \"McDonald\").\n   340→    const hasGarbledCamelCase = words.some(\n   341→      (w) =>\n   342→        w.length >= 3 &&\n   343→        w.length <= 7 &&\n   344→        /[a-z][A-Z]/.test(w) &&\n   345→        !/^(Mc|Mac)[A-Z]/.test(w)\n   346→    );\n   347→    if (hasGarbledCamelCase) {\n   348→      return true;\n   349→    }\n   350→  }\n   351→\n   352→  return false;\n   353→}\n   354→\n   355→const COOKING_INSTRUCTION_STARTS = /^(beat|fold|stir|mix|add|pour|bake|cook|cool|remove|place|combine|whisk|knead|roll|spread|brush|slice|chop|dice|mince|drain|rinse|peel|grate|melt|simmer|boil|fry|sauté|saute|roast|grill|broil|steam|let|set|transfer|serve|garnish|arrange|sprinkle|season|preheat|cover|uncover|reduce|bring|toss|cut|trim|shape|form|scatter|score|pat|rub|skim|strain|heat|discard|rest|marinate|wrap|flip|turn|layer|stuff|drizzle|squeeze|zest|soak|thaw|freeze|chill|warm|toast|crush|pound|crack|break|separate|weigh|measure|sift|dust|coat|dip|dredge|baste|debone|butterfly|truss|shred|puree|blend|process|pulse|whip|cream|proof|rise|punch|divide|portion|assemble)\\b/i;\n   356→\n   357→// Polish imperative cooking verbs (with OCR-resilient forms — no diacritics required).\n   358→// These cover the most common recipe instruction starters. Includes common OCR-corrupted\n   359→// forms (e.g., \"Smaż\" → \"Smaz\", \"Dodaj\" → \"Dodaj\").\n   360→// Note: only verbs that NEVER start a recipe title. \"Piecz\" (bake) is excluded because\n   361→// \"Pieczeń\" (roast) and \"Pieczarki\" (mushrooms) share the prefix.\n   362→const POLISH_COOKING_INSTRUCTION_STARTS = /^(podawaj|dodaj|dodawaj|sma[zż]|gotuj|odced[zź]|wymieszaj|mieszaj|wlej|nalej|przygotuj|zagotuj|pokr[oó]j|obierz|wrzuc|wrzuć|usma[zż]|podsma[zż]|prze[lł][oó][zż]|zblenduj|ubij|roztrzepaj|rozprowad[zź]|wyrob|zamieszaj|posyp|polej|odstaw|na[lł][oó][zż]|przykryj|odkryj|wstaw|zdejmij|ods[aą]cz|rozgrzej|posiekaj|zetrzyj|wy[lł][oó][zż]|wyjmij|ukr[oó]j|przekr[oó]j|formuj|ugniataj|rozwałkuj|ugotuj|ugotowa[cć]|upiecz|podawa[cć]|zapiekaj|obtocz|obtoczy[cć]|podgrzej|podgrzewaj)\\b/i;\n   363→\n   364→function looksLikeCookingInstruction(text: string): boolean {\n   365→  const words = text.trim().split(/\\s+/);\n   366→  if (words.length < 4) return false;  // Instructions are multi-word sentences\n   367→  if (COOKING_INSTRUCTION_STARTS.test(text.trim())) return true;\n   368→  if (POLISH_COOKING_INSTRUCTION_STARTS.test(text.trim())) return true;\n   369→  return false;\n   370→}\n   371→\n   372→/**\n   373→ * A line starting with a lowercase letter and having 4+ words is prose continuation.\n   374→ * Recipe titles are capitalized (Title Case or ALL CAPS), so a lowercase-start line\n   375→ * is a strong signal for mid-recipe body text.\n   376→ */\n   377→function isBodyProse(line: string): boolean {\n   378→  return /^[a-ząćęłńóśźż]/.test(line) && wordCount(line) >= 4;\n   379→}\n   380→\n   381→/**\n   382→ * Detect pages where the OCR capture starts mid-recipe with no title present.\n   383→ * Returns true if the first 3 non-empty lines (after `startFrom`) are all ingredients,\n   384→ * cooking instructions, or body prose continuation text.\n   385→ */\n   386→function isTitleAbsentPage(lines: Array<string>, startFrom: number = 0): boolean {\n   387→  const relevantLines = startFrom > 0 ? lines.slice(startFrom) : lines;\n   388→  const nonEmptyLines = relevantLines.map(l => l.trim()).filter(l => l.length > 0);\n   389→\n   390→  if (nonEmptyLines.length < 3) return false;\n   391→\n   392→  const first3 = nonEmptyLines.slice(0, 3);\n   393→\n   394→  return first3.every(line =>\n   395→    looksLikeIngredient(line) ||\n   396→    looksLikeCookingInstruction(line) ||\n   397→    isBodyProse(line)\n   398→  );\n   399→}"}]},"parent_tool_use_id":"toolu_01Ai1nTajqSDN4nP3EWvSEVf","session_id":"f3952b68-8982-4bda-aefc-f210110437d7","uuid":"2be32b41-ca15-4994-a695-728068f3543a"}
{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_013yk5YH34FR6QcWqRuY4Xzy","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01H4CuNm4EH5u2jCc39Lb4UM","name":"Read","input":{"file_path":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/title-extractor.ts","offset":400,"limit":200},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":4080,"cache_read_input_tokens":15730,"cache_creation":{"ephemeral_5m_input_tokens":4080,"ephemeral_1h_input_tokens":0},"output_tokens":18,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01Ai1nTajqSDN4nP3EWvSEVf","session_id":"f3952b68-8982-4bda-aefc-f210110437d7","uuid":"1b50c30d-90b2-4a4c-8682-e8b8aa3f7d0a"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01H4CuNm4EH5u2jCc39Lb4UM","type":"tool_result","content":"   400→\n   401→function passesHardFilters(text: string): boolean {\n   402→  if (text.length < 3 || text.length > 80) return false;\n   403→  if (looksLikeIngredient(text)) return false;\n   404→  if (startsWithNumber(text)) return false;\n   405→  if (looksLikeMetadata(text)) return false;\n   406→  if (isLikelyGarbled(text)) return false;\n   407→  // Apply lightweight OCR normalization before instruction check\n   408→  // so that \"Podaw4ć\" is recognized as \"Podawać\" (cooking instruction).\n   409→  // Only 4→a for now — the specific OCR artifact causing failures.\n   410→  // Uses same letter-adjacent guard logic as applyBlindOcrRepairToken.\n   411→  const ocrNormForInstruction = text\n   412→    .replace(/(?<=[a-zà-ż])4/g, \"a\")\n   413→    .replace(/4(?=[a-zà-ż])/g, \"a\");\n   414→  if (looksLikeCookingInstruction(text)) return false;\n   415→  if (ocrNormForInstruction !== text && looksLikeCookingInstruction(ocrNormForInstruction)) return false;\n   416→  // Pipe-separated lines are book category/chapter headers, not recipe titles\n   417→  if (text.includes(\" | \")) return false;\n   418→  // Trailing page number (e.g. \"VEGETABLE SIDES                         145\")\n   419→  if (/\\s{3,}\\d{1,4}\\s*$/.test(text)) return false;\n   420→  // Slash-separated breadcrumbs (e.g., \"/ Jesien / Zupy\") are navigation, not titles\n   421→  // Only filter when 2+ slashes are present — single-slash lines like\n   422→  // \"TITLE / SUBTITLE\" are legitimate continuation-merged titles\n   423→  if ((text.match(/\\//g) || []).length >= 2) return false;\n   424→  // Bullet-list items (ingredients or instruction steps) are never titles\n   425→  if (/^\\s*[-•*]\\s/.test(text)) return false;\n   426→  // \"For the sauce:\", \"For the filling:\" etc. are sub-section headers\n   427→  if (/^For the\\s+/i.test(text) && /:\\s*$/.test(text)) return false;\n   428→  // Lines ending with \":\" are recipe sub-section headers, not titles.\n   429→  // Exception: compound titles using \" : \" as a title separator (e.g. \"LEMON CURD : LEMON CURD WITH THYME\").\n   430→  if (/:\\s*$/.test(text.trim()) && !/ : /.test(text)) return false;\n   431→  // Page references are navigation markers, not recipe titles\n   432→  if (/^Page\\s+\\d+/i.test(text.trim())) return false;\n   433→  if (/^Strona\\s+\\d+/i.test(text.trim())) return false;\n   434→  // Corrupted spillover annotations from synthetic multi-page OCR\n   435→  if (/^\\[CORRUPTED\\s+SPILLOVER/i.test(text.trim())) return false;\n   436→  // Parenthetical OCR annotation lines describing corruption artifacts\n   437→  if (/^\\(OCR\\b/i.test(text.trim())) return false;\n   438→  if (/^\\(.*\\bcorruption\\b/i.test(text.trim())) return false;\n   439→  // Square-bracket category tags (e.g., \"[CLASSIC FALL SOUPS]\")\n   440→  if (/^\\[.*\\]$/.test(text.trim())) return false;\n   441→  // Known recipe section labels are structural headers, not titles\n   442→  if (isSectionLabel(text)) return false;\n   443→  // Single-word non-title fragments\n   444→  const words = text.trim().split(/\\s+/);\n   445→  if (words.length === 1 && NON_TITLE_WORDS.has(text.trim().toLowerCase())) return false;\n   446→  // Lines with ≥8 words are almost certainly body text, not titles.\n   447→  // Exception: multi-title compounds with \" + \", \" : \", or \" & \" separators are allowed.\n   448→  if (words.length >= 8 && !/ [+:&/] /.test(text)) return false;\n   449→  return true;\n   450→}\n   451→\n   452→/**\n   453→ * Detect initial burst of short garbled lines.\n   454→ * Returns the index of the first non-garbled or long line.\n   455→ */\n   456→function findBurstEnd(lines: Array<{ text: string }>): number {\n   457→  let i = 0;\n   458→\n   459→  // Skip overflow preambles: blocks introduced by \"PREVIOUS RECIPE OVERFLOW\",\n   460→  // \"PREVIOUS PAGE CONTENT\", \"CORRUPTED SECTION\", etc. that precede the actual recipe.\n   461→  const OVERFLOW_MARKERS = /\\b(PREVIOUS\\s+(RECIPE|PAGE)\\b|SPILLOVER|CONTINUATION|CORRUPTED\\s+(SECTION|TEXT)\\b|PARTIAL\\s+RECIPE)\\b/i;\n   462→  let overflowEnd = 0;\n   463→  for (let k = 0; k < lines.length && k < 30; k++) {\n   464→    // Don't re-examine lines already determined to be overflow\n   465→    if (overflowEnd > 0 && k < overflowEnd) continue;\n   466→    if (OVERFLOW_MARKERS.test(lines[k].text) || /^\\[.*\\b(PREVIOUS|CORRUPTED|SPILLOVER|CONTINUATION|PARTIAL)\\b.*\\]$/i.test(lines[k].text)) {\n   467→      // Skip forward past the overflow block to the next visual separator or blank cluster\n   468→      let m = k + 1;\n   469→      let consecutiveBlanks = 0;\n   470→      while (m < lines.length) {\n   471→        const lineText = lines[m].text;\n   472→        // Stop at visual separator\n   473→        if (/^[=\\-]{4,}$/.test(lineText)) {\n   474→          overflowEnd = m + 1;\n   475→          break;\n   476→        }\n   477→        // Track consecutive blank lines\n   478→        if (lineText.trim().length === 0) {\n   479→          consecutiveBlanks++;\n   480→          if (consecutiveBlanks >= 2) {\n   481→            overflowEnd = m + 1;\n   482→            break;\n   483→          }\n   484→        } else {\n   485→          consecutiveBlanks = 0;\n   486→          // Stop at ALL_CAPS line with ≥2 words (likely next recipe heading)\n   487→          if (isAllCaps(lineText) && wordCount(lineText) >= 2) {\n   488→            overflowEnd = m; // Don't skip past the heading itself\n   489→            break;\n   490→          }\n   491→        }\n   492→        m++;\n   493→      }\n   494→      // If we walked to end without finding termination, skip everything we saw\n   495→      if (overflowEnd === 0) overflowEnd = m;\n   496→    }\n   497→  }\n   498→  if (overflowEnd > 0) i = overflowEnd;\n   499→\n   500→  while (i < lines.length && lines[i].text.length < 20 && isLikelyGarbled(lines[i].text) && !isAllCaps(lines[i].text)) {\n   501→    i++;\n   502→  }\n   503→  // Skip body-content prologues: when 3+ consecutive lines at the start are cooking\n   504→  // instructions, prose continuations, or a mix of both, skip them to find the actual\n   505→  // title region. This unifies the previous separate instruction and prose checks to\n   506→  // handle interleaved patterns (e.g., instruction → prose continuation → instruction).\n   507→  if (i === 0) {\n   508→    let j = 0;\n   509→    while (j < lines.length) {\n   510→      const t = lines[j].text;\n   511→      const isInstruction = looksLikeCookingInstruction(t);\n   512→      // Short body-text continuation: lowercase-start with 2+ words catches fragments\n   513→      // like \"creamy but still al dente...\" that follow cooking instructions.\n   514→      // Lower threshold than isBodyProse (2 vs 4 words) to handle interleaved patterns.\n   515→      const isContinuation = /^[a-ząćęłńóśźż]/.test(t) && wordCount(t) >= 2;\n   516→      // Non-lowercase body text: comma-ending or long sentence-ending lines\n   517→      const isBodyEnding = (t.endsWith(\",\") || (t.endsWith(\".\") && wordCount(t) > 4)) && wordCount(t) >= 4;\n   518→\n   519→      if (isInstruction || isContinuation || isBodyEnding) {\n   520→        j++;\n   521→      } else {\n   522→        break;\n   523→      }\n   524→    }\n   525→    if (j >= 3) {\n   526→      i = j;\n   527→    }\n   528→  }\n   529→  return i;\n   530→}\n   531→\n   532→function stripParentheticalGloss(text: string): string {\n   533→  // Strip trailing English-gloss parentheticals from ALL_CAPS titles.\n   534→  // e.g. \"PIEROGI RUSKIE (Boiled Dumplings with Potato and Cheese)\" → \"PIEROGI RUSKIE\"\n   535→  // Keep if parenthetical is ALL_CAPS (variation/subtitle in same language).\n   536→  // Keep if both base and paren are mixed-case (both are part of the title).\n   537→  const match = text.match(/^(.+?)\\s*\\(([^)]+)\\)\\s*$/);\n   538→  if (!match) return text;\n   539→  const [, base, paren] = match;\n   540→  if (isAllCaps(paren)) return text;\n   541→  if (!isAllCaps(base) && !isAllCaps(paren)) return text;\n   542→  return base.trim();\n   543→}\n   544→\n   545→function stripPageNumber(text: string): string {\n   546→  // \"34  Berry Jam\" → \"Berry Jam\" (2+ spaces distinguishes from \"2 eggs\")\n   547→  const match = text.match(/^\\d{1,3}\\s{2,}(.+)$/);\n   548→  return match ? match[1] : text;\n   549→}\n   550→\n   551→/**\n   552→ * Strip trailing parenthesized page or step numbers.\n   553→ * \"Ugotuj ziemniaky. (38)\" → \"Ugotuj ziemniaky.\"\n   554→ * \"RECIPE NAME (p. 42)\" → \"RECIPE NAME\"\n   555→ */\n   556→function stripTrailingPageRef(text: string): string {\n   557→  return text.replace(/\\s*\\((?:p\\.?\\s*)?\\d{1,4}\\)\\s*$/, \"\").trim();\n   558→}\n   559→\n   560→function wordCount(text: string): number {\n   561→  return text.split(/\\s+/).filter((w) => w.length > 0).length;\n   562→}\n   563→\n   564→/**\n   565→ * Build candidate strings from lines: single lines plus multi-line joins (2-3 consecutive).\n   566→ * Skips initial burst of short garbled lines. Scans all remaining lines. Caps at 25.\n   567→ */\n   568→export type CandidateOrigin = \"single\" | \"2-line\" | \"3-line\";\n   569→\n   570→function buildCandidates(\n   571→  lines: Array<string>\n   572→): { candidates: Array<{ text: string; position: number; origin: CandidateOrigin }>; burstEnd: number } {\n   573→  const nonEmptyLines: Array<{ text: string; index: number }> = [];\n   574→\n   575→  for (let i = 0; i < lines.length; i++) {\n   576→    const trimmed = lines[i].trim();\n   577→    if (trimmed.length > 0) {\n   578→      nonEmptyLines.push({ text: trimmed, index: i });\n   579→    }\n   580→  }\n   581→\n   582→  const burstEnd = findBurstEnd(nonEmptyLines);\n   583→\n   584→  // Pre-join hyphen-broken lines: \"ROASTED CHICKEN WITH ROOT VEGET-\" + \"ABLES\" → single line.\n   585→  // Only applies within the candidate region (after burst end).\n   586→  for (let hi = burstEnd; hi < nonEmptyLines.length - 1; hi++) {\n   587→    if (nonEmptyLines[hi].text.endsWith(\"-\")) {\n   588→      const joined = nonEmptyLines[hi].text.slice(0, -1) + nonEmptyLines[hi + 1].text;\n   589→      nonEmptyLines[hi] = { text: joined, index: nonEmptyLines[hi].index };\n   590→      nonEmptyLines.splice(hi + 1, 1);\n   591→    }\n   592→  }\n   593→\n   594→  // Pre-merge consecutive short ALL_CAPS lines (OCR-fragmented headings).\n   595→  // When a sequence of 2+ ALL_CAPS lines each has ≤2 words and ≤25 chars, they are\n   596→  // almost certainly OCR fragments of a single heading. Merge them into one line so\n   597→  // the complete title enters the candidate pool without hitting the 3-line join ceiling.\n   598→  const capsCoalesced: Array<{ text: string; index: number }> = [];\n   599→  let ci = burstEnd;"}]},"parent_tool_use_id":"toolu_01Ai1nTajqSDN4nP3EWvSEVf","session_id":"f3952b68-8982-4bda-aefc-f210110437d7","uuid":"43354efd-f05c-4dc4-8480-aacbf9bb4a8b"}
