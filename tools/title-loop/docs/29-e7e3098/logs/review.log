{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014xwu697EsAhGLpMpNgWzQx","type":"tool_result","content":"   300→  // Single word with internal lowercase→uppercase transition — OCR noise (e.g., \"UuIw\", \"aBC\")\n   301→  // No recipe title uses this pattern as a standalone single-word candidate.\n   302→  if (words.length === 1 && /[a-z][A-Z]/.test(text.trim()) && !/^(Mc|Mac)[A-Z]/.test(text.trim())) {\n   303→    return true;\n   304→  }\n   305→\n   306→  // Recipe titles never start with a lowercase letter\n   307→  if (/^[a-z]/.test(text.trim())) {\n   308→    return true;\n   309→  }"}]},"parent_tool_use_id":"toolu_014Ly7gdkN3pM2SNaecquFX4","session_id":"f3952b68-8982-4bda-aefc-f210110437d7","uuid":"48988800-84f6-4b45-819a-1b4c563be639"}
