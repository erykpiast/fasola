{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ARev4TKWKAVmVzYMDqE8QP","type":"tool_result","content":"  1300→  // the fallback path in scored also uses the correct heading.\n  1301→  if (\n  1302→    translationCandidates.length > 0 &&\n  1303→    firstStructuralHeading &&\n  1304→    translationCandidates.some((t) => t.text === firstStructuralHeading!.text)\n  1305→  ) {\n  1306→    const nonTranslationStructural = structuralCandidates.filter(\n  1307→      (sc) => !translationCandidates.some((t) => t.text === sc.text)\n  1308→    );\n  1309→    const newHeading = nonTranslationStructural.length > 0\n  1310→      ? nonTranslationStructural.reduce((a, b) => a.rawScore > b.rawScore ? a : b)\n  1311→      : undefined;\n  1312→\n  1313→    // Patch scored array: remove old structural bonus, apply new one\n  1314→    for (const s of scored) {\n  1315→      if (s.text === firstStructuralHeading.text) {\n  1316→        s.score -= 0.10;\n  1317→        s.baseScore -= 0.10;\n  1318→      }\n  1319→      if (newHeading && s.text === newHeading.text) {\n  1320→        s.score += 0.10;\n  1321→        s.baseScore += 0.10;\n  1322→      }\n  1323→    }\n  1324→    // Update reference for downstream prefix-removal logic\n  1325→    firstStructuralHeading = newHeading ?? undefined;\n  1326→  }\n  1327→\n  1328→  // Subtitle suppression: when a short mixed-case title at position 0 is followed by a\n  1329→  // longer mixed-case candidate at position 1-2, the longer one is a subtitle/translation.\n  1330→  // Apply a penalty so the primary title (position 0) wins.\n  1331→  const pos0Primary = scored.find((s) => s.position === 0 && !isAllCaps(s.text) && wordCount(s.text) <= 5);\n  1332→  if (pos0Primary) {\n  1333→    const subtitleCandidates = scored.filter((s) =>\n  1334→      s.position >= 1 && s.position <= 2 &&\n  1335→      !isAllCaps(s.text) &&\n  1336→      wordCount(s.text) > wordCount(pos0Primary.text) + 2\n  1337→    );\n  1338→    for (const sub of subtitleCandidates) {\n  1339→      sub.score -= 0.15;\n  1340→    }\n  1341→  }\n  1342→\n  1343→  // Bilingual layout pattern: [FoodName (≤2 words)]\\n[Translation (2-5 words, mixed-case)]\\n...[Section label]\n  1344→  // Common in bilingual cookbooks: foreign food name at position 0, English translation at position 1-2.\n  1345→  // When detected, boost the position-0 candidate so it clears the threshold.\n  1346→  // Note: the ALL_CAPS bilingual block above (lines 940-995) handles mixed-case + ALL_CAPS pairs.\n  1347→  // This block handles mixed-case + mixed-case translation pairs — the two do not overlap because\n  1348→  // the mixed-case guard (`biSecond.text !== biSecond.text.toUpperCase()`) excludes ALL_CAPS lines.\n  1349→  if (scored.length >= 2) {\n  1350→    const biFirst = scored.find((s) => s.position === 0);\n  1351→    // Restrict to single-line candidates (same guard as the ALL_CAPS bilingual block at line 953)\n  1352→    const biSecond = scored.find((s) => s.position >= 1 && s.position <= 2 && s !== biFirst && s.origin === \"single\");\n  1353→\n  1354→    if (biFirst && biSecond) {\n  1355→      const firstWords = biFirst.text.trim().split(/\\s+/);\n  1356→      const secondWords = biSecond.text.trim().split(/\\s+/);\n  1357→\n  1358→      const isBilingualLayout =\n  1359→        firstWords.length <= 2 &&\n  1360→        secondWords.length >= 2 &&\n  1361→        secondWords.length <= 5 &&\n  1362→        // Second line is mixed-case (not ALL_CAPS, not all-lower)\n  1363→        biSecond.text !== biSecond.text.toUpperCase() &&\n  1364→        biSecond.text !== biSecond.text.toLowerCase() &&\n  1365→        // Second line is not an ingredient or instruction\n  1366→        !looksLikeIngredient(biSecond.text) &&\n  1367→        !looksLikeCookingInstruction(biSecond.text);\n  1368→\n  1369→      if (isBilingualLayout) {\n  1370→        // Check if a section label follows within a few lines after the first candidate\n  1371→        const sectionLabelNearby = lines\n  1372→          .slice(biFirst.position + 1, biFirst.position + 6)\n  1373→          .some((line) => isSectionLabel(line.trim()));\n  1374→\n  1375→        if (sectionLabelNearby) {\n  1376→          biFirst.score += 0.15;\n  1377→          biFirst.baseScore += 0.15;\n  1378→          biFirst.thresholdScore += 0.15;\n  1379→        }\n  1380→      }\n  1381→    }\n  1382→  }\n  1383→\n  1384→  // Pre-filter: when ≥2 ALL_CAPS candidates are present, identify OCR artifacts (those whose\n  1385→  // vocabulary has no support elsewhere in the document) and remove them before computing the\n  1386→  // threshold. Artifacts like \"DAT FLATBREADS\" can inflate the threshold via their early-position\n  1387→  // bonus, which causes legitimate titles later in the document to fall just below the cutoff.\n  1388→  // Safety: only pre-filter if ≥2 candidates remain after removal (avoids false-positive removal\n  1389→  // of unique-vocabulary titles on two-recipe pages).\n  1390→  // NOTE: The ≥2 guard is conservative — when there are exactly 2 ALL_CAPS candidates and one is\n  1391→  // an artifact, the artifact is NOT removed. Relaxing to ≥1 causes regressions because 3-line\n  1392→  // join candidates (which span a section label) can pass corroboration via shared vocabulary,\n  1393→  // while the legitimate short title fails. See \"WORD ONE / INGREDIENTS / WORD TWO\" test case.\n  1394→  const allCapsInScored = scoredForThreshold.filter((s) => isAllCaps(s.text));\n  1395→  if (allCapsInScored.length >= 2) {\n  1396→    const artifactTexts = new Set(\n  1397→      allCapsInScored\n  1398→        .filter((cap) => !passesCorroboration(cap.text, cap.position, lines, burstEnd))\n  1399→        .map((c) => c.text)\n  1400→    );\n  1401→    if (artifactTexts.size > 0) {\n  1402→      const remainingCaps = allCapsInScored.filter((c) => !artifactTexts.has(c.text));\n  1403→      if (remainingCaps.length >= 2) {\n  1404→        scoredForThreshold = scoredForThreshold.filter((s) => !artifactTexts.has(s.text));\n  1405→      }\n  1406→    }\n  1407→  }\n  1408→\n  1409→  // Use thresholdScore (excludes structural bonus) so the structural bonus doesn't inflate\n  1410→  // the threshold and block equally-valid headings on multi-recipe pages.\n  1411→  const bestThresholdScore = Math.max(...scoredForThreshold.map((s) => s.thresholdScore));\n  1412→  const threshold = Math.max(0.08, bestThresholdScore * 0.7);\n  1413→\n  1414→  // Filter candidates above threshold\n  1415→  let selected = scoredForThreshold.filter((s) => s.score >= threshold);\n  1416→\n  1417→  // Empty-pool fallback: when threshold filtering discards every candidate,\n  1418→  // the hard filters' structural verdict should not be overruled by weak\n  1419→  // embedding differentiation. Return the best positional candidate only\n  1420→  // if it has a meaningful positive raw score (avoids ingredient-list leakage).\n  1421→  if (selected.length === 0 && scored.length > 0) {\n  1422→    const fallback = scored\n  1423→      .slice()\n  1424→      .sort((a, b) => a.position - b.position || b.score - a.score);\n  1425→    // Position-0 candidates that passed hard filters are very likely titles even with\n  1426→    // weak embedding signal. Relax the rawScore guard for early-position candidates.\n  1427→    const rawScoreThreshold = fallback[0].position <= 2 ? -0.05 : 0.02;\n  1428→    if (fallback[0].rawScore > rawScoreThreshold) {\n  1429→      selected = [fallback[0]];\n  1430→    }\n  1431→  }\n  1432→\n  1433→  // Title-absent page guard: when the page starts mid-recipe (all of the first 3 non-empty\n  1434→  // lines are ingredients or cooking instructions), require a much higher rawScore and\n  1435→  // discard candidates deep in the file. This prevents stray body text or adjacent recipe\n  1436→  // titles from being picked up on pages with no title (Pattern 4).\n  1437→  if (titleAbsent) {\n  1438→    const titleAbsentThreshold = 0.10;\n  1439→    selected = selected.filter(s => s.rawScore >= titleAbsentThreshold);\n  1440→    selected = selected.filter(s => s.position <= 2);\n  1441→  }\n  1442→\n  1443→  // Remove word-boundary prefixes of firstStructuralHeading when the heading itself survived\n  1444→  // the threshold. Cases:\n  1445→  //   ARAYES case:  firstStructuralHeading = \"ARAYES SHRAK\" (2-word join qualifies; \"ARAYES\"\n  1446→  //     alone = 1 word, so it never qualified). Filter removes \"ARAYES\" so dedup keeps the join.\n  1447→  //   SAFFRON case: baseHeading was the partial line; continuation logic above upgraded\n  1448→  //     firstStructuralHeading to the full join. Filter removes the partial so dedup keeps join.\n  1449→  // Safety: only fires when the complete heading itself is in selected (passed the threshold).\n  1450→  if (firstStructuralHeading && selected.some((s) => s.text === firstStructuralHeading.text)) {\n  1451→    const fshLower = firstStructuralHeading.text.toLowerCase();\n  1452→    selected = selected.filter((s) => {\n  1453→      if (s.text === firstStructuralHeading.text) return true;\n  1454→      const sLower = s.text.toLowerCase();\n  1455→      // Remove s if it is a space-delimited prefix of the structural heading\n  1456→      return !fshLower.startsWith(sLower + \" \");\n  1457→    });\n  1458→  }\n  1459→\n  1460→  // Protect continuation joins: when a multi-line join (2-line or 3-line) survived the threshold\n  1461→  // and its second part starts with a continuation character, remove the single-line prefix/suffix\n  1462→  // so the dedup \"shorter wins\" rule doesn't destroy the complete join.\n  1463→  // Note: the pre-merge step above already handles the common Baked Eggs case (&/continuation\n  1464→  // on next line) by turning it into a single candidate — this block covers the rarer case where\n  1465→  // a continuation-character join was generated as a 2-line/3-line candidate and the prefix\n  1466→  // single also survived threshold independently (e.g. from a different code path or OCR layout).\n  1467→  // Safety: only fires for joins whose continuation starts with /&+:( — digit continuations\n  1468→  // like \"Pierogi Ruskie 200g mąki\" are NOT protected, so dedup correctly keeps the shorter form.\n  1469→  const survivingJoins = selected.filter((s) => s.origin === \"2-line\" || s.origin === \"3-line\");\n  1470→  if (survivingJoins.length > 0) {\n  1471→    selected = selected.filter((s) => {\n  1472→      if (s.origin !== \"single\") return true;\n  1473→      const sLower = s.text.toLowerCase();\n  1474→      // Remove PREFIX singles whose continuation join also survived\n  1475→      const isPrefixOfJoin = survivingJoins.some((j) => {\n  1476→        const jLower = j.text.toLowerCase();\n  1477→        if (!jLower.startsWith(sLower + \" \")) return false;\n  1478→        const remainder = jLower.slice(sLower.length + 1);\n  1479→        return /^[/&+:(]/.test(remainder);\n  1480→      });\n  1481→      if (isPrefixOfJoin) return false;\n  1482→      // Remove SUFFIX singles (e.g. \"& Coriander\") whose parent join also survived\n  1483→      const isSuffixOfJoin = survivingJoins.some((j) => {\n  1484→        const jLower = j.text.toLowerCase();\n  1485→        if (!jLower.endsWith(\" \" + sLower)) return false;\n  1486→        // Only remove if the suffix starts with a continuation character\n  1487→        return /^[/&+:(]/.test(sLower);\n  1488→      });\n  1489→      if (isSuffixOfJoin) return false;\n  1490→      return true;\n  1491→    });\n  1492→  }\n  1493→\n  1494→  // Pre-dedup: remove sub-section headers that are substrings of other surviving candidates.\n  1495→  // A sub-section header is an ALL_CAPS candidate followed by ingredient-like lines in the source.\n  1496→  // Example: \"CHLEBEK\" (bread section header, followed by \"500 g mąki\") is a substring of\n  1497→  // \"CHLEBEK Z WARZYWAMI I BOCZKIEM\" (the real title). Without this filter, dedup kills the title.\n  1498→  selected = selected.filter((candidate) => {\n  1499→    if (!isAllCaps(candidate.text)) return true;"}]},"parent_tool_use_id":"toolu_01Ai1nTajqSDN4nP3EWvSEVf","session_id":"f3952b68-8982-4bda-aefc-f210110437d7","uuid":"20989ef9-c6dd-4d7e-b9a2-8211c67dfeb6"}
