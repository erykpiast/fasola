{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AK8Q62kWRgzPBd46q8gA35","type":"tool_result","content":"  1648→      // If all survivors are closely positioned (within 10 lines of each other), keep them all —\n  1649→      // they're likely genuine multi-recipe content on a single page.\n  1650→      // If any survivor is far from the earliest, apply a positional tiebreak: the real title\n  1651→      // is almost always the earliest candidate; distant survivors are likely body-text leakage.\n  1652→      selected.sort((a, b) => a.position - b.position);\n  1653→      const earliest = selected[0];\n  1654→      const farthest = selected[selected.length - 1];\n  1655→      if (farthest.position - earliest.position > 10) {\n  1656→        // Large span → body-text leakage. Collapse to one: prefer the highest-scoring\n  1657→        // candidate within 3 positions of the earliest (position tolerance for OCR gaps),\n  1658→        // falling back to the earliest itself if none score higher.\n  1659→        const closeCompetitors = selected.filter(\n  1660→          (s) => s.position <= earliest.position + 3 && s.score > earliest.score\n  1661→        );\n  1662→        selected = closeCompetitors.length > 0\n  1663→          ? [closeCompetitors.reduce((a, b) => (a.score > b.score ? a : b))]\n  1664→          : [earliest];\n  1665→      }\n  1666→      // Span ≤ 10 → all survivors are closely positioned; fall through keeping all.\n  1667→    }\n  1668→  }\n  1669→\n  1670→  // Cap at 3, sort by document position\n  1671→  selected.sort((a, b) => a.position - b.position);\n  1672→  selected = selected.slice(0, 3);\n  1673→\n  1674→  if (selected.length === 0) {\n  1675→    // Last resort: embedding scoring provided no usable signal.\n  1676→    // Return the earliest candidate that passed hard filters — it already survived\n  1677→    // ingredient, metadata, garbled, section-label, and cooking-instruction checks.\n  1678→    // Position 0 in a recipe file is overwhelmingly the title.\n  1679→    // Exclude hard-disqualified candidates (rawScore -1.0 = truncated OCR artifact).\n  1680→    const lastResort = scored\n  1681→      .slice()\n  1682→      .filter((s) => s.rawScore > -0.5)\n  1683→      .sort((a, b) => a.position - b.position || b.score - a.score);\n  1684→    if (lastResort.length > 0) {\n  1685→      return normalizeOcrTitle(lastResort[0].text.normalize(\"NFC\").trim());\n  1686→    }\n  1687→    return undefined;\n  1688→  }\n  1689→\n  1690→  const result = selected.map((s) => normalizeOcrTitle(s.text.normalize(\"NFC\").trim())).join(\" + \");\n  1691→\n  1692→  return result;\n  1693→}\n  1694→\n  1695→/**\n  1696→ * Extract potential recipe title from OCR text (sync heuristic fallback)\n  1697→ */\n  1698→export function extractTitle(text: string): string | undefined {\n  1699→  if (!text || text.trim().length === 0) {\n  1700→    return undefined;\n  1701→  }\n  1702→\n  1703→  const lines = text.split(\"\\n\").map((line) => line.trim());\n  1704→\n  1705→  for (const line of lines) {\n  1706→    if (line.length === 0) continue;\n  1707→    if (line.length < 3 || line.length > 50) continue;"}]},"parent_tool_use_id":"toolu_01Ai1nTajqSDN4nP3EWvSEVf","session_id":"f3952b68-8982-4bda-aefc-f210110437d7","uuid":"d905cbdb-b07c-402e-abdc-e788c5d4de02"}
