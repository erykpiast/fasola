{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EPQY3iVEAkjw2HZEUoGtjX","type":"tool_result","content":"   600→  while (ci < nonEmptyLines.length) {\n   601→    const line = nonEmptyLines[ci];\n   602→    if (\n   603→      isAllCaps(line.text) &&\n   604→      wordCount(line.text) <= 2 &&\n   605→      line.text.length <= 25 &&\n   606→      !isSectionLabel(line.text) &&\n   607→      !looksLikeMetadata(line.text)\n   608→    ) {\n   609→      let merged = line.text;\n   610→      const startIndex = line.index;\n   611→      let j = ci + 1;\n   612→      while (j < nonEmptyLines.length) {\n   613→        const next = nonEmptyLines[j];\n   614→        if (\n   615→          isAllCaps(next.text) &&\n   616→          wordCount(next.text) <= 2 &&\n   617→          next.text.length <= 25 &&\n   618→          ((!isSectionLabel(next.text) && !isSectionLabel(repairOcrText(next.text))) ||\n   619→           (wordCount(next.text) === 1 && wordCount(merged) >= 2 && wordCount(merged) <= 4 &&\n   620→            isCategorySectionLabel(next.text))) &&\n   621→          !looksLikeMetadata(next.text) &&\n   622→          (merged + \" \" + next.text).length <= 80\n   623→        ) {\n   624→          merged += \" \" + next.text;\n   625→          j++;\n   626→        } else {\n   627→          break;\n   628→        }\n   629→      }\n   630→      if (j > ci + 1) {\n   631→        capsCoalesced.push({ text: merged, index: startIndex });\n   632→        ci = j;\n   633→        continue;\n   634→      }\n   635→    }\n   636→    capsCoalesced.push(line);\n   637→    ci++;\n   638→  }\n   639→\n   640→  // Pre-merge continuation lines: a line starting with /&+:( is never a standalone title.\n   641→  // Merge it into the preceding line so the complete title enters the pool as a single candidate,\n   642→  // avoiding the fragile chain of conditions required by the downstream join survival logic.\n   643→  // Limitation: only one continuation line per preceding line is merged. Titles split across\n   644→  // three or more lines with continuation tokens (rare in practice) are not handled here —\n   645→  // the downstream 2-line and 3-line join candidates cover those cases instead.\n   646→  const mergedLines: Array<{ text: string; index: number }> = [];\n   647→  for (let i = 0; i < capsCoalesced.length; i++) {\n   648→    const line = capsCoalesced[i];\n   649→    if (i + 1 < capsCoalesced.length) {\n   650→      const nextText = capsCoalesced[i + 1].text;\n   651→      if (/^[/&+:(]/.test(nextText)) {\n   652→        mergedLines.push({ text: `${line.text} ${nextText}`, index: line.index });\n   653→        i++;\n   654→        continue;\n   655→      }\n   656→    }\n   657→    mergedLines.push(line);\n   658→  }\n   659→\n   660→  const candidates: Array<{ text: string; position: number; origin: CandidateOrigin }> = [];\n   661→  const seen = new Set<string>();\n   662→\n   663→  // Build a set of positions to skip: short ALL_CAPS lines immediately following metadata\n   664→  const metadataContinuationPositions = new Set<number>();\n   665→  for (let i = 0; i < mergedLines.length - 1; i++) {\n   666→    if (looksLikeMetadata(mergedLines[i].text)) {\n   667→      const next = mergedLines[i + 1];\n   668→      if (isAllCaps(next.text) && wordCount(next.text) <= 2 && next.text.length <= 15) {\n   669→        metadataContinuationPositions.add(next.index);\n   670→      }\n   671→    }\n   672→  }\n   673→\n   674→  for (let i = 0; i < mergedLines.length; i++) {\n   675→    const line = mergedLines[i];\n   676→\n   677→    // Skip metadata continuation fragments\n   678→    if (metadataContinuationPositions.has(line.index)) continue;\n   679→\n   680→    // Single line — strip page-number prefixes and parenthetical glosses before scoring\n   681→    const singleText = repairOcrText(stripParentheticalGloss(stripTrailingPageRef(stripPageNumber(line.text))));\n   682→    if (passesHardFilters(singleText)) {\n   683→      const norm = singleText.toLowerCase();\n   684→      if (!seen.has(norm)) {\n   685→        seen.add(norm);\n   686→        candidates.push({ text: singleText, position: line.index, origin: \"single\" });\n   687→      }\n   688→    }\n   689→\n   690→    // Blind OCR repair for early-position candidates: when the original text\n   691→    // has OCR artifacts or erratic casing and is in the first few lines,\n   692→    // generate additional candidates with blind digit→letter repair and/or\n   693→    // casing normalization. This gives the embedding scorer clean versions\n   694→    // even when dictionary repair misses.\n   695→    if (line.index <= 5 && (OCR_ARTIFACT_PATTERN.test(line.text) || hasErraticCasing(line.text))) {\n   696→      let repairable = singleText;\n   697→      if (hasErraticCasing(repairable)) {\n   698→        repairable = normalizeErraticCasing(repairable);\n   699→        if (repairable !== singleText && passesHardFilters(repairable)) {\n   700→          const norm = repairable.toLowerCase();\n   701→          if (!seen.has(norm)) {\n   702→            seen.add(norm);\n   703→            candidates.push({ text: repairable, position: line.index, origin: \"single\" });\n   704→          }\n   705→        }\n   706→      }\n   707→      const variants = generateBlindOcrVariants(repairable);\n   708→      for (const variant of variants) {\n   709→        if (passesHardFilters(variant)) {\n   710→          const norm = variant.toLowerCase();\n   711→          if (!seen.has(norm)) {\n   712→            seen.add(norm);\n   713→            candidates.push({ text: variant, position: line.index, origin: \"single\" });\n   714→          }\n   715→        }\n   716→      }\n   717→    }\n   718→\n   719→    // 2-line join — skip if first line is a section label AND join would be ≤2 words\n   720→    // (a section label followed by modifiers is likely a recipe title, not a category header)\n   721→    if (i + 1 < mergedLines.length) {\n   722→      const joined2 = repairOcrText(`${line.text} ${mergedLines[i + 1].text}`);\n   723→      const shouldBlock2 = isSectionLabel(line.text) &&\n   724→        (wordCount(joined2) <= 2 || isAlwaysBlockJoinLabel(line.text));\n   725→      if (!shouldBlock2 && passesHardFilters(joined2)) {\n   726→        const norm = joined2.toLowerCase();\n   727→        if (!seen.has(norm)) {\n   728→          seen.add(norm);\n   729→          candidates.push({ text: joined2, position: line.index, origin: \"2-line\" });\n   730→        }\n   731→      }\n   732→    }\n   733→\n   734→    // 3-line join — skip if first line is a section label AND join would be ≤2 words\n   735→    if (i + 2 < mergedLines.length) {\n   736→      const joined3 = repairOcrText(`${line.text} ${mergedLines[i + 1].text} ${mergedLines[i + 2].text}`);\n   737→      const shouldBlock3 = isSectionLabel(line.text) &&\n   738→        (wordCount(joined3) <= 2 || isAlwaysBlockJoinLabel(line.text));\n   739→      if (!shouldBlock3 && passesHardFilters(joined3)) {\n   740→        const norm = joined3.toLowerCase();\n   741→        if (!seen.has(norm)) {\n   742→          seen.add(norm);\n   743→          candidates.push({ text: joined3, position: line.index, origin: \"3-line\" });\n   744→        }\n   745→      }\n   746→    }\n   747→  }\n   748→\n   749→  // Pre-filter to 25 before embedding calls: prefer ALL_CAPS and short candidates.\n   750→  // Position-based scoring handles final ranking.\n   751→  if (candidates.length > 25) {\n   752→    const prioritized = candidates.slice().sort((a, b) => {\n   753→      const aAllCaps = isAllCaps(a.text) ? 0 : 1;\n   754→      const bAllCaps = isAllCaps(b.text) ? 0 : 1;\n   755→      if (aAllCaps !== bAllCaps) return aAllCaps - bAllCaps;\n   756→      const aShort = wordCount(a.text) <= 5 ? 0 : 1;\n   757→      const bShort = wordCount(b.text) <= 5 ? 0 : 1;\n   758→      return aShort - bShort;\n   759→    });\n   760→    return { candidates: prioritized.slice(0, 25), burstEnd: nonEmptyLines[burstEnd]?.index ?? lines.length };\n   761→  }\n   762→\n   763→  return { candidates, burstEnd: nonEmptyLines[burstEnd]?.index ?? lines.length };\n   764→}\n   765→\n   766→/**\n   767→ * Convert an ALL_CAPS string to Title Case, using a small-words list.\n   768→ * Preserves Polish/French diacritics.\n   769→ */\n   770→function toTitleCase(text: string): string {\n   771→  const smallWords = new Set([\n   772→    \"a\", \"an\", \"the\", \"and\", \"but\", \"or\", \"for\", \"nor\",\n   773→    \"in\", \"on\", \"at\", \"to\", \"of\", \"by\", \"with\", \"from\",\n   774→    \"z\", \"w\", \"i\", \"ze\", \"na\", \"do\", \"od\", \"za\", \"po\",\n   775→  ]);\n   776→  return text.split(/(\\s+)/).map((word, idx) => {\n   777→    if (/^\\s+$/.test(word)) return word;\n   778→    const lower = word.toLowerCase();\n   779→    if (idx === 0 || !smallWords.has(lower)) {\n   780→      return lower.charAt(0).toUpperCase() + lower.slice(1);\n   781→    }\n   782→    return lower;\n   783→  }).join(\"\");\n   784→}\n   785→\n   786→/**\n   787→ * OCR digit→letter substitution map.\n   788→ * Each key is a character that OCR commonly confuses; values are possible correct letters.\n   789→ */\n   790→const OCR_SUBSTITUTIONS: Record<string, string[]> = {\n   791→  \"0\": [\"o\"],\n   792→  \"1\": [\"i\", \"l\"],\n   793→  \"4\": [\"a\"],\n   794→  \"5\": [\"s\"],\n   795→  \"¡\": [\"i\"],\n   796→  \"í\": [\"i\", \"l\"],\n   797→  \"€\": [\"e\"],\n   798→};\n   799→"}]},"parent_tool_use_id":"toolu_01Ai1nTajqSDN4nP3EWvSEVf","session_id":"f3952b68-8982-4bda-aefc-f210110437d7","uuid":"a9c3a3e3-7bb7-4012-ae01-97810fcfdfd0"}
