{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QXtitQYbxQMXkQeRPkaAtS","type":"tool_result","content":"     1→import {\n     2→  extractTitle,\n     3→  extractTitleWithEmbeddings,\n     4→  _resetEmbeddingCacheForTests,\n     5→} from \"../title-extractor\";\n     6→\n     7→/**\n     8→ * Creates a mock embed function that returns predictable vectors.\n     9→ * Words matching titleWords get a vector pointing \"toward titles\",\n    10→ * words matching headerWords get a vector pointing \"toward headers\",\n    11→ * and everything else gets a neutral vector.\n    12→ */\n    13→function createMockEmbed(\n    14→  titleWords: Array<string>,\n    15→  headerWords: Array<string>\n    16→): (text: string) => Promise<Array<number>> {\n    17→  // Reference phrases from the module\n    18→  const TITLE_REF =\n    19→    \"recipe name, dish title, name of the food, nazwa przepisu, nazwa dania\";\n    20→  const HEADER_REF =\n    21→    \"ingredients list, cooking directions, section heading, składniki, przygotowanie, sposób wykonania\";\n    22→  const NOISE_REF =\n    23→    \"page number, table of contents, book footer, garbled text\";\n    24→\n    25→  return async (text: string): Promise<Array<number>> => {\n    26→    const lower = text.toLowerCase();\n    27→\n    28→    // Title reference → unit vector in dimension 0\n    29→    if (lower === TITLE_REF.toLowerCase()) {\n    30→      return [1, 0, 0];\n    31→    }\n    32→    // Header reference → unit vector in dimension 1\n    33→    if (lower === HEADER_REF.toLowerCase()) {\n    34→      return [0, 1, 0];\n    35→    }\n    36→    // Noise reference → unit vector in dimension 2 (orthogonal)\n    37→    if (lower === NOISE_REF.toLowerCase()) {\n    38→      return [0, 0, 1];\n    39→    }\n    40→\n    41→    // Check if text contains title-like words → high cosine with title ref\n    42→    const isTitle = titleWords.some((w) => lower.includes(w.toLowerCase()));\n    43→    // Check if text contains header-like words → high cosine with header ref\n    44→    const isHeader = headerWords.some((w) => lower.includes(w.toLowerCase()));\n    45→\n    46→    if (isTitle && !isHeader) {\n    47→      return [0.9, 0.1, 0]; // High title similarity, low header similarity\n    48→    }\n    49→    if (isHeader && !isTitle) {\n    50→      return [0.1, 0.9, 0]; // Low title similarity, high header similarity\n    51→    }\n    52→    if (isTitle && isHeader) {\n    53→      return [0.5, 0.5, 0]; // Ambiguous\n    54→    }\n    55→    // Neutral\n    56→    return [0.3, 0.3, 0.7];\n    57→  };\n    58→}\n    59→\n    60→describe(\"extractTitle (heuristic)\", () => {\n    61→  it(\"returns undefined for empty text\", () => {\n    62→    expect(extractTitle(\"\")).toBeUndefined();\n    63→    expect(extractTitle(\"  \")).toBeUndefined();\n    64→  });\n    65→\n    66→  it(\"returns the first valid line\", () => {\n    67→    expect(extractTitle(\"Chicken Soup\\nIngredients\\n1 cup water\")).toBe(\n    68→      \"Chicken Soup\"\n    69→    );\n    70→  });\n    71→\n    72→  it(\"skips lines that are too short or too long\", () => {\n    73→    const longLine = \"A\".repeat(51);\n    74→    expect(extractTitle(`ab\\n${longLine}\\nGood Title`)).toBe(\"Good Title\");\n    75→  });\n    76→\n    77→  it(\"skips ingredient lines\", () => {\n    78→    expect(extractTitle(\"2 cups flour\\nApple Pie\")).toBe(\"Apple Pie\");\n    79→  });\n    80→\n    81→  it(\"skips all-caps lines\", () => {\n    82→    expect(extractTitle(\"INGREDIENTS\\nChocolate Cake\")).toBe(\"Chocolate Cake\");\n    83→  });\n    84→\n    85→  it(\"skips lines starting with numbers\", () => {\n    86→    expect(extractTitle(\"12\\nApple Pie\")).toBe(\"Apple Pie\");\n    87→  });\n    88→});\n    89→\n    90→describe(\"extractTitleWithEmbeddings\", () => {\n    91→  beforeEach(() => {\n    92→    _resetEmbeddingCacheForTests();\n    93→  });\n    94→\n    95→  it(\"returns undefined for empty text\", async () => {\n    96→    const embed = createMockEmbed([], []);\n    97→    expect(await extractTitleWithEmbeddings(\"\", embed)).toBeUndefined();\n    98→    expect(await extractTitleWithEmbeddings(\"  \", embed)).toBeUndefined();\n    99→  });\n   100→"}]},"parent_tool_use_id":null,"session_id":"f3952b68-8982-4bda-aefc-f210110437d7","uuid":"3fa1d1a1-f78d-419a-b510-18f217b5b43d","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/__tests__/title-extractor.test.ts","content":"import {\n  extractTitle,\n  extractTitleWithEmbeddings,\n  _resetEmbeddingCacheForTests,\n} from \"../title-extractor\";\n\n/**\n * Creates a mock embed function that returns predictable vectors.\n * Words matching titleWords get a vector pointing \"toward titles\",\n * words matching headerWords get a vector pointing \"toward headers\",\n * and everything else gets a neutral vector.\n */\nfunction createMockEmbed(\n  titleWords: Array<string>,\n  headerWords: Array<string>\n): (text: string) => Promise<Array<number>> {\n  // Reference phrases from the module\n  const TITLE_REF =\n    \"recipe name, dish title, name of the food, nazwa przepisu, nazwa dania\";\n  const HEADER_REF =\n    \"ingredients list, cooking directions, section heading, składniki, przygotowanie, sposób wykonania\";\n  const NOISE_REF =\n    \"page number, table of contents, book footer, garbled text\";\n\n  return async (text: string): Promise<Array<number>> => {\n    const lower = text.toLowerCase();\n\n    // Title reference → unit vector in dimension 0\n    if (lower === TITLE_REF.toLowerCase()) {\n      return [1, 0, 0];\n    }\n    // Header reference → unit vector in dimension 1\n    if (lower === HEADER_REF.toLowerCase()) {\n      return [0, 1, 0];\n    }\n    // Noise reference → unit vector in dimension 2 (orthogonal)\n    if (lower === NOISE_REF.toLowerCase()) {\n      return [0, 0, 1];\n    }\n\n    // Check if text contains title-like words → high cosine with title ref\n    const isTitle = titleWords.some((w) => lower.includes(w.toLowerCase()));\n    // Check if text contains header-like words → high cosine with header ref\n    const isHeader = headerWords.some((w) => lower.includes(w.toLowerCase()));\n\n    if (isTitle && !isHeader) {\n      return [0.9, 0.1, 0]; // High title similarity, low header similarity\n    }\n    if (isHeader && !isTitle) {\n      return [0.1, 0.9, 0]; // Low title similarity, high header similarity\n    }\n    if (isTitle && isHeader) {\n      return [0.5, 0.5, 0]; // Ambiguous\n    }\n    // Neutral\n    return [0.3, 0.3, 0.7];\n  };\n}\n\ndescribe(\"extractTitle (heuristic)\", () => {\n  it(\"returns undefined for empty text\", () => {\n    expect(extractTitle(\"\")).toBeUndefined();\n    expect(extractTitle(\"  \")).toBeUndefined();\n  });\n\n  it(\"returns the first valid line\", () => {\n    expect(extractTitle(\"Chicken Soup\\nIngredients\\n1 cup water\")).toBe(\n      \"Chicken Soup\"\n    );\n  });\n\n  it(\"skips lines that are too short or too long\", () => {\n    const longLine = \"A\".repeat(51);\n    expect(extractTitle(`ab\\n${longLine}\\nGood Title`)).toBe(\"Good Title\");\n  });\n\n  it(\"skips ingredient lines\", () => {\n    expect(extractTitle(\"2 cups flour\\nApple Pie\")).toBe(\"Apple Pie\");\n  });\n\n  it(\"skips all-caps lines\", () => {\n    expect(extractTitle(\"INGREDIENTS\\nChocolate Cake\")).toBe(\"Chocolate Cake\");\n  });\n\n  it(\"skips lines starting with numbers\", () => {\n    expect(extractTitle(\"12\\nApple Pie\")).toBe(\"Apple Pie\");\n  });\n});\n\ndescribe(\"extractTitleWithEmbeddings\", () => {\n  beforeEach(() => {\n    _resetEmbeddingCacheForTests();\n  });\n\n  it(\"returns undefined for empty text\", async () => {\n    const embed = createMockEmbed([], []);\n    expect(await extractTitleWithEmbeddings(\"\", embed)).toBeUndefined();\n    expect(await extractTitleWithEmbeddings(\"  \", embed)).toBeUndefined();\n  });\n","numLines":100,"startLine":1,"totalLines":482}}}
