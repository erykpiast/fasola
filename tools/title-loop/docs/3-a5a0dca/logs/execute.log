{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JscJjTbRfB9d17BYJXsceP","type":"tool_result","content":"     1→/**\n     2→ * Title Extraction\n     3→ * Extracts potential recipe title from OCR text using heuristics or semantic embeddings\n     4→ */\n     5→\n     6→import { cosineSimilarity } from \"./embeddings\";\n     7→\n     8→export type EmbedFn = (text: string) => Promise<Array<number>>;\n     9→\n    10→const TITLE_REFERENCE =\n    11→  \"recipe name, dish title, name of the food, nazwa przepisu, nazwa dania\";\n    12→const HEADER_REFERENCE =\n    13→  \"ingredients list, cooking directions, section heading, składniki, przygotowanie, sposób wykonania\";\n    14→const NOISE_REFERENCE =\n    15→  \"page number, table of contents, book footer, garbled text\";\n    16→\n    17→/**\n    18→ * Measurement units commonly found in ingredient lists\n    19→ */\n    20→const MEASUREMENT_PATTERNS = [\n    21→  \"cup\",\n    22→  \"cups\",\n    23→  \"tbsp\",\n    24→  \"tsp\",\n    25→  \"tablespoon\",\n    26→  \"teaspoon\",\n    27→  \"oz\",\n    28→  \"lb\",\n    29→  \"gram\",\n    30→  \"grams\",\n    31→  \"kg\",\n    32→  \"ml\",\n    33→  \"liter\",\n    34→  \"pinch\",\n    35→  \"dash\",\n    36→  \"handful\",\n    37→];\n    38→\n    39→/**\n    40→ * Patterns that identify recipe metadata lines (not titles)\n    41→ */\n    42→const METADATA_PATTERNS = [\n    43→  /^(SERVES?|MAKES?|YIELDS?)\\b/i,\n    44→  /^(PREP(ARATION)?|COOK(ING)?|PROOF|RISING|FERMENTATION|REST(ING)?)\\s*(AND\\s*)?(COOK(ING)?)?\\s*TIME/i,\n    45→  /^SAMPLE\\s+SCHEDULE\\b/i,\n    46→  /^BULK\\s+FERMENTATION\\b/i,\n    47→  /^(THIS\\s+RECIPE\\s+)?MAKES\\b/i,\n    48→];\n    49→\n    50→/**\n    51→ * Single-word non-title words — standalone OCR fragments unlikely to be recipe titles\n    52→ */\n    53→const NON_TITLE_WORDS = new Set([\n    54→  \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"are\", \"was\",\n    55→  \"has\", \"his\", \"her\", \"its\", \"our\", \"who\", \"how\", \"may\", \"new\", \"now\",\n    56→  \"old\", \"see\", \"way\", \"did\", \"get\", \"let\", \"say\", \"she\", \"too\", \"use\",\n    57→  \"buns\", \"with\",\n    58→]);\n    59→\n    60→function looksLikeIngredient(line: string): boolean {\n    61→  const lowerLine = line.toLowerCase();\n    62→  return MEASUREMENT_PATTERNS.some((pattern) => lowerLine.includes(pattern));\n    63→}\n    64→\n    65→function startsWithNumber(line: string): boolean {\n    66→  return /^\\s*\\d/.test(line);\n    67→}\n    68→\n    69→function isAllCaps(line: string): boolean {\n    70→  const letters = line.replace(/[^a-zA-Z]/g, \"\");\n    71→  return letters.length > 0 && letters === letters.toUpperCase();\n    72→}\n    73→\n    74→function looksLikeMetadata(text: string): boolean {\n    75→  return METADATA_PATTERNS.some((pattern) => pattern.test(text.trim()));\n    76→}\n    77→\n    78→function isLikelyGarbled(text: string): boolean {\n    79→  const letters = text.replace(/[^a-zA-Z]/g, \"\");\n    80→  if (letters.length < 2) return true;\n    81→\n    82→  // Check vowel ratio — English/Polish text typically has 30–50% vowels\n    83→  const vowels = letters.replace(/[^aeiouAEIOUyYąęóĄĘÓ]/g, \"\").length;\n    84→  const vowelRatio = vowels / letters.length;\n    85→  if (vowelRatio < 0.15 || vowelRatio > 0.85) return true;\n    86→\n    87→  // Single orphaned word ≤3 letters that isn't a common word\n    88→  const words = text.trim().split(/\\s+/);\n    89→  const COMMON_SHORT = new Set([\n    90→    \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"had\", \"her\",\n    91→    \"was\", \"one\", \"our\", \"out\", \"are\", \"has\", \"his\", \"how\", \"its\", \"may\",\n    92→    \"new\", \"now\", \"old\", \"see\", \"way\", \"who\", \"did\", \"get\", \"let\", \"say\",\n    93→    \"she\", \"too\", \"use\",\n    94→  ]);\n    95→  if (words.length === 1 && letters.length <= 3 && !COMMON_SHORT.has(text.trim().toLowerCase())) {\n    96→    return true;\n    97→  }\n    98→\n    99→  // Recipe titles never start with a lowercase letter\n   100→  if (/^[a-z]/.test(text.trim())) {\n   101→    return true;\n   102→  }\n   103→\n   104→  // Mid-text sentence boundary (\". \" followed by a letter) — body text fragment spliced from multiple sentences\n   105→  const trimmed = text.trim();\n   106→  if (/\\.\\s+[a-zA-Z]/.test(trimmed) && !trimmed.endsWith(\")\")) {\n   107→    return true;\n   108→  }\n   109→\n   110→  // Multi-word candidate containing a garbled OCR fragment: a short lowercase word that isn't a known short word\n   111→  if (words.length >= 2) {\n   112→    const commonShort2 = new Set([\n   113→      \"a\", \"i\", \"of\", \"or\", \"to\", \"in\", \"on\", \"is\", \"it\", \"an\",\n   114→      \"as\", \"at\", \"by\", \"do\", \"go\", \"if\", \"no\", \"so\", \"up\", \"we\",\n   115→      \"w\", \"z\",  // Polish prepositions\n   116→    ]);\n   117→    const hasGarbledWord = words.some(\n   118→      (w) =>\n   119→        /^[a-z]/.test(w) &&\n   120→        w.replace(/[^a-z]/g, \"\").length <= 2 &&\n   121→        !commonShort2.has(w.toLowerCase())\n   122→    );\n   123→    if (hasGarbledWord) {\n   124→      return true;\n   125→    }\n   126→  }\n   127→\n   128→  return false;\n   129→}\n   130→\n   131→function passesHardFilters(text: string): boolean {\n   132→  if (text.length < 3 || text.length > 80) return false;\n   133→  if (looksLikeIngredient(text)) return false;\n   134→  if (startsWithNumber(text)) return false;\n   135→  if (looksLikeMetadata(text)) return false;\n   136→  if (isLikelyGarbled(text)) return false;\n   137→  // Single-word non-title fragments\n   138→  const words = text.trim().split(/\\s+/);\n   139→  if (words.length === 1 && NON_TITLE_WORDS.has(text.trim().toLowerCase())) return false;\n   140→  return true;\n   141→}\n   142→\n   143→/**\n   144→ * Detect initial burst of short garbled lines.\n   145→ * Returns the index of the first non-garbled or long line.\n   146→ */\n   147→function findBurstEnd(lines: Array<{ text: string }>): number {\n   148→  let i = 0;\n   149→  while (i < lines.length && lines[i].text.length < 20 && isLikelyGarbled(lines[i].text)) {\n   150→    i++;\n   151→  }\n   152→  return i;\n   153→}\n   154→\n   155→function wordCount(text: string): number {\n   156→  return text.split(/\\s+/).filter((w) => w.length > 0).length;\n   157→}\n   158→\n   159→/**\n   160→ * Build candidate strings from lines: single lines plus multi-line joins (2-3 consecutive).\n   161→ * Skips initial burst of short garbled lines. Scans all remaining lines. Caps at 25.\n   162→ */\n   163→function buildCandidates(\n   164→  lines: Array<string>\n   165→): Array<{ text: string; position: number }> {\n   166→  const nonEmptyLines: Array<{ text: string; index: number }> = [];\n   167→\n   168→  for (let i = 0; i < lines.length; i++) {\n   169→    const trimmed = lines[i].trim();\n   170→    if (trimmed.length > 0) {\n   171→      nonEmptyLines.push({ text: trimmed, index: i });\n   172→    }\n   173→  }\n   174→\n   175→  const burstEnd = findBurstEnd(nonEmptyLines);\n   176→  const candidates: Array<{ text: string; position: number }> = [];\n   177→  const seen = new Set<string>();\n   178→\n   179→  for (let i = burstEnd; i < nonEmptyLines.length; i++) {\n   180→    const line = nonEmptyLines[i];\n   181→\n   182→    // Single line\n   183→    if (passesHardFilters(line.text)) {\n   184→      const norm = line.text.toLowerCase();\n   185→      if (!seen.has(norm)) {\n   186→        seen.add(norm);\n   187→        candidates.push({ text: line.text, position: line.index });\n   188→      }\n   189→    }\n   190→\n   191→    // 2-line join\n   192→    if (i + 1 < nonEmptyLines.length) {\n   193→      const joined2 = `${line.text} ${nonEmptyLines[i + 1].text}`;\n   194→      if (passesHardFilters(joined2)) {\n   195→        const norm = joined2.toLowerCase();\n   196→        if (!seen.has(norm)) {\n   197→          seen.add(norm);\n   198→          candidates.push({ text: joined2, position: line.index });\n   199→        }\n   200→      }\n   201→    }\n   202→\n   203→    // 3-line join\n   204→    if (i + 2 < nonEmptyLines.length) {\n   205→      const joined3 = `${line.text} ${nonEmptyLines[i + 1].text} ${nonEmptyLines[i + 2].text}`;\n   206→      if (passesHardFilters(joined3)) {\n   207→        const norm = joined3.toLowerCase();\n   208→        if (!seen.has(norm)) {\n   209→          seen.add(norm);\n   210→          candidates.push({ text: joined3, position: line.index });\n   211→        }\n   212→      }\n   213→    }\n   214→  }\n   215→\n   216→  // Pre-filter to 25 before embedding calls: prefer ALL_CAPS and short candidates.\n   217→  // Position-based scoring handles final ranking.\n   218→  if (candidates.length > 25) {\n   219→    const prioritized = candidates.slice().sort((a, b) => {\n   220→      const aAllCaps = isAllCaps(a.text) ? 0 : 1;\n   221→      const bAllCaps = isAllCaps(b.text) ? 0 : 1;\n   222→      if (aAllCaps !== bAllCaps) return aAllCaps - bAllCaps;\n   223→      const aShort = wordCount(a.text) <= 5 ? 0 : 1;\n   224→      const bShort = wordCount(b.text) <= 5 ? 0 : 1;\n   225→      return aShort - bShort;\n   226→    });\n   227→    return prioritized.slice(0, 25);\n   228→  }\n   229→\n   230→  return candidates;\n   231→}\n   232→\n   233→// Module-level cache for reference embeddings\n   234→let cachedTitleRefEmbedding: Array<number> | null = null;\n   235→let cachedHeaderRefEmbedding: Array<number> | null = null;\n   236→let cachedNoiseRefEmbedding: Array<number> | null = null;\n   237→\n   238→export function _resetEmbeddingCacheForTests(): void {\n   239→  cachedTitleRefEmbedding = null;\n   240→  cachedHeaderRefEmbedding = null;\n   241→  cachedNoiseRefEmbedding = null;\n   242→}\n   243→\n   244→export async function extractTitleWithEmbeddings(\n   245→  text: string,\n   246→  embed: EmbedFn\n   247→): Promise<string | undefined> {\n   248→  if (!text || text.trim().length === 0) {\n   249→    return undefined;\n   250→  }\n   251→\n   252→  const lines = text.split(\"\\n\");\n   253→  const candidates = buildCandidates(lines);\n   254→\n   255→  if (candidates.length === 0) {\n   256→    return undefined;\n   257→  }\n   258→\n   259→  // Cache reference embeddings\n   260→  if (!cachedTitleRefEmbedding) {\n   261→    cachedTitleRefEmbedding = await embed(TITLE_REFERENCE);\n   262→  }\n   263→  if (!cachedHeaderRefEmbedding) {\n   264→    cachedHeaderRefEmbedding = await embed(HEADER_REFERENCE);\n   265→  }\n   266→  if (!cachedNoiseRefEmbedding) {\n   267→    cachedNoiseRefEmbedding = await embed(NOISE_REFERENCE);\n   268→  }\n   269→\n   270→  // Find the first ALL_CAPS candidate with ≥2 words where every significant word has ≥4 alpha letters.\n   271→  // This structural signal identifies the first clean recipe title heading in cookbook scans.\n   272→  // Insignificant tokens (≤1 alpha letter: \"/\", \"&\", \"+\", \":\", \"D)\", etc.) are filtered before\n   273→  // the check so that multi-line joins with continuation punctuation still qualify.\n   274→  const firstStructuralHeading = candidates.find((c) => {\n   275→    if (!isAllCaps(c.text) || wordCount(c.text) < 2) return false;\n   276→    const significantWords = c.text\n   277→      .trim()\n   278→      .split(/\\s+/)\n   279→      .filter((w) => w.replace(/[^A-Z]/g, \"\").length > 1);\n   280→    return (\n   281→      significantWords.length >= 2 &&\n   282→      significantWords.every((w) => w.replace(/[^A-Z]/g, \"\").length >= 4)\n   283→    );\n   284→  });\n   285→\n   286→  const scored: Array<{ text: string; position: number; score: number; rawScore: number; baseScore: number }> = [];\n   287→\n   288→  for (const candidate of candidates) {\n   289→    const embedding = await embed(candidate.text);\n   290→    const titleSim = cosineSimilarity(embedding, cachedTitleRefEmbedding);\n   291→    const headerSim = cosineSimilarity(embedding, cachedHeaderRefEmbedding);\n   292→    const noiseSim = cosineSimilarity(embedding, cachedNoiseRefEmbedding);\n   293→    const rawScore = titleSim - Math.max(headerSim, noiseSim);\n   294→\n   295→    // Position factor: multiplicative tiebreaker — amplifies existing signal, doesn't replace it\n   296→    const relativePosition = candidate.position / lines.length;\n   297→    const positionFactor = relativePosition < 0.5\n   298→      ? 1.0 + 0.12 * (1 - relativePosition * 2)\n   299→      : 1.0;\n   300→\n   301→    // ALL_CAPS bonus: recipe books use ALL_CAPS for titles and section headings\n   302→    const allCapsBonus = isAllCaps(candidate.text) && candidate.text.replace(/[^a-zA-Z]/g, \"\").length >= 4\n   303→      ? 0.08\n   304→      : 0;\n   305→\n   306→    // Structural heading bonus: first clean ALL_CAPS heading is almost always the recipe title\n   307→    const structuralBonus =\n   308→      firstStructuralHeading && candidate === firstStructuralHeading ? 0.10 : 0;\n   309→\n   310→    // baseScore excludes position factor — used for threshold so position boost on the first\n   311→    // title doesn't inflate the bar and exclude valid later titles on multi-recipe pages\n   312→    const baseScore = rawScore + allCapsBonus + structuralBonus;\n   313→    const score = rawScore * positionFactor + allCapsBonus + structuralBonus;\n   314→    scored.push({ text: candidate.text, position: candidate.position, score, rawScore, baseScore });\n   315→  }\n   316→\n   317→  if (scored.length === 0) {\n   318→    return undefined;\n   319→  }\n   320→\n   321→  // Use position-free baseScore for threshold so position boost on the first title doesn't\n   322→  // inflate the bar and exclude valid later titles on multi-recipe pages.\n   323→  const bestBaseScore = Math.max(...scored.map((s) => s.baseScore));\n   324→  const threshold = Math.max(0.08, bestBaseScore * 0.7);\n   325→\n   326→  // Filter candidates above threshold\n   327→  let selected = scored.filter((s) => s.score >= threshold);\n   328→\n   329→  // Remove word-boundary prefixes of the firstStructuralHeading when the heading itself\n   330→  // survived the threshold. A multi-line join that qualifies as the structural heading\n   331→  // (e.g. \"ARAYES SHRAK\", \"SAFFRON WHEAT BUNS WITH QUARK / COTTAGE CHEESE (VARIATION D)\")\n   332→  // is the complete title; the first OCR line (\"ARAYES\", \"SAFFRON WHEAT BUNS WITH QUARK\")\n   333→  // is just an incomplete prefix. Without this step the dedup below would discard the\n   334→  // complete heading in favour of the shorter prefix.\n   335→  if (firstStructuralHeading && selected.some((s) => s === firstStructuralHeading)) {\n   336→    const fshLower = firstStructuralHeading.text.toLowerCase();\n   337→    selected = selected.filter((s) => {\n   338→      if (s === firstStructuralHeading) return true;\n   339→      const sLower = s.text.toLowerCase();\n   340→      // Keep unless s is a proper word-boundary prefix of the structural heading\n   341→      return !fshLower.startsWith(sLower + \" \");\n   342→    });\n   343→  }\n   344→\n   345→  // Deduplicate: if one title is a substring of another, keep the shorter (more focused) one.\n   346→  // DO NOT CHANGE THIS LOGIC — it has been incorrectly \"improved\" by the title-loop 5 times.\n   347→  // The tests require shorter wins: \"Pierogi Ruskie\" over \"Pierogi Ruskie 200g mąki 3 ziemniaki\".\n   348→  selected = selected.filter((a) => {\n   349→    const aLower = a.text.toLowerCase();\n   350→    return !selected.some(\n   351→      (b) =>\n   352→        b !== a &&\n   353→        aLower.includes(b.text.toLowerCase()) &&\n   354→        b.text.length < a.text.length\n   355→    );\n   356→  });\n   357→\n   358→  // Multi-title guard: only join multiple candidates with \"+\" when there is\n   359→  // structural evidence of a multi-recipe page (≥2 ALL_CAPS headings).\n   360→  // A single ALL_CAPS title among mixed-case survivors is a single-recipe page —\n   361→  // collapse to the highest-scoring candidate.\n   362→  // Zero ALL_CAPS survivors → mixed-case multi-title page → keep all.\n   363→  if (selected.length > 1) {\n   364→    const allCapsSelected = selected.filter((s) => isAllCaps(s.text));\n   365→    if (allCapsSelected.length >= 2) {\n   366→      selected = allCapsSelected;\n   367→    } else if (allCapsSelected.length === 1) {\n   368→      selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n   369→    }\n   370→  }\n   371→\n   372→  // Cap at 3, sort by document position\n   373→  selected.sort((a, b) => a.position - b.position);\n   374→  selected = selected.slice(0, 3);\n   375→\n   376→  if (selected.length === 0) {\n   377→    return undefined;\n   378→  }\n   379→\n   380→  return selected.map((s) => s.text).join(\" + \");\n   381→}\n   382→\n   383→/**\n   384→ * Extract potential recipe title from OCR text (sync heuristic fallback)\n   385→ */\n   386→export function extractTitle(text: string): string | undefined {\n   387→  if (!text || text.trim().length === 0) {\n   388→    return undefined;\n   389→  }\n   390→\n   391→  const lines = text.split(\"\\n\").map((line) => line.trim());\n   392→\n   393→  for (const line of lines) {\n   394→    if (line.length === 0) continue;\n   395→    if (line.length < 3 || line.length > 50) continue;\n   396→    if (looksLikeIngredient(line)) continue;\n   397→    if (isAllCaps(line)) continue;\n   398→    if (startsWithNumber(line)) continue;\n   399→    return line;\n   400→  }\n   401→\n   402→  return undefined;\n   403→}\n   404→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_01Kuaxaddg7PYiKxqeFpHYmk","session_id":"a0a05f64-dc5e-4fd2-9d6c-8483fb711304","uuid":"3523bed9-d89b-4752-a9bb-5ffe7738c6a6"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011Wjf9d134WjFuBsZ8w45hn","type":"tool_result","content":"     1→import {\n     2→  extractTitle,\n     3→  extractTitleWithEmbeddings,\n     4→  _resetEmbeddingCacheForTests,\n     5→} from \"../title-extractor\";\n     6→\n     7→/**\n     8→ * Creates a mock embed function that returns predictable vectors.\n     9→ * Words matching titleWords get a vector pointing \"toward titles\",\n    10→ * words matching headerWords get a vector pointing \"toward headers\",\n    11→ * and everything else gets a neutral vector.\n    12→ */\n    13→function createMockEmbed(\n    14→  titleWords: Array<string>,\n    15→  headerWords: Array<string>\n    16→): (text: string) => Promise<Array<number>> {\n    17→  // Reference phrases from the module\n    18→  const TITLE_REF =\n    19→    \"recipe name, dish title, name of the food, nazwa przepisu, nazwa dania\";\n    20→  const HEADER_REF =\n    21→    \"ingredients list, cooking directions, section heading, składniki, przygotowanie, sposób wykonania\";\n    22→  const NOISE_REF =\n    23→    \"page number, table of contents, book footer, garbled text\";\n    24→\n    25→  return async (text: string): Promise<Array<number>> => {\n    26→    const lower = text.toLowerCase();\n    27→\n    28→    // Title reference → unit vector in dimension 0\n    29→    if (lower === TITLE_REF.toLowerCase()) {\n    30→      return [1, 0, 0];\n    31→    }\n    32→    // Header reference → unit vector in dimension 1\n    33→    if (lower === HEADER_REF.toLowerCase()) {\n    34→      return [0, 1, 0];\n    35→    }\n    36→    // Noise reference → unit vector in dimension 2 (orthogonal)\n    37→    if (lower === NOISE_REF.toLowerCase()) {\n    38→      return [0, 0, 1];\n    39→    }\n    40→\n    41→    // Check if text contains title-like words → high cosine with title ref\n    42→    const isTitle = titleWords.some((w) => lower.includes(w.toLowerCase()));\n    43→    // Check if text contains header-like words → high cosine with header ref\n    44→    const isHeader = headerWords.some((w) => lower.includes(w.toLowerCase()));\n    45→\n    46→    if (isTitle && !isHeader) {\n    47→      return [0.9, 0.1, 0]; // High title similarity, low header similarity\n    48→    }\n    49→    if (isHeader && !isTitle) {\n    50→      return [0.1, 0.9, 0]; // Low title similarity, high header similarity\n    51→    }\n    52→    if (isTitle && isHeader) {\n    53→      return [0.5, 0.5, 0]; // Ambiguous\n    54→    }\n    55→    // Neutral\n    56→    return [0.3, 0.3, 0.7];\n    57→  };\n    58→}\n    59→\n    60→describe(\"extractTitle (heuristic)\", () => {\n    61→  it(\"returns undefined for empty text\", () => {\n    62→    expect(extractTitle(\"\")).toBeUndefined();\n    63→    expect(extractTitle(\"  \")).toBeUndefined();\n    64→  });\n    65→\n    66→  it(\"returns the first valid line\", () => {\n    67→    expect(extractTitle(\"Chicken Soup\\nIngredients\\n1 cup water\")).toBe(\n    68→      \"Chicken Soup\"\n    69→    );\n    70→  });\n    71→\n    72→  it(\"skips lines that are too short or too long\", () => {\n    73→    const longLine = \"A\".repeat(51);\n    74→    expect(extractTitle(`ab\\n${longLine}\\nGood Title`)).toBe(\"Good Title\");\n    75→  });\n    76→\n    77→  it(\"skips ingredient lines\", () => {\n    78→    expect(extractTitle(\"2 cups flour\\nApple Pie\")).toBe(\"Apple Pie\");\n    79→  });\n    80→\n    81→  it(\"skips all-caps lines\", () => {\n    82→    expect(extractTitle(\"INGREDIENTS\\nChocolate Cake\")).toBe(\"Chocolate Cake\");\n    83→  });\n    84→\n    85→  it(\"skips lines starting with numbers\", () => {\n    86→    expect(extractTitle(\"12\\nApple Pie\")).toBe(\"Apple Pie\");\n    87→  });\n    88→});\n    89→\n    90→describe(\"extractTitleWithEmbeddings\", () => {\n    91→  beforeEach(() => {\n    92→    _resetEmbeddingCacheForTests();\n    93→  });\n    94→\n    95→  it(\"returns undefined for empty text\", async () => {\n    96→    const embed = createMockEmbed([], []);\n    97→    expect(await extractTitleWithEmbeddings(\"\", embed)).toBeUndefined();\n    98→    expect(await extractTitleWithEmbeddings(\"  \", embed)).toBeUndefined();\n    99→  });\n   100→\n   101→  it(\"picks title over section header (Polish)\", async () => {\n   102→    const embed = createMockEmbed([\"pierogi ruskie\"], [\"składniki\"]);\n   103→    const text = \"Składniki\\nPierogi Ruskie\\n200g mąki\\n3 ziemniaki\";\n   104→    const result = await extractTitleWithEmbeddings(text, embed);\n   105→    expect(result).toBe(\"Pierogi Ruskie\");\n   106→  });\n   107→\n   108→  it(\"picks title over section header (English)\", async () => {\n   109→    const embed = createMockEmbed([\"chicken soup\"], [\"ingredients\"]);\n   110→    const text = \"Ingredients\\nChicken Soup\\n1 cup water\\nSalt\";\n   111→    const result = await extractTitleWithEmbeddings(text, embed);\n   112→    expect(result).toBe(\"Chicken Soup\");\n   113→  });\n   114→\n   115→  it(\"preserves all-caps titles\", async () => {\n   116→    const embed = createMockEmbed([\"chocolate cake\"], [\"ingredients\"]);\n   117→    const text = \"CHOCOLATE CAKE\\nIngredients\\n200g flour\";\n   118→    const result = await extractTitleWithEmbeddings(text, embed);\n   119→    expect(result).toBe(\"CHOCOLATE CAKE\");\n   120→  });\n   121→\n   122→  it(\"skips numbered lines\", async () => {\n   123→    const embed = createMockEmbed([\"apple pie\"], []);\n   124→    const text = \"12\\nApple Pie\\nSome instructions\";\n   125→    const result = await extractTitleWithEmbeddings(text, embed);\n   126→    expect(result).toBe(\"Apple Pie\");\n   127→  });\n   128→\n   129→  it(\"joins multi-line title (2 lines)\", async () => {\n   130→    const embed = createMockEmbed(\n   131→      [\"kurczak w sosie śmietanowym z pieczarkami\"],\n   132→      [\"składniki\"]\n   133→    );\n   134→    const text =\n   135→      \"Kurczak w sosie\\nśmietanowym z pieczarkami\\nSkładniki\\n200g kurczaka\";\n   136→    const result = await extractTitleWithEmbeddings(text, embed);\n   137→    expect(result).toBe(\"Kurczak w sosie śmietanowym z pieczarkami\");\n   138→  });\n   139→\n   140→  it(\"joins multi-line title (3 lines)\", async () => {\n   141→    const embed = createMockEmbed(\n   142→      [\"makaron z sosem pomidorowym i bazylią\"],\n   143→      [\"składniki\"]\n   144→    );\n   145→    const text =\n   146→      \"Makaron z sosem\\npomidorowym\\ni bazylią\\nSkładniki\\n300g makaronu\";\n   147→    const result = await extractTitleWithEmbeddings(text, embed);\n   148→    expect(result).toBe(\"Makaron z sosem pomidorowym i bazylią\");\n   149→  });\n   150→\n   151→  it(\"does not over-greedily join title with header\", async () => {\n   152→    const embed = createMockEmbed([\"apple pie\"], [\"ingredients\"]);\n   153→    const text = \"Apple Pie\\nIngredients\\n200g flour\";\n   154→    const result = await extractTitleWithEmbeddings(text, embed);\n   155→    // Should prefer \"Apple Pie\" alone, not \"Apple Pie Ingredients\"\n   156→    expect(result).toBe(\"Apple Pie\");\n   157→  });\n   158→\n   159→  it(\"returns multiple titles joined with + when both score well\", async () => {\n   160→    const embed = createMockEmbed(\n   161→      [\"first recipe\", \"second recipe\"],\n   162→      []\n   163→    );\n   164→    const text = \"First Recipe\\nSecond Recipe\\nSome other text\";\n   165→    const result = await extractTitleWithEmbeddings(text, embed);\n   166→    expect(result).toBe(\"First Recipe + Second Recipe\");\n   167→  });\n   168→\n   169→  it(\"skips burst of short lines at start and finds title after\", async () => {\n   170→    const embed = createMockEmbed([\"beef stew\"], [\"ingredients\"]);\n   171→    // 3+ short garbled lines at start, then real content with a long line\n   172→    const text =\n   173→      \"pg 42\\nA.\\nfoo\\nThis is a longer line that triggers burst end detection\\nBeef Stew\\nIngredients\\n500g beef\";\n   174→    const result = await extractTitleWithEmbeddings(text, embed);\n   175→    expect(result).toBe(\"Beef Stew\");\n   176→  });\n   177→\n   178→  it(\"two titles deep in text returns both joined\", async () => {\n   179→    const embed = createMockEmbed(\n   180→      [\"pasta carbonara\", \"tiramisu classico\"],\n   181→      [\"ingredients\", \"składniki\"]\n   182→    );\n   183→    const text =\n   184→      \"Ingredients\\nPasta Carbonara\\n200g pasta\\n100g guanciale\\nIngredients\\nTiramisu Classico\\n250g mascarpone\";\n   185→    const result = await extractTitleWithEmbeddings(text, embed);\n   186→    expect(result).toBe(\"Pasta Carbonara + Tiramisu Classico\");\n   187→  });\n   188→\n   189→  it(\"single-recipe page still returns one title\", async () => {\n   190→    const embed = createMockEmbed([\"tomato soup\"], [\"ingredients\"]);\n   191→    const text = \"Tomato Soup\\nIngredients\\n4 tomatoes\\n1 cup cream\\nSalt\";\n   192→    const result = await extractTitleWithEmbeddings(text, embed);\n   193→    expect(result).toBe(\"Tomato Soup\");\n   194→  });\n   195→});\n   196→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_01Kuaxaddg7PYiKxqeFpHYmk","session_id":"a0a05f64-dc5e-4fd2-9d6c-8483fb711304","uuid":"ba8f9a4e-a972-4bbb-a12e-f28095895483"}
