{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011vpTn5Dg2cfzbdnQUYtcx8","type":"tool_result","content":"  1200→  }\n  1201→  // Direct-successor bonus: when the line immediately before this candidate is a\n  1202→  // section label, metadata, or pipe-separated line, the candidate is very likely\n  1203→  // the title that follows that header. This complements the first-after-preamble\n  1204→  // bonus which requires ALL preceding lines to be filtered — this one fires even\n  1205→  // when earlier non-filtered lines exist. Checked for the top 3 candidates only\n  1206→  // (ci <= 2) to prevent the bonus from firing on random mid-document lines.\n  1207→  for (let ci = 0; ci < scored.length && ci <= 2; ci++) {\n  1208→    const candidate = scored[ci];\n  1209→    if (candidate.position > 0) {\n  1210→      // Scan backward past blank lines to find nearest non-empty preceding line\n  1211→      let prevPos = candidate.position - 1;\n  1212→      while (prevPos >= 0 && lines[prevPos].trim() === \"\") {\n  1213→        prevPos--;\n  1214→      }\n  1215→      if (prevPos >= 0) {\n  1216→        const prevLine = lines[prevPos].trim();\n  1217→        const prevIsHeader =\n  1218→          isSectionLabel(prevLine) ||\n  1219→          looksLikeMetadata(prevLine) ||\n  1220→          prevLine.includes(\" | \");\n  1221→        if (prevIsHeader) {\n  1222→          candidate.score += 0.10;\n  1223→          candidate.baseScore += 0.10;\n  1224→          candidate.thresholdScore += 0.10;\n  1225→        }\n  1226→      }\n  1227→    }\n  1228→  }\n  1229→\n  1230→  // Cap combined positional boost (position factor + first-after-preamble + direct-successor)\n  1231→  // to avoid over-boosting when multiple bonuses fire together. Applied after all positional\n  1232→  // bonuses so the cap covers all of them (per improvement plan: shared +0.15 max).\n  1233→  // Raise cap slightly for pipe-separated metadata followed by ALL_CAPS candidate.\n  1234→  // This is a near-certain title pattern in Polish cookbooks where MiniLM\n  1235→  // (English-centric) gives weak embedding scores for Polish ALL_CAPS text.\n  1236→  // hasPipePreamble is set above inside the allPrecedingFiltered block, so it is\n  1237→  // only true when the preamble-bonus logic also fired (consistent gating).\n  1238→  const maxPositionalBoost =\n  1239→    hasPipePreamble && isAllCaps(firstCandidate.text) ? 0.18 : 0.15;\n  1240→  const totalPositionalBoost = firstCandidate.score - baseScoreBeforePositionalBonuses;\n  1241→  if (totalPositionalBoost > maxPositionalBoost) {\n  1242→    const excess = totalPositionalBoost - maxPositionalBoost;\n  1243→    firstCandidate.score -= excess;\n  1244→    firstCandidate.baseScore -= excess;\n  1245→    firstCandidate.thresholdScore -= excess;\n  1246→  }\n  1247→\n  1248→  // --- Pre-threshold bilingual title detection ---\n  1249→  // When a mixed-case candidate at position 0 is followed by an ALL_CAPS candidate\n  1250→  // at position ≤ 2 that is semantically similar to it, this is a bilingual recipe\n  1251→  // page (e.g., Polish title + ALL_CAPS Korean romanization). Suppress confirmed\n  1252→  // translation candidates before computing threshold so their bonuses don't inflate\n  1253→  // the threshold beyond the mixed-case title's reach.\n  1254→  // Note: we check position ≤ 2 (local proximity), not global ALL_CAPS count, so\n  1255→  // section headers later in the document (SKŁADNIKI, WARZYWA, etc.) are irrelevant.\n  1256→  let translationCandidates: typeof scored = [];\n  1257→  let scoredForThreshold = scored;\n  1258→  const prePos0 = scored.find((s) => s.position === 0 && !isAllCaps(s.text));\n  1259→  if (prePos0) {\n  1260→    const nearbyAllCaps = scored.filter(\n  1261→      (s) => isAllCaps(s.text) && s.position >= 1 && s.position <= 2 && s.origin === \"single\"\n  1262→    );\n  1263→    const pos0Embedding = rawScored.find((r) => r.text === prePos0.text)?.embedding;\n  1264→\n  1265→    // Method 1: embedding similarity (works for related languages)\n  1266→    if (pos0Embedding && nearbyAllCaps.length > 0) {\n  1267→      translationCandidates = nearbyAllCaps.filter((cap) => {\n  1268→        const capEmbedding = rawScored.find((r) => r.text === cap.text)?.embedding;\n  1269→        if (!capEmbedding) return false;\n  1270→        return cosineSimilarity(pos0Embedding, capEmbedding) > 0.4;\n  1271→      });\n  1272→    }\n  1273→\n  1274→    // Method 2: layout-based detection (cross-lingual fallback).\n  1275→    // When embedding similarity is insufficient (e.g. Polish ↔ Korean romanization),\n  1276→    // detect bilingual layout by position and word overlap:\n  1277→    // mixed-case ≥2 words at pos 0 + ALL_CAPS ≥2 words at pos 1-2 with no shared words.\n  1278→    if (translationCandidates.length === 0 && wordCount(prePos0.text) >= 2) {\n  1279→      const pos0Words = new Set(\n  1280→        prePos0.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2)\n  1281→      );\n  1282→      translationCandidates = nearbyAllCaps.filter((cap) => {\n  1283→        if (wordCount(cap.text) < 2) return false;\n  1284→        const capWords = cap.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2);\n  1285→        return !capWords.some((w) => pos0Words.has(w));\n  1286→      });\n  1287→    }\n  1288→\n  1289→    if (translationCandidates.length > 0) {\n  1290→      // Suppress standalone translations and any multi-line joins that embed the translation\n  1291→      // as a suffix or substring (e.g. \"Smażona zielona fasolka GREEN BEANS BORKEUM\" ends with\n  1292→      // the translation; \"Title GREEN BEANS BORKEUM 그린빈\" includes it as a substring).\n  1293→      scoredForThreshold = scored.filter((s) => {\n  1294→        const sLower = s.text.toLowerCase();\n  1295→        return !translationCandidates.some((t) => {\n  1296→          const tLower = t.text.toLowerCase();\n  1297→          return sLower.startsWith(tLower) ||\n  1298→                 sLower.endsWith(\" \" + tLower) ||\n  1299→                 sLower.includes(\" \" + tLower);\n  1300→        });\n  1301→      });\n  1302→    }\n  1303→  }\n  1304→\n  1305→  // Fix 2: If the structural heading was identified as a bilingual translation, reassign it.\n  1306→  // This prevents the translation's ALL_CAPS bonus from inflating the threshold and ensures\n  1307→  // the fallback path in scored also uses the correct heading.\n  1308→  if (\n  1309→    translationCandidates.length > 0 &&\n  1310→    firstStructuralHeading &&\n  1311→    translationCandidates.some((t) => t.text === firstStructuralHeading!.text)\n  1312→  ) {\n  1313→    const nonTranslationStructural = structuralCandidates.filter(\n  1314→      (sc) => !translationCandidates.some((t) => t.text === sc.text)\n  1315→    );\n  1316→    const newHeading = nonTranslationStructural.length > 0\n  1317→      ? nonTranslationStructural.reduce((a, b) => a.rawScore > b.rawScore ? a : b)\n  1318→      : undefined;\n  1319→\n  1320→    // Patch scored array: remove old structural bonus, apply new one\n  1321→    for (const s of scored) {\n  1322→      if (s.text === firstStructuralHeading.text) {\n  1323→        s.score -= 0.10;\n  1324→        s.baseScore -= 0.10;\n  1325→      }\n  1326→      if (newHeading && s.text === newHeading.text) {\n  1327→        s.score += 0.10;\n  1328→        s.baseScore += 0.10;\n  1329→      }\n  1330→    }\n  1331→    // Update reference for downstream prefix-removal logic\n  1332→    firstStructuralHeading = newHeading ?? undefined;\n  1333→  }\n  1334→\n  1335→  // Subtitle suppression: when a short mixed-case title at position 0 is followed by a\n  1336→  // longer mixed-case candidate at position 1-2, the longer one is a subtitle/translation.\n  1337→  // Apply a penalty so the primary title (position 0) wins.\n  1338→  const pos0Primary = scored.find((s) => s.position === 0 && !isAllCaps(s.text) && wordCount(s.text) <= 5);\n  1339→  if (pos0Primary) {\n  1340→    const subtitleCandidates = scored.filter((s) =>\n  1341→      s.position >= 1 && s.position <= 2 &&\n  1342→      !isAllCaps(s.text) &&\n  1343→      wordCount(s.text) > wordCount(pos0Primary.text) + 2\n  1344→    );\n  1345→    for (const sub of subtitleCandidates) {\n  1346→      sub.score -= 0.15;\n  1347→    }\n  1348→  }\n  1349→"}]},"parent_tool_use_id":"toolu_01MuRDLkjqbLufaY3yNmM2NL","session_id":"16a007dd-b5bf-42f6-8e6e-e330e7ca459a","uuid":"b29685de-b8c2-42ae-a19c-45bdcc087235"}
