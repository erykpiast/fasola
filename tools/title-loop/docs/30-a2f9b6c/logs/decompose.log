dients (without diacritics) ───────────────────────────────\n    94→  \"kurczak\", \"wolowina\", \"wieprzowina\", \"cielecina\", \"golonka\",\n    95→  \"losos\", \"dorsz\", \"krewetki\", \"ryz\", \"makaron\", \"chleb\", \"maslo\",\n    96→  \"smietana\", \"ser\", \"czosnek\", \"cebula\", \"pomidor\", \"ziemniak\",\n    97→  \"marchew\", \"seler\", \"pieprz\", \"sol\", \"cukier\", \"maka\", \"jajko\",\n    98→  \"mleko\", \"olej\", \"ocet\", \"cytryna\", \"pomarancza\", \"jablko\", \"jagoda\",\n    99→  \"malina\", \"truskawka\", \"wisnia\", \"brzoskwinia\", \"gruszka\", \"sliwka\",\n   100→  \"winogrono\", \"banan\", \"orzech\", \"migdal\", \"imbir\", \"cynamon\",\n   101→  \"kminek\", \"papryka\", \"kurkuma\", \"oregano\", \"bazylia\", \"tymianek\",\n   102→  \"rozmaryn\", \"pietruszka\", \"kolendra\", \"koperek\", \"mieta\", \"szalwia\",\n   103→  \"szpinak\", \"kapusta\", \"kalafior\", \"szparag\", \"baklazan\", \"cukinia\",\n   104→  \"dynia\", \"ogorek\", \"rzodkiewka\", \"burak\", \"grzyb\", \"awokado\",\n   105→  \"oliwka\", \"fasola\", \"soczewica\", \"ciecierzyca\", \"kasza\", \"owies\",\n   106→  \"jeczmien\", \"pszenica\", \"zyto\",\n   107→\n   108→  // Polish bread varieties\n   109→  \"pszenny\", \"razowy\", \"zytni\", \"wieloziarnisty\", \"tostowy\",\n   110→\n   111→  // Polish cooking terms (without diacritics)\n   112→  \"piec\", \"smazyc\", \"grillowac\", \"gotowac\", \"dusic\", \"blanszowac\",\n   113→  \"kroic\", \"siekac\", \"marynowac\", \"przyprawiac\", \"karmelizowac\",\n   114→  \"podsmaz\", \"zapiekac\", \"gotowac\", \"dusic\", \"wedzic\", \"kisic\",\n   115→\n   116→  // Polish dishes\n   117→  \"bigos\", \"zurek\", \"barszcz\", \"rosol\", \"kotlet\", \"schabowy\",\n   118→  \"golabki\", \"placki\", \"nalesniki\", \"piernik\", \"sernik\", \"makowiec\",\n   119→  \"babka\", \"chalka\", \"rogal\", \"paczek\", \"faworki\", \"kluski\",\n   120→  \"kopytka\", \"pyzy\", \"uszka\", \"gzik\", \"flaczki\", \"zrazy\", \"gulasz\",\n   121→  \"leczo