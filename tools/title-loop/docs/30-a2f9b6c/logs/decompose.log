6→  if (words.length < 4) return false;  // Instructions are multi-word sentences\n   367→  if (COOKING_INSTRUCTION_STARTS.test(text.trim())) return true;\n   368→  if (POLISH_COOKING_INSTRUCTION_STARTS.test(text.trim())) return true;\n   369→  return false;\n   370→}\n   371→\n   372→/**\n   373→ * A line starting with a lowercase letter and having 4+ words is prose continuation.\n   374→ * Recipe titles are capitalized (Title Case or ALL CAPS), so a lowercase-start line\n   375→ * is a strong signal for mid-recipe body text.\n   376→ */\n   377→function isBodyProse(line: string): boolean {\n   378→  return /^[a-ząćęłńóśźż]/.test(line) && wordCount(line) >= 4;\n   379→}\n   380→\n   381→/**\n   382→ * Detect pages where the OCR capture starts mid-recipe with no title present.\n   383→ * Returns true if the first 3 non-empty lines (after `startFrom`) are all ingredients,\n   384→ * cooking instructions, or body prose continuation text.\n   385→ */\n   386→function isTitleAbsentPage(lines: Array<string>, startFrom: number = 0): boolean {\n   387→  const relevantLines = startFrom > 0 ? lines.slice(startFrom) : lines;\n   388→  const nonEmptyLines = relevantLines.map(l => l.trim()).filter(l => l.length > 0);\n   389→\n   390→  if (nonEmptyLines.length < 3) return false;\n   391→\n   392→  const first3 = nonEmptyLines.slice(0, 3);\n   393→\n   394→  return first3.every(line =>\n   395→    looksLikeIngredient(line) ||\n   396→    looksLikeCookingInstruction(line) ||\n   397→    isBodyProse(line)\n   398→  );\n   399→}\n   400→\n   401→function passesHardFilters(text: string): boolean {\n   402→  if (text.length < 3 || text.length > 80) return false;\n   403→  if (looksLikeIngredient(text)) return false;\n   404→  if (startsWithNumber(text)) return false;\n   405→  if (looksLikeMetadata(text)) return false;\n   406→  if (isLikelyGarbled(text)) return false;\n   407→  if (looksLikeCookingInstruction(text)) return false;\n   408→  // Apply lightweight OCR normalization before a second instruction check\n   409→  // so that \"Podaw4ć\" is recognized as \"Podawać\" (cooking instruction).\n   410→  // Only 4→a for now — the specific OCR artifact causing failures.\n   411→  // Uses same letter-adjacent guard logic as applyBlindOcrRepairToken.\n   412→  const ocrNormForInstruction = text\n   413→    .replace(/(?<=[a-zà-ż])4/g, \"a\")\n   414→    .replace(/4(?=[a-zà-ż])/g, \"a\");\n   415→  if (ocrNormForInstruction !== text && looksLikeCookingInstruction(ocrNormForInstruction)) return false;\n   416→  // Pipe-separated lines are book category/chapter headers, not recipe titles\n   417→  if (text.includes(\" | \")) return false;\n   418→  // Trailing page number (e.g. \"VEGETABLE SIDES                         145\")\n   419→  if (/\\s{3,}\\d{1,4}\\s*$/.test(text)) return false;\n   420→  // Slash-separated breadcrumbs (e.g., \"/ Jesien / Zupy\") are navigation, not titles\n   421→  // Only filter when 2+ slashes are present — single-slash lines like\n   422→  // \"TITLE / SUBTITLE\" are legitimate continuation-merged titles\n   423→  if ((text.match(/\\//g) || []).length >= 2) return false;\n   424→  // Bullet-list items (ingredients or instruction steps) are never titles\n   425→  if (/^\\s*[-•*]\\s/.test(text)) return false;\n   426→  // \"For the sauce:\", \"For the filling:\" etc. are sub-section headers\n   427→  if (/^For the\\s+/i.test(text) && /:\\s*$/.test(text)) return false;\n   428→  // Lines ending with \":\" are recipe sub-section headers, not titles.\n   429→  // Exception: compound titles using \" : \" as a title separator (e.g. \"LEMON CURD : LEMON CURD WITH THYME\").\n   430→  if (/:\\s*$/.test(text.trim()) && !/ : /.test(text)) return false;\n   431→  // Page references are navigation markers, not recipe titles\n   432→  if (/^Page\\s+\\d+/i.test(text.trim())) return false;\n   433→  if (/^Strona\\s+\\d+/i.test(text.trim())) return false;\n   434→  // Corrupted spillover annotations from synthetic multi-page OCR\n   435→  if (/^\\[CORRUPTED\\s+SPILLOVER/i.test(text.trim())) return false;\n   436→  // Parenthetical OCR annotation lines describing corruption artifacts\n   437→  if (/^\\(OCR\\b/i.test(text.trim())) return false;\n   438→  if (/^\\(.*\\bcorruption\\b/i.test(text.trim())) return false;\n   439→  // Square-bracket category tags (e.g., \"[CLASSIC FALL SOUPS]\")\n   440→  if (/^\\[.*\\]$/.test(text.trim())) return false;\n   441→  // Known recipe section labels are structural headers, not titles\n   442→  if (isSectionLabel(text)) return false;\n   443→  // Single-word non-title fragments\n   444→  const words = text.trim().split(/\\s+/);\n   445→  if (words.length === 1 && NON_TITLE_WORDS.has(text.trim().toLowerCase())) return false;\n   446→  // Lines with ≥8 words are almost certainly body text, not titles.\n   447→  // Exception: multi-title compounds with \" + \", \" : \", or \" & \" separators are allowed.\n   448→  if (words.length >= 8 && !/ [+:&/] /.test(text)) return false;\n   449→  return true;"}]},"parent_tool_use_id":"toolu_01MuRDLkjqbLufaY3yNmM2NL","session_id":"16a007dd-b5bf-42f6-8e6e-e330e7ca459a","uuid":"504565b6-332a-464b-97e3-d37645beb78c"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XrSdW8J4JeNkDUp6JD5Kzi","type":"tool_result","content":"   630→      if (j > ci + 1) {\n   631→        capsCoalesced.push({ text: merged, index: startIndex });\n   632→        ci = j;\n   633→        continue;\n   634→      }\n   635→    }\n   636→    capsCoalesced.push(line);\n   637→    ci++;\n   638→  }\n   639→\n   640→  // Pre-merge continuation lines: a line starting with /&+:( is never a standalone title.\n   641→  // Merge it into the preceding line so the complete title enters the pool as a single candidate,\n   642→  // avoiding the fragile chain of conditions required by the downstream join survival logic.\n   643→  // Limitation: only one continuation line per preceding line is merged. Titles split across\n   644→  // three or more lines with continuation tokens (rare in practice) are not handled here —\n   645→  // the downstream 2-line and 3-line join candidates cover those cases instead.\n   646→  const mergedLines: Array<{ text: string; index: number }> = [];\n   647→  for (let i = 0; i < capsCoalesced.length; i++) {\n   648→    const line = capsCoalesced[i];\n   649→    if (i + 1 < capsCoalesced.length) {\n   650→      const nextText = capsCoalesced[i + 1].text;\n   651→      if (/^[/&+:(]/.test(nextText)) {\n   652→        mergedLines.push({ text: `${line.text} ${nextText}`, index: line.index });\n   653→        i++;\n   654→        continue;\n   655→      }\n   656→    }\n   657→    mergedLines.push(line);\n   658→  }\n   659→\n   660→  const candidates: Array<{ text: string; position: number; origin: CandidateOrigin }> = [];\n   661→  const seen = new Set<string>();\n   662→\n   663→  // Build a set of positions to skip: short ALL_CAPS lines immediately following metadata\n   664→  const metadataContinuationPositions = new Set<number>();\n   665→  for (let i = 0; i < mergedLines.length - 1; i++) {\n   666→    if (looksLikeMetadata(mergedLines[i].text)) {\n   667→      const next = mergedLines[i + 1];\n   668→      if (isAllCaps(next.text) && wordCount(next.text) <= 2 && next.text.length <= 15) {\n   669→        metadataContinuationPositions.add(next.index);\n   670→      }\n   671→    }\n   672→  }\n   673→\n   674→  for (let i = 0; i < mergedLines.length; i++) {\n   675→    const line = mergedLines[i];\n   676→\n   677→    // Skip metadata continuation fragments\n   678→    if (metadataContinuationPositions.has(line.index)) continue;\n   679→\n   680→    // Single line — strip page-number prefixes and parenthetical glosses before scoring\n   681→    const singleText = repairOcrText(stripParentheticalGloss(stripTrailingPageRef(stripPageNumber(line.text))));\n   682→    if (passesHardFilters(singleText)) {\n   683→      const norm = singleText.toLowerCase();\n   684→      if (!seen.has(norm)) {\n   685→        seen.add(norm);\n   686→        candidates.push({ text: singleText, position: line.index, origin: \"single\" });\n   687→      }\n   688→    }\n   689→\n   690→    // Blind OCR repair for early-position candidates: when the original text\n   691→    // has OCR artifacts or erratic casing and is in the first few lines,\n   692→    // generate additional candidates with blind digit→letter repair and/or\n   693→    // casing normalization. This gives the embedding scorer clean versions\n   694→    // even when dictionary repair misses.\n   695→    if (line.index <= 5) {\n   696→      const hasOcrArtifact = OCR_ARTIFACT_PATTERN.test(line.text);\n   697→      const lineHasErraticCasing = hasErraticCasing(line.text);\n   698→      if (hasOcrArtifact || lineHasErraticCasing) {\n   699→        let repairable = singleText;\n   700→        if (lineHasErraticCasing) {\n   701→          repairable = normalizeErraticCasing(repairable);\n   702→          if (repairable !== singleText && passesHardFilters(repairable)) {\n   703→            const norm = repairable.toLowerCase();\n   704→            if (!seen.has(norm)) {\n   705→              seen.add(norm);\n   706→              candidates.push({ text: repairable, position: line.index, origin: \"single\" });\n   707→            }\n   708→          }\n   709→        }\n   710→        const variants = generateBlindOcrVariants(repairable);\n   711→        for (const variant of variants) {\n   712→          if (passesHardFilters(variant)) {\n   713→            const norm = variant.toLowerCase();\n   714→            if (!seen.has(norm)) {\n   715→              seen.add(norm);\n   716→              candidates.push({ text: variant, position: line.index, origin: \"single\" });\n   717→            }\n   718→          }\n   719→        }\n   720→      }\n   721→    }\n   722→\n   723→    // 2-line join — skip if first line is a section label AND join would be ≤2 words\n   724→    // (a section label followed by modifiers is likely a recipe title, not a category header)\n   725→    if (i + 1 < mergedLines.length) {\n   726→      const joined2 = repairOcrText(`${line.text} ${mergedLines[i + 1].text}`);\n   727→      const shouldBlock2 = isSectionLabel(line.text) &&\n   728→        (wordCount(joined2) <= 2 || isAlwaysBlockJoinLabel(line.text));\n   729→      if (!shouldBlock2 && passesHardFilters(joined2)) {\n   730→        const norm = joined2.toLowerCase();\n   731→        if (!seen.has(norm)) {\n   732→          seen.add(norm);\n   733→          candidates.push({ text: joined2, position: line.index, origin: \"2-line\" });\n   734→        }\n   735→      }\n   736→    }\n   737→\n   738→    // 3-line join — skip if first line is a section label AND join would be ≤2 words\n   739→    if (i + 2 < mergedLines.length) {\n   740→      const joined3 = repairOcrText(`${line.text} ${mergedLines[i + 1].text} ${mergedLines[i + 2].text}`);\n   741→      const shouldBlock3 = isSectionLabel(line.text) &&\n   742→        (wordCount(joined3) <= 2 || isAlwaysBlockJoinLabel(line.text));\n   743→      if (!shouldBlock3 && passesHardFilters(joined3)) {\n   744→        const norm = joined3.toLowerCase();\n   745→        if (!seen.has(norm)) {\n   746→          seen.add(norm);\n   747→          candidates.push({ text: joined3, position: line.index, origin: \"3-line\" });\n   748→        }\n   749→      }\n   750→    }\n   751→  }\n   752→\n   753→  // Pre-filter to 25 before embedding calls: prefer ALL_CAPS and short candidates.\n   754→  // Position-based scoring handles final ranking.\n   755→  if (candidates.length > 25) {\n   756→    const prioritized = candidates.slice().sort((a, b) => {\n   757→      const aAllCaps = isAllCaps(a.text) ? 0 : 1;\n   758→      const bAllCaps = isAllCaps(b.text) ? 0 : 1;\n   759→      if (aAllCaps !== bAllCaps) return aAllCaps - bAllCaps;\n   760→      const aShort = wordCount(a.text) <= 5 ? 0 : 1;\n   761→      const bShort = wordCount(b.text) <= 5 ? 0 : 1;\n   762→      return aShort - bShort;\n   763→    });\n   764→    return { candidates: prioritized.slice(0, 25), burstEnd: nonEmptyLines[burstEnd]?.index ?? lines.length };\n   765→  }\n   766→\n   767→  return { candidates, burstEnd: nonEmptyLines[burstEnd]?.index ?? lines.length };\n   768→}\n   769→\n   770→/**\n   771→ * Convert an ALL_CAPS string to Title Case, using a small-words list.\n   772→ * Preserves Polish/French diacritics.\n   773→ */\n   774→function toTitleCase(text: string): string {\n   775→  const smallWords = new Set([\n   776→    \"a\", \"an\", \"the\", \"and\", \"but\", \"or\", \"for\", \"nor\",\n   777→    \"in\", \"on\", \"at\", \"to\", \"of\", \"by\", \"with\", \"from\",\n   778→    \"z\", \"w\", \"i\", \"ze\", \"na\", \"do\", \"od\", \"za\", \"po\",\n   779→  ]);"}]},"parent_tool_use_id":"toolu_01MuRDLkjqbLufaY3yNmM2NL","session_id":"16a007dd-b5bf-42f6-8e6e-e330e7ca459a","uuid":"4c7876e1-0180-42a3-91fb-3faaa1da04ee"}
