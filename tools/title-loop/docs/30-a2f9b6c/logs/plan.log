{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015r5Mm5Qoy8dLXH1LB5wuYu","type":"tool_result","content":"   250→\n   251→  if (contentWords.length === 0) {\n   252→    return true; // No checkable words — pass through\n   253→  }\n   254→\n   255→  let corroboratedCount = 0;\n   256→  for (const word of contentWords) {\n   257→    for (let i = startLine; i < allLines.length; i++) {\n   258→      if (i === position) continue;\n   259→      if (allLines[i].toUpperCase().includes(word)) {\n   260→        corroboratedCount++;\n   261→        break;\n   262→      }\n   263→    }\n   264→  }\n   265→\n   266→  const score = corroboratedCount / contentWords.length;\n   267→  const threshold = contentWords.length <= 3 ? 1.0 : 0.67;\n   268→  return score >= threshold;\n   269→}\n   270→\n   271→function isLikelyGarbled(text: string): boolean {\n   272→  const letters = text.replace(/[^a-zA-Z]/g, \"\");\n   273→  if (letters.length < 2) return true;\n   274→\n   275→  // Pipe embedded in words = OCR artifact (e.g., \"Sp|aszcz\", \"pa|ką\")\n   276→  if (/[a-zA-ZÀ-ÿа-яА-Я]\\|[a-zA-ZÀ-ÿа-яА-Я]/.test(text)) return true;\n   277→\n   278→  // Mixed Latin + Cyrillic = OCR corruption\n   279→  if (/[а-яА-ЯёЁіІїЇєЄґҐ]/.test(text) && /[a-zA-Z]/.test(text)) return true;\n   280→\n   281→  // Check vowel ratio — English/Polish text typically has 30–50% vowels\n   282→  const vowels = letters.replace(/[^aeiouAEIOUyYąęóĄĘÓ]/g, \"\").length;\n   283→  const vowelRatio = vowels / letters.length;\n   284→  if (vowelRatio < 0.10 || vowelRatio > 0.85) return true;\n   285→\n   286→  // Single orphaned word ≤3 letters that isn't a common word\n   287→  const words = text.trim().split(/\\s+/);\n   288→  const COMMON_SHORT = new Set([\n   289→    \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"had\", \"her\",\n   290→    \"was\", \"one\", \"our\", \"out\", \"are\", \"has\", \"his\", \"how\", \"its\", \"may\",\n   291→    \"new\", \"now\", \"old\", \"see\", \"way\", \"who\", \"did\", \"get\", \"let\", \"say\",\n   292→    \"she\", \"too\", \"use\",\n   293→  ]);\n   294→  // Count all Unicode letters (not just ASCII) so Polish words like \"Żur\" (3 letters) pass\n   295→  const unicodeLetters = text.trim().replace(/[^a-zA-ZąćęłńóśźżĄĆĘŁŃÓŚŹŻ]/g, \"\");\n   296→  if (words.length === 1 && unicodeLetters.length <= 3 && !COMMON_SHORT.has(text.trim().toLowerCase())) {\n   297→    return true;\n   298→  }\n   299→\n   300→  // Single word with internal lowercase→uppercase transition — OCR noise (e.g., \"UuIw\", \"aBC\")\n   301→  // No recipe title uses this pattern as a standalone single-word candidate.\n   302→  if (words.length === 1 && /[a-z][A-Z]/.test(text.trim()) && !/^(Mc|Mac)[A-Z]/.test(text.trim())) {\n   303→    return true;\n   304→  }\n   305→\n   306→  // Recipe titles never start with a lowercase letter\n   307→  if (/^[a-z]/.test(text.trim())) {\n   308→    return true;\n   309→  }\n   310→\n   311→  // Mid-text sentence boundary (\". \" followed by a letter) — body text fragment spliced from multiple sentences\n   312→  const trimmed = text.trim();\n   313→  if (/\\.\\s+[a-zA-Z]/.test(trimmed) && !trimmed.endsWith(\")\")) {\n   314→    return true;\n   315→  }\n   316→\n   317→  // Multi-word candidate containing a garbled OCR fragment: a short lowercase word that isn't a known short word\n   318→  if (words.length >= 2) {\n   319→    const commonShort2 = new Set([\n   320→      \"a\", \"i\", \"of\", \"or\", \"to\", \"in\", \"on\", \"is\", \"it\", \"an\",\n   321→      \"as\", \"at\", \"by\", \"do\", \"go\", \"if\", \"no\", \"so\", \"up\", \"we\",\n   322→      \"w\", \"z\",   // Polish prepositions (basic)\n   323→      \"ze\", \"bo\", \"na\", \"ni\", \"po\", \"ku\", \"od\", \"za\", \"co\",  // Polish prepositions (extended)\n   324→    ]);\n   325→    const hasGarbledWord = words.some(\n   326→      (w) =>\n   327→        /^[a-z]/.test(w) &&\n   328→        w.replace(/[^a-z]/g, \"\").length 