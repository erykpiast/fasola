{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01JxcovFKGnpiYxHrbhshDdo","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01PSeL6NFUjT1YbpmCavcyyS","name":"Bash","input":{"command":"cat > /tmp/debug-title4.ts << 'SCRIPT'\nimport { readFileSync } from \"fs\";\n\n// Re-implement key functions from title-extractor to debug\nconst FOOD_DICTIONARY_MODULE = require(\"@/lib/text-classifier/food-dictionary\");\nconst FOOD_DICTIONARY: Set<string> = FOOD_DICTIONARY_MODULE.FOOD_DICTIONARY;\n\nconst OCR_SUBSTITUTIONS: Record<string, string[]> = {\n  \"0\": [\"o\"], \"1\": [\"i\", \"l\"], \"4\": [\"a\"], \"5\": [\"s\"],\n  \"¡\": [\"i\"], \"í\": [\"i\", \"l\"], \"€\": [\"e\"],\n};\nconst OCR_ARTIFACT_PATTERN = /[0-9¡Íí€]/;\n\nfunction generateSubstitutions(base: string, positions: Array<{index: number; replacements: string[]}>, posIdx: number): string[] {\n  if (posIdx >= positions.length) return [base];\n  const { index, replacements } = positions[posIdx];\n  const results: string[] = [];\n  for (const replacement of replacements) {\n    const variant = base.slice(0, index) + replacement + base.slice(index + 1);\n    results.push(...generateSubstitutions(variant, positions, posIdx + 1));\n  }\n  return results;\n}\n\nfunction repairOcrWord(word: string): string {\n  if (!OCR_ARTIFACT_PATTERN.test(word)) return word;\n  const lower = word.toLowerCase();\n  const positions: Array<{index: number; replacements: string[]}> = [];\n  for (let i = 0; i < lower.length; i++) {\n    const replacements = OCR_SUBSTITUTIONS[lower[i]];\n    if (replacements) positions.push({ index: i, replacements });\n  }\n  if (positions.length === 0 || positions.length > 8) return word;\n  const candidates = generateSubstitutions(lower, positions, 0);\n  for (const candidate of candidates) {\n    if (FOOD_DICTIONARY.has(candidate)) {\n      if (word === word.toUpperCase()) return candidate.toUpperCase();\n      if (word[0] === word[0].toUpperCase()) return candidate[0].toUpperCase() + candidate.slice(1);\n      return candidate;\n    }\n  }\n  return word;\n}\n\nfunction repairOcrText(text: string): string {\n  return text.split(/\\s+/).map((word) => {\n    const match = word.match(/^([^a-zA-Z0-9À-ÿ]*)(.*?)([^a-zA-Z0-9À-ÿ]*)$/);\n    if (!match) return word;\n    const [, prefix, core, suffix] = match;\n    if (!core) return word;\n    const repaired = repairOcrWord(core);\n    return prefix + repaired + suffix;\n  }).join(\" \");\n}\n\n// Test\nconst raw = \"Bra1sed Cod w1th Wh1te W1ne\";\nconsole.log(\"Raw:\", raw);\nconst repaired = repairOcrText(raw);\nconsole.log(\"Repaired:\", repaired);\n\n// Test each word individually\nfor (const word of raw.split(/\\s+/)) {\n  console.log(`  ${word} → ${repairOcrWord(word)}`);\n}\nSCRIPT\nnpx tsx /tmp/debug-title4.ts 2>&1","description":"Debug OCR repair word by word","timeout":30000},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":538,"cache_read_input_tokens":103655,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":538},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"8a56c14a-0bc6-452a-98e5-f30796680f9b","uuid":"fa669288-c926-4292-886b-1584768bce5c"}
