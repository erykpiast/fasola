{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AAf3PtpG8RbBnW5rjNhjRb","type":"tool_result","content":"   100→\n   101→function startsWithNumber(line: string): boolean {\n   102→  // Match lines starting with a digit or Unicode fraction, optionally preceded by bullet\n   103→  return /^\\s*(?:[-•*]\\s*)?[\\d½⅓⅔¼¾⅕⅖⅗⅘⅙⅚⅛⅜⅝⅞]/.test(line);\n   104→}\n   105→\n   106→function stripDiacritics(text: string): string {\n   107→  return text.normalize(\"NFKD\").replace(/[\\u0300-\\u036f]/g, \"\");\n   108→}\n   109→\n   110→/**\n   111→ * Known recipe section labels — these are structural headers, not recipe titles.\n   112→ * Matched case-insensitively after trimming, stripping trailing punctuation, and stripping diacritics.\n   113→ * Polish entries are stored without diacritics for OCR resilience (e.g. \"SKLADNIKI\" matches \"składniki\").\n   114→ */\n   115→const SECTION_LABELS = new Set([\n   116→  // English\n   117→  \"ingredients\", \"directions\", \"instructions\", \"method\", \"preparation\",\n   118→  \"steps\", \"notes\", \"tip\", \"tips\", \"variations\", \"variation\",\n   119→  \"garnish\", \"topping\", \"toppings\", \"frosting\", \"filling\",\n   120→  \"serving suggestion\", \"serving suggestions\", \"serving\",\n   121→  \"glaze\", \"for the sauce\", \"for the filling\", \"for the dough\",\n   122→  \"for the topping\", \"for the glaze\", \"for the pasta dough\",\n   123→  \"for the pasta\", \"for the crust\",\n   124→  // Polish — recipe section labels (stored without diacritics for OCR resilience)\n   125→  \"skladniki\", \"przygotowanie\", \"sposob przygotowania\", \"sposob wykonania\",\n   126→  \"wykonanie\", \"wskazowki\", \"podpowiedz\", \"warianty\",\n   127→  \"sos\", \"nadzienie\", \"polewa\", \"lukier\", \"ciasto\",  // ciasto = dough/pastry base (recipe-internal section AND chapter label)\n   128→  \"instrukcje\",       // instructions\n   129→  \"uwagi\",            // notes/remarks\n   130→  \"notatki\",          // notes\n   131→  \"podawanie\",        // serving\n   132→  \"przechowywanie\",   // storage\n   133→  // Polish — recipe-book chapter/category labels (food groups, meal types)\n   134→  \"warzywa\",          // vegetables\n   135→  \"mieso\",            // meat (mięso)\n   136→  \"miesa\",            // meats (mięsa)\n   137→  \"ryby\",             // fish\n   138→  \"owoce morza\",      // seafood\n   139→  \"zupy\",             // soups\n   140→  \"salatki\",          // salads (sałatki)\n   141→  \"desery\",           // desserts\n   142→  \"napoje\",           // drinks\n   143→  \"pieczywo\",         // bread/baked goods\n   144→  \"przekaski\",        // appetizers/snacks\n   145→  \"sniadania\",        // breakfasts (śniadania)\n   146→  \"obiady\",           // dinners/lunches\n   147→  \"kolacje\",          // suppers\n   148→  \"makarony\",         // pasta dishes\n   149→  \"kasza\",            // groats/grains\n   150→  \"kasze\",            // groats/grains (plural)\n   151→  \"dania glowne\",     // main courses (dania główne)\n   152→  \"przystawki\",       // starters\n   153→  \"dodatki\",          // side dishes\n   154→  \"przetwory\",        // preserves\n   155→  \"wypieki\",          // baked goods\n   156→  \"ciasta\",           // cakes (plural)\n   157→  \"ciastka\",          // cookies\n   158→  \"torty\",            // layer cakes\n   159→  // \"placki\" removed — it commonly starts recipe titles like \"Placki Ziemniaczane\", \"Placki Żółte z Kukurydzą\"\n   160→  \"koktajle\",         // cocktails/smoothies\n   161→  // English — recipe-book chapter/category labels\n   162→  \"vegetables\", \"seafood\", \"fish\", \"soups\", \"salads\", \"desserts\",\n   163→  \"appetizers\", \"breads\", \"breakfast\", \"pasta\", \"grains\",\n   164→  \"main courses\", \"side dishes\", \"preserves\", \"baked goods\",\n   165→  \"fish & seafood\", \"soups & broths\", \"desserts & baked goods\",\n   166→  \"meats\", \"poultry\", \"game\",\n   167→]);\n   168→\n   169→/**\n   170→ * Subset of SECTION_LABELS that are food-group/chapter labels (not structural process labels).\n   171→ * These may appear as the last word of a compound recipe title (e.g. \"LEMON HERB ROASTED VEGETABLES\").\n   172→ */\n   173→const CATEGORY_SECTION_LABELS = new Set([\n   174→  // English food categories\n   175→  \"vegetables\", \"seafood\", \"fish\", \"soups\", \"salads\", \"desserts\",\n   176→  \"appetizers\", \"breads\", \"breakfast\", \"pasta\", \"grains\",\n   177→  \"meats\", \"poultry\", \"game\",\n   178→  // Polish food categories\n   179→  \"warzywa\", \"mieso\", \"miesa\", \"ryby\", \"zupy\", \"salatki\", \"desery\",\n   180→  \"napoje\", \"pieczywo\", \"przekaski\", \"sniadania\", \"obiady\", \"kolacje\",\n   181→  \"makarony\", \"kasza\", \"kasze\", \"przystawki\", \"dodatki\", \"wypieki\",\n   182→  \"ciasta\", \"ciastka\", \"torty\", \"koktajle\",\n   183→]);\n   184→\n   185→function isCategorySectionLabel(text: string): boolean {\n   186→  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n   187→  return CATEGORY_SECTION_LABELS.has(normalized);\n   188→}\n   189→\n   190→function isSectionLabel(text: string): boolean {\n   191→  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n   192→  if (SECTION_LABELS.has(normalized)) return true;\n   193→  // OCR variant: leading \"l\" may be OCR-corrupted \"I\" (e.g. \"lngredients\" → \"ingredients\")\n   194→  const ocrNormalized = normalized.replace(/^l/, \"i\");\n   195→  if (ocrNormalized !== normalized && SECTION_LABELS.has(ocrNormalized)) return true;\n   196→  return false;\n   197→}\n   198→\n   199→/**\n   200→ * Recipe-internal section labels that should ALWAYS block multi-line joins,\n   201→ * even when the combined word count is ≥ 3.\n   202→ * Category labels (\"zupy\", \"placki\", etc.) are NOT in this set — they can\n   203→ * legitimately start a multi-word recipe title like \"Zupy Zimowe Warzywne\".\n   204→ */\n   205→const ALWAYS_BLOCK_JOIN_LABELS = new Set([\n   206→  \"ingredients\", \"directions\", \"instructions\", \"method\", \"preparation\",\n   207→  \"steps\", \"notes\", \"tip\", \"tips\", \"variations\", \"variation\",\n   208→  \"garnish\", \"topping\", \"toppings\", \"frosting\", \"filling\",\n   209→  \"serving suggestion\", \"serving suggestions\", \"serving\",\n   210→  \"glaze\", \"instrukcje\", \"uwagi\", \"notatki\", \"podawanie\", \"przechowywanie\",\n   211→  \"skladniki\", \"przygotowanie\", \"sposob przygotowania\", \"sposob wykonania\",\n   212→  \"wykonanie\", \"wskazowki\", \"podpowiedz\", \"warianty\",\n   213→  \"sos\", \"nadzienie\", \"polewa\", \"lukier\", \"ciasto\",\n   214→]);\n   215→\n   216→function isAlwaysBlockJoinLabel(text: string): boolean {\n   217→  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n   218→  return ALWAYS_BLOCK_JOIN_LABELS.has(normalized);\n   219→}\n   220→\n   221→function isAllCaps(line: string): boolean {\n   222→  const letters = line.replace(/[^a-zA-Z]/g, \"\");\n   223→  return letters.length > 0 && letters === letters.toUpperCase();\n   224→}\n   225→\n   226→function looksLikeMetadata(text: string): boolean {\n   227→  return METADATA_PATTERNS.some((pattern) => pattern.test(text.trim()));\n   228→}\n   229→\n   230→/** Content words are ≥3 alpha characters after stripping punctuation. */\n   231→function extractContentWords(text: string): string[] {\n   232→  return text\n   233→    .split(/\\s+/)\n   234→    .filter((w) => w.replace(/[^a-zA-ZÀ-ÿ]/g, \"\").length >= 3)\n   235→    .map((w) => w.toUpperCase());\n   236→}\n   237→\n   238→/**\n   239→ * Returns true if the candidate's vocabulary is sufficiently supported by the rest of\n   240→ * the document. Short candidates (≤3 content words) require 100% corroboration;\n   241→ * longer candidates require ≥67%. Used to detect orphaned OCR artifacts in multi-title pages.\n   242→ */\n   243→function passesCorroboration(\n   244→  text: string,\n   245→  position: number,\n   246→  allLines: string[],\n   247→  startLine: number = 0 // Only check corroboration against lines from this index onward\n   248→): boolean {\n   249→  const contentWords = extractContentWords(text);"}]},"parent_tool_use_id":null,"session_id":"8a56c14a-0bc6-452a-98e5-f30796680f9b","uuid":"d6aec4c1-b784-4421-9815-747f5079b61b","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/title-extractor.ts","content":"\nfunction startsWithNumber(line: string): boolean {\n  // Match lines starting with a digit or Unicode fraction, optionally preceded by bullet\n  return /^\\s*(?:[-•*]\\s*)?[\\d½⅓⅔¼¾⅕⅖⅗⅘⅙⅚⅛⅜⅝⅞]/.test(line);\n}\n\nfunction stripDiacritics(text: string): string {\n  return text.normalize(\"NFKD\").replace(/[\\u0300-\\u036f]/g, \"\");\n}\n\n/**\n * Known recipe section labels — these are structural headers, not recipe titles.\n * Matched case-insensitively after trimming, stripping trailing punctuation, and stripping diacritics.\n * Polish entries are stored without diacritics for OCR resilience (e.g. \"SKLADNIKI\" matches \"składniki\").\n */\nconst SECTION_LABELS = new Set([\n  // English\n  \"ingredients\", \"directions\", \"instructions\", \"method\", \"preparation\",\n  \"steps\", \"notes\", \"tip\", \"tips\", \"variations\", \"variation\",\n  \"garnish\", \"topping\", \"toppings\", \"frosting\", \"filling\",\n  \"serving suggestion\", \"serving suggestions\", \"serving\",\n  \"glaze\", \"for the sauce\", \"for the filling\", \"for the dough\",\n  \"for the topping\", \"for the glaze\", \"for the pasta dough\",\n  \"for the pasta\", \"for the crust\",\n  // Polish — recipe section labels (stored without diacritics for OCR resilience)\n  \"skladniki\", \"przygotowanie\", \"sposob przygotowania\", \"sposob wykonania\",\n  \"wykonanie\", \"wskazowki\", \"podpowiedz\", \"warianty\",\n  \"sos\", \"nadzienie\", \"polewa\", \"lukier\", \"ciasto\",  // ciasto = dough/pastry base (recipe-internal section AND chapter label)\n  \"instrukcje\",       // instructions\n  \"uwagi\",            // notes/remarks\n  \"notatki\",          // notes\n  \"podawanie\",        // serving\n  \"przechowywanie\",   // storage\n  // Polish — recipe-book chapter/category labels (food groups, meal types)\n  \"warzywa\",          // vegetables\n  \"mieso\",            // meat (mięso)\n  \"miesa\",            // meats (mięsa)\n  \"ryby\",             // fish\n  \"owoce morza\",      // seafood\n  \"zupy\",             // soups\n  \"salatki\",          // salads (sałatki)\n  \"desery\",           // desserts\n  \"napoje\",           // drinks\n  \"pieczywo\",         // bread/baked goods\n  \"przekaski\",        // appetizers/snacks\n  \"sniadania\",        // breakfasts (śniadania)\n  \"obiady\",           // dinners/lunches\n  \"kolacje\",          // suppers\n  \"makarony\",         // pasta dishes\n  \"kasza\",            // groats/grains\n  \"kasze\",            // groats/grains (plural)\n  \"dania glowne\",     // main courses (dania główne)\n  \"przystawki\",       // starters\n  \"dodatki\",          // side dishes\n  \"przetwory\",        // preserves\n  \"wypieki\",          // baked goods\n  \"ciasta\",           // cakes (plural)\n  \"ciastka\",          // cookies\n  \"torty\",            // layer cakes\n  // \"placki\" removed — it commonly starts recipe titles like \"Placki Ziemniaczane\", \"Placki Żółte z Kukurydzą\"\n  \"koktajle\",         // cocktails/smoothies\n  // English — recipe-book chapter/category labels\n  \"vegetables\", \"seafood\", \"fish\", \"soups\", \"salads\", \"desserts\",\n  \"appetizers\", \"breads\", \"breakfast\", \"pasta\", \"grains\",\n  \"main courses\", \"side dishes\", \"preserves\", \"baked goods\",\n  \"fish & seafood\", \"soups & broths\", \"desserts & baked goods\",\n  \"meats\", \"poultry\", \"game\",\n]);\n\n/**\n * Subset of SECTION_LABELS that are food-group/chapter labels (not structural process labels).\n * These may appear as the last word of a compound recipe title (e.g. \"LEMON HERB ROASTED VEGETABLES\").\n */\nconst CATEGORY_SECTION_LABELS = new Set([\n  // English food categories\n  \"vegetables\", \"seafood\", \"fish\", \"soups\", \"salads\", \"desserts\",\n  \"appetizers\", \"breads\", \"breakfast\", \"pasta\", \"grains\",\n  \"meats\", \"poultry\", \"game\",\n  // Polish food categories\n  \"warzywa\", \"mieso\", \"miesa\", \"ryby\", \"zupy\", \"salatki\", \"desery\",\n  \"napoje\", \"pieczywo\", \"przekaski\", \"sniadania\", \"obiady\", \"kolacje\",\n  \"makarony\", \"kasza\", \"kasze\", \"przystawki\", \"dodatki\", \"wypieki\",\n  \"ciasta\", \"ciastka\", \"torty\", \"koktajle\",\n]);\n\nfunction isCategorySectionLabel(text: string): boolean {\n  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n  return CATEGORY_SECTION_LABELS.has(normalized);\n}\n\nfunction isSectionLabel(text: string): boolean {\n  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n  if (SECTION_LABELS.has(normalized)) return true;\n  // OCR variant: leading \"l\" may be OCR-corrupted \"I\" (e.g. \"lngredients\" → \"ingredients\")\n  const ocrNormalized = normalized.replace(/^l/, \"i\");\n  if (ocrNormalized !== normalized && SECTION_LABELS.has(ocrNormalized)) return true;\n  return false;\n}\n\n/**\n * Recipe-internal section labels that should ALWAYS block multi-line joins,\n * even when the combined word count is ≥ 3.\n * Category labels (\"zupy\", \"placki\", etc.) are NOT in this set — they can\n * legitimately start a multi-word recipe title like \"Zupy Zimowe Warzywne\".\n */\nconst ALWAYS_BLOCK_JOIN_LABELS = new Set([\n  \"ingredients\", \"directions\", \"instructions\", \"method\", \"preparation\",\n  \"steps\", \"notes\", \"tip\", \"tips\", \"variations\", \"variation\",\n  \"garnish\", \"topping\", \"toppings\", \"frosting\", \"filling\",\n  \"serving suggestion\", \"serving suggestions\", \"serving\",\n  \"glaze\", \"instrukcje\", \"uwagi\", \"notatki\", \"podawanie\", \"przechowywanie\",\n  \"skladniki\", \"przygotowanie\", \"sposob przygotowania\", \"sposob wykonania\",\n  \"wykonanie\", \"wskazowki\", \"podpowiedz\", \"warianty\",\n  \"sos\", \"nadzienie\", \"polewa\", \"lukier\", \"ciasto\",\n]);\n\nfunction isAlwaysBlockJoinLabel(text: string): boolean {\n  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n  return ALWAYS_BLOCK_JOIN_LABELS.has(normalized);\n}\n\nfunction isAllCaps(line: string): boolean {\n  const letters = line.replace(/[^a-zA-Z]/g, \"\");\n  return letters.length > 0 && letters === letters.toUpperCase();\n}\n\nfunction looksLikeMetadata(text: string): boolean {\n  return METADATA_PATTERNS.some((pattern) => pattern.test(text.trim()));\n}\n\n/** Content words are ≥3 alpha characters after stripping punctuation. */\nfunction extractContentWords(text: string): string[] {\n  return text\n    .split(/\\s+/)\n    .filter((w) => w.replace(/[^a-zA-ZÀ-ÿ]/g, \"\").length >= 3)\n    .map((w) => w.toUpperCase());\n}\n\n/**\n * Returns true if the candidate's vocabulary is sufficiently supported by the rest of\n * the document. Short candidates (≤3 content words) require 100% corroboration;\n * longer candidates require ≥67%. Used to detect orphaned OCR artifacts in multi-title pages.\n */\nfunction passesCorroboration(\n  text: string,\n  position: number,\n  allLines: string[],\n  startLine: number = 0 // Only check corroboration against lines from this index onward\n): boolean {\n  const contentWords = extractContentWords(text);","numLines":150,"startLine":100,"totalLines":1723}}}
