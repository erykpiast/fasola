f (nonEmptyLines.length < 3) return false;\n   391→\n   392→  const first3 = nonEmptyLines.slice(0, 3);\n   393→\n   394→  return first3.every(line =>\n   395→    looksLikeIngredient(line) ||\n   396→    looksLikeCookingInstruction(line) ||\n   397→    isBodyProse(line)\n   398→  );\n   399→}\n   400→\n   401→function passesHardFilters(text: string): boolean {\n   402→  if (text.length < 3 || text.length > 80) return false;\n   403→  if (looksLikeIngredient(text)) return false;\n   404→  if (startsWithNumber(text)) return false;\n   405→  if (looksLikeMetadata(text)) return false;\n   406→  if (isLikelyGarbled(text)) return false;\n   407→  if (looksLikeCookingInstruction(text)) return false;\n   408→  // Apply lightweight OCR normalization before a second instruction check\n   409→  // so that \"Podaw4ć\" is recognized as \"Podawać\" (cooking instruction).\n   410→  // Only 4→a for now — the specific OCR artifact causing failures.\n   411→  // Uses same letter-adjacent guard logic as applyBlindOcrRepairToken.\n   412→  const ocrNormForInstruction = text\n   413→    .replace(/(?<=[a-zà-ż])4/g, \"a\")\n   414→    .replace(/4(?=[a-zà-ż])/g, \"a\");\n   415→  if (ocrNormForInstruction !== text && looksLikeCookingInstruction(ocrNormForInstruction)) return false;\n   416→  // Pipe-separated lines are book category/chapter headers, not recipe titles\n   417→  if (text.includes(\" | \")) return false;\n   418→  // Trailing page number (e.g. \"VEGETABLE SIDES                         145\")\n   419→  if (/\\s{3,}\\d{1,4}\\s*$/.test(text)) return false;\n   420→  // Slash-separated breadcrumbs (e.g., \"/ Jesien / Zupy\") are navigation, not titles\n   421→  // Only filter when 2+ slashes are present — single-slash lines like\n   422→  // \"TITLE / SUBTITLE\" are legitimate continuation-merged titles\n   423→  if ((text.match(/\\//g) || []).length >= 2) return false;\n   424→  // Bullet-list items (ingredients or instruction steps) are never titles\n   425→  if (/^\\s*[-•*]\\s