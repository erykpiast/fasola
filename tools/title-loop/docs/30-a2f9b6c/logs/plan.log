{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012Q6US9gvtU2UAuXp1x5W4U","type":"tool_result","content":"  1449→\n  1450→  // Remove word-boundary prefixes of firstStructuralHeading when the heading itself survived\n  1451→  // the threshold. Cases:\n  1452→  //   ARAYES case:  firstStructuralHeading = \"ARAYES SHRAK\" (2-word join qualifies; \"ARAYES\"\n  1453→  //     alone = 1 word, so it never qualified). Filter removes \"ARAYES\" so dedup keeps the join.\n  1454→  //   SAFFRON case: baseHeading was the partial line; continuation logic above upgraded\n  1455→  //     firstStructuralHeading to the full join. Filter removes the partial so dedup keeps join.\n  1456→  // Safety: only fires when the complete heading itself is in selected (passed the threshold).\n  1457→  if (firstStructuralHeading && selected.some((s) => s.text === firstStructuralHeading.text)) {\n  1458→    const fshLower = firstStructuralHeading.text.toLowerCase();\n  1459→    selected = selected.filter((s) => {\n  1460→      if (s.text === firstStructuralHeading.text) return true;\n  1461→      const sLower = s.text.toLowerCase();\n  1462→      // Remove s if it is a space-delimited prefix of the structural heading\n  1463→      return !fshLower.startsWith(sLower + \" \");\n  1464→    });\n  1465→  }\n  1466→\n  1467→  // Protect continuation joins: when a multi-line join (2-line or 3-line) survived the threshold\n  1468→  // and its second part starts with a continuation character, remove the single-line prefix/suffix\n  1469→  // so the dedup \"shorter wins\" rule doesn't destroy the complete join.\n  1470→  // Note: the pre-merge step above already handles the common Baked Eggs case (&/continuation\n  1471→  // on next line) by turning it into a single candidate — this block covers the rarer case where\n  1472→  // a continuation-character join was generated as a 2-line/3-line candidate and the prefix\n  1473→  // single also survived threshold independently (e.g. from a different code path or OCR layout).\n  1474→  // Safety: only fires for joins whose continuation starts with /&+:( — digit continuations\n  1475→  // like \"Pierogi Ruskie 200g mąki\" are NOT protected, so dedup correctly keeps the shorter form.\n  1476→  const survivingJoins = selected.filter((s) => s.origin === \"2-line\" || s.origin === \"3-line\");\n  1477→  if (survivingJoins.length > 0) {\n  1478→    selected = selected.filter((s) => {\n  1479→      if (s.origin !== \"single\") return true;\n  1480→      const sLower = s.text.toLowerCase();\n  1481→      // Remove PREFIX singles whose continuation join also survived\n  1482→      const isPrefixOfJoin = survivingJoins.some((j) => {\n  1483→        const jLower = j.text.toLowerCase();\n  1484→        if (!jLower.startsWith(sLower + \" \")) return false;\n  1485→        const remainder = jLower.slice(sLower.length + 1);\n  1486→        return /^[/&+:(]/.test(remainder);\n  1487→      });\n  1488→      if (isPrefixOfJoin) return false;\n  1489→      // Remove SUFFIX singles (e.g. \"& Coriander\") whose parent join also survived\n  1490→      const isSuffixOfJoin = survivingJoins.some((j) => {\n  1491→        const jLower = j.text.toLowerCase();\n  1492→        if (!jLower.endsWith(\" \" + sLower)) return false;\n  1493→        // Only remove if the suffix starts with a continuation character\n  1494→        return /^[/&+:(]/.test(sLower);\n  1495→      });\n  1496→      if (isSuffixOfJoin) return false;\n  1497→      return true;\n  1498→    });\n  1499→  }\n  1500→\n  1501→  // Pre-dedup: remove sub-section headers that are substrings of other surviving candidates.\n  1502→  // A sub-section header is an ALL_CAPS candidate followed by ingredient-like lines in the source.\n  1503→  // Example: \"CHLEBEK\" (bread section header, followed by \"500 g mąki\") is a substring of\n  1504→  // \"CHLEBEK Z WARZYWAMI I BOCZKIEM\" (the real title). Without this filter, dedup kills the title.\n  1505→  selected = selected.filter((candidate) => {\n  1506→    if (!isAllCaps(candidate.text)) return true;\n  1507→    // Check if this candidate is immediately followed by ingredient-like content\n  1508→    const nextSourceLines = lines.slice(candidate.position + 1, candidate.position + 2);\n  1509→    const followedByIngredients = nextSourceLines.some(\n  1510→      (l) => looksLikeIngredient(l.trim()) || startsWithNumber(l.trim())\n  1511→    );\n  1512→    if (!followedByIngredients) return true;\n  1513→    // Only remove if a longer candidate contains this one as a substring\n  1514→    const candidateLower = candidate.text.toLowerCase();\n  1515→    const hasLongerParent = rawScored.some(\n  1516→      (other) =>\n  1517→        other.text !== candidate.text &&\n  1518→        other.text.length > candidate.text.length &&\n  1519→        other.text.toLowerCase().includes(candidateLower)\n  1520→    );\n  1521→    return !hasLongerParent;\n  1522→  });\n  1523→\n  1524→  // Protect multi-line joins from being destroyed by their own component singles.\n  1525→  // When \"Lamb Stew\" (2-line join) survives AND both \"Lamb\" and \"Stew\" (singles) also survive,\n  1526→  // the join is the intended title — remove the singles.\n  1527→  const joinsToProtect = selected.filter((s) => s.origin === \"2-line\" || s.origin === \"3-line\");\n  1528→  if (joinsToProtect.length > 0) {\n  1529→    const singlesToRemove = new Set<string>();\n  1530→    for (const join of joinsToProtect) {\n  1531→      const joinWords = join.text.split(/\\s+/);\n  1532→      const componentSingles = selected.filter(\n  1533→        (s) => s.origin === \"single\" && joinWords.some((w) => s.text.toLowerCase() === w.toLowerCase())\n  1534→      );\n  1535→      if (componentSingles.length >= Math.min(joinWords.length, 2)) {\n  1536→        componentSingles.forEach((s) => singlesToRemove.add(s.text));\n  1537→      }\n  1538→    }\n  1539→    if (singlesToRemove.size > 0) {\n  1540→      selected = selected.filter((s) => s.origin !== \"single\" || !singlesToRemove.has(s.text));\n  1541→    }\n  1542→  }\n  1543→\n  1544→  // Protect position-0 compound titles from distant sub-section headers.\n  1545→  // When a position-0 compound title is longer and contains a shorter candidate\n  1546→  // that appears > 10 lines later, remove the distant candidate so the dedup\n  1547→  // (shorter-wins rule) doesn't destroy the compound title.\n  1548→  const pos0Compounds = selected.filter((s) => s.position === 0);\n  1549→  if (pos0Compounds.length > 0) {\n  1550→    selected = selected.filter((s) => {\n  1551→      if (s.position === 0) return true;\n  1552→      const sLower = s.text.toLowerCase();\n  1553→      return !pos0Compounds.some(\n  1554→        (p0) =>\n  1555→          p0.position + 10 < s.position &&\n  1556→          s.text.length < p0.text.length &&\n  1557→          p0.text.toLowerCase().includes(sLower)\n  1558→      );\n  1559→    });\n  1560→  }\n  1561→\n  1562→  // Deduplicate: if one title is a substring of another, keep the shorter (more focused) one.\n  1563→  // DO NOT CHANGE THIS LOGIC — it has been incorrectly \"improved\" by the title-loop 5 times.\n  1564→  // The tests require shorter wins: \"Pierogi Ruskie\" over \"Pierogi Ruskie 200g mąki 3 ziemniaki\".\n  1565→  // The pre-filter above handles the conflicting case (structural heading prefix removal) so that\n  1566→  // the incomplete prefix line is never present here when the complete join is in selected.\n  1567→  selected = selected.filter((a) => {\n  1568→    const aLower = a.text.toLowerCase();\n  1569→    // Protect compound titles — these use explicit separators and the full form is intentional\n  1570→    if (/ [+:&] /.test(a.text)) return true;\n  1571→    return !selected.some((b) => {\n  1572→      if (b === a) return false;\n  1573→      if (b.text.length >= a.text.length) return false;\n  1574→      if (!aLower.includes(b.text.toLowerCase())) return false;\n  1575→\n  1576→      // Protect multi-line joins whose suffix over the shorter candidate is a food-category label.\n  1577→      // E.g., \"LEMON HERB ROASTED VEGETABLES\" (2-line) vs \"LEMON HERB ROASTED\" (single):\n  1578→      // \"VEGETABLES\" is in CATEGORY_SECTION_LABELS — keep the full joined form.\n  1579→      // Use startsWith (not includes) to ensure b is a true prefix, not a mid-string match.\n  1580→      if ((a.origin === \"2-line\" || a.origin === \"3-line\") &&\n  1581→          aLower.startsWith(b.text.toLowerCase() + \" \")) {\n  1582→        const suffix = a.text.slice(b.text.length).trim();\n  1583→        const suffixNorm = stripDiacritics(suffix.toLowerCase());\n  1584→        if (CATEGORY_SECTION_LABELS.has(suffixNorm)) {\n  1585→          return false; // Don't remove `a` — its suffix is a food-category label\n  1586→        }\n  1587→      }\n  1588→\n  1589→      return true;\n  1590→    });\n  1591→  });\n  1592→\n  1593→  // Multi-title guard: only join multiple candidates with \"+\" when there is\n  1594→  // structural evidence of a multi-recipe page (≥2 ALL_CAPS headings).\n  1595→  // A single ALL_CAPS title among mixed-case survivors is a single-recipe page —\n  1596→  // collapse to the highest-scoring candidate.\n  1597→  // Zero ALL_CAPS survivors → apply positional tiebreak only when candidates are\n  1598→  // spread far apart (>10 lines), which indicates body-text leakage. Closely-\n  1599→  // positioned candidates are likely genuine multi-recipe content.\n  1600→  if (selected.length > 1) {\n  1601→    const allCapsSelected = selected.filter((s) => isAllCaps(s.text));\n  1602→    if (allCapsSelected.length >= 2) {\n  1603→      // Vocabulary corroboration: filter out ALL_CAPS candidates whose content words\n  1604→      // don't appear elsewhere in the document. This catches orphaned OCR artifacts\n  1605→      // (e.g., \"DAT FLATBREADS\" from a preceding page) that look structurally identical\n  1606→      // to real titles but have no vocabulary support in the document body.\n  1607→      const corroboratedCaps = allCapsSelected.filter((cap) =>\n  1608→        passesCorroboration(cap.text, cap.position, lines, burstEnd)\n  1609→      );\n  1610→\n  1611→      // Use corroborated candidates if any remain; otherwise fall back to original set\n  1612→      // (don't remove all candidates — that would break legitimate multi-title pages\n  1613→      // where corroboration fails for benign reasons).\n  1614→      const capsToUse = corroboratedCaps.length >= 2 ? corroboratedCaps : allCapsSelected;\n  1615→\n  1616→      // Check whether non-first ALL_CAPS headings are section headers within one recipe\n  1617→      // (followed immediately by ingredient-like content) rather than separate recipe titles.\n  1618→      // A multi-recipe page has body text between titles; a single-recipe page has\n  1619→      // ingredient lines immediately after each section heading.\n  1620→      const sortedCaps = [...capsToUse].sort((a, b) => a.position - b.position);\n  1621→      const isSubHeader = sortedCaps.slice(1).every((cap) => {\n  1622→        const nextLines = lines.slice(cap.position + 1, cap.position + 3);\n  1623→        return nextLines.some(\n  1624→          (l) => looksLikeIngredient(l.trim()) || startsWithNumber(l.trim())\n  1625→        );\n  1626→      });\n  1627→      if (isSubHeader) {\n  1628→        selected = [sortedCaps[0]];\n  1629→      } else {\n  1630→        selected = capsToUse;\n  1631→      }\n  1632→    } else if (allCapsSelected.length === 1) {\n  1633→      const theCapCandidate = allCapsSelected[0];\n  1634→      // Use non-empty line count so the 75% threshold is consistent regardless of blank-line density.\n  1635→      const nonEmptyCount = lines.filter((l) => l.trim().length > 0).length;\n  1636→      const capRelPos = theCapCandidate.position / Math.max(nonEmptyCount, 1);\n  1637→      // If the sole ALL_CAPS candidate is in the last 25% of the document,\n  1638→      // it's likely a category footer, not a title. Prefer the best earlier candidate.\n  1639→      if (capRelPos > 0.75) {\n  1640→        const earlierCandidates = selected.filter(\n  1641→          (s) => s.position / Math.max(nonEmptyCount, 1) <= 0.75\n  1642→        );\n  1643→        if (earlierCandidates.length > 0) {\n  1644→          selected = [earlierCandidates.reduce((a, b) => (a.score > b.score ? a : b))];\n  1645→        } else {\n  1646→          // All candidates are in the last 25% — no positional basis to prefer one over another;\n  1647→          // fall back to score, accepting that the guard cannot help here.\n  1648→          selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n  1649→        }\n  1650→      } else {\n  1651→        selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n  1652→      }\n  1653→    } else {\n  1654→      // Zero ALL_CAPS survivors → mixed-case page.\n  1655→      // If all survivors are closely positioned (within 10 lines of each other), keep them all —\n  1656→      // they're likely genuine multi-recipe content on a single page.\n  1657→      // If any survivor is far from the earliest, apply a positional tiebreak: the real title\n  1658→      // is almost always the earliest candidate; distant survivors are likely body-text leakage.\n  1659→      selected.sort((a, b) => a.position - b.position);\n  1660→      const earliest = selected[0];\n  1661→      const farthest = selected[selected.length - 1];\n  1662→      if (farthest.position - earliest.position > 10) {\n  1663→        // Large span → body-text leakage. Collapse to one: prefer the highest-scoring\n  1664→        // candidate within 3 positions of the earliest (position tolerance for OCR gaps),\n  1665→        // falling back to the earliest itself if none score higher.\n  1666→        const closeCompetitors = selected.filter(\n  1667→          (s) => s.position <= earliest.position + 3 && s.score > earliest.score\n  1668→        );\n  1669→        selected = closeCompetitors.length > 0\n  1670→          ? [closeCompetitors.reduce((a, b) => (a.score > b.score ? a : b))]\n  1671→          : [earliest];\n  1672→      }\n  1673→      // Span ≤ 10 → all survivors are closely positioned; fall through keeping all.\n  1674→    }\n  1675→  }\n  1676→\n  1677→  // Cap at 3, sort by document position\n  1678→  selected.sort((a, b) => a.position - b.position);\n  1679→  selected = selected.slice(0, 3);\n  1680→\n  1681→  if (selected.length === 0) {\n  1682→    // Last resort: embedding scoring provided no usable signal.\n  1683→    // Return the earliest candidate that passed hard filters — it already survived\n  1684→    // ingredient, metadata, garbled, section-label, and cooking-instruction checks.\n  1685→    // Position 0 in a recipe file is overwhelmingly the title.\n  1686→    // Exclude hard-disqualified candidates (rawScore -1.0 = truncated OCR artifact).\n  1687→    const lastResort = scored\n  1688→      .slice()\n  1689→      .filter((s) => s.rawScore > -0.5)\n  1690→      .sort((a, b) => a.position - b.position || b.score - a.score);\n  1691→    if (lastResort.length > 0) {\n  1692→      return normalizeOcrTitle(lastResort[0].text.normalize(\"NFC\").trim());\n  1693→    }\n  1694→    return undefined;\n  1695→  }\n  1696→\n  1697→  const result = selected.map((s) => normalizeOcrTitle(s.text.normalize(\"NFC\").trim())).join(\" + \");\n  1698→"}]},"parent_tool_use_id":null,"session_id":"8a56c14a-0bc6-452a-98e5-f30796680f9b","uuid":"4051866f-d0c6-4b68-b236-5096ca9e013c","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/title-extractor.ts","content":"\n  // Remove word-boundary prefixes of firstStructuralHeading when the heading itself survived\n  // the threshold. Cases:\n  //   ARAYES case:  firstStructuralHeading = \"ARAYES SHRAK\" (2-word join qualifies; \"ARAYES\"\n  //     alone = 1 word, so it never qualified). Filter removes \"ARAYES\" so dedup keeps the join.\n  //   SAFFRON case: baseHeading was the partial line; continuation logic above upgraded\n  //     firstStructuralHeading to the full join. Filter removes the partial so dedup keeps join.\n  // Safety: only fires when the complete heading itself is in selected (passed the threshold).\n  if (firstStructuralHeading && selected.some((s) => s.text === firstStructuralHeading.text)) {\n    const fshLower = firstStructuralHeading.text.toLowerCase();\n    selected = selected.filter((s) => {\n      if (s.text === firstStructuralHeading.text) return true;\n      const sLower = s.text.toLowerCase();\n      // Remove s if it is a space-delimited prefix of the structural heading\n      return !fshLower.startsWith(sLower + \" \");\n    });\n  }\n\n  // Protect continuation joins: when a multi-line join (2-line or 3-line) survived the threshold\n  // and its second part starts with a continuation character, remove the single-line prefix/suffix\n  // so the dedup \"shorter wins\" rule doesn't destroy the complete join.\n  // Note: the pre-merge step above already handles the common Baked Eggs case (&/continuation\n  // on next line) by turning it into a single candidate — this block covers the rarer case where\n  // a continuation-character join was generated as a 2-line/3-line candidate and the prefix\n  // single also survived threshold independently (e.g. from a different code path or OCR layout).\n  // Safety: only fires for joins whose continuation starts with /&+:( — digit continuations\n  // like \"Pierogi Ruskie 200g mąki\" are NOT protected, so dedup correctly keeps the shorter form.\n  const survivingJoins = selected.filter((s) => s.origin === \"2-line\" || s.origin === \"3-line\");\n  if (survivingJoins.length > 0) {\n    selected = selected.filter((s) => {\n      if (s.origin !== \"single\") return true;\n      const sLower = s.text.toLowerCase();\n      // Remove PREFIX singles whose continuation join also survived\n      const isPrefixOfJoin = survivingJoins.some((j) => {\n        const jLower = j.text.toLowerCase();\n        if (!jLower.startsWith(sLower + \" \")) return false;\n        const remainder = jLower.slice(sLower.length + 1);\n        return /^[/&+:(]/.test(remainder);\n      });\n      if (isPrefixOfJoin) return false;\n      // Remove SUFFIX singles (e.g. \"& Coriander\") whose parent join also survived\n      const isSuffixOfJoin = survivingJoins.some((j) => {\n        const jLower = j.text.toLowerCase();\n        if (!jLower.endsWith(\" \" + sLower)) return false;\n        // Only remove if the suffix starts with a continuation character\n        return /^[/&+:(]/.test(sLower);\n      });\n      if (isSuffixOfJoin) return false;\n      return true;\n    });\n  }\n\n  // Pre-dedup: remove sub-section headers that are substrings of other surviving candidates.\n  // A sub-section header is an ALL_CAPS candidate followed by ingredient-like lines in the source.\n  // Example: \"CHLEBEK\" (bread section header, followed by \"500 g mąki\") is a substring of\n  // \"CHLEBEK Z WARZYWAMI I BOCZKIEM\" (the real title). Without this filter, dedup kills the title.\n  selected = selected.filter((candidate) => {\n    if (!isAllCaps(candidate.text)) return true;\n    // Check if this candidate is immediately followed by ingredient-like content\n    const nextSourceLines = lines.slice(candidate.position + 1, candidate.position + 2);\n    const followedByIngredients = nextSourceLines.some(\n      (l) => looksLikeIngredient(l.trim()) || startsWithNumber(l.trim())\n    );\n    if (!followedByIngredients) return true;\n    // Only remove if a longer candidate contains this one as a substring\n    const candidateLower = candidate.text.toLowerCase();\n    const hasLongerParent = rawScored.some(\n      (other) =>\n        other.text !== candidate.text &&\n        other.text.length > candidate.text.length &&\n        other.text.toLowerCase().includes(candidateLower)\n    );\n    return !hasLongerParent;\n  });\n\n  // Protect multi-line joins from being destroyed by their own component singles.\n  // When \"Lamb Stew\" (2-line join) survives AND both \"Lamb\" and \"Stew\" (singles) also survive,\n  // the join is the intended title — remove the singles.\n  const joinsToProtect = selected.filter((s) => s.origin === \"2-line\" || s.origin === \"3-line\");\n  if (joinsToProtect.length > 0) {\n    const singlesToRemove = new Set<string>();\n    for (const join of joinsToProtect) {\n      const joinWords = join.text.split(/\\s+/);\n      const componentSingles = selected.filter(\n        (s) => s.origin === \"single\" && joinWords.some((w) => s.text.toLowerCase() === w.toLowerCase())\n      );\n      if (componentSingles.length >= Math.min(joinWords.length, 2)) {\n        componentSingles.forEach((s) => singlesToRemove.add(s.text));\n      }\n    }\n    if (singlesToRemove.size > 0) {\n      selected = selected.filter((s) => s.origin !== \"single\" || !singlesToRemove.has(s.text));\n    }\n  }\n\n  // Protect position-0 compound titles from distant sub-section headers.\n  // When a position-0 compound title is longer and contains a shorter candidate\n  // that appears > 10 lines later, remove the distant candidate so the dedup\n  // (shorter-wins rule) doesn't destroy the compound title.\n  const pos0Compounds = selected.filter((s) => s.position === 0);\n  if (pos0Compounds.length > 0) {\n    selected = selected.filter((s) => {\n      if (s.position === 0) return true;\n      const sLower = s.text.toLowerCase();\n      return !pos0Compounds.some(\n        (p0) =>\n          p0.position + 10 < s.position &&\n          s.text.length < p0.text.length &&\n          p0.text.toLowerCase().includes(sLower)\n      );\n    });\n  }\n\n  // Deduplicate: if one title is a substring of another, keep the shorter (more focused) one.\n  // DO NOT CHANGE THIS LOGIC — it has been incorrectly \"improved\" by the title-loop 5 times.\n  // The tests require shorter wins: \"Pierogi Ruskie\" over \"Pierogi Ruskie 200g mąki 3 ziemniaki\".\n  // The pre-filter above handles the conflicting case (structural heading prefix removal) so that\n  // the incomplete prefix line is never present here when the complete join is in selected.\n  selected = selected.filter((a) => {\n    const aLower = a.text.toLowerCase();\n    // Protect compound titles — these use explicit separators and the full form is intentional\n    if (/ [+:&] /.test(a.text)) return true;\n    return !selected.some((b) => {\n      if (b === a) return false;\n      if (b.text.length >= a.text.length) return false;\n      if (!aLower.includes(b.text.toLowerCase())) return false;\n\n      // Protect multi-line joins whose suffix over the shorter candidate is a food-category label.\n      // E.g., \"LEMON HERB ROASTED VEGETABLES\" (2-line) vs \"LEMON HERB ROASTED\" (single):\n      // \"VEGETABLES\" is in CATEGORY_SECTION_LABELS — keep the full joined form.\n      // Use startsWith (not includes) to ensure b is a true prefix, not a mid-string match.\n      if ((a.origin === \"2-line\" || a.origin === \"3-line\") &&\n          aLower.startsWith(b.text.toLowerCase() + \" \")) {\n        const suffix = a.text.slice(b.text.length).trim();\n        const suffixNorm = stripDiacritics(suffix.toLowerCase());\n        if (CATEGORY_SECTION_LABELS.has(suffixNorm)) {\n          return false; // Don't remove `a` — its suffix is a food-category label\n        }\n      }\n\n      return true;\n    });\n  });\n\n  // Multi-title guard: only join multiple candidates with \"+\" when there is\n  // structural evidence of a multi-recipe page (≥2 ALL_CAPS headings).\n  // A single ALL_CAPS title among mixed-case survivors is a single-recipe page —\n  // collapse to the highest-scoring candidate.\n  // Zero ALL_CAPS survivors → apply positional tiebreak only when candidates are\n  // spread far apart (>10 lines), which indicates body-text leakage. Closely-\n  // positioned candidates are likely genuine multi-recipe content.\n  if (selected.length > 1) {\n    const allCapsSelected = selected.filter((s) => isAllCaps(s.text));\n    if (allCapsSelected.length >= 2) {\n      // Vocabulary corroboration: filter out ALL_CAPS candidates whose content words\n      // don't appear elsewhere in the document. This catches orphaned OCR artifacts\n      // (e.g., \"DAT FLATBREADS\" from a preceding page) that look structurally identical\n      // to real titles but have no vocabulary support in the document body.\n      const corroboratedCaps = allCapsSelected.filter((cap) =>\n        passesCorroboration(cap.text, cap.position, lines, burstEnd)\n      );\n\n      // Use corroborated candidates if any remain; otherwise fall back to original set\n      // (don't remove all candidates — that would break legitimate multi-title pages\n      // where corroboration fails for benign reasons).\n      const capsToUse = corroboratedCaps.length >= 2 ? corroboratedCaps : allCapsSelected;\n\n      // Check whether non-first ALL_CAPS headings are section headers within one recipe\n      // (followed immediately by ingredient-like content) rather than separate recipe titles.\n      // A multi-recipe page has body text between titles; a single-recipe page has\n      // ingredient lines immediately after each section heading.\n      const sortedCaps = [...capsToUse].sort((a, b) => a.position - b.position);\n      const isSubHeader = sortedCaps.slice(1).every((cap) => {\n        const nextLines = lines.slice(cap.position + 1, cap.position + 3);\n        return nextLines.some(\n          (l) => looksLikeIngredient(l.trim()) || startsWithNumber(l.trim())\n        );\n      });\n      if (isSubHeader) {\n        selected = [sortedCaps[0]];\n      } else {\n        selected = capsToUse;\n      }\n    } else if (allCapsSelected.length === 1) {\n      const theCapCandidate = allCapsSelected[0];\n      // Use non-empty line count so the 75% threshold is consistent regardless of blank-line density.\n      const nonEmptyCount = lines.filter((l) => l.trim().length > 0).length;\n      const capRelPos = theCapCandidate.position / Math.max(nonEmptyCount, 1);\n      // If the sole ALL_CAPS candidate is in the last 25% of the document,\n      // it's likely a category footer, not a title. Prefer the best earlier candidate.\n      if (capRelPos > 0.75) {\n        const earlierCandidates = selected.filter(\n          (s) => s.position / Math.max(nonEmptyCount, 1) <= 0.75\n        );\n        if (earlierCandidates.length > 0) {\n          selected = [earlierCandidates.reduce((a, b) => (a.score > b.score ? a : b))];\n        } else {\n          // All candidates are in the last 25% — no positional basis to prefer one over another;\n          // fall back to score, accepting that the guard cannot help here.\n          selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n        }\n      } else {\n        selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n      }\n    } else {\n      // Zero ALL_CAPS survivors → mixed-case page.\n      // If all survivors are closely positioned (within 10 lines of each other), keep them all —\n      // they're likely genuine multi-recipe content on a single page.\n      // If any survivor is far from the earliest, apply a positional tiebreak: the real title\n      // is almost always the earliest candidate; distant survivors are likely body-text leakage.\n      selected.sort((a, b) => a.position - b.position);\n      const earliest = selected[0];\n      const farthest = selected[selected.length - 1];\n      if (farthest.position - earliest.position > 10) {\n        // Large span → body-text leakage. Collapse to one: prefer the highest-scoring\n        // candidate within 3 positions of the earliest (position tolerance for OCR gaps),\n        // falling back to the earliest itself if none score higher.\n        const closeCompetitors = selected.filter(\n          (s) => s.position <= earliest.position + 3 && s.score > earliest.score\n        );\n        selected = closeCompetitors.length > 0\n          ? [closeCompetitors.reduce((a, b) => (a.score > b.score ? a : b))]\n          : [earliest];\n      }\n      // Span ≤ 10 → all survivors are closely positioned; fall through keeping all.\n    }\n  }\n\n  // Cap at 3, sort by document position\n  selected.sort((a, b) => a.position - b.position);\n  selected = selected.slice(0, 3);\n\n  if (selected.length === 0) {\n    // Last resort: embedding scoring provided no usable signal.\n    // Return the earliest candidate that passed hard filters — it already survived\n    // ingredient, metadata, garbled, section-label, and cooking-instruction checks.\n    // Position 0 in a recipe file is overwhelmingly the title.\n    // Exclude hard-disqualified candidates (rawScore -1.0 = truncated OCR artifact).\n    const lastResort = scored\n      .slice()\n      .filter((s) => s.rawScore > -0.5)\n      .sort((a, b) => a.position - b.position || b.score - a.score);\n    if (lastResort.length > 0) {\n      return normalizeOcrTitle(lastResort[0].text.normalize(\"NFC\").trim());\n    }\n    return undefined;\n  }\n\n  const result = selected.map((s) => normalizeOcrTitle(s.text.normalize(\"NFC\").trim())).join(\" + \");\n","numLines":250,"startLine":1449,"totalLines":1723}}}
