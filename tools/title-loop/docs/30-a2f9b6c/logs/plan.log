index ?? lines.length };\n   768→}\n   769→\n   770→/**\n   771→ * Convert an ALL_CAPS string to Title Case, using a small-words list.\n   772→ * Preserves Polish/French diacritics.\n   773→ */\n   774→function toTitleCase(text: string): string {\n   775→  const smallWords = new Set([\n   776→    \"a\", \"an\", \"the\", \"and\", \"but\", \"or\", \"for\", \"nor\",\n   777→    \"in\", \"on\", \"at\", \"to\", \"of\", \"by\", \"with\", \"from\",\n   778→    \"z\", \"w\", \"i\", \"ze\", \"na\", \"do\", \"od\", \"za\", \"po\",\n   779→  ]);\n   780→  return text.split(/(\\s+)/).map((word, idx) => {\n   781→    if (/^\\s+$/.test(word)) return word;\n   782→    const lower = word.toLowerCase();\n   783→    if (idx === 0 || !smallWords.has(lower)) {\n   784→      return lower.charAt(0).toUpperCase() + lower.slice(1);\n   785→    }\n   786→    return lower;\n   787→  }).join(\"\");\n   788→}\n   789→\n   790→/**\n   791→ * OCR digit→letter substitution map.\n   792→ * Each key is a character that OCR commonly confuses; values are possible correct letters.\n   793→ */\n   794→const OCR_SUBSTITUTIONS: Record<string, string[]> = {\n   795→  \"0\": [\"o\"],\n   796→  \"1\": [\"i\", \"l\"],\n   797→  \"4\": [\"a\"],\n   798→  \"5\": [\"s\"],\n   799→  \"¡\": [\"i\"],\n   800→  \"í\": [\"i\", \"l\"],\n   801→  \"€\": [\"e\"],\n   802→};\n   803→\n   804→const OCR_ARTIFACT_PATTERN = /[0-9¡Íí€]/;\n   805→\n   806→/**\n   807→ * Attempt to repair a single OCR-corrupted word using dictionary lookup.\n   808→ * Returns the repaired word if a dictionary match is found, otherwise returns the original.\n   809→ */\n   810→function repairOcrWord(word: string): string {\n   811→  if (!OCR_ARTIFACT_PATTERN.test(word)) return word;\n   812→\n   813→  const lower = word.toLowerCase();\n   814→\n   815→  const positions: Array<{ index: number; replacements: Array<string> }> = [];\n   816→  for (let i = 0; i < lower.length; i++) {\n   817→    const replacements = OCR_SUBSTITUTIONS[lower[i]];\n   