{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FFekQdGNTGLc3He8hMedHU","type":"tool_result","content":"  1250→  // at position ≤ 2 that is semantically similar to it, this is a bilingual recipe\n  1251→  // page (e.g., Polish title + ALL_CAPS Korean romanization). Suppress confirmed\n  1252→  // translation candidates before computing threshold so their bonuses don't inflate\n  1253→  // the threshold beyond the mixed-case title's reach.\n  1254→  // Note: we check position ≤ 2 (local proximity), not global ALL_CAPS count, so\n  1255→  // section headers later in the document (SKŁADNIKI, WARZYWA, etc.) are irrelevant.\n  1256→  let translationCandidates: typeof scored = [];\n  1257→  let scoredForThreshold = scored;\n  1258→  const prePos0 = scored.find((s) => s.position === 0 && !isAllCaps(s.text));\n  1259→  if (prePos0) {\n  1260→    const nearbyAllCaps = scored.filter(\n  1261→      (s) => isAllCaps(s.text) && s.position >= 1 && s.position <= 2 && s.origin === \"single\"\n  1262→    );\n  1263→    const pos0Embedding = rawScored.find((r) => r.text === prePos0.text)?.embedding;\n  1264→\n  1265→    // Method 1: embedding similarity (works for related languages)\n  1266→    if (pos0Embedding && nearbyAllCaps.length > 0) {\n  1267→      translationCandidates = nearbyAllCaps.filter((cap) => {\n  1268→        const capEmbedding = rawScored.find((r) => r.text === cap.text)?.embedding;\n  1269→        if (!capEmbedding) return false;\n  1270→        return cosineSimilarity(pos0Embedding, capEmbedding) > 0.4;\n  1271→      });\n  1272→    }\n  1273→\n  1274→    // Method 2: layout-based detection (cross-lingual fallback).\n  1275→    // When embedding similarity is insufficient (e.g. Polish ↔ Korean romanization),\n  1276→    // detect bilingual layout by position and word overlap:\n  1277→    // mixed-case ≥2 words at pos 0 + ALL_CAPS ≥2 words at pos 1-2 with no shared words.\n  1278→    if (translationCandidates.length === 0 && wordCount(prePos0.text) >= 2) {\n  1279→      const pos0Words = new Set(\n  1280→        prePos0.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2)\n  1281→      );\n  1282→      translationCandidates = nearbyAllCaps.filter((cap) => {\n  1283→        if (wordCount(cap.text) < 2) return false;\n  1284→        const capWords = cap.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2);\n  1285→        return !capWords.some((w) => pos0Words.has(w));\n  1286→      });\n  1287→    }\n  1288→\n  1289→    if (translationCandidates.length > 0) {\n  1290→      // Suppress standalone translations and any multi-line joins that embed the translation\n  1291→      // as a suffix or substring (e.g. \"Smażona zielona fasolka GREEN BEANS BORKEUM\" ends with\n  1292→      // the translation; \"Title GREEN BEANS BORKEUM 그린빈\" includes it as a substring).\n  1293→      scoredForThreshold = scored.filter((s) => {\n  1294→        const sLower = s.text.toLowerCase();\n  1295→        return !translationCandidates.some((t) => {\n  1296→          const tLower = t.text.toLowerCase();\n  1297→          return sLower.startsWith(tLower) ||\n  1298→                 sLower.endsWith(\" \" + tLower) ||\n  1299→                 sLower.includes(\" \" + tLower);\n  1300→        });\n  1301→      });\n  1302→    }\n  1303→  }\n  1304→\n  1305→  // Fix 2: If the structural heading was identified as a bilingual translation, reassign it.\n  1306→  // This prevents the translation's ALL_CAPS bonus from inflating the threshold and ensures\n  1307→  // the fallback path in scored also uses the correct heading.\n  1308→  if (\n  1309→    translationCandidates.length > 0 &&\n  1310→    firstStructuralHeading &&\n  1311→    translationCandidates.some((t) => t.text === firstStructuralHeading!.text)\n  1312→  ) {\n  1313→    const nonTranslationStructural = structuralCandidates.filter(\n  1314→      (sc) => !translationCandidates.some((t) => t.text === sc.text)\n  1315→    );\n  1316→    const newHeading = nonTranslationStructural.length > 0\n  1317→      ? nonTranslationStructural.reduce((a, b) => a.rawScore > b.rawScore ? a : b)\n  1318→      : undefined;\n  1319→\n  1320→    // Patch scored array: remove old structural bonus, apply new one\n  1321→    for (const s of scored) {\n  1322→      if (s.text === firstStructuralHeading.text) {\n  1323→        s.score -= 0.10;\n  1324→        s.baseScore -= 0.10;\n  1325→      }\n  1326→      if (newHeading && s.text === newHeading.text) {\n  1327→        s.score += 0.10;\n  1328→        s.baseScore += 0.10;\n  1329→      }\n  1330→    }\n  1331→    // Update reference for downstream prefix-removal logic\n  1332→    firstStructuralHeading = newHeading ?? undefined;\n  1333→  }\n  1334→\n  1335→  // Subtitle suppression: when a short mixed-case title at position 0 is followed by a\n  1336→  // longer mixed-case candidate at position 1-2, the longer one is a subtitle/translation.\n  1337→  // Apply a penalty so the primary title (position 0) wins.\n  1338→  const pos0Primary = scored.find((s) => s.position === 0 && !isAllCaps(s.text) && wordCount(s.text) <= 5);\n  1339→  if (pos0Primary) {\n  1340→    const subtitleCandidates = scored.filter((s) =>\n  1341→      s.position >= 1 && s.position <= 2 &&\n  1342→      !isAllCaps(s.text) &&\n  1343→      wordCount(s.text) > wordCount(pos0Primary.text) + 2\n  1344→    );\n  1345→    for (const sub of subtitleCandidates) {\n  1346→      sub.score -= 0.15;\n  1347→    }\n  1348→  }\n  1349→\n  1350→  // Bilingual layout pattern: [FoodName (≤2 words)]\\n[Translation (2-5 words, mixed-case)]\\n...[Section label]\n  1351→  // Common in bilingual cookbooks: foreign food name at position 0, English translation at position 1-2.\n  1352→  // When detected, boost the position-0 candidate so it clears the threshold.\n  1353→  // Note: the ALL_CAPS bilingual block above (lines 940-995) handles mixed-case + ALL_CAPS pairs.\n  1354→  // This block handles mixed-case + mixed-case translation pairs — the two do not overlap because\n  1355→  // the mixed-case guard (`biSecond.text !== biSecond.text.toUpperCase()`) excludes ALL_CAPS lines.\n  1356→  if (scored.length >= 2) {\n  1357→    const biFirst = scored.find((s) => s.position === 0);\n  1358→    // Restrict to single-line candidates (same guard as the ALL_CAPS bilingual block at line 953)\n  1359→    const biSecond = scored.find((s) => s.position >= 1 && s.position <= 2 && s !== biFirst && s.origin === \"single\");\n  1360→\n  1361→    if (biFirst && biSecond) {\n  1362→      const firstWords = biFirst.text.trim().split(/\\s+/);\n  1363→      const secondWords = biSecond.text.trim().split(/\\s+/);\n  1364→\n  1365→      const isBilingualLayout =\n  1366→        firstWords.length <= 2 &&\n  1367→        secondWords.length >= 2 &&\n  1368→        secondWords.length <= 5 &&\n  1369→        // Second line is mixed-case (not ALL_CAPS, not all-lower)\n  1370→        biSecond.text !== biSecond.text.toUpperCase() &&\n  1371→        biSecond.text !== biSecond.text.toLowerCase() &&\n  1372→        // Second line is not an ingredient or instruction\n  1373→        !looksLikeIngredient(biSecond.text) &&\n  1374→        !looksLikeCookingInstruction(biSecond.text);\n  1375→\n  1376→      if (isBilingualLayout) {\n  1377→        // Check if a section label follows within a few lines after the first candidate\n  1378→        const sectionLabelNearby = lines\n  1379→          .slice(biFirst.position + 1, biFirst.position + 6)\n  1380→          .some((line) => isSectionLabel(line.trim()));\n  1381→\n  1382→        if (sectionLabelNearby) {\n  1383→          biFirst.score += 0.15;\n  1384→          biFirst.baseScore += 0.15;\n  1385→          biFirst.thresholdScore += 0.15;\n  1386→        }\n  1387→      }\n  1388→    }\n  1389→  }\n  1390→\n  1391→  // Pre-filter: when ≥2 ALL_CAPS candidates are present, identify OCR artifacts (those whose\n  1392→  // vocabulary has no support elsewhere in the document) and remove them before computing the\n  1393→  // threshold. Artifacts like \"DAT FLATBREADS\" can inflate the threshold via their early-position\n  1394→  // bonus, which causes legitimate titles later in the document to fall just below the cutoff.\n  1395→  // Safety: only pre-filter if ≥2 candidates remain after removal (avoids false-positive removal\n  1396→  // of unique-vocabulary titles on two-recipe pages).\n  1397→  // NOTE: The ≥2 guard is conservative — when there are exactly 2 ALL_CAPS candidates and one is\n  1398→  // an artifact, the artifact is NOT removed. Relaxing to ≥1 causes regressions because 3-line\n  1399→  // join candidates (which span a section label) can pass corroboration via shared vocabulary,\n  1400→  // while the legitimate short title fails. See \"WORD ONE / INGREDIENTS / WORD TWO\" test case.\n  1401→  const allCapsInScored = scoredForThreshold.filter((s) => isAllCaps(s.text));\n  1402→  if (allCapsInScored.length >= 2) {\n  1403→    const artifactTexts = new Set(\n  1404→      allCapsInScored\n  1405→        .filter((cap) => !passesCorroboration(cap.text, cap.position, lines, burstEnd))\n  1406→        .map((c) => c.text)\n  1407→    );\n  1408→    if (artifactTexts.size > 0) {\n  1409→      const remainingCaps = allCapsInScored.filter((c) => !artifactTexts.has(c.text));\n  1410→      if (remainingCaps.length >= 2) {\n  1411→        scoredForThreshold = scoredForThreshold.filter((s) => !artifactTexts.has(s.text));\n  1412→      }\n  1413→    }\n  1414→  }\n  1415→\n  1416→  // Use thresholdScore (excludes structural bonus) so the structural bonus doesn't inflate\n  1417→  // the threshold and block equally-valid headings on multi-recipe pages.\n  1418→  const bestThresholdScore = Math.max(...scoredForThreshold.map((s) => s.thresholdScore));\n  1419→  const threshold = Math.max(0.08, bestThresholdScore * 0.7);\n  1420→\n  1421→  // Filter candidates above threshold\n  1422→  let selected = scoredForThreshold.filter((s) => s.score >= threshold);\n  1423→\n  1424→  // Empty-pool fallback: when threshold filtering discards every candidate,\n  1425→  // the hard filters' structural verdict should not be overruled by weak\n  1426→  // embedding differentiation. Return the best positional candidate only\n  1427→  // if it has a meaningful positive raw score (avoids ingredient-list leakage).\n  1428→  if (selected.length === 0 && scored.length > 0) {\n  1429→    const fallback = scored\n  1430→      .slice()\n  1431→      .sort((a, b) => a.position - b.position || b.score - a.score);\n  1432→    // Position-0 candidates that passed hard filters are very likely titles even with\n  1433→    // weak embedding signal. Relax the rawScore guard for early-position candidates.\n  1434→    const rawScoreThreshold = fallback[0].position <= 2 ? -0.05 : 0.02;\n  1435→    if (fallback[0].rawScore > rawScoreThreshold) {\n  1436→      selected = [fallback[0]];\n  1437→    }\n  1438→  }\n  1439→\n  1440→  // Title-absent page guard: when the page starts mid-recipe (all of the first 3 non-empty\n  1441→  // lines are ingredients or cooking instructions), require a much higher rawScore and\n  1442→  // discard candidates deep in the file. This prevents stray body text or adjacent recipe\n  1443→  // titles from being picked up on pages with no title (Pattern 4).\n  1444→  if (titleAbsent) {\n  1445→    const titleAbsentThreshold = 0.10;\n  1446→    selected = selected.filter(s => s.rawScore >= titleAbsentThreshold);\n  1447→    selected = selected.filter(s => s.position <= 2);\n  1448→  }\n  1449→"}]},"parent_tool_use_id":null,"session_id":"8a56c14a-0bc6-452a-98e5-f30796680f9b","uuid":"75b95b4e-0768-433e-966b-31a126f95ee2","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/title-extractor.ts","content":"  // at position ≤ 2 that is semantically similar to it, this is a bilingual recipe\n  // page (e.g., Polish title + ALL_CAPS Korean romanization). Suppress confirmed\n  // translation candidates before computing threshold so their bonuses don't inflate\n  // the threshold beyond the mixed-case title's reach.\n  // Note: we check position ≤ 2 (local proximity), not global ALL_CAPS count, so\n  // section headers later in the document (SKŁADNIKI, WARZYWA, etc.) are irrelevant.\n  let translationCandidates: typeof scored = [];\n  let scoredForThreshold = scored;\n  const prePos0 = scored.find((s) => s.position === 0 && !isAllCaps(s.text));\n  if (prePos0) {\n    const nearbyAllCaps = scored.filter(\n      (s) => isAllCaps(s.text) && s.position >= 1 && s.position <= 2 && s.origin === \"single\"\n    );\n    const pos0Embedding = rawScored.find((r) => r.text === prePos0.text)?.embedding;\n\n    // Method 1: embedding similarity (works for related languages)\n    if (pos0Embedding && nearbyAllCaps.length > 0) {\n      translationCandidates = nearbyAllCaps.filter((cap) => {\n        const capEmbedding = rawScored.find((r) => r.text === cap.text)?.embedding;\n        if (!capEmbedding) return false;\n        return cosineSimilarity(pos0Embedding, capEmbedding) > 0.4;\n      });\n    }\n\n    // Method 2: layout-based detection (cross-lingual fallback).\n    // When embedding similarity is insufficient (e.g. Polish ↔ Korean romanization),\n    // detect bilingual layout by position and word overlap:\n    // mixed-case ≥2 words at pos 0 + ALL_CAPS ≥2 words at pos 1-2 with no shared words.\n    if (translationCandidates.length === 0 && wordCount(prePos0.text) >= 2) {\n      const pos0Words = new Set(\n        prePos0.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2)\n      );\n      translationCandidates = nearbyAllCaps.filter((cap) => {\n        if (wordCount(cap.text) < 2) return false;\n        const capWords = cap.text.toLowerCase().split(/\\s+/).filter((w) => w.length > 2);\n        return !capWords.some((w) => pos0Words.has(w));\n      });\n    }\n\n    if (translationCandidates.length > 0) {\n      // Suppress standalone translations and any multi-line joins that embed the translation\n      // as a suffix or substring (e.g. \"Smażona zielona fasolka GREEN BEANS BORKEUM\" ends with\n      // the translation; \"Title GREEN BEANS BORKEUM 그린빈\" includes it as a substring).\n      scoredForThreshold = scored.filter((s) => {\n        const sLower = s.text.toLowerCase();\n        return !translationCandidates.some((t) => {\n          const tLower = t.text.toLowerCase();\n          return sLower.startsWith(tLower) ||\n                 sLower.endsWith(\" \" + tLower) ||\n                 sLower.includes(\" \" + tLower);\n        });\n      });\n    }\n  }\n\n  // Fix 2: If the structural heading was identified as a bilingual translation, reassign it.\n  // This prevents the translation's ALL_CAPS bonus from inflating the threshold and ensures\n  // the fallback path in scored also uses the correct heading.\n  if (\n    translationCandidates.length > 0 &&\n    firstStructuralHeading &&\n    translationCandidates.some((t) => t.text === firstStructuralHeading!.text)\n  ) {\n    const nonTranslationStructural = structuralCandidates.filter(\n      (sc) => !translationCandidates.some((t) => t.text === sc.text)\n    );\n    const newHeading = nonTranslationStructural.length > 0\n      ? nonTranslationStructural.reduce((a, b) => a.rawScore > b.rawScore ? a : b)\n      : undefined;\n\n    // Patch scored array: remove old structural bonus, apply new one\n    for (const s of scored) {\n      if (s.text === firstStructuralHeading.text) {\n        s.score -= 0.10;\n        s.baseScore -= 0.10;\n      }\n      if (newHeading && s.text === newHeading.text) {\n        s.score += 0.10;\n        s.baseScore += 0.10;\n      }\n    }\n    // Update reference for downstream prefix-removal logic\n    firstStructuralHeading = newHeading ?? undefined;\n  }\n\n  // Subtitle suppression: when a short mixed-case title at position 0 is followed by a\n  // longer mixed-case candidate at position 1-2, the longer one is a subtitle/translation.\n  // Apply a penalty so the primary title (position 0) wins.\n  const pos0Primary = scored.find((s) => s.position === 0 && !isAllCaps(s.text) && wordCount(s.text) <= 5);\n  if (pos0Primary) {\n    const subtitleCandidates = scored.filter((s) =>\n      s.position >= 1 && s.position <= 2 &&\n      !isAllCaps(s.text) &&\n      wordCount(s.text) > wordCount(pos0Primary.text) + 2\n    );\n    for (const sub of subtitleCandidates) {\n      sub.score -= 0.15;\n    }\n  }\n\n  // Bilingual layout pattern: [FoodName (≤2 words)]\\n[Translation (2-5 words, mixed-case)]\\n...[Section label]\n  // Common in bilingual cookbooks: foreign food name at position 0, English translation at position 1-2.\n  // When detected, boost the position-0 candidate so it clears the threshold.\n  // Note: the ALL_CAPS bilingual block above (lines 940-995) handles mixed-case + ALL_CAPS pairs.\n  // This block handles mixed-case + mixed-case translation pairs — the two do not overlap because\n  // the mixed-case guard (`biSecond.text !== biSecond.text.toUpperCase()`) excludes ALL_CAPS lines.\n  if (scored.length >= 2) {\n    const biFirst = scored.find((s) => s.position === 0);\n    // Restrict to single-line candidates (same guard as the ALL_CAPS bilingual block at line 953)\n    const biSecond = scored.find((s) => s.position >= 1 && s.position <= 2 && s !== biFirst && s.origin === \"single\");\n\n    if (biFirst && biSecond) {\n      const firstWords = biFirst.text.trim().split(/\\s+/);\n      const secondWords = biSecond.text.trim().split(/\\s+/);\n\n      const isBilingualLayout =\n        firstWords.length <= 2 &&\n        secondWords.length >= 2 &&\n        secondWords.length <= 5 &&\n        // Second line is mixed-case (not ALL_CAPS, not all-lower)\n        biSecond.text !== biSecond.text.toUpperCase() &&\n        biSecond.text !== biSecond.text.toLowerCase() &&\n        // Second line is not an ingredient or instruction\n        !looksLikeIngredient(biSecond.text) &&\n        !looksLikeCookingInstruction(biSecond.text);\n\n      if (isBilingualLayout) {\n        // Check if a section label follows within a few lines after the first candidate\n        const sectionLabelNearby = lines\n          .slice(biFirst.position + 1, biFirst.position + 6)\n          .some((line) => isSectionLabel(line.trim()));\n\n        if (sectionLabelNearby) {\n          biFirst.score += 0.15;\n          biFirst.baseScore += 0.15;\n          biFirst.thresholdScore += 0.15;\n        }\n      }\n    }\n  }\n\n  // Pre-filter: when ≥2 ALL_CAPS candidates are present, identify OCR artifacts (those whose\n  // vocabulary has no support elsewhere in the document) and remove them before computing the\n  // threshold. Artifacts like \"DAT FLATBREADS\" can inflate the threshold via their early-position\n  // bonus, which causes legitimate titles later in the document to fall just below the cutoff.\n  // Safety: only pre-filter if ≥2 candidates remain after removal (avoids false-positive removal\n  // of unique-vocabulary titles on two-recipe pages).\n  // NOTE: The ≥2 guard is conservative — when there are exactly 2 ALL_CAPS candidates and one is\n  // an artifact, the artifact is NOT removed. Relaxing to ≥1 causes regressions because 3-line\n  // join candidates (which span a section label) can pass corroboration via shared vocabulary,\n  // while the legitimate short title fails. See \"WORD ONE / INGREDIENTS / WORD TWO\" test case.\n  const allCapsInScored = scoredForThreshold.filter((s) => isAllCaps(s.text));\n  if (allCapsInScored.length >= 2) {\n    const artifactTexts = new Set(\n      allCapsInScored\n        .filter((cap) => !passesCorroboration(cap.text, cap.position, lines, burstEnd))\n        .map((c) => c.text)\n    );\n    if (artifactTexts.size > 0) {\n      const remainingCaps = allCapsInScored.filter((c) => !artifactTexts.has(c.text));\n      if (remainingCaps.length >= 2) {\n        scoredForThreshold = scoredForThreshold.filter((s) => !artifactTexts.has(s.text));\n      }\n    }\n  }\n\n  // Use thresholdScore (excludes structural bonus) so the structural bonus doesn't inflate\n  // the threshold and block equally-valid headings on multi-recipe pages.\n  const bestThresholdScore = Math.max(...scoredForThreshold.map((s) => s.thresholdScore));\n  const threshold = Math.max(0.08, bestThresholdScore * 0.7);\n\n  // Filter candidates above threshold\n  let selected = scoredForThreshold.filter((s) => s.score >= threshold);\n\n  // Empty-pool fallback: when threshold filtering discards every candidate,\n  // the hard filters' structural verdict should not be overruled by weak\n  // embedding differentiation. Return the best positional candidate only\n  // if it has a meaningful positive raw score (avoids ingredient-list leakage).\n  if (selected.length === 0 && scored.length > 0) {\n    const fallback = scored\n      .slice()\n      .sort((a, b) => a.position - b.position || b.score - a.score);\n    // Position-0 candidates that passed hard filters are very likely titles even with\n    // weak embedding signal. Relax the rawScore guard for early-position candidates.\n    const rawScoreThreshold = fallback[0].position <= 2 ? -0.05 : 0.02;\n    if (fallback[0].rawScore > rawScoreThreshold) {\n      selected = [fallback[0]];\n    }\n  }\n\n  // Title-absent page guard: when the page starts mid-recipe (all of the first 3 non-empty\n  // lines are ingredients or cooking instructions), require a much higher rawScore and\n  // discard candidates deep in the file. This prevents stray body text or adjacent recipe\n  // titles from being picked up on pages with no title (Pattern 4).\n  if (titleAbsent) {\n    const titleAbsentThreshold = 0.10;\n    selected = selected.filter(s => s.rawScore >= titleAbsentThreshold);\n    selected = selected.filter(s => s.position <= 2);\n  }\n","numLines":200,"startLine":1250,"totalLines":1723}}}
