th === 1 && /[a-z][A-Z]/.test(t.trim()) && !/^(Mc|Mac)[A-Z]/.test(t.trim())) return true;\n  if (/^[a-z]/.test(t.trim())) return true;\n  if (/\\.\\s+[a-zA-Z]/.test(t.trim()) && !t.trim().endsWith(\")\")) return true;\n  if (words.length >= 2) {\n    const commonShort2 = new Set([\"a\",\"i\",\"of\",\"or\",\"to\",\"in\",\"on\",\"is\",\"it\",\"an\",\"as\",\"at\",\"by\",\"do\",\"go\",\"if\",\"no\",\"so\",\"up\",\"we\",\"w\",\"z\",\"ze\",\"bo\",\"na\",\"ni\",\"po\",\"ku\",\"od\",\"za\",\"co\"]);\n    const hasGarbledWord = words.some(w => /^[a-z]/.test(w) && w.replace(/[^a-z]/g, \"\").length <= 2 && !commonShort2.has(w.toLowerCase()));\n    if (hasGarbledWord) return true;\n    const hasGarbledCamelCase = words.some(w => w.length >= 3 && w.length <= 7 && /[a-z][A-Z]/.test(w) && !/^(Mc|Mac)[A-Z]/.test(w));\n    if (hasGarbledCamelCase) return true;\n  }\n  return false;\n}\n\n// Check line 0 garbled status\nconst line0 = nonEmptyLines[0].text;\nconsole.log(\"Line 0:\", JSON.stringify(line0));\nconsole.log(\"Line 0 length:\", line0.length);\nconsole.log(\"Line 0 garbled:\", isLikelyGarbled(line0));\nconsole.log(\"Line 0 allcaps:\", isAllCaps(line0));\n\n// Check the garbled multi-word checks\nconst words0 = line0.trim().split(/\\s+/);\nconsole.log(\"Words:\", words0);\nconst commonShort2 = new Set([\"a\",\"i\",\"of\",\"or\",\"to\",\"in\",\"on\",\"is\",\"it\",\"an\",\"as\",\"at\",\"by\",\"do\",\"go\",\"if\",\"no\",\"so\",\"up\",\"we\",\"w\",\"z\",\"ze\",\"bo\",\"na\",\"ni\",\"po\",\"ku\",\"od\",\"za\",\"co\"]);\nfor (const w of words0) {\n  const isLower = /^[a-z]/.test(w);\n  const shortLen = w.replace(/[^a-z]/g, \"\").length;\n  const isCommon = commonShort2.has(w.toLowerCase());\n  if (isLower) {\n    console.log(`  \"${w}\": lowercase start, pure-lower-len=${shortLen}, common=${isCommon}`);\n  }\n}\n\n// Check the looksLikeCookingInstruction for line 0\nconst COOKING_INSTRUCTION_STARTS = /^(beat|fold|stir|mix|add|pour|bake|cook|cool|remove|place|combine|whisk|knead|rol