{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0119S9MzHvbfsfyt7MmgejVt","type":"tool_result","content":"   450→}\n   451→\n   452→/**\n   453→ * Detect initial burst of short garbled lines.\n   454→ * Returns the index of the first non-garbled or long line.\n   455→ */\n   456→function findBurstEnd(lines: Array<{ text: string }>): number {\n   457→  let i = 0;\n   458→\n   459→  // Skip overflow preambles: blocks introduced by \"PREVIOUS RECIPE OVERFLOW\",\n   460→  // \"PREVIOUS PAGE CONTENT\", \"CORRUPTED SECTION\", etc. that precede the actual recipe.\n   461→  const OVERFLOW_MARKERS = /\\b(PREVIOUS\\s+(RECIPE|PAGE)\\b|SPILLOVER|CONTINUATION|CORRUPTED\\s+(SECTION|TEXT)\\b|PARTIAL\\s+RECIPE)\\b/i;\n   462→  let overflowEnd = 0;\n   463→  for (let k = 0; k < lines.length && k < 30; k++) {\n   464→    // Don't re-examine lines already determined to be overflow\n   465→    if (overflowEnd > 0 && k < overflowEnd) continue;\n   466→    if (OVERFLOW_MARKERS.test(lines[k].text) || /^\\[.*\\b(PREVIOUS|CORRUPTED|SPILLOVER|CONTINUATION|PARTIAL)\\b.*\\]$/i.test(lines[k].text)) {\n   467→      // Skip forward past the overflow block to the next visual separator or blank cluster\n   468→      let m = k + 1;\n   469→      let consecutiveBlanks = 0;\n   470→      while (m < lines.length) {\n   471→        const lineText = lines[m].text;\n   472→        // Stop at visual separator\n   473→        if (/^[=\\-]{4,}$/.test(lineText)) {\n   474→          overflowEnd = m + 1;\n   475→          break;\n   476→        }\n   477→        // Track consecutive blank lines\n   478→        if (lineText.trim().length === 0) {\n   479→          consecutiveBlanks++;\n   480→          if (consecutiveBlanks >= 2) {\n   481→            overflowEnd = m + 1;\n   482→            break;\n   483→          }\n   484→        } else {\n   485→          consecutiveBlanks = 0;\n   486→          // Stop at ALL_CAPS line with ≥2 words (likely next recipe heading)\n   487→          if (isAllCaps(lineText) && wordCount(lineText) >= 2) {\n   488→            overflowEnd = m; // Don't skip past the heading itself\n   489→            break;\n   490→          }\n   491→        }\n   492→        m++;\n   493→      }\n   494→      // If we walked to end without finding termination, skip everything we saw\n   495→      if (overflowEnd === 0) overflowEnd = m;\n   496→    }\n   497→  }\n   498→  if (overflowEnd > 0) i = overflowEnd;\n   499→\n   500→  while (i < lines.length && lines[i].text.length < 20 && isLikelyGarbled(lines[i].text) && !isAllCaps(lines[i].text)) {\n   501→    i++;\n   502→  }\n   503→  // Skip body-content prologues: when 3+ consecutive lines at the start are cooking\n   504→  // instructions, prose continuations, or a mix of both, skip them to find the actual\n   505→  // title region. This unifies the previous separate instruction and prose checks to\n   506→  // handle interleaved patterns (e.g., instruction → prose continuation → instruction).\n   507→  if (i === 0) {\n   508→    let j = 0;\n   509→    while (j < lines.length) {\n   510→      const t = lines[j].text;\n   511→      const isInstruction = looksLikeCookingInstruction(t);\n   512→      // Short body-text continuation: lowercase-start with 2+ words catches fragments\n   513→      // like \"creamy but still al dente...\" that follow cooking instructions.\n   514→      // Lower threshold than isBodyProse (2 vs 4 words) to handle interleaved patterns.\n   515→      const isContinuation = /^[a-ząćęłńóśźż]/.test(t) && wordCount(t) >= 2;\n   516→      // Non-lowercase body text: comma-ending or long sentence-ending lines\n   517→      const isBodyEnding = (t.endsWith(\",\") || (t.endsWith(\".\") && wordCount(t) > 4)) && wordCount(t) >= 4;\n   518→\n   519→      if (isInstruction || isContinuation || isBodyEnding) {\n   520→        j++;\n   521→      } else {\n   522→        break;\n   523→      }\n   524→    }\n   525→    if (j >= 3) {\n   526→      i = j;\n   527→    }\n   52