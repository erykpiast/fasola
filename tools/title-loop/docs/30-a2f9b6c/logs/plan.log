{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0192DB58K3UjKzJoVQsx8pEQ","type":"tool_result","content":"  1050→  // Cache reference embeddings\n  1051→  if (!cachedTitleRefEmbedding) {\n  1052→    cachedTitleRefEmbedding = await embed(TITLE_REFERENCE);\n  1053→  }\n  1054→  if (!cachedHeaderRefEmbedding) {\n  1055→    cachedHeaderRefEmbedding = await embed(HEADER_REFERENCE);\n  1056→  }\n  1057→  if (!cachedNoiseRefEmbedding) {\n  1058→    cachedNoiseRefEmbedding = await embed(NOISE_REFERENCE);\n  1059→  }\n  1060→\n  1061→  // Find ALL_CAPS candidates with ≥2 words where every significant word has ≥4 alpha letters.\n  1062→  // Insignificant tokens (≤1 alpha letter: \"/\", \"&\", \"+\", \":\", \"D)\", etc.) are filtered before\n  1063→  // the check so that multi-line joins with continuation punctuation still qualify.\n  1064→  const isStructuralHeading = (c: { text: string }): boolean => {\n  1065→    if (!isAllCaps(c.text) || wordCount(c.text) < 2) return false;\n  1066→    const sigWords = c.text.trim().split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length > 1);\n  1067→    return sigWords.length >= 2 && sigWords.every((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n  1068→  };\n  1069→\n  1070→  // Pass 1: compute rawScore for all candidates (embedding quality signal)\n  1071→  const rawScored: Array<{ text: string; position: number; origin: CandidateOrigin; rawScore: number; embedding: Array<number> }> = [];\n  1072→  for (const candidate of candidates) {\n  1073→    const embedding = await embed(candidate.text);\n  1074→    const titleSim = cosineSimilarity(embedding, cachedTitleRefEmbedding);\n  1075→    const headerSim = cosineSimilarity(embedding, cachedHeaderRefEmbedding);\n  1076→    const noiseSim = cosineSimilarity(embedding, cachedNoiseRefEmbedding);\n  1077→    const rawScore = titleSim - Math.max(headerSim, noiseSim);\n  1078→    rawScored.push({ text: candidate.text, position: candidate.position, origin: candidate.origin, rawScore, embedding });\n  1079→  }\n  1080→\n  1081→  // Select baseHeading by embedding quality (rawScore), not position.\n  1082→  // This prevents OCR-garbled fragments from claiming the structural heading slot.\n  1083→  const structuralCandidates = rawScored.filter((s) => isStructuralHeading(s));\n  1084→\n  1085→  // Penalize structural headings with truncated OCR words:\n  1086→  // if \"FRON\" appears and another heading has \"SAFFRON\", \"FRON\" is likely garbled.\n  1087→  for (const sc of structuralCandidates) {\n  1088→    const sigWords = sc.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n  1089→    for (const other of structuralCandidates) {\n  1090→      if (other === sc) continue;\n  1091→      const otherSigWords = other.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n  1092→      const hasTruncation = sigWords.some((w) =>\n  1093→        otherSigWords.some((ow) => ow !== w && ow.length > w.length && ow.endsWith(w))\n  1094→      );\n  1095→      if (hasTruncation) {\n  1096→        sc.rawScore = -1.0;  // Hard disqualification — truncated OCR artifact\n  1097→        break;\n  1098→      }\n  1099→    }\n  1100→  }\n  1101→\n  1102→  const bestStructural = structuralCandidates.length > 0\n  1103→    ? structuralCandidates.reduce((a, b) => {\n  1104→        const scoreDiff = a.rawScore - b.rawScore;\n  1105→        if (Math.abs(scoreDiff) > 0.03) return scoreDiff > 0 ? a : b;\n  1106→        // Tiebreak: single-line origin beats multi-line joins (avoids conflating two separate headings)\n  1107→        if (a.origin === \"single\" && b.origin !== \"single\") return a;\n  1108→        if (b.origin === \"single\" && a.origin !== \"single\") return b;\n  1109→        // Tiebreak: more words (more specific) → better\n  1110→        const wcDiff = wordCount(b.text) - wordCount(a.text);\n  1111→        if (wcDiff !== 0) return wcDiff > 0 ? b : a;\n  1112→        // Tiebreak: earlier position → better\n  1113→        return a.position < b.position ? a : b;\n  1114→      })\n  1115→    : null;\n  1116→  const baseHeading = bestStructural ?? undefined;\n  1117→\n  1118→  // When the best structural heading has a continuation on the next line introduced by a\n  1119→  // punctuation token (/, &, +, :, or parenthesis), prefer the longer 2-line join as the\n  1120→  // complete heading. E.g. \"SAFFRON WHEAT BUNS WITH QUARK\" + \"/ COTTAGE CHEESE (VARIATION D)\".\n  1121→  // Guard: the remainder after the prefix must start with a continuation character to avoid\n  1122→  // merging two separate consecutive recipe titles (FINNISH MILK FLATBREADS stays separate\n  1123→  // from FINNISH POTATO FLATBREADS because \"FINNISH\" does not start with a continuation token).\n  1124→  let firstStructuralHeading = baseHeading && (\n  1125→    rawScored.find((c) => {\n  1126→      if (!isStructuralHeading(c)) return false;\n  1127→      const hLower = baseHeading.text.toLowerCase();\n  1128→      const cLower = c.text.toLowerCase();\n  1129→      return cLower.startsWith(hLower + \" \") && /^[/&+:(]/.test(cLower.slice(hLower.length + 1));\n  1130→    }) ?? baseHeading\n  1131→  );\n  1132→\n  1133→  // Pass 2: apply bonuses\n  1134→  const scored: Array<{ text: string; position: number; origin: CandidateOrigin; score: number; rawScore: number; baseScore: number; thresholdScore: number }> = rawScored.map((rs, candidateIndex) => {\n  1135→    // Position factor: multiplicative tiebreaker — amplifies existing signal, doesn't replace it.\n  1136→    // Use candidate-relative position (rank among candidates that passed hard filters) rather than\n  1137→    // raw line position, so filtered preamble lines don't penalize the first real candidate.\n  1138→    const candidateRelativePosition = candidateIndex / rawScored.length;\n  1139→    const positionFactor = candidateRelativePosition < 0.5\n  1140→      ? 1.0 + 0.12 * (1 - candidateRelativePosition * 2)\n  1141→      : 1.0;\n  1142→\n  1143→    // ALL_CAPS bonus: recipe books use ALL_CAPS for titles and section headings.\n  1144→    // Single-word ALL_CAPS terms are overwhelmingly section/category labels, not recipe titles;\n  1145→    // real recipe titles in ALL_CAPS are almost always multi-word. Reduce the bonus for single words.\n  1146→    const allCapsBonus = isAllCaps(rs.text) && rs.text.replace(/[^a-zA-Z]/g, \"\").length >= 4\n  1147→      ? (wordCount(rs.text) >= 2 ? 0.08 : 0.03)\n  1148→      : 0;\n  1149→\n  1150→    // Structural heading bonus: best ALL_CAPS heading (or its continuation join) is almost always the recipe title\n  1151→    const structuralBonus = firstStructuralHeading && rs.text === firstStructuralHeading.text ? 0.10 : 0;\n  1152→\n  1153→    // thresholdScore excludes structural bonus so the bonus doesn't inflate the threshold\n  1154→    // and prevent equally-valid structural headings from passing on multi-recipe pages.\n  1155→    const thresholdScore = rs.rawScore + allCapsBonus;\n  1156→    // baseScore excludes position factor — used for diagnostics and ranking\n  1157→    const baseScore = rs.rawScore + allCapsBonus + structuralBonus;\n  1158→    const score = rs.rawScore * positionFactor + allCapsBonus + structuralBonus;\n  1159→    return { text: rs.text, position: rs.position, origin: rs.origin, score, rawScore: rs.rawScore, baseScore, thresholdScore };\n  1160→  });\n  1161→\n  1162→  if (scored.length === 0) {\n  1163→    return undefined;\n  1164→  }\n  1165→\n  1166→  // First-after-preamble bonus (Pattern 3): when lines before the first candidate were all\n  1167→  // filtered/empty, the first surviving candidate occupies the structural \"title position\".\n  1168→  // E.g. \"FISH & SEAFOOD\\nHalibut with Saffron Cream Sauce\\n...\" — \"FISH & SEAFOOD\" is filtered\n  1169→  // as a section label, so \"Halibut...\" is the first candidate and gets this boost.\n  1170→  const firstCandidate = scored[0];\n  1171→  // Capture base score before positional bonuses to cap combined boost later\n  1172→  let hasPipePreamble = false;\n  1173→  const baseScoreBeforePositionalBonuses = firstCandidate.baseScore;\n  1174→  if (firstCandidate.position > 0) {\n  1175→    const allPrecedingFiltered = lines\n  1176→      .slice(0, firstCandidate.position)\n  1177→      .every((line) => {\n  1178→        const trimmed = line.trim();\n  1179→        return trimmed === \"\" || !passesHardFilters(trimmed) || isSectionLabel(trimmed);\n  1180→      });\n  1181→    if (allPrecedingFiltered) {\n  1182→      // Stronger bonus when preamble contained structural markers (section labels, metadata)\n  1183→      // vs. only empty lines — structural markers are stronger positional evidence.\n  1184→      let hasStructuralPreamble = false;\n  1185→      for (const line of lines.slice(0, firstCandidate.position)) {\n  1186→        const trimmed = line.trim();\n  1187→        if (trimmed === \"\") continue;\n  1188→        if (trimmed.includes(\" | \")) {\n  1189→          hasStructuralPreamble = true;\n  1190→          hasPipePreamble = true;\n  1191→        } else if (isSectionLabel(trimmed) || looksLikeMetadata(trimmed)) {\n  1192→          hasStructuralPreamble = true;\n  1193→        }\n  1194→      }\n  1195→      const preambleBonus = hasStructuralPreamble ? 0.12 : 0.08;\n  1196→      firstCandidate.score += preambleBonus;\n  1197→      firstCandidate.baseScore += preambleBonus;\n  1198→      firstCandidate.thresholdScore += preambleBonus;\n  1199→    }\n  1200→  }\n  1201→  // Direct-successor bonus: when the line immediately before this candidate is a\n  1202→  // section label, metadata, or pipe-separated line, the candidate is very likely\n  1203→  // the title that follows that header. This complements the first-after-preamble\n  1204→  // bonus which requires ALL preceding lines to be filtered — this one fires even\n  1205→  // when earlier non-filtered lines exist. Checked for the top 3 candidates only\n  1206→  // (ci <= 2) to prevent the bonus from firing on random mid-document lines.\n  1207→  for (let ci = 0; ci < scored.length && ci <= 2; ci++) {\n  1208→    const candidate = scored[ci];\n  1209→    if (candidate.position > 0) {\n  1210→      // Scan backward past blank lines to find nearest non-empty preceding line\n  1211→      let prevPos = candidate.position - 1;\n  1212→      while (prevPos >= 0 && lines[prevPos].trim() === \"\") {\n  1213→        prevPos--;\n  1214→      }\n  1215→      if (prevPos >= 0) {\n  1216→        const prevLine = lines[prevPos].trim();\n  1217→        const prevIsHeader =\n  1218→          isSectionLabel(prevLine) ||\n  1219→          looksLikeMetadata(prevLine) ||\n  1220→          prevLine.includes(\" | \");\n  1221→        if (prevIsHeader) {\n  1222→          candidate.score += 0.10;\n  1223→          candidate.baseScore += 0.10;\n  1224→          candidate.thresholdScore += 0.10;\n  1225→        }\n  1226→      }\n  1227→    }\n  1228→  }\n  1229→\n  1230→  // Cap combined positional boost (position factor + first-after-preamble + direct-successor)\n  1231→  // to avoid over-boosting when multiple bonuses fire together. Applied after all positional\n  1232→  // bonuses so the cap covers all of them (per improvement plan: shared +0.15 max).\n  1233→  // Raise cap slightly for pipe-separated metadata followed by ALL_CAPS candidate.\n  1234→  // This is a near-certain title pattern in Polish cookbooks where MiniLM\n  1235→  // (English-centric) gives weak embedding scores for Polish ALL_CAPS text.\n  1236→  // hasPipePreamble is set above inside the allPrecedingFiltered block, so it is\n  1237→  // only true when the preamble-bonus logic also fired (consistent gating).\n  1238→  const maxPositionalBoost =\n  1239→    hasPipePreamble && isAllCaps(firstCandidate.text) ? 0.18 : 0.15;\n  1240→  const totalPositionalBoost = firstCandidate.score - baseScoreBeforePositionalBonuses;\n  1241→  if (totalPositionalBoost > maxPositionalBoost) {\n  1242→    const excess = totalPositionalBoost - maxPositionalBoost;\n  1243→    firstCandidate.score -= excess;\n  1244→    firstCandidate.baseScore -= excess;\n  1245→    firstCandidate.thresholdScore -= excess;\n  1246→  }\n  1247→\n  1248→  // --- Pre-threshold bilingual title detection ---\n  1249→  // When a mixed-case candidate at position 0 is followed by an ALL_CAPS candidate"}]},"parent_tool_use_id":null,"session_id":"8a56c14a-0bc6-452a-98e5-f30796680f9b","uuid":"a9729c62-6995-47e4-ba77-39c8b1de5ca7","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/title-extractor.ts","content":"  // Cache reference embeddings\n  if (!cachedTitleRefEmbedding) {\n    cachedTitleRefEmbedding = await embed(TITLE_REFERENCE);\n  }\n  if (!cachedHeaderRefEmbedding) {\n    cachedHeaderRefEmbedding = await embed(HEADER_REFERENCE);\n  }\n  if (!cachedNoiseRefEmbedding) {\n    cachedNoiseRefEmbedding = await embed(NOISE_REFERENCE);\n  }\n\n  // Find ALL_CAPS candidates with ≥2 words where every significant word has ≥4 alpha letters.\n  // Insignificant tokens (≤1 alpha letter: \"/\", \"&\", \"+\", \":\", \"D)\", etc.) are filtered before\n  // the check so that multi-line joins with continuation punctuation still qualify.\n  const isStructuralHeading = (c: { text: string }): boolean => {\n    if (!isAllCaps(c.text) || wordCount(c.text) < 2) return false;\n    const sigWords = c.text.trim().split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length > 1);\n    return sigWords.length >= 2 && sigWords.every((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n  };\n\n  // Pass 1: compute rawScore for all candidates (embedding quality signal)\n  const rawScored: Array<{ text: string; position: number; origin: CandidateOrigin; rawScore: number; embedding: Array<number> }> = [];\n  for (const candidate of candidates) {\n    const embedding = await embed(candidate.text);\n    const titleSim = cosineSimilarity(embedding, cachedTitleRefEmbedding);\n    const headerSim = cosineSimilarity(embedding, cachedHeaderRefEmbedding);\n    const noiseSim = cosineSimilarity(embedding, cachedNoiseRefEmbedding);\n    const rawScore = titleSim - Math.max(headerSim, noiseSim);\n    rawScored.push({ text: candidate.text, position: candidate.position, origin: candidate.origin, rawScore, embedding });\n  }\n\n  // Select baseHeading by embedding quality (rawScore), not position.\n  // This prevents OCR-garbled fragments from claiming the structural heading slot.\n  const structuralCandidates = rawScored.filter((s) => isStructuralHeading(s));\n\n  // Penalize structural headings with truncated OCR words:\n  // if \"FRON\" appears and another heading has \"SAFFRON\", \"FRON\" is likely garbled.\n  for (const sc of structuralCandidates) {\n    const sigWords = sc.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n    for (const other of structuralCandidates) {\n      if (other === sc) continue;\n      const otherSigWords = other.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n      const hasTruncation = sigWords.some((w) =>\n        otherSigWords.some((ow) => ow !== w && ow.length > w.length && ow.endsWith(w))\n      );\n      if (hasTruncation) {\n        sc.rawScore = -1.0;  // Hard disqualification — truncated OCR artifact\n        break;\n      }\n    }\n  }\n\n  const bestStructural = structuralCandidates.length > 0\n    ? structuralCandidates.reduce((a, b) => {\n        const scoreDiff = a.rawScore - b.rawScore;\n        if (Math.abs(scoreDiff) > 0.03) return scoreDiff > 0 ? a : b;\n        // Tiebreak: single-line origin beats multi-line joins (avoids conflating two separate headings)\n        if (a.origin === \"single\" && b.origin !== \"single\") return a;\n        if (b.origin === \"single\" && a.origin !== \"single\") return b;\n        // Tiebreak: more words (more specific) → better\n        const wcDiff = wordCount(b.text) - wordCount(a.text);\n        if (wcDiff !== 0) return wcDiff > 0 ? b : a;\n        // Tiebreak: earlier position → better\n        return a.position < b.position ? a : b;\n      })\n    : null;\n  const baseHeading = bestStructural ?? undefined;\n\n  // When the best structural heading has a continuation on the next line introduced by a\n  // punctuation token (/, &, +, :, or parenthesis), prefer the longer 2-line join as the\n  // complete heading. E.g. \"SAFFRON WHEAT BUNS WITH QUARK\" + \"/ COTTAGE CHEESE (VARIATION D)\".\n  // Guard: the remainder after the prefix must start with a continuation character to avoid\n  // merging two separate consecutive recipe titles (FINNISH MILK FLATBREADS stays separate\n  // from FINNISH POTATO FLATBREADS because \"FINNISH\" does not start with a continuation token).\n  let firstStructuralHeading = baseHeading && (\n    rawScored.find((c) => {\n      if (!isStructuralHeading(c)) return false;\n      const hLower = baseHeading.text.toLowerCase();\n      const cLower = c.text.toLowerCase();\n      return cLower.startsWith(hLower + \" \") && /^[/&+:(]/.test(cLower.slice(hLower.length + 1));\n    }) ?? baseHeading\n  );\n\n  // Pass 2: apply bonuses\n  const scored: Array<{ text: string; position: number; origin: CandidateOrigin; score: number; rawScore: number; baseScore: number; thresholdScore: number }> = rawScored.map((rs, candidateIndex) => {\n    // Position factor: multiplicative tiebreaker — amplifies existing signal, doesn't replace it.\n    // Use candidate-relative position (rank among candidates that passed hard filters) rather than\n    // raw line position, so filtered preamble lines don't penalize the first real candidate.\n    const candidateRelativePosition = candidateIndex / rawScored.length;\n    const positionFactor = candidateRelativePosition < 0.5\n      ? 1.0 + 0.12 * (1 - candidateRelativePosition * 2)\n      : 1.0;\n\n    // ALL_CAPS bonus: recipe books use ALL_CAPS for titles and section headings.\n    // Single-word ALL_CAPS terms are overwhelmingly section/category labels, not recipe titles;\n    // real recipe titles in ALL_CAPS are almost always multi-word. Reduce the bonus for single words.\n    const allCapsBonus = isAllCaps(rs.text) && rs.text.replace(/[^a-zA-Z]/g, \"\").length >= 4\n      ? (wordCount(rs.text) >= 2 ? 0.08 : 0.03)\n      : 0;\n\n    // Structural heading bonus: best ALL_CAPS heading (or its continuation join) is almost always the recipe title\n    const structuralBonus = firstStructuralHeading && rs.text === firstStructuralHeading.text ? 0.10 : 0;\n\n    // thresholdScore excludes structural bonus so the bonus doesn't inflate the threshold\n    // and prevent equally-valid structural headings from passing on multi-recipe pages.\n    const thresholdScore = rs.rawScore + allCapsBonus;\n    // baseScore excludes position factor — used for diagnostics and ranking\n    const baseScore = rs.rawScore + allCapsBonus + structuralBonus;\n    const score = rs.rawScore * positionFactor + allCapsBonus + structuralBonus;\n    return { text: rs.text, position: rs.position, origin: rs.origin, score, rawScore: rs.rawScore, baseScore, thresholdScore };\n  });\n\n  if (scored.length === 0) {\n    return undefined;\n  }\n\n  // First-after-preamble bonus (Pattern 3): when lines before the first candidate were all\n  // filtered/empty, the first surviving candidate occupies the structural \"title position\".\n  // E.g. \"FISH & SEAFOOD\\nHalibut with Saffron Cream Sauce\\n...\" — \"FISH & SEAFOOD\" is filtered\n  // as a section label, so \"Halibut...\" is the first candidate and gets this boost.\n  const firstCandidate = scored[0];\n  // Capture base score before positional bonuses to cap combined boost later\n  let hasPipePreamble = false;\n  const baseScoreBeforePositionalBonuses = firstCandidate.baseScore;\n  if (firstCandidate.position > 0) {\n    const allPrecedingFiltered = lines\n      .slice(0, firstCandidate.position)\n      .every((line) => {\n        const trimmed = line.trim();\n        return trimmed === \"\" || !passesHardFilters(trimmed) || isSectionLabel(trimmed);\n      });\n    if (allPrecedingFiltered) {\n      // Stronger bonus when preamble contained structural markers (section labels, metadata)\n      // vs. only empty lines — structural markers are stronger positional evidence.\n      let hasStructuralPreamble = false;\n      for (const line of lines.slice(0, firstCandidate.position)) {\n        const trimmed = line.trim();\n        if (trimmed === \"\") continue;\n        if (trimmed.includes(\" | \")) {\n          hasStructuralPreamble = true;\n          hasPipePreamble = true;\n        } else if (isSectionLabel(trimmed) || looksLikeMetadata(trimmed)) {\n          hasStructuralPreamble = true;\n        }\n      }\n      const preambleBonus = hasStructuralPreamble ? 0.12 : 0.08;\n      firstCandidate.score += preambleBonus;\n      firstCandidate.baseScore += preambleBonus;\n      firstCandidate.thresholdScore += preambleBonus;\n    }\n  }\n  // Direct-successor bonus: when the line immediately before this candidate is a\n  // section label, metadata, or pipe-separated line, the candidate is very likely\n  // the title that follows that header. This complements the first-after-preamble\n  // bonus which requires ALL preceding lines to be filtered — this one fires even\n  // when earlier non-filtered lines exist. Checked for the top 3 candidates only\n  // (ci <= 2) to prevent the bonus from firing on random mid-document lines.\n  for (let ci = 0; ci < scored.length && ci <= 2; ci++) {\n    const candidate = scored[ci];\n    if (candidate.position > 0) {\n      // Scan backward past blank lines to find nearest non-empty preceding line\n      let prevPos = candidate.position - 1;\n      while (prevPos >= 0 && lines[prevPos].trim() === \"\") {\n        prevPos--;\n      }\n      if (prevPos >= 0) {\n        const prevLine = lines[prevPos].trim();\n        const prevIsHeader =\n          isSectionLabel(prevLine) ||\n          looksLikeMetadata(prevLine) ||\n          prevLine.includes(\" | \");\n        if (prevIsHeader) {\n          candidate.score += 0.10;\n          candidate.baseScore += 0.10;\n          candidate.thresholdScore += 0.10;\n        }\n      }\n    }\n  }\n\n  // Cap combined positional boost (position factor + first-after-preamble + direct-successor)\n  // to avoid over-boosting when multiple bonuses fire together. Applied after all positional\n  // bonuses so the cap covers all of them (per improvement plan: shared +0.15 max).\n  // Raise cap slightly for pipe-separated metadata followed by ALL_CAPS candidate.\n  // This is a near-certain title pattern in Polish cookbooks where MiniLM\n  // (English-centric) gives weak embedding scores for Polish ALL_CAPS text.\n  // hasPipePreamble is set above inside the allPrecedingFiltered block, so it is\n  // only true when the preamble-bonus logic also fired (consistent gating).\n  const maxPositionalBoost =\n    hasPipePreamble && isAllCaps(firstCandidate.text) ? 0.18 : 0.15;\n  const totalPositionalBoost = firstCandidate.score - baseScoreBeforePositionalBonuses;\n  if (totalPositionalBoost > maxPositionalBoost) {\n    const excess = totalPositionalBoost - maxPositionalBoost;\n    firstCandidate.score -= excess;\n    firstCandidate.baseScore -= excess;\n    firstCandidate.thresholdScore -= excess;\n  }\n\n  // --- Pre-threshold bilingual title detection ---\n  // When a mixed-case candidate at position 0 is followed by an ALL_CAPS candidate","numLines":200,"startLine":1050,"totalLines":1723}}}
