{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DpmcbRL63X2tjRhnaqcgTN","type":"tool_result","content":"  1512→  // Remove pre-merged continuation prefix singles: buildCandidates now emits both the original\n  1513→  // standalone line AND the pre-merged continuation form (both single origin). The standalone\n  1514→  // prefix must be suppressed when the longer merged form also survived the threshold.\n  1515→  // Example: \"Baked Eggs with Feta, Harissa Tomato Sauce\" (standalone) gets removed when\n  1516→  //          \"Baked Eggs with Feta, Harissa Tomato Sauce & Coriander\" (pre-merged) is present.\n  1517→  selected = selected.filter((s) => {\n  1518→    if (s.origin !== \"single\") return true;\n  1519→    const sLower = s.text.toLowerCase();\n  1520→    // Remove s if a longer single candidate exists that is a continuation extension of s\n  1521→    return !selected.some((other) => {\n  1522→      if (other === s || other.origin !== \"single\") return false;\n  1523→      const oLower = other.text.toLowerCase();\n  1524→      if (!oLower.startsWith(sLower + \" \")) return false;\n  1525→      const remainder = oLower.slice(sLower.length + 1);\n  1526→      return /^[/&+:(]/.test(remainder);\n  1527→    });\n  1528→  });\n  1529→\n  1530→  // Pre-dedup: remove sub-section headers that are substrings of other surviving candidates.\n  1531→  // A sub-section header is an ALL_CAPS candidate followed by ingredient-like lines in the source.\n  1532→  // Example: \"CHLEBEK\" (bread section header, followed by \"500 g mąki\") is a substring of\n  1533→  // \"CHLEBEK Z WARZYWAMI I BOCZKIEM\" (the real title). Without this filter, dedup kills the title.\n  1534→  selected = selected.filter((candidate) => {\n  1535→    if (!isAllCaps(candidate.text)) return true;\n  1536→    // Check if this candidate is immediately followed by ingredient-like content\n  1537→    const nextSourceLines = lines.slice(candidate.position + 1, candidate.position + 2);\n  1538→    const followedByIngredients = nextSourceLines.some(\n  1539→      (l) => looksLikeIngredient(l.trim()) || startsWithNumber(l.trim())\n  1540→    );\n  1541→    if (!followedByIngredients) return true;\n  1542→    // Only remove if a longer candidate contains this one as a substring\n  1543→    const candidateLower = candidate.text.toLowerCase();\n  1544→    const hasLongerParent = rawScored.some(\n  1545→      (other) =>\n  1546→        other.text !== candidate.text &&\n  1547→        other.text.length > candidate.text.length &&\n  1548→        other.text.toLowerCase().includes(candidateLower)\n  1549→    );\n  1550→    return !hasLongerParent;\n  1551→  });"}]},"parent_tool_use_id":"toolu_01GGSMyoXVHYzdjtsDxebzpc","session_id":"cda1f0b1-248e-469a-8a6a-1e44556e08de","uuid":"e1b4037e-031a-442b-aa19-52a62c5dbdf3"}
