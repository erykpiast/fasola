wo separate headings)\n  1118→        if (a.origin === \"single\" && b.origin !== \"single\") return a;\n  1119→        if (b.origin === \"single\" && a.origin !== \"single\") return b;\n  1120→        // Tiebreak: more words (more specific) → better\n  1121→        const wcDiff = wordCount(b.text) - wordCount(a.text);\n  1122→        if (wcDiff !== 0) return wcDiff > 0 ? b : a;\n  1123→        // Tiebreak: earlier position → better\n  1124→        return a.position < b.position ? a : b;\n  1125→      })\n  1126→    : null;\n  1127→  const baseHeading = bestStructural ?? undefined;\n  1128→\n  1129→  // When the best structural heading has a continuation on the next line introduced by a\n  1130→  // punctuation token (/, &, +, :, or parenthesis), prefer the longer 2-line join as the\n  1131→  // complete heading. E.g. \"SAFFRON WHEAT BUNS WITH QUARK\" + \"/ COTTAGE CHEESE (VARIATION D)\".\n  1132→  // Guard: the remainder after the prefix must start with a continuation character to avoid\n  1133→  // merging two separate consecutive recipe titles (FINNISH MILK FLATBREADS stays separate\n  1134→  // from FINNISH POTATO FLATBREADS because \"FINNISH\" does not start with a continuation token).\n  1135→  let firstStructuralHeading = baseHeading && (\n  1136→    rawScored.find((c) => {\n  1137→      if (!isStructuralHeading(c)) return false;\n  1138→      const hLower = baseHeading.text.toLowerCase();\n  1139→      const cLower = c.text.toLowerCase();\n  1140→      return cLower.startsWith(hLower + \" \") && /^[/&+:(]/.test(cLower.slice(hLower.length + 1));\n  1141→    }) ?? baseHeading\n  1142→  );\n  1143→\n  1144→  // Pass 2: apply bonuses\n  1145→  const scored: Array<{ text: string; position: number; origin: CandidateOrigin; score: number; rawScore: number; baseScore: number; thresholdScore: number }> = rawScored.map((rs, candidateIndex) => {\n  1146→    // Position factor: multiplicative tiebreaker — amplifies existing signal, doesn't replace it.\n  1147→    // Use