{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01P4wCEicx5NCSvFji1tHfVz","type":"tool_result","content":"  1455→  if (titleAbsent) {\n  1456→    const titleAbsentThreshold = 0.10;\n  1457→    selected = selected.filter(s => s.rawScore >= titleAbsentThreshold);\n  1458→    selected = selected.filter(s => s.position <= 2);\n  1459→  }\n  1460→\n  1461→  // Remove word-boundary prefixes of firstStructuralHeading when the heading itself survived\n  1462→  // the threshold. Cases:\n  1463→  //   ARAYES case:  firstStructuralHeading = \"ARAYES SHRAK\" (2-word join qualifies; \"ARAYES\"\n  1464→  //     alone = 1 word, so it never qualified). Filter removes \"ARAYES\" so dedup keeps the join.\n  1465→  //   SAFFRON case: baseHeading was the partial line; continuation logic above upgraded\n  1466→  //     firstStructuralHeading to the full join. Filter removes the partial so dedup keeps join.\n  1467→  // Safety: only fires when the complete heading itself is in selected (passed the threshold).\n  1468→  if (firstStructuralHeading && selected.some((s) => s.text === firstStructuralHeading.text)) {\n  1469→    const fshLower = firstStructuralHeading.text.toLowerCase();\n  1470→    selected = selected.filter((s) => {\n  1471→      if (s.text === firstStructuralHeading.text) return true;\n  1472→      const sLower = s.text.toLowerCase();\n  1473→      // Remove s if it is a space-delimited prefix of the structural heading\n  1474→      return !fshLower.startsWith(sLower + \" \");\n  1475→    });\n  1476→  }\n  1477→\n  1478→  // Protect continuation joins: when a multi-line join (2-line or 3-line) survived the threshold\n  1479→  // and its second part starts with a continuation character, remove the single-line prefix/suffix\n  1480→  // so the dedup \"shorter wins\" rule doesn't destroy the complete join.\n  1481→  // Note: pre-merged single candidates (Baked Eggs case) are handled by the separate filter below\n  1482→  // (lines ~1501). This block covers the rarer case where a continuation-character join was\n  1483→  // generated as a 2-line/3-line candidate and the prefix single also survived threshold\n  1484→  // independently (e.g. from a different code path or OCR layout).\n  1485→  // Safety: only fires for joins whose continuation starts with /&+:( — digit continuations\n  1486→  // like \"Pierogi Ruskie 200g mąki\" are NOT protected, so dedup correctly keeps the shorter form.\n  1487→  const survivingJoins = selected.filter((s) => s.origin === \"2-line\" || s.origin === \"3-line\");\n  1488→  if (survivingJoins.length > 0) {\n  1489→    selected = selected.filter((s) => {\n  1490→      if (s.origin !== \"single\") return true;\n  1491→      const sLower = s.text.toLowerCase();\n  1492→      // Remove PREFIX singles whose continuation join also survived\n  1493→      const isPrefixOfJoin = survivingJoins.some((j) => {\n  1494→        const jLower = j.text.toLowerCase();\n  1495→        if (!jLower.startsWith(sLower + \" \")) return false;\n  1496→        const remainder = jLower.slice(sLower.length + 1);\n  1497→        return /^[/&+:(]/.test(remainder);\n  1498→      });\n  1499→      if (isPrefixOfJoin) return false;\n  1500→      // Remove SUFFIX singles (e.g. \"& Coriander\") whose parent join also survived\n  1501→      const isSuffixOfJoin = survivingJoins.some((j) => {\n  1502→        const jLower = j.text.toLowerCase();\n  1503→        if (!jLower.endsWith(\" \" + sLower)) return false;\n  1504→        // Only remove if the suffix starts with a continuation character\n  1505→        return /^[/&+:(]/.test(sLower);\n  1506→      });\n  1507→      if (isSuffixOfJoin) return false;\n  1508→      return true;\n  1509→    });"}]},"parent_tool_use_id":"toolu_01HsJtVqciNfVzyfHAHcqyA9","session_id":"cda1f0b1-248e-469a-8a6a-1e44556e08de","uuid":"de1295e1-8a5b-4aab-9073-4bd221688baa"}
