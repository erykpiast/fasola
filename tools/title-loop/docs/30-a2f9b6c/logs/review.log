{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VDVTQVtFjmUPjpbDB5MeKk","type":"tool_result","content":"   435→  // Lines ending with \":\" are recipe sub-section headers, not titles.\n   436→  // Exception: compound titles using \" : \" as a title separator (e.g. \"LEMON CURD : LEMON CURD WITH THYME\").\n   437→  if (/:\\s*$/.test(text.trim()) && !/ : /.test(text)) return false;\n   438→  // Page references are navigation markers, not recipe titles\n   439→  if (/^Page\\s+\\d+/i.test(text.trim())) return false;\n   440→  if (/^Strona\\s+\\d+/i.test(text.trim())) return false;\n   441→  // Corrupted spillover annotations from synthetic multi-page OCR\n   442→  if (/^\\[CORRUPTED\\s+SPILLOVER/i.test(text.trim())) return false;\n   443→  // Parenthetical OCR annotation lines describing corruption artifacts\n   444→  if (/^\\(OCR\\b/i.test(text.trim())) return false;\n   445→  if (/^\\(.*\\bcorruption\\b/i.test(text.trim())) return false;\n   446→  // Square-bracket category tags (e.g., \"[CLASSIC FALL SOUPS]\")\n   447→  if (/^\\[.*\\]$/.test(text.trim())) return false;\n   448→  // Known recipe section labels are structural headers, not titles\n   449→  if (isSectionLabel(text)) return false;\n   450→  // Single-word non-title fragments\n   451→  const words = text.trim().split(/\\s+/);\n   452→  if (words.length === 1 && NON_TITLE_WORDS.has(text.trim().toLowerCase())) return false;\n   453→  // Lines with ≥8 words are almost certainly body text, not titles.\n   454→  // Exception: multi-title compounds with \" + \", \" : \", or \" & \" separators are allowed.\n   455→  if (words.length >= 8 && !/ [+:&/] /.test(text)) return false;\n   456→  return true;\n   457→}\n   458→\n   459→/**"}]},"parent_tool_use_id":"toolu_01XjLSauSC3oNEccjMzcEMnr","session_id":"cda1f0b1-248e-469a-8a6a-1e44556e08de","uuid":"2e037a85-5788-43fe-93ec-88319110a101"}
