{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01X9MZvQiUQvckQxhzcvjRfQ","type":"tool_result","content":"     1→/**\n     2→ * Title Extraction\n     3→ * Extracts potential recipe title from OCR text using heuristics or semantic embeddings\n     4→ */\n     5→\n     6→import { cosineSimilarity } from \"./embeddings\";\n     7→import { FOOD_DICTIONARY } from \"./food-dictionary\";\n     8→\n     9→export type EmbedFn = (text: string) => Promise<Array<number>>;\n    10→\n    11→const TITLE_REFERENCE =\n    12→  \"recipe name, dish title, name of the food, nazwa przepisu, nazwa dania\";\n    13→const HEADER_REFERENCE =\n    14→  \"ingredients list, cooking directions, section heading, składniki, przygotowanie, sposób wykonania\";\n    15→const NOISE_REFERENCE =\n    16→  \"page number, table of contents, book footer, garbled text\";\n    17→\n    18→/**\n    19→ * Measurement units commonly found in ingredient lists\n    20→ */\n    21→const MEASUREMENT_PATTERNS = [\n    22→  // English\n    23→  \"cup\",\n    24→  \"cups\",\n    25→  \"tbsp\",\n    26→  \"tsp\",\n    27→  \"tablespoon\",\n    28→  \"teaspoon\",\n    29→  // \"oz\" and \"lb\" are matched with word boundaries in looksLikeIngredient\n    30→  // to avoid false positives (\"oz\" in \"mozzarella\", \"lb\" in \"albacore\")\n    31→  \"gram\",\n    32→  \"grams\",\n    33→  \"kg\",\n    34→  \"ml\",\n    35→  \"liter\",\n    36→  \"pinch\",\n    37→  \"dash\",\n    38→  \"handful\",\n    39→  // Polish\n    40→  \"łyżka\", \"łyżki\", \"łyżek\",           // tablespoon(s)\n    41→  \"łyżeczka\", \"łyżeczki\", \"łyżeczek\",   // teaspoon(s)\n    42→  \"szklanka\", \"szklanki\", \"szklanek\",    // cup(s)\n    43→  \"szczypta\",                            // pinch\n    44→  \"garść\",                               // handful\n    45→  \"opakowanie\", \"opakowania\",            // package(s)\n    46→  \"plasterek\", \"plasterki\",             // slice(s)\n    47→];\n    48→\n    49→/**\n    50→ * Patterns that identify recipe metadata lines (not titles)\n    51→ */\n    52→const METADATA_PATTERNS = [\n    53→  /^(SERVES?|MAKES?|YIELDS?)\\b/i,\n    54→  /^(PREP(ARATION)?|COOK(ING)?|PROOF|RISING|FERMENTATION|REST(ING)?)\\s*(AND\\s*)?(COOK(ING)?)?\\s*TIME/i,\n    55→  /^SAMPLE\\s+SCHEDULE\\b/i,\n    56→  /^BULK\\s+FERMENTATION\\b/i,\n    57→  /^(THIS\\s+RECIPE\\s+)?MAKES\\b/i,\n    58→  // Polish serving-size patterns: \"NA 3 PAPRYKI\", \"NA OKOŁO 1 KG\", \"DLA 4 OSÓB\"\n    59→  /^NA\\s+(\\d|OKOŁO)\\b/i,\n    60→  /^DLA\\s+\\d/i,\n    61→  // OCR-resilient: \"DLA\" + any token + serving-unit word (handles DLA & OSOB, DLA § OSOB, etc.)\n    62→  /^DLA\\s+\\S+\\s+OSOB/i,\n    63→  // OCR-resilient: \"DLA\" + single non-alphanumeric char (common digit→symbol OCR error)\n    64→  /^DLA\\s+[^a-zA-Z0-9\\s]\\s/i,\n    65→  // Time-unit metadata: any line containing \"N MIN\" or \"N GODZ\" is prep/cook/rest time,\n    66→  // regardless of OCR-corrupted prefix (catches PRZYGOTOWANTE, GOTOMANTE, etc.)\n    67→  /\\b\\d+\\s*MIN\\b/i,\n    68→  /\\b\\d+\\s*GODZ/i,\n    69→  // Season/category indicators\n    70→  /^SEZON\\s*:/i,\n    71→  /^KATEGORIA\\s*:/i,\n    72→  /^RODZAJ\\s*:/i,\n    73→  /^PORCJI\\s*:/i,       // Polish serving count\n    74→  /^PORTIONS?\\s*:/i,    // English serving count\n    75→  /^CZ[ĘE]Ś[ĆC]\\s*\\d/i,   // CZĘŚĆ 1: ... (Polish \"Part 1:\")\n    76→  /^PART\\s+\\d/i,             // PART 1: ... (English)\n    77→  /^MAIN\\s+RECIPE\\s*:/i,    // \"MAIN RECIPE: ...\" structural prefix lines\n    78→  /^--\\s*\\w/,               // \"--VARIATION:\", \"--WERSJA NOWOCZESNA\" sub-section headers\n    79→];\n    80→\n    81→/**\n    82→ * Single-word non-title words — standalone OCR fragments unlikely to be recipe titles\n    83→ */\n    84→const NON_TITLE_WORDS = new Set([\n    85→  \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"are\", \"was\",\n    86→  \"has\", \"his\", \"her\", \"its\", \"our\", \"who\", \"how\", \"may\", \"new\", \"now\",\n    87→  \"old\", \"see\", \"way\", \"did\", \"get\", \"let\", \"say\", \"she\", \"too\", \"use\",\n    88→  \"buns\", \"with\",\n    89→]);\n    90→\n    91→function looksLikeIngredient(line: string): boolean {\n    92→  const lowerLine = line.toLowerCase();\n    93→  if (MEASUREMENT_PATTERNS.some((pattern) => lowerLine.includes(pattern))) return true;\n    94→  // Compact metric: \"100g\", \"50ml\", \"250g\" — digit immediately followed by g/ml/kg\n    95→  if (/\\b\\d+\\s*(?:g|ml|kg)\\b/i.test(line)) return true;\n    96→  // \"to taste\" / \"do smaku\" — qualitative ingredient with no unit\n    97→  if (/\\bto taste\\b/i.test(line) || /\\bdo smaku\\b/i.test(line)) return true;\n    98→  return false;\n    99→}\n   100→"}]},"parent_tool_use_id":"toolu_01GGSMyoXVHYzdjtsDxebzpc","session_id":"cda1f0b1-248e-469a-8a6a-1e44556e08de","uuid":"28dc1106-5ef1-435c-a921-6fb2659b54f1"}
