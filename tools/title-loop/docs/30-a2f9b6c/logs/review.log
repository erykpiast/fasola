{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AisHURDJRSPu3Tq9otvc29","type":"tool_result","content":"   355→const COOKING_INSTRUCTION_STARTS = /^(beat|fold|stir|mix|add|pour|bake|cook|cool|remove|place|combine|whisk|knead|roll|spread|brush|slice|chop|dice|mince|drain|rinse|peel|grate|melt|simmer|boil|fry|sauté|saute|roast|grill|broil|steam|let|set|transfer|serve|garnish|arrange|sprinkle|season|preheat|cover|uncover|reduce|bring|toss|cut|trim|shape|form|scatter|score|pat|rub|skim|strain|heat|discard|rest|marinate|wrap|flip|turn|layer|stuff|drizzle|squeeze|zest|soak|thaw|freeze|chill|warm|toast|crush|pound|crack|break|separate|weigh|measure|sift|dust|coat|dip|dredge|baste|debone|butterfly|truss|shred|puree|blend|process|pulse|whip|cream|proof|rise|punch|divide|portion|assemble)\\b/i;\n   356→\n   357→// Polish imperative cooking verbs (with OCR-resilient forms — no diacritics required).\n   358→// These cover the most common recipe instruction starters. Includes common OCR-corrupted\n   359→// forms (e.g., \"Smaż\" → \"Smaz\", \"Dodaj\" → \"Dodaj\").\n   360→// Note: only verbs that NEVER start a recipe title. \"Piecz\" (bake) is excluded because\n   361→// \"Pieczeń\" (roast) and \"Pieczarki\" (mushrooms) share the prefix.\n   362→// Use a Unicode-aware word-boundary lookahead instead of \\b, because JS \\b does not recognise\n   363→// Polish letters (ą ć ę ł ń ó ś ź ż) as word characters. Without this, `smaż\\b` would\n   364→// incorrectly match \"Smażona\" since \\b fires between ż (non-\\w) and the following o (\\w).\n   365→const POLISH_COOKING_INSTRUCTION_STARTS = /^(podawaj|dodaj|dodawaj|sma[zż]|gotuj|odced[zź]|wymieszaj|mieszaj|wlej|nalej|przygotuj|zagotuj|pokr[oó]j|obierz|wrzuc|wrzuć|usma[zż]|podsma[zż]|prze[lł][oó][zż]|zblenduj|ubij|roztrzepaj|rozprowad[zź]|wyrob|zamieszaj|posyp|polej|odstaw|na[lł][oó][zż]|przykryj|odkryj|wstaw|zdejmij|ods[aą]cz|rozgrzej|posiekaj|zetrzyj|wy[lł][oó][zż]|wyjmij|ukr[oó]j|przekr[oó]j|formuj|ugniataj|rozwałkuj|ugotuj|ugotowa[cć]|upiecz|podawa[cć]|zapiekaj|obtocz|obtoczy[cć]|podgrzej|podgrzewaj)(?![a-zA-ZąćęłńóśźżĄĆĘŁŃÓŚŹŻ])/i;\n   366→\n   367→function looksLikeCookingInstruction(text: string): boolean {\n   368→  const words = text.trim().split(/\\s+/);\n   369→  // Polish cooking instructions are commonly 2-3 words (\"Ugotuj ziemniaki.\", \"Upiecz chleb.\")\n   370→  // and are unambiguous because Polish recipe titles don't start with imperative verbs.\n   371→  if (POLISH_COOKING_INSTRUCTION_STARTS.test(text.trim())) {\n   372→    return words.length >= 2;  // Polish: 2+ words is enough\n   373→  }\n   374→  if (words.length < 4) return false;  // English: keep existing 4-word threshold\n   375→  if (COOKING_INSTRUCTION_STARTS.test(text.trim())) return true;\n   376→  return false;\n   377→}\n   378→\n   379→/**\n   380→ * A line starting with a lowercase letter and having 4+ words is prose continuation.\n   381→ * Recipe titles are capitalized (Title Case or ALL CAPS), so a lowercase-start line\n   382→ * is a strong signal for mid-recipe body text.\n   383→ */\n   384→function isBodyProse(line: string): boolean {\n   385→  return /^[a-ząćęłńóśźż]/.test(line) && wordCount(line) >= 4;\n   386→}\n   387→\n   388→/**\n   389→ * Detect pages where the OCR capture starts mid-recipe with no title present.\n   390→ * Returns true if the first 3 non-empty lines (after `startFrom`) are all ingredients,\n   391→ * cooking instructions, or body prose continuation text.\n   392→ */\n   393→function isTitleAbsentPage(lines: Array<string>, startFrom: number = 0): boolean {\n   394→  const relevantLines = startFrom > 0 ? lines.slice(startFrom) : lines;\n   395→  const nonEmptyLines = relevantLines.map(l => l.trim()).filter(l => l.length > 0);\n   396→\n   397→  if (nonEmptyLines.length < 3) return false;\n   398→\n   399→  const first3 = nonEmptyLines.slice(0, 3);\n   400→\n   401→  return first3.every(line =>\n   402→    looksLikeIngredient(line) ||\n   403→    looksLikeCookingInstruction(line) ||\n   404→    isBodyProse(line)\n   405→  );\n   406→}\n   407→\n   408→function passesHardFilters(text: string): boolean {\n   409→  if (text.length < 3 || text.length > 80) return false;\n   410→  if (looksLikeIngredient(text)) return false;\n   411→  if (startsWithNumber(text)) return false;\n   412→  if (looksLikeMetadata(text)) return false;\n   413→  if (isLikelyGarbled(text)) return false;\n   414→  if (looksLikeCookingInstruction(text)) return false;\n   415→  // Apply lightweight OCR normalization before a second instruction check\n   416→  // so that \"Podaw4ć\" is recognized as \"Podawać\" (cooking instruction).\n   417→  // Only 4→a for now — the specific OCR artifact causing failures.\n   418→  // Uses same letter-adjacent guard logic as applyBlindOcrRepairToken.\n   419→  const ocrNormForInstruction = text\n   420→    .replace(/(?<=[a-zà-ż])4/g, \"a\")\n   421→    .replace(/4(?=[a-zà-ż])/g, \"a\");\n   422→  if (ocrNormForInstruction !== text && looksLikeCookingInstruction(ocrNormForInstruction)) return false;\n   423→  // Pipe-separated lines are book category/chapter headers, not recipe titles\n   424→  if (text.includes(\" | \")) return false;\n   425→  // Trailing page number (e.g. \"VEGETABLE SIDES                         145\")\n   426→  if (/\\s{3,}\\d{1,4}\\s*$/.test(text)) return false;\n   427→  // Slash-separated breadcrumbs (e.g., \"/ Jesien / Zupy\") are navigation, not titles\n   428→  // Only filter when 2+ slashes are present — single-slash lines like\n   429→  // \"TITLE / SUBTITLE\" are legitimate continuation-merged titles\n   430→  if ((text.match(/\\//g) || []).length >= 2) return false;\n   431→  // Bullet-list items (ingredients or instruction steps) are never titles\n   432→  if (/^\\s*[-•*]\\s/.test(text)) return false;\n   433→  // \"For the sauce:\", \"For the filling:\" etc. are sub-section headers\n   434→  if (/^For the\\s+/i.test(text) && /:\\s*$/.test(text)) return false;"}]},"parent_tool_use_id":"toolu_01XjLSauSC3oNEccjMzcEMnr","session_id":"cda1f0b1-248e-469a-8a6a-1e44556e08de","uuid":"70e0aef2-36a6-4cc4-b9d6-a813ed44e443"}
