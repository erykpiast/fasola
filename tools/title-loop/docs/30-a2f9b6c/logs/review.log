{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SgkrvMRPcKgZdvU5GyoKhr","type":"tool_result","content":"   600→\n   601→  // Pre-merge consecutive short ALL_CAPS lines (OCR-fragmented headings).\n   602→  // When a sequence of 2+ ALL_CAPS lines each has ≤2 words and ≤25 chars, they are\n   603→  // almost certainly OCR fragments of a single heading. Merge them into one line so\n   604→  // the complete title enters the candidate pool without hitting the 3-line join ceiling.\n   605→  const capsCoalesced: Array<{ text: string; index: number }> = [];\n   606→  let ci = burstEnd;\n   607→  while (ci < nonEmptyLines.length) {\n   608→    const line = nonEmptyLines[ci];\n   609→    if (\n   610→      isAllCaps(line.text) &&\n   611→      wordCount(line.text) <= 2 &&\n   612→      line.text.length <= 25 &&\n   613→      !isSectionLabel(line.text) &&\n   614→      !looksLikeMetadata(line.text)\n   615→    ) {\n   616→      let merged = line.text;\n   617→      const startIndex = line.index;\n   618→      let j = ci + 1;\n   619→      while (j < nonEmptyLines.length) {\n   620→        const next = nonEmptyLines[j];\n   621→        if (\n   622→          isAllCaps(next.text) &&\n   623→          wordCount(next.text) <= 2 &&\n   624→          next.text.length <= 25 &&\n   625→          ((!isSectionLabel(next.text) && !isSectionLabel(repairOcrText(next.text))) ||\n   626→           (wordCount(next.text) === 1 && wordCount(merged) >= 2 && wordCount(merged) <= 4 &&\n   627→            isCategorySectionLabel(next.text))) &&\n   628→          !looksLikeMetadata(next.text) &&\n   629→          (merged + \" \" + next.text).length <= 80\n   630→        ) {\n   631→          merged += \" \" + next.text;\n   632→          j++;\n   633→        } else {\n   634→          break;\n   635→        }\n   636→      }\n   637→      if (j > ci + 1) {\n   638→        capsCoalesced.push({ text: merged, index: startIndex });\n   639→        ci = j;\n   640→        continue;\n   641→      }\n   642→    }\n   643→    capsCoalesced.push(line);\n   644→    ci++;"}]},"parent_tool_use_id":"toolu_01HsJtVqciNfVzyfHAHcqyA9","session_id":"cda1f0b1-248e-469a-8a6a-1e44556e08de","uuid":"dd53f601-d6fb-41b9-931d-b1e711102eb4"}
