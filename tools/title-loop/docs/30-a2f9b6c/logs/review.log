{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Lq2wuoyVVSdvy7QdeaN5bR","type":"tool_result","content":"   226→function looksLikeMetadata(text: string): boolean {\n   227→  return METADATA_PATTERNS.some((pattern) => pattern.test(text.trim()));\n   228→}\n   229→\n   230→/** Content words are ≥3 alpha characters after stripping punctuation. */\n   231→function extractContentWords(text: string): string[] {\n   232→  return text\n   233→    .split(/\\s+/)\n   234→    .filter((w) => w.replace(/[^a-zA-ZÀ-ÿ]/g, \"\").length >= 3)\n   235→    .map((w) => w.toUpperCase());\n   236→}\n   237→\n   238→/**\n   239→ * Returns true if the candidate's vocabulary is sufficiently supported by the rest of\n   240→ * the document. Short candidates (≤3 content words) require 100% corroboration;\n   241→ * longer candidates require ≥67%. Used to detect orphaned OCR artifacts in multi-title pages.\n   242→ */\n   243→function passesCorroboration(\n   244→  text: string,\n   245→  position: number,\n   246→  allLines: string[],\n   247→  startLine: number = 0 // Only check corroboration against lines from this index onward\n   248→): boolean {\n   249→  const contentWords = extractContentWords(text);\n   250→\n   251→  if (contentWords.length === 0) {\n   252→    return true; // No checkable words — pass through\n   253→  }\n   254→\n   255→  let corroboratedCount = 0;\n   256→  for (const word of contentWords) {\n   257→    for (let i = startLine; i < allLines.length; i++) {\n   258→      if (i === position) continue;\n   259→      if (allLines[i].toUpperCase().includes(word)) {\n   260→        corroboratedCount++;\n   261→        break;\n   262→      }\n   263→    }\n   264→  }\n   265→\n   266→  const score = corroboratedCount / contentWords.length;\n   267→  const threshold = contentWords.length <= 3 ? 1.0 : 0.67;\n   268→  return score >= threshold;\n   269→}\n   270→"}]},"parent_tool_use_id":"toolu_01XjLSauSC3oNEccjMzcEMnr","session_id":"cda1f0b1-248e-469a-8a6a-1e44556e08de","uuid":"7e498184-e5e3-4db3-b68c-e633504d30fd"}
