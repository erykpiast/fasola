{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012gy9Ya9bREStvGW6bAfpQR","type":"tool_result","content":"     1→/**\n     2→ * Common English and Polish food/cooking words and structural recipe title\n     3→ * words (prepositions, adjectives) for OCR repair.\n     4→ * Words are lowercase, without diacritics (OCR-resilient matching).\n     5→ * Used by repairOcrWord() to resolve ambiguous digit→letter substitutions.\n     6→ */\n     7→export const FOOD_DICTIONARY: Set<string> = new Set([\n     8→  // ── English ingredients ──────────────────────────────────────────────────\n     9→  \"chicken\", \"beef\", \"pork\", \"lamb\", \"veal\", \"duck\", \"turkey\", \"venison\",\n    10→  \"salmon\", \"cod\", \"halibut\", \"tuna\", \"trout\", \"sardine\", \"anchovy\", \"sole\",\n    11→  \"shrimp\", \"prawn\", \"lobster\", \"crab\", \"scallop\", \"mussel\", \"clam\",\n    12→  \"tofu\", \"tempeh\", \"seitan\",\n    13→\n    14→  // Grains & starches\n    15→  \"rice\", \"pasta\", \"bread\", \"noodle\", \"flour\", \"oat\", \"barley\", \"wheat\",\n    16→  \"rye\", \"quinoa\", \"corn\", \"cornmeal\", \"semolina\", \"couscous\", \"polenta\",\n    17→  \"buckwheat\", \"millet\",\n    18→\n    19→  // Dairy & eggs\n    20→  \"butter\", \"cream\", \"cheese\", \"milk\", \"egg\", \"yogurt\", \"ghee\",\n    21→  \"ricotta\", \"mozzarella\", \"parmesan\", \"cheddar\", \"brie\", \"feta\",\n    22→\n    23→  // Fats & condiments\n    24→  \"oil\", \"vinegar\", \"mustard\", \"ketchup\", \"mayo\", \"mayonnaise\",\n    25→  \"soy\", \"sauce\", \"paste\", \"stock\", \"broth\", \"gravy\",\n    26→\n    27→  // Vegetables\n    28→  \"garlic\", \"onion\", \"tomato\", \"potato\", \"carrot\", \"celery\", \"pepper\",\n    29→  \"broccoli\", \"cauliflower\", \"asparagus\", \"artichoke\", \"eggplant\",\n    30→  \"zucchini\", \"squash\", \"pumpkin\", \"cucumber\", \"radish\", \"turnip\",\n    31→  \"beet\", \"mushroom\", \"avocado\", \"olive\", \"bean\", \"lentil\", \"chickpea\",\n    32→  \"arugula\", \"spinach\", \"kale\", \"lettuce\", \"cabbage\", \"leek\", \"fennel\",\n    33→  \"chard\", \"endive\", \"watercress\", \"sprout\", \"pea\", \"edamame\",\n    34→  \"scallion\", \"shallot\", \"chili\", \"jalapeno\", \"poblano\", \"serrano\",\n    35→  \"brukselka\",\n    36→\n    37→  // Fruits\n    38→  \"lemon\", \"lime\", \"orange\", \"apple\", \"berry\", \"blackberry\", \"blueberry\",\n    39→  \"raspberry\", \"strawberry\", \"cherry\", \"peach\", \"pear\", \"plum\", \"grape\",\n    40→  \"banana\", \"mango\", \"pineapple\", \"coconut\", \"fig\", \"date\", \"apricot\",\n    41→  \"pomegranate\", \"melon\", \"watermelon\", \"grapefruit\", \"papaya\", \"kiwi\",\n    42→  \"passion\", \"guava\", \"lychee\",\n    43→\n    44→  // Nuts & seeds\n    45→  \"almond\", \"walnut\", \"pecan\", \"cashew\", \"pistachio\", \"hazelnut\",\n    46→  \"peanut\", \"sesame\", \"flaxseed\", \"chia\", \"sunflower\", \"pumpkinseed\",\n    47→  \"poppy\",\n    48→\n    49→  // Spices & herbs\n    50→  \"ginger\", \"cinnamon\", \"cumin\", \"paprika\", \"turmeric\", \"oregano\",\n    51→  \"basil\", \"thyme\", \"rosemary\", \"parsley\", \"cilantro\", \"dill\", \"mint\",\n    52→  \"sage\", \"chive\", \"tarragon\", \"nutmeg\", \"clove\", \"cardamom\", \"saffron\",\n    53→  \"vanilla\", \"anise\", \"coriander\", \"bay\", \"marjoram\", \"chervil\",\n    54→  \"fenugreek\", \"sumac\", \"caraway\", \"allspice\",\n    55→\n    56→  // Sweeteners & flavourings\n    57→  \"chocolate\", \"cocoa\", \"honey\", \"maple\", \"molasses\", \"sugar\", \"salt\",\n    58→  \"yeast\", \"baking\", \"powder\", \"soda\",\n    59→\n    60→  // Common recipe adjectives / descriptors\n    61→  \"white\", \"red\", \"green\", \"black\", \"brown\", \"sweet\", \"sour\", \"hot\",\n    62→  \"cold\", \"fresh\", \"dried\", \"whole\", \"ground\", \"roasted\", \"grilled\",\n    63→  \"braised\", \"baked\", \"fried\", \"steamed\", \"smoked\", \"stuffed\", \"glazed\",\n    64→  \"caramelized\", \"pickled\", \"fermented\", \"cured\", \"raw\", \"cooked\",\n    65→  \"crispy\", \"tender\", \"spicy\", \"savory\", \"creamy\", \"crunchy\", \"tangy\",\n    66→  \"herb\", \"herbed\", \"seasoned\", \"marinated\",\n    67→\n    68→  // Cooking terms / verbs\n    69→  \"bake\", \"roast\", \"grill\", \"fry\", \"saute\", \"braise\", \"simmer\", \"boil\",\n    70→  \"steam\", \"poach\", \"broil\", \"smoke\", \"cure\", \"pickle\", \"ferment\",\n    71→  \"blanch\", \"reduce\", \"deglaze\", \"emulsify\", \"whisk\", \"knead\", \"fold\",\n    72→  \"chop\", \"dice\", \"mince\", \"slice\", \"julienne\", \"marinate\", \"season\",\n    73→  \"glaze\", \"caramelize\", \"sear\", \"flambe\", \"infuse\", \"steep\", \"toast\",\n    74→  \"blend\", \"puree\", \"strain\", \"press\", \"squeeze\", \"drizzle\", \"toss\",\n    75→  \"stir\", \"mix\", \"beat\", \"cream\", \"sift\", \"coat\", \"dredge\", \"bread\",\n    76→\n    77→  // Dish types\n    78→  \"salad\", \"soup\", \"stew\", \"casserole\", \"risotto\", \"curry\", \"pie\",\n    79→  \"tart\", \"cake\", \"cookie\", \"brownie\", \"muffin\", \"scone\", \"pancake\",\n    80→  \"waffle\", \"crepe\", \"quiche\", \"frittata\", \"omelette\", \"sandwich\",\n    81→  \"wrap\", \"burger\", \"pizza\", \"dumpling\", \"pierogi\", \"sushi\", \"taco\",\n    82→  \"burrito\", \"enchilada\", \"chowder\", \"bisque\", \"broth\", \"consomme\",\n    83→  \"terrine\", \"pate\", \"mousse\", \"souffle\", \"galette\", \"clafoutis\",\n    84→  \"cobbler\", \"crumble\", \"pudding\", \"custard\", \"parfait\", \"tiramisu\",\n    85→  \"cheesecake\", \"torte\", \"trifle\", \"fool\", \"compote\", \"sorbet\",\n    86→  \"gelato\", \"icecream\", \"meringue\", \"macaron\",\n    87→\n    88→  // Wine & drinks that appear in recipes\n    89→  \"wine\", \"beer\", \"cider\", \"brandy\", \"rum\", \"vodka\", \"gin\", \"whiskey\",\n    90→  \"vermouth\", \"sherry\", \"port\", \"mirin\", \"sake\", \"tea\", \"coffee\",\n    91→  \"juice\",\n    92→\n    93→  // ── Polish ingredients (without diacritics) ───────────────────────────────\n    94→  \"kurczak\", \"wolowina\", \"wieprzowina\", \"cielecina\", \"golonka\",\n    95→  \"losos\", \"dorsz\", \"krewetki\", \"ryz\", \"makaron\", \"chleb\", \"maslo\",\n    96→  \"smietana\", \"ser\", \"czosnek\", \"cebula\", \"pomidor\", \"ziemniak\",\n    97→  \"marchew\", \"seler\", \"pieprz\", \"sol\", \"cukier\", \"maka\", \"jajko\",\n    98→  \"mleko\", \"olej\", \"ocet\", \"cytryna\", \"pomarancza\", \"jablko\", \"jagoda\",\n    99→  \"malina\", \"truskawka\", \"wisnia\", \"brzoskwinia\", \"gruszka\", \"sliwka\",\n   100→  \"winogrono\", \"banan\", \"orzech\", \"migdal\", \"imbir\", \"cynamon\",\n   101→  \"kminek\", \"papryka\", \"kurkuma\", \"oregano\", \"bazylia\", \"tymianek\",\n   102→  \"rozmaryn\", \"pietruszka\", \"kolendra\", \"koperek\", \"mieta\", \"szalwia\",\n   103→  \"szpinak\", \"kapusta\", \"kalafior\", \"szparag\", \"baklazan\", \"cukinia\",\n   104→  \"dynia\", \"ogorek\", \"rzodkiewka\", \"burak\", \"grzyb\", \"awokado\",\n   105→  \"oliwka\", \"fasola\", \"soczewica\", \"ciecierzyca\", \"kasza\", \"owies\",\n   106→  \"jeczmien\", \"pszenica\", \"zyto\",\n   107→\n   108→  // Polish bread varieties\n   109→  \"pszenny\", \"razowy\", \"zytni\", \"wieloziarnisty\", \"tostowy\",\n   110→\n   111→  // Polish cooking terms (without diacritics)\n   112→  \"piec\", \"smazyc\", \"grillowac\", \"gotowac\", \"dusic\", \"blanszowac\",\n   113→  \"kroic\", \"siekac\", \"marynowac\", \"przyprawiac\", \"karmelizowac\",\n   114→  \"podsmaz\", \"zapiekac\", \"gotowac\", \"dusic\", \"wedzic\", \"kisic\",\n   115→\n   116→  // Polish dishes\n   117→  \"bigos\", \"zurek\", \"barszcz\", \"rosol\", \"kotlet\", \"schabowy\",\n   118→  \"golabki\", \"placki\", \"nalesniki\", \"piernik\", \"sernik\", \"makowiec\",\n   119→  \"babka\", \"chalka\", \"rogal\", \"paczek\", \"faworki\", \"kluski\",\n   120→  \"kopytka\", \"pyzy\", \"uszka\", \"gzik\", \"flaczki\", \"zrazy\", \"gulasz\",\n   121→  \"leczo\", \"kapusniak\", \"grochowka\", \"krupnik\", \"zupa\", \"sałatka\",\n   122→  \"salatka\", \"mizeria\", \"surowka\",\n   123→\n   124→  // Polish ingredient descriptors (without diacritics)\n   125→  \"swiezy\", \"suszony\", \"marynowany\", \"wegdzony\", \"pieczony\", \"gotowany\",\n   126→  \"smazony\", \"surowy\", \"mrożony\", \"mrozony\", \"konserwowy\",\n   127→  \"ziemniaczane\", \"ziemniaczany\",\n   128→\n   129→  // Polish section labels (appear in recipe texts, useful for context)\n   130→  \"skladniki\", \"przygotowanie\", \"sposob\", \"wykonanie\", \"porcje\",\n   131→  \"czas\", \"temperatura\", \"pieczenia\",\n   132→\n   133→  // ── Common title words (for OCR repair) ─────────────────────────────────\n   134→  // Prepositions & conjunctions\n   135→  \"with\", \"from\", \"over\", \"under\", \"the\", \"and\", \"for\",\n   136→  // Adjectives commonly in recipe titles\n   137→  \"classic\", \"simple\", \"quick\", \"easy\", \"light\",\n   138→  \"thick\", \"thin\", \"old\", \"new\",\n   139→  // Short food terms missing from main dictionary\n   140→  \"dip\", \"bun\", \"buns\", \"roll\", \"rolls\",\n   141→  \"jam\", \"jelly\", \"loaf\", \"hash\", \"bowl\",\n   142→  // Polish common title words (without diacritics)\n   143→  \"pieczone\", \"smazone\",\n   144→  \"gotowane\", \"duszone\", \"duszony\",\n   145→  \"domowy\", \"domowe\", \"tradycyjny\", \"tradycyjne\",\n   146→]);\n   147→"}]},"parent_tool_use_id":null,"session_id":"cda1f0b1-248e-469a-8a6a-1e44556e08de","uuid":"d8ebdade-c83e-460f-83b5-ba204fac7f0d","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/food-dictionary.ts","content":"/**\n * Common English and Polish food/cooking words and structural recipe title\n * words (prepositions, adjectives) for OCR repair.\n * Words are lowercase, without diacritics (OCR-resilient matching).\n * Used by repairOcrWord() to resolve ambiguous digit→letter substitutions.\n */\nexport const FOOD_DICTIONARY: Set<string> = new Set([\n  // ── English ingredients ──────────────────────────────────────────────────\n  \"chicken\", \"beef\", \"pork\", \"lamb\", \"veal\", \"duck\", \"turkey\", \"venison\",\n  \"salmon\", \"cod\", \"halibut\", \"tuna\", \"trout\", \"sardine\", \"anchovy\", \"sole\",\n  \"shrimp\", \"prawn\", \"lobster\", \"crab\", \"scallop\", \"mussel\", \"clam\",\n  \"tofu\", \"tempeh\", \"seitan\",\n\n  // Grains & starches\n  \"rice\", \"pasta\", \"bread\", \"noodle\", \"flour\", \"oat\", \"barley\", \"wheat\",\n  \"rye\", \"quinoa\", \"corn\", \"cornmeal\", \"semolina\", \"couscous\", \"polenta\",\n  \"buckwheat\", \"millet\",\n\n  // Dairy & eggs\n  \"butter\", \"cream\", \"cheese\", \"milk\", \"egg\", \"yogurt\", \"ghee\",\n  \"ricotta\", \"mozzarella\", \"parmesan\", \"cheddar\", \"brie\", \"feta\",\n\n  // Fats & condiments\n  \"oil\", \"vinegar\", \"mustard\", \"ketchup\", \"mayo\", \"mayonnaise\",\n  \"soy\", \"sauce\", \"paste\", \"stock\", \"broth\", \"gravy\",\n\n  // Vegetables\n  \"garlic\", \"onion\", \"tomato\", \"potato\", \"carrot\", \"celery\", \"pepper\",\n  \"broccoli\", \"cauliflower\", \"asparagus\", \"artichoke\", \"eggplant\",\n  \"zucchini\", \"squash\", \"pumpkin\", \"cucumber\", \"radish\", \"turnip\",\n  \"beet\", \"mushroom\", \"avocado\", \"olive\", \"bean\", \"lentil\", \"chickpea\",\n  \"arugula\", \"spinach\", \"kale\", \"lettuce\", \"cabbage\", \"leek\", \"fennel\",\n  \"chard\", \"endive\", \"watercress\", \"sprout\", \"pea\", \"edamame\",\n  \"scallion\", \"shallot\", \"chili\", \"jalapeno\", \"poblano\", \"serrano\",\n  \"brukselka\",\n\n  // Fruits\n  \"lemon\", \"lime\", \"orange\", \"apple\", \"berry\", \"blackberry\", \"blueberry\",\n  \"raspberry\", \"strawberry\", \"cherry\", \"peach\", \"pear\", \"plum\", \"grape\",\n  \"banana\", \"mango\", \"pineapple\", \"coconut\", \"fig\", \"date\", \"apricot\",\n  \"pomegranate\", \"melon\", \"watermelon\", \"grapefruit\", \"papaya\", \"kiwi\",\n  \"passi