{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017wdjSbZ5ZY9Ghzu3y4KEXg","type":"tool_result","content":"   152→  \"przystawki\",       // starters\n   153→  \"dodatki\",          // side dishes\n   154→  \"przetwory\",        // preserves\n   155→  \"wypieki\",          // baked goods\n   156→  \"ciasta\",           // cakes (plural)\n   157→  \"ciastka\",          // cookies\n   158→  \"torty\",            // layer cakes\n   159→  // \"placki\" removed — it commonly starts recipe titles like \"Placki Ziemniaczane\", \"Placki Żółte z Kukurydzą\"\n   160→  \"koktajle\",         // cocktails/smoothies\n   161→  // English — recipe-book chapter/category labels\n   162→  \"vegetables\", \"seafood\", \"fish\", \"soups\", \"salads\", \"desserts\",\n   163→  \"appetizers\", \"breads\", \"breakfast\", \"pasta\", \"grains\",\n   164→  \"main courses\", \"side dishes\", \"preserves\", \"baked goods\",\n   165→  \"fish & seafood\", \"soups & broths\", \"desserts & baked goods\",\n   166→  \"meats\", \"poultry\", \"game\",\n   167→]);\n   168→\n   169→/**\n   170→ * Subset of SECTION_LABELS that are food-group/chapter labels (not structural process labels).\n   171→ * These may appear as the last word of a compound recipe title (e.g. \"LEMON HERB ROASTED VEGETABLES\").\n   172→ */\n   173→const CATEGORY_SECTION_LABELS = new Set([\n   174→  // English food categories\n   175→  \"vegetables\", \"seafood\", \"fish\", \"soups\", \"salads\", \"desserts\",\n   176→  \"appetizers\", \"breads\", \"breakfast\", \"pasta\", \"grains\",\n   177→  \"meats\", \"poultry\", \"game\",\n   178→  // Polish food categories\n   179→  \"warzywa\", \"mieso\", \"miesa\", \"ryby\", \"zupy\", \"salatki\", \"desery\",\n   180→  \"napoje\", \"pieczywo\", \"przekaski\", \"sniadania\", \"obiady\", \"kolacje\",\n   181→  \"makarony\", \"kasza\", \"kasze\", \"przystawki\", \"dodatki\", \"wypieki\",\n   182→  \"ciasta\", \"ciastka\", \"torty\", \"koktajle\",\n   183→]);\n   184→\n   185→function isCategorySectionLabel(text: string): boolean {\n   186→  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n   187→  return CATEGORY_SECTION_LABELS.has(normalized);\n   188→}\n   189→\n   190→function isSectionLabel(text: string): boolean {\n   191→  const normalized = stripDiacritics(text.trim().replace(/[:.]$/, \"\").toLowerCase());\n   192→  if (SECTION_LABELS.has(normalized)) return true;\n   193→  // OCR variant: leading \"l\" may be OCR-corrupted \"I\" (e.g. \"lngredients\" → \"ingredients\")\n   194→  const ocrNormalized = normalized.replace(/^l/, \"i\");\n   195→  if (ocrNormalized !== normalized && SECTION_LABELS.has(ocrNormalized)) return true;\n   196→  return false;\n   197→}\n   198→\n   199→/**\n   200→ * Recipe-internal section labels that should ALWAYS block multi-line joins,\n   201→ * even when the combined word count is ≥ 3."}]},"parent_tool_use_id":"toolu_01HsJtVqciNfVzyfHAHcqyA9","session_id":"cda1f0b1-248e-469a-8a6a-1e44556e08de","uuid":"940d02bf-0615-46cd-9d21-aa04efed0d6b"}
