{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FWyuGKgeBtx8CK4Wj5uSCY","type":"tool_result","content":"   400→\n   401→  return first3.every(line =>\n   402→    looksLikeIngredient(line) ||\n   403→    looksLikeCookingInstruction(line) ||\n   404→    isBodyProse(line)\n   405→  );\n   406→}\n   407→\n   408→function passesHardFilters(text: string): boolean {\n   409→  if (text.length < 3 || text.length > 80) return false;\n   410→  if (looksLikeIngredient(text)) return false;\n   411→  if (startsWithNumber(text)) return false;\n   412→  if (looksLikeMetadata(text)) return false;\n   413→  if (isLikelyGarbled(text)) return false;\n   414→  if (looksLikeCookingInstruction(text)) return false;\n   415→  // Apply lightweight OCR normalization before a second instruction check\n   416→  // so that \"Podaw4ć\" is recognized as \"Podawać\" (cooking instruction).\n   417→  // Only 4→a for now — the specific OCR artifact causing failures.\n   418→  // Uses same letter-adjacent guard logic as applyBlindOcrRepairToken.\n   419→  const ocrNormForInstruction = text\n   420→    .replace(/(?<=[a-zà-ż])4/g, \"a\")\n   421→    .replace(/4(?=[a-zà-ż])/g, \"a\");\n   422→  if (ocrNormForInstruction !== text && looksLikeCookingInstruction(ocrNormForInstruction)) return false;\n   423→  // Pipe-separated lines are book category/chapter headers, not recipe titles\n   424→  if (text.includes(\" | \")) return false;\n   425→  // Trailing page number (e.g. \"VEGETABLE SIDES                         145\")\n   426→  if (/\\s{3,}\\d{1,4}\\s*$/.test(text)) return false;\n   427→  // Slash-separated breadcrumbs (e.g., \"/ Jesien / Zupy\") are navigation, not titles\n   428→  // Only filter when 2+ slashes are present — single-slash lines like\n   429→  // \"TITLE / SUBTITLE\" are legitimate continuation-merged titles\n   430→  if ((text.match(/\\//g) || []).length >= 2) return false;\n   431→  // Bullet-list items (ingredients or instruction steps) are never titles\n   432→  if (/^\\s*[-•*]\\s/.test(text)) return false;\n   433→  // \"For the sauce:\", \"For the filling:\" etc. are sub-section headers\n   434→  if (/^For the\\s+/i.test(text) && /:\\s*$/.test(text)) return false;\n   435→  // Lines ending with \":\" are recipe sub-section headers, not titles.\n   436→  // Exception: compound titles using \" : \" as a title separator (e.g. \"LEMON CURD : LEMON CURD WITH THYME\").\n   437→  if (/:\\s*$/.test(text.trim()) && !/ : /.test(text)) return false;\n   438→  // Page references are navigation markers, not recipe titles\n   439→  if (/^Page\\s+\\d+/i.test(text.trim())) return false;\n   440→  if (/^Strona\\s+\\d+/i.test(text.trim())) return false;\n   441→  // Corrupted spillover annotations from synthetic multi-page OCR\n   442→  if (/^\\[CORRUPTED\\s+SPILLOVER/i.test(text.trim())) return false;\n   443→  // Parenthetical OCR annotation lines describing corruption artifacts\n   444→  if (/^\\(OCR\\b/i.test(text.trim())) return false;\n   445→  if (/^\\(.*\\bcorruption\\b/i.test(text.trim())) return false;\n   446→  // Square-bracket category tags (e.g., \"[CLASSIC FALL SOUPS]\")\n   447→  if (/^\\[.*\\]$/.test(text.trim())) return false;\n   448→  // Known recipe section labels are structural headers, not titles\n   449→  if (isSectionLabel(text)) return false;\n   450→  // Single-word non-title fragments\n   451→  const words = text.trim().split(/\\s+/);\n   452→  if (words.length === 1 && NON_TITLE_WORDS.has(text.trim().toLowerCase())) return false;\n   453→  // Lines with ≥8 words are almost certainly body text, not titles.\n   454→  // Exception: multi-title compounds with \" + \", \" : \", or \" & \" separators are allowed.\n   455→  if (words.length >= 8 && !/ [+:&/] /.test(text)) return false;\n   456→  return true;\n   457→}\n   458→\n   459→/**\n   460→ * Detect initial burst of short garbled lines.\n   461→ * Returns the index of the first non-garbled or long line.\n   462→ */\n   463→function findBurstEnd(lines: Array<{ text: string }>): number {\n   464→  let i = 0;\n   465→\n   466→  // Skip overflow preambles: blocks introduced by \"PREVIOUS RECIPE OVERFLOW\",\n   467→  // \"PREVIOUS PAGE CONTENT\", \"CORRUPTED SECTION\", etc. that precede the actual recipe.\n   468→  const OVERFLOW_MARKERS = /\\b(PREVIOUS\\s+(RECIPE|PAGE)\\b|SPILLOVER|CONTINUATION|CORRUPTED\\s+(SECTION|TEXT)\\b|PARTIAL\\s+RECIPE)\\b/i;\n   469→  let overflowEnd = 0;\n   470→  for (let k = 0; k < lines.length && k < 30; k++) {\n   471→    // Don't re-examine lines already determined to be overflow\n   472→    if (overflowEnd > 0 && k < overflowEnd) continue;\n   473→    if (OVERFLOW_MARKERS.test(lines[k].text) || /^\\[.*\\b(PREVIOUS|CORRUPTED|SPILLOVER|CONTINUATION|PARTIAL)\\b.*\\]$/i.test(lines[k].text)) {\n   474→      // Skip forward past the overflow block to the next visual separator or blank cluster\n   475→      let m = k + 1;\n   476→      let consecutiveBlanks = 0;\n   477→      while (m < lines.length) {\n   478→        const lineText = lines[m].text;\n   479→        // Stop at visual separator\n   480→        if (/^[=\\-]{4,}$/.test(lineText)) {\n   481→          overflowEnd = m + 1;\n   482→          break;\n   483→        }\n   484→        // Track consecutive blank lines\n   485→        if (lineText.trim().length === 0) {\n   486→          consecutiveBlanks++;\n   487→          if (consecutiveBlanks >= 2) {\n   488→            overflowEnd = m + 1;\n   489→            break;\n   490→          }\n   491→        } else {\n   492→          consecutiveBlanks = 0;\n   493→          // Stop at ALL_CAPS line with ≥2 words (likely next recipe heading)\n   494→          if (isAllCaps(lineText) && wordCount(lineText) >= 2) {\n   495→            overflowEnd = m; // Don't skip past the heading itself\n   496→            break;\n   497→          }\n   498→        }\n   499→        m++;\n   500→      }\n   501→      // If we walked to end without finding termination, skip everything we saw\n   502→      if (overflowEnd === 0) overflowEnd = m;\n   503→    }\n   504→  }\n   505→  if (overflowEnd > 0) i = overflowEnd;\n   506→\n   507→  while (i < lines.length && lines[i].text.length < 20 && isLikelyGarbled(lines[i].text) && !isAllCaps(lines[i].text)) {\n   508→    i++;\n   509→  }\n   510→  // Skip body-content prologues: when 3+ consecutive lines at the start are cooking\n   511→  // instructions, prose continuations, or a mix of both, skip them to find the actual\n   512→  // title region. This unifies the previous separate instruction and prose checks to\n   513→  // handle interleaved patterns (e.g., instruction → prose continuation → instruction).\n   514→  if (i === 0) {\n   515→    let j = 0;\n   516→    while (j < lines.length) {\n   517→      const t = lines[j].text;\n   518→      const isInstruction = looksLikeCookingInstruction(t);\n   519→      // Short body-text continuation: lowercase-start with 2+ words catches fragments\n   520→      // like \"creamy but still al dente...\" that follow cooking instructions.\n   521→      // Lower threshold than isBodyProse (2 vs 4 words) to handle interleaved patterns.\n   522→      const isContinuation = /^[a-ząćęłńóśźż]/.test(t) && wordCount(t) >= 2;\n   523→      // Non-lowercase body text: comma-ending or long sentence-ending lines\n   524→      const isBodyEnding = (t.endsWith(\",\") || (t.endsWith(\".\") && wordCount(t) > 4)) && wordCount(t) >= 4;\n   525→\n   526→      if (isInstruction || isContinuation || isBodyEnding) {\n   527→        j++;\n   528→      } else {\n   529→        break;\n   530→      }\n   531→    }\n   532→    if (j >= 3) {\n   533→      i = j;\n   534→    }\n   535→  }\n   536→  return i;\n   537→}\n   538→\n   539→function stripParentheticalGloss(text: string): string {\n   540→  // Strip trailing English-gloss parentheticals from ALL_CAPS titles.\n   541→  // e.g. \"PIEROGI RUSKIE (Boiled Dumplings with Potato and Cheese)\" → \"PIEROGI RUSKIE\"\n   542→  // Keep if parenthetical is ALL_CAPS (variation/subtitle in same language).\n   543→  // Keep if both base and paren are mixed-case (both are part of the title).\n   544→  const match = text.match(/^(.+?)\\s*\\(([^)]+)\\)\\s*$/);\n   545→  if (!match) return text;\n   546→  const [, base, paren] = match;\n   547→  if (isAllCaps(paren)) return text;\n   548→  if (!isAllCaps(base) && !isAllCaps(paren)) return text;\n   549→  return base.trim();\n   550→}\n   551→\n   552→function stripPageNumber(text: string): string {\n   553→  // \"34  Berry Jam\" → \"Berry Jam\" (2+ spaces distinguishes from \"2 eggs\")\n   554→  const match = text.match(/^\\d{1,3}\\s{2,}(.+)$/);\n   555→  return match ? match[1] : text;\n   556→}\n   557→\n   558→/**\n   559→ * Strip trailing parenthesized page or step numbers.\n   560→ * \"Ugotuj ziemniaky. (38)\" → \"Ugotuj ziemniaky.\"\n   561→ * \"RECIPE NAME (p. 42)\" → \"RECIPE NAME\"\n   562→ */\n   563→function stripTrailingPageRef(text: string): string {\n   564→  return text.replace(/\\s*\\((?:p\\.?\\s*)?\\d{1,4}\\)\\s*$/, \"\").trim();\n   565→}\n   566→\n   567→function wordCount(text: string): number {\n   568→  return text.split(/\\s+/).filter((w) => w.length > 0).length;\n   569→}\n   570→\n   571→/**\n   572→ * Build candidate strings from lines: single lines plus multi-line joins (2-3 consecutive).\n   573→ * Skips initial burst of short garbled lines. Scans all remaining lines. Caps at 25.\n   574→ */\n   575→export type CandidateOrigin = \"single\" | \"2-line\" | \"3-line\";\n   576→\n   577→function buildCandidates(\n   578→  lines: Array<string>\n   579→): { candidates: Array<{ text: string; position: number; origin: CandidateOrigin }>; burstEnd: number } {\n   580→  const nonEmptyLines: Array<{ text: string; index: number }> = [];\n   581→\n   582→  for (let i = 0; i < lines.length; i++) {\n   583→    const trimmed = lines[i].trim();\n   584→    if (trimmed.length > 0) {\n   585→      nonEmptyLines.push({ text: trimmed, index: i });\n   586→    }\n   587→  }\n   588→\n   589→  const burstEnd = findBurstEnd(nonEmptyLines);\n   590→\n   591→  // Pre-join hyphen-broken lines: \"ROASTED CHICKEN WITH ROOT VEGET-\" + \"ABLES\" → single line.\n   592→  // Only applies within the candidate region (after burst end).\n   593→  for (let hi = burstEnd; hi < nonEmptyLines.length - 1; hi++) {\n   594→    if (nonEmptyLines[hi].text.endsWith(\"-\")) {\n   595→      const joined = nonEmptyLines[hi].text.slice(0, -1) + nonEmptyLines[hi + 1].text;\n   596→      nonEmptyLines[hi] = { text: joined, index: nonEmptyLines[hi].index };\n   597→      nonEmptyLines.splice(hi + 1, 1);\n   598→    }\n   599→  }\n   600→\n   601→  // Pre-merge consecutive short ALL_CAPS lines (OCR-fragmented headings).\n   602→  // When a sequence of 2+ ALL_CAPS lines each has ≤2 words and ≤25 chars, they are\n   603→  // almost certainly OCR fragments of a single heading. Merge them into one line so\n   604→  // the complete title enters the candidate pool without hitting the 3-line join ceiling.\n   605→  const capsCoalesced: Array<{ text: string; index: number }> = [];\n   606→  let ci = burstEnd;\n   607→  while (ci < nonEmptyLines.length) {\n   608→    const line = nonEmptyLines[ci];\n   609→    if (\n   610→      isAllCaps(line.text) &&\n   611→      wordCount(line.text) <= 2 &&\n   612→      line.text.length <= 25 &&\n   613→      !isSectionLabel(line.text) &&\n   614→      !looksLikeMetadata(line.text)\n   615→    ) {\n   616→      let merged = line.text;\n   617→      const startIndex = line.index;\n   618→      let j = ci + 1;\n   619→      while (j < nonEmptyLines.length) {\n   620→        const next = nonEmptyLines[j];\n   621→        if (\n   622→          isAllCaps(next.text) &&\n   623→          wordCount(next.text) <= 2 &&\n   624→          next.text.length <= 25 &&\n   625→          ((!isSectionLabel(next.text) && !isSectionLabel(repairOcrText(next.text))) ||\n   626→           (wordCount(next.text) === 1 && wordCount(merged) >= 2 && wordCount(merged) <= 4 &&\n   627→            isCategorySectionLabel(next.text))) &&\n   628→          !looksLikeMetadata(next.text) &&\n   629→          (merged + \" \" + next.text).length <= 80\n   630→        ) {\n   631→          merged += \" \" + next.text;\n   632→          j++;\n   633→        } else {\n   634→          break;\n   635→        }\n   636→      }\n   637→      if (j > ci + 1) {\n   638→        capsCoalesced.push({ text: merged, index: startIndex });\n   639→        ci = j;\n   640→        continue;\n   641→      }\n   642→    }\n   643→    capsCoalesced.push(line);\n   644→    ci++;\n   645→  }\n   646→\n   647→  // Pre-merge continuation lines: a line starting with /&+:( is never a standalone title.\n   648→  // Merge it into the preceding line so the complete title enters the pool as a single candidate,\n   649→  // avoiding the fragile chain of conditions required by the downstream join survival logic.\n   650→  // Limitation: only one continuation line per preceding line is merged. Titles split across\n   651→  // three or more lines with continuation tokens (rare in practice) are not handled here —\n   652→  // the downstream 2-line and 3-line join candidates cover those cases instead.\n   653→  const mergedLines: Array<{ text: string; index: number }> = [];\n   654→  for (let i = 0; i < capsCoalesced.length; i++) {\n   655→    const line = capsCoalesced[i];\n   656→    mergedLines.push(line);  // always keep the original standalone\n   657→    if (i + 1 < capsCoalesced.length) {\n   658→      const nextText = capsCoalesced[i + 1].text;\n   659→      if (/^[/&+:(]/.test(nextText)) {\n   660→        mergedLines.push({ text: `${line.text} ${nextText}`, index: line.index });\n   661→        i++;\n   662→        continue;\n   663→      }\n   664→    }\n   665→  }\n   666→\n   667→  const candidates: Array<{ text: string; position: number; origin: CandidateOrigin }> = [];\n   668→  const seen = new Set<string>();\n   669→\n   670→  // Build a set of positions to skip: short ALL_CAPS lines immediately following metadata\n   671→  const metadataContinuationPositions = new Set<number>();\n   672→  for (let i = 0; i < mergedLines.length - 1; i++) {\n   673→    if (looksLikeMetadata(mergedLines[i].text)) {\n   674→      const next = mergedLines[i + 1];\n   675→      if (isAllCaps(next.text) && wordCount(next.text) <= 2 && next.text.length <= 15) {\n   676→        metadataContinuationPositions.add(next.index);\n   677→      }\n   678→    }\n   679→  }\n   680→\n   681→  for (let i = 0; i < mergedLines.length; i++) {\n   682→    const line = mergedLines[i];\n   683→\n   684→    // Skip metadata continuation fragments\n   685→    if (metadataContinuationPositions.has(line.index)) continue;\n   686→\n   687→    // Single line — strip page-number prefixes and parenthetical glosses before scoring\n   688→    const singleText = repairOcrText(stripParentheticalGloss(stripTrailingPageRef(stripPageNumber(line.text))));\n   689→    if (passesHardFilters(singleText)) {\n   690→      const norm = singleText.toLowerCase();\n   691→      if (!seen.has(norm)) {\n   692→        seen.add(norm);\n   693→        candidates.push({ text: singleText, position: line.index, origin: \"single\" });\n   694→      }\n   695→    }\n   696→\n   697→    // Blind OCR repair for early-position candidates: when the original text\n   698→    // has OCR artifacts or erratic casing and is in the first few lines,\n   699→    // generate additional candidates with blind digit→letter repair and/or\n   700→    // casing normalization. This gives the embedding scorer clean versions\n   701→    // even when dictionary repair misses.\n   702→    if (line.index <= 5) {\n   703→      const hasOcrArtifact = OCR_ARTIFACT_PATTERN.test(line.text);\n   704→      const lineHasErraticCasing = hasErraticCasing(line.text);\n   705→      if (hasOcrArtifact || lineHasErraticCasing) {\n   706→        let repairable = singleText;\n   707→        if (lineHasErraticCasing) {\n   708→          repairable = normalizeErraticCasing(repairable);\n   709→          if (repairable !== singleText && passesHardFilters(repairable)) {\n   710→            const norm = repairable.toLowerCase();\n   711→            if (!seen.has(norm)) {\n   712→              seen.add(norm);\n   713→              candidates.push({ text: repairable, position: line.index, origin: \"single\" });\n   714→            }\n   715→          }\n   716→        }\n   717→        const variants = generateBlindOcrVariants(repairable);\n   718→        for (const variant of variants) {\n   719→          if (passesHardFilters(variant)) {\n   720→            const norm = variant.toLowerCase();\n   721→            if (!seen.has(norm)) {\n   722→              seen.add(norm);\n   723→              candidates.push({ text: variant, position: line.index, origin: \"single\" });\n   724→            }\n   725→          }\n   726→        }\n   727→      }\n   728→    }\n   729→\n   730→    // 2-line join — skip if first line is a section label AND join would be ≤2 words\n   731→    // (a section label followed by modifiers is likely a recipe title, not a category header)\n   732→    // Also skip if the next line is metadata (e.g. serving size \"DLA & OSOB\").\n   733→    if (i + 1 < mergedLines.length && !looksLikeMetadata(mergedLines[i + 1].text)) {\n   734→      const joined2 = repairOcrText(`${line.text} ${mergedLines[i + 1].text}`);\n   735→      const shouldBlock2 = isSectionLabel(line.text) &&\n   736→        (wordCount(joined2) <= 2 || isAlwaysBlockJoinLabel(line.text));\n   737→      if (!shouldBlock2 && passesHardFilters(joined2)) {\n   738→        const norm = joined2.toLowerCase();\n   739→        if (!seen.has(norm)) {\n   740→          seen.add(norm);\n   741→          candidates.push({ text: joined2, position: line.index, origin: \"2-line\" });\n   742→        }\n   743→      }\n   744→    }\n   745→\n   746→    // 3-line join — skip if first line is a section label AND join would be ≤2 words.\n   747→    // Also skip if any continuation line is metadata.\n   748→    if (i + 2 < mergedLines.length &&\n   749→        !looksLikeMetadata(mergedLines[i + 1].text) &&\n   750→        !looksLikeMetadata(mergedLines[i + 2].text)) {\n   751→      const joined3 = repairOcrText(`${line.text} ${mergedLines[i + 1].text} ${mergedLines[i + 2].text}`);\n   752→      const shouldBlock3 = isSectionLabel(line.text) &&\n   753→        (wordCount(joined3) <= 2 || isAlwaysBlockJoinLabel(line.text));\n   754→      if (!shouldBlock3 && passesHardFilters(joined3)) {\n   755→        const norm = joined3.toLowerCase();\n   756→        if (!seen.has(norm)) {\n   757→          seen.add(norm);\n   758→          candidates.push({ text: joined3, position: line.index, origin: \"3-line\" });\n   759→        }\n   760→      }\n   761→    }\n   762→  }\n   763→\n   764→  // Pre-filter to 25 before embedding calls: prefer ALL_CAPS and short candidates.\n   765→  // Position-based scoring handles final ranking.\n   766→  if (candidates.length > 25) {\n   767→    const prioritized = candidates.slice().sort((a, b) => {\n   768→      const aAllCaps = isAllCaps(a.text) ? 0 : 1;\n   769→      const bAllCaps = isAllCaps(b.text) ? 0 : 1;\n   770→      if (aAllCaps !== bAllCaps) return aAllCaps - bAllCaps;\n   771→      const aShort = wordCount(a.text) <= 5 ? 0 : 1;\n   772→      const bShort = wordCount(b.text) <= 5 ? 0 : 1;\n   773→      return aShort - bShort;\n   774→    });\n   775→    return { candidates: prioritized.slice(0, 25), burstEnd: nonEmptyLines[burstEnd]?.index ?? lines.length };\n   776→  }\n   777→\n   778→  return { candidates, burstEnd: nonEmptyLines[burstEnd]?.index ?? lines.length };\n   779→}\n   780→\n   781→/**\n   782→ * Convert an ALL_CAPS string to Title Case, using a small-words list.\n   783→ * Preserves Polish/French diacritics.\n   784→ */\n   785→function toTitleCase(text: string): string {\n   786→  const smallWords = new Set([\n   787→    \"a\", \"an\", \"the\", \"and\", \"but\", \"or\", \"for\", \"nor\",\n   788→    \"in\", \"on\", \"at\", \"to\", \"of\", \"by\", \"with\", \"from\",\n   789→    \"z\", \"w\", \"i\", \"ze\", \"na\", \"do\", \"od\", \"za\", \"po\",\n   790→  ]);\n   791→  return text.split(/(\\s+)/).map((word, idx) => {\n   792→    if (/^\\s+$/.test(word)) return word;\n   793→    const lower = word.toLowerCase();\n   794→    if (idx === 0 || !smallWords.has(lower)) {\n   795→      return lower.charAt(0).toUpperCase() + lower.slice(1);\n   796→    }\n   797→    return lower;\n   798→  }).join(\"\");\n   799→}"}]},"parent_tool_use_id":null,"session_id":"cda1f0b1-248e-469a-8a6a-1e44556e08de","uuid":"721283c0-a7dc-41a0-be84-df5a91986cdc","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/title-extractor.ts","content":"\n  return first3.every(line =>\n    looksLikeIngredient(line) ||\n    looksLikeCookingInstruction(line) ||\n    isBodyProse(line)\n  );\n}\n\nfunction passesHardFilters(text: string): boolean {\n  if (text.length < 3 || text.length > 80) return false;\n  if (looksLikeIngredient(text)) return false;\n  if (startsWithNumber(text)) return false;\n  if (looksLikeMetadata(text)) return false;\n  if (isLikelyGarbled(text)) return false;\n  if (looksLikeCookingInstruction(text)) return false;\n  // Apply lightweight OCR normalization before a second instruction check\n  // so that \"Podaw4ć\" is recognized as \"Podawać\" (cooking instruction).\n  // Only 4→a for now — the specific OCR artifact causing failures.\n  // Uses same letter-adjacent guard logic as applyBlindOcrRepairToken.\n  const ocrNormForInstruction = text\n    .replace(/(?<=[a-zà-ż])4/g, \"a\")\n    .replace(/4(?=[a-zà-ż])/g, \"a\");\n  if (ocrNormForInstruction !== text && looksLikeCookingInstruction(ocrNormForInstruction)) return false;\n  // Pipe-separated lines are book category/chapter headers, not recipe titles\n  if (text.includes(\" | \")) return false;\n  // Trailing page number (e.g. \"VEGETABLE SIDES                         145\")\n  if (/\\s{3,}\\d{1,4}\\s*$/.test(text)) return false;\n  // Slash-separated breadcrumbs (e.g., \"/ Jesien / Zupy\") are navigation, not titles\n  // Only filter when 2+ slashes are present — single-slash lines like\n  // \"TITLE / SUBTITLE\" are legitimate continuation-merged titles\n  if ((text.match(/\\//g) || []).length >= 2) return false;\n  // Bullet-list items (ingredients or instruction steps) are never titles\n  if (/^\\s*[-•*]\\s/.test(text)) return false;\n  // \"For the sauce:\", \"For the filling:\" etc. are sub-section headers\n  if (/^For the\\s+/i.test(text) && /:\\s*$/.test(text)) return false;\n  // Lines ending with \":\" are recipe sub-section headers, not titles.\n  // Exception: compound titles using \" : \" as a title separator (e.g. \"LEMON CURD : LEMON CURD WITH THYME\").\n  if (/:\\s*$/.test(text.trim()) && !/ : /.test(text)) return false;\n  // Page references are navigation markers, not recipe titles\n  if (/^Page\\s+\\d+/i.test(text.trim())) return false;\n  if (/^Strona\\s+\\d+/i.test(text.trim())) return false;\n  // Corrupted spillover annotations from synthetic multi-page OCR\n  if (/^\\[CORRUPTED\\s+SPILLOVER/i.test(text.trim())) return false;\n  // Parenthetical OCR annotation lines describing corruption artifacts\n  if (/^\\(OCR\\b/i.test(text.trim())) return false;\n  if (/^\\(.*\\bcorruption\\b/i.test(text.trim())) return false;\n  // Square-bracket category tags (e.g., \"[CLASSIC FALL SOUPS]\")\n  if (/^\\[.*\\]$/.test(text.trim())) return false;\n  // Known recipe section labels are structural headers, not titles\n  if (isSectionLabel(text)) return false;\n  // Single-word non-title fragments\n  const words = text.trim().split(/\\s+/);\n  if (words.length === 1 && NON_TITLE_WORDS.has(text.trim().toLowerCase())) return false;\n  // Lines with ≥8 words are almost certainly body text, not titles.\n  // Exception: multi-title compounds with \" + \", \" : \", or \" & \" separators are allowed.\n  if (words.length >= 8 && !/ [+:&/] /.test(text)) return false;\n  return true;\n}\n\n/**\n * Detect initial burst of short garbled lines.\n * Returns the index of the first non-garbled or long line.\n */\nfunction findBurstEnd(lines: Array<{ text: string }>): number {\n  let i = 0;\n\n  // Skip overflow preambles: blocks introduced by \"PREVIOUS RECIPE OVERFLOW\",\n  // \"PREVIOUS PAGE CONTENT\", \"CORRUPTED SECTION\", etc. that precede the actual recipe.\n  const OVERFLOW_MARKERS = /\\b(PREVIOUS\\s+(RECIPE|PAGE)\\b|SPILLOVER|CONTINUATION|CORRUPTED\\s+(SECTION|TEXT)\\b|PARTIAL\\s+RECIPE)\\b/i;\n  let overflowEnd = 0;\n  for (let k = 0; k < lines.length && k < 30; k++) {\n    // Don't re-examine lines already determined to be overflow\n    if (overflowEnd > 0 && k < overflowEnd) continue;\n    if (OVERFLOW_MARKERS.test(lines[k].text) || /^\\[.*\\b(PREVIOUS|CORRUPTED|SPILLOVER|CONTINUATION|PARTIAL)\\b.*\\]$/i.test(lines[k].text)) {\n      // Skip forward past the overflow block to the next visual separator or blank cluster\n      let m = k + 1;\n      let consecutiveBlanks = 0;\n      while (m < lines.length) {\n        const lineText = lines[m].text;\n        // Stop at visual separator\n        if (/^[=\\-]{4,}$/.test(lineText)) {\n          overflowEnd = m + 1;\n          break;\n        }\n        // Track consecutive blank lines\n        if (lineText.trim().length === 0) {\n          consecutiveBlanks++;\n          if (consecutiveBlanks >= 2) {\n            overflowEnd = m + 1;\n            break;\n          }\n        } else {\n          consecutiveBlanks = 0;\n          // Stop at ALL_CAPS line with ≥2 words (likely next recipe heading)\n          if (isAllCaps(lineText) && wordCount(lineText) >= 2) {\n            overflowEnd = m; // Don't skip past the heading itself\n            break;\n          }\n        }\n        m++;\n      }\n      // If we walked to end without finding termination, skip everything we saw\n      if (overflowEnd === 0) overflowEnd = m;\n    }\n  }\n  if (overflowEnd > 0) i = overflowEnd;\n\n  while (i < lines.length && lines[i].text.length < 20 && isLikelyGarbled(lines[i].text) && !isAllCaps(lines[i].text)) {\n    i++;\n  }\n  // Skip body-content prologues: when 3+ consecutive lines at the start are cooking\n  // instructions, prose continuations, or a mix of both, skip them to find the actual\n  // title region. This unifies the previous separate instruction and prose checks to\n  // handle interleaved patterns (e.g., instruction → prose continuation → instruction).\n  if (i === 0) {\n    let j = 0;\n    while (j < lines.length) {\n      const t = lines[j].text;\n      const isInstruction = looksLikeCookingInstruction(t);\n      // Short body-text continuation: lowercase-start with 2+ words catches fragments\n      // like \"creamy but still al dente...\" that follow cooking instructions.\n      // Lower threshold than isBodyProse (2 vs 4 words) to handle interleaved patterns.\n      const isContinuation = /^[a-ząćęłńóśźż]/.test(t) && wordCount(t) >= 2;\n      // Non-lowercase body text: comma-ending or long sentence-ending lines\n      const isBodyEnding = (t.endsWith(\",\") || (t.endsWith(\".\") && wordCount(t) > 4)) && wordCount(t) >= 4;\n\n      if (isInstruction || isContinuation || isBodyEnding) {\n        j++;\n      } else {\n        break;\n      }\n    }\n    if (j >= 3) {\n      i = j;\n    }\n  }\n  return i;\n}\n\nfunction stripParentheticalGloss(text: string): string {\n  // Strip trailing English-gloss parentheticals from ALL_CAPS titles.\n  // e.g. \"PIEROGI RUSKIE (Boiled Dumplings with Potato and Cheese)\" → \"PIEROGI RUSKIE\"\n  // Keep if parenthetical is ALL_CAPS (variation/subtitle in same language).\n  // Keep if both base and paren are mixed-case (both are part of the title).\n  const match = text.match(/^(.+?)\\s*\\(([^)]+)\\)\\s*$/);\n  if (!match) return text;\n  const [, base, paren] = match;\n  if (isAllCaps(paren)) return text;\n  if (!isAllCaps(base) && !isAllCaps(paren)) return text;\n  return base.trim();\n}\n\nfunction stripPageNumber(text: string): string {\n  // \"34  Berry Jam\" → \"Berry Jam\" (2+ spaces distinguishes from \"2 eggs\")\n  const match = text.match(/^\\d{1,3}\\s{2,}(.+)$/);\n  return match ? match[1] : text;\n}\n\n/**\n * Strip trailing parenthesized page or step numbers.\n * \"Ugotuj ziemniaky. (38)\" → \"Ugotuj ziemniaky.\"\n * \"RECIPE NAME (p. 42)\" → \"RECIPE NAME\"\n */\nfunction stripTrailingPageRef(text: string): string {\n  return text.replace(/\\s*\\((?:p\\.?\\s*)?\\d{1,4}\\)\\s*$/, \"\").trim();\n}\n\nfunction wordCount(text: string): number {\n  return text.split(/\\s+/).filter((w) => w.length > 0).length;\n}\n\n/**\n * Build candidate strings from lines: single lines plus multi-line joins (2-3 consecutive).\n * Skips initial burst of short garbled lines. Scans all remaining lines. Caps at 25.\n */\nexport type CandidateOrigin = \"single\" | \"2-line\" | \"3-line\";\n\nfunction buildCandidates(\n  lines: Array<string>\n): { candidates: Array<{ text: string; position: number; origin: CandidateOrigin }>; burstEnd: number } {\n  const nonEmptyLines: Array<{ text: string; index: number }> = [];\n\n  for (let i = 0; i < lines.length; i++) {\n    const trimmed = lines[i].trim();\n    if (trimmed.length > 0) {\n      nonEmptyLines.push({ text: trimmed, index: i });\n    }\n  }\n\n  const burstEnd = findBurstEnd(nonEmptyLines);\n\n  // Pre-join hyphen-broken lines: \"ROASTED CHICKEN WITH ROOT VEGET-\" + \"ABLES\" → single line.\n  // Only applies within the candidate region (after burst end).\n  for (let hi = burstEnd; hi < nonEmptyLines.length - 1; hi++) {\n    if (nonEmptyLines[hi].text.endsWith(\"-\")) {\n      const joined = nonEmptyLines[hi].text.slice(0, -1) + nonEmptyLines[hi + 1].text;\n      nonEmptyLines[hi] = { text: joined, index: nonEmptyLines[hi].index };\n      nonEmptyLines.splice(hi + 1, 1);\n    }\n  }\n\n  // Pre-merge consecutive short ALL_CAPS lines (OCR-fragmented headings).\n  // When a sequence of 2+ ALL_CAPS lines each has ≤2 words and ≤25 chars, they are\n  // almost certainly OCR fragments of a single heading. Merge them into one line so\n  // the complete title enters the candidate pool without hitting the 3-line join ceiling.\n  const capsCoalesced: Array<{ text: string; index: number }> = [];\n  let ci = burstEnd;\n  while (ci < nonEmptyLines.length) {\n    const line = nonEmptyLines[ci];\n    if (\n      isAllCaps(line.text) &&\n      wordCount(line.text) <= 2 &&\n      line.text.length <= 25 &&\n      !isSectionLabel(line.text) &&\n      !looksLikeMetadata(line.text)\n    ) {\n      let merged = line.text;\n      const startIndex = line.index;\n      let j = ci + 1;\n      while (j < nonEmptyLines.length) {\n        const next = nonEmptyLines[j];\n        if (\n          isAllCaps(next.text) &&\n          wordCount(next.text) <= 2 &&\n          next.text.length <= 25 &&\n          ((!isSectionLabel(next.text) && !isSectionLabel(repairOcrText(next.text))) ||\n           (wordCount(next.text) === 1 && wordCount(merged) >= 2 && wordCount(merged) <= 4 &&\n            isCategorySectionLabel(next.text))) &&\n          !looksLikeMetadata(next.text) &&\n          (merged + \" \" + next.text).length <= 80\n        ) {\n          merged += \" \" + next.text;\n          j++;\n        } else {\n          break;\n        }\n      }\n      if (j > ci + 1) {\n        capsCoalesced.push({ text: merged, index: startIndex });\n        ci = j;\n        continue;\n      }\n    }\n    capsCoalesced.push(line);\n    ci++;\n  }\n\n  // Pre-merge continuation lines: a line starting with /&+:( is never a standalone title.\n  // Merge it into the preceding line so the complete title enters the pool as a single candidate,\n  // avoiding the fragile chain of conditions required by the downstream join survival logic.\n  // Limitation: only one continuation line per preceding line is merged. Titles split across\n  // three or more lines with continuation tokens (rare in practice) are not handled here —\n  // the downstream 2-line and 3-line join candidates cover those cases instead.\n  const mergedLines: Array<{ text: string; index: number }> = [];\n  for (let i = 0; i < capsCoalesced.length; i++) {\n    const line = capsCoalesced[i];\n    mergedLines.push(line);  // always keep the original standalone\n    if (i + 1 < capsCoalesced.length) {\n      const nextText = capsCoalesced[i + 1].text;\n      if (/^[/&+:(]/.test(nextText)) {\n        mergedLines.push({ text: `${line.text} ${nextText}`, index: line.index });\n        i++;\n        continue;\n      }\n    }\n  }\n\n  const candidates: Array<{ text: string; position: number; origin: CandidateOrigin }> = [];\n  const seen = new Set<string>();\n\n  // Build a set of positions to skip: short ALL_CAPS lines immediately following metadata\n  const metadataContinuationPositions = new Set<number>();\n  for (let i = 0; i < mergedLines.length - 1; i++) {\n    if (looksLikeMetadata(mergedLines[i].text)) {\n      const next = mergedLines[i + 1];\n      if (isAllCaps(next.text) && wordCount(next.text) <= 2 && next.text.length <= 15) {\n        metadataContinuationPositions.add(next.index);\n      }\n    }\n  }\n\n  for (let i = 0; i < mergedLines.length; i++) {\n    const line = mergedLines[i];\n\n    // Skip metadata continuation fragments\n    if (metadataContinuationPositions.has(line.index)) continue;\n\n    // Single line — strip page-number prefixes and parenthetical glosses before scoring\n    const singleText = repairOcrText(stripParentheticalGloss(stripTrailingPageRef(stripPageNumber(line.text))));\n    if (passesHardFilters(singleText)) {\n      const norm = singleText.toLowerCase();\n      if (!seen.has(norm)) {\n        seen.add(norm);\n        candidates.push({ text: singleText, position: line.index, origin: \"single\" });\n      }\n    }\n\n    // Blind OCR repair for early-position candidates: when the original text\n    // has OCR artifacts or erratic casing and is in the first few lines,\n    // generate additional candidates with blind digit→letter repair and/or\n    // casing normalization. This gives the embedding scorer clean versions\n    // even when dictionary repair misses.\n    if (line.index <= 5) {\n      const hasOcrArtifact = OCR_ARTIFACT_PATTERN.test(line.text);\n      const lineHasErraticCasing = hasErraticCasing(line.text);\n      if (hasOcrArtifact || lineHasErraticCasing) {\n        let repairable = singleText;\n        if (lineHasErraticCasing) {\n          repairable = normalizeErraticCasing(repairable);\n          if (repairable !== singleText && passesHardFilters(repairable)) {\n            const norm = repairable.toLowerCase();\n            if (!seen.has(norm)) {\n              seen.add(norm);\n              candidates.push({ text: repairable, position: line.index, origin: \"single\" });\n            }\n          }\n        }\n        const variants = generateBlindOcrVariants(repairable);\n        for (const variant of variants) {\n          if (passesHardFilters(variant)) {\n            const norm = variant.toLowerCase();\n            if (!seen.has(norm)) {\n              seen.add(norm);\n              candidates.push({ text: variant, position: line.index, origin: \"single\" });\n            }\n          }\n        }\n      }\n    }\n\n    // 2-line join — skip if first line is a section label AND join would be ≤2 words\n    // (a section label followed by modifiers is likely a recipe title, not a category header)\n    // Also skip if the next line is metadata (e.g. serving size \"DLA & OSOB\").\n    if (i + 1 < mergedLines.length && !looksLikeMetadata(mergedLines[i + 1].text)) {\n      const joined2 = repairOcrText(`${line.text} ${mergedLines[i + 1].text}`);\n      const shouldBlock2 = isSectionLabel(line.text) &&\n        (wordCount(joined2) <= 2 || isAlwaysBlockJoinLabel(line.text));\n      if (!shouldBlock2 && passesHardFilters(joined2)) {\n        const norm = joined2.toLowerCase();\n        if (!seen.has(norm)) {\n          seen.add(norm);\n          candidates.push({ text: joined2, position: line.index, origin: \"2-line\" });\n        }\n      }\n    }\n\n    // 3-line join — skip if first line is a section label AND join would be ≤2 words.\n    // Also skip if any continuation line is metadata.\n    if (i + 2 < mergedLines.length &&\n        !looksLikeMetadata(mergedLines[i + 1].text) &&\n        !looksLikeMetadata(mergedLines[i + 2].text)) {\n      const joined3 = repairOcrText(`${line.text} ${mergedLines[i + 1].text} ${mergedLines[i + 2].text}`);\n      const shouldBlock3 = isSectionLabel(line.text) &&\n        (wordCount(joined3) <= 2 || isAlwaysBlockJoinLabel(line.text));\n      if (!shouldBlock3 && passesHardFilters(joined3)) {\n        const norm = joined3.toLowerCase();\n        if (!seen.has(norm)) {\n          seen.add(norm);\n          candidates.push({ text: joined3, position: line.index, origin: \"3-line\" });\n        }\n      }\n    }\n  }\n\n  // Pre-filter to 25 before embedding calls: prefer ALL_CAPS and short candidates.\n  // Position-based scoring handles final ranking.\n  if (candidates.length > 25) {\n    const prioritized = candidates.slice().sort((a, b) => {\n      const aAllCaps = isAllCaps(a.text) ? 0 : 1;\n      const bAllCaps = isAllCaps(b.text) ? 0 : 1;\n      if (aAllCaps !== bAllCaps) return aAllCaps - bAllCaps;\n      const aShort = wordCount(a.text) <= 5 ? 0 : 1;\n      const bShort = wordCount(b.text) <= 5 ? 0 : 1;\n      return aShort - bShort;\n    });\n    return { candidates: prioritized.slice(0, 25), burstEnd: nonEmptyLines[burstEnd]?.index ?? lines.length };\n  }\n\n  return { candidates, burstEnd: nonEmptyLines[burstEnd]?.index ?? lines.length };\n}\n\n/**\n * Convert an ALL_CAPS string to Title Case, using a small-words list.\n * Preserves Polish/French diacritics.\n */\nfunction toTitleCase(text: string): string {\n  const smallWords = new Set([\n    \"a\", \"an\", \"the\", \"and\", \"but\", \"or\", \"for\", \"nor\",\n    \"in\", \"on\", \"at\", \"to\", \"of\", \"by\", \"with\", \"from\",\n    \"z\", \"w\", \"i\", \"ze\", \"na\", \"do\", \"od\", \"za\", \"po\",\n  ]);\n  return text.split(/(\\s+)/).map((word, idx) => {\n    if (/^\\s+$/.test(word)) return word;\n    const lower = word.toLowerCase();\n    if (idx === 0 || !smallWords.has(lower)) {\n      return lower.charAt(0).toUpperCase() + lower.slice(1);\n    }\n    return lower;\n  }).join(\"\");\n}","numLines":400,"startLine":400,"totalLines":1752}}}
