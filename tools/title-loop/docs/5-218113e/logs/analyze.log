{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Mqu2yktCBwRu5UdGQBsnyr","type":"tool_result","content":"     1→/**\n     2→ * Title Extraction\n     3→ * Extracts potential recipe title from OCR text using heuristics or semantic embeddings\n     4→ */\n     5→\n     6→import { cosineSimilarity } from \"./embeddings\";\n     7→\n     8→export type EmbedFn = (text: string) => Promise<Array<number>>;\n     9→\n    10→const TITLE_REFERENCE =\n    11→  \"recipe name, dish title, name of the food, nazwa przepisu, nazwa dania\";\n    12→const HEADER_REFERENCE =\n    13→  \"ingredients list, cooking directions, section heading, składniki, przygotowanie, sposób wykonania\";\n    14→const NOISE_REFERENCE =\n    15→  \"page number, table of contents, book footer, garbled text\";\n    16→\n    17→/**\n    18→ * Measurement units commonly found in ingredient lists\n    19→ */\n    20→const MEASUREMENT_PATTERNS = [\n    21→  \"cup\",\n    22→  \"cups\",\n    23→  \"tbsp\",\n    24→  \"tsp\",\n    25→  \"tablespoon\",\n    26→  \"teaspoon\",\n    27→  \"oz\",\n    28→  \"lb\",\n    29→  \"gram\",\n    30→  \"grams\",\n    31→  \"kg\",\n    32→  \"ml\",\n    33→  \"liter\",\n    34→  \"pinch\",\n    35→  \"dash\",\n    36→  \"handful\",\n    37→];\n    38→\n    39→/**\n    40→ * Patterns that identify recipe metadata lines (not titles)\n    41→ */\n    42→const METADATA_PATTERNS = [\n    43→  /^(SERVES?|MAKES?|YIELDS?)\\b/i,\n    44→  /^(PREP(ARATION)?|COOK(ING)?|PROOF|RISING|FERMENTATION|REST(ING)?)\\s*(AND\\s*)?(COOK(ING)?)?\\s*TIME/i,\n    45→  /^SAMPLE\\s+SCHEDULE\\b/i,\n    46→  /^BULK\\s+FERMENTATION\\b/i,\n    47→  /^(THIS\\s+RECIPE\\s+)?MAKES\\b/i,\n    48→];\n    49→\n    50→/**\n    51→ * Single-word non-title words — standalone OCR fragments unlikely to be recipe titles\n    52→ */\n    53→const NON_TITLE_WORDS = new Set([\n    54→  \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"are\", \"was\",\n    55→  \"has\", \"his\", \"her\", \"its\", \"our\", \"who\", \"how\", \"may\", \"new\", \"now\",\n    56→  \"old\", \"see\", \"way\", \"did\", \"get\", \"let\", \"say\", \"she\", \"too\", \"use\",\n    57→  \"buns\", \"with\",\n    58→]);\n    59→\n    60→function looksLikeIngredient(line: string): boolean {\n    61→  const lowerLine = line.toLowerCase();\n    62→  return MEASUREMENT_PATTERNS.some((pattern) => lowerLine.includes(pattern));\n    63→}\n    64→\n    65→function startsWithNumber(line: string): boolean {\n    66→  return /^\\s*\\d/.test(line);\n    67→}\n    68→\n    69→function isAllCaps(line: string): boolean {\n    70→  const letters = line.replace(/[^a-zA-Z]/g, \"\");\n    71→  return letters.length > 0 && letters === letters.toUpperCase();\n    72→}\n    73→\n    74→function looksLikeMetadata(text: string): boolean {\n    75→  return METADATA_PATTERNS.some((pattern) => pattern.test(text.trim()));\n    76→}\n    77→\n    78→function isLikelyGarbled(text: string): boolean {\n    79→  const letters = text.replace(/[^a-zA-Z]/g, \"\");\n    80→  if (letters.length < 2) return true;\n    81→\n    82→  // Check vowel ratio — English/Polish text typically has 30–50% vowels\n    83→  const vowels = letters.replace(/[^aeiouAEIOUyYąęóĄĘÓ]/g, \"\").length;\n    84→  const vowelRatio = vowels / letters.length;\n    85→  if (vowelRatio < 0.15 || vowelRatio > 0.85) return true;\n    86→\n    87→  // Single orphaned word ≤3 letters that isn't a common word\n    88→  const words = text.trim().split(/\\s+/);\n    89→  const COMMON_SHORT = new Set([\n    90→    \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"had\", \"her\",\n    91→    \"was\", \"one\", \"our\", \"out\", \"are\", \"has\", \"his\", \"how\", \"its\", \"may\",\n    92→    \"new\", \"now\", \"old\", \"see\", \"way\", \"who\", \"did\", \"get\", \"let\", \"say\",\n    93→    \"she\", \"too\", \"use\",\n    94→  ]);\n    95→  if (words.length === 1 && letters.length <= 3 && !COMMON_SHORT.has(text.trim().toLowerCase())) {\n    96→    return true;\n    97→  }\n    98→\n    99→  // Recipe titles never start with a lowercase letter\n   100→  if (/^[a-z]/.test(text.trim())) {\n   101→    return true;\n   102→  }\n   103→\n   104→  // Mid-text sentence boundary (\". \" followed by a letter) — body text fragment spliced from multiple sentences\n   105→  const trimmed = text.trim();\n   106→  if (/\\.\\s+[a-zA-Z]/.test(trimmed) && !trimmed.endsWith(\")\")) {\n   107→    return true;\n   108→  }\n   109→\n   110→  // Multi-word candidate containing a garbled OCR fragment: a short lowercase word that isn't a known short word\n   111→  if (words.length >= 2) {\n   112→    const commonShort2 = new Set([\n   113→      \"a\", \"i\", \"of\", \"or\", \"to\", \"in\", \"on\", \"is\", \"it\", \"an\",\n   114→      \"as\", \"at\", \"by\", \"do\", \"go\", \"if\", \"no\", \"so\", \"up\", \"we\",\n   115→      \"w\", \"z\",  // Polish prepositions\n   116→    ]);\n   117→    const hasGarbledWord = words.some(\n   118→      (w) =>\n   119→        /^[a-z]/.test(w) &&\n   120→        w.replace(/[^a-z]/g, \"\").length <= 2 &&\n   121→        !commonShort2.has(w.toLowerCase())\n   122→    );\n   123→    if (hasGarbledWord) {\n   124→      return true;\n   125→    }\n   126→  }\n   127→\n   128→  return false;\n   129→}\n   130→\n   131→function passesHardFilters(text: string): boolean {\n   132→  if (text.length < 3 || text.length > 80) return false;\n   133→  if (looksLikeIngredient(text)) return false;\n   134→  if (startsWithNumber(text)) return false;\n   135→  if (looksLikeMetadata(text)) return false;\n   136→  if (isLikelyGarbled(text)) return false;\n   137→  // Single-word non-title fragments\n   138→  const words = text.trim().split(/\\s+/);\n   139→  if (words.length === 1 && NON_TITLE_WORDS.has(text.trim().toLowerCase())) return false;\n   140→  return true;\n   141→}\n   142→\n   143→/**\n   144→ * Detect initial burst of short garbled lines.\n   145→ * Returns the index of the first non-garbled or long line.\n   146→ */\n   147→function findBurstEnd(lines: Array<{ text: string }>): number {\n   148→  let i = 0;\n   149→  while (i < lines.length && lines[i].text.length < 20 && isLikelyGarbled(lines[i].text)) {\n   150→    i++;\n   151→  }\n   152→  return i;\n   153→}\n   154→\n   155→function wordCount(text: string): number {\n   156→  return text.split(/\\s+/).filter((w) => w.length > 0).length;\n   157→}\n   158→\n   159→/**\n   160→ * Build candidate strings from lines: single lines plus multi-line joins (2-3 consecutive).\n   161→ * Skips initial burst of short garbled lines. Scans all remaining lines. Caps at 25.\n   162→ */\n   163→function buildCandidates(\n   164→  lines: Array<string>\n   165→): Array<{ text: string; position: number }> {\n   166→  const nonEmptyLines: Array<{ text: string; index: number }> = [];\n   167→\n   168→  for (let i = 0; i < lines.length; i++) {\n   169→    const trimmed = lines[i].trim();\n   170→    if (trimmed.length > 0) {\n   171→      nonEmptyLines.push({ text: trimmed, index: i });\n   172→    }\n   173→  }\n   174→\n   175→  const burstEnd = findBurstEnd(nonEmptyLines);\n   176→  const candidates: Array<{ text: string; position: number }> = [];\n   177→  const seen = new Set<string>();\n   178→\n   179→  for (let i = burstEnd; i < nonEmptyLines.length; i++) {\n   180→    const line = nonEmptyLines[i];\n   181→\n   182→    // Single line\n   183→    if (passesHardFilters(line.text)) {\n   184→      const norm = line.text.toLowerCase();\n   185→      if (!seen.has(norm)) {\n   186→        seen.add(norm);\n   187→        candidates.push({ text: line.text, position: line.index });\n   188→      }\n   189→    }\n   190→\n   191→    // 2-line join\n   192→    if (i + 1 < nonEmptyLines.length) {\n   193→      const joined2 = `${line.text} ${nonEmptyLines[i + 1].text}`;\n   194→      if (passesHardFilters(joined2)) {\n   195→        const norm = joined2.toLowerCase();\n   196→        if (!seen.has(norm)) {\n   197→          seen.add(norm);\n   198→          candidates.push({ text: joined2, position: line.index });\n   199→        }\n   200→      }\n   201→    }\n   202→\n   203→    // 3-line join\n   204→    if (i + 2 < nonEmptyLines.length) {\n   205→      const joined3 = `${line.text} ${nonEmptyLines[i + 1].text} ${nonEmptyLines[i + 2].text}`;\n   206→      if (passesHardFilters(joined3)) {\n   207→        const norm = joined3.toLowerCase();\n   208→        if (!seen.has(norm)) {\n   209→          seen.add(norm);\n   210→          candidates.push({ text: joined3, position: line.index });\n   211→        }\n   212→      }\n   213→    }\n   214→  }\n   215→\n   216→  // Pre-filter to 25 before embedding calls: prefer ALL_CAPS and short candidates.\n   217→  // Position-based scoring handles final ranking.\n   218→  if (candidates.length > 25) {\n   219→    const prioritized = candidates.slice().sort((a, b) => {\n   220→      const aAllCaps = isAllCaps(a.text) ? 0 : 1;\n   221→      const bAllCaps = isAllCaps(b.text) ? 0 : 1;\n   222→      if (aAllCaps !== bAllCaps) return aAllCaps - bAllCaps;\n   223→      const aShort = wordCount(a.text) <= 5 ? 0 : 1;\n   224→      const bShort = wordCount(b.text) <= 5 ? 0 : 1;\n   225→      return aShort - bShort;\n   226→    });\n   227→    return prioritized.slice(0, 25);\n   228→  }\n   229→\n   230→  return candidates;\n   231→}\n   232→\n   233→// Module-level cache for reference embeddings\n   234→let cachedTitleRefEmbedding: Array<number> | null = null;\n   235→let cachedHeaderRefEmbedding: Array<number> | null = null;\n   236→let cachedNoiseRefEmbedding: Array<number> | null = null;\n   237→\n   238→export function _resetEmbeddingCacheForTests(): void {\n   239→  cachedTitleRefEmbedding = null;\n   240→  cachedHeaderRefEmbedding = null;\n   241→  cachedNoiseRefEmbedding = null;\n   242→}\n   243→\n   244→export async function extractTitleWithEmbeddings(\n   245→  text: string,\n   246→  embed: EmbedFn\n   247→): Promise<string | undefined> {\n   248→  if (!text || text.trim().length === 0) {\n   249→    return undefined;\n   250→  }\n   251→\n   252→  const lines = text.split(\"\\n\");\n   253→  const candidates = buildCandidates(lines);\n   254→\n   255→  if (candidates.length === 0) {\n   256→    return undefined;\n   257→  }\n   258→\n   259→  // Cache reference embeddings\n   260→  if (!cachedTitleRefEmbedding) {\n   261→    cachedTitleRefEmbedding = await embed(TITLE_REFERENCE);\n   262→  }\n   263→  if (!cachedHeaderRefEmbedding) {\n   264→    cachedHeaderRefEmbedding = await embed(HEADER_REFERENCE);\n   265→  }\n   266→  if (!cachedNoiseRefEmbedding) {\n   267→    cachedNoiseRefEmbedding = await embed(NOISE_REFERENCE);\n   268→  }\n   269→\n   270→  // Find the first ALL_CAPS candidate with ≥2 words where every significant word has ≥4 alpha letters.\n   271→  // Insignificant tokens (≤1 alpha letter: \"/\", \"&\", \"+\", \":\", \"D)\", etc.) are filtered before\n   272→  // the check so that multi-line joins with continuation punctuation still qualify.\n   273→  const isStructuralHeading = (c: { text: string }): boolean => {\n   274→    if (!isAllCaps(c.text) || wordCount(c.text) < 2) return false;\n   275→    const sigWords = c.text.trim().split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length > 1);\n   276→    return sigWords.length >= 2 && sigWords.every((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   277→  };\n   278→  const baseHeading = candidates.find(isStructuralHeading);\n   279→  // When the initial heading has a continuation on the next line introduced by a punctuation token\n   280→  // (/, &, +, :, or parenthesis), prefer the longer 2-line join as the complete heading.\n   281→  // E.g. \"SAFFRON WHEAT BUNS WITH QUARK\" + \"/ COTTAGE CHEESE (VARIATION D)\" → prefers the join.\n   282→  // Guard: the remainder after the prefix must start with a continuation character to avoid\n   283→  // merging two separate consecutive recipe titles (FINNISH MILK FLATBREADS stays separate\n   284→  // from FINNISH POTATO FLATBREADS because \"FINNISH\" does not start with a continuation token).\n   285→  const firstStructuralHeading = baseHeading && (\n   286→    candidates.find((c) => {\n   287→      if (!isStructuralHeading(c)) return false;\n   288→      const hLower = baseHeading.text.toLowerCase();\n   289→      const cLower = c.text.toLowerCase();\n   290→      return cLower.startsWith(hLower + \" \") && /^[/&+:(]/.test(cLower.slice(hLower.length + 1));\n   291→    }) ?? baseHeading\n   292→  );\n   293→\n   294→  const scored: Array<{ text: string; position: number; score: number; rawScore: number; baseScore: number }> = [];\n   295→\n   296→  for (const candidate of candidates) {\n   297→    const embedding = await embed(candidate.text);\n   298→    const titleSim = cosineSimilarity(embedding, cachedTitleRefEmbedding);\n   299→    const headerSim = cosineSimilarity(embedding, cachedHeaderRefEmbedding);\n   300→    const noiseSim = cosineSimilarity(embedding, cachedNoiseRefEmbedding);\n   301→    const rawScore = titleSim - Math.max(headerSim, noiseSim);\n   302→\n   303→    // Position factor: multiplicative tiebreaker — amplifies existing signal, doesn't replace it\n   304→    const relativePosition = candidate.position / lines.length;\n   305→    const positionFactor = relativePosition < 0.5\n   306→      ? 1.0 + 0.12 * (1 - relativePosition * 2)\n   307→      : 1.0;\n   308→\n   309→    // ALL_CAPS bonus: recipe books use ALL_CAPS for titles and section headings\n   310→    const allCapsBonus = isAllCaps(candidate.text) && candidate.text.replace(/[^a-zA-Z]/g, \"\").length >= 4\n   311→      ? 0.08\n   312→      : 0;\n   313→\n   314→    // Structural heading bonus: first clean ALL_CAPS heading is almost always the recipe title\n   315→    const structuralBonus =\n   316→      firstStructuralHeading && candidate === firstStructuralHeading ? 0.10 : 0;\n   317→\n   318→    // baseScore excludes position factor — used for threshold so position boost on the first\n   319→    // title doesn't inflate the bar and exclude valid later titles on multi-recipe pages\n   320→    const baseScore = rawScore + allCapsBonus + structuralBonus;\n   321→    const score = rawScore * positionFactor + allCapsBonus + structuralBonus;\n   322→    scored.push({ text: candidate.text, position: candidate.position, score, rawScore, baseScore });\n   323→  }\n   324→\n   325→  if (scored.length === 0) {\n   326→    return undefined;\n   327→  }\n   328→\n   329→  // Use position-free baseScore for threshold so position boost on the first title doesn't\n   330→  // inflate the bar and exclude valid later titles on multi-recipe pages.\n   331→  const bestBaseScore = Math.max(...scored.map((s) => s.baseScore));\n   332→  const threshold = Math.max(0.08, bestBaseScore * 0.7);\n   333→\n   334→  // Filter candidates above threshold\n   335→  let selected = scored.filter((s) => s.score >= threshold);\n   336→\n   337→  // Remove word-boundary prefixes of firstStructuralHeading when the heading itself survived\n   338→  // the threshold. Cases:\n   339→  //   ARAYES case:  firstStructuralHeading = \"ARAYES SHRAK\" (2-word join qualifies; \"ARAYES\"\n   340→  //     alone = 1 word, so it never qualified). Filter removes \"ARAYES\" so dedup keeps the join.\n   341→  //   SAFFRON case: baseHeading was the partial line; continuation logic above upgraded\n   342→  //     firstStructuralHeading to the full join. Filter removes the partial so dedup keeps join.\n   343→  // Safety: only fires when the complete heading itself is in selected (passed the threshold).\n   344→  if (firstStructuralHeading && selected.some((s) => s.text === firstStructuralHeading.text)) {\n   345→    const fshLower = firstStructuralHeading.text.toLowerCase();\n   346→    selected = selected.filter((s) => {\n   347→      if (s.text === firstStructuralHeading.text) return true;\n   348→      const sLower = s.text.toLowerCase();\n   349→      // Remove s if it is a space-delimited prefix of the structural heading\n   350→      return !fshLower.startsWith(sLower + \" \");\n   351→    });\n   352→  }\n   353→\n   354→  // Deduplicate: if one title is a substring of another, keep the shorter (more focused) one.\n   355→  // DO NOT CHANGE THIS LOGIC — it has been incorrectly \"improved\" by the title-loop 5 times.\n   356→  // The tests require shorter wins: \"Pierogi Ruskie\" over \"Pierogi Ruskie 200g mąki 3 ziemniaki\".\n   357→  // The pre-filter above handles the conflicting case (structural heading prefix removal) so that\n   358→  // the incomplete prefix line is never present here when the complete join is in selected.\n   359→  selected = selected.filter((a) => {\n   360→    const aLower = a.text.toLowerCase();\n   361→    return !selected.some(\n   362→      (b) =>\n   363→        b !== a &&\n   364→        aLower.includes(b.text.toLowerCase()) &&\n   365→        b.text.length < a.text.length\n   366→    );\n   367→  });\n   368→\n   369→  // Multi-title guard: only join multiple candidates with \"+\" when there is\n   370→  // structural evidence of a multi-recipe page (≥2 ALL_CAPS headings).\n   371→  // A single ALL_CAPS title among mixed-case survivors is a single-recipe page —\n   372→  // collapse to the highest-scoring candidate.\n   373→  // Zero ALL_CAPS survivors → mixed-case multi-title page → keep all.\n   374→  if (selected.length > 1) {\n   375→    const allCapsSelected = selected.filter((s) => isAllCaps(s.text));\n   376→    if (allCapsSelected.length >= 2) {\n   377→      selected = allCapsSelected;\n   378→    } else if (allCapsSelected.length === 1) {\n   379→      selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n   380→    }\n   381→  }\n   382→\n   383→  // Cap at 3, sort by document position\n   384→  selected.sort((a, b) => a.position - b.position);\n   385→  selected = selected.slice(0, 3);\n   386→\n   387→  if (selected.length === 0) {\n   388→    return undefined;\n   389→  }\n   390→\n   391→  return selected.map((s) => s.text).join(\" + \");\n   392→}\n   393→\n   394→/**\n   395→ * Extract potential recipe title from OCR text (sync heuristic fallback)\n   396→ */\n   397→export function extractTitle(text: string): string | undefined {\n   398→  if (!text || text.trim().length === 0) {\n   399→    return undefined;\n   400→  }\n   401→\n   402→  const lines = text.split(\"\\n\").map((line) => line.trim());\n   403→\n   404→  for (const line of lines) {\n   405→    if (line.length === 0) continue;\n   406→    if (line.length < 3 || line.length > 50) continue;\n   407→    if (looksLikeIngredient(line)) continue;\n   408→    if (isAllCaps(line)) continue;\n   409→    if (startsWithNumber(line)) continue;\n   410→    return line;\n   411→  }\n   412→\n   413→  return undefined;\n   414→}\n   415→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"89da370b-71e2-4fdf-ac53-b3797a019eb5","uuid":"da88f1a0-0b55-4516-9dcc-03d8a52f9bb1","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/title-extractor.ts","content":"/**\n * Title Extraction\n * Extracts potential recipe title from OCR text using heuristics or semantic embeddings\n */\n\nimport { cosineSimilarity } from \"./embeddings\";\n\nexport type EmbedFn = (text: string) => Promise<Array<number>>;\n\nconst TITLE_REFERENCE =\n  \"recipe name, dish title, name of the food, nazwa przepisu, nazwa dania\";\nconst HEADER_REFERENCE =\n  \"ingredients list, cooking directions, section heading, składniki, przygotowanie, sposób wykonania\";\nconst NOISE_REFERENCE =\n  \"page number, table of contents, book footer, garbled text\";\n\n/**\n * Measurement units commonly found in ingredient lists\n */\nconst MEASUREMENT_PATTERNS = [\n  \"cup\",\n  \"cups\",\n  \"tbsp\",\n  \"tsp\",\n  \"tablespoon\",\n  \"teaspoon\",\n  \"oz\",\n  \"lb\",\n  \"gram\",\n  \"grams\",\n  \"kg\",\n  \"ml\",\n  \"liter\",\n  \"pinch\",\n  \"dash\",\n  \"handful\",\n];\n\n/**\n * Patterns that identify recipe metadata lines (not titles)\n */\nconst METADATA_PATTERNS = [\n  /^(SERVES?|MAKES?|YIELDS?)\\b/i,\n  /^(PREP(ARATION)?|COOK(ING)?|PROOF|RISING|FERMENTATION|REST(ING)?)\\s*(AND\\s*)?(COOK(ING)?)?\\s*TIME/i,\n  /^SAMPLE\\s+SCHEDULE\\b/i,\n  /^BULK\\s+FERMENTATION\\b/i,\n  /^(THIS\\s+RECIPE\\s+)?MAKES\\b/i,\n];\n\n/**\n * Single-word non-title words — standalone OCR fragments unlikely to be recipe titles\n */\nconst NON_TITLE_WORDS = new Set([\n  \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"are\", \"was\",\n  \"has\", \"his\", \"her\", \"its\", \"our\", \"who\", \"how\", \"may\", \"new\", \"now\",\n  \"old\", \"see\", \"way\", \"did\", \"get\", \"let\", \"say\", \"she\", \"too\", \"use\",\n  \"buns\", \"with\",\n]);\n\nfunction looksLikeIngredient(line: string): boolean {\n  const lowerLine = line.toLowerCase();\n  return MEASUREMENT_PATTERNS.some((pattern) => lowerLine.includes(pattern));\n}\n\nfunction startsWithNumber(line: string): boolean {\n  return /^\\s*\\d/.test(line);\n}\n\nfunction isAllCaps(line: string): boolean {\n  const letters = line.replace(/[^a-zA-Z]/g, \"\");\n  return letters.length > 0 && letters === letters.toUpperCase();\n}\n\nfunction looksLikeMetadata(text: string): boolean {\n  return METADATA_PATTERNS.some((pattern) => pattern.test(text.trim()));\n}\n\nfunction isLikelyGarbled(text: string): boolean {\n  const letters = text.replace(/[^a-zA-Z]/g, \"\");\n  if (letters.length < 2) return true;\n\n  // Check vowel ratio — English/Polish text typically has 30–50% vowels\n  const vowels = letters.replace(/[^aeiouAEIOUyYąęóĄĘÓ]/g, \"\").length;\n  const vowelRatio = vowels / letters.length;\n  if (vowelRatio < 0.15 || vowelRatio > 0.85) return true;\n\n  // Single orphaned word ≤3 letters that isn't a common word\n  const words = text.trim().split(/\\s+/);\n  const COMMON_SHORT = new Set([\n    \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"had\", \"her\",\n    \"was\", \"one\", \"our\", \"out\", \"are\", \"has\", \"his\", \"how\", \"its\", \"may\",\n    \"new\", \"now\", \"old\", \"see\", \"way\", \"who\", \"did\", \"get\", \"let\", \"say\",\n    \"she\", \"too\", \"use\",\n  ]);\n  if (words.length === 1 && letters.length <= 3 && !COMMON_SHORT.has(text.trim().toLowerCase())) {\n    return true;\n  }\n\n  // Recipe titles never start with a lowercase letter\n  if (/^[a-z]/.test(text.trim())) {\n    return true;\n  }\n\n  // Mid-text sentence boundary (\". \" followed by a letter) — body text fragment spliced from multiple sentences\n  const trimmed = text.trim();\n  if (/\\.\\s+[a-zA-Z]/.test(trimmed) && !trimmed.endsWith(\")\")) {\n    return true;\n  }\n\n  // Multi-word candidate containing a garbled OCR fragment: a short lowercase word that isn't a known short word\n  if (words.length >= 2) {\n    const commonShort2 = new Set([\n      \"a\", \"i\", \"of\", \"or\", \"to\", \"in\", \"on\", \"is\", \"it\", \"an\",\n      \"as\", \"at\", \"by\", \"do\", \"go\", \"if\", \"no\", \"so\", \"up\", \"we\",\n      \"w\", \"z\",  // Polish prepositions\n    ]);\n    const hasGarbledWord = words.some(\n      (w) =>\n        /^[a-z]/.test(w) &&\n        w.replace(/[^a-z]/g, \"\").length <= 2 &&\n        !commonShort2.has(w.toLowerCase())\n    );\n    if (hasGarbledWord) {\n      return true;\n    }\n  }\n\n  return false;\n}\n\nfunction passesHardFilters(text: string): boolean {\n  if (text.length < 3 || text.length > 80) return false;\n  if (looksLikeIngredient(text)) return false;\n  if (startsWithNumber(text)) return false;\n  if (looksLikeMetadata(text)) return false;\n  if (isLikelyGarbled(text)) return false;\n  // Single-word non-title fragments\n  const words = text.trim().split(/\\s+/);\n  if (words.length === 1 && NON_TITLE_WORDS.has(text.trim().toLowerCase())) return false;\n  return true;\n}\n\n/**\n * Detect initial burst of short garbled lines.\n * Returns the index of the first non-garbled or long line.\n */\nfunction findBurstEnd(lines: Array<{ text: string }>): number {\n  let i = 0;\n  while (i < lines.length && lines[i].text.length < 20 && isLikelyGarbled(lines[i].text)) {\n    i++;\n  }\n  return i;\n}\n\nfunction wordCount(text: string): number {\n  return text.split(/\\s+/).filter((w) => w.length > 0).length;\n}\n\n/**\n * Build candidate strings from lines: single lines plus multi-line joins (2-3 consecutive).\n * Skips initial burst of short garbled lines. Scans all remaining lines. Caps at 25.\n */\nfunction buildCandidates(\n  lines: Array<string>\n): Array<{ text: string; position: number }> {\n  const nonEmptyLines: Array<{ text: string; index: number }> = [];\n\n  for (let i = 0; i < lines.length; i++) {\n    const trimmed = lines[i].trim();\n    if (trimmed.length > 0) {\n      nonEmptyLines.push({ text: trimmed, index: i });\n    }\n  }\n\n  const burstEnd = findBurstEnd(nonEmptyLines);\n  const candidates: Array<{ text: string; position: number }> = [];\n  const seen = new Set<string>();\n\n  for (let i = burstEnd; i < nonEmptyLines.length; i++) {\n    const line = nonEmptyLines[i];\n\n    // Single line\n    if (passesHardFilters(line.text)) {\n      const norm = line.text.toLowerCase();\n      if (!seen.has(norm)) {\n        seen.add(norm);\n        candidates.push({ text: line.text, position: line.index });\n      }\n    }\n\n    // 2-line join\n    if (i + 1 < nonEmptyLines.length) {\n      const joined2 = `${line.text} ${nonEmptyLines[i + 1].text}`;\n      if (passesHardFilters(joined2)) {\n        const norm = joined2.toLowerCase();\n        if (!seen.has(norm)) {\n          seen.add(norm);\n          candidates.push({ text: joined2, position: line.index });\n        }\n      }\n    }\n\n    // 3-line join\n    if (i + 2 < nonEmptyLines.length) {\n      const joined3 = `${line.text} ${nonEmptyLines[i + 1].text} ${nonEmptyLines[i + 2].text}`;\n      if (passesHardFilters(joined3)) {\n        const norm = joined3.toLowerCase();\n        if (!seen.has(norm)) {\n          seen.add(norm);\n          candidates.push({ text: joined3, position: line.index });\n        }\n      }\n    }\n  }\n\n  // Pre-filter to 25 before embedding calls: prefer ALL_CAPS and short candidates.\n  // Position-based scoring handles final ranking.\n  if (candidates.length > 25) {\n    const prioritized = candidates.slice().sort((a, b) => {\n      const aAllCaps = isAllCaps(a.text) ? 0 : 1;\n      const bAllCaps = isAllCaps(b.text) ? 0 : 1;\n      if (aAllCaps !== bAllCaps) return aAllCaps - bAllCaps;\n      const aShort = wordCount(a.text) <= 5 ? 0 : 1;\n      const bShort = wordCount(b.text) <= 5 ? 0 : 1;\n      return aShort - bShort;\n    });\n    return prioritized.slice(0, 25);\n  }\n\n  return candidates;\n}\n\n// Module-level cache for reference embeddings\nlet cachedTitleRefEmbedding: Array<number> | null = null;\nlet cachedHeaderRefEmbedding: Array<number> | null = null;\nlet cachedNoiseRefEmbedding: Array<number> | null = null;\n\nexport function _resetEmbeddingCacheForTests(): void {\n  cachedTitleRefEmbedding = null;\n  cachedHeaderRefEmbedding = null;\n  cachedNoiseRefEmbedding = null;\n}\n\nexport async function extractTitleWithEmbeddings(\n  text: string,\n  embed: EmbedFn\n): Promise<string | undefined> {\n  if (!text || text.trim().length === 0) {\n    return undefined;\n  }\n\n  const lines = text.split(\"\\n\");\n  const candidates = buildCandidates(lines);\n\n  if (candidates.length === 0) {\n    return undefined;\n  }\n\n  // Cache reference embeddings\n  if (!cachedTitleRefEmbedding) {\n    cachedTitleRefEmbedding = await embed(TITLE_REFERENCE);\n  }\n  if (!cachedHeaderRefEmbedding) {\n    cachedHeaderRefEmbedding = await embed(HEADER_REFERENCE);\n  }\n  if (!cachedNoiseRefEmbedding) {\n    cachedNoiseRefEmbedding = await embed(NOISE_REFERENCE);\n  }\n\n  // Find the first ALL_CAPS candidate with ≥2 words where every significant word has ≥4 alpha letters.\n  // Insignificant tokens (≤1 alpha letter: \"/\", \"&\", \"+\", \":\", \"D)\", etc.) are filtered before\n  // the check so that multi-line joins with continuation punctuation still qualify.\n  const isStructuralHeading = (c: { text: string }): boolean => {\n    if (!isAllCaps(c.text) || wordCount(c.text) < 2) return false;\n    const sigWords = c.text.trim().split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length > 1);\n    return sigWords.length >= 2 && sigWords.every((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n  };\n  const baseHeading = candidates.find(isStructuralHeading);\n  // When the initial heading has a continuation on the next line introduced by a punctuation token\n  // (/, &, +, :, or parenthesis), prefer the longer 2-line join as the complete heading.\n  // E.g. \"SAFFRON WHEAT BUNS WITH QUARK\" + \"/ COTTAGE CHEESE (VARIATION D)\" → prefers the join.\n  // Guard: the remainder after the prefix must start with a continuation character to avoid\n  // merging two separate consecutive recipe titles (FINNISH MILK FLATBREADS stays separate\n  // from FINNISH POTATO FLATBREADS because \"FINNISH\" does not start with a continuation token).\n  const firstStructuralHeading = baseHeading && (\n    candidates.find((c) => {\n      if (!isStructuralHeading(c)) return false;\n      const hLower = baseHeading.text.toLowerCase();\n      const cLower = c.text.toLowerCase();\n      return cLower.startsWith(hLower + \" \") && /^[/&+:(]/.test(cLower.slice(hLower.length + 1));\n    }) ?? baseHeading\n  );\n\n  const scored: Array<{ text: string; position: number; score: number; rawScore: number; baseScore: number }> = [];\n\n  for (const candidate of candidates) {\n    const embedding = await embed(candidate.text);\n    const titleSim = cosineSimilarity(embedding, cachedTitleRefEmbedding);\n    const headerSim = cosineSimilarity(embedding, cachedHeaderRefEmbedding);\n    const noiseSim = cosineSimilarity(embedding, cachedNoiseRefEmbedding);\n    const rawScore = titleSim - Math.max(headerSim, noiseSim);\n\n    // Position factor: multiplicative tiebreaker — amplifies existing signal, doesn't replace it\n    const relativePosition = candidate.position / lines.length;\n    const positionFactor = relativePosition < 0.5\n      ? 1.0 + 0.12 * (1 - relativePosition * 2)\n      : 1.0;\n\n    // ALL_CAPS bonus: recipe books use ALL_CAPS for titles and section headings\n    const allCapsBonus = isAllCaps(candidate.text) && candidate.text.replace(/[^a-zA-Z]/g, \"\").length >= 4\n      ? 0.08\n      : 0;\n\n    // Structural heading bonus: first clean ALL_CAPS heading is almost always the recipe title\n    const structuralBonus =\n      firstStructuralHeading && candidate === firstStructuralHeading ? 0.10 : 0;\n\n    // baseScore excludes position factor — used for threshold so position boost on the first\n    // title doesn't inflate the bar and exclude valid later titles on multi-recipe pages\n    const baseScore = rawScore + allCapsBonus + structuralBonus;\n    const score = rawScore * positionFactor + allCapsBonus + structuralBonus;\n    scored.push({ text: candidate.text, position: candidate.position, score, rawScore, baseScore });\n  }\n\n  if (scored.length === 0) {\n    return undefined;\n  }\n\n  // Use position-free baseScore for threshold so position boost on the first title doesn't\n  // inflate the bar and exclude valid later titles on multi-recipe pages.\n  const bestBaseScore = Math.max(...scored.map((s) => s.baseScore));\n  const threshold = Math.max(0.08, bestBaseScore * 0.7);\n\n  // Filter candidates above threshold\n  let selected = scored.filter((s) => s.score >= threshold);\n\n  // Remove word-boundary prefixes of firstStructuralHeading when the heading itself survived\n  // the threshold. Cases:\n  //   ARAYES case:  firstStructuralHeading = \"ARAYES SHRAK\" (2-word join qualifies; \"ARAYES\"\n  //     alone = 1 word, so it never qualified). Filter removes \"ARAYES\" so dedup keeps the join.\n  //   SAFFRON case: baseHeading was the partial line; continuation logic above upgraded\n  //     firstStructuralHeading to the full join. Filter removes the partial so dedup keeps join.\n  // Safety: only fires when the complete heading itself is in selected (passed the threshold).\n  if (firstStructuralHeading && selected.some((s) => s.text === firstStructuralHeading.text)) {\n    const fshLower = firstStructuralHeading.text.toLowerCase();\n    selected = selected.filter((s) => {\n      if (s.text === firstStructuralHeading.text) return true;\n      const sLower = s.text.toLowerCase();\n      // Remove s if it is a space-delimited prefix of the structural heading\n      return !fshLower.startsWith(sLower + \" \");\n    });\n  }\n\n  // Deduplicate: if one title is a substring of another, keep the shorter (more focused) one.\n  // DO NOT CHANGE THIS LOGIC — it has been incorrectly \"improved\" by the title-loop 5 times.\n  // The tests require shorter wins: \"Pierogi Ruskie\" over \"Pierogi Ruskie 200g mąki 3 ziemniaki\".\n  // The pre-filter above handles the conflicting case (structural heading prefix removal) so that\n  // the incomplete prefix line is never present here when the complete join is in selected.\n  selected = selected.filter((a) => {\n    const aLower = a.text.toLowerCase();\n    return !selected.some(\n      (b) =>\n        b !== a &&\n        aLower.includes(b.text.toLowerCase()) &&\n        b.text.length < a.text.length\n    );\n  });\n\n  // Multi-title guard: only join multiple candidates with \"+\" when there is\n  // structural evidence of a multi-recipe page (≥2 ALL_CAPS headings).\n  // A single ALL_CAPS title among mixed-case survivors is a single-recipe page —\n  // collapse to the highest-scoring candidate.\n  // Zero ALL_CAPS survivors → mixed-case multi-title page → keep all.\n  if (selected.length > 1) {\n    const allCapsSelected = selected.filter((s) => isAllCaps(s.text));\n    if (allCapsSelected.length >= 2) {\n      selected = allCapsSelected;\n    } else if (allCapsSelected.length === 1) {\n      selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n    }\n  }\n\n  // Cap at 3, sort by document position\n  selected.sort((a, b) => a.position - b.position);\n  selected = selected.slice(0, 3);\n\n  if (selected.length === 0) {\n    return undefined;\n  }\n\n  return selected.map((s) => s.text).join(\" + \");\n}\n\n/**\n * Extract potential recipe title from OCR text (sync heuristic fallback)\n */\nexport function extractTitle(text: string): string | undefined {\n  if (!text || text.trim().length === 0) {\n    return undefined;\n  }\n\n  const lines = text.split(\"\\n\").map((line) => line.trim());\n\n  for (const line of lines) {\n    if (line.length === 0) continue;\n    if (line.length < 3 || line.length > 50) continue;\n    if (looksLikeIngredient(line)) continue;\n    if (isAllCaps(line)) continue;\n    if (startsWithNumber(line)) continue;\n    return line;\n  }\n\n  return undefined;\n}\n","numLines":415,"startLine":1,"totalLines":415}}}
