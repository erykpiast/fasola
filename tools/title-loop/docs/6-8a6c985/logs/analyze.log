{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Ek6oXtnzNbBkc8K1Fy9Xa2","type":"tool_result","content":"     1→#!/usr/bin/env python3\n     2→\"\"\"\n     3→Self-improving title extraction loop.\n     4→\n     5→Iteratively evaluates and improves the title extraction algorithm by:\n     6→1. Running extraction against real and generated OCR input files\n     7→2. Using Claude Code headless for analysis, planning, and implementation\n     8→3. Committing improvements and tracking accuracy across iterations\n     9→\n    10→Fully resumable: detects which step of an iteration was last completed\n    11→and picks up from there.\n    12→\n    13→Usage: python3 tools/title-loop/title-loop.py\n    14→\"\"\"\n    15→\n    16→import glob\n    17→import json\n    18→import os\n    19→import re\n    20→import shutil\n    21→import subprocess\n    22→import sys\n    23→import threading\n    24→import time\n    25→from pathlib import Path\n    26→\n    27→# --- Configuration ---\n    28→MAX_ITERATIONS = 20\n    29→ACCURACY_THRESHOLD = 0.95  # \"close to 100%\"\n    30→SYNTHETIC_COUNT = 100\n    31→CLAUDE_TIMEOUT = 900  # 15 minutes per Claude invocation\n    32→CLAUDE_STALL_TIMEOUT = 60  # kill if no output for N seconds (default)\n    33→CLAUDE_STALL_TIMEOUT_BY_MODEL = {\"opus\": 180, \"sonnet\": 120, \"haiku\": 60}\n    34→CLAUDE_MAX_RETRIES = 3  # max retries per stage on stall/failure\n    35→EXTRACT_TIMEOUT = 120  # 2 minutes per file extraction\n    36→\n    37→PROJECT_ROOT = Path(__file__).resolve().parent.parent.parent\n    38→LOOP_DIR = Path(__file__).resolve().parent\n    39→INPUT_DIR = LOOP_DIR / \"input\"\n    40→DOCS_DIR = LOOP_DIR / \"docs\"\n    41→EXTRACT_SCRIPT = LOOP_DIR / \"extract-title.ts\"\n    42→ITER_LOG = DOCS_DIR / \"iter.txt\"\n    43→\n    44→# Number of recent output lines to show in live display\n    45→\n    46→\n    47→# --- Resume state detection ---\n    48→\n    49→def find_iter_dir(iteration: int) -> Path | None:\n    50→    \"\"\"Find the iteration directory for a given iteration number (hash may vary).\"\"\"\n    51→    matches = sorted(DOCS_DIR.glob(f\"{iteration}-*\"))\n    52→    matches = [m for m in matches if re.match(rf\"^{iteration}-[a-f0-9]+$\", m.name)]\n    53→    return matches[0] if matches else None\n    54→\n    55→\n    56→def get_logged_accuracy(iteration: int) -> float | None:\n    57→    \"\"\"Read the accuracy logged for a specific iteration from iter.txt.\"\"\"\n    58→    if not ITER_LOG.exists():\n    59→        return None\n    60→    for line in ITER_LOG.read_text().strip().splitlines():\n    61→        m = re.match(r\"^(\\d+)\\s*-\\s*([\\d.]+)%\", line)\n    62→        if m and int(m.group(1)) == iteration:\n    63→            return float(m.group(2)) / 100\n    64→    return None\n    65→\n    66→\n    67→def get_last_logged_iteration() -> int:\n    68→    \"\"\"Read iter.txt to find the last logged iteration number. Returns 0 if none.\"\"\"\n    69→    if not ITER_LOG.exists():\n    70→        return 0\n    71→    last = 0\n    72→    for line in ITER_LOG.read_text().strip().splitlines():\n    73→        m = re.match(r\"^(\\d+)\\s*-\\s*\", line)\n    74→        if m:\n    75→            last = int(m.group(1))\n    76→    return last\n    77→\n    78→\n    79→def determine_resume_phase(iteration: int) -> str:\n    80→    \"\"\"\n    81→    Determine what phase to resume from for a given iteration.\n    82→\n    83→    Returns one of:\n    84→      'evaluate'  — no results yet, start from scratch\n    85→      'analyze'   — results exist but no feedback.md\n    86→      'plan'      — feedback exists but no improvement-plan.md\n    87→      'execute'   — plan exists but not yet implemented/committed\n    88→      'done'      — accuracy met threshold, iteration complete\n    89→    \"\"\"\n    90→    iter_dir = find_iter_dir(iteration)\n    91→    if iter_dir is None or not (iter_dir / \"results.txt\").exists():\n    92→        return \"evaluate\"\n    93→\n    94→    accuracy = get_logged_accuracy(iteration)\n    95→    if accuracy is not None and accuracy >= ACCURACY_THRESHOLD:\n    96→        return \"done\"\n    97→\n    98→    if not (iter_dir / \"feedback.md\").exists():\n    99→        return \"analyze\"\n   100→\n   101→    if not (iter_dir / \"improvement-plan.md\").exists():\n   102→        return \"plan\"\n   103→\n   104→    if (iter_dir / \"committed\").exists():\n   105→        return \"done\"\n   106→\n   107→    return \"execute\"\n   108→\n   109→\n   110→# --- Core helpers ---\n   111→\n   112→def normalize(s: str) -> str:\n   113→    \"\"\"Normalize whitespace and case for comparison.\"\"\"\n   114→    return \" \".join(s.lower().split())\n   115→\n   116→\n   117→def titles_match(extracted: str, expected: str) -> bool:\n   118→    \"\"\"\n   119→    Binary match: does the extracted title contain all expected title parts?\n   120→    Expected may contain multiple titles separated by '+'.\n   121→    \"\"\"\n   122→    if not extracted:\n   123→        return False\n   124→    extracted_norm = normalize(extracted)\n   125→    expected_parts = [normalize(p) for p in expected.split(\"+\")]\n   126→    return all(part in extracted_norm for part in expected_parts)\n   127→\n   128→\n   129→def extract_expected_title(filename: str) -> str:\n   130→    \"\"\"Extract expected title from filename like 'Tomato Soup.real.txt'.\"\"\"\n   131→    name = Path(filename).name\n   132→    cleaned = re.sub(r\"\\.(real|generated\\.\\d+)\\.txt$\", \"\", name)\n   133→    if cleaned == name:\n   134→        raise ValueError(f\"Unrecognized filename format: {filename!r}\")\n   135→    return cleaned\n   136→\n   137→\n   138→def run_extraction(file_path: str) -> str:\n   139→    \"\"\"Run the title extraction CLI on a file and return the extracted title.\"\"\"\n   140→    try:\n   141→        result = subprocess.run(\n   142→            [\"npx\", \"tsx\", str(EXTRACT_SCRIPT), file_path],\n   143→            capture_output=True,\n   144→            text=True,\n   145→            timeout=EXTRACT_TIMEOUT,\n   146→            cwd=str(PROJECT_ROOT),\n   147→        )\n   148→        if result.returncode != 0:\n   149→            print(f\"  WARNING: extraction failed for {file_path}: {result.stderr.strip()}\")\n   150→            return \"\"\n   151→        return result.stdout.strip()\n   152→    except subprocess.TimeoutExpired:\n   153→        print(f\"  WARNING: extraction timed out for {file_path}\")\n   154→        return \"\"\n   155→\n   156→\n   157→def evaluate_files(file_paths: list[str]) -> list[dict]:\n   158→    \"\"\"Evaluate extraction on a list of files. Returns list of result dicts.\"\"\"\n   159→    results = []\n   160→    for fp in file_paths:\n   161→        expected = extract_expected_title(fp)\n   162→        extracted = run_extraction(fp)\n   163→        match = titles_match(extracted, expected)\n   164→        results.append({\n   165→            \"file\": fp,\n   166→            \"expected\": expected,\n   167→            \"extracted\": extracted,\n   168→            \"match\": match,\n   169→        })\n   170→        status = \"YES\" if match else \"NO\"\n   171→        print(f\"  {status}: expected='{expected}' got='{extracted}'\")\n   172→    return results\n   173→\n   174→\n   175→def compute_accuracy(results: list[dict]) -> float:\n   176→    \"\"\"Compute accuracy as fraction of matches.\"\"\"\n   177→    if not results:\n   178→        return 0.0\n   179→    return sum(1 for r in results if r[\"match\"]) / len(results)\n   180→\n   181→\n   182→def write_results(iter_dir: Path, results: list[dict]) -> None:\n   183→    \"\"\"Write results.txt with one line per file.\"\"\"\n   184→    iter_dir.mkdir(parents=True, exist_ok=True)\n   185→    with open(iter_dir / \"results.txt\", \"w\") as f:\n   186→        for r in results:\n   187→            status = \"yes\" if r[\"match\"] else \"no\"\n   188→            f.write(f\"{r['expected']} - {status}\\n\")\n   189→\n   190→\n   191→def load_results_from_file(iter_dir: Path) -> list[dict]:\n   192→    \"\"\"Reconstruct minimal results from results.txt for building failure prompts.\"\"\"\n   193→    results = []\n   194→    results_path = iter_dir / \"results.txt\"\n   195→    if not results_path.exists():\n   196→        return results\n   197→    for line in results_path.read_text().strip().splitlines():\n   198→        m = re.match(r\"^(.+) - (yes|no)$\", line)\n   199→        if m:\n   200→            expected = m.group(1)\n   201→            match = m.group(2) == \"yes\"\n   202→            real_file = INPUT_DIR / f\"{expected}.real.txt\"\n   203→            file_path = str(real_file) if real_file.exists() else f\"(input file for '{expected}')\"\n   204→            results.append({\n   205→                \"file\": file_path,\n   206→                \"expected\": expected,\n   207→                \"extracted\": \"(from previous evaluation)\",\n   208→                \"match\": match,\n   209→            })\n   210→    return results\n   211→\n   212→\n   213→def get_commit_hash() -> str:\n   214→    \"\"\"Get current git commit hash (short).\"\"\"\n   215→    result = subprocess.run(\n   216→        [\"git\", \"rev-parse\", \"--short\", \"HEAD\"],\n   217→        capture_output=True,\n   218→        text=True,\n   219→        cwd=str(PROJECT_ROOT),\n   220→    )\n   221→    return result.stdout.strip()\n   222→\n   223→\n   224→def git_commit_all(message: str) -> str:\n   225→    \"\"\"Stage source changes and iteration docs. Returns new commit hash.\"\"\"\n   226→    subprocess.run(\n   227→        [\"git\", \"add\",\n   228→         \"lib/text-classifier/\",\n   229→         \"tools/title-loop/docs/\",\n   230→         \"tools/title-loop/extract-title.ts\",\n   231→         \"tools/title-loop/title-loop.py\"],\n   232→        cwd=str(PROJECT_ROOT),\n   233→        check=True,\n   234→    )\n   235→    # The Entire hook reads from /dev/tty (not stdin) to prompt for session linking.\n   236→    # Unsetting CLAUDECODE prevents it from detecting an active session, so it skips\n   237→    # the prompt entirely. The hook still runs and adds its trailer.\n   238→    env = {**os.environ, \"CLAUDECODE\": \"\"}\n   239→    subprocess.run(\n   240→        [\"git\", \"commit\", \"-m\", message],\n   241→        env=env,\n   242→        cwd=str(PROJECT_ROOT),\n   243→        check=True,\n   244→    )\n   245→    return get_commit_hash()\n   246→\n   247→\n   248→# --- Claude invocation with live display ---\n   249→\n   250→def _clear_display(height: int) -> None:\n   251→    \"\"\"Move cursor up and clear lines to overwrite previous display.\"\"\"\n   252→    if height > 0:\n   253→        sys.stdout.write(f\"\\033[{height}A\")\n   254→        for _ in range(height):\n   255→            sys.stdout.write(\"\\033[2K\\n\")\n   256→        sys.stdout.write(f\"\\033[{height}A\")\n   257→\n   258→\n   259→def _render_display(model: str, elapsed: float,\n   260→                    input_tokens: int = 0, output_tokens: int = 0) -> int:\n   261→    \"\"\"Render the live display line. Returns number of lines written.\"\"\"\n   262→    term_width = shutil.get_terminal_size().columns\n   263→\n   264→    header = f\"  Running Claude ({model})...\"\n   265→    stats = f\"\\u2191 {input_tokens:,} | \\u2193 {output_tokens:,} | {elapsed:.0f}s\"\n   266→    padding = max(1, term_width - len(header) - len(stats))\n   267→    sys.stdout.write(f\"{header}{' ' * padding}{stats}\\n\")\n   268→\n   269→    sys.stdout.flush()\n   270→    return 1\n   271→\n   272→\n   273→class ClaudeStallError(RuntimeError):\n   274→    \"\"\"Raised when Claude produces no output for CLAUDE_STALL_TIMEOUT seconds.\"\"\"\n   275→    pass\n   276→\n   277→\n   278→def _run_claude_once(\n   279→    prompt: str,\n   280→    model: str = \"sonnet\",\n   281→    log_path: Path | None = None,\n   282→) -> str:\n   283→    \"\"\"\n   284→    Run Claude Code in headless mode with live streaming display (single attempt).\n   285→\n   286→    Uses --output-format stream-json with --include-partial-messages to get\n   287→    real-time text deltas. Shows elapsed time and the last 5 lines of output.\n   288→    Saves full output to log_path if provided.\n   289→\n   290→    Raises ClaudeStallError if no output received for CLAUDE_STALL_TIMEOUT seconds.\n   291→    Raises RuntimeError on non-zero exit or overall timeout.\n   292→    \"\"\"\n   293→    cmd = [\n   294→        \"claude\", \"--print\", \"--dangerously-skip-permissions\",\n   295→        \"--verbose\",\n   296→        \"--output-format\", \"stream-json\",\n   297→        \"--include-partial-messages\",\n   298→    ]\n   299→\n   300→    model_ids = {\n   301→        \"opus\": \"claude-opus-4-6\",\n   302→        \"sonnet\": \"claude-sonnet-4-6\",\n   303→        \"haiku\": \"claude-haiku-4-5-20251001\",\n   304→    }\n   305→    cmd.extend([\"--model\", model_ids.get(model, model_ids[\"sonnet\"])])\n   306→\n   307→    start = time.time()\n   308→    raw_lines: list[str] = []  # raw NDJSON lines for logging\n   309→    result_text = \"\"  # final result extracted from stream\n   310→    input_tokens = 0  # running count from message_start usage\n   311→    output_tokens = 0  # running count from message_delta usage\n   312→    display_height = 0\n   313→    reader_done = threading.Event()\n   314→    last_activity = time.time()  # tracks last time we received any output\n   315→    lock = threading.Lock()\n   316→\n   317→    proc = subprocess.Popen(\n   318→        cmd,\n   319→        stdin=subprocess.PIPE,\n   320→        stdout=subprocess.PIPE,\n   321→        stderr=subprocess.PIPE,\n   322→        text=True,\n   323→        cwd=str(PROJECT_ROOT),\n   324→    )\n   325→\n   326→    # Send prompt and close stdin\n   327→    try:\n   328→        proc.stdin.write(prompt)\n   329→        proc.stdin.close()\n   330→    except BrokenPipeError:\n   331→        pass\n   332→\n   333→    # Read and parse stream-json stdout in background\n   334→    def reader():\n   335→        nonlocal result_text, last_activity, input_tokens, output_tokens\n   336→        try:\n   337→            for line in proc.stdout:\n   338→                with lock:\n   339→                    last_activity = time.time()\n   340→                raw_lines.append(line)\n   341→                stripped = line.strip()\n   342→                if not stripped:\n   343→                    continue\n   344→                try:\n   345→                    event = json.loads(stripped)\n   346→                except json.JSONDecodeError:\n   347→                    continue\n   348→\n   349→                etype = event.get(\"type\", \"\")\n   350→\n   351→                if etype == \"stream_event\":\n   352→                    nested = event.get(\"event\", {})\n   353→                    ntype = nested.get(\"type\", \"\")\n   354→                    # Track input tokens from message_start\n   355→                    if ntype == \"message_start\":\n   356→                        usage = nested.get(\"message\", {}).get(\"usage\", {})\n   357→                        input_tokens += usage.get(\"input_tokens\", 0)\n   358→                        input_tokens += usage.get(\"cache_creation_input_tokens\", 0)\n   359→                        input_tokens += usage.get(\"cache_read_input_tokens\", 0)\n   360→                    # Track output tokens from message_delta\n   361→                    elif ntype == \"message_delta\":\n   362→                        usage = nested.get(\"usage\", {})\n   363→                        tok = usage.get(\"output_tokens\", 0)\n   364→                        if tok:\n   365→                            output_tokens += tok\n   366→\n   367→                # Final result\n   368→                elif etype == \"result\":\n   369→                    result_text = event.get(\"result\", \"\")\n   370→        finally:\n   371→            reader_done.set()\n   372→\n   373→    thread = threading.Thread(target=reader, daemon=True)\n   374→    thread.start()\n   375→\n   376→    # Live display loop\n   377→    stall_timeout = CLAUDE_STALL_TIMEOUT_BY_MODEL.get(model, CLAUDE_STALL_TIMEOUT)\n   378→    stalled = False\n   379→    try:\n   380→        while not reader_done.is_set():\n   381→            elapsed = time.time() - start\n   382→\n   383→            # Overall timeout check\n   384→            if elapsed > CLAUDE_TIMEOUT:\n   385→                proc.kill()\n   386→                break\n   387→\n   388→            # Stall detection: no output for stall_timeout seconds\n   389→            with lock:\n   390→                silence = time.time() - last_activity\n   391→            if silence > stall_timeout:\n   392→                stalled = True\n   393→                proc.kill()\n   394→                break\n   395→\n   396→            _clear_display(display_height)\n   397→            display_height = _render_display(model, elapsed, input_tokens, output_tokens)\n   398→\n   399→            reader_done.wait(timeout=1.0)\n   400→\n   401→        # Final display update\n   402→        elapsed = time.time() - start\n   403→        _clear_display(display_height)\n   404→        display_height = _render_display(model, elapsed, input_tokens, output_tokens)\n   405→\n   406→    except KeyboardInterrupt:\n   407→        proc.kill()\n   408→        _clear_display(display_height)\n   409→        print(f\"  Claude ({model}) interrupted by user\")\n   410→        raise\n   411→\n   412→    # Wait for process to finish\n   413→    try:\n   414→        proc.wait(timeout=30)\n   415→    except subprocess.TimeoutExpired:\n   416→        proc.kill()\n   417→        proc.wait()\n   418→\n   419→    stderr_output = proc.stderr.read()\n   420→    elapsed = time.time() - start\n   421→\n   422→    # Use result from stream; fall back to joining raw output\n   423→    full_output = result_text or \"\".join(raw_lines)\n   424→\n   425→    # Save log (always, even on failure)\n   426→    if log_path:\n   427→        log_path.parent.mkdir(parents=True, exist_ok=True)\n   428→        with open(log_path, \"w\") as f:\n   429→            f.write(f\"# Claude ({model}) — {time.strftime('%Y-%m-%d %H:%M:%S')}\\n\")\n   430→            f.write(f\"# Duration: {elapsed:.0f}s — Exit: {proc.returncode}\\n\")\n   431→            f.write(f\"# Prompt:\\n\")\n   432→            for pline in prompt.splitlines():\n   433→                f.write(f\"#   {pline}\\n\")\n   434→            f.write(f\"\\n{'=' * 60}\\n\\n\")\n   435→            f.write(result_text or \"\")\n   436→            if stderr_output:\n   437→                f.write(f\"\\n{'=' * 60}\\n# STDERR:\\n{stderr_output}\\n\")\n   438→            # Also save raw NDJSON stream for debugging\n   439→            f.write(f\"\\n{'=' * 60}\\n# RAW STREAM ({len(raw_lines)} events):\\n\")\n   440→            for rl in raw_lines:\n   441→                f.write(rl)\n   442→\n   443→    # Status line and error handling\n   444→    if stalled:\n   445→        msg = f\"Claude ({model}) stalled (no output for {stall_timeout}s) at {elapsed:.0f}s\"\n   446→        print(f\"\\n  {msg}\")\n   447→        raise ClaudeStallError(msg)\n   448→    elif proc.returncode == 0:\n   449→        print(f\"\\n  Claude ({model}) finished in {elapsed:.0f}s\")\n   450→    elif elapsed > CLAUDE_TIMEOUT:\n   451→        print(f\"\\n  Claude ({model}) timed out after {elapsed:.0f}s\")\n   452→        raise RuntimeError(f\"Claude ({model}) timed out after {elapsed:.0f}s\")\n   453→    else:\n   454→        msg = f\"Claude ({model}) failed (exit {proc.returncode}) in {elapsed:.0f}s\"\n   455→        print(f\"\\n  {msg}\")\n   456→        if stderr_output:\n   457→            print(f\"  stderr: {stderr_output[:500]}\")\n   458→        raise RuntimeError(f\"{msg}\\n{stderr_output[:1000]}\")\n   459→\n   460→    return result_text or full_output\n   461→\n   462→\n   463→def run_claude(\n   464→    prompt: str,\n   465→    model: str = \"sonnet\",\n   466→    log_path: Path | None = None,\n   467→) -> str:\n   468→    \"\"\"\n   469→    Run Claude Code with automatic retry on stalls.\n   470→\n   471→    Retries up to CLAUDE_MAX_RETRIES times when Claude stalls (no output for\n   472→    CLAUDE_STALL_TIMEOUT seconds). After exhausting retries, raises RuntimeError.\n   473→    Non-stall failures (exit code, overall timeout) are raised immediately.\n   474→    \"\"\"\n   475→    for attempt in range(1, CLAUDE_MAX_RETRIES + 1):\n   476→        try:\n   477→            return _run_claude_once(prompt, model=model, log_path=log_path)\n   478→        except ClaudeStallError:\n   479→            if attempt < CLAUDE_MAX_RETRIES:\n   480→                print(f\"  Retrying ({attempt}/{CLAUDE_MAX_RETRIES})...\")\n   481→            else:\n   482→                raise RuntimeError(\n   483→                    f\"Claude ({model}) stalled {CLAUDE_MAX_RETRIES} times — giving up\"\n   484→                )\n   485→    # unreachable, but satisfies type checker\n   486→    raise RuntimeError(\"unreachable\")\n   487→\n   488→\n   489→# --- Iteration phases ---\n   490→\n   491→def phase_evaluate(iteration: int, log_dir: Path) -> tuple[Path, float, list[dict]]:\n   492→    \"\"\"Run evaluation, write results, log accuracy. Returns (iter_dir, accuracy, results).\"\"\"\n   493→    print(f\"\\nEvaluating real input files...\")\n   494→    real_files = sorted(glob.glob(str(INPUT_DIR / \"*.real.txt\")))\n   495→    print(f\"  Found {len(real_files)} real files\")\n   496→    real_results = evaluate_files(real_files)\n   497→    real_accuracy = compute_accuracy(real_results)\n   498→    print(f\"\\n  Real accuracy: {real_accuracy:.1%} ({sum(1 for r in real_results if r['match'])}/{len(real_results)})\")\n   499→\n   500→    gen_results: list[dict] = []\n   501→    combined_accuracy = real_accuracy\n   502→\n   503→    # If real accuracy is high enough, test on generated data too\n   504→    if real_accuracy >= ACCURACY_THRESHOLD:\n   505→        print(f\"\\nGenerating {SYNTHETIC_COUNT} synthetic OCR files...\")\n   506→        generate_synthetic_data(iteration, log_dir=log_dir)\n   507→\n   508→        print(f\"\\nEvaluating generated files...\")\n   509→        gen_files = sorted(glob.glob(str(INPUT_DIR / f\"*.generated.{iteration}.txt\")))\n   510→        print(f\"  Found {len(gen_files)} generated files\")\n   511→        if gen_files:\n   512→            gen_results = evaluate_files(gen_files)\n   513→            gen_accuracy = compute_accuracy(gen_results)\n   514→            print(f\"\\n  Generated accuracy: {gen_accuracy:.1%}\")\n   515→            combined_accuracy = compute_accuracy(real_results + gen_results)\n   516→        else:\n   517→            print(\"  WARNING: No generated files found. Claude may have failed.\")\n   518→\n   519→    all_results = real_results + gen_results\n   520→    print(f\"\\n  Combined accuracy: {combined_accuracy:.1%}\")\n   521→\n   522→    # Log iteration accuracy\n   523→    with open(ITER_LOG, \"a\") as f:\n   524→        f.write(f\"{iteration} - {combined_accuracy:.1%}\\n\")\n   525→\n   526→    # Create iteration directory and write results\n   527→    commit_hash = get_commit_hash()\n   528→    iter_dir = DOCS_DIR / f\"{iteration}-{commit_hash}\"\n   529→    write_results(iter_dir, all_results)\n   530→    print(f\"  Results written to {iter_dir.relative_to(PROJECT_ROOT)}\")\n   531→\n   532→    return iter_dir, combined_accuracy, all_results\n   533→\n   534→\n   535→def generate_synthetic_data(iteration: int, log_dir: Path) -> None:\n   536→    \"\"\"Generate synthetic OCR data using Claude Code.\"\"\"\n   537→    real_files = glob.glob(str(INPUT_DIR / \"*.real.txt\"))\n   538→    existing_titles = [extract_expected_title(f) for f in real_files]\n   539→    titles_list = \", \".join(existing_titles)\n   540→\n   541→    prompt = f\"\"\"Generate {SYNTHETIC_COUNT} realistic fake OCR recipe text files.\n   542→\n   543→Each file should simulate real OCR output from a scanned cookbook page. Include typical\n   544→OCR artifacts: slightly misrecognized characters, broken line wraps, page numbers,\n   545→headers/footers, section labels.\n   546→\n   547→Save each file to: tools/title-loop/input/{{RECIPE_TITLE}}.generated.{iteration}.txt\n   548→\n   549→The recipe title in the filename must EXACTLY match the main title as it appears in the\n   550→generated text content (case-insensitive matching is fine, but the words must match).\n   551→\n   552→Requirements:\n   553→- Mix of English and Polish recipes (roughly 60/40)\n   554→- Variety: soups, mains, desserts, salads, appetizers, breads, drinks, preserves\n   555→- Include multi-word titles (2-5 words), some single-word titles\n   556→- Include OCR noise: garbled short lines at top/bottom, stray numbers, broken words\n   557→- Some files should have the title after noise/headers (not first line)\n   558→- Vary title position: top, after page number, after section header, mid-page\n   559→- Some should have section headers like INGREDIENTS, SKŁADNIKI before or near the title\n   560→- Generate DIFFERENT recipes than these existing ones: {titles_list}\n   561→- Each file should be 15-40 lines long\n   562→\n   563→Generate all {SYNTHETIC_COUNT} files. Work through them systematically.\"\"\"\n   564→\n   565→    run_claude(prompt, model=\"haiku\", log_path=log_dir / \"generate.log\")\n   566→\n   567→\n   568→def phase_analyze(iter_dir: Path, results: list[dict]) -> None:\n   569→    \"\"\"Analyze extraction failures with Claude (Sonnet).\"\"\"\n   570→    log_dir = iter_dir / \"logs\"\n   571→    failures = [r for r in results if not r[\"match\"]]\n   572→    if not failures:\n   573→        (iter_dir / \"feedback.md\").write_text(\"No failures to analyze — all extractions matched.\\n\")\n   574→        return\n   575→\n   576→    failure_details = \"\\n\".join(\n   577→        f\"- File: {r['file']}\\n  Expected: '{r['expected']}'\\n  Got: '{r['extracted']}'\"\n   578→        for r in failures\n   579→    )\n   580→\n   581→    prompt = f\"\"\"Analyze the title extraction failures below. Read each failing input file\n   582→and the current implementation at lib/text-classifier/title-extractor.ts.\n   583→\n   584→Write your analysis to {iter_dir.relative_to(PROJECT_ROOT)}/feedback.md explaining:\n   585→1. What patterns the algorithm fails on\n   586→2. Why each specific failure occurred\n   587→3. Common themes across failures\n   588→\n   589→Do NOT modify any code files. Only write the feedback.md file.\n   590→\n   591→Failures:\n   592→{failure_details}\n   593→\n   594→Results file: {iter_dir.relative_to(PROJECT_ROOT)}/results.txt\"\"\"\n   595→\n   596→    run_claude(prompt, model=\"sonnet\", log_path=log_dir / \"analyze.log\")\n   597→\n   598→\n   599→def phase_plan(iter_dir: Path, iteration: int) -> None:\n   600→    \"\"\"Plan algorithm improvements with Claude (Opus).\"\"\"\n   601→    log_dir = iter_dir / \"logs\"\n   602→    prompt = f\"\"\"Read the feedback at {iter_dir.relative_to(PROJECT_ROOT)}/feedback.md\n   603→and the current title extraction implementation at lib/text-classifier/title-extractor.ts.\n   604→Also read previous iteration docs in tools/title-loop/docs/ to understand what has been tried.\n   605→\n   606→Your job: propose changes that fix every failure. Think creatively and ambitiously.\n   607→\n   608→Hard constraints:\n   609→- Must run on a mobile device (React Native / Expo)\n   610→- Total title extraction must complete under 10 seconds\n   611→- Changes land in lib/text-classifier/ and related files\n   612→\n   613→Everything else is open for debate. The current approach (MiniLM embeddings + heuristic scoring)\n   614→is one option, but you are free to propose alternatives if they'd work better:\n   615→- Different embedding model or similarity strategy\n   616→- Replacing embeddings entirely with a rule-based or hybrid approach\n   617→- Restructuring the pipeline (e.g., two-pass, re-ranking, candidate merging)\n   618→- Changing how candidates are generated, filtered, or deduplicated\n   619→- Any other approach that solves the failures within the hard constraints\n   620→\n   621→Don't be incremental for the sake of it — if the feedback reveals a fundamental design flaw,\n   622→propose a fundamental fix. But also don't change things that already work well.\n   623→\n   624→Before writing any files, briefly outline your key proposed changes (2-3 sentences per failure)\n   625→so you can think through the approach first.\n   626→\n   627→Then write a detailed improvement plan to {iter_dir.relative_to(PROJECT_ROOT)}/improvement-plan.md\n   628→that includes:\n   629→1. Root cause analysis for each failure pattern\n   630→2. Specific code changes with before/after examples\n   631→3. New or modified heuristics, scoring adjustments, or pipeline changes\n   632→4. Expected impact on accuracy\n   633→\n   634→Do NOT modify any code files. Only write the improvement-plan.md file.\"\"\"\n   635→\n   636→    run_claude(prompt, model=\"opus\", log_path=log_dir / \"plan.log\")\n   637→\n   638→\n   639→def phase_execute(iter_dir: Path) -> None:\n   640→    \"\"\"Execute improvements with Claude (Sonnet), verify, and commit.\"\"\"\n   641→    log_dir = iter_dir / \"logs\"\n   642→    prompt = f\"\"\"Execute the improvement plan at {iter_dir.relative_to(PROJECT_ROOT)}/improvement-plan.md.\n   643→\n   644→Modify lib/text-classifier/title-extractor.ts and any related files as needed.\n   645→Make sure:\n   646→1. All existing tests still pass\n   647→2. The CLI at tools/title-loop/extract-title.ts still works\n   648→3. The code is clean and follows the project conventions in AGENTS.md\n   649→4. No unnecessary changes outside the title extraction logic\n   650→\n   651→CRITICAL CONSTRAINT: Do NOT modify the substring deduplication logic in title-extractor.ts.\n   652→The block starting with \"// Deduplicate: if one title is a substring of another, keep the shorter\"\n   653→must remain exactly as-is. It keeps the SHORTER candidate. Do not invert this to keep the longer.\n   654→This has been incorrectly changed 5 times and breaks tests every time.\n   655→\n   656→After making changes, run: npx vitest run --globals lib/text-classifier/__tests__/title-extractor.test.ts\n   657→Fix any test failures before finishing.\"\"\"\n   658→\n   659→    run_claude(prompt, model=\"sonnet\", log_path=log_dir / \"execute.log\")\n   660→\n   661→    # Verify tests and CLI\n   662→    print(f\"\\nVerifying tests and CLI...\")\n   663→    tests_ok = run_tests()\n   664→    cli_ok = verify_cli()\n   665→\n   666→    if not tests_ok or not cli_ok:\n   667→        print(\"  WARNING: Verification failed. Attempting to fix...\")\n   668→        fix_prompt = \"\"\"The title extraction tests or CLI are failing after recent changes.\n   669→Please fix any issues in lib/text-classifier/title-extractor.ts.\n   670→Run: npx vitest run lib/text-classifier/__tests__/title-extractor.test.ts\n   671→And verify: npx tsx tools/title-loop/extract-title.ts tools/title-loop/input/*.real.txt\n   672→Make sure both pass before finishing.\"\"\"\n   673→        run_claude(fix_prompt, model=\"sonnet\", log_path=log_dir / \"fix.log\")\n   674→\n   675→        if not run_tests() or not verify_cli():\n   676→            raise RuntimeError(\"Tests or CLI still failing after fix attempt\")\n   677→\n   678→\n   679→def run_tests() -> bool:\n   680→    \"\"\"Run the title extraction tests.\"\"\"\n   681→    print(\"  Running tests...\")\n   682→    result = subprocess.run(\n   683→        [\"npx\", \"vitest\", \"run\", \"--globals\", \"lib/text-classifier/__tests__/title-extractor.test.ts\"],\n   684→        capture_output=True,\n   685→        text=True,\n   686→        timeout=120,\n   687→        cwd=str(PROJECT_ROOT),\n   688→    )\n   689→    if result.returncode != 0:\n   690→        print(f\"  Tests FAILED: {result.stdout[-500:]}\")\n   691→        return False\n   692→    print(\"  Tests passed.\")\n   693→    return True\n   694→\n   695→\n   696→def verify_cli() -> bool:\n   697→    \"\"\"Verify the CLI script runs without errors on a sample file.\"\"\"\n   698→    real_files = glob.glob(str(INPUT_DIR / \"*.real.txt\"))\n   699→    if not real_files:\n   700→        print(\"  No real files to test CLI with\")\n   701→        return False\n   702→\n   703→    sample = real_files[0]\n   704→    print(f\"  Verifying CLI on: {Path(sample).name}\")\n   705→    result = subprocess.run(\n   706→        [\"npx\", \"tsx\", str(EXTRACT_SCRIPT), sample],\n   707→        capture_output=True,\n   708→        text=True,\n   709→        timeout=EXTRACT_TIMEOUT,\n   710→        cwd=str(PROJECT_ROOT),\n   711→    )\n   712→    if result.returncode != 0:\n   713→        print(f\"  CLI verification FAILED: {result.stderr[:300]}\")\n   714→        return False\n   715→    print(f\"  CLI output: '{result.stdout.strip()}'\")\n   716→    return True\n   717→\n   718→\n   719→# --- Main loop ---\n   720→\n   721→def main() -> None:\n   722→    \"\"\"Main self-improving loop with full mid-iteration resumability.\"\"\"\n   723→    DOCS_DIR.mkdir(parents=True, exist_ok=True)\n   724→\n   725→    last_logged = get_last_logged_iteration()\n   726→    if last_logged > 0:\n   727→        last_phase = determine_resume_phase(last_logged)\n   728→        if last_phase == \"done\":\n   729→            accuracy = get_logged_accuracy(last_logged)\n   730→            if accuracy is not None and accuracy >= ACCURACY_THRESHOLD:\n   731→                print(f\"Iteration {last_logged} already reached target accuracy ({accuracy:.1%}). Nothing to do.\")\n   732→                return\n   733→            start_iteration = last_logged + 1\n   734→        else:\n   735→            start_iteration = last_logged\n   736→    else:\n   737→        start_iteration = 1\n   738→\n   739→    print(\"=\" * 60)\n   740→    print(\"SELF-IMPROVING TITLE EXTRACTION LOOP\")\n   741→    print(f\"Max iterations: {MAX_ITERATIONS}\")\n   742→    print(f\"Accuracy threshold: {ACCURACY_THRESHOLD:.0%}\")\n   743→    print(f\"Input dir: {INPUT_DIR}\")\n   744→    if start_iteration > 1:\n   745→        phase = determine_resume_phase(start_iteration)\n   746→        print(f\"Resuming: iteration {start_iteration}, phase '{phase}'\")\n   747→    print(\"=\" * 60)\n   748→    print()\n   749→\n   750→    # Verify CLI works before starting\n   751→    print(\"Pre-flight: verifying CLI...\")\n   752→    if not verify_cli():\n   753→        print(\"FATAL: CLI verification failed. Fix before running the loop.\")\n   754→        sys.exit(1)\n   755→    print()\n   756→\n   757→    for iteration in range(start_iteration, MAX_ITERATIONS + 1):\n   758→        phase = determine_resume_phase(iteration)\n   759→\n   760→        if phase == \"done\":\n   761→            print(f\"Iteration {iteration} already completed. Skipping.\")\n   762→            continue\n   763→\n   764→        print(\"=\" * 60)\n   765→        print(f\"ITERATION {iteration}\" + (f\"  (resuming from '{phase}')\" if phase != \"evaluate\" else \"\"))\n   766→        print(\"=\" * 60)\n   767→\n   768→        iter_dir = find_iter_dir(iteration)\n   769→        all_results: list[dict] | None = None\n   770→\n   771→        # Ensure logs dir exists for this iteration\n   772→        if iter_dir:\n   773→            (iter_dir / \"logs\").mkdir(parents=True, exist_ok=True)\n   774→\n   775→        # --- EVALUATE ---\n   776→        if phase == \"evaluate\":\n   777→            # Create provisional log dir (iter_dir doesn't exist yet)\n   778→            commit_hash = get_commit_hash()\n   779→            provisional_log_dir = DOCS_DIR / f\"{iteration}-{commit_hash}\" / \"logs\"\n   780→            provisional_log_dir.mkdir(parents=True, exist_ok=True)\n   781→\n   782→            try:\n   783→                iter_dir, combined_accuracy, all_results = phase_evaluate(iteration, log_dir=provisional_log_dir)\n   784→            except RuntimeError as e:\n   785→                print(f\"  FATAL: {e}. Stopping.\")\n   786→                break\n   787→\n   788→            if combined_accuracy >= ACCURACY_THRESHOLD:\n   789→                print(f\"\\n{'=' * 60}\")\n   790→                print(f\"TARGET ACCURACY REACHED: {combined_accuracy:.1%}\")\n   791→                print(f\"Stopping after iteration {iteration}\")\n   792→                print(f\"{'=' * 60}\")\n   793→                break\n   794→\n   795→        assert iter_dir is not None, f\"No iteration directory found for iteration {iteration}\"\n   796→\n   797→        # --- ANALYZE ---\n   798→        if phase in (\"evaluate\", \"analyze\"):\n   799→            print(f\"\\nAnalyzing failures with Claude (Sonnet)...\")\n   800→            if all_results is None:\n   801→                all_results = load_results_from_file(iter_dir)\n   802→            try:\n   803→                phase_analyze(iter_dir, all_results)\n   804→            except RuntimeError as e:\n   805→                print(f\"  FATAL: {e}. Stopping.\")\n   806→                break\n   807→\n   808→        # --- PLAN ---\n   809→        if phase in (\"evaluate\", \"analyze\", \"plan\"):\n   810→            print(f\"\\nPlanning improvements with Claude (Opus)...\")\n   811→            try:\n   812→                phase_plan(iter_dir, iteration)\n   813→            except RuntimeError as e:\n   814→                print(f\"  FATAL: {e}. Stopping.\")\n   815→                break\n   816→\n   817→        # --- EXECUTE + VERIFY + COMMIT ---\n   818→        print(f\"\\nExecuting improvements with Claude (Sonnet)...\")\n   819→        try:\n   820→            phase_execute(iter_dir)\n   821→        except RuntimeError as e:\n   822→            print(f\"  FATAL: {e}. Stopping.\")\n   823→            break\n   824→\n   825→        # Commit changes\n   826→        print(f\"\\nCommitting changes...\")\n   827→        try:\n   828→            commit_hash = git_commit_all(f\"title-extraction: iteration {iteration}\")\n   829→            print(f\"  Committed: {commit_hash}\")\n   830→        except subprocess.CalledProcessError as e:\n   831→            # git commit exits 1 both for \"nothing to commit\" and real failures.\n   832→            # Check git status to distinguish.\n   833→            status = subprocess.run(\n   834→                [\"git\", \"status\", \"--porcelain\"],\n   835→                capture_output=True, text=True, cwd=str(PROJECT_ROOT),\n   836→            )\n   837→            if not status.stdout.strip():\n   838→                print(\"  WARNING: Nothing to commit (no changes made)\")\n   839→                commit_hash = get_commit_hash()\n   840→            else:\n   841→                print(f\"  FATAL: git commit failed: {e}. Stopping.\")\n   842→                break\n   843→\n   844→        # Mark iteration as committed so resume skips it\n   845→        (iter_dir / \"committed\").write_text(f\"{commit_hash}\\n\")\n   846→\n   847→        # Prepare next iteration directory\n   848→        next_dir = DOCS_DIR / f\"{iteration + 1}-{commit_hash}\"\n   849→        next_dir.mkdir(parents=True, exist_ok=True)\n   850→\n   851→        print(f\"\\n  Next iteration dir: {next_dir.relative_to(PROJECT_ROOT)}\")\n   852→        print()\n   853→\n   854→    else:\n   855→        print(f\"\\n{'=' * 60}\")\n   856→        print(f\"MAX ITERATIONS ({MAX_ITERATIONS}) REACHED\")\n   857→        print(f\"Final accuracy may not have met threshold.\")\n   858→        print(f\"{'=' * 60}\")\n   859→\n   860→    # Print summary\n   861→    print(f\"\\nIteration log:\")\n   862→    if ITER_LOG.exists():\n   863→        print(ITER_LOG.read_text())\n   864→\n   865→\n   866→if __name__ == \"__main__\":\n   867→    main()\n   868→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"220c2158-c29d-4d36-918e-39dcfccb497b","uuid":"9b2a1766-9d66-4629-a894-b66f5ee1b978","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/tools/title-loop/title-loop.py","content":"#!/usr/bin/env python3\n\"\"\"\nSelf-improving title extraction loop.\n\nIteratively evaluates and improves the title extraction algorithm by:\n1. Running extraction against real and generated OCR input files\n2. Using Claude Code headless for analysis, planning, and implementation\n3. Committing improvements and tracking accuracy across iterations\n\nFully resumable: detects which step of an iteration was last completed\nand picks up from there.\n\nUsage: python3 tools/title-loop/title-loop.py\n\"\"\"\n\nimport glob\nimport json\nimport os\nimport re\nimport shutil\nimport subprocess\nimport sys\nimport threading\nimport time\nfrom pathlib import Path\n\n# --- Configuration ---\nMAX_ITERATIONS = 20\nACCURACY_THRESHOLD = 0.95  # \"close to 100%\"\nSYNTHETIC_COUNT = 100\nCLAUDE_TIMEOUT = 900  # 15 minutes per Claude invocation\nCLAUDE_STALL_TIMEOUT = 60  # kill if no output for N seconds (default)\nCLAUDE_STALL_TIMEOUT_BY_MODEL = {\"opus\": 180, \"sonnet\": 120, \"haiku\": 60}\nCLAUDE_MAX_RETRIES = 3  # max retries per stage on stall/failure\nEXTRACT_TIMEOUT = 120  # 2 minutes per file extraction\n\nPROJECT_ROOT = Path(__file__).resolve().parent.parent.parent\nLOOP_DIR = Path(__file__).resolve().parent\nINPUT_DIR = LOOP_DIR / \"input\"\nDOCS_DIR = LOOP_DIR / \"docs\"\nEXTRACT_SCRIPT = LOOP_DIR / \"extract-title.ts\"\nITER_LOG = DOCS_DIR / \"iter.txt\"\n\n# Number of recent output lines to show in live display\n\n\n# --- Resume state detection ---\n\ndef find_iter_dir(iteration: int) -> Path | None:\n    \"\"\"Find the iteration directory for a given iteration number (hash may vary).\"\"\"\n    matches = sorted(DOCS_DIR.glob(f\"{iteration}-*\"))\n    matches = [m for m in matches if re.match(rf\"^{iteration}-[a-f0-9]+$\", m.name)]\n    return matches[0] if matches else None\n\n\ndef get_logged_accuracy(iteration: int) -> float | None:\n    \"\"\"Read the accuracy logged for a specific iteration from iter.txt.\"\"\"\n    if not ITER_LOG.exists():\n        return None\n    for line in ITER_LOG.read_text().strip().splitlines():\n        m = re.match(r\"^(\\d+)\\s*-\\s*([\\d.]+)%\", line)\n        if m and int(m.group(1)) == iteration:\n            return float(m.group(2)) / 100\n    return None\n\n\ndef get_last_logged_iteration() -> int:\n    \"\"\"Read iter.txt to find the last logged iteration number. Returns 0 if none.\"\"\"\n    if not ITER_LOG.exists():\n        return 0\n    last = 0\n    for line in ITER_LOG.read_text().strip().splitlines():\n        m = re.match(r\"^(\\d+)\\s*-\\s*\", line)\n        if m:\n            last = int(m.group(1))\n    return last\n\n\ndef determine_resume_phase(iteration: int) -> str:\n    \"\"\"\n    Determine what phase to resume from for a given iteration.\n\n    Returns one of:\n      'evaluate'  — no results yet, start from scratch\n      'analyze'   — results exist but no feedback.md\n      'plan'      — feedback exists but no improvement-plan.md\n      'execute'   — plan exists but not yet implemented/committed\n      'done'      — accuracy met threshold, iteration complete\n    \"\"\"\n    iter_dir = find_iter_dir(iteration)\n    if iter_dir is None or not (iter_dir / \"results.txt\").exists():\n        return \"evaluate\"\n\n    accuracy = get_logged_accuracy(iteration)\n    if accuracy is not None and accuracy >= ACCURACY_THRESHOLD:\n        return \"done\"\n\n    if not (iter_dir / \"feedback.md\").exists():\n        return \"analyze\"\n\n    if not (iter_dir / \"improvement-plan.md\").exists():\n        return \"plan\"\n\n    if (iter_dir / \"committed\").exists():\n        return \"done\"\n\n    return \"execute\"\n\n\n# --- Core helpers ---\n\ndef normalize(s: str) -> str:\n    \"\"\"Normalize whitespace and case for comparison.\"\"\"\n    return \" \".join(s.lower().split())\n\n\ndef titles_match(extracted: str, expected: str) -> bool:\n    \"\"\"\n    Binary match: does the extracted title contain all expected title parts?\n    Expected may contain multiple titles separated by '+'.\n    \"\"\"\n    if not extracted:\n        return False\n    extracted_norm = normalize(extracted)\n    expected_parts = [normalize(p) for p in expected.split(\"+\")]\n    return all(part in extracted_norm for part in expected_parts)\n\n\ndef extract_expected_title(filename: str) -> str:\n    \"\"\"Extract expected title from filename like 'Tomato Soup.real.txt'.\"\"\"\n    name = Path(filename).name\n    cleaned = re.sub(r\"\\.(real|generated\\.\\d+)\\.txt$\", \"\", name)\n    if cleaned == name:\n        raise ValueError(f\"Unrecognized filename format: {filename!r}\")\n    return cleaned\n\n\ndef run_extraction(file_path: str) -> str:\n    \"\"\"Run the title extraction CLI on a file and return the extracted title.\"\"\"\n    try:\n        result = subprocess.run(\n            [\"npx\", \"tsx\", str(EXTRACT_SCRIPT), file_path],\n            capture_output=True,\n            text=True,\n            timeout=EXTRACT_TIMEOUT,\n            cwd=str(PROJECT_ROOT),\n        )\n        if result.returncode != 0:\n            print(f\"  WARNING: extraction failed for {file_path}: {result.stderr.strip()}\")\n            return \"\"\n        return result.stdout.strip()\n    except subprocess.TimeoutExpired:\n        print(f\"  WARNING: extraction timed out for {file_path}\")\n        return \"\"\n\n\ndef evaluate_files(file_paths: list[str]) -> list[dict]:\n    \"\"\"Evaluate extraction on a list of files. Returns list of result dicts.\"\"\"\n    results = []\n    for fp in file_paths:\n        expected = extract_expected_title(fp)\n        extracted = run_extraction(fp)\n        match = titles_match(extracted, expected)\n        results.append({\n            \"file\": fp,\n            \"expected\": expected,\n            \"extracted\": extracted,\n            \"match\": match,\n        })\n        status = \"YES\" if match else \"NO\"\n        print(f\"  {status}: expected='{expected}' got='{extracted}'\")\n    return results\n\n\ndef compute_accuracy(results: list[dict]) -> float:\n    \"\"\"Compute accuracy as fraction of matches.\"\"\"\n    if not results:\n        return 0.0\n    return sum(1 for r in results if r[\"match\"]) / len(results)\n\n\ndef write_results(iter_dir: Path, results: list[dict]) -> None:\n    \"\"\"Write results.txt with one line per file.\"\"\"\n    iter_dir.mkdir(parents=True, exist_ok=True)\n    with open(iter_dir / \"results.txt\", \"w\") as f:\n        for r in results:\n            status = \"yes\" if r[\"match\"] else \"no\"\n            f.write(f\"{r['expected']} - {status}\\n\")\n\n\ndef load_results_from_file(iter_dir: Path) -> list[dict]:\n    \"\"\"Reconstruct minimal results from results.txt for building failure prompts.\"\"\"\n    results = []\n    results_path = iter_dir / \"results.txt\"\n    if not results_path.exists():\n        return results\n    for line in results_path.read_text().strip().splitlines():\n        m = re.match(r\"^(.+) - (yes|no)$\", line)\n        if m:\n            expected = m.group(1)\n            match = m.group(2) == \"yes\"\n            real_file = INPUT_DIR / f\"{expected}.real.txt\"\n            file_path = str(real_file) if real_file.exists() else f\"(input file for '{expected}')\"\n            results.append({\n                \"file\": file_path,\n                \"expected\": expected,\n                \"extracted\": \"(from previous evaluation)\",\n                \"match\": match,\n            })\n    return results\n\n\ndef get_commit_hash() -> str:\n    \"\"\"Get current git commit hash (short).\"\"\"\n    result = subprocess.run(\n        [\"git\", \"rev-parse\", \"--short\", \"HEAD\"],\n        capture_output=True,\n        text=True,\n        cwd=str(PROJECT_ROOT),\n    )\n    return result.stdout.strip()\n\n\ndef git_commit_all(message: str) -> str:\n    \"\"\"Stage source changes and iteration docs. Returns new commit hash.\"\"\"\n    subprocess.run(\n        [\"git\", \"add\",\n         \"lib/text-classifier/\",\n         \"tools/title-loop/docs/\",\n         \"tools/title-loop/extract-title.ts\",\n         \"tools/title-loop/title-loop.py\"],\n        cwd=str(PROJECT_ROOT),\n        check=True,\n    )\n    # The Entire hook reads from /dev/tty (not stdin) to prompt for session linking.\n    # Unsetting CLAUDECODE prevents it from detecting an active session, so it skips\n    # the prompt entirely. The hook still runs and adds its trailer.\n    env = {**os.environ, \"CLAUDECODE\": \"\"}\n    subprocess.run(\n        [\"git\", \"commit\", \"-m\", message],\n        env=env,\n        cwd=str(PROJECT_ROOT),\n        check=True,\n    )\n    return get_commit_hash()\n\n\n# --- Claude invocation with live display ---\n\ndef _clear_display(height: int) -> None:\n    \"\"\"Move cursor up and clear lines to overwrite previous display.\"\"\"\n    if height > 0:\n        sys.stdout.write(f\"\\033[{height}A\")\n        for _ in range(height):\n            sys.stdout.write(\"\\033[2K\\n\")\n        sys.stdout.write(f\"\\033[{height}A\")\n\n\ndef _render_display(model: str, elapsed: float,\n                    input_tokens: int = 0, output_tokens: int = 0) -> int:\n    \"\"\"Render the live display line. Returns number of lines written.\"\"\"\n    term_width = shutil.get_terminal_size().columns\n\n    header = f\"  Running Claude ({model})...\"\n    stats = f\"\\u2191 {input_tokens:,} | \\u2193 {output_tokens:,} | {elapsed:.0f}s\"\n    padding = max(1, term_width - len(header) - len(stats))\n    sys.stdout.write(f\"{header}{' ' * padding}{stats}\\n\")\n\n    sys.stdout.flush()\n    return 1\n\n\nclass ClaudeStallError(RuntimeError):\n    \"\"\"Raised when Claude produces no output for CLAUDE_STALL_TIMEOUT seconds.\"\"\"\n    pass\n\n\ndef _run_claude_once(\n    prompt: str,\n    model: str = \"sonnet\",\n    log_path: Path | None = None,\n) -> str:\n    \"\"\"\n    Run Claude Code in headless mode with live streaming display (single attempt).\n\n    Uses --output-format stream-json with --include-partial-messages to get\n    real-time text deltas. Shows elapsed time and the last 5 lines of output.\n    Saves full output to log_path if provided.\n\n    Raises ClaudeStallError if no output received for CLAUDE_STALL_TIMEOUT seconds.\n    Raises RuntimeError on non-zero exit or overall timeout.\n    \"\"\"\n    cmd = [\n        \"claude\", \"--print\", \"--dangerously-skip-permissions\",\n        \"--verbose\",\n        \"--output-format\", \"stream-json\",\n        \"--include-partial-messages\",\n    ]\n\n    model_ids = {\n        \"opus\": \"claude-opus-4-6\",\n        \"sonnet\": \"claude-sonnet-4-6\",\n        \"haiku\": \"claude-haiku-4-5-20251001\",\n    }\n    cmd.extend([\"--model\", model_ids.get(model, model_ids[\"sonnet\"])])\n\n    start = time.time()\n    raw_lines: list[str] = []  # raw NDJSON lines for logging\n    result_text = \"\"  # final result extracted from stream\n    input_tokens = 0  # running count from message_start usage\n    output_tokens = 0  # running count from message_delta usage\n    display_height = 0\n    reader_done = threading.Event()\n    last_activity = time.time()  # tracks last time we received any output\n    lock = threading.Lock()\n\n    proc = subprocess.Popen(\n        cmd,\n        stdin=subprocess.PIPE,\n        stdout=subprocess.PIPE,\n        stderr=subprocess.PIPE,\n        text=True,\n        cwd=str(PROJECT_ROOT),\n    )\n\n    # Send prompt and close stdin\n    try:\n        proc.stdin.write(prompt)\n        proc.stdin.close()\n    except BrokenPipeError:\n        pass\n\n    # Read and parse stream-json stdout in background\n    def reader():\n        nonlocal result_text, last_activity, input_tokens, output_tokens\n        try:\n            for line in proc.stdout:\n                with lock:\n                    last_activity = time.time()\n                raw_lines.append(line)\n                stripped = line.strip()\n                if not stripped:\n                    continue\n                try:\n                    event = json.loads(stripped)\n                except json.JSONDecodeError:\n                    continue\n\n                etype = event.get(\"type\", \"\")\n\n                if etype == \"stream_event\":\n                    nested = event.get(\"event\", {})\n                    ntype = nested.get(\"type\", \"\")\n                    # Track input tokens from message_start\n                    if ntype == \"message_start\":\n                        usage = nested.get(\"message\", {}).get(\"usage\", {})\n                        input_tokens += usage.get(\"input_tokens\", 0)\n                        input_tokens += usage.get(\"cache_creation_input_tokens\", 0)\n                        input_tokens += usage.get(\"cache_read_input_tokens\", 0)\n                    # Track output tokens from message_delta\n                    elif ntype == \"message_delta\":\n                        usage = nested.get(\"usage\", {})\n                        tok = usage.get(\"output_tokens\", 0)\n                        if tok:\n                            output_tokens += tok\n\n                # Final result\n                elif etype == \"result\":\n                    result_text = event.get(\"result\", \"\")\n        finally:\n            reader_done.set()\n\n    thread = threading.Thread(target=reader, daemon=True)\n    thread.start()\n\n    # Live display loop\n    stall_timeout = CLAUDE_STALL_TIMEOUT_BY_MODEL.get(model, CLAUDE_STALL_TIMEOUT)\n    stalled = False\n    try:\n        while not reader_done.is_set():\n            elapsed = time.time() - start\n\n            # Overall timeout check\n            if elapsed > CLAUDE_TIMEOUT:\n                proc.kill()\n                break\n\n            # Stall detection: no output for stall_timeout seconds\n            with lock:\n                silence = time.time() - last_activity\n            if silence > stall_timeout:\n                stalled = True\n                proc.kill()\n                break\n\n            _clear_display(display_height)\n            display_height = _render_display(model, elapsed, input_tokens, output_tokens)\n\n            reader_done.wait(timeout=1.0)\n\n        # Final display update\n        elapsed = time.time() - start\n        _clear_display(display_height)\n        display_height = _render_display(model, elapsed, input_tokens, output_tokens)\n\n    except KeyboardInterrupt:\n        proc.kill()\n        _clear_display(display_height)\n        print(f\"  Claude ({model}) interrupted by user\")\n        raise\n\n    # Wait for process to finish\n    try:\n        proc.wait(timeout=30)\n    except subprocess.TimeoutExpired:\n        proc.kill()\n        proc.wait()\n\n    stderr_output = proc.stderr.read()\n    elapsed = time.time() - start\n\n    # Use result from stream; fall back to joining raw output\n    full_output = result_text or \"\".join(raw_lines)\n\n    # Save log (always, even on failure)\n    if log_path:\n        log_path.parent.mkdir(parents=True, exist_ok=True)\n        with open(log_path, \"w\") as f:\n            f.write(f\"# Claude ({model}) — {time.strftime('%Y-%m-%d %H:%M:%S')}\\n\")\n            f.write(f\"# Duration: {elapsed:.0f}s — Exit: {proc.returncode}\\n\")\n            f.write(f\"# Prompt:\\n\")\n            for pline in prompt.splitlines():\n                f.write(f\"#   {pline}\\n\")\n            f.write(f\"\\n{'=' * 60}\\n\\n\")\n            f.write(result_text or \"\")\n            if stderr_output:\n                f.write(f\"\\n{'=' * 60}\\n# STDERR:\\n{stderr_output}\\n\")\n            # Also save raw NDJSON stream for debugging\n            f.write(f\"\\n{'=' * 60}\\n# RAW STREAM ({len(raw_lines)} events):\\n\")\n            for rl in raw_lines:\n                f.write(rl)\n\n    # Status line and error handling\n    if stalled:\n        msg = f\"Claude ({model}) stalled (no output for {stall_timeout}s) at {elapsed:.0f}s\"\n        print(f\"\\n  {msg}\")\n        raise ClaudeStallError(msg)\n    elif proc.returncode == 0:\n        print(f\"\\n  Claude ({model}) finished in {elapsed:.0f}s\")\n    elif elapsed > CLAUDE_TIMEOUT:\n        print(f\"\\n  Claude ({model}) timed out after {elapsed:.0f}s\")\n        raise RuntimeError(f\"Claude ({model}) timed out after {elapsed:.0f}s\")\n    else:\n        msg = f\"Claude ({model}) failed (exit {proc.returncode}) in {elapsed:.0f}s\"\n        print(f\"\\n  {msg}\")\n        if stderr_output:\n            print(f\"  stderr: {stderr_output[:500]}\")\n        raise RuntimeError(f\"{msg}\\n{stderr_output[:1000]}\")\n\n    return result_text or full_output\n\n\ndef run_claude(\n    prompt: str,\n    model: str = \"sonnet\",\n    log_path: Path | None = None,\n) -> str:\n    \"\"\"\n    Run Claude Code with automatic retry on stalls.\n\n    Retries up to CLAUDE_MAX_RETRIES times when Claude stalls (no output for\n    CLAUDE_STALL_TIMEOUT seconds). After exhausting retries, raises RuntimeError.\n    Non-stall failures (exit code, overall timeout) are raised immediately.\n    \"\"\"\n    for attempt in range(1, CLAUDE_MAX_RETRIES + 1):\n        try:\n            return _run_claude_once(prompt, model=model, log_path=log_path)\n        except ClaudeStallError:\n            if attempt < CLAUDE_MAX_RETRIES:\n                print(f\"  Retrying ({attempt}/{CLAUDE_MAX_RETRIES})...\")\n            else:\n                raise RuntimeError(\n                    f\"Claude ({model}) stalled {CLAUDE_MAX_RETRIES} times — giving up\"\n                )\n    # unreachable, but satisfies type checker\n    raise RuntimeError(\"unreachable\")\n\n\n# --- Iteration phases ---\n\ndef phase_evaluate(iteration: int, log_dir: Path) -> tuple[Path, float, list[dict]]:\n    \"\"\"Run evaluation, write results, log accuracy. Returns (iter_dir, accuracy, results).\"\"\"\n    print(f\"\\nEvaluating real input files...\")\n    real_files = sorted(glob.glob(str(INPUT_DIR / \"*.real.txt\")))\n    print(f\"  Found {len(real_files)} real files\")\n    real_results = evaluate_files(real_files)\n    real_accuracy = compute_accuracy(real_results)\n    print(f\"\\n  Real accuracy: {real_accuracy:.1%} ({sum(1 for r in real_results if r['match'])}/{len(real_results)})\")\n\n    gen_results: list[dict] = []\n    combined_accuracy = real_accuracy\n\n    # If real accuracy is high enough, test on generated data too\n    if real_accuracy >= ACCURACY_THRESHOLD:\n        print(f\"\\nGenerating {SYNTHETIC_COUNT} synthetic OCR files...\")\n        generate_synthetic_data(iteration, log_dir=log_dir)\n\n        print(f\"\\nEvaluating generated files...\")\n        gen_files = sorted(glob.glob(str(INPUT_DIR / f\"*.generated.{iteration}.txt\")))\n        print(f\"  Found {len(gen_files)} generated files\")\n        if gen_files:\n            gen_results = evaluate_files(gen_files)\n            gen_accuracy = compute_accuracy(gen_results)\n            print(f\"\\n  Generated accuracy: {gen_accuracy:.1%}\")\n            combined_accuracy = compute_accuracy(real_results + gen_results)\n        else:\n            print(\"  WARNING: No generated files found. Claude may have failed.\")\n\n    all_results = real_results + gen_results\n    print(f\"\\n  Combined accuracy: {combined_accuracy:.1%}\")\n\n    # Log iteration accuracy\n    with open(ITER_LOG, \"a\") as f:\n        f.write(f\"{iteration} - {combined_accuracy:.1%}\\n\")\n\n    # Create iteration directory and write results\n    commit_hash = get_commit_hash()\n    iter_dir = DOCS_DIR / f\"{iteration}-{commit_hash}\"\n    write_results(iter_dir, all_results)\n    print(f\"  Results written to {iter_dir.relative_to(PROJECT_ROOT)}\")\n\n    return iter_dir, combined_accuracy, all_results\n\n\ndef generate_synthetic_data(iteration: int, log_dir: Path) -> None:\n    \"\"\"Generate synthetic OCR data using Claude Code.\"\"\"\n    real_files = glob.glob(str(INPUT_DIR / \"*.real.txt\"))\n    existing_titles = [extract_expected_title(f) for f in real_files]\n    titles_list = \", \".join(existing_titles)\n\n    prompt = f\"\"\"Generate {SYNTHETIC_COUNT} realistic fake OCR recipe text files.\n\nEach file should simulate real OCR output from a scanned cookbook page. Include typical\nOCR artifacts: slightly misrecognized characters, broken line wraps, page numbers,\nheaders/footers, section labels.\n\nSave each file to: tools/title-loop/input/{{RECIPE_TITLE}}.generated.{iteration}.txt\n\nThe recipe title in the filename must EXACTLY match the main title as it appears in the\ngenerated text content (case-insensitive matching is fine, but the words must match).\n\nRequirements:\n- Mix of English and Polish recipes (roughly 60/40)\n- Variety: soups, mains, desserts, salads, appetizers, breads, drinks, preserves\n- Include multi-word titles (2-5 words), some single-word titles\n- Include OCR noise: garbled short lines at top/bottom, stray numbers, broken words\n- Some files should have the title after noise/headers (not first line)\n- Vary title position: top, after page number, after section header, mid-page\n- Some should have section headers like INGREDIENTS, SKŁADNIKI before or near the title\n- Generate DIFFERENT recipes than these existing ones: {titles_list}\n- Each file should be 15-40 lines long\n\nGenerate all {SYNTHETIC_COUNT} files. Work through them systematically.\"\"\"\n\n    run_claude(prompt, model=\"haiku\", log_path=log_dir / \"generate.log\")\n\n\ndef phase_analyze(iter_dir: Path, results: list[dict]) -> None:\n    \"\"\"Analyze extraction failures with Claude (Sonnet).\"\"\"\n    log_dir = iter_dir / \"logs\"\n    failures = [r for r in results if not r[\"match\"]]\n    if not failures:\n        (iter_dir / \"feedback.md\").write_text(\"No failures to analyze — all extractions matched.\\n\")\n        return\n\n    failure_details = \"\\n\".join(\n        f\"- File: {r['file']}\\n  Expected: '{r['expected']}'\\n  Got: '{r['extracted']}'\"\n        for r in failures\n    )\n\n    prompt = f\"\"\"Analyze the title extraction failures below. Read each failing input file\nand the current implementation at lib/text-classifier/title-extractor.ts.\n\nWrite your analysis to {iter_dir.relative_to(PROJECT_ROOT)}/feedback.md explaining:\n1. What patterns the algorithm fails on\n2. Why each specific failure occurred\n3. Common themes across failures\n\nDo NOT modify any code files. Only write the feedback.md file.\n\nFailures:\n{failure_details}\n\nResults file: {iter_dir.relative_to(PROJECT_ROOT)}/results.txt\"\"\"\n\n    run_claude(prompt, model=\"sonnet\", log_path=log_dir / \"analyze.log\")\n\n\ndef phase_plan(iter_dir: Path, iteration: int) -> None:\n    \"\"\"Plan algorithm improvements with Claude (Opus).\"\"\"\n    log_dir = iter_dir / \"logs\"\n    prompt = f\"\"\"Read the feedback at {iter_dir.relative_to(PROJECT_ROOT)}/feedback.md\nand the current title extraction implementation at lib/text-classifier/title-extractor.ts.\nAlso read previous iteration docs in tools/title-loop/docs/ to understand what has been tried.\n\nYour job: propose changes that fix every failure. Think creatively and ambitiously.\n\nHard constraints:\n- Must run on a mobile device (React Native / Expo)\n- Total title extraction must complete under 10 seconds\n- Changes land in lib/text-classifier/ and related files\n\nEverything else is open for debate. The current approach (MiniLM embeddings + heuristic scoring)\nis one option, but you are free to propose alternatives if they'd work better:\n- Different embedding model or similarity strategy\n- Replacing embeddings entirely with a rule-based or hybrid approach\n- Restructuring the pipeline (e.g., two-pass, re-ranking, candidate merging)\n- Changing how candidates are generated, filtered, or deduplicated\n- Any other approach that solves the failures within the hard constraints\n\nDon't be incremental for the sake of it — if the feedback reveals a fundamental design flaw,\npropose a fundamental fix. But also don't change things that already work well.\n\nBefore writing any files, briefly outline your key proposed changes (2-3 sentences per failure)\nso you can think through the approach first.\n\nThen write a detailed improvement plan to {iter_dir.relative_to(PROJECT_ROOT)}/improvement-plan.md\nthat includes:\n1. Root cause analysis for each failure pattern\n2. Specific code changes with before/after examples\n3. New or modified heuristics, scoring adjustments, or pipeline changes\n4. Expected impact on accuracy\n\nDo NOT modify any code files. Only write the improvement-plan.md file.\"\"\"\n\n    run_claude(prompt, model=\"opus\", log_path=log_dir / \"plan.log\")\n\n\ndef phase_execute(iter_dir: Path) -> None:\n    \"\"\"Execute improvements with Claude (Sonnet), verify, and commit.\"\"\"\n    log_dir = iter_dir / \"logs\"\n    prompt = f\"\"\"Execute the improvement plan at {iter_dir.relative_to(PROJECT_ROOT)}/improvement-plan.md.\n\nModify lib/text-classifier/title-extractor.ts and any related files as needed.\nMake sure:\n1. All existing tests still pass\n2. The CLI at tools/title-loop/extract-title.ts still works\n3. The code is clean and follows the project conventions in AGENTS.md\n4. No unnecessary changes outside the title extraction logic\n\nCRITICAL CONSTRAINT: Do NOT modify the substring deduplication logic in title-extractor.ts.\nThe block starting with \"// Deduplicate: if one title is a substring of another, keep the shorter\"\nmust remain exactly as-is. It keeps the SHORTER candidate. Do not invert this to keep the longer.\nThis has been incorrectly changed 5 times and breaks tests every time.\n\nAfter making changes, run: npx vitest run --globals lib/text-classifier/__tests__/title-extractor.test.ts\nFix any test failures before finishing.\"\"\"\n\n    run_claude(prompt, model=\"sonnet\", log_path=log_dir / \"execute.log\")\n\n    # Verify tests and CLI\n    print(f\"\\nVerifying tests and CLI...\")\n    tests_ok = run_tests()\n    cli_ok = verify_cli()\n\n    if not tests_ok or not cli_ok:\n        print(\"  WARNING: Verification failed. Attempting to fix...\")\n        fix_prompt = \"\"\"The title extraction tests or CLI are failing after recent changes.\nPlease fix any issues in lib/text-classifier/title-extractor.ts.\nRun: npx vitest run lib/text-classifier/__tests__/title-extractor.test.ts\nAnd verify: npx tsx tools/title-loop/extract-title.ts tools/title-loop/input/*.real.txt\nMake sure both pass before finishing.\"\"\"\n        run_claude(fix_prompt, model=\"sonnet\", log_path=log_dir / \"fix.log\")\n\n        if not run_tests() or not verify_cli():\n            raise RuntimeError(\"Tests or CLI still failing after fix attempt\")\n\n\ndef run_tests() -> bool:\n    \"\"\"Run the title extraction tests.\"\"\"\n    print(\"  Running tests...\")\n    result = subprocess.run(\n        [\"npx\", \"vitest\", \"run\", \"--globals\", \"lib/text-classifier/__tests__/title-extractor.test.ts\"],\n        capture_output=True,\n        text=True,\n        timeout=120,\n        cwd=str(PROJECT_ROOT),\n    )\n    if result.returncode != 0:\n        print(f\"  Tests FAILED: {result.stdout[-500:]}\")\n        return False\n    print(\"  Tests passed.\")\n    return True\n\n\ndef verify_cli() -> bool:\n    \"\"\"Verify the CLI script runs without errors on a sample file.\"\"\"\n    real_files = glob.glob(str(INPUT_DIR / \"*.real.txt\"))\n    if not real_files:\n        print(\"  No real files to test CLI with\")\n        return False\n\n    sample = real_files[0]\n    print(f\"  Verifying CLI on: {Path(sample).name}\")\n    result = subprocess.run(\n        [\"npx\", \"tsx\", str(EXTRACT_SCRIPT), sample],\n        capture_output=True,\n        text=True,\n        timeout=EXTRACT_TIMEOUT,\n        cwd=str(PROJECT_ROOT),\n    )\n    if result.returncode != 0:\n        print(f\"  CLI verification FAILED: {result.stderr[:300]}\")\n        return False\n    print(f\"  CLI output: '{result.stdout.strip()}'\")\n    return True\n\n\n# --- Main loop ---\n\ndef main() -> None:\n    \"\"\"Main self-improving loop with full mid-iteration resumability.\"\"\"\n    DOCS_DIR.mkdir(parents=True, exist_ok=True)\n\n    last_logged = get_last_logged_iteration()\n    if last_logged > 0:\n        last_phase = determine_resume_phase(last_logged)\n        if last_phase == \"done\":\n            accuracy = get_logged_accuracy(last_logged)\n            if accuracy is not None and accuracy >= ACCURACY_THRESHOLD:\n                print(f\"Iteration {last_logged} already reached target accuracy ({accuracy:.1%}). Nothing to do.\")\n                return\n            start_iteration = last_logged + 1\n        else:\n            start_iteration = last_logged\n    else:\n        start_iteration = 1\n\n    print(\"=\" * 60)\n    print(\"SELF-IMPROVING TITLE EXTRACTION LOOP\")\n    print(f\"Max iterations: {MAX_ITERATIONS}\")\n    print(f\"Accuracy threshold: {ACCURACY_THRESHOLD:.0%}\")\n    print(f\"Input dir: {INPUT_DIR}\")\n    if start_iteration > 1:\n        phase = determine_resume_phase(start_iteration)\n        print(f\"Resuming: iteration {start_iteration}, phase '{phase}'\")\n    print(\"=\" * 60)\n    print()\n\n    # Verify CLI works before starting\n    print(\"Pre-flight: verifying CLI...\")\n    if not verify_cli():\n        print(\"FATAL: CLI verification failed. Fix before running the loop.\")\n        sys.exit(1)\n    print()\n\n    for iteration in range(start_iteration, MAX_ITERATIONS + 1):\n        phase = determine_resume_phase(iteration)\n\n        if phase == \"done\":\n            print(f\"Iteration {iteration} already completed. Skipping.\")\n            continue\n\n        print(\"=\" * 60)\n        print(f\"ITERATION {iteration}\" + (f\"  (resuming from '{phase}')\" if phase != \"evaluate\" else \"\"))\n        print(\"=\" * 60)\n\n        iter_dir = find_iter_dir(iteration)\n        all_results: list[dict] | None = None\n\n        # Ensure logs dir exists for this iteration\n        if iter_dir:\n            (iter_dir / \"logs\").mkdir(parents=True, exist_ok=True)\n\n        # --- EVALUATE ---\n        if phase == \"evaluate\":\n            # Create provisional log dir (iter_dir doesn't exist yet)\n            commit_hash = get_commit_hash()\n            provisional_log_dir = DOCS_DIR / f\"{iteration}-{commit_hash}\" / \"logs\"\n            provisional_log_dir.mkdir(parents=True, exist_ok=True)\n\n            try:\n                iter_dir, combined_accuracy, all_results = phase_evaluate(iteration, log_dir=provisional_log_dir)\n            except RuntimeError as e:\n                print(f\"  FATAL: {e}. Stopping.\")\n                break\n\n            if combined_accuracy >= ACCURACY_THRESHOLD:\n                print(f\"\\n{'=' * 60}\")\n                print(f\"TARGET ACCURACY REACHED: {combined_accuracy:.1%}\")\n                print(f\"Stopping after iteration {iteration}\")\n                print(f\"{'=' * 60}\")\n                break\n\n        assert iter_dir is not None, f\"No iteration directory found for iteration {iteration}\"\n\n        # --- ANALYZE ---\n        if phase in (\"evaluate\", \"analyze\"):\n            print(f\"\\nAnalyzing failures with Claude (Sonnet)...\")\n            if all_results is None:\n                all_results = load_results_from_file(iter_dir)\n            try:\n                phase_analyze(iter_dir, all_results)\n            except RuntimeError as e:\n                print(f\"  FATAL: {e}. Stopping.\")\n                break\n\n        # --- PLAN ---\n        if phase in (\"evaluate\", \"analyze\", \"plan\"):\n            print(f\"\\nPlanning improvements with Claude (Opus)...\")\n            try:\n                phase_plan(iter_dir, iteration)\n            except RuntimeError as e:\n                print(f\"  FATAL: {e}. Stopping.\")\n                break\n\n        # --- EXECUTE + VERIFY + COMMIT ---\n        print(f\"\\nExecuting improvements with Claude (Sonnet)...\")\n        try:\n            phase_execute(iter_dir)\n        except RuntimeError as e:\n            print(f\"  FATAL: {e}. Stopping.\")\n            break\n\n        # Commit changes\n        print(f\"\\nCommitting changes...\")\n        try:\n            commit_hash = git_commit_all(f\"title-extraction: iteration {iteration}\")\n            print(f\"  Committed: {commit_hash}\")\n        except subprocess.CalledProcessError as e:\n            # git commit exits 1 both for \"nothing to commit\" and real failures.\n            # Check git status to distinguish.\n            status = subprocess.run(\n                [\"git\", \"status\", \"--porcelain\"],\n                capture_output=True, text=True, cwd=str(PROJECT_ROOT),\n            )\n            if not status.stdout.strip():\n                print(\"  WARNING: Nothing to commit (no changes made)\")\n                commit_hash = get_commit_hash()\n            else:\n                print(f\"  FATAL: git commit failed: {e}. Stopping.\")\n                break\n\n        # Mark iteration as committed so resume skips it\n        (iter_dir / \"committed\").write_text(f\"{commit_hash}\\n\")\n\n        # Prepare next iteration directory\n        next_dir = DOCS_DIR / f\"{iteration + 1}-{commit_hash}\"\n        next_dir.mkdir(parents=True, exist_ok=True)\n\n        print(f\"\\n  Next iteration dir: {next_dir.relative_to(PROJECT_ROOT)}\")\n        print()\n\n    else:\n        print(f\"\\n{'=' * 60}\")\n        print(f\"MAX ITERATIONS ({MAX_ITERATIONS}) REACHED\")\n        print(f\"Final accuracy may not have met threshold.\")\n        print(f\"{'=' * 60}\")\n\n    # Print summary\n    print(f\"\\nIteration log:\")\n    if ITER_LOG.exists():\n        print(ITER_LOG.read_text())\n\n\nif __name__ == \"__main__\":\n    main()\n","numLines":868,"startLine":1,"totalLines":868}}}
