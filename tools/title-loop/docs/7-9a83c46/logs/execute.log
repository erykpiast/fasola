{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BTUHbMaHFiqsVVeAxcteCb","type":"tool_result","content":"     1→#!/usr/bin/env python3\n     2→\"\"\"\n     3→Self-improving title extraction loop.\n     4→\n     5→Iteratively evaluates and improves the title extraction algorithm by:\n     6→1. Running extraction against real and generated OCR input files\n     7→2. Using Claude Code headless for analysis, planning, and implementation\n     8→3. Committing improvements and tracking accuracy across iterations\n     9→\n    10→Fully resumable: detects which step of an iteration was last completed\n    11→and picks up from there.\n    12→\n    13→Usage: python3 tools/title-loop/title-loop.py\n    14→\"\"\"\n    15→\n    16→import glob\n    17→import json\n    18→import os\n    19→import re\n    20→import shutil\n    21→import subprocess\n    22→import sys\n    23→import threading\n    24→import time\n    25→from pathlib import Path\n    26→\n    27→# --- Configuration ---\n    28→MAX_ITERATIONS = 20\n    29→ACCURACY_THRESHOLD = 0.95  # \"close to 100%\"\n    30→SYNTHETIC_COUNT = 100\n    31→CLAUDE_TIMEOUT = 900  # 15 minutes per Claude invocation\n    32→CLAUDE_STALL_TIMEOUT = 60  # kill if no output for N seconds (default)\n    33→CLAUDE_STALL_TIMEOUT_BY_MODEL = {\"opus\": 180, \"sonnet\": 120, \"haiku\": 60}\n    34→CLAUDE_MAX_RETRIES = 3  # max retries per stage on stall/failure\n    35→EXTRACT_TIMEOUT = 120  # 2 minutes per file extraction\n    36→\n    37→PROJECT_ROOT = Path(__file__).resolve().parent.parent.parent\n    38→LOOP_DIR = Path(__file__).resolve().parent\n    39→INPUT_DIR = LOOP_DIR / \"input\"\n    40→DOCS_DIR = LOOP_DIR / \"docs\"\n    41→EXTRACT_SCRIPT = LOOP_DIR / \"extract-title.ts\"\n    42→ITER_LOG = DOCS_DIR / \"iter.txt\"\n    43→\n    44→# Number of recent output lines to show in live display\n    45→\n    46→\n    47→# --- Resume state detection ---\n    48→\n    49→def find_iter_dir(iteration: int) -> Path | None:\n    50→    \"\"\"Find the iteration directory for a given iteration number (hash may vary).\"\"\"\n    51→    matches = sorted(DOCS_DIR.glob(f\"{iteration}-*\"))\n    52→    matches = [m for m in matches if re.match(rf\"^{iteration}-[a-f0-9]+$\", m.name)]\n    53→    return matches[0] if matches else None\n    54→\n    55→\n    56→def get_logged_accuracy(iteration: int) -> float | None:\n    57→    \"\"\"Read the accuracy logged for a specific iteration from iter.txt.\"\"\"\n    58→    if not ITER_LOG.exists():\n    59→        return None\n    60→    for line in ITER_LOG.read_text().strip().splitlines():\n    61→        m = re.match(r\"^(\\d+)\\s*-\\s*([\\d.]+)%\", line)\n    62→        if m and int(m.group(1)) == iteration:\n    63→            return float(m.group(2)) / 100\n    64→    return None\n    65→\n    66→\n    67→def get_last_logged_iteration() -> int:\n    68→    \"\"\"Read iter.txt to find the last logged iteration number. Returns 0 if none.\"\"\"\n    69→    if not ITER_LOG.exists():\n    70→        return 0\n    71→    last = 0\n    72→    for line in ITER_LOG.read_text().strip().splitlines():\n    73→        m = re.match(r\"^(\\d+)\\s*-\\s*\", line)\n    74→        if m:\n    75→            last = int(m.group(1))\n    76→    return last\n    77→\n    78→\n    79→def determine_resume_phase(iteration: int) -> str:\n    80→    \"\"\"\n    81→    Determine what phase to resume from for a given iteration.\n    82→\n    83→    Returns one of:\n    84→      'evaluate'  — no results yet, start from scratch\n    85→      'analyze'   — results exist but no feedback.md\n    86→      'plan'      — feedback exists but no improvement-plan.md\n    87→      'execute'   — plan exists but not yet implemented/committed\n    88→      'done'      — accuracy met threshold, iteration complete\n    89→    \"\"\"\n    90→    iter_dir = find_iter_dir(iteration)\n    91→    if iter_dir is None or not (iter_dir / \"results.txt\").exists():\n    92→        return \"evaluate\"\n    93→\n    94→    accuracy = get_logged_accuracy(iteration)\n    95→    if accuracy is not None and accuracy >= ACCURACY_THRESHOLD:\n    96→        return \"done\"\n    97→\n    98→    if not (iter_dir / \"feedback.md\").exists():\n    99→        return \"analyze\"\n   100→\n   101→    if not (iter_dir / \"improvement-plan.md\").exists():\n   102→        return \"plan\"\n   103→\n   104→    if (iter_dir / \"committed\").exists():\n   105→        return \"done\"\n   106→\n   107→    return \"execute\"\n   108→\n   109→\n   110→# --- Core helpers ---\n   111→\n   112→def normalize(s: str) -> str:\n   113→    \"\"\"Normalize whitespace and case for comparison.\"\"\"\n   114→    return \" \".join(s.lower().split())\n   115→\n   116→\n   117→def normalize_separators(s: str) -> str:\n   118→    \"\"\"Normalize filesystem-substituted characters (: replaces / in filenames).\"\"\"\n   119→    return s.replace(\":\", \"/\")\n   120→\n   121→\n   122→def titles_match(extracted: str, expected: str) -> bool:\n   123→    \"\"\"\n   124→    Binary match: does the extracted title contain all expected title parts?\n   125→    Expected may contain multiple titles separated by '+'.\n   126→    \"\"\"\n   127→    if not extracted:\n   128→        return False\n   129→    extracted_norm = normalize_separators(normalize(extracted))\n   130→    expected_parts = [normalize_separators(normalize(p)) for p in expected.split(\"+\")]\n   131→    return all(part in extracted_norm for part in expected_parts)\n   132→\n   133→\n   134→def extract_expected_title(filename: str) -> str:\n   135→    \"\"\"Extract expected title from filename like 'Tomato Soup.real.txt'.\"\"\"\n   136→    name = Path(filename).name\n   137→    cleaned = re.sub(r\"\\.(real|generated\\.\\d+)\\.txt$\", \"\", name)\n   138→    if cleaned == name:\n   139→        raise ValueError(f\"Unrecognized filename format: {filename!r}\")\n   140→    return cleaned\n   141→\n   142→\n   143→def run_extraction(file_path: str) -> str:\n   144→    \"\"\"Run the title extraction CLI on a file and return the extracted title.\"\"\"\n   145→    try:\n   146→        result = subprocess.run(\n   147→            [\"npx\", \"tsx\", str(EXTRACT_SCRIPT), file_path],\n   148→            capture_output=True,\n   149→            text=True,\n   150→            timeout=EXTRACT_TIMEOUT,\n   151→            cwd=str(PROJECT_ROOT),\n   152→        )\n   153→        if result.returncode != 0:\n   154→            print(f\"  WARNING: extraction failed for {file_path}: {result.stderr.strip()}\")\n   155→            return \"\"\n   156→        return result.stdout.strip()\n   157→    except subprocess.TimeoutExpired:\n   158→        print(f\"  WARNING: extraction timed out for {file_path}\")\n   159→        return \"\"\n   160→\n   161→\n   162→def evaluate_files(file_paths: list[str]) -> list[dict]:\n   163→    \"\"\"Evaluate extraction on a list of files. Returns list of result dicts.\"\"\"\n   164→    results = []\n   165→    for fp in file_paths:\n   166→        expected = extract_expected_title(fp)\n   167→        extracted = run_extraction(fp)\n   168→        match = titles_match(extracted, expected)\n   169→        results.append({\n   170→            \"file\": fp,\n   171→            \"expected\": expected,\n   172→            \"extracted\": extracted,\n   173→            \"match\": match,\n   174→        })\n   175→        status = \"YES\" if match else \"NO\"\n   176→        print(f\"  {status}: expected='{expected}' got='{extracted}'\")\n   177→    return results\n   178→\n   179→\n   180→def compute_accuracy(results: list[dict]) -> float:\n   181→    \"\"\"Compute accuracy as fraction of matches.\"\"\"\n   182→    if not results:\n   183→        return 0.0\n   184→    return sum(1 for r in results if r[\"match\"]) / len(results)\n   185→\n   186→\n   187→def write_results(iter_dir: Path, results: list[dict]) -> None:\n   188→    \"\"\"Write results.txt with one line per file.\"\"\"\n   189→    iter_dir.mkdir(parents=True, exist_ok=True)\n   190→    with open(iter_dir / \"results.txt\", \"w\") as f:\n   191→        for r in results:\n   192→            status = \"yes\" if r[\"match\"] else \"no\"\n   193→            f.write(f\"{r['expected']} - {status}\\n\")\n   194→\n   195→\n   196→def load_results_from_file(iter_dir: Path) -> list[dict]:\n   197→    \"\"\"Reconstruct minimal results from results.txt for building failure prompts.\"\"\"\n   198→    results = []\n   199→    results_path = iter_dir / \"results.txt\"\n   200→    if not results_path.exists():\n   201→        return results\n   202→    for line in results_path.read_text().strip().splitlines():\n   203→        m = re.match(r\"^(.+) - (yes|no)$\", line)\n   204→        if m:\n   205→            expected = m.group(1)\n   206→            match = m.group(2) == \"yes\"\n   207→            real_file = INPUT_DIR / f\"{expected}.real.txt\"\n   208→            file_path = str(real_file) if real_file.exists() else f\"(input file for '{expected}')\"\n   209→            results.append({\n   210→                \"file\": file_path,\n   211→                \"expected\": expected,\n   212→                \"extracted\": \"(from previous evaluation)\",\n   213→                \"match\": match,\n   214→            })\n   215→    return results\n   216→\n   217→\n   218→def get_commit_hash() -> str:\n   219→    \"\"\"Get current git commit hash (short).\"\"\"\n   220→    result = subprocess.run(\n   221→        [\"git\", \"rev-parse\", \"--short\", \"HEAD\"],\n   222→        capture_output=True,\n   223→        text=True,\n   224→        cwd=str(PROJECT_ROOT),\n   225→    )\n   226→    return result.stdout.strip()\n   227→\n   228→\n   229→def git_commit_all(message: str) -> str:\n   230→    \"\"\"Stage source changes and iteration docs. Returns new commit hash.\"\"\"\n   231→    subprocess.run(\n   232→        [\"git\", \"add\",\n   233→         \"lib/text-classifier/\",\n   234→         \"tools/title-loop/docs/\",\n   235→         \"tools/title-loop/extract-title.ts\",\n   236→         \"tools/title-loop/title-loop.py\"],\n   237→        cwd=str(PROJECT_ROOT),\n   238→        check=True,\n   239→    )\n   240→    # Temporarily disable Entire hooks to avoid interactive /dev/tty prompts\n   241→    subprocess.run([\"entire\", \"disable\"], cwd=str(PROJECT_ROOT),\n   242→                   capture_output=True)\n   243→    try:\n   244→        subprocess.run(\n   245→            [\"git\", \"commit\", \"-m\", message],\n   246→            cwd=str(PROJECT_ROOT),\n   247→            check=True,\n   248→        )\n   249→        return get_commit_hash()\n   250→    finally:\n   251→        subprocess.run([\"entire\", \"enable\", \"--agent\", \"claude-code\"],\n   252→                       cwd=str(PROJECT_ROOT), capture_output=True)\n   253→\n   254→\n   255→# --- Claude invocation with live display ---\n   256→\n   257→def _clear_display(height: int) -> None:\n   258→    \"\"\"Move cursor up and clear lines to overwrite previous display.\"\"\"\n   259→    if height > 0:\n   260→        sys.stdout.write(f\"\\033[{height}A\")\n   261→        for _ in range(height):\n   262→            sys.stdout.write(\"\\033[2K\\n\")\n   263→        sys.stdout.write(f\"\\033[{height}A\")\n   264→\n   265→\n   266→def _render_display(model: str, elapsed: float,\n   267→                    input_tokens: int = 0, output_tokens: int = 0) -> int:\n   268→    \"\"\"Render the live display line. Returns number of lines written.\"\"\"\n   269→    term_width = shutil.get_terminal_size().columns\n   270→\n   271→    header = f\"  Running Claude ({model})...\"\n   272→    stats = f\"\\u2191 {input_tokens:,} | \\u2193 {output_tokens:,} | {elapsed:.0f}s\"\n   273→    padding = max(1, term_width - len(header) - len(stats))\n   274→    sys.stdout.write(f\"{header}{' ' * padding}{stats}\\n\")\n   275→\n   276→    sys.stdout.flush()\n   277→    return 1\n   278→\n   279→\n   280→class ClaudeStallError(RuntimeError):\n   281→    \"\"\"Raised when Claude produces no output for CLAUDE_STALL_TIMEOUT seconds.\"\"\"\n   282→    pass\n   283→\n   284→\n   285→def _run_claude_once(\n   286→    prompt: str,\n   287→    model: str = \"sonnet\",\n   288→    log_path: Path | None = None,\n   289→) -> str:\n   290→    \"\"\"\n   291→    Run Claude Code in headless mode with live streaming display (single attempt).\n   292→\n   293→    Uses --output-format stream-json with --include-partial-messages to get\n   294→    real-time text deltas. Shows elapsed time and the last 5 lines of output.\n   295→    Saves full output to log_path if provided.\n   296→\n   297→    Raises ClaudeStallError if no output received for CLAUDE_STALL_TIMEOUT seconds.\n   298→    Raises RuntimeError on non-zero exit or overall timeout.\n   299→    \"\"\"\n   300→    cmd = [\n   301→        \"claude\", \"--print\", \"--dangerously-skip-permissions\",\n   302→        \"--verbose\",\n   303→        \"--output-format\", \"stream-json\",\n   304→        \"--include-partial-messages\",\n   305→    ]\n   306→\n   307→    model_ids = {\n   308→        \"opus\": \"claude-opus-4-6\",\n   309→        \"sonnet\": \"claude-sonnet-4-6\",\n   310→        \"haiku\": \"claude-haiku-4-5-20251001\",\n   311→    }\n   312→    cmd.extend([\"--model\", model_ids.get(model, model_ids[\"sonnet\"])])\n   313→\n   314→    start = time.time()\n   315→    raw_lines: list[str] = []  # raw NDJSON lines for logging\n   316→    result_text = \"\"  # final result extracted from stream\n   317→    input_tokens = 0  # running count from message_start usage\n   318→    output_tokens = 0  # running count from message_delta usage\n   319→    last_activity = time.time()  # tracks last time model produced any output\n   320→    display_height = 0\n   321→    reader_done = threading.Event()\n   322→    lock = threading.Lock()\n   323→\n   324→    proc = subprocess.Popen(\n   325→        cmd,\n   326→        stdin=subprocess.PIPE,\n   327→        stdout=subprocess.PIPE,\n   328→        stderr=subprocess.PIPE,\n   329→        text=True,\n   330→        cwd=str(PROJECT_ROOT),\n   331→    )\n   332→\n   333→    # Send prompt and close stdin\n   334→    try:\n   335→        proc.stdin.write(prompt)\n   336→        proc.stdin.close()\n   337→    except BrokenPipeError:\n   338→        pass\n   339→\n   340→    # Read and parse stream-json stdout in background\n   341→    def reader():\n   342→        nonlocal result_text, input_tokens, output_tokens, last_activity\n   343→        try:\n   344→            for line in proc.stdout:\n   345→                raw_lines.append(line)\n   346→                stripped = line.strip()\n   347→                if not stripped:\n   348→                    continue\n   349→                try:\n   350→                    event = json.loads(stripped)\n   351→                except json.JSONDecodeError:\n   352→                    continue\n   353→\n   354→                etype = event.get(\"type\", \"\")\n   355→\n   356→                if etype == \"stream_event\":\n   357→                    nested = event.get(\"event\", {})\n   358→                    ntype = nested.get(\"type\", \"\")\n   359→                    # Any content_block_delta (thinking, text, tool JSON) = model is active\n   360→                    if ntype == \"content_block_delta\":\n   361→                        with lock:\n   362→                            last_activity = time.time()\n   363→                    # Track input tokens from message_start\n   364→                    elif ntype == \"message_start\":\n   365→                        usage = nested.get(\"message\", {}).get(\"usage\", {})\n   366→                        added = (usage.get(\"input_tokens\", 0)\n   367→                                 + usage.get(\"cache_creation_input_tokens\", 0)\n   368→                                 + usage.get(\"cache_read_input_tokens\", 0))\n   369→                        if added:\n   370→                            with lock:\n   371→                                input_tokens += added\n   372→                                last_activity = time.time()\n   373→                    # Track output tokens from message_delta\n   374→                    elif ntype == \"message_delta\":\n   375→                        usage = nested.get(\"usage\", {})\n   376→                        tok = usage.get(\"output_tokens\", 0)\n   377→                        if tok:\n   378→                            with lock:\n   379→                                output_tokens += tok\n   380→                                last_activity = time.time()\n   381→\n   382→                # Final result\n   383→                elif etype == \"result\":\n   384→                    result_text = event.get(\"result\", \"\")\n   385→        finally:\n   386→            reader_done.set()\n   387→\n   388→    thread = threading.Thread(target=reader, daemon=True)\n   389→    thread.start()\n   390→\n   391→    # Live display loop\n   392→    stall_timeout = CLAUDE_STALL_TIMEOUT_BY_MODEL.get(model, CLAUDE_STALL_TIMEOUT)\n   393→    stalled = False\n   394→    try:\n   395→        while not reader_done.is_set():\n   396→            elapsed = time.time() - start\n   397→\n   398→            # Overall timeout check\n   399→            if elapsed > CLAUDE_TIMEOUT:\n   400→                proc.kill()\n   401→                break\n   402→\n   403→            # Stall detection: no token traffic for stall_timeout seconds\n   404→            with lock:\n   405→                silence = time.time() - last_activity\n   406→            if silence > stall_timeout:\n   407→                stalled = True\n   408→                proc.kill()\n   409→                break\n   410→\n   411→            _clear_display(display_height)\n   412→            display_height = _render_display(model, elapsed, input_tokens, output_tokens)\n   413→\n   414→            reader_done.wait(timeout=1.0)\n   415→\n   416→        # Final display update\n   417→        elapsed = time.time() - start\n   418→        _clear_display(display_height)\n   419→        display_height = _render_display(model, elapsed, input_tokens, output_tokens)\n   420→\n   421→    except KeyboardInterrupt:\n   422→        proc.kill()\n   423→        _clear_display(display_height)\n   424→        print(f\"  Claude ({model}) interrupted by user\")\n   425→        raise\n   426→\n   427→    # Wait for process to finish\n   428→    try:\n   429→        proc.wait(timeout=30)\n   430→    except subprocess.TimeoutExpired:\n   431→        proc.kill()\n   432→        proc.wait()\n   433→\n   434→    stderr_output = proc.stderr.read()\n   435→    elapsed = time.time() - start\n   436→\n   437→    # Use result from stream; fall back to joining raw output\n   438→    full_output = result_text or \"\".join(raw_lines)\n   439→\n   440→    # Save log (always, even on failure)\n   441→    if log_path:\n   442→        log_path.parent.mkdir(parents=True, exist_ok=True)\n   443→        with open(log_path, \"w\") as f:\n   444→            f.write(f\"# Claude ({model}) — {time.strftime('%Y-%m-%d %H:%M:%S')}\\n\")\n   445→            f.write(f\"# Duration: {elapsed:.0f}s — Exit: {proc.returncode}\\n\")\n   446→            f.write(f\"# Prompt:\\n\")\n   447→            for pline in prompt.splitlines():\n   448→                f.write(f\"#   {pline}\\n\")\n   449→            f.write(f\"\\n{'=' * 60}\\n\\n\")\n   450→            f.write(result_text or \"\")\n   451→            if stderr_output:\n   452→                f.write(f\"\\n{'=' * 60}\\n# STDERR:\\n{stderr_output}\\n\")\n   453→            # Also save raw NDJSON stream for debugging\n   454→            f.write(f\"\\n{'=' * 60}\\n# RAW STREAM ({len(raw_lines)} events):\\n\")\n   455→            for rl in raw_lines:\n   456→                f.write(rl)\n   457→\n   458→    # Status line and error handling\n   459→    if stalled:\n   460→        msg = f\"Claude ({model}) stalled (no output for {stall_timeout}s) at {elapsed:.0f}s\"\n   461→        print(f\"\\n  {msg}\")\n   462→        raise ClaudeStallError(msg)\n   463→    elif proc.returncode == 0:\n   464→        print(f\"\\n  Claude ({model}) finished in {elapsed:.0f}s\")\n   465→    elif elapsed > CLAUDE_TIMEOUT:\n   466→        print(f\"\\n  Claude ({model}) timed out after {elapsed:.0f}s\")\n   467→        raise RuntimeError(f\"Claude ({model}) timed out after {elapsed:.0f}s\")\n   468→    else:\n   469→        msg = f\"Claude ({model}) failed (exit {proc.returncode}) in {elapsed:.0f}s\"\n   470→        print(f\"\\n  {msg}\")\n   471→        if stderr_output:\n   472→            print(f\"  stderr: {stderr_output[:500]}\")\n   473→        raise RuntimeError(f\"{msg}\\n{stderr_output[:1000]}\")\n   474→\n   475→    return result_text or full_output\n   476→\n   477→\n   478→def run_claude(\n   479→    prompt: str,\n   480→    model: str = \"sonnet\",\n   481→    log_path: Path | None = None,\n   482→) -> str:\n   483→    \"\"\"\n   484→    Run Claude Code with automatic retry on stalls.\n   485→\n   486→    Retries up to CLAUDE_MAX_RETRIES times when Claude stalls (no output for\n   487→    CLAUDE_STALL_TIMEOUT seconds). After exhausting retries, raises RuntimeError.\n   488→    Non-stall failures (exit code, overall timeout) are raised immediately.\n   489→    \"\"\"\n   490→    for attempt in range(1, CLAUDE_MAX_RETRIES + 1):\n   491→        try:\n   492→            return _run_claude_once(prompt, model=model, log_path=log_path)\n   493→        except ClaudeStallError:\n   494→            if attempt < CLAUDE_MAX_RETRIES:\n   495→                print(f\"  Retrying ({attempt}/{CLAUDE_MAX_RETRIES})...\")\n   496→            else:\n   497→                raise RuntimeError(\n   498→                    f\"Claude ({model}) stalled {CLAUDE_MAX_RETRIES} times — giving up\"\n   499→                )\n   500→    # unreachable, but satisfies type checker\n   501→    raise RuntimeError(\"unreachable\")\n   502→\n   503→\n   504→# --- Iteration phases ---\n   505→\n   506→def phase_evaluate(iteration: int, log_dir: Path) -> tuple[Path, float, list[dict]]:\n   507→    \"\"\"Run evaluation, write results, log accuracy. Returns (iter_dir, accuracy, results).\"\"\"\n   508→    print(f\"\\nEvaluating real input files...\")\n   509→    real_files = sorted(glob.glob(str(INPUT_DIR / \"*.real.txt\")))\n   510→    print(f\"  Found {len(real_files)} real files\")\n   511→    real_results = evaluate_files(real_files)\n   512→    real_accuracy = compute_accuracy(real_results)\n   513→    print(f\"\\n  Real accuracy: {real_accuracy:.1%} ({sum(1 for r in real_results if r['match'])}/{len(real_results)})\")\n   514→\n   515→    gen_results: list[dict] = []\n   516→    combined_accuracy = real_accuracy\n   517→\n   518→    # If real accuracy is high enough, test on generated data too\n   519→    if real_accuracy >= ACCURACY_THRESHOLD:\n   520→        print(f\"\\nGenerating {SYNTHETIC_COUNT} synthetic OCR files...\")\n   521→        generate_synthetic_data(iteration, log_dir=log_dir)\n   522→\n   523→        print(f\"\\nEvaluating generated files...\")\n   524→        gen_files = sorted(glob.glob(str(INPUT_DIR / f\"*.generated.{iteration}.txt\")))\n   525→        print(f\"  Found {len(gen_files)} generated files\")\n   526→        if gen_files:\n   527→            gen_results = evaluate_files(gen_files)\n   528→            gen_accuracy = compute_accuracy(gen_results)\n   529→            print(f\"\\n  Generated accuracy: {gen_accuracy:.1%}\")\n   530→            combined_accuracy = compute_accuracy(real_results + gen_results)\n   531→        else:\n   532→            print(\"  WARNING: No generated files found. Claude may have failed.\")\n   533→\n   534→    all_results = real_results + gen_results\n   535→    print(f\"\\n  Combined accuracy: {combined_accuracy:.1%}\")\n   536→\n   537→    # Log iteration accuracy\n   538→    with open(ITER_LOG, \"a\") as f:\n   539→        f.write(f\"{iteration} - {combined_accuracy:.1%}\\n\")\n   540→\n   541→    # Create iteration directory and write results\n   542→    commit_hash = get_commit_hash()\n   543→    iter_dir = DOCS_DIR / f\"{iteration}-{commit_hash}\"\n   544→    write_results(iter_dir, all_results)\n   545→    print(f\"  Results written to {iter_dir.relative_to(PROJECT_ROOT)}\")\n   546→\n   547→    return iter_dir, combined_accuracy, all_results\n   548→\n   549→\n   550→def generate_synthetic_data(iteration: int, log_dir: Path) -> None:\n   551→    \"\"\"Generate synthetic OCR data using Claude Code.\"\"\"\n   552→    real_files = glob.glob(str(INPUT_DIR / \"*.real.txt\"))\n   553→    existing_titles = [extract_expected_title(f) for f in real_files]\n   554→    titles_list = \", \".join(existing_titles)\n   555→\n   556→    prompt = f\"\"\"Generate {SYNTHETIC_COUNT} realistic fake OCR recipe text files.\n   557→\n   558→Each file should simulate real OCR output from a scanned cookbook page. Include typical\n   559→OCR artifacts: slightly misrecognized characters, broken line wraps, page numbers,\n   560→headers/footers, section labels.\n   561→\n   562→Save each file to: tools/title-loop/input/{{RECIPE_TITLE}}.generated.{iteration}.txt\n   563→\n   564→The recipe title in the filename must EXACTLY match the main title as it appears in the\n   565→generated text content (case-insensitive matching is fine, but the words must match).\n   566→\n   567→Requirements:\n   568→- Mix of English and Polish recipes (roughly 60/40)\n   569→- Variety: soups, mains, desserts, salads, appetizers, breads, drinks, preserves\n   570→- Include multi-word titles (2-5 words), some single-word titles\n   571→- Include OCR noise: garbled short lines at top/bottom, stray numbers, broken words\n   572→- Some files should have the title after noise/headers (not first line)\n   573→- Vary title position: top, after page number, after section header, mid-page\n   574→- Some should have section headers like INGREDIENTS, SKŁADNIKI before or near the title\n   575→- Generate DIFFERENT recipes than these existing ones: {titles_list}\n   576→- Each file should be 15-40 lines long\n   577→\n   578→Generate all {SYNTHETIC_COUNT} files. Work through them systematically.\"\"\"\n   579→\n   580→    run_claude(prompt, model=\"haiku\", log_path=log_dir / \"generate.log\")\n   581→\n   582→\n   583→def phase_analyze(iter_dir: Path, results: list[dict]) -> None:\n   584→    \"\"\"Analyze extraction failures with Claude (Sonnet).\"\"\"\n   585→    log_dir = iter_dir / \"logs\"\n   586→    failures = [r for r in results if not r[\"match\"]]\n   587→    if not failures:\n   588→        (iter_dir / \"feedback.md\").write_text(\"No failures to analyze — all extractions matched.\\n\")\n   589→        return\n   590→\n   591→    failure_details = \"\\n\".join(\n   592→        f\"- File: {r['file']}\\n  Expected: '{r['expected']}'\\n  Got: '{r['extracted']}'\"\n   593→        for r in failures\n   594→    )\n   595→\n   596→    prompt = f\"\"\"Analyze the title extraction failures below. Read each failing input file\n   597→and the current implementation at lib/text-classifier/title-extractor.ts.\n   598→\n   599→Write your analysis to {iter_dir.relative_to(PROJECT_ROOT)}/feedback.md explaining:\n   600→1. What patterns the algorithm fails on\n   601→2. Why each specific failure occurred\n   602→3. Common themes across failures\n   603→\n   604→Do NOT modify any code files. Only write the feedback.md file.\n   605→\n   606→Failures:\n   607→{failure_details}\n   608→\n   609→Results file: {iter_dir.relative_to(PROJECT_ROOT)}/results.txt\"\"\"\n   610→\n   611→    run_claude(prompt, model=\"sonnet\", log_path=log_dir / \"analyze.log\")\n   612→\n   613→\n   614→def phase_plan(iter_dir: Path, iteration: int) -> None:\n   615→    \"\"\"Plan algorithm improvements with Claude (Opus).\"\"\"\n   616→    log_dir = iter_dir / \"logs\"\n   617→    prompt = f\"\"\"Read the feedback at {iter_dir.relative_to(PROJECT_ROOT)}/feedback.md\n   618→and the current title extraction implementation at lib/text-classifier/title-extractor.ts.\n   619→Also read previous iteration docs in tools/title-loop/docs/ to understand what has been tried.\n   620→\n   621→Your job: propose changes that fix every failure. Think creatively and ambitiously.\n   622→\n   623→Hard constraints:\n   624→- Must run on a mobile device (React Native / Expo)\n   625→- Total title extraction must complete under 10 seconds\n   626→- Changes land in lib/text-classifier/ and related files\n   627→\n   628→Everything else is open for debate. The current approach (MiniLM embeddings + heuristic scoring)\n   629→is one option, but you are free to propose alternatives if they'd work better:\n   630→- Different embedding model or similarity strategy\n   631→- Replacing embeddings entirely with a rule-based or hybrid approach\n   632→- Restructuring the pipeline (e.g., two-pass, re-ranking, candidate merging)\n   633→- Changing how candidates are generated, filtered, or deduplicated\n   634→- Any other approach that solves the failures within the hard constraints\n   635→\n   636→Don't be incremental for the sake of it — if the feedback reveals a fundamental design flaw,\n   637→propose a fundamental fix. But also don't change things that already work well.\n   638→\n   639→Before writing any files, briefly outline your key proposed changes (2-3 sentences per failure)\n   640→so you can think through the approach first.\n   641→\n   642→Then write a detailed improvement plan to {iter_dir.relative_to(PROJECT_ROOT)}/improvement-plan.md\n   643→that includes:\n   644→1. Root cause analysis for each failure pattern\n   645→2. Specific code changes with before/after examples\n   646→3. New or modified heuristics, scoring adjustments, or pipeline changes\n   647→4. Expected impact on accuracy\n   648→\n   649→Do NOT modify any code files. Only write the improvement-plan.md file.\"\"\"\n   650→\n   651→    run_claude(prompt, model=\"opus\", log_path=log_dir / \"plan.log\")\n   652→\n   653→\n   654→def phase_execute(iter_dir: Path) -> None:\n   655→    \"\"\"Execute improvements with Claude (Sonnet), verify, and commit.\"\"\"\n   656→    log_dir = iter_dir / \"logs\"\n   657→    prompt = f\"\"\"Execute the improvement plan at {iter_dir.relative_to(PROJECT_ROOT)}/improvement-plan.md.\n   658→\n   659→Modify lib/text-classifier/title-extractor.ts and any related files as needed.\n   660→Make sure:\n   661→1. All existing tests still pass\n   662→2. The CLI at tools/title-loop/extract-title.ts still works\n   663→3. The code is clean and follows the project conventions in AGENTS.md\n   664→4. No unnecessary changes outside the title extraction logic\n   665→\n   666→CRITICAL CONSTRAINT: Do NOT modify the substring deduplication logic in title-extractor.ts.\n   667→The block starting with \"// Deduplicate: if one title is a substring of another, keep the shorter\"\n   668→must remain exactly as-is. It keeps the SHORTER candidate. Do not invert this to keep the longer.\n   669→This has been incorrectly changed 5 times and breaks tests every time.\n   670→\n   671→After making changes, run: npx vitest run --globals lib/text-classifier/__tests__/title-extractor.test.ts\n   672→Fix any test failures before finishing.\"\"\"\n   673→\n   674→    run_claude(prompt, model=\"sonnet\", log_path=log_dir / \"execute.log\")\n   675→\n   676→    # Verify tests and CLI\n   677→    print(f\"\\nVerifying tests and CLI...\")\n   678→    tests_ok = run_tests()\n   679→    cli_ok = verify_cli()\n   680→\n   681→    if not tests_ok or not cli_ok:\n   682→        print(\"  WARNING: Verification failed. Attempting to fix...\")\n   683→        fix_prompt = \"\"\"The title extraction tests or CLI are failing after recent changes.\n   684→Please fix any issues in lib/text-classifier/title-extractor.ts.\n   685→Run: npx vitest run lib/text-classifier/__tests__/title-extractor.test.ts\n   686→And verify: npx tsx tools/title-loop/extract-title.ts tools/title-loop/input/*.real.txt\n   687→Make sure both pass before finishing.\"\"\"\n   688→        run_claude(fix_prompt, model=\"sonnet\", log_path=log_dir / \"fix.log\")\n   689→\n   690→        if not run_tests() or not verify_cli():\n   691→            raise RuntimeError(\"Tests or CLI still failing after fix attempt\")\n   692→\n   693→\n   694→def run_tests() -> bool:\n   695→    \"\"\"Run the title extraction tests.\"\"\"\n   696→    print(\"  Running tests...\")\n   697→    result = subprocess.run(\n   698→        [\"npx\", \"vitest\", \"run\", \"--globals\", \"lib/text-classifier/__tests__/title-extractor.test.ts\"],\n   699→        capture_output=True,\n   700→        text=True,\n   701→        timeout=120,\n   702→        cwd=str(PROJECT_ROOT),\n   703→    )\n   704→    if result.returncode != 0:\n   705→        print(f\"  Tests FAILED: {result.stdout[-500:]}\")\n   706→        return False\n   707→    print(\"  Tests passed.\")\n   708→    return True\n   709→\n   710→\n   711→def verify_cli() -> bool:\n   712→    \"\"\"Verify the CLI script runs without errors on a sample file.\"\"\"\n   713→    real_files = glob.glob(str(INPUT_DIR / \"*.real.txt\"))\n   714→    if not real_files:\n   715→        print(\"  No real files to test CLI with\")\n   716→        return False\n   717→\n   718→    sample = real_files[0]\n   719→    print(f\"  Verifying CLI on: {Path(sample).name}\")\n   720→    result = subprocess.run(\n   721→        [\"npx\", \"tsx\", str(EXTRACT_SCRIPT), sample],\n   722→        capture_output=True,\n   723→        text=True,\n   724→        timeout=EXTRACT_TIMEOUT,\n   725→        cwd=str(PROJECT_ROOT),\n   726→    )\n   727→    if result.returncode != 0:\n   728→        print(f\"  CLI verification FAILED: {result.stderr[:300]}\")\n   729→        return False\n   730→    print(f\"  CLI output: '{result.stdout.strip()}'\")\n   731→    return True\n   732→\n   733→\n   734→# --- Main loop ---\n   735→\n   736→def main() -> None:\n   737→    \"\"\"Main self-improving loop with full mid-iteration resumability.\"\"\"\n   738→    DOCS_DIR.mkdir(parents=True, exist_ok=True)\n   739→\n   740→    last_logged = get_last_logged_iteration()\n   741→    if last_logged > 0:\n   742→        last_phase = determine_resume_phase(last_logged)\n   743→        if last_phase == \"done\":\n   744→            accuracy = get_logged_accuracy(last_logged)\n   745→            if accuracy is not None and accuracy >= ACCURACY_THRESHOLD:\n   746→                print(f\"Iteration {last_logged} already reached target accuracy ({accuracy:.1%}). Nothing to do.\")\n   747→                return\n   748→            start_iteration = last_logged + 1\n   749→        else:\n   750→            start_iteration = last_logged\n   751→    else:\n   752→        start_iteration = 1\n   753→\n   754→    print(\"=\" * 60)\n   755→    print(\"SELF-IMPROVING TITLE EXTRACTION LOOP\")\n   756→    print(f\"Max iterations: {MAX_ITERATIONS}\")\n   757→    print(f\"Accuracy threshold: {ACCURACY_THRESHOLD:.0%}\")\n   758→    print(f\"Input dir: {INPUT_DIR}\")\n   759→    if start_iteration > 1:\n   760→        phase = determine_resume_phase(start_iteration)\n   761→        print(f\"Resuming: iteration {start_iteration}, phase '{phase}'\")\n   762→    print(\"=\" * 60)\n   763→    print()\n   764→\n   765→    # Verify CLI works before starting\n   766→    print(\"Pre-flight: verifying CLI...\")\n   767→    if not verify_cli():\n   768→        print(\"FATAL: CLI verification failed. Fix before running the loop.\")\n   769→        sys.exit(1)\n   770→    print()\n   771→\n   772→    for iteration in range(start_iteration, MAX_ITERATIONS + 1):\n   773→        phase = determine_resume_phase(iteration)\n   774→\n   775→        if phase == \"done\":\n   776→            print(f\"Iteration {iteration} already completed. Skipping.\")\n   777→            continue\n   778→\n   779→        print(\"=\" * 60)\n   780→        print(f\"ITERATION {iteration}\" + (f\"  (resuming from '{phase}')\" if phase != \"evaluate\" else \"\"))\n   781→        print(\"=\" * 60)\n   782→\n   783→        iter_dir = find_iter_dir(iteration)\n   784→        all_results: list[dict] | None = None\n   785→\n   786→        # Ensure logs dir exists for this iteration\n   787→        if iter_dir:\n   788→            (iter_dir / \"logs\").mkdir(parents=True, exist_ok=True)\n   789→\n   790→        # --- EVALUATE ---\n   791→        if phase == \"evaluate\":\n   792→            # Create provisional log dir (iter_dir doesn't exist yet)\n   793→            commit_hash = get_commit_hash()\n   794→            provisional_log_dir = DOCS_DIR / f\"{iteration}-{commit_hash}\" / \"logs\"\n   795→            provisional_log_dir.mkdir(parents=True, exist_ok=True)\n   796→\n   797→            try:\n   798→                iter_dir, combined_accuracy, all_results = phase_evaluate(iteration, log_dir=provisional_log_dir)\n   799→            except RuntimeError as e:\n   800→                print(f\"  FATAL: {e}. Stopping.\")\n   801→                break\n   802→\n   803→            if combined_accuracy >= ACCURACY_THRESHOLD:\n   804→                print(f\"\\n{'=' * 60}\")\n   805→                print(f\"TARGET ACCURACY REACHED: {combined_accuracy:.1%}\")\n   806→                print(f\"Stopping after iteration {iteration}\")\n   807→                print(f\"{'=' * 60}\")\n   808→                break\n   809→\n   810→        assert iter_dir is not None, f\"No iteration directory found for iteration {iteration}\"\n   811→\n   812→        # --- ANALYZE ---\n   813→        if phase in (\"evaluate\", \"analyze\"):\n   814→            print(f\"\\nAnalyzing failures with Claude (Sonnet)...\")\n   815→            if all_results is None:\n   816→                all_results = load_results_from_file(iter_dir)\n   817→            try:\n   818→                phase_analyze(iter_dir, all_results)\n   819→            except RuntimeError as e:\n   820→                print(f\"  FATAL: {e}. Stopping.\")\n   821→                break\n   822→\n   823→        # --- PLAN ---\n   824→        if phase in (\"evaluate\", \"analyze\", \"plan\"):\n   825→            print(f\"\\nPlanning improvements with Claude (Opus)...\")\n   826→            try:\n   827→                phase_plan(iter_dir, iteration)\n   828→            except RuntimeError as e:\n   829→                print(f\"  FATAL: {e}. Stopping.\")\n   830→                break\n   831→\n   832→        # --- EXECUTE + VERIFY + COMMIT ---\n   833→        print(f\"\\nExecuting improvements with Claude (Sonnet)...\")\n   834→        try:\n   835→            phase_execute(iter_dir)\n   836→        except RuntimeError as e:\n   837→            print(f\"  FATAL: {e}. Stopping.\")\n   838→            break\n   839→\n   840→        # Commit changes\n   841→        print(f\"\\nCommitting changes...\")\n   842→        try:\n   843→            commit_hash = git_commit_all(f\"title-extraction: iteration {iteration}\")\n   844→            print(f\"  Committed: {commit_hash}\")\n   845→        except subprocess.CalledProcessError as e:\n   846→            # git commit exits 1 both for \"nothing to commit\" and real failures.\n   847→            # Check git status to distinguish.\n   848→            status = subprocess.run(\n   849→                [\"git\", \"status\", \"--porcelain\"],\n   850→                capture_output=True, text=True, cwd=str(PROJECT_ROOT),\n   851→            )\n   852→            if not status.stdout.strip():\n   853→                print(\"  WARNING: Nothing to commit (no changes made)\")\n   854→                commit_hash = get_commit_hash()\n   855→            else:\n   856→                print(f\"  FATAL: git commit failed: {e}. Stopping.\")\n   857→                break\n   858→\n   859→        # Mark iteration as committed so resume skips it\n   860→        (iter_dir / \"committed\").write_text(f\"{commit_hash}\\n\")\n   861→\n   862→        # Prepare next iteration directory\n   863→        next_dir = DOCS_DIR / f\"{iteration + 1}-{commit_hash}\"\n   864→        next_dir.mkdir(parents=True, exist_ok=True)\n   865→\n   866→        print(f\"\\n  Next iteration dir: {next_dir.relative_to(PROJECT_ROOT)}\")\n   867→        print()\n   868→\n   869→    else:\n   870→        print(f\"\\n{'=' * 60}\")\n   871→        print(f\"MAX ITERATIONS ({MAX_ITERATIONS}) REACHED\")\n   872→        print(f\"Final accuracy may not have met threshold.\")\n   873→        print(f\"{'=' * 60}\")\n   874→\n   875→    # Print summary\n   876→    print(f\"\\nIteration log:\")\n   877→    if ITER_LOG.exists():\n   878→        print(ITER_LOG.read_text())\n   879→\n   880→\n   881→if __name__ == \"__main__\":\n   882→    main()\n   883→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"52016906-9333-4309-a52f-615c04047092","uuid":"e3e775d1-1f8f-4305-a355-a89d1a6519ba","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/tools/title-loop/title-loop.py","content":"#!/usr/bin/env python3\n\"\"\"\nSelf-improving title extraction loop.\n\nIteratively evaluates and improves the title extraction algorithm by:\n1. Running extraction against real and generated OCR input files\n2. Using Claude Code headless for analysis, planning, and implementation\n3. Committing improvements and tracking accuracy across iterations\n\nFully resumable: detects which step of an iteration was last completed\nand picks up from there.\n\nUsage: python3 tools/title-loop/title-loop.py\n\"\"\"\n\nimport glob\nimport json\nimport os\nimport re\nimport shutil\nimport subprocess\nimport sys\nimport threading\nimport time\nfrom pathlib import Path\n\n# --- Configuration ---\nMAX_ITERATIONS = 20\nACCURACY_THRESHOLD = 0.95  # \"close to 100%\"\nSYNTHETIC_COUNT = 100\nCLAUDE_TIMEOUT = 900  # 15 minutes per Claude invocation\nCLAUDE_STALL_TIMEOUT = 60  # kill if no output for N seconds (default)\nCLAUDE_STALL_TIMEOUT_BY_MODEL = {\"opus\": 180, \"sonnet\": 120, \"haiku\": 60}\nCLAUDE_MAX_RETRIES = 3  # max retries per stage on stall/failure\nEXTRACT_TIMEOUT = 120  # 2 minutes per file extraction\n\nPROJECT_ROOT = Path(__file__).resolve().parent.parent.parent\nLOOP_DIR = Path(__file__).resolve().parent\nINPUT_DIR = LOOP_DIR / \"input\"\nDOCS_DIR = LOOP_DIR / \"docs\"\nEXTRACT_SCRIPT = LOOP_DIR / \"extract-title.ts\"\nITER_LOG = DOCS_DIR / \"iter.txt\"\n\n# Number of recent output lines to show in live display\n\n\n# --- Resume state detection ---\n\ndef find_iter_dir(iteration: int) -> Path | None:\n    \"\"\"Find the iteration directory for a given iteration number (hash may vary).\"\"\"\n    matches = sorted(DOCS_DIR.glob(f\"{iteration}-*\"))\n    matches = [m for m in matches if re.match(rf\"^{iteration}-[a-f0-9]+$\", m.name)]\n    return matches[0] if matches else None\n\n\ndef get_logged_accuracy(iteration: int) -> float | None:\n    \"\"\"Read the accuracy logged for a specific iteration from iter.txt.\"\"\"\n    if not ITER_LOG.exists():\n        return None\n    for line in ITER_LOG.read_text().strip().splitlines():\n        m = re.match(r\"^(\\d+)\\s*-\\s*([\\d.]+)%\", line)\n        if m and int(m.group(1)) == iteration:\n            return float(m.group(2)) / 100\n    return None\n\n\ndef get_last_logged_iteration() -> int:\n    \"\"\"Read iter.txt to find the last logged iteration number. Returns 0 if none.\"\"\"\n    if not ITER_LOG.exists():\n        return 0\n    last = 0\n    for line in ITER_LOG.read_text().strip().splitlines():\n        m = re.match(r\"^(\\d+)\\s*-\\s*\", line)\n        if m:\n            last = int(m.group(1))\n    return last\n\n\ndef determine_resume_phase(iteration: int) -> str:\n    \"\"\"\n    Determine what phase to resume from for a given iteration.\n\n    Returns one of:\n      'evaluate'  — no results yet, start from scratch\n      'analyze'   — results exist but no feedback.md\n      'plan'      — feedback exists but no improvement-plan.md\n      'execute'   — plan exists but not yet implemented/committed\n      'done'      — accuracy met threshold, iteration complete\n    \"\"\"\n    iter_dir = find_iter_dir(iteration)\n    if iter_dir is None or not (iter_dir / \"results.txt\").exists():\n        return \"evaluate\"\n\n    accuracy = get_logged_accuracy(iteration)\n    if accuracy is not None and accuracy >= ACCURACY_THRESHOLD:\n        return \"done\"\n\n    if not (iter_dir / \"feedback.md\").exists():\n        return \"analyze\"\n\n    if not (iter_dir / \"improvement-plan.md\").exists():\n        return \"plan\"\n\n    if (iter_dir / \"committed\").exists():\n        return \"done\"\n\n    return \"execute\"\n\n\n# --- Core helpers ---\n\ndef normalize(s: str) -> str:\n    \"\"\"Normalize whitespace and case for comparison.\"\"\"\n    return \" \".join(s.lower().split())\n\n\ndef normalize_separators(s: str) -> str:\n    \"\"\"Normalize filesystem-substituted characters (: replaces / in filenames).\"\"\"\n    return s.replace(\":\", \"/\")\n\n\ndef titles_match(extracted: str, expected: str) -> bool:\n    \"\"\"\n    Binary match: does the extracted title contain all expected title parts?\n    Expected may contain multiple titles separated by '+'.\n    \"\"\"\n    if not extracted:\n        return False\n    extracted_norm = normalize_separators(normalize(extracted))\n    expected_parts = [normalize_separators(normalize(p)) for p in expected.split(\"+\")]\n    return all(part in extracted_norm for part in expected_parts)\n\n\ndef extract_expected_title(filename: str) -> str:\n    \"\"\"Extract expected title from filename like 'Tomato Soup.real.txt'.\"\"\"\n    name = Path(filename).name\n    cleaned = re.sub(r\"\\.(real|generated\\.\\d+)\\.txt$\", \"\", name)\n    if cleaned == name:\n        raise ValueError(f\"Unrecognized filename format: {filename!r}\")\n    return cleaned\n\n\ndef run_extraction(file_path: str) -> str:\n    \"\"\"Run the title extraction CLI on a file and return the extracted title.\"\"\"\n    try:\n        result = subprocess.run(\n            [\"npx\", \"tsx\", str(EXTRACT_SCRIPT), file_path],\n            capture_output=True,\n            text=True,\n            timeout=EXTRACT_TIMEOUT,\n            cwd=str(PROJECT_ROOT),\n        )\n        if result.returncode != 0:\n            print(f\"  WARNING: extraction failed for {file_path}: {result.stderr.strip()}\")\n            return \"\"\n        return result.stdout.strip()\n    except subprocess.TimeoutExpired:\n        print(f\"  WARNING: extraction timed out for {file_path}\")\n        return \"\"\n\n\ndef evaluate_files(file_paths: list[str]) -> list[dict]:\n    \"\"\"Evaluate extraction on a list of files. Returns list of result dicts.\"\"\"\n    results = []\n    for fp in file_paths:\n        expected = extract_expected_title(fp)\n        extracted = run_extraction(fp)\n        match = titles_match(extracted, expected)\n        results.append({\n            \"file\": fp,\n            \"expected\": expected,\n            \"extracted\": extracted,\n            \"match\": match,\n        })\n        status = \"YES\" if match else \"NO\"\n        print(f\"  {status}: expected='{expected}' got='{extracted}'\")\n    return results\n\n\ndef compute_accuracy(results: list[dict]) -> float:\n    \"\"\"Compute accuracy as fraction of matches.\"\"\"\n    if not results:\n        return 0.0\n    return sum(1 for r in results if r[\"match\"]) / len(results)\n\n\ndef write_results(iter_dir: Path, results: list[dict]) -> None:\n    \"\"\"Write results.txt with one line per file.\"\"\"\n    iter_dir.mkdir(parents=True, exist_ok=True)\n    with open(iter_dir / \"results.txt\", \"w\") as f:\n        for r in results:\n            status = \"yes\" if r[\"match\"] else \"no\"\n            f.write(f\"{r['expected']} - {status}\\n\")\n\n\ndef load_results_from_file(iter_dir: Path) -> list[dict]:\n    \"\"\"Reconstruct minimal results from results.txt for building failure prompts.\"\"\"\n    results = []\n    results_path = iter_dir / \"results.txt\"\n    if not results_path.exists():\n        return results\n    for line in results_path.read_text().strip().splitlines():\n        m = re.match(r\"^(.+) - (yes|no)$\", line)\n        if m:\n            expected = m.group(1)\n            match = m.group(2) == \"yes\"\n            real_file = INPUT_DIR / f\"{expected}.real.txt\"\n            file_path = str(real_file) if real_file.exists() else f\"(input file for '{expected}')\"\n            results.append({\n                \"file\": file_path,\n                \"expected\": expected,\n                \"extracted\": \"(from previous evaluation)\",\n                \"match\": match,\n            })\n    return results\n\n\ndef get_commit_hash() -> str:\n    \"\"\"Get current git commit hash (short).\"\"\"\n    result = subprocess.run(\n        [\"git\", \"rev-parse\", \"--short\", \"HEAD\"],\n        capture_output=True,\n        text=True,\n        cwd=str(PROJECT_ROOT),\n    )\n    return result.stdout.strip()\n\n\ndef git_commit_all(message: str) -> str:\n    \"\"\"Stage source changes and iteration docs. Returns new commit hash.\"\"\"\n    subprocess.run(\n        [\"git\", \"add\",\n         \"lib/text-classifier/\",\n         \"tools/title-loop/docs/\",\n         \"tools/title-loop/extract-title.ts\",\n         \"tools/title-loop/title-loop.py\"],\n        cwd=str(PROJECT_ROOT),\n        check=True,\n    )\n    # Temporarily disable Entire hooks to avoid interactive /dev/tty prompts\n    subprocess.run([\"entire\", \"disable\"], cwd=str(PROJECT_ROOT),\n                   capture_output=True)\n    try:\n        subprocess.run(\n            [\"git\", \"commit\", \"-m\", message],\n            cwd=str(PROJECT_ROOT),\n            check=True,\n        )\n        return get_commit_hash()\n    finally:\n        subprocess.run([\"entire\", \"enable\", \"--agent\", \"claude-code\"],\n                       cwd=str(PROJECT_ROOT), capture_output=True)\n\n\n# --- Claude invocation with live display ---\n\ndef _clear_display(height: int) -> None:\n    \"\"\"Move cursor up and clear lines to overwrite previous display.\"\"\"\n    if height > 0:\n        sys.stdout.write(f\"\\033[{height}A\")\n        for _ in range(height):\n            sys.stdout.write(\"\\033[2K\\n\")\n        sys.stdout.write(f\"\\033[{height}A\")\n\n\ndef _render_display(model: str, elapsed: float,\n                    input_tokens: int = 0, output_tokens: int = 0) -> int:\n    \"\"\"Render the live display line. Returns number of lines written.\"\"\"\n    term_width = shutil.get_terminal_size().columns\n\n    header = f\"  Running Claude ({model})...\"\n    stats = f\"\\u2191 {input_tokens:,} | \\u2193 {output_tokens:,} | {elapsed:.0f}s\"\n    padding = max(1, term_width - len(header) - len(stats))\n    sys.stdout.write(f\"{header}{' ' * padding}{stats}\\n\")\n\n    sys.stdout.flush()\n    return 1\n\n\nclass ClaudeStallError(RuntimeError):\n    \"\"\"Raised when Claude produces no output for CLAUDE_STALL_TIMEOUT seconds.\"\"\"\n    pass\n\n\ndef _run_claude_once(\n    prompt: str,\n    model: str = \"sonnet\",\n    log_path: Path | None = None,\n) -> str:\n    \"\"\"\n    Run Claude Code in headless mode with live streaming display (single attempt).\n\n    Uses --output-format stream-json with --include-partial-messages to get\n    real-time text deltas. Shows elapsed time and the last 5 lines of output.\n    Saves full output to log_path if provided.\n\n    Raises ClaudeStallError if no output received for CLAUDE_STALL_TIMEOUT seconds.\n    Raises RuntimeError on non-zero exit or overall timeout.\n    \"\"\"\n    cmd = [\n        \"claude\", \"--print\", \"--dangerously-skip-permissions\",\n        \"--verbose\",\n        \"--output-format\", \"stream-json\",\n        \"--include-partial-messages\",\n    ]\n\n    model_ids = {\n        \"opus\": \"claude-opus-4-6\",\n        \"sonnet\": \"claude-sonnet-4-6\",\n        \"haiku\": \"claude-haiku-4-5-20251001\",\n    }\n    cmd.extend([\"--model\", model_ids.get(model, model_ids[\"sonnet\"])])\n\n    start = time.time()\n    raw_lines: list[str] = []  # raw NDJSON lines for logging\n    result_text = \"\"  # final result extracted from stream\n    input_tokens = 0  # running count from message_start usage\n    output_tokens = 0  # running count from message_delta usage\n    last_activity = time.time()  # tracks last time model produced any output\n    display_height = 0\n    reader_done = threading.Event()\n    lock = threading.Lock()\n\n    proc = subprocess.Popen(\n        cmd,\n        stdin=subprocess.PIPE,\n        stdout=subprocess.PIPE,\n        stderr=subprocess.PIPE,\n        text=True,\n        cwd=str(PROJECT_ROOT),\n    )\n\n    # Send prompt and close stdin\n    try:\n        proc.stdin.write(prompt)\n        proc.stdin.close()\n    except BrokenPipeError:\n        pass\n\n    # Read and parse stream-json stdout in background\n    def reader():\n        nonlocal result_text, input_tokens, output_tokens, last_activity\n        try:\n            for line in proc.stdout:\n                raw_lines.append(line)\n                stripped = line.strip()\n                if not stripped:\n                    continue\n                try:\n                    event = json.loads(stripped)\n                except json.JSONDecodeError:\n                    continue\n\n                etype = event.get(\"type\", \"\")\n\n                if etype == \"stream_event\":\n                    nested = event.get(\"event\", {})\n                    ntype = nested.get(\"type\", \"\")\n                    # Any content_block_delta (thinking, text, tool JSON) = model is active\n                    if ntype == \"content_block_delta\":\n                        with lock:\n                            last_activity = time.time()\n                    # Track input tokens from message_start\n                    elif ntype == \"message_start\":\n                        usage = nested.get(\"message\", {}).get(\"usage\", {})\n                        added = (usage.get(\"input_tokens\", 0)\n                                 + usage.get(\"cache_creation_input_tokens\", 0)\n                                 + usage.get(\"cache_read_input_tokens\", 0))\n                        if added:\n                            with lock:\n                                input_tokens += added\n                                last_activity = time.time()\n                    # Track output tokens from message_delta\n                    elif ntype == \"message_delta\":\n                        usage = nested.get(\"usage\", {})\n                        tok = usage.get(\"output_tokens\", 0)\n                        if tok:\n                            with lock:\n                                output_tokens += tok\n                                last_activity = time.time()\n\n                # Final result\n                elif etype == \"result\":\n                    result_text = event.get(\"result\", \"\")\n        finally:\n            reader_done.set()\n\n    thread = threading.Thread(target=reader, daemon=True)\n    thread.start()\n\n    # Live display loop\n    stall_timeout = CLAUDE_STALL_TIMEOUT_BY_MODEL.get(model, CLAUDE_STALL_TIMEOUT)\n    stalled = False\n    try:\n        while not reader_done.is_set():\n            elapsed = time.time() - start\n\n            # Overall timeout check\n            if elapsed > CLAUDE_TIMEOUT:\n                proc.kill()\n                break\n\n            # Stall detection: no token traffic for stall_timeout seconds\n            with lock:\n                silence = time.time() - last_activity\n            if silence > stall_timeout:\n                stalled = True\n                proc.kill()\n                break\n\n            _clear_display(display_height)\n            display_height = _render_display(model, elapsed, input_tokens, output_tokens)\n\n            reader_done.wait(timeout=1.0)\n\n        # Final display update\n        elapsed = time.time() - start\n        _clear_display(display_height)\n        display_height = _render_display(model, elapsed, input_tokens, output_tokens)\n\n    except KeyboardInterrupt:\n        proc.kill()\n        _clear_display(display_height)\n        print(f\"  Claude ({model}) interrupted by user\")\n        raise\n\n    # Wait for process to finish\n    try:\n        proc.wait(timeout=30)\n    except subprocess.TimeoutExpired:\n        proc.kill()\n        proc.wait()\n\n    stderr_output = proc.stderr.read()\n    elapsed = time.time() - start\n\n    # Use result from stream; fall back to joining raw output\n    full_output = result_text or \"\".join(raw_lines)\n\n    # Save log (always, even on failure)\n    if log_path:\n        log_path.parent.mkdir(parents=True, exist_ok=True)\n        with open(log_path, \"w\") as f:\n            f.write(f\"# Claude ({model}) — {time.strftime('%Y-%m-%d %H:%M:%S')}\\n\")\n            f.write(f\"# Duration: {elapsed:.0f}s — Exit: {proc.returncode}\\n\")\n            f.write(f\"# Prompt:\\n\")\n            for pline in prompt.splitlines():\n                f.write(f\"#   {pline}\\n\")\n            f.write(f\"\\n{'=' * 60}\\n\\n\")\n            f.write(result_text or \"\")\n            if stderr_output:\n                f.write(f\"\\n{'=' * 60}\\n# STDERR:\\n{stderr_output}\\n\")\n            # Also save raw NDJSON stream for debugging\n            f.write(f\"\\n{'=' * 60}\\n# RAW STREAM ({len(raw_lines)} events):\\n\")\n            for rl in raw_lines:\n                f.write(rl)\n\n    # Status line and error handling\n    if stalled:\n        msg = f\"Claude ({model}) stalled (no output for {stall_timeout}s) at {elapsed:.0f}s\"\n        print(f\"\\n  {msg}\")\n        raise ClaudeStallError(msg)\n    elif proc.returncode == 0:\n        print(f\"\\n  Claude ({model}) finished in {elapsed:.0f}s\")\n    elif elapsed > CLAUDE_TIMEOUT:\n        print(f\"\\n  Claude ({model}) timed out after {elapsed:.0f}s\")\n        raise RuntimeError(f\"Claude ({model}) timed out after {elapsed:.0f}s\")\n    else:\n        msg = f\"Claude ({model}) failed (exit {proc.returncode}) in {elapsed:.0f}s\"\n        print(f\"\\n  {msg}\")\n        if stderr_output:\n            print(f\"  stderr: {stderr_output[:500]}\")\n        raise RuntimeError(f\"{msg}\\n{stderr_output[:1000]}\")\n\n    return result_text or full_output\n\n\ndef run_claude(\n    prompt: str,\n    model: str = \"sonnet\",\n    log_path: Path | None = None,\n) -> str:\n    \"\"\"\n    Run Claude Code with automatic retry on stalls.\n\n    Retries up to CLAUDE_MAX_RETRIES times when Claude stalls (no output for\n    CLAUDE_STALL_TIMEOUT seconds). After exhausting retries, raises RuntimeError.\n    Non-stall failures (exit code, overall timeout) are raised immediately.\n    \"\"\"\n    for attempt in range(1, CLAUDE_MAX_RETRIES + 1):\n        try:\n            return _run_claude_once(prompt, model=model, log_path=log_path)\n        except ClaudeStallError:\n            if attempt < CLAUDE_MAX_RETRIES:\n                print(f\"  Retrying ({attempt}/{CLAUDE_MAX_RETRIES})...\")\n            else:\n                raise RuntimeError(\n                    f\"Claude ({model}) stalled {CLAUDE_MAX_RETRIES} times — giving up\"\n                )\n    # unreachable, but satisfies type checker\n    raise RuntimeError(\"unreachable\")\n\n\n# --- Iteration phases ---\n\ndef phase_evaluate(iteration: int, log_dir: Path) -> tuple[Path, float, list[dict]]:\n    \"\"\"Run evaluation, write results, log accuracy. Returns (iter_dir, accuracy, results).\"\"\"\n    print(f\"\\nEvaluating real input files...\")\n    real_files = sorted(glob.glob(str(INPUT_DIR / \"*.real.txt\")))\n    print(f\"  Found {len(real_files)} real files\")\n    real_results = evaluate_files(real_files)\n    real_accuracy = compute_accuracy(real_results)\n    print(f\"\\n  Real accuracy: {real_accuracy:.1%} ({sum(1 for r in real_results if r['match'])}/{len(real_results)})\")\n\n    gen_results: list[dict] = []\n    combined_accuracy = real_accuracy\n\n    # If real accuracy is high enough, test on generated data too\n    if real_accuracy >= ACCURACY_THRESHOLD:\n        print(f\"\\nGenerating {SYNTHETIC_COUNT} synthetic OCR files...\")\n        generate_synthetic_data(iteration, log_dir=log_dir)\n\n        print(f\"\\nEvaluating generated files...\")\n        gen_files = sorted(glob.glob(str(INPUT_DIR / f\"*.generated.{iteration}.txt\")))\n        print(f\"  Found {len(gen_files)} generated files\")\n        if gen_files:\n            gen_results = evaluate_files(gen_files)\n            gen_accuracy = compute_accuracy(gen_results)\n            print(f\"\\n  Generated accuracy: {gen_accuracy:.1%}\")\n            combined_accuracy = compute_accuracy(real_results + gen_results)\n        else:\n            print(\"  WARNING: No generated files found. Claude may have failed.\")\n\n    all_results = real_results + gen_results\n    print(f\"\\n  Combined accuracy: {combined_accuracy:.1%}\")\n\n    # Log iteration accuracy\n    with open(ITER_LOG, \"a\") as f:\n        f.write(f\"{iteration} - {combined_accuracy:.1%}\\n\")\n\n    # Create iteration directory and write results\n    commit_hash = get_commit_hash()\n    iter_dir = DOCS_DIR / f\"{iteration}-{commit_hash}\"\n    write_results(iter_dir, all_results)\n    print(f\"  Results written to {iter_dir.relative_to(PROJECT_ROOT)}\")\n\n    return iter_dir, combined_accuracy, all_results\n\n\ndef generate_synthetic_data(iteration: int, log_dir: Path) -> None:\n    \"\"\"Generate synthetic OCR data using Claude Code.\"\"\"\n    real_files = glob.glob(str(INPUT_DIR / \"*.real.txt\"))\n    existing_titles = [extract_expected_title(f) for f in real_files]\n    titles_list = \", \".join(existing_titles)\n\n    prompt = f\"\"\"Generate {SYNTHETIC_COUNT} realistic fake OCR recipe text files.\n\nEach file should simulate real OCR output from a scanned cookbook page. Include typical\nOCR artifacts: slightly misrecognized characters, broken line wraps, page numbers,\nheaders/footers, section labels.\n\nSave each file to: tools/title-loop/input/{{RECIPE_TITLE}}.generated.{iteration}.txt\n\nThe recipe title in the filename must EXACTLY match the main title as it appears in the\ngenerated text content (case-insensitive matching is fine, but the words must match).\n\nRequirements:\n- Mix of English and Polish recipes (roughly 60/40)\n- Variety: soups, mains, desserts, salads, appetizers, breads, drinks, preserves\n- Include multi-word titles (2-5 words), some single-word titles\n- Include OCR noise: garbled short lines at top/bottom, stray numbers, broken words\n- Some files should have the title after noise/headers (not first line)\n- Vary title position: top, after page number, after section header, mid-page\n- Some should have section headers like INGREDIENTS, SKŁADNIKI before or near the title\n- Generate DIFFERENT recipes than these existing ones: {titles_list}\n- Each file should be 15-40 lines long\n\nGenerate all {SYNTHETIC_COUNT} files. Work through them systematically.\"\"\"\n\n    run_claude(prompt, model=\"haiku\", log_path=log_dir / \"generate.log\")\n\n\ndef phase_analyze(iter_dir: Path, results: list[dict]) -> None:\n    \"\"\"Analyze extraction failures with Claude (Sonnet).\"\"\"\n    log_dir = iter_dir / \"logs\"\n    failures = [r for r in results if not r[\"match\"]]\n    if not failures:\n        (iter_dir / \"feedback.md\").write_text(\"No failures to analyze — all extractions matched.\\n\")\n        return\n\n    failure_details = \"\\n\".join(\n        f\"- File: {r['file']}\\n  Expected: '{r['expected']}'\\n  Got: '{r['extracted']}'\"\n        for r in failures\n    )\n\n    prompt = f\"\"\"Analyze the title extraction failures below. Read each failing input file\nand the current implementation at lib/text-classifier/title-extractor.ts.\n\nWrite your analysis to {iter_dir.relative_to(PROJECT_ROOT)}/feedback.md explaining:\n1. What patterns the algorithm fails on\n2. Why each specific failure occurred\n3. Common themes across failures\n\nDo NOT modify any code files. Only write the feedback.md file.\n\nFailures:\n{failure_details}\n\nResults file: {iter_dir.relative_to(PROJECT_ROOT)}/results.txt\"\"\"\n\n    run_claude(prompt, model=\"sonnet\", log_path=log_dir / \"analyze.log\")\n\n\ndef phase_plan(iter_dir: Path, iteration: int) -> None:\n    \"\"\"Plan algorithm improvements with Claude (Opus).\"\"\"\n    log_dir = iter_dir / \"logs\"\n    prompt = f\"\"\"Read the feedback at {iter_dir.relative_to(PROJECT_ROOT)}/feedback.md\nand the current title extraction implementation at lib/text-classifier/title-extractor.ts.\nAlso read previous iteration docs in tools/title-loop/docs/ to understand what has been tried.\n\nYour job: propose changes that fix every failure. Think creatively and ambitiously.\n\nHard constraints:\n- Must run on a mobile device (React Native / Expo)\n- Total title extraction must complete under 10 seconds\n- Changes land in lib/text-classifier/ and related files\n\nEverything else is open for debate. The current approach (MiniLM embeddings + heuristic scoring)\nis one option, but you are free to propose alternatives if they'd work better:\n- Different embedding model or similarity strategy\n- Replacing embeddings entirely with a rule-based or hybrid approach\n- Restructuring the pipeline (e.g., two-pass, re-ranking, candidate merging)\n- Changing how candidates are generated, filtered, or deduplicated\n- Any other approach that solves the failures within the hard constraints\n\nDon't be incremental for the sake of it — if the feedback reveals a fundamental design flaw,\npropose a fundamental fix. But also don't change things that already work well.\n\nBefore writing any files, briefly outline your key proposed changes (2-3 sentences per failure)\nso you can think through the approach first.\n\nThen write a detailed improvement plan to {iter_dir.relative_to(PROJECT_ROOT)}/improvement-plan.md\nthat includes:\n1. Root cause analysis for each failure pattern\n2. Specific code changes with before/after examples\n3. New or modified heuristics, scoring adjustments, or pipeline changes\n4. Expected impact on accuracy\n\nDo NOT modify any code files. Only write the improvement-plan.md file.\"\"\"\n\n    run_claude(prompt, model=\"opus\", log_path=log_dir / \"plan.log\")\n\n\ndef phase_execute(iter_dir: Path) -> None:\n    \"\"\"Execute improvements with Claude (Sonnet), verify, and commit.\"\"\"\n    log_dir = iter_dir / \"logs\"\n    prompt = f\"\"\"Execute the improvement plan at {iter_dir.relative_to(PROJECT_ROOT)}/improvement-plan.md.\n\nModify lib/text-classifier/title-extractor.ts and any related files as needed.\nMake sure:\n1. All existing tests still pass\n2. The CLI at tools/title-loop/extract-title.ts still works\n3. The code is clean and follows the project conventions in AGENTS.md\n4. No unnecessary changes outside the title extraction logic\n\nCRITICAL CONSTRAINT: Do NOT modify the substring deduplication logic in title-extractor.ts.\nThe block starting with \"// Deduplicate: if one title is a substring of another, keep the shorter\"\nmust remain exactly as-is. It keeps the SHORTER candidate. Do not invert this to keep the longer.\nThis has been incorrectly changed 5 times and breaks tests every time.\n\nAfter making changes, run: npx vitest run --globals lib/text-classifier/__tests__/title-extractor.test.ts\nFix any test failures before finishing.\"\"\"\n\n    run_claude(prompt, model=\"sonnet\", log_path=log_dir / \"execute.log\")\n\n    # Verify tests and CLI\n    print(f\"\\nVerifying tests and CLI...\")\n    tests_ok = run_tests()\n    cli_ok = verify_cli()\n\n    if not tests_ok or not cli_ok:\n        print(\"  WARNING: Verification failed. Attempting to fix...\")\n        fix_prompt = \"\"\"The title extraction tests or CLI are failing after recent changes.\nPlease fix any issues in lib/text-classifier/title-extractor.ts.\nRun: npx vitest run lib/text-classifier/__tests__/title-extractor.test.ts\nAnd verify: npx tsx tools/title-loop/extract-title.ts tools/title-loop/input/*.real.txt\nMake sure both pass before finishing.\"\"\"\n        run_claude(fix_prompt, model=\"sonnet\", log_path=log_dir / \"fix.log\")\n\n        if not run_tests() or not verify_cli():\n            raise RuntimeError(\"Tests or CLI still failing after fix attempt\")\n\n\ndef run_tests() -> bool:\n    \"\"\"Run the title extraction tests.\"\"\"\n    print(\"  Running tests...\")\n    result = subprocess.run(\n        [\"npx\", \"vitest\", \"run\", \"--globals\", \"lib/text-classifier/__tests__/title-extractor.test.ts\"],\n        capture_output=True,\n        text=True,\n        timeout=120,\n        cwd=str(PROJECT_ROOT),\n    )\n    if result.returncode != 0:\n        print(f\"  Tests FAILED: {result.stdout[-500:]}\")\n        return False\n    print(\"  Tests passed.\")\n    return True\n\n\ndef verify_cli() -> bool:\n    \"\"\"Verify the CLI script runs without errors on a sample file.\"\"\"\n    real_files = glob.glob(str(INPUT_DIR / \"*.real.txt\"))\n    if not real_files:\n        print(\"  No real files to test CLI with\")\n        return False\n\n    sample = real_files[0]\n    print(f\"  Verifying CLI on: {Path(sample).name}\")\n    result = subprocess.run(\n        [\"npx\", \"tsx\", str(EXTRACT_SCRIPT), sample],\n        capture_output=True,\n        text=True,\n        timeout=EXTRACT_TIMEOUT,\n        cwd=str(PROJECT_ROOT),\n    )\n    if result.returncode != 0:\n        print(f\"  CLI verification FAILED: {result.stderr[:300]}\")\n        return False\n    print(f\"  CLI output: '{result.stdout.strip()}'\")\n    return True\n\n\n# --- Main loop ---\n\ndef main() -> None:\n    \"\"\"Main self-improving loop with full mid-iteration resumability.\"\"\"\n    DOCS_DIR.mkdir(parents=True, exist_ok=True)\n\n    last_logged = get_last_logged_iteration()\n    if last_logged > 0:\n        last_phase = determine_resume_phase(last_logged)\n        if last_phase == \"done\":\n            accuracy = get_logged_accuracy(last_logged)\n            if accuracy is not None and accuracy >= ACCURACY_THRESHOLD:\n                print(f\"Iteration {last_logged} already reached target accuracy ({accuracy:.1%}). Nothing to do.\")\n                return\n            start_iteration = last_logged + 1\n        else:\n            start_iteration = last_logged\n    else:\n        start_iteration = 1\n\n    print(\"=\" * 60)\n    print(\"SELF-IMPROVING TITLE EXTRACTION LOOP\")\n    print(f\"Max iterations: {MAX_ITERATIONS}\")\n    print(f\"Accuracy threshold: {ACCURACY_THRESHOLD:.0%}\")\n    print(f\"Input dir: {INPUT_DIR}\")\n    if start_iteration > 1:\n        phase = determine_resume_phase(start_iteration)\n        print(f\"Resuming: iteration {start_iteration}, phase '{phase}'\")\n    print(\"=\" * 60)\n    print()\n\n    # Verify CLI works before starting\n    print(\"Pre-flight: verifying CLI...\")\n    if not verify_cli():\n        print(\"FATAL: CLI verification failed. Fix before running the loop.\")\n        sys.exit(1)\n    print()\n\n    for iteration in range(start_iteration, MAX_ITERATIONS + 1):\n        phase = determine_resume_phase(iteration)\n\n        if phase == \"done\":\n            print(f\"Iteration {iteration} already completed. Skipping.\")\n            continue\n\n        print(\"=\" * 60)\n        print(f\"ITERATION {iteration}\" + (f\"  (resuming from '{phase}')\" if phase != \"evaluate\" else \"\"))\n        print(\"=\" * 60)\n\n        iter_dir = find_iter_dir(iteration)\n        all_results: list[dict] | None = None\n\n        # Ensure logs dir exists for this iteration\n        if iter_dir:\n            (iter_dir / \"logs\").mkdir(parents=True, exist_ok=True)\n\n        # --- EVALUATE ---\n        if phase == \"evaluate\":\n            # Create provisional log dir (iter_dir doesn't exist yet)\n            commit_hash = get_commit_hash()\n            provisional_log_dir = DOCS_DIR / f\"{iteration}-{commit_hash}\" / \"logs\"\n            provisional_log_dir.mkdir(parents=True, exist_ok=True)\n\n            try:\n                iter_dir, combined_accuracy, all_results = phase_evaluate(iteration, log_dir=provisional_log_dir)\n            except RuntimeError as e:\n                print(f\"  FATAL: {e}. Stopping.\")\n                break\n\n            if combined_accuracy >= ACCURACY_THRESHOLD:\n                print(f\"\\n{'=' * 60}\")\n                print(f\"TARGET ACCURACY REACHED: {combined_accuracy:.1%}\")\n                print(f\"Stopping after iteration {iteration}\")\n                print(f\"{'=' * 60}\")\n                break\n\n        assert iter_dir is not None, f\"No iteration directory found for iteration {iteration}\"\n\n        # --- ANALYZE ---\n        if phase in (\"evaluate\", \"analyze\"):\n            print(f\"\\nAnalyzing failures with Claude (Sonnet)...\")\n            if all_results is None:\n                all_results = load_results_from_file(iter_dir)\n            try:\n                phase_analyze(iter_dir, all_results)\n            except RuntimeError as e:\n                print(f\"  FATAL: {e}. Stopping.\")\n                break\n\n        # --- PLAN ---\n        if phase in (\"evaluate\", \"analyze\", \"plan\"):\n            print(f\"\\nPlanning improvements with Claude (Opus)...\")\n            try:\n                phase_plan(iter_dir, iteration)\n            except RuntimeError as e:\n                print(f\"  FATAL: {e}. Stopping.\")\n                break\n\n        # --- EXECUTE + VERIFY + COMMIT ---\n        print(f\"\\nExecuting improvements with Claude (Sonnet)...\")\n        try:\n            phase_execute(iter_dir)\n        except RuntimeError as e:\n            print(f\"  FATAL: {e}. Stopping.\")\n            break\n\n        # Commit changes\n        print(f\"\\nCommitting changes...\")\n        try:\n            commit_hash = git_commit_all(f\"title-extraction: iteration {iteration}\")\n            print(f\"  Committed: {commit_hash}\")\n        except subprocess.CalledProcessError as e:\n            # git commit exits 1 both for \"nothing to commit\" and real failures.\n            # Check git status to distinguish.\n            status = subprocess.run(\n                [\"git\", \"status\", \"--porcelain\"],\n                capture_output=True, text=True, cwd=str(PROJECT_ROOT),\n            )\n            if not status.stdout.strip():\n                print(\"  WARNING: Nothing to commit (no changes made)\")\n                commit_hash = get_commit_hash()\n            else:\n                print(f\"  FATAL: git commit failed: {e}. Stopping.\")\n                break\n\n        # Mark iteration as committed so resume skips it\n        (iter_dir / \"committed\").write_text(f\"{commit_hash}\\n\")\n\n        # Prepare next iteration directory\n        next_dir = DOCS_DIR / f\"{iteration + 1}-{commit_hash}\"\n        next_dir.mkdir(parents=True, exist_ok=True)\n\n        print(f\"\\n  Next iteration dir: {next_dir.relative_to(PROJECT_ROOT)}\")\n        print()\n\n    else:\n        print(f\"\\n{'=' * 60}\")\n        print(f\"MAX ITERATIONS ({MAX_ITERATIONS}) REACHED\")\n        print(f\"Final accuracy may not have met threshold.\")\n        print(f\"{'=' * 60}\")\n\n    # Print summary\n    print(f\"\\nIteration log:\")\n    if ITER_LOG.exists():\n        print(ITER_LOG.read_text())\n\n\nif __name__ == \"__main__\":\n    main()\n","numLines":883,"startLine":1,"totalLines":883}}}
