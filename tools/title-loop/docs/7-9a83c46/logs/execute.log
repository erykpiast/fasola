e and the only\n   456→  // ALL_CAPS candidate is immediately after (position ≤ 2), treat the ALL_CAPS\n   457→  // line as a subtitle/transliteration and prefer the first-line title.\n   458→  // This handles bilingual cookbooks where the primary-language title precedes\n   459→  // an ALL_CAPS romanization or foreign-script transliteration.\n   460→  if (selected.length >= 1) {\n   461→    const pos0 = selected.find((s) => s.position === 0 && !isAllCaps(s.text));\n   462→    const allCapsCandidates = selected.filter((s) => isAllCaps(s.text));\n   463→    if (\n   464→      pos0 &&\n   465→      allCapsCandidates.length === 1 &&\n   466→      allCapsCandidates[0].position <= 2 &&\n   467→      pos0.score >= threshold\n   468→    ) {\n   469→      selected = selected.filter((s) => s !== allCapsCandidates[0]);\n   470→    }\n   471→  }\n   472→\n   473→  // Multi-title guard: only join multiple candidates with \"+\" when there is\n   474→  // structural evidence of a multi-recipe page (≥2 ALL_CAPS headings).\n   475→  // A single ALL_CAPS title among mixed-case survivors is a single-recipe page —\n   476→  // collapse to the highest-scoring candidate.\n   477→  // Zero ALL_CAPS survivors → mixed-case multi-title page → keep all.\n   478→  if (selected.length > 1) {\n   479→    const allCapsSelected = selected.filter((s) => isAllCaps(s.text));\n   480→    if (allCapsSelected.length >= 2) {\n   481→      // Check whether non-first ALL_CAPS headings are section headers within one recipe\n   482→      // (followed immediately by ingredient-like content) rather than separate recipe titles.\n   483→      // A multi-recipe page has body text between titles; a single-recipe page has\n   484→      // ingredient lines immediately after each section heading.\n   485→      const sortedCaps = [...allCapsSelected].sort((a, b) => a.position - b.position);\n   486→      const isSubHeader = sortedCaps.slice(1).every((cap) => {\n   487→        const nextLines = lines.slice(cap.position + 1, cap.position + 3);\n   488→        return nextLines.some(\n   489→          (l) => looksLikeIngredient(l.trim()) || /^\\s*\\d/.test(l.trim())\n   490→        );\n   491→      });\n   492→      if (isSubHeader) {\n   493→        selected = [sortedCaps[0]];\n   494→      } else {\n   495→        selected = allCapsSelected;\n   496→      }\n   497→    } else if (allCapsSelected.length === 1) {\n   498→      selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n   499→    }\n   500→  }\n   501→\n   502→  // Cap at 3, sort by document position\n   503→  selected.sort((a, b) => a.position - b.position);\n   504→  selected = selected.slice(0, 3);\n   505→\n   506→  if (selected.length === 0) {\n   507→    return undefined;\n   508→  }\n   509→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"52016906-9333-4309-a52f-615c04047092","uuid":"a50ba184-cc52-4232-9882-aa38fa0bf892","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/title-extractor.ts","content":"        const jLower = j.text.toLowerCase();\n        if (!jLower.startsWith(sLower + \" \")) return false;\n        const remainder = jLower.slice(sLower.length + 1);\n        return /^[/&+:(]/.test(remainder);\n      });\n      if (isPrefixOfJoin) return false;\n      // Remove SUFFIX singles: \"& Coriander\" when\n      // \"Baked Eggs with Feta, Harissa Tomato Sauce & Coriander\" survived\n      const isSuffixOfJoin = survivingJoins.some((j) => {\n        const jLower = j.text.toLowerCase();\n        if (!jLower.endsWith(\" \" + sLower)) return false;\n        // Only remove if the suffix starts with a continuation character\n        return /^[/&+:(]/.test(sLower);\n      });\n      if (isSuffixOfJoin) return false;\n      return true;\n    });\n  }\n\n  // Deduplicate: if one title is a substring of another, keep the shorter (more focused) one.\n  // DO NOT CHANGE THIS LOGIC — it has been incorrectly \"improved\" by the title-loop 5 times.\n  // The tests require shorter wins: \"Pierogi Ruskie\" over \"Pierogi Ruskie 200g mąki 3 ziemniaki\".\n  // The pre-filter above handles the conflicting case (structural heading prefix removal) so that\n  // the incomplete prefix line is never present here when the complete join is in selected.\n  selected = selected.filter((a) => {\n    const aLower = a.text.toLowerCase();\n    return !selected.some(\n      (b) =>\n        b !== a &&\n        aLower.includes(b.text.toLowerCase()) &&\n        b.text.length < a.text.length\n    );\n  });\n\n  // First-line mixed-case title protection:\n  // When a mixed-case title at position 0 has a reasonable score and the only\n  // ALL_CAPS candidate is immediately after (position ≤ 2), treat the ALL_CAPS\n  // line as a subtitle/transliteration and prefer the first-line title.\n  // This handles bilingual cookbooks where the primary-language title precedes\n  // an ALL_CAPS romanization or foreign-script transliteration.\n  if (selected.length >= 1) {\n    const pos0 = selected.find((s) => s.position === 0 && !isAllCaps(s.text));\n    const allCapsCandidates = selected.filter((s) => isAllCaps(s.text));\n    if (\n      pos0 &&\n      allCapsCandidates.length === 1 &&\n      allCapsCandidates[0].position <= 2 &&\n      pos0.score >= threshold\n    ) {\n      selected = selected.filter((s) => s !== allCapsCandidates[0]);\n    }\n  }\n\n  // Multi-title guard: only join multiple candidates with \"+\" when there is\n  // structural evidence of a multi-recipe page (≥2 ALL_CAPS headings).\n  // A single ALL_CAPS title among mixed-case survivors is a single-recipe page —\n  // collapse to the highest-scoring candidate.\n  // Zero ALL_CAPS survivors → mixed-case multi-title page → keep all.\n  if (selected.length > 1) {\n    const allCapsSelected = selected.filter((s) => isAllCaps(s.text));\n    if (allCapsSelected.length >= 2) {\n      // Check whether non-first ALL_CAPS headings are section headers within one recipe\n      // (followed immediately by ingredient-like content) rather than separate recipe titles.\n      // A multi-recipe page has body text between titles; a single-recipe page has\n      // ingredient lines immediately after each section heading.\n      const sortedCaps = [...allCapsSelected].sort((a, b) => a.position - b.position);\n      const isSubHeader = sortedCaps.slice(1).every((cap) => {\n        const nextLines = lines.slice(cap.position + 1, cap.position + 3);\n        return nextLines.some(\n          (l) => looksLikeIngredient(l.trim()) || /^\\s*\\d/.test(l.trim())\n        );\n      });\n      if (isSubHeader) {\n        selected = [sortedCaps[0]];\n      } else {\n        selected = allCapsSelected;\n      }\n    } else if (allCapsSelected.length === 1) {\n      selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n    }\n  }\n\n  // Cap at 3, sort by document position\n  selected.sort((a, b) => a.position - b.position);\n  selected = selected.slice(0, 3);\n\n  if (selected.length === 0) {\n    return undefined;\n  }\n","numLines":90,"startLine":420,"totalLines":534}}}
