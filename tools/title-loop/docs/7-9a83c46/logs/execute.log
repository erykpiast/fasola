{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Fp3QJbRUfKqXec9LPN5JSN","type":"tool_result","content":"     1→/**\n     2→ * Title Extraction\n     3→ * Extracts potential recipe title from OCR text using heuristics or semantic embeddings\n     4→ */\n     5→\n     6→import { cosineSimilarity } from \"./embeddings\";\n     7→\n     8→export type EmbedFn = (text: string) => Promise<Array<number>>;\n     9→\n    10→const TITLE_REFERENCE =\n    11→  \"recipe name, dish title, name of the food, nazwa przepisu, nazwa dania\";\n    12→const HEADER_REFERENCE =\n    13→  \"ingredients list, cooking directions, section heading, składniki, przygotowanie, sposób wykonania\";\n    14→const NOISE_REFERENCE =\n    15→  \"page number, table of contents, book footer, garbled text\";\n    16→\n    17→/**\n    18→ * Measurement units commonly found in ingredient lists\n    19→ */\n    20→const MEASUREMENT_PATTERNS = [\n    21→  \"cup\",\n    22→  \"cups\",\n    23→  \"tbsp\",\n    24→  \"tsp\",\n    25→  \"tablespoon\",\n    26→  \"teaspoon\",\n    27→  \"oz\",\n    28→  \"lb\",\n    29→  \"gram\",\n    30→  \"grams\",\n    31→  \"kg\",\n    32→  \"ml\",\n    33→  \"liter\",\n    34→  \"pinch\",\n    35→  \"dash\",\n    36→  \"handful\",\n    37→];\n    38→\n    39→/**\n    40→ * Patterns that identify recipe metadata lines (not titles)\n    41→ */\n    42→const METADATA_PATTERNS = [\n    43→  /^(SERVES?|MAKES?|YIELDS?)\\b/i,\n    44→  /^(PREP(ARATION)?|COOK(ING)?|PROOF|RISING|FERMENTATION|REST(ING)?)\\s*(AND\\s*)?(COOK(ING)?)?\\s*TIME/i,\n    45→  /^SAMPLE\\s+SCHEDULE\\b/i,\n    46→  /^BULK\\s+FERMENTATION\\b/i,\n    47→  /^(THIS\\s+RECIPE\\s+)?MAKES\\b/i,\n    48→];\n    49→\n    50→/**\n    51→ * Single-word non-title words — standalone OCR fragments unlikely to be recipe titles\n    52→ */\n    53→const NON_TITLE_WORDS = new Set([\n    54→  \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"are\", \"was\",\n    55→  \"has\", \"his\", \"her\", \"its\", \"our\", \"who\", \"how\", \"may\", \"new\", \"now\",\n    56→  \"old\", \"see\", \"way\", \"did\", \"get\", \"let\", \"say\", \"she\", \"too\", \"use\",\n    57→  \"buns\", \"with\",\n    58→]);\n    59→\n    60→function looksLikeIngredient(line: string): boolean {\n    61→  const lowerLine = line.toLowerCase();\n    62→  return MEASUREMENT_PATTERNS.some((pattern) => lowerLine.includes(pattern));\n    63→}\n    64→\n    65→function startsWithNumber(line: string): boolean {\n    66→  return /^\\s*\\d/.test(line);\n    67→}\n    68→\n    69→function isAllCaps(line: string): boolean {\n    70→  const letters = line.replace(/[^a-zA-Z]/g, \"\");\n    71→  return letters.length > 0 && letters === letters.toUpperCase();\n    72→}\n    73→\n    74→function looksLikeMetadata(text: string): boolean {\n    75→  return METADATA_PATTERNS.some((pattern) => pattern.test(text.trim()));\n    76→}\n    77→\n    78→function isLikelyGarbled(text: string): boolean {\n    79→  const letters = text.replace(/[^a-zA-Z]/g, \"\");\n    80→  if (letters.length < 2) return true;\n    81→\n    82→  // Check vowel ratio — English/Polish text typically has 30–50% vowels\n    83→  const vowels = letters.replace(/[^aeiouAEIOUyYąęóĄĘÓ]/g, \"\").length;\n    84→  const vowelRatio = vowels / letters.length;\n    85→  if (vowelRatio < 0.15 || vowelRatio > 0.85) return true;\n    86→\n    87→  // Single orphaned word ≤3 letters that isn't a common word\n    88→  const words = text.trim().split(/\\s+/);\n    89→  const COMMON_SHORT = new Set([\n    90→    \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"had\", \"her\",\n    91→    \"was\", \"one\", \"our\", \"out\", \"are\", \"has\", \"his\", \"how\", \"its\", \"may\",\n    92→    \"new\", \"now\", \"old\", \"see\", \"way\", \"who\", \"did\", \"get\", \"let\", \"say\",\n    93→    \"she\", \"too\", \"use\",\n    94→  ]);\n    95→  if (words.length === 1 && letters.length <= 3 && !COMMON_SHORT.has(text.trim().toLowerCase())) {\n    96→    return true;\n    97→  }\n    98→\n    99→  // Recipe titles never start with a lowercase letter\n   100→  if (/^[a-z]/.test(text.trim())) {\n   101→    return true;\n   102→  }\n   103→\n   104→  // Mid-text sentence boundary (\". \" followed by a letter) — body text fragment spliced from multiple sentences\n   105→  const trimmed = text.trim();\n   106→  if (/\\.\\s+[a-zA-Z]/.test(trimmed) && !trimmed.endsWith(\")\")) {\n   107→    return true;\n   108→  }\n   109→\n   110→  // Multi-word candidate containing a garbled OCR fragment: a short lowercase word that isn't a known short word\n   111→  if (words.length >= 2) {\n   112→    const commonShort2 = new Set([\n   113→      \"a\", \"i\", \"of\", \"or\", \"to\", \"in\", \"on\", \"is\", \"it\", \"an\",\n   114→      \"as\", \"at\", \"by\", \"do\", \"go\", \"if\", \"no\", \"so\", \"up\", \"we\",\n   115→      \"w\", \"z\",  // Polish prepositions\n   116→    ]);\n   117→    const hasGarbledWord = words.some(\n   118→      (w) =>\n   119→        /^[a-z]/.test(w) &&\n   120→        w.replace(/[^a-z]/g, \"\").length <= 2 &&\n   121→        !commonShort2.has(w.toLowerCase())\n   122→    );\n   123→    if (hasGarbledWord) {\n   124→      return true;\n   125→    }\n   126→  }\n   127→\n   128→  return false;\n   129→}\n   130→\n   131→function passesHardFilters(text: string): boolean {\n   132→  if (text.length < 3 || text.length > 80) return false;\n   133→  if (looksLikeIngredient(text)) return false;\n   134→  if (startsWithNumber(text)) return false;\n   135→  if (looksLikeMetadata(text)) return false;\n   136→  if (isLikelyGarbled(text)) return false;\n   137→  // Single-word non-title fragments\n   138→  const words = text.trim().split(/\\s+/);\n   139→  if (words.length === 1 && NON_TITLE_WORDS.has(text.trim().toLowerCase())) return false;\n   140→  return true;\n   141→}\n   142→\n   143→/**\n   144→ * Detect initial burst of short garbled lines.\n   145→ * Returns the index of the first non-garbled or long line.\n   146→ */\n   147→function findBurstEnd(lines: Array<{ text: string }>): number {\n   148→  let i = 0;\n   149→  while (i < lines.length && lines[i].text.length < 20 && isLikelyGarbled(lines[i].text)) {\n   150→    i++;\n   151→  }\n   152→  return i;\n   153→}\n   154→\n   155→function wordCount(text: string): number {\n   156→  return text.split(/\\s+/).filter((w) => w.length > 0).length;\n   157→}\n   158→\n   159→/**\n   160→ * Build candidate strings from lines: single lines plus multi-line joins (2-3 consecutive).\n   161→ * Skips initial burst of short garbled lines. Scans all remaining lines. Caps at 25.\n   162→ */\n   163→export type CandidateOrigin = \"single\" | \"2-line\" | \"3-line\";\n   164→\n   165→function buildCandidates(\n   166→  lines: Array<string>\n   167→): Array<{ text: string; position: number; origin: CandidateOrigin }> {\n   168→  const nonEmptyLines: Array<{ text: string; index: number }> = [];\n   169→\n   170→  for (let i = 0; i < lines.length; i++) {\n   171→    const trimmed = lines[i].trim();\n   172→    if (trimmed.length > 0) {\n   173→      nonEmptyLines.push({ text: trimmed, index: i });\n   174→    }\n   175→  }\n   176→\n   177→  const burstEnd = findBurstEnd(nonEmptyLines);\n   178→\n   179→  // Pre-merge continuation lines: a line starting with /&+:( is never a standalone title.\n   180→  // Merge it into the preceding line so the complete title enters the pool as a single candidate,\n   181→  // avoiding the fragile chain of conditions required by the downstream join survival logic.\n   182→  const mergedLines: Array<{ text: string; index: number }> = [];\n   183→  for (let i = burstEnd; i < nonEmptyLines.length; i++) {\n   184→    const line = nonEmptyLines[i];\n   185→    if (i + 1 < nonEmptyLines.length) {\n   186→      const nextText = nonEmptyLines[i + 1].text;\n   187→      if (/^[/&+:(]/.test(nextText)) {\n   188→        mergedLines.push({ text: `${line.text} ${nextText}`, index: line.index });\n   189→        i++;\n   190→        continue;\n   191→      }\n   192→    }\n   193→    mergedLines.push(line);\n   194→  }\n   195→\n   196→  const candidates: Array<{ text: string; position: number; origin: CandidateOrigin }> = [];\n   197→  const seen = new Set<string>();\n   198→\n   199→  for (let i = 0; i < mergedLines.length; i++) {\n   200→    const line = mergedLines[i];\n   201→\n   202→    // Single line\n   203→    if (passesHardFilters(line.text)) {\n   204→      const norm = line.text.toLowerCase();\n   205→      if (!seen.has(norm)) {\n   206→        seen.add(norm);\n   207→        candidates.push({ text: line.text, position: line.index, origin: \"single\" });\n   208→      }\n   209→    }\n   210→\n   211→    // 2-line join\n   212→    if (i + 1 < mergedLines.length) {\n   213→      const joined2 = `${line.text} ${mergedLines[i + 1].text}`;\n   214→      if (passesHardFilters(joined2)) {\n   215→        const norm = joined2.toLowerCase();\n   216→        if (!seen.has(norm)) {\n   217→          seen.add(norm);\n   218→          candidates.push({ text: joined2, position: line.index, origin: \"2-line\" });\n   219→        }\n   220→      }\n   221→    }\n   222→\n   223→    // 3-line join\n   224→    if (i + 2 < mergedLines.length) {\n   225→      const joined3 = `${line.text} ${mergedLines[i + 1].text} ${mergedLines[i + 2].text}`;\n   226→      if (passesHardFilters(joined3)) {\n   227→        const norm = joined3.toLowerCase();\n   228→        if (!seen.has(norm)) {\n   229→          seen.add(norm);\n   230→          candidates.push({ text: joined3, position: line.index, origin: \"3-line\" });\n   231→        }\n   232→      }\n   233→    }\n   234→  }\n   235→\n   236→  // Pre-filter to 25 before embedding calls: prefer ALL_CAPS and short candidates.\n   237→  // Position-based scoring handles final ranking.\n   238→  if (candidates.length > 25) {\n   239→    const prioritized = candidates.slice().sort((a, b) => {\n   240→      const aAllCaps = isAllCaps(a.text) ? 0 : 1;\n   241→      const bAllCaps = isAllCaps(b.text) ? 0 : 1;\n   242→      if (aAllCaps !== bAllCaps) return aAllCaps - bAllCaps;\n   243→      const aShort = wordCount(a.text) <= 5 ? 0 : 1;\n   244→      const bShort = wordCount(b.text) <= 5 ? 0 : 1;\n   245→      return aShort - bShort;\n   246→    });\n   247→    return prioritized.slice(0, 25);\n   248→  }\n   249→\n   250→  return candidates;\n   251→}\n   252→\n   253→// Module-level cache for reference embeddings\n   254→let cachedTitleRefEmbedding: Array<number> | null = null;\n   255→let cachedHeaderRefEmbedding: Array<number> | null = null;\n   256→let cachedNoiseRefEmbedding: Array<number> | null = null;\n   257→\n   258→export function _resetEmbeddingCacheForTests(): void {\n   259→  cachedTitleRefEmbedding = null;\n   260→  cachedHeaderRefEmbedding = null;\n   261→  cachedNoiseRefEmbedding = null;\n   262→}\n   263→\n   264→export async function extractTitleWithEmbeddings(\n   265→  text: string,\n   266→  embed: EmbedFn\n   267→): Promise<string | undefined> {\n   268→  if (!text || text.trim().length === 0) {\n   269→    return undefined;\n   270→  }\n   271→\n   272→  const lines = text.split(\"\\n\");\n   273→  const candidates = buildCandidates(lines);\n   274→\n   275→  if (candidates.length === 0) {\n   276→    return undefined;\n   277→  }\n   278→\n   279→  // Cache reference embeddings\n   280→  if (!cachedTitleRefEmbedding) {\n   281→    cachedTitleRefEmbedding = await embed(TITLE_REFERENCE);\n   282→  }\n   283→  if (!cachedHeaderRefEmbedding) {\n   284→    cachedHeaderRefEmbedding = await embed(HEADER_REFERENCE);\n   285→  }\n   286→  if (!cachedNoiseRefEmbedding) {\n   287→    cachedNoiseRefEmbedding = await embed(NOISE_REFERENCE);\n   288→  }\n   289→\n   290→  // Find ALL_CAPS candidates with ≥2 words where every significant word has ≥4 alpha letters.\n   291→  // Insignificant tokens (≤1 alpha letter: \"/\", \"&\", \"+\", \":\", \"D)\", etc.) are filtered before\n   292→  // the check so that multi-line joins with continuation punctuation still qualify.\n   293→  const isStructuralHeading = (c: { text: string }): boolean => {\n   294→    if (!isAllCaps(c.text) || wordCount(c.text) < 2) return false;\n   295→    const sigWords = c.text.trim().split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length > 1);\n   296→    return sigWords.length >= 2 && sigWords.every((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   297→  };\n   298→\n   299→  // Pass 1: compute rawScore for all candidates (embedding quality signal)\n   300→  const rawScored: Array<{ text: string; position: number; origin: CandidateOrigin; rawScore: number; embedding: Array<number> }> = [];\n   301→  for (const candidate of candidates) {\n   302→    const embedding = await embed(candidate.text);\n   303→    const titleSim = cosineSimilarity(embedding, cachedTitleRefEmbedding);\n   304→    const headerSim = cosineSimilarity(embedding, cachedHeaderRefEmbedding);\n   305→    const noiseSim = cosineSimilarity(embedding, cachedNoiseRefEmbedding);\n   306→    const rawScore = titleSim - Math.max(headerSim, noiseSim);\n   307→    rawScored.push({ text: candidate.text, position: candidate.position, origin: candidate.origin, rawScore, embedding });\n   308→  }\n   309→\n   310→  // Select baseHeading by embedding quality (rawScore), not position.\n   311→  // This prevents OCR-garbled fragments from claiming the structural heading slot.\n   312→  const structuralCandidates = rawScored.filter((s) => isStructuralHeading(s));\n   313→\n   314→  // Penalize structural headings with truncated OCR words:\n   315→  // if \"FRON\" appears and another heading has \"SAFFRON\", \"FRON\" is likely garbled.\n   316→  for (const sc of structuralCandidates) {\n   317→    const sigWords = sc.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   318→    for (const other of structuralCandidates) {\n   319→      if (other === sc) continue;\n   320→      const otherSigWords = other.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   321→      const hasTruncation = sigWords.some((w) =>\n   322→        otherSigWords.some((ow) => ow !== w && ow.length > w.length && ow.endsWith(w))\n   323→      );\n   324→      if (hasTruncation) {\n   325→        sc.rawScore = -1.0;  // Hard disqualification — truncated OCR artifact\n   326→        break;\n   327→      }\n   328→    }\n   329→  }\n   330→\n   331→  const bestStructural = structuralCandidates.length > 0\n   332→    ? structuralCandidates.reduce((a, b) => a.rawScore > b.rawScore ? a : b)\n   333→    : null;\n   334→  const baseHeading = bestStructural ?? undefined;\n   335→\n   336→  // When the best structural heading has a continuation on the next line introduced by a\n   337→  // punctuation token (/, &, +, :, or parenthesis), prefer the longer 2-line join as the\n   338→  // complete heading. E.g. \"SAFFRON WHEAT BUNS WITH QUARK\" + \"/ COTTAGE CHEESE (VARIATION D)\".\n   339→  // Guard: the remainder after the prefix must start with a continuation character to avoid\n   340→  // merging two separate consecutive recipe titles (FINNISH MILK FLATBREADS stays separate\n   341→  // from FINNISH POTATO FLATBREADS because \"FINNISH\" does not start with a continuation token).\n   342→  const firstStructuralHeading = baseHeading && (\n   343→    rawScored.find((c) => {\n   344→      if (!isStructuralHeading(c)) return false;\n   345→      const hLower = baseHeading.text.toLowerCase();\n   346→      const cLower = c.text.toLowerCase();\n   347→      return cLower.startsWith(hLower + \" \") && /^[/&+:(]/.test(cLower.slice(hLower.length + 1));\n   348→    }) ?? baseHeading\n   349→  );\n   350→\n   351→  // Pass 2: apply bonuses\n   352→  const scored: Array<{ text: string; position: number; origin: CandidateOrigin; score: number; rawScore: number; baseScore: number; thresholdScore: number }> = rawScored.map((rs) => {\n   353→    // Position factor: multiplicative tiebreaker — amplifies existing signal, doesn't replace it\n   354→    const relativePosition = rs.position / lines.length;\n   355→    const positionFactor = relativePosition < 0.5\n   356→      ? 1.0 + 0.12 * (1 - relativePosition * 2)\n   357→      : 1.0;\n   358→\n   359→    // ALL_CAPS bonus: recipe books use ALL_CAPS for titles and section headings\n   360→    const allCapsBonus = isAllCaps(rs.text) && rs.text.replace(/[^a-zA-Z]/g, \"\").length >= 4\n   361→      ? 0.08\n   362→      : 0;\n   363→\n   364→    // Structural heading bonus: best ALL_CAPS heading (or its continuation join) is almost always the recipe title\n   365→    const structuralBonus = firstStructuralHeading && rs.text === firstStructuralHeading.text ? 0.10 : 0;\n   366→\n   367→    // thresholdScore excludes structural bonus so the bonus doesn't inflate the threshold\n   368→    // and prevent equally-valid structural headings from passing on multi-recipe pages.\n   369→    const thresholdScore = rs.rawScore + allCapsBonus;\n   370→    // baseScore excludes position factor — used for diagnostics and ranking\n   371→    const baseScore = rs.rawScore + allCapsBonus + structuralBonus;\n   372→    const score = rs.rawScore * positionFactor + allCapsBonus + structuralBonus;\n   373→    return { text: rs.text, position: rs.position, origin: rs.origin, score, rawScore: rs.rawScore, baseScore, thresholdScore };\n   374→  });\n   375→\n   376→  if (scored.length === 0) {\n   377→    return undefined;\n   378→  }\n   379→\n   380→  // Use thresholdScore (excludes structural bonus) so the structural bonus doesn't inflate\n   381→  // the threshold and block equally-valid headings on multi-recipe pages.\n   382→  const bestThresholdScore = Math.max(...scored.map((s) => s.thresholdScore));\n   383→  const threshold = Math.max(0.08, bestThresholdScore * 0.7);\n   384→\n   385→  // Filter candidates above threshold\n   386→  let selected = scored.filter((s) => s.score >= threshold);\n   387→\n   388→  // Remove word-boundary prefixes of firstStructuralHeading when the heading itself survived\n   389→  // the threshold. Cases:\n   390→  //   ARAYES case:  firstStructuralHeading = \"ARAYES SHRAK\" (2-word join qualifies; \"ARAYES\"\n   391→  //     alone = 1 word, so it never qualified). Filter removes \"ARAYES\" so dedup keeps the join.\n   392→  //   SAFFRON case: baseHeading was the partial line; continuation logic above upgraded\n   393→  //     firstStructuralHeading to the full join. Filter removes the partial so dedup keeps join.\n   394→  // Safety: only fires when the complete heading itself is in selected (passed the threshold).\n   395→  if (firstStructuralHeading && selected.some((s) => s.text === firstStructuralHeading.text)) {\n   396→    const fshLower = firstStructuralHeading.text.toLowerCase();\n   397→    selected = selected.filter((s) => {\n   398→      if (s.text === firstStructuralHeading.text) return true;\n   399→      const sLower = s.text.toLowerCase();\n   400→      // Remove s if it is a space-delimited prefix of the structural heading\n   401→      return !fshLower.startsWith(sLower + \" \");\n   402→    });\n   403→  }\n   404→\n   405→  // Protect continuation joins: when a multi-line join survived the threshold and its second\n   406→  // part starts with a continuation character, remove the single-line prefix so the dedup\n   407→  // \"shorter wins\" rule doesn't destroy the complete join.\n   408→  // E.g. \"Baked Eggs with Feta, Harissa Tomato Sauce\" is removed when\n   409→  // \"Baked Eggs with Feta, Harissa Tomato Sauce & Coriander\" also survived (continuation: &).\n   410→  // Safety: only fires for joins whose continuation starts with /&+:( — digit continuations\n   411→  // like \"Pierogi Ruskie 200g mąki\" are NOT protected, so dedup correctly keeps the shorter form.\n   412→  const survivingJoins = selected.filter((s) => s.origin === \"2-line\" || s.origin === \"3-line\");\n   413→  if (survivingJoins.length > 0) {\n   414→    selected = selected.filter((s) => {\n   415→      if (s.origin !== \"single\") return true;\n   416→      const sLower = s.text.toLowerCase();\n   417→      // Remove PREFIX singles: \"Baked Eggs with Feta, Harissa Tomato Sauce\" when\n   418→      // \"Baked Eggs with Feta, Harissa Tomato Sauce & Coriander\" survived\n   419→      const isPrefixOfJoin = survivingJoins.some((j) => {\n   420→        const jLower = j.text.toLowerCase();\n   421→        if (!jLower.startsWith(sLower + \" \")) return false;\n   422→        const remainder = jLower.slice(sLower.length + 1);\n   423→        return /^[/&+:(]/.test(remainder);\n   424→      });\n   425→      if (isPrefixOfJoin) return false;\n   426→      // Remove SUFFIX singles: \"& Coriander\" when\n   427→      // \"Baked Eggs with Feta, Harissa Tomato Sauce & Coriander\" survived\n   428→      const isSuffixOfJoin = survivingJoins.some((j) => {\n   429→        const jLower = j.text.toLowerCase();\n   430→        if (!jLower.endsWith(\" \" + sLower)) return false;\n   431→        // Only remove if the suffix starts with a continuation character\n   432→        return /^[/&+:(]/.test(sLower);\n   433→      });\n   434→      if (isSuffixOfJoin) return false;\n   435→      return true;\n   436→    });\n   437→  }\n   438→\n   439→  // Deduplicate: if one title is a substring of another, keep the shorter (more focused) one.\n   440→  // DO NOT CHANGE THIS LOGIC — it has been incorrectly \"improved\" by the title-loop 5 times.\n   441→  // The tests require shorter wins: \"Pierogi Ruskie\" over \"Pierogi Ruskie 200g mąki 3 ziemniaki\".\n   442→  // The pre-filter above handles the conflicting case (structural heading prefix removal) so that\n   443→  // the incomplete prefix line is never present here when the complete join is in selected.\n   444→  selected = selected.filter((a) => {\n   445→    const aLower = a.text.toLowerCase();\n   446→    return !selected.some(\n   447→      (b) =>\n   448→        b !== a &&\n   449→        aLower.includes(b.text.toLowerCase()) &&\n   450→        b.text.length < a.text.length\n   451→    );\n   452→  });\n   453→\n   454→  // First-line mixed-case title protection:\n   455→  // When a mixed-case title at position 0 has a reasonable score and the only\n   456→  // ALL_CAPS candidate is immediately after (position ≤ 2), treat the ALL_CAPS\n   457→  // line as a subtitle/transliteration and prefer the first-line title.\n   458→  // This handles bilingual cookbooks where the primary-language title precedes\n   459→  // an ALL_CAPS romanization or foreign-script transliteration.\n   460→  if (selected.length >= 1) {\n   461→    const pos0 = selected.find((s) => s.position === 0 && !isAllCaps(s.text));\n   462→    const allCapsCandidates = selected.filter((s) => isAllCaps(s.text));\n   463→    if (\n   464→      pos0 &&\n   465→      allCapsCandidates.length === 1 &&\n   466→      allCapsCandidates[0].position <= 2 &&\n   467→      pos0.score >= threshold\n   468→    ) {\n   469→      selected = selected.filter((s) => s !== allCapsCandidates[0]);\n   470→    }\n   471→  }\n   472→\n   473→  // Multi-title guard: only join multiple candidates with \"+\" when there is\n   474→  // structural evidence of a multi-recipe page (≥2 ALL_CAPS headings).\n   475→  // A single ALL_CAPS title among mixed-case survivors is a single-recipe page —\n   476→  // collapse to the highest-scoring candidate.\n   477→  // Zero ALL_CAPS survivors → mixed-case multi-title page → keep all.\n   478→  if (selected.length > 1) {\n   479→    const allCapsSelected = selected.filter((s) => isAllCaps(s.text));\n   480→    if (allCapsSelected.length >= 2) {\n   481→      // Check whether non-first ALL_CAPS headings are section headers within one recipe\n   482→      // (followed immediately by ingredient-like content) rather than separate recipe titles.\n   483→      // A multi-recipe page has body text between titles; a single-recipe page has\n   484→      // ingredient lines immediately after each section heading.\n   485→      const sortedCaps = [...allCapsSelected].sort((a, b) => a.position - b.position);\n   486→      const isSubHeader = sortedCaps.slice(1).every((cap) => {\n   487→        const nextLines = lines.slice(cap.position + 1, cap.position + 3);\n   488→        return nextLines.some(\n   489→          (l) => looksLikeIngredient(l.trim()) || /^\\s*\\d/.test(l.trim())\n   490→        );\n   491→      });\n   492→      if (isSubHeader) {\n   493→        selected = [sortedCaps[0]];\n   494→      } else {\n   495→        selected = allCapsSelected;\n   496→      }\n   497→    } else if (allCapsSelected.length === 1) {\n   498→      selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n   499→    }\n   500→  }\n   501→\n   502→  // Cap at 3, sort by document position\n   503→  selected.sort((a, b) => a.position - b.position);\n   504→  selected = selected.slice(0, 3);\n   505→\n   506→  if (selected.length === 0) {\n   507→    return undefined;\n   508→  }\n   509→\n   510→  return selected.map((s) => s.text).join(\" + \");\n   511→}\n   512→\n   513→/**\n   514→ * Extract potential recipe title from OCR text (sync heuristic fallback)\n   515→ */\n   516→export function extractTitle(text: string): string | undefined {\n   517→  if (!text || text.trim().length === 0) {\n   518→    return undefined;\n   519→  }\n   520→\n   521→  const lines = text.split(\"\\n\").map((line) => line.trim());\n   522→\n   523→  for (const line of lines) {\n   524→    if (line.length === 0) continue;\n   525→    if (line.length < 3 || line.length > 50) continue;\n   526→    if (looksLikeIngredient(line)) continue;\n   527→    if (isAllCaps(line)) continue;\n   528→    if (startsWithNumber(line)) continue;\n   529→    return line;\n   530→  }\n   531→\n   532→  return undefined;\n   533→}\n   534→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_01Ht4X3Td1AcwwJ3k4zJifoM","session_id":"52016906-9333-4309-a52f-615c04047092","uuid":"7addb275-9997-4411-8962-3eaef764d236"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012tCt565HHyMGnR6hgsehUT","type":"tool_result","content":"     1→import {\n     2→  extractTitle,\n     3→  extractTitleWithEmbeddings,\n     4→  _resetEmbeddingCacheForTests,\n     5→} from \"../title-extractor\";\n     6→\n     7→/**\n     8→ * Creates a mock embed function that returns predictable vectors.\n     9→ * Words matching titleWords get a vector pointing \"toward titles\",\n    10→ * words matching headerWords get a vector pointing \"toward headers\",\n    11→ * and everything else gets a neutral vector.\n    12→ */\n    13→function createMockEmbed(\n    14→  titleWords: Array<string>,\n    15→  headerWords: Array<string>\n    16→): (text: string) => Promise<Array<number>> {\n    17→  // Reference phrases from the module\n    18→  const TITLE_REF =\n    19→    \"recipe name, dish title, name of the food, nazwa przepisu, nazwa dania\";\n    20→  const HEADER_REF =\n    21→    \"ingredients list, cooking directions, section heading, składniki, przygotowanie, sposób wykonania\";\n    22→  const NOISE_REF =\n    23→    \"page number, table of contents, book footer, garbled text\";\n    24→\n    25→  return async (text: string): Promise<Array<number>> => {\n    26→    const lower = text.toLowerCase();\n    27→\n    28→    // Title reference → unit vector in dimension 0\n    29→    if (lower === TITLE_REF.toLowerCase()) {\n    30→      return [1, 0, 0];\n    31→    }\n    32→    // Header reference → unit vector in dimension 1\n    33→    if (lower === HEADER_REF.toLowerCase()) {\n    34→      return [0, 1, 0];\n    35→    }\n    36→    // Noise reference → unit vector in dimension 2 (orthogonal)\n    37→    if (lower === NOISE_REF.toLowerCase()) {\n    38→      return [0, 0, 1];\n    39→    }\n    40→\n    41→    // Check if text contains title-like words → high cosine with title ref\n    42→    const isTitle = titleWords.some((w) => lower.includes(w.toLowerCase()));\n    43→    // Check if text contains header-like words → high cosine with header ref\n    44→    const isHeader = headerWords.some((w) => lower.includes(w.toLowerCase()));\n    45→\n    46→    if (isTitle && !isHeader) {\n    47→      return [0.9, 0.1, 0]; // High title similarity, low header similarity\n    48→    }\n    49→    if (isHeader && !isTitle) {\n    50→      return [0.1, 0.9, 0]; // Low title similarity, high header similarity\n    51→    }\n    52→    if (isTitle && isHeader) {\n    53→      return [0.5, 0.5, 0]; // Ambiguous\n    54→    }\n    55→    // Neutral\n    56→    return [0.3, 0.3, 0.7];\n    57→  };\n    58→}\n    59→\n    60→describe(\"extractTitle (heuristic)\", () => {\n    61→  it(\"returns undefined for empty text\", () => {\n    62→    expect(extractTitle(\"\")).toBeUndefined();\n    63→    expect(extractTitle(\"  \")).toBeUndefined();\n    64→  });\n    65→\n    66→  it(\"returns the first valid line\", () => {\n    67→    expect(extractTitle(\"Chicken Soup\\nIngredients\\n1 cup water\")).toBe(\n    68→      \"Chicken Soup\"\n    69→    );\n    70→  });\n    71→\n    72→  it(\"skips lines that are too short or too long\", () => {\n    73→    const longLine = \"A\".repeat(51);\n    74→    expect(extractTitle(`ab\\n${longLine}\\nGood Title`)).toBe(\"Good Title\");\n    75→  });\n    76→\n    77→  it(\"skips ingredient lines\", () => {\n    78→    expect(extractTitle(\"2 cups flour\\nApple Pie\")).toBe(\"Apple Pie\");\n    79→  });\n    80→\n    81→  it(\"skips all-caps lines\", () => {\n    82→    expect(extractTitle(\"INGREDIENTS\\nChocolate Cake\")).toBe(\"Chocolate Cake\");\n    83→  });\n    84→\n    85→  it(\"skips lines starting with numbers\", () => {\n    86→    expect(extractTitle(\"12\\nApple Pie\")).toBe(\"Apple Pie\");\n    87→  });\n    88→});\n    89→\n    90→describe(\"extractTitleWithEmbeddings\", () => {\n    91→  beforeEach(() => {\n    92→    _resetEmbeddingCacheForTests();\n    93→  });\n    94→\n    95→  it(\"returns undefined for empty text\", async () => {\n    96→    const embed = createMockEmbed([], []);\n    97→    expect(await extractTitleWithEmbeddings(\"\", embed)).toBeUndefined();\n    98→    expect(await extractTitleWithEmbeddings(\"  \", embed)).toBeUndefined();\n    99→  });\n   100→\n   101→  it(\"picks title over section header (Polish)\", async () => {\n   102→    const embed = createMockEmbed([\"pierogi ruskie\"], [\"składniki\"]);\n   103→    const text = \"Składniki\\nPierogi Ruskie\\n200g mąki\\n3 ziemniaki\";\n   104→    const result = await extractTitleWithEmbeddings(text, embed);\n   105→    expect(result).toBe(\"Pierogi Ruskie\");\n   106→  });\n   107→\n   108→  it(\"picks title over section header (English)\", async () => {\n   109→    const embed = createMockEmbed([\"chicken soup\"], [\"ingredients\"]);\n   110→    const text = \"Ingredients\\nChicken Soup\\n1 cup water\\nSalt\";\n   111→    const result = await extractTitleWithEmbeddings(text, embed);\n   112→    expect(result).toBe(\"Chicken Soup\");\n   113→  });\n   114→\n   115→  it(\"preserves all-caps titles\", async () => {\n   116→    const embed = createMockEmbed([\"chocolate cake\"], [\"ingredients\"]);\n   117→    const text = \"CHOCOLATE CAKE\\nIngredients\\n200g flour\";\n   118→    const result = await extractTitleWithEmbeddings(text, embed);\n   119→    expect(result).toBe(\"CHOCOLATE CAKE\");\n   120→  });\n   121→\n   122→  it(\"skips numbered lines\", async () => {\n   123→    const embed = createMockEmbed([\"apple pie\"], []);\n   124→    const text = \"12\\nApple Pie\\nSome instructions\";\n   125→    const result = await extractTitleWithEmbeddings(text, embed);\n   126→    expect(result).toBe(\"Apple Pie\");\n   127→  });\n   128→\n   129→  it(\"joins multi-line title (2 lines)\", async () => {\n   130→    const embed = createMockEmbed(\n   131→      [\"kurczak w sosie śmietanowym z pieczarkami\"],\n   132→      [\"składniki\"]\n   133→    );\n   134→    const text =\n   135→      \"Kurczak w sosie\\nśmietanowym z pieczarkami\\nSkładniki\\n200g kurczaka\";\n   136→    const result = await extractTitleWithEmbeddings(text, embed);\n   137→    expect(result).toBe(\"Kurczak w sosie śmietanowym z pieczarkami\");\n   138→  });\n   139→\n   140→  it(\"joins multi-line title (3 lines)\", async () => {\n   141→    const embed = createMockEmbed(\n   142→      [\"makaron z sosem pomidorowym i bazylią\"],\n   143→      [\"składniki\"]\n   144→    );\n   145→    const text =\n   146→      \"Makaron z sosem\\npomidorowym\\ni bazylią\\nSkładniki\\n300g makaronu\";\n   147→    const result = await extractTitleWithEmbeddings(text, embed);\n   148→    expect(result).toBe(\"Makaron z sosem pomidorowym i bazylią\");\n   149→  });\n   150→\n   151→  it(\"does not over-greedily join title with header\", async () => {\n   152→    const embed = createMockEmbed([\"apple pie\"], [\"ingredients\"]);\n   153→    const text = \"Apple Pie\\nIngredients\\n200g flour\";\n   154→    const result = await extractTitleWithEmbeddings(text, embed);\n   155→    // Should prefer \"Apple Pie\" alone, not \"Apple Pie Ingredients\"\n   156→    expect(result).toBe(\"Apple Pie\");\n   157→  });\n   158→\n   159→  it(\"returns multiple titles joined with + when both score well\", async () => {\n   160→    const embed = createMockEmbed(\n   161→      [\"first recipe\", \"second recipe\"],\n   162→      []\n   163→    );\n   164→    const text = \"First Recipe\\nSecond Recipe\\nSome other text\";\n   165→    const result = await extractTitleWithEmbeddings(text, embed);\n   166→    expect(result).toBe(\"First Recipe + Second Recipe\");\n   167→  });\n   168→\n   169→  it(\"skips burst of short lines at start and finds title after\", async () => {\n   170→    const embed = createMockEmbed([\"beef stew\"], [\"ingredients\"]);\n   171→    // 3+ short garbled lines at start, then real content with a long line\n   172→    const text =\n   173→      \"pg 42\\nA.\\nfoo\\nThis is a longer line that triggers burst end detection\\nBeef Stew\\nIngredients\\n500g beef\";\n   174→    const result = await extractTitleWithEmbeddings(text, embed);\n   175→    expect(result).toBe(\"Beef Stew\");\n   176→  });\n   177→\n   178→  it(\"two titles deep in text returns both joined\", async () => {\n   179→    const embed = createMockEmbed(\n   180→      [\"pasta carbonara\", \"tiramisu classico\"],\n   181→      [\"ingredients\", \"składniki\"]\n   182→    );\n   183→    const text =\n   184→      \"Ingredients\\nPasta Carbonara\\n200g pasta\\n100g guanciale\\nIngredients\\nTiramisu Classico\\n250g mascarpone\";\n   185→    const result = await extractTitleWithEmbeddings(text, embed);\n   186→    expect(result).toBe(\"Pasta Carbonara + Tiramisu Classico\");\n   187→  });\n   188→\n   189→  it(\"single-recipe page still returns one title\", async () => {\n   190→    const embed = createMockEmbed([\"tomato soup\"], [\"ingredients\"]);\n   191→    const text = \"Tomato Soup\\nIngredients\\n4 tomatoes\\n1 cup cream\\nSalt\";\n   192→    const result = await extractTitleWithEmbeddings(text, embed);\n   193→    expect(result).toBe(\"Tomato Soup\");\n   194→  });\n   195→\n   196→  it(\"keeps 2-word ALL_CAPS join over its single-word prefix (ARAYES-type)\", async () => {\n   197→    // \"ARAYES\" alone is 1 word → never qualifies as firstStructuralHeading.\n   198→    // \"ARAYES SHRAK\" qualifies → pre-filter removes \"ARAYES\" so dedup keeps the join.\n   199→    const embed = createMockEmbed([\"arayes\"], [\"ingredients\"]);\n   200→    const text = \"ARAYES\\nSHRAK\\nIngredients\\n2 cups flour\";\n   201→    const result = await extractTitleWithEmbeddings(text, embed);\n   202→    expect(result).toBe(\"ARAYES SHRAK\");\n   203→  });\n   204→\n   205→  it(\"extends ALL_CAPS structural heading when next line starts with continuation token (SAFFRON-type)\", async () => {\n   206→    // \"TITLE FIRST PART\" qualifies as structural heading; continuation upgrades it to the join.\n   207→    // Pre-filter then removes the partial so dedup keeps the complete join.\n   208→    const embed = createMockEmbed([\"title first part\"], [\"ingredients\"]);\n   209→    const text = \"TITLE FIRST PART\\n/ SECOND PART\\nIngredients\\n1 cup flour\";\n   210→    const result = await extractTitleWithEmbeddings(text, embed);\n   211→    expect(result).toBe(\"TITLE FIRST PART / SECOND PART\");\n   212→  });\n   213→\n   214→  it(\"pre-merges continuation line starting with & into preceding line (Baked Eggs type)\", async () => {\n   215→    // \"& Coriander\" starts with & so it's merged into the preceding line before candidate\n   216→    // generation — the complete title enters the pool as a single candidate.\n   217→    const embed = createMockEmbed(\n   218→      [\"baked eggs with feta\"],\n   219→      [\"ingredients\"]\n   220→    );\n   221→    const text =\n   222→      \"Baked Eggs with Feta, Harissa Tomato Sauce\\n& Coriander\\nIngredients\\n2 eggs\";\n   223→    const result = await extractTitleWithEmbeddings(text, embed);\n   224→    expect(result).toBe(\"Baked Eggs with Feta, Harissa Tomato Sauce & Coriander\");\n   225→  });\n   226→\n   227→  it(\"does not pre-merge second line that lacks a continuation character (ARAYES-type safety)\", async () => {\n   228→    // \"SHRAK\" does not start with /&+:( so it is NOT pre-merged.\n   229→    // The existing structural heading join logic handles it instead.\n   230→    const embed = createMockEmbed([\"arayes\"], [\"ingredients\"]);\n   231→    const text = \"ARAYES\\nSHRAK\\nIngredients\\n2 cups flour\";\n   232→    const result = await extractTitleWithEmbeddings(text, embed);\n   233→    expect(result).toBe(\"ARAYES SHRAK\");\n   234→  });\n   235→\n   236→  it(\"returns only the first ALL_CAPS heading when subsequent ALL_CAPS headings are section headers followed by ingredients (CHLEBEK type)\", async () => {\n   237→    // WARZYWA I BOCZEK is immediately followed by ingredient lines (numbers) →\n   238→    // it's a section header, not a second recipe title. Keep only CHLEBEK Z WARZYWAMI I BOCZKIEM.\n   239→    const embed = createMockEmbed(\n   240→      [\"chlebek z warzywami i boczkiem\", \"warzywa i boczek\"],\n   241→      []\n   242→    );\n   243→    const text = [\n   244→      \"CHLEBEK Z WARZYWAMI I BOCZKIEM\",\n   245→      \"WARZYWA I BOCZEK\",\n   246→      \"500 g strączków zielonego groszku\",\n   247→      \"1 żółta papryka\",\n   248→      \"CHLEBEK\",\n   249→      \"500 g mąki\",\n   250→    ].join(\"\\n\");\n   251→    const result = await extractTitleWithEmbeddings(text, embed);\n   252→    expect(result).toBe(\"CHLEBEK Z WARZYWAMI I BOCZKIEM\");\n   253→  });\n   254→\n   255→  it(\"returns both ALL_CAPS titles when headings are NOT followed by ingredient lines (FINNISH-type)\", async () => {\n   256→    // POTATO FLATBREADS is followed by body text, not ingredients →\n   257→    // these are two separate recipe titles on a multi-recipe page.\n   258→    const embed = createMockEmbed(\n   259→      [\"milk flatbreads\", \"potato flatbreads\"],\n   260→      []\n   261→    );\n   262→    const text = [\n   263→      \"MILK FLATBREADS\",\n   264→      \"Mix flour with milk and knead\",\n   265→      \"Cook on a dry skillet\",\n   266→      \"POTATO FLATBREADS\",\n   267→      \"Boil potatoes until tender\",\n   268→      \"Mash well before mixing\",\n   269→    ].join(\"\\n\");\n   270→    const result = await extractTitleWithEmbeddings(text, embed);\n   271→    expect(result).toBe(\"MILK FLATBREADS + POTATO FLATBREADS\");\n   272→  });\n   273→\n   274→  it(\"prefers mixed-case title at position 0 over ALL_CAPS subtitle at position 1 (bilingual page)\", async () => {\n   275→    // \"Faszerowana papryka\" is the Polish title at position 0 (mixed-case).\n   276→    // \"PAPRIKA GYERAN-JJIM\" is an ALL_CAPS romanization at position 1 — treated as subtitle.\n   277→    const embed = createMockEmbed(\n   278→      [\"faszerowana papryka\", \"paprika gyeran\