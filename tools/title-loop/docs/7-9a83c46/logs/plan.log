{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0127FiotDFvsKbTrndMLRHR7","type":"tool_result","content":"     1→/**\n     2→ * Title Extraction\n     3→ * Extracts potential recipe title from OCR text using heuristics or semantic embeddings\n     4→ */\n     5→\n     6→import { cosineSimilarity } from \"./embeddings\";\n     7→\n     8→export type EmbedFn = (text: string) => Promise<Array<number>>;\n     9→\n    10→const TITLE_REFERENCE =\n    11→  \"recipe name, dish title, name of the food, nazwa przepisu, nazwa dania\";\n    12→const HEADER_REFERENCE =\n    13→  \"ingredients list, cooking directions, section heading, składniki, przygotowanie, sposób wykonania\";\n    14→const NOISE_REFERENCE =\n    15→  \"page number, table of contents, book footer, garbled text\";\n    16→\n    17→/**\n    18→ * Measurement units commonly found in ingredient lists\n    19→ */\n    20→const MEASUREMENT_PATTERNS = [\n    21→  \"cup\",\n    22→  \"cups\",\n    23→  \"tbsp\",\n    24→  \"tsp\",\n    25→  \"tablespoon\",\n    26→  \"teaspoon\",\n    27→  \"oz\",\n    28→  \"lb\",\n    29→  \"gram\",\n    30→  \"grams\",\n    31→  \"kg\",\n    32→  \"ml\",\n    33→  \"liter\",\n    34→  \"pinch\",\n    35→  \"dash\",\n    36→  \"handful\",\n    37→];\n    38→\n    39→/**\n    40→ * Patterns that identify recipe metadata lines (not titles)\n    41→ */\n    42→const METADATA_PATTERNS = [\n    43→  /^(SERVES?|MAKES?|YIELDS?)\\b/i,\n    44→  /^(PREP(ARATION)?|COOK(ING)?|PROOF|RISING|FERMENTATION|REST(ING)?)\\s*(AND\\s*)?(COOK(ING)?)?\\s*TIME/i,\n    45→  /^SAMPLE\\s+SCHEDULE\\b/i,\n    46→  /^BULK\\s+FERMENTATION\\b/i,\n    47→  /^(THIS\\s+RECIPE\\s+)?MAKES\\b/i,\n    48→];\n    49→\n    50→/**\n    51→ * Single-word non-title words — standalone OCR fragments unlikely to be recipe titles\n    52→ */\n    53→const NON_TITLE_WORDS = new Set([\n    54→  \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"are\", \"was\",\n    55→  \"has\", \"his\", \"her\", \"its\", \"our\", \"who\", \"how\", \"may\", \"new\", \"now\",\n    56→  \"old\", \"see\", \"way\", \"did\", \"get\", \"let\", \"say\", \"she\", \"too\", \"use\",\n    57→  \"buns\", \"with\",\n    58→]);\n    59→\n    60→function looksLikeIngredient(line: string): boolean {\n    61→  const lowerLine = line.toLowerCase();\n    62→  return MEASUREMENT_PATTERNS.some((pattern) => lowerLine.includes(pattern));\n    63→}\n    64→\n    65→function startsWithNumber(line: string): boolean {\n    66→  return /^\\s*\\d/.test(line);\n    67→}\n    68→\n    69→function isAllCaps(line: string): boolean {\n    70→  const letters = line.replace(/[^a-zA-Z]/g, \"\");\n    71→  return letters.length > 0 && letters === letters.toUpperCase();\n    72→}\n    73→\n    74→function looksLikeMetadata(text: string): boolean {\n    75→  return METADATA_PATTERNS.some((pattern) => pattern.test(text.trim()));\n    76→}\n    77→\n    78→function isLikelyGarbled(text: string): boolean {\n    79→  const letters = text.replace(/[^a-zA-Z]/g, \"\");\n    80→  if (letters.length < 2) return true;\n    81→\n    82→  // Check vowel ratio — English/Polish text typically has 30–50% vowels\n    83→  const vowels = letters.replace(/[^aeiouAEIOUyYąęóĄĘÓ]/g, \"\").length;\n    84→  const vowelRatio = vowels / letters.length;\n    85→  if (vowelRatio < 0.15 || vowelRatio > 0.85) return true;\n    86→\n    87→  // Single orphaned word ≤3 letters that isn't a common word\n    88→  const words = text.trim().split(/\\s+/);\n    89→  const COMMON_SHORT = new Set([\n    90→    \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"had\", \"her\",\n    91→    \"was\", \"one\", \"our\", \"out\", \"are\", \"has\", \"his\", \"how\", \"its\", \"may\",\n    92→    \"new\", \"now\", \"old\", \"see\", \"way\", \"who\", \"did\", \"get\", \"let\", \"say\",\n    93→    \"she\", \"too\", \"use\",\n    94→  ]);\n    95→  if (words.length === 1 && letters.length <= 3 && !COMMON_SHORT.has(text.trim().toLowerCase())) {\n    96→    return true;\n    97→  }\n    98→\n    99→  // Recipe titles never start with a lowercase letter\n   100→  if (/^[a-z]/.test(text.trim())) {\n   101→    return true;\n   102→  }\n   103→\n   104→  // Mid-text sentence boundary (\". \" followed by a letter) — body text fragment spliced from multiple sentences\n   105→  const trimmed = text.trim();\n   106→  if (/\\.\\s+[a-zA-Z]/.test(trimmed) && !trimmed.endsWith(\")\")) {\n   107→    return true;\n   108→  }\n   109→\n   110→  // Multi-word candidate containing a garbled OCR fragment: a short lowercase word that isn't a known short word\n   111→  if (words.length >= 2) {\n   112→    const commonShort2 = new Set([\n   113→      \"a\", \"i\", \"of\", \"or\", \"to\", \"in\", \"on\", \"is\", \"it\", \"an\",\n   114→      \"as\", \"at\", \"by\", \"do\", \"go\", \"if\", \"no\", \"so\", \"up\", \"we\",\n   115→      \"w\", \"z\",  // Polish prepositions\n   116→    ]);\n   117→    const hasGarbledWord = words.some(\n   118→      (w) =>\n   119→        /^[a-z]/.test(w) &&\n   120→        w.replace(/[^a-z]/g, \"\").length <= 2 &&\n   121→        !commonShort2.has(w.toLowerCase())\n   122→    );\n   123→    if (hasGarbledWord) {\n   124→      return true;\n   125→    }\n   126→  }\n   127→\n   128→  return false;\n   129→}\n   130→\n   131→function passesHardFilters(text: string): boolean {\n   132→  if (text.length < 3 || text.length > 80) return false;\n   133→  if (looksLikeIngredient(text)) return false;\n   134→  if (startsWithNumber(text)) return false;\n   135→  if (looksLikeMetadata(text)) return false;\n   136→  if (isLikelyGarbled(text)) return false;\n   137→  // Single-word non-title fragments\n   138→  const words = text.trim().split(/\\s+/);\n   139→  if (words.length === 1 && NON_TITLE_WORDS.has(text.trim().toLowerCase())) return false;\n   140→  return true;\n   141→}\n   142→\n   143→/**\n   144→ * Detect initial burst of short garbled lines.\n   145→ * Returns the index of the first non-garbled or long line.\n   146→ */\n   147→function findBurstEnd(lines: Array<{ text: string }>): number {\n   148→  let i = 0;\n   149→  while (i < lines.length && lines[i].text.length < 20 && isLikelyGarbled(lines[i].text)) {\n   150→    i++;"}]},"parent_tool_use_id":"toolu_014SMcitGhR7RLPNfFUpgyat","session_id":"dda4a6e7-7d44-4b1e-8d84-edc63f9f063b","uuid":"61b548c8-374a-4f8a-a1be-d8ad23343fdd"}
