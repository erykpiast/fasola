{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016JorNL2JdmG8hCQnvt6SSh","type":"tool_result","content":"     1→/**\n     2→ * Title Extraction\n     3→ * Extracts potential recipe title from OCR text using heuristics or semantic embeddings\n     4→ */\n     5→\n     6→import { cosineSimilarity } from \"./embeddings\";\n     7→\n     8→export type EmbedFn = (text: string) => Promise<Array<number>>;\n     9→\n    10→const TITLE_REFERENCE =\n    11→  \"recipe name, dish title, name of the food, nazwa przepisu, nazwa dania\";\n    12→const HEADER_REFERENCE =\n    13→  \"ingredients list, cooking directions, section heading, składniki, przygotowanie, sposób wykonania\";\n    14→const NOISE_REFERENCE =\n    15→  \"page number, table of contents, book footer, garbled text\";\n    16→\n    17→/**\n    18→ * Measurement units commonly found in ingredient lists\n    19→ */\n    20→const MEASUREMENT_PATTERNS = [\n    21→  \"cup\",\n    22→  \"cups\",\n    23→  \"tbsp\",\n    24→  \"tsp\",\n    25→  \"tablespoon\",\n    26→  \"teaspoon\",\n    27→  \"oz\",\n    28→  \"lb\",\n    29→  \"gram\",\n    30→  \"grams\",\n    31→  \"kg\",\n    32→  \"ml\",\n    33→  \"liter\",\n    34→  \"pinch\",\n    35→  \"dash\",\n    36→  \"handful\",\n    37→];\n    38→\n    39→/**\n    40→ * Patterns that identify recipe metadata lines (not titles)\n    41→ */\n    42→const METADATA_PATTERNS = [\n    43→  /^(SERVES?|MAKES?|YIELDS?)\\b/i,\n    44→  /^(PREP(ARATION)?|COOK(ING)?|PROOF|RISING|FERMENTATION|REST(ING)?)\\s*(AND\\s*)?(COOK(ING)?)?\\s*TIME/i,\n    45→  /^SAMPLE\\s+SCHEDULE\\b/i,\n    46→  /^BULK\\s+FERMENTATION\\b/i,\n    47→  /^(THIS\\s+RECIPE\\s+)?MAKES\\b/i,\n    48→];\n    49→\n    50→/**\n    51→ * Single-word non-title words — standalone OCR fragments unlikely to be recipe titles\n    52→ */\n    53→const NON_TITLE_WORDS = new Set([\n    54→  \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"are\", \"was\",\n    55→  \"has\", \"his\", \"her\", \"its\", \"our\", \"who\", \"how\", \"may\", \"new\", \"now\",\n    56→  \"old\", \"see\", \"way\", \"did\", \"get\", \"let\", \"say\", \"she\", \"too\", \"use\",\n    57→  \"buns\", \"with\",\n    58→]);\n    59→\n    60→function looksLikeIngredient(line: string): boolean {\n    61→  const lowerLine = line.toLowerCase();\n    62→  return MEASUREMENT_PATTERNS.some((pattern) => lowerLine.includes(pattern));\n    63→}\n    64→\n    65→function startsWithNumber(line: string): boolean {\n    66→  return /^\\s*\\d/.test(line);\n    67→}\n    68→\n    69→function isAllCaps(line: string): boolean {\n    70→  const letters = line.replace(/[^a-zA-Z]/g, \"\");\n    71→  return letters.length > 0 && letters === letters.toUpperCase();\n    72→}\n    73→\n    74→function looksLikeMetadata(text: string): boolean {\n    75→  return METADATA_PATTERNS.some((pattern) => pattern.test(text.trim()));\n    76→}\n    77→\n    78→function isLikelyGarbled(text: string): boolean {\n    79→  const letters = text.replace(/[^a-zA-Z]/g, \"\");\n    80→  if (letters.length < 2) return true;\n    81→\n    82→  // Check vowel ratio — English/Polish text typically has 30–50% vowels\n    83→  const vowels = letters.replace(/[^aeiouAEIOUyYąęóĄĘÓ]/g, \"\").length;\n    84→  const vowelRatio = vowels / letters.length;\n    85→  if (vowelRatio < 0.15 || vowelRatio > 0.85) return true;\n    86→\n    87→  // Single orphaned word ≤3 letters that isn't a common word\n    88→  const words = text.trim().split(/\\s+/);\n    89→  const COMMON_SHORT = new Set([\n    90→    \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"had\", \"her\",\n    91→    \"was\", \"one\", \"our\", \"out\", \"are\", \"has\", \"his\", \"how\", \"its\", \"may\",\n    92→    \"new\", \"now\", \"old\", \"see\", \"way\", \"who\", \"did\", \"get\", \"let\", \"say\",\n    93→    \"she\", \"too\", \"use\",\n    94→  ]);\n    95→  if (words.length === 1 && letters.length <= 3 && !COMMON_SHORT.has(text.trim().toLowerCase())) {\n    96→    return true;\n    97→  }\n    98→\n    99→  // Recipe titles never start with a lowercase letter\n   100→  if (/^[a-z]/.test(text.trim())) {\n   101→    return true;\n   102→  }\n   103→\n   104→  // Mid-text sentence boundary (\". \" followed by a letter) — body text fragment spliced from multiple sentences\n   105→  const trimmed = text.trim();\n   106→  if (/\\.\\s+[a-zA-Z]/.test(trimmed) && !trimmed.endsWith(\")\")) {\n   107→    return true;\n   108→  }\n   109→\n   110→  // Multi-word candidate containing a garbled OCR fragment: a short lowercase word that isn't a known short word\n   111→  if (words.length >= 2) {\n   112→    const commonShort2 = new Set([\n   113→      \"a\", \"i\", \"of\", \"or\", \"to\", \"in\", \"on\", \"is\", \"it\", \"an\",\n   114→      \"as\", \"at\", \"by\", \"do\", \"go\", \"if\", \"no\", \"so\", \"up\", \"we\",\n   115→      \"w\", \"z\",  // Polish prepositions\n   116→    ]);\n   117→    const hasGarbledWord = words.some(\n   118→      (w) =>\n   119→        /^[a-z]/.test(w) &&\n   120→        w.replace(/[^a-z]/g, \"\").length <= 2 &&\n   121→        !commonShort2.has(w.toLowerCase())\n   122→    );\n   123→    if (hasGarbledWord) {\n   124→      return true;\n   125→    }\n   126→  }\n   127→\n   128→  return false;\n   129→}\n   130→\n   131→function passesHardFilters(text: string): boolean {\n   132→  if (text.length < 3 || text.length > 80) return false;\n   133→  if (looksLikeIngredient(text)) return false;\n   134→  if (startsWithNumber(text)) return false;\n   135→  if (looksLikeMetadata(text)) return false;\n   136→  if (isLikelyGarbled(text)) return false;\n   137→  // Single-word non-title fragments\n   138→  const words = text.trim().split(/\\s+/);\n   139→  if (words.length === 1 && NON_TITLE_WORDS.has(text.trim().toLowerCase())) return false;\n   140→  return true;\n   141→}\n   142→\n   143→/**\n   144→ * Detect initial burst of short garbled lines.\n   145→ * Returns the index of the first non-garbled or long line.\n   146→ */\n   147→function findBurstEnd(lines: Array<{ text: string }>): number {\n   148→  let i = 0;\n   149→  while (i < lines.length && lines[i].text.length < 20 && isLikelyGarbled(lines[i].text)) {\n   150→    i++;\n   151→  }\n   152→  return i;\n   153→}\n   154→\n   155→function wordCount(text: string): number {\n   156→  return text.split(/\\s+/).filter((w) => w.length > 0).length;\n   157→}\n   158→\n   159→/**\n   160→ * Build candidate strings from lines: single lines plus multi-line joins (2-3 consecutive).\n   161→ * Skips initial burst of short garbled lines. Scans all remaining lines. Caps at 25.\n   162→ */\n   163→export type CandidateOrigin = \"single\" | \"2-line\" | \"3-line\";\n   164→\n   165→function buildCandidates(\n   166→  lines: Array<string>\n   167→): Array<{ text: string; position: number; origin: CandidateOrigin }> {\n   168→  const nonEmptyLines: Array<{ text: string; index: number }> = [];\n   169→\n   170→  for (let i = 0; i < lines.length; i++) {\n   171→    const trimmed = lines[i].trim();\n   172→    if (trimmed.length > 0) {\n   173→      nonEmptyLines.push({ text: trimmed, index: i });\n   174→    }\n   175→  }\n   176→\n   177→  const burstEnd = findBurstEnd(nonEmptyLines);\n   178→\n   179→  // Pre-merge continuation lines: a line starting with /&+:( is never a standalone title.\n   180→  // Merge it into the preceding line so the complete title enters the pool as a single candidate,\n   181→  // avoiding the fragile chain of conditions required by the downstream join survival logic.\n   182→  // Limitation: only one continuation line per preceding line is merged. Titles split across\n   183→  // three or more lines with continuation tokens (rare in practice) are not handled here —\n   184→  // the downstream 2-line and 3-line join candidates cover those cases instead.\n   185→  const mergedLines: Array<{ text: string; index: number }> = [];\n   186→  for (let i = burstEnd; i < nonEmptyLines.length; i++) {\n   187→    const line = nonEmptyLines[i];\n   188→    if (i + 1 < nonEmptyLines.length) {\n   189→      const nextText = nonEmptyLines[i + 1].text;\n   190→      if (/^[/&+:(]/.test(nextText)) {\n   191→        mergedLines.push({ text: `${line.text} ${nextText}`, index: line.index });\n   192→        i++;\n   193→        continue;\n   194→      }\n   195→    }\n   196→    mergedLines.push(line);\n   197→  }\n   198→\n   199→  const candidates: Array<{ text: string; position: number; origin: CandidateOrigin }> = [];\n   200→  const seen = new Set<string>();\n   201→\n   202→  for (let i = 0; i < mergedLines.length; i++) {\n   203→    const line = mergedLines[i];\n   204→\n   205→    // Single line\n   206→    if (passesHardFilters(line.text)) {\n   207→      const norm = line.text.toLowerCase();\n   208→      if (!seen.has(norm)) {\n   209→        seen.add(norm);\n   210→        candidates.push({ text: line.text, position: line.index, origin: \"single\" });\n   211→      }\n   212→    }\n   213→\n   214→    // 2-line join\n   215→    if (i + 1 < mergedLines.length) {\n   216→      const joined2 = `${line.text} ${mergedLines[i + 1].text}`;\n   217→      if (passesHardFilters(joined2)) {\n   218→        const norm = joined2.toLowerCase();\n   219→        if (!seen.has(norm)) {\n   220→          seen.add(norm);\n   221→          candidates.push({ text: joined2, position: line.index, origin: \"2-line\" });\n   222→        }\n   223→      }\n   224→    }\n   225→\n   226→    // 3-line join\n   227→    if (i + 2 < mergedLines.length) {\n   228→      const joined3 = `${line.text} ${mergedLines[i + 1].text} ${mergedLines[i + 2].text}`;\n   229→      if (passesHardFilters(joined3)) {\n   230→        const norm = joined3.toLowerCase();\n   231→        if (!seen.has(norm)) {\n   232→          seen.add(norm);\n   233→          candidates.push({ text: joined3, position: line.index, origin: \"3-line\" });\n   234→        }\n   235→      }\n   236→    }\n   237→  }\n   238→\n   239→  // Pre-filter to 25 before embedding calls: prefer ALL_CAPS and short candidates.\n   240→  // Position-based scoring handles final ranking.\n   241→  if (candidates.length > 25) {\n   242→    const prioritized = candidates.slice().sort((a, b) => {\n   243→      const aAllCaps = isAllCaps(a.text) ? 0 : 1;\n   244→      const bAllCaps = isAllCaps(b.text) ? 0 : 1;\n   245→      if (aAllCaps !== bAllCaps) return aAllCaps - bAllCaps;\n   246→      const aShort = wordCount(a.text) <= 5 ? 0 : 1;\n   247→      const bShort = wordCount(b.text) <= 5 ? 0 : 1;\n   248→      return aShort - bShort;\n   249→    });\n   250→    return prioritized.slice(0, 25);\n   251→  }\n   252→\n   253→  return candidates;\n   254→}\n   255→\n   256→// Module-level cache for reference embeddings\n   257→let cachedTitleRefEmbedding: Array<number> | null = null;\n   258→let cachedHeaderRefEmbedding: Array<number> | null = null;\n   259→let cachedNoiseRefEmbedding: Array<number> | null = null;\n   260→\n   261→export function _resetEmbeddingCacheForTests(): void {\n   262→  cachedTitleRefEmbedding = null;\n   263→  cachedHeaderRefEmbedding = null;\n   264→  cachedNoiseRefEmbedding = null;\n   265→}\n   266→\n   267→export async function extractTitleWithEmbeddings(\n   268→  text: string,\n   269→  embed: EmbedFn\n   270→): Promise<string | undefined> {\n   271→  if (!text || text.trim().length === 0) {\n   272→    return undefined;\n   273→  }\n   274→\n   275→  const lines = text.split(\"\\n\");\n   276→  const candidates = buildCandidates(lines);\n   277→\n   278→  if (candidates.length === 0) {\n   279→    return undefined;\n   280→  }\n   281→\n   282→  // Cache reference embeddings\n   283→  if (!cachedTitleRefEmbedding) {\n   284→    cachedTitleRefEmbedding = await embed(TITLE_REFERENCE);\n   285→  }\n   286→  if (!cachedHeaderRefEmbedding) {\n   287→    cachedHeaderRefEmbedding = await embed(HEADER_REFERENCE);\n   288→  }\n   289→  if (!cachedNoiseRefEmbedding) {\n   290→    cachedNoiseRefEmbedding = await embed(NOISE_REFERENCE);\n   291→  }\n   292→\n   293→  // Find ALL_CAPS candidates with ≥2 words where every significant word has ≥4 alpha letters.\n   294→  // Insignificant tokens (≤1 alpha letter: \"/\", \"&\", \"+\", \":\", \"D)\", etc.) are filtered before\n   295→  // the check so that multi-line joins with continuation punctuation still qualify.\n   296→  const isStructuralHeading = (c: { text: string }): boolean => {\n   297→    if (!isAllCaps(c.text) || wordCount(c.text) < 2) return false;\n   298→    const sigWords = c.text.trim().split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length > 1);\n   299→    return sigWords.length >= 2 && sigWords.every((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   300→  };\n   301→\n   302→  // Pass 1: compute rawScore for all candidates (embedding quality signal)\n   303→  const rawScored: Array<{ text: string; position: number; origin: CandidateOrigin; rawScore: number; embedding: Array<number> }> = [];\n   304→  for (const candidate of candidates) {\n   305→    const embedding = await embed(candidate.text);\n   306→    const titleSim = cosineSimilarity(embedding, cachedTitleRefEmbedding);\n   307→    const headerSim = cosineSimilarity(embedding, cachedHeaderRefEmbedding);\n   308→    const noiseSim = cosineSimilarity(embedding, cachedNoiseRefEmbedding);\n   309→    const rawScore = titleSim - Math.max(headerSim, noiseSim);\n   310→    rawScored.push({ text: candidate.text, position: candidate.position, origin: candidate.origin, rawScore, embedding });\n   311→  }\n   312→\n   313→  // Select baseHeading by embedding quality (rawScore), not position.\n   314→  // This prevents OCR-garbled fragments from claiming the structural heading slot.\n   315→  const structuralCandidates = rawScored.filter((s) => isStructuralHeading(s));\n   316→\n   317→  // Penalize structural headings with truncated OCR words:\n   318→  // if \"FRON\" appears and another heading has \"SAFFRON\", \"FRON\" is likely garbled.\n   319→  for (const sc of structuralCandidates) {\n   320→    const sigWords = sc.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   321→    for (const other of structuralCandidates) {\n   322→      if (other === sc) continue;\n   323→      const otherSigWords = other.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n   324→      const hasTruncation = sigWords.some((w) =>\n   325→        otherSigWords.some((ow) => ow !== w && ow.length > w.length && ow.endsWith(w))\n   326→      );\n   327→      if (hasTruncation) {\n   328→        sc.rawScore = -1.0;  // Hard disqualification — truncated OCR artifact\n   329→        break;\n   330→      }\n   331→    }\n   332→  }\n   333→\n   334→  const bestStructural = structuralCandidates.length > 0\n   335→    ? structuralCandidates.reduce((a, b) => a.rawScore > b.rawScore ? a : b)\n   336→    : null;\n   337→  const baseHeading = bestStructural ?? undefined;\n   338→\n   339→  // When the best structural heading has a continuation on the next line introduced by a\n   340→  // punctuation token (/, &, +, :, or parenthesis), prefer the longer 2-line join as the\n   341→  // complete heading. E.g. \"SAFFRON WHEAT BUNS WITH QUARK\" + \"/ COTTAGE CHEESE (VARIATION D)\".\n   342→  // Guard: the remainder after the prefix must start with a continuation character to avoid\n   343→  // merging two separate consecutive recipe titles (FINNISH MILK FLATBREADS stays separate\n   344→  // from FINNISH POTATO FLATBREADS because \"FINNISH\" does not start with a continuation token).\n   345→  const firstStructuralHeading = baseHeading && (\n   346→    rawScored.find((c) => {\n   347→      if (!isStructuralHeading(c)) return false;\n   348→      const hLower = baseHeading.text.toLowerCase();\n   349→      const cLower = c.text.toLowerCase();\n   350→      return cLower.startsWith(hLower + \" \") && /^[/&+:(]/.test(cLower.slice(hLower.length + 1));\n   351→    }) ?? baseHeading\n   352→  );\n   353→\n   354→  // Pass 2: apply bonuses\n   355→  const scored: Array<{ text: string; position: number; origin: CandidateOrigin; score: number; rawScore: number; baseScore: number; thresholdScore: number }> = rawScored.map((rs) => {\n   356→    // Position factor: multiplicative tiebreaker — amplifies existing signal, doesn't replace it\n   357→    const relativePosition = rs.position / lines.length;\n   358→    const positionFactor = relativePosition < 0.5\n   359→      ? 1.0 + 0.12 * (1 - relativePosition * 2)\n   360→      : 1.0;\n   361→\n   362→    // ALL_CAPS bonus: recipe books use ALL_CAPS for titles and section headings\n   363→    const allCapsBonus = isAllCaps(rs.text) && rs.text.replace(/[^a-zA-Z]/g, \"\").length >= 4\n   364→      ? 0.08\n   365→      : 0;\n   366→\n   367→    // Structural heading bonus: best ALL_CAPS heading (or its continuation join) is almost always the recipe title\n   368→    const structuralBonus = firstStructuralHeading && rs.text === firstStructuralHeading.text ? 0.10 : 0;\n   369→\n   370→    // thresholdScore excludes structural bonus so the bonus doesn't inflate the threshold\n   371→    // and prevent equally-valid structural headings from passing on multi-recipe pages.\n   372→    const thresholdScore = rs.rawScore + allCapsBonus;\n   373→    // baseScore excludes position factor — used for diagnostics and ranking\n   374→    const baseScore = rs.rawScore + allCapsBonus + structuralBonus;\n   375→    const score = rs.rawScore * positionFactor + allCapsBonus + structuralBonus;\n   376→    return { text: rs.text, position: rs.position, origin: rs.origin, score, rawScore: rs.rawScore, baseScore, thresholdScore };\n   377→  });\n   378→\n   379→  if (scored.length === 0) {\n   380→    return undefined;\n   381→  }\n   382→\n   383→  // --- Pre-threshold bilingual title detection ---\n   384→  // When a mixed-case candidate at position 0 is followed by a single ALL_CAPS\n   385→  // candidate at position ≤ 2 in the FULL scored pool, this is a bilingual recipe\n   386→  // page (e.g., Polish title + ALL_CAPS Korean romanization). Suppress the ALL_CAPS\n   387→  // candidate before computing threshold so its bonuses don't inflate the threshold\n   388→  // beyond the mixed-case title's reach.\n   389→  let scoredForThreshold = scored;\n   390→  const prePos0 = scored.find((s) => s.position === 0 && !isAllCaps(s.text));\n   391→  const preAllCaps = scored.filter((s) => isAllCaps(s.text));\n   392→  if (prePos0 && preAllCaps.length === 1 && preAllCaps[0].position <= 2) {\n   393→    const capsLower = preAllCaps[0].text.toLowerCase();\n   394→    scoredForThreshold = scored.filter((s) => !s.text.toLowerCase().startsWith(capsLower));\n   395→  }\n   396→\n   397→  // Use thresholdScore (excludes structural bonus) so the structural bonus doesn't inflate\n   398→  // the threshold and block equally-valid headings on multi-recipe pages.\n   399→  const bestThresholdScore = Math.max(...scoredForThreshold.map((s) => s.thresholdScore));\n   400→  const threshold = Math.max(0.08, bestThresholdScore * 0.7);\n   401→\n   402→  // Filter candidates above threshold\n   403→  let selected = scoredForThreshold.filter((s) => s.score >= threshold);\n   404→\n   405→  // Empty-pool fallback: when threshold filtering discards every candidate,\n   406→  // the hard filters' structural verdict should not be overruled by weak\n   407→  // embedding differentiation. Return the best positional candidate.\n   408→  if (selected.length === 0 && scored.length > 0) {\n   409→    const fallback = scored\n   410→      .slice()\n   411→      .sort((a, b) => a.position - b.position || b.score - a.score);\n   412→    selected = [fallback[0]];\n   413→  }\n   414→\n   415→  // Remove word-boundary prefixes of firstStructuralHeading when the heading itself survived\n   416→  // the threshold. Cases:\n   417→  //   ARAYES case:  firstStructuralHeading = \"ARAYES SHRAK\" (2-word join qualifies; \"ARAYES\"\n   418→  //     alone = 1 word, so it never qualified). Filter removes \"ARAYES\" so dedup keeps the join.\n   419→  //   SAFFRON case: baseHeading was the partial line; continuation logic above upgraded\n   420→  //     firstStructuralHeading to the full join. Filter removes the partial so dedup keeps join.\n   421→  // Safety: only fires when the complete heading itself is in selected (passed the threshold).\n   422→  if (firstStructuralHeading && selected.some((s) => s.text === firstStructuralHeading.text)) {\n   423→    const fshLower = firstStructuralHeading.text.toLowerCase();\n   424→    selected = selected.filter((s) => {\n   425→      if (s.text === firstStructuralHeading.text) return true;\n   426→      const sLower = s.text.toLowerCase();\n   427→      // Remove s if it is a space-delimited prefix of the structural heading\n   428→      return !fshLower.startsWith(sLower + \" \");\n   429→    });\n   430→  }\n   431→\n   432→  // Protect continuation joins: when a multi-line join (2-line or 3-line) survived the threshold\n   433→  // and its second part starts with a continuation character, remove the single-line prefix/suffix\n   434→  // so the dedup \"shorter wins\" rule doesn't destroy the complete join.\n   435→  // Note: the pre-merge step above already handles the common Baked Eggs case (&/continuation\n   436→  // on next line) by turning it into a single candidate — this block covers the rarer case where\n   437→  // a continuation-character join was generated as a 2-line/3-line candidate and the prefix\n   438→  // single also survived threshold independently (e.g. from a different code path or OCR layout).\n   439→  // Safety: only fires for joins whose continuation starts with /&+:( — digit continuations\n   440→  // like \"Pierogi Ruskie 200g mąki\" are NOT protected, so dedup correctly keeps the shorter form.\n   441→  const survivingJoins = selected.filter((s) => s.origin === \"2-line\" || s.origin === \"3-line\");\n   442→  if (survivingJoins.length > 0) {\n   443→    selected = selected.filter((s) => {\n   444→      if (s.origin !== \"single\") return true;\n   445→      const sLower = s.text.toLowerCase();\n   446→      // Remove PREFIX singles whose continuation join also survived\n   447→      const isPrefixOfJoin = survivingJoins.some((j) => {\n   448→        const jLower = j.text.toLowerCase();\n   449→        if (!jLower.startsWith(sLower + \" \")) return false;\n   450→        const remainder = jLower.slice(sLower.length + 1);\n   451→        return /^[/&+:(]/.test(remainder);\n   452→      });\n   453→      if (isPrefixOfJoin) return false;\n   454→      // Remove SUFFIX singles (e.g. \"& Coriander\") whose parent join also survived\n   455→      const isSuffixOfJoin = survivingJoins.some((j) => {\n   456→        const jLower = j.text.toLowerCase();\n   457→        if (!jLower.endsWith(\" \" + sLower)) return false;\n   458→        // Only remove if the suffix starts with a continuation character\n   459→        return /^[/&+:(]/.test(sLower);\n   460→      });\n   461→      if (isSuffixOfJoin) return false;\n   462→      return true;\n   463→    });\n   464→  }\n   465→\n   466→  // Deduplicate: if one title is a substring of another, keep the shorter (more focused) one.\n   467→  // DO NOT CHANGE THIS LOGIC — it has been incorrectly \"improved\" by the title-loop 5 times.\n   468→  // The tests require shorter wins: \"Pierogi Ruskie\" over \"Pierogi Ruskie 200g mąki 3 ziemniaki\".\n   469→  // The pre-filter above handles the conflicting case (structural heading prefix removal) so that\n   470→  // the incomplete prefix line is never present here when the complete join is in selected.\n   471→  selected = selected.filter((a) => {\n   472→    const aLower = a.text.toLowerCase();\n   473→    return !selected.some(\n   474→      (b) =>\n   475→        b !== a &&\n   476→        aLower.includes(b.text.toLowerCase()) &&\n   477→        b.text.length < a.text.length\n   478→    );\n   479→  });\n   480→\n   481→  // Multi-title guard: only join multiple candidates with \"+\" when there is\n   482→  // structural evidence of a multi-recipe page (≥2 ALL_CAPS headings).\n   483→  // A single ALL_CAPS title among mixed-case survivors is a single-recipe page —\n   484→  // collapse to the highest-scoring candidate.\n   485→  // Zero ALL_CAPS survivors → mixed-case multi-title page → keep all.\n   486→  if (selected.length > 1) {\n   487→    const allCapsSelected = selected.filter((s) => isAllCaps(s.text));\n   488→    if (allCapsSelected.length >= 2) {\n   489→      // Check whether non-first ALL_CAPS headings are section headers within one recipe\n   490→      // (followed immediately by ingredient-like content) rather than separate recipe titles.\n   491→      // A multi-recipe page has body text between titles; a single-recipe page has\n   492→      // ingredient lines immediately after each section heading.\n   493→      const sortedCaps = [...allCapsSelected].sort((a, b) => a.position - b.position);\n   494→      const isSubHeader = sortedCaps.slice(1).every((cap) => {\n   495→        const nextLines = lines.slice(cap.position + 1, cap.position + 3);\n   496→        return nextLines.some(\n   497→          (l) => looksLikeIngredient(l.trim()) || /^\\s*\\d/.test(l.trim())\n   498→        );\n   499→      });\n   500→      if (isSubHeader) {\n   501→        selected = [sortedCaps[0]];\n   502→      } else {\n   503→        selected = allCapsSelected;\n   504→      }\n   505→    } else if (allCapsSelected.length === 1) {\n   506→      selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n   507→    }\n   508→  }\n   509→\n   510→  // Cap at 3, sort by document position\n   511→  selected.sort((a, b) => a.position - b.position);\n   512→  selected = selected.slice(0, 3);\n   513→\n   514→  if (selected.length === 0) {\n   515→    return undefined;\n   516→  }\n   517→\n   518→  return selected.map((s) => s.text).join(\" + \");\n   519→}\n   520→\n   521→/**\n   522→ * Extract potential recipe title from OCR text (sync heuristic fallback)\n   523→ */\n   524→export function extractTitle(text: string): string | undefined {\n   525→  if (!text || text.trim().length === 0) {\n   526→    return undefined;\n   527→  }\n   528→\n   529→  const lines = text.split(\"\\n\").map((line) => line.trim());\n   530→\n   531→  for (const line of lines) {\n   532→    if (line.length === 0) continue;\n   533→    if (line.length < 3 || line.length > 50) continue;\n   534→    if (looksLikeIngredient(line)) continue;\n   535→    if (isAllCaps(line)) continue;\n   536→    if (startsWithNumber(line)) continue;\n   537→    return line;\n   538→  }\n   539→\n   540→  return undefined;\n   541→}\n   542→"}]},"parent_tool_use_id":null,"session_id":"688165a7-dc9e-4c33-9dca-71554537d527","uuid":"57930f32-4ff8-43d5-ad64-26717a8bed7c","tool_use_result":{"type":"text","file":{"filePath":"/Users/eryk.napierala/Projects/fasola/lib/text-classifier/title-extractor.ts","content":"/**\n * Title Extraction\n * Extracts potential recipe title from OCR text using heuristics or semantic embeddings\n */\n\nimport { cosineSimilarity } from \"./embeddings\";\n\nexport type EmbedFn = (text: string) => Promise<Array<number>>;\n\nconst TITLE_REFERENCE =\n  \"recipe name, dish title, name of the food, nazwa przepisu, nazwa dania\";\nconst HEADER_REFERENCE =\n  \"ingredients list, cooking directions, section heading, składniki, przygotowanie, sposób wykonania\";\nconst NOISE_REFERENCE =\n  \"page number, table of contents, book footer, garbled text\";\n\n/**\n * Measurement units commonly found in ingredient lists\n */\nconst MEASUREMENT_PATTERNS = [\n  \"cup\",\n  \"cups\",\n  \"tbsp\",\n  \"tsp\",\n  \"tablespoon\",\n  \"teaspoon\",\n  \"oz\",\n  \"lb\",\n  \"gram\",\n  \"grams\",\n  \"kg\",\n  \"ml\",\n  \"liter\",\n  \"pinch\",\n  \"dash\",\n  \"handful\",\n];\n\n/**\n * Patterns that identify recipe metadata lines (not titles)\n */\nconst METADATA_PATTERNS = [\n  /^(SERVES?|MAKES?|YIELDS?)\\b/i,\n  /^(PREP(ARATION)?|COOK(ING)?|PROOF|RISING|FERMENTATION|REST(ING)?)\\s*(AND\\s*)?(COOK(ING)?)?\\s*TIME/i,\n  /^SAMPLE\\s+SCHEDULE\\b/i,\n  /^BULK\\s+FERMENTATION\\b/i,\n  /^(THIS\\s+RECIPE\\s+)?MAKES\\b/i,\n];\n\n/**\n * Single-word non-title words — standalone OCR fragments unlikely to be recipe titles\n */\nconst NON_TITLE_WORDS = new Set([\n  \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"are\", \"was\",\n  \"has\", \"his\", \"her\", \"its\", \"our\", \"who\", \"how\", \"may\", \"new\", \"now\",\n  \"old\", \"see\", \"way\", \"did\", \"get\", \"let\", \"say\", \"she\", \"too\", \"use\",\n  \"buns\", \"with\",\n]);\n\nfunction looksLikeIngredient(line: string): boolean {\n  const lowerLine = line.toLowerCase();\n  return MEASUREMENT_PATTERNS.some((pattern) => lowerLine.includes(pattern));\n}\n\nfunction startsWithNumber(line: string): boolean {\n  return /^\\s*\\d/.test(line);\n}\n\nfunction isAllCaps(line: string): boolean {\n  const letters = line.replace(/[^a-zA-Z]/g, \"\");\n  return letters.length > 0 && letters === letters.toUpperCase();\n}\n\nfunction looksLikeMetadata(text: string): boolean {\n  return METADATA_PATTERNS.some((pattern) => pattern.test(text.trim()));\n}\n\nfunction isLikelyGarbled(text: string): boolean {\n  const letters = text.replace(/[^a-zA-Z]/g, \"\");\n  if (letters.length < 2) return true;\n\n  // Check vowel ratio — English/Polish text typically has 30–50% vowels\n  const vowels = letters.replace(/[^aeiouAEIOUyYąęóĄĘÓ]/g, \"\").length;\n  const vowelRatio = vowels / letters.length;\n  if (vowelRatio < 0.15 || vowelRatio > 0.85) return true;\n\n  // Single orphaned word ≤3 letters that isn't a common word\n  const words = text.trim().split(/\\s+/);\n  const COMMON_SHORT = new Set([\n    \"the\", \"and\", \"for\", \"but\", \"not\", \"you\", \"all\", \"can\", \"had\", \"her\",\n    \"was\", \"one\", \"our\", \"out\", \"are\", \"has\", \"his\", \"how\", \"its\", \"may\",\n    \"new\", \"now\", \"old\", \"see\", \"way\", \"who\", \"did\", \"get\", \"let\", \"say\",\n    \"she\", \"too\", \"use\",\n  ]);\n  if (words.length === 1 && letters.length <= 3 && !COMMON_SHORT.has(text.trim().toLowerCase())) {\n    return true;\n  }\n\n  // Recipe titles never start with a lowercase letter\n  if (/^[a-z]/.test(text.trim())) {\n    return true;\n  }\n\n  // Mid-text sentence boundary (\". \" followed by a letter) — body text fragment spliced from multiple sentences\n  const trimmed = text.trim();\n  if (/\\.\\s+[a-zA-Z]/.test(trimmed) && !trimmed.endsWith(\")\")) {\n    return true;\n  }\n\n  // Multi-word candidate containing a garbled OCR fragment: a short lowercase word that isn't a known short word\n  if (words.length >= 2) {\n    const commonShort2 = new Set([\n      \"a\", \"i\", \"of\", \"or\", \"to\", \"in\", \"on\", \"is\", \"it\", \"an\",\n      \"as\", \"at\", \"by\", \"do\", \"go\", \"if\", \"no\", \"so\", \"up\", \"we\",\n      \"w\", \"z\",  // Polish prepositions\n    ]);\n    const hasGarbledWord = words.some(\n      (w) =>\n        /^[a-z]/.test(w) &&\n        w.replace(/[^a-z]/g, \"\").length <= 2 &&\n        !commonShort2.has(w.toLowerCase())\n    );\n    if (hasGarbledWord) {\n      return true;\n    }\n  }\n\n  return false;\n}\n\nfunction passesHardFilters(text: string): boolean {\n  if (text.length < 3 || text.length > 80) return false;\n  if (looksLikeIngredient(text)) return false;\n  if (startsWithNumber(text)) return false;\n  if (looksLikeMetadata(text)) return false;\n  if (isLikelyGarbled(text)) return false;\n  // Single-word non-title fragments\n  const words = text.trim().split(/\\s+/);\n  if (words.length === 1 && NON_TITLE_WORDS.has(text.trim().toLowerCase())) return false;\n  return true;\n}\n\n/**\n * Detect initial burst of short garbled lines.\n * Returns the index of the first non-garbled or long line.\n */\nfunction findBurstEnd(lines: Array<{ text: string }>): number {\n  let i = 0;\n  while (i < lines.length && lines[i].text.length < 20 && isLikelyGarbled(lines[i].text)) {\n    i++;\n  }\n  return i;\n}\n\nfunction wordCount(text: string): number {\n  return text.split(/\\s+/).filter((w) => w.length > 0).length;\n}\n\n/**\n * Build candidate strings from lines: single lines plus multi-line joins (2-3 consecutive).\n * Skips initial burst of short garbled lines. Scans all remaining lines. Caps at 25.\n */\nexport type CandidateOrigin = \"single\" | \"2-line\" | \"3-line\";\n\nfunction buildCandidates(\n  lines: Array<string>\n): Array<{ text: string; position: number; origin: CandidateOrigin }> {\n  const nonEmptyLines: Array<{ text: string; index: number }> = [];\n\n  for (let i = 0; i < lines.length; i++) {\n    const trimmed = lines[i].trim();\n    if (trimmed.length > 0) {\n      nonEmptyLines.push({ text: trimmed, index: i });\n    }\n  }\n\n  const burstEnd = findBurstEnd(nonEmptyLines);\n\n  // Pre-merge continuation lines: a line starting with /&+:( is never a standalone title.\n  // Merge it into the preceding line so the complete title enters the pool as a single candidate,\n  // avoiding the fragile chain of conditions required by the downstream join survival logic.\n  // Limitation: only one continuation line per preceding line is merged. Titles split across\n  // three or more lines with continuation tokens (rare in practice) are not handled here —\n  // the downstream 2-line and 3-line join candidates cover those cases instead.\n  const mergedLines: Array<{ text: string; index: number }> = [];\n  for (let i = burstEnd; i < nonEmptyLines.length; i++) {\n    const line = nonEmptyLines[i];\n    if (i + 1 < nonEmptyLines.length) {\n      const nextText = nonEmptyLines[i + 1].text;\n      if (/^[/&+:(]/.test(nextText)) {\n        mergedLines.push({ text: `${line.text} ${nextText}`, index: line.index });\n        i++;\n        continue;\n      }\n    }\n    mergedLines.push(line);\n  }\n\n  const candidates: Array<{ text: string; position: number; origin: CandidateOrigin }> = [];\n  const seen = new Set<string>();\n\n  for (let i = 0; i < mergedLines.length; i++) {\n    const line = mergedLines[i];\n\n    // Single line\n    if (passesHardFilters(line.text)) {\n      const norm = line.text.toLowerCase();\n      if (!seen.has(norm)) {\n        seen.add(norm);\n        candidates.push({ text: line.text, position: line.index, origin: \"single\" });\n      }\n    }\n\n    // 2-line join\n    if (i + 1 < mergedLines.length) {\n      const joined2 = `${line.text} ${mergedLines[i + 1].text}`;\n      if (passesHardFilters(joined2)) {\n        const norm = joined2.toLowerCase();\n        if (!seen.has(norm)) {\n          seen.add(norm);\n          candidates.push({ text: joined2, position: line.index, origin: \"2-line\" });\n        }\n      }\n    }\n\n    // 3-line join\n    if (i + 2 < mergedLines.length) {\n      const joined3 = `${line.text} ${mergedLines[i + 1].text} ${mergedLines[i + 2].text}`;\n      if (passesHardFilters(joined3)) {\n        const norm = joined3.toLowerCase();\n        if (!seen.has(norm)) {\n          seen.add(norm);\n          candidates.push({ text: joined3, position: line.index, origin: \"3-line\" });\n        }\n      }\n    }\n  }\n\n  // Pre-filter to 25 before embedding calls: prefer ALL_CAPS and short candidates.\n  // Position-based scoring handles final ranking.\n  if (candidates.length > 25) {\n    const prioritized = candidates.slice().sort((a, b) => {\n      const aAllCaps = isAllCaps(a.text) ? 0 : 1;\n      const bAllCaps = isAllCaps(b.text) ? 0 : 1;\n      if (aAllCaps !== bAllCaps) return aAllCaps - bAllCaps;\n      const aShort = wordCount(a.text) <= 5 ? 0 : 1;\n      const bShort = wordCount(b.text) <= 5 ? 0 : 1;\n      return aShort - bShort;\n    });\n    return prioritized.slice(0, 25);\n  }\n\n  return candidates;\n}\n\n// Module-level cache for reference embeddings\nlet cachedTitleRefEmbedding: Array<number> | null = null;\nlet cachedHeaderRefEmbedding: Array<number> | null = null;\nlet cachedNoiseRefEmbedding: Array<number> | null = null;\n\nexport function _resetEmbeddingCacheForTests(): void {\n  cachedTitleRefEmbedding = null;\n  cachedHeaderRefEmbedding = null;\n  cachedNoiseRefEmbedding = null;\n}\n\nexport async function extractTitleWithEmbeddings(\n  text: string,\n  embed: EmbedFn\n): Promise<string | undefined> {\n  if (!text || text.trim().length === 0) {\n    return undefined;\n  }\n\n  const lines = text.split(\"\\n\");\n  const candidates = buildCandidates(lines);\n\n  if (candidates.length === 0) {\n    return undefined;\n  }\n\n  // Cache reference embeddings\n  if (!cachedTitleRefEmbedding) {\n    cachedTitleRefEmbedding = await embed(TITLE_REFERENCE);\n  }\n  if (!cachedHeaderRefEmbedding) {\n    cachedHeaderRefEmbedding = await embed(HEADER_REFERENCE);\n  }\n  if (!cachedNoiseRefEmbedding) {\n    cachedNoiseRefEmbedding = await embed(NOISE_REFERENCE);\n  }\n\n  // Find ALL_CAPS candidates with ≥2 words where every significant word has ≥4 alpha letters.\n  // Insignificant tokens (≤1 alpha letter: \"/\", \"&\", \"+\", \":\", \"D)\", etc.) are filtered before\n  // the check so that multi-line joins with continuation punctuation still qualify.\n  const isStructuralHeading = (c: { text: string }): boolean => {\n    if (!isAllCaps(c.text) || wordCount(c.text) < 2) return false;\n    const sigWords = c.text.trim().split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length > 1);\n    return sigWords.length >= 2 && sigWords.every((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n  };\n\n  // Pass 1: compute rawScore for all candidates (embedding quality signal)\n  const rawScored: Array<{ text: string; position: number; origin: CandidateOrigin; rawScore: number; embedding: Array<number> }> = [];\n  for (const candidate of candidates) {\n    const embedding = await embed(candidate.text);\n    const titleSim = cosineSimilarity(embedding, cachedTitleRefEmbedding);\n    const headerSim = cosineSimilarity(embedding, cachedHeaderRefEmbedding);\n    const noiseSim = cosineSimilarity(embedding, cachedNoiseRefEmbedding);\n    const rawScore = titleSim - Math.max(headerSim, noiseSim);\n    rawScored.push({ text: candidate.text, position: candidate.position, origin: candidate.origin, rawScore, embedding });\n  }\n\n  // Select baseHeading by embedding quality (rawScore), not position.\n  // This prevents OCR-garbled fragments from claiming the structural heading slot.\n  const structuralCandidates = rawScored.filter((s) => isStructuralHeading(s));\n\n  // Penalize structural headings with truncated OCR words:\n  // if \"FRON\" appears and another heading has \"SAFFRON\", \"FRON\" is likely garbled.\n  for (const sc of structuralCandidates) {\n    const sigWords = sc.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n    for (const other of structuralCandidates) {\n      if (other === sc) continue;\n      const otherSigWords = other.text.split(/\\s+/).filter((w) => w.replace(/[^A-Z]/g, \"\").length >= 4);\n      const hasTruncation = sigWords.some((w) =>\n        otherSigWords.some((ow) => ow !== w && ow.length > w.length && ow.endsWith(w))\n      );\n      if (hasTruncation) {\n        sc.rawScore = -1.0;  // Hard disqualification — truncated OCR artifact\n        break;\n      }\n    }\n  }\n\n  const bestStructural = structuralCandidates.length > 0\n    ? structuralCandidates.reduce((a, b) => a.rawScore > b.rawScore ? a : b)\n    : null;\n  const baseHeading = bestStructural ?? undefined;\n\n  // When the best structural heading has a continuation on the next line introduced by a\n  // punctuation token (/, &, +, :, or parenthesis), prefer the longer 2-line join as the\n  // complete heading. E.g. \"SAFFRON WHEAT BUNS WITH QUARK\" + \"/ COTTAGE CHEESE (VARIATION D)\".\n  // Guard: the remainder after the prefix must start with a continuation character to avoid\n  // merging two separate consecutive recipe titles (FINNISH MILK FLATBREADS stays separate\n  // from FINNISH POTATO FLATBREADS because \"FINNISH\" does not start with a continuation token).\n  const firstStructuralHeading = baseHeading && (\n    rawScored.find((c) => {\n      if (!isStructuralHeading(c)) return false;\n      const hLower = baseHeading.text.toLowerCase();\n      const cLower = c.text.toLowerCase();\n      return cLower.startsWith(hLower + \" \") && /^[/&+:(]/.test(cLower.slice(hLower.length + 1));\n    }) ?? baseHeading\n  );\n\n  // Pass 2: apply bonuses\n  const scored: Array<{ text: string; position: number; origin: CandidateOrigin; score: number; rawScore: number; baseScore: number; thresholdScore: number }> = rawScored.map((rs) => {\n    // Position factor: multiplicative tiebreaker — amplifies existing signal, doesn't replace it\n    const relativePosition = rs.position / lines.length;\n    const positionFactor = relativePosition < 0.5\n      ? 1.0 + 0.12 * (1 - relativePosition * 2)\n      : 1.0;\n\n    // ALL_CAPS bonus: recipe books use ALL_CAPS for titles and section headings\n    const allCapsBonus = isAllCaps(rs.text) && rs.text.replace(/[^a-zA-Z]/g, \"\").length >= 4\n      ? 0.08\n      : 0;\n\n    // Structural heading bonus: best ALL_CAPS heading (or its continuation join) is almost always the recipe title\n    const structuralBonus = firstStructuralHeading && rs.text === firstStructuralHeading.text ? 0.10 : 0;\n\n    // thresholdScore excludes structural bonus so the bonus doesn't inflate the threshold\n    // and prevent equally-valid structural headings from passing on multi-recipe pages.\n    const thresholdScore = rs.rawScore + allCapsBonus;\n    // baseScore excludes position factor — used for diagnostics and ranking\n    const baseScore = rs.rawScore + allCapsBonus + structuralBonus;\n    const score = rs.rawScore * positionFactor + allCapsBonus + structuralBonus;\n    return { text: rs.text, position: rs.position, origin: rs.origin, score, rawScore: rs.rawScore, baseScore, thresholdScore };\n  });\n\n  if (scored.length === 0) {\n    return undefined;\n  }\n\n  // --- Pre-threshold bilingual title detection ---\n  // When a mixed-case candidate at position 0 is followed by a single ALL_CAPS\n  // candidate at position ≤ 2 in the FULL scored pool, this is a bilingual recipe\n  // page (e.g., Polish title + ALL_CAPS Korean romanization). Suppress the ALL_CAPS\n  // candidate before computing threshold so its bonuses don't inflate the threshold\n  // beyond the mixed-case title's reach.\n  let scoredForThreshold = scored;\n  const prePos0 = scored.find((s) => s.position === 0 && !isAllCaps(s.text));\n  const preAllCaps = scored.filter((s) => isAllCaps(s.text));\n  if (prePos0 && preAllCaps.length === 1 && preAllCaps[0].position <= 2) {\n    const capsLower = preAllCaps[0].text.toLowerCase();\n    scoredForThreshold = scored.filter((s) => !s.text.toLowerCase().startsWith(capsLower));\n  }\n\n  // Use thresholdScore (excludes structural bonus) so the structural bonus doesn't inflate\n  // the threshold and block equally-valid headings on multi-recipe pages.\n  const bestThresholdScore = Math.max(...scoredForThreshold.map((s) => s.thresholdScore));\n  const threshold = Math.max(0.08, bestThresholdScore * 0.7);\n\n  // Filter candidates above threshold\n  let selected = scoredForThreshold.filter((s) => s.score >= threshold);\n\n  // Empty-pool fallback: when threshold filtering discards every candidate,\n  // the hard filters' structural verdict should not be overruled by weak\n  // embedding differentiation. Return the best positional candidate.\n  if (selected.length === 0 && scored.length > 0) {\n    const fallback = scored\n      .slice()\n      .sort((a, b) => a.position - b.position || b.score - a.score);\n    selected = [fallback[0]];\n  }\n\n  // Remove word-boundary prefixes of firstStructuralHeading when the heading itself survived\n  // the threshold. Cases:\n  //   ARAYES case:  firstStructuralHeading = \"ARAYES SHRAK\" (2-word join qualifies; \"ARAYES\"\n  //     alone = 1 word, so it never qualified). Filter removes \"ARAYES\" so dedup keeps the join.\n  //   SAFFRON case: baseHeading was the partial line; continuation logic above upgraded\n  //     firstStructuralHeading to the full join. Filter removes the partial so dedup keeps join.\n  // Safety: only fires when the complete heading itself is in selected (passed the threshold).\n  if (firstStructuralHeading && selected.some((s) => s.text === firstStructuralHeading.text)) {\n    const fshLower = firstStructuralHeading.text.toLowerCase();\n    selected = selected.filter((s) => {\n      if (s.text === firstStructuralHeading.text) return true;\n      const sLower = s.text.toLowerCase();\n      // Remove s if it is a space-delimited prefix of the structural heading\n      return !fshLower.startsWith(sLower + \" \");\n    });\n  }\n\n  // Protect continuation joins: when a multi-line join (2-line or 3-line) survived the threshold\n  // and its second part starts with a continuation character, remove the single-line prefix/suffix\n  // so the dedup \"shorter wins\" rule doesn't destroy the complete join.\n  // Note: the pre-merge step above already handles the common Baked Eggs case (&/continuation\n  // on next line) by turning it into a single candidate — this block covers the rarer case where\n  // a continuation-character join was generated as a 2-line/3-line candidate and the prefix\n  // single also survived threshold independently (e.g. from a different code path or OCR layout).\n  // Safety: only fires for joins whose continuation starts with /&+:( — digit continuations\n  // like \"Pierogi Ruskie 200g mąki\" are NOT protected, so dedup correctly keeps the shorter form.\n  const survivingJoins = selected.filter((s) => s.origin === \"2-line\" || s.origin === \"3-line\");\n  if (survivingJoins.length > 0) {\n    selected = selected.filter((s) => {\n      if (s.origin !== \"single\") return true;\n      const sLower = s.text.toLowerCase();\n      // Remove PREFIX singles whose continuation join also survived\n      const isPrefixOfJoin = survivingJoins.some((j) => {\n        const jLower = j.text.toLowerCase();\n        if (!jLower.startsWith(sLower + \" \")) return false;\n        const remainder = jLower.slice(sLower.length + 1);\n        return /^[/&+:(]/.test(remainder);\n      });\n      if (isPrefixOfJoin) return false;\n      // Remove SUFFIX singles (e.g. \"& Coriander\") whose parent join also survived\n      const isSuffixOfJoin = survivingJoins.some((j) => {\n        const jLower = j.text.toLowerCase();\n        if (!jLower.endsWith(\" \" + sLower)) return false;\n        // Only remove if the suffix starts with a continuation character\n        return /^[/&+:(]/.test(sLower);\n      });\n      if (isSuffixOfJoin) return false;\n      return true;\n    });\n  }\n\n  // Deduplicate: if one title is a substring of another, keep the shorter (more focused) one.\n  // DO NOT CHANGE THIS LOGIC — it has been incorrectly \"improved\" by the title-loop 5 times.\n  // The tests require shorter wins: \"Pierogi Ruskie\" over \"Pierogi Ruskie 200g mąki 3 ziemniaki\".\n  // The pre-filter above handles the conflicting case (structural heading prefix removal) so that\n  // the incomplete prefix line is never present here when the complete join is in selected.\n  selected = selected.filter((a) => {\n    const aLower = a.text.toLowerCase();\n    return !selected.some(\n      (b) =>\n        b !== a &&\n        aLower.includes(b.text.toLowerCase()) &&\n        b.text.length < a.text.length\n    );\n  });\n\n  // Multi-title guard: only join multiple candidates with \"+\" when there is\n  // structural evidence of a multi-recipe page (≥2 ALL_CAPS headings).\n  // A single ALL_CAPS title among mixed-case survivors is a single-recipe page —\n  // collapse to the highest-scoring candidate.\n  // Zero ALL_CAPS survivors → mixed-case multi-title page → keep all.\n  if (selected.length > 1) {\n    const allCapsSelected = selected.filter((s) => isAllCaps(s.text));\n    if (allCapsSelected.length >= 2) {\n      // Check whether non-first ALL_CAPS headings are section headers within one recipe\n      // (followed immediately by ingredient-like content) rather than separate recipe titles.\n      // A multi-recipe page has body text between titles; a single-recipe page has\n      // ingredient lines immediately after each section heading.\n      const sortedCaps = [...allCapsSelected].sort((a, b) => a.position - b.position);\n      const isSubHeader = sortedCaps.slice(1).every((cap) => {\n        const nextLines = lines.slice(cap.position + 1, cap.position + 3);\n        return nextLines.some(\n          (l) => looksLikeIngredient(l.trim()) || /^\\s*\\d/.test(l.trim())\n        );\n      });\n      if (isSubHeader) {\n        selected = [sortedCaps[0]];\n      } else {\n        selected = allCapsSelected;\n      }\n    } else if (allCapsSelected.length === 1) {\n      selected = [selected.reduce((a, b) => (a.score > b.score ? a : b))];\n    }\n  }\n\n  // Cap at 3, sort by document position\n  selected.sort((a, b) => a.position - b.position);\n  selected = selected.slice(0, 3);\n\n  if (selected.length === 0) {\n    return undefined;\n  }\n\n  return selected.map((s) => s.text).join(\" + \");\n}\n\n/**\n * Extract potential recipe title from OCR text (sync heuristic fallback)\n */\nexport function extractTitle(text: string): string | undefined {\n  if (!text || text.trim().length === 0) {\n    return undefined;\n  }\n\n  const lines = text.split(\"\\n\").map((line) => line.trim());\n\n  for (const line of lines) {\n    if (line.length === 0) continue;\n    if (line.length < 3 || line.length > 50) continue;\n    if (looksLikeIngredient(line)) continue;\n    if (isAllCaps(line)) continue;\n    if (startsWithNumber(line)) continue;\n    return line;\n  }\n\n  return undefined;\n}\n","numLines":542,"startLine":1,"totalLines":542}}}
